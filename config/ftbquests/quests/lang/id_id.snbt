	file.0000000000000001.title: "All The Mods 10"
	quest.0000A88BB40B2149.quest_desc: ["Sebelum kamu ke Chaos Island sebaiknya persiapan dulu, dia mungkin terlihat seperti Ender Dragon tapi yang ini jauh lebih sulit. Kamu butuh Senjata Draconic atau Tools yang memberikan banyak damage karena itu akan memudahkan. Dia juga akan memberikan damage yang luar biasa banyak, Armor bagus seperti Unobtainium atau Meka-Suit sangat direkomendasikan. (Juga efek Regeneration, Absorption, dan Resistance akan membantumu bertahan hidup). Jangan khawatir kamu selalu bisa kembali untuk bertarung lain hari kalau belum siap."]
	quest.0000A88BB40B2149.title: "Ini berat, kamu perlu persiapan"
	quest.00075A5F9AC120ED.quest_desc: ["Ini akan mengambil item dari peti input (masukan) kamu."]
	quest.00075A5F9AC120ED.quest_subtitle: "Selalu Dibutuhkan"
	quest.000C1ECD781F3F81.quest_desc: ["&2&lNature&r dibuat untuk menggunakan Bumi demi keuntungan kita dengan cara &2Meracuni&r dan &2Melemahkan&r musuh-musuh kita! Sama seperti yang dilakukan Korporasi Besar terhadap Bumi itu sendiri! \\n&2&lNature&r menggunakan &2Poisonous Potato&r sebagai Material Fokusnya. \\n\\n&2Scroll&r-nya berwarna &aHijau Muda&r dengan teks &2Hijau Gelap&r."]
	quest.000C1ECD781F3F81.title: "&2&lNature"
	quest.001A348054127235.quest_desc: ["&5Budding Amethyst&r sangat berguna untuk resep Crafting dan juga untuk menumbuhkan &5Amethyst&r! \\n\\nDengan satu &5Amethyst Block&r, &a60 Eterna&r, antara &c30% &fsampai &c50% Quanta&r, dan &550% Arcana&r, kita bisa melakukan &d&lInfuse&r pada blok tersebut. \\n\\nUntuk mendapatkan statistik tersebut, kita bisa menggunakan 15 &4Glowing Hellshelves&r dan 4 &2Melonshelves&r."]
	quest.001A348054127235.title: "Membuat &5Budding Amethyst"
	quest.001C1881E9289566.quest_desc: ["&9Rare&r adalah tingkatan menengah dalam sistem Rarity. \\n\\nItem ini muncul di semua &lWorld Tier&r, tetapi paling sering ditemukan di &lWorld Tier: &eAscent&r. \\n\\n&9Luminous Crystal Shard&r dibuat dengan menghancurkan &eItem&r &9Rare&r di &c&lSalvaging Table&r."]
	quest.001C1881E9289566.quest_subtitle: "&9Rare"
	quest.001C1881E9289566.title: "&9Luminous Crystal Shard"
	quest.001DE8028CAF0A08.quest_desc: ["Mesin-mesin &5&lMekanism&r bisa jadi sangat berisik! \\n\\nMari kita hentikan itu!"]
	quest.001DE8028CAF0A08.quest_subtitle: "shhhhh... jangan berisik...."
	quest.001DE8028CAF0A08.title: "Muffling &8Upgrade"
	quest.002163B909070CF8.quest_desc: [
		"Memungkinkanmu melihat detail tentang blok/cairan tertentu, bahkan menembus dinding.\\n"
		"{image:atm:textures/questpics/pneumaticcraft/block_tracker.png width:150 height:150 align:center}"
	]
	quest.002163B909070CF8.quest_subtitle: "Maks: 1"
	quest.002B8F2DE2CB4D2C.quest_desc: ["Pegang Shield di off hand dan &7Scroll of Strengthening&r di main hand lalu tahan Right Click."]
	quest.002B8F2DE2CB4D2C.title: "Strong Shield"
	quest.002D65E4D7E8F62B.title: "Katalis Grader Tingkat 2"
	quest.00307A898A639191.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.003AA945CACCD641.quest_subtitle: "Dibuat dengan Offering Table"
	quest.003AA945CACCD641.title: "Bee Of the Depths"
	quest.003FF3813A864BA1.quest_subtitle: "Berikan satu ember (bucket) Strange Matter ke Lava Bee"
	quest.003FF3813A864BA1.title: "Strange Matter Bee"
	quest.00453FF528AA0B1C.quest_desc: ["Lonestar Skeleton adalah Mob yang hostile dan bisa spawn dimana aja. \\n\\nMereka punya 10 Heart dan bakal lempar Pedang mereka ke kamu buat nyerang. \\n\\nKalau mati mereka bisa drop Tulang, Swamp Silver Nugget, Shattered Sword, dan drop yang ditambahin Corail buat Undead Mob."]
	quest.00453FF528AA0B1C.title: "Lonestar Skeleton"
	quest.004D61425172324F.quest_desc: ["&8Chainmail Armor&r sedikit lebih buruk daripada Besi (Iron). Kegunaan utamanya di &l&2Minecraft&r dulunya adalah kelangkaannya, hanya bisa didapat melalui Trading atau drop dari Mob. \\n\\nTentu saja karena ini modded, kita bisa men-craft-nya sekarang! Yang sebenarnya malah menghilangkan nilai eksklusifnya..."]
	quest.004D61425172324F.quest_subtitle: "12"
	quest.004D61425172324F.title: "&8Chainmail Armor"
	quest.0052E5592A6BBEC1.quest_desc: [
		"Ini adalah &2&lMinecraft&r, aku tidak bisa mengatur caramu membangun..."
		"{@pagebreak}"
		"Tapi aku bisa memberimu tips untuk itu!"
	]
	quest.0052E5592A6BBEC1.title: "&lTips Membangun!&r"
	quest.005CC8A3325FE2BD.quest_desc: ["&bFroststeel&r, &7Cloggrum&r, dan &eRegalium&r bisa didapatkan dengan menambang. \\nUntuk &cUtheric&r dan &aForgotten&r, kamu harus mengalahkan mob tertentu. \\n\\nAda pertanyaan lain?"]
	quest.005CC8A3325FE2BD.title: "Logam &2&lUndergarden&r"
	quest.00611844AFD5C31E.quest_desc: ["Meskipun Inscriber dan Charger menerima daya RF/FE secara bawaan, sebagian besar jaringan ME menggunakan sistem dayanya sendiri yang disebut AE.\\n\\nRF/FE dapat diubah menjadi AE dengan rasio 2:1 (RF:AE), baik langsung melalui ME Controller, atau melalui &bEnergy Acceptor&f, yang bisa dihubungkan ke bagian mana pun dari jaringan."]
	quest.00611844AFD5C31E.quest_subtitle: "Hubungkan Daya"
	quest.0072C4F028C327CB.quest_subtitle: "Magmatic + Nomad"
	quest.0072C4F028C327CB.title: "BlazBee"
	quest.00764A738DA6451C.quest_desc: ["Kalahkan 4 &dEndermite&r. \\n\\nKita benar-benar menghabisi semuanya sekarang, ya kan?"]
	quest.007A11C49E06F15F.quest_desc: ["Ini bisa dibuat dengan Crafting. \\n\\n&9Cetak Biru Komponen Crafting&r adalah salah satu &9Cetak Biru&r paling penting. \\n\\nDigunakan untuk membantu &6Meja Kerja Insinyur&r membuat Komponen Mekanik kecil lebih murah daripada Meja Crafting. \\n\\nJuga bisa digunakan untuk Crafting Barang unik seperti Bola Lampu dan Sirkuit!"]
	quest.007A11C49E06F15F.title: "&9Cetak Biru Komponen Crafting"
	quest.0089A394566B0F3B.quest_desc: ["&aUncommon&r adalah Rarity tingkat kedua. \\n\\nItem ini mulai muncul di &lWorld Tier: &9Haven&r, paling melimpah di &lWorld Tier: &2Frontier&r, dan berhenti muncul di &lWorld Tier: &4Pinnacle&r. \\n\\n&aTimeworn Fabric&r dibuat dengan menghancurkan &eItem&r &aUncommon&r di &c&lSalvaging Table&r."]
	quest.0089A394566B0F3B.quest_subtitle: "&aUncommon"
	quest.0089A394566B0F3B.title: "&aTimeworn Fabric"
	quest.008D186B4E0ED14F.quest_desc: [
		"Steam Oven adalah mesin lain yang menggunakan Uap (Steam) untuk sesuatu yang berguna. \\n\\nDengan memasukkan Uap ke dalamnya, alat ini akan bertindak sebagai tungku (furnace) untuk item apa pun di dalamnya. Mengolah Ingot dari bijih dan memasak makanan. \\n\\nIni adalah mesin multiblock berukuran 2x2x2."
		"{image:atm:textures/questpics/railcraft/rail_oven.png width:100 height:100 align:center}"
	]
	quest.008D186B4E0ED14F.title: "Steam Oven"
	quest.008E65AF545A706E.quest_desc: [
		"Meski jadi salah satu &5Mesin&r termahal di &5&lMekanism&r, sebenernya gak terlalu susah dipake! \\n\\nPertama, abis Bikin, kita perlu ngisi Bahan Bakarnya pake &aPolonium&r. &cTubing&r aja ke salah satu &dSPS Port&r soalnya kita bakal ngubah &aPolonium&r jadi &dAntimatter&r! \\n\\nBuat ngubahnya kita butuh Daya buat &dSupercharged Coil&r! &aKabel&rin &aEnergi&r gede-gedean ke &dSPS Port&r biar bisa dikirim ke &dSupercharged Coil&r. \\nTiap &dSupercharged Coil&r cuma bisa nerima &aEnergi&r segitu doang, jadi buat efisiensi maksimal pake 2! Iya sih bisa pake 1 tapi kan kita butuh &dAntimatter&r tahun ini bukan tahun depan! \\n\\nBegitu udah ngeblast &aPolonium&r pake jutaan FE, kita dapet &dAntimatter&r. Eh tunggu ini &cChemical&r &dAntimatter&r?!?! Kita butuh..."
		"{@pagebreak}"
		"{image:atm:textures/questpics/mek/mek_sps1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps2.png width:100 height:90 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps3.png width:120 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps4.png width:120 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps5.png width:120 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps6.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_sps7.png width:100 height:100 align:center}"
		"{@pagebreak}"
	]
	quest.008E65AF545A706E.quest_subtitle: "&d&lSPS"
	quest.008E65AF545A706E.title: "&d&lSuper-Critical Phase Shifter"
	quest.0095422BC87AA135.quest_desc: [
		"Lagi? Sobat, kita mau &7Ingot &fnggak mau &7Clump &fataupun &7Shard&r! &7INGOT&r! \\n\\nMasukkan &7Ore Shard&r itu ke dalam &b&lPurifier&r pakai &bOxygen&r (biasanya dari &9&lElectrolytic Separator&r kita yang sebelumnya) buat bikin &7Ore Clump&r. \\n\\nSekarang tinggal ulangi langkah dari Tier sebelumnya. &4Crush &f(hancurkan) &7Clump&f tadi buat dapat &7Dirty Dust&r. \\n\\n&dEnrich &f(perkaya) &7Dirty Dust&r-nya biar bersih. \\n\\nTerus, &6Smelt &f(bakar) &7Dust &f-nya buat dapat &7Ingot&r kita!"
		"{image:atm:textures/questpics/mek/mek_tier3_3.png width:250 height:100 align:center}"
	]
	quest.0095422BC87AA135.quest_subtitle: "Pengolahan Bijih Tier 3"
	quest.0095422BC87AA135.title: "&7Shard&f, jadi &7Clump&f, jadi &7Dust&f, jadi &7Ingot"
	quest.00A17728A387B426.quest_desc: ["Wood Nest digunakan untuk memancing Carpenter Bee dan Blue Banded Bee.\\n\\nDark Oak Nest memancing 3 jenis lebah yang berbeda.\\n\\nSarang-sarang ini bisa diletakkan di biome Overworld mana pun."]
	quest.00A17728A387B426.quest_subtitle: "Dapat digunakan di biome Overworld mana pun"
	quest.00A17728A387B426.title: "Wood Nests"
	quest.00A6020BC979947F.quest_desc: ["Dengan &9Marid Crusher&r yang baru saja kamu panggil, kamu bisa menghancurkan Echo Shard dan Iesnium Ingot, yang jika digabungkan dengan Glow Ink Sac akan menciptakan Cyan Chalk."]
	quest.00A6020BC979947F.title: "&3Cyan Chalk (Kapur Sian)"
	quest.00A91BD731486644.quest_subtitle: "Ceylon Ebony + Sour Cherry"
	quest.00AC7CC291A3E590.quest_desc: ["Kamu pasti (pasti banget) udah liat struktur-struktur di seluruh dunia yang kayaknya ada Beacon keluar dari sana. Mereka terbuat dari cobblestone, punya 4 kaki penopang, lumayan tinggi di udara! \\n\\nSemoga kamu tau tapi mereka disebut &8Dark Temples&r dan mereka punya &aEnviromental Accumulator&r yang kita butuhin. \\n\\nKamu harus nunggu Thunderstorm terjadi buat ngisi Weather Container-mu. Terus, kamu bisa bikin &3Lightning Bomb&r-mu!"]
	quest.00AC7CC291A3E590.title: "&3Lightning Bomb"
	quest.00B7DD3AFC94B037.quest_subtitle: "Beech + Alder"
	quest.00C95A190BE2CBF9.quest_desc: ["Untuk mendapatkan &#994ABAStyrene&r, kamu harus mereaksikan &#C2C969Iron Dust&r dengan &#69C9B6EthylBenzene&r dan Uap (Steam). &#69C9B6EthylBenzene&r adalah produk dari penyulingan &#CDCF95Steam Cracked Naptha&r."]
	quest.00C95A190BE2CBF9.title: "Penyulingan Tingkat Lanjut"
	quest.00CB8D60E7831A57.quest_desc: ["Catacomb adalah struktur bawah tanah masif yang terbuat dari Depthrock Brick. Terkadang ada bagian yang mencuat ke permukaan tanah yang bisa kamu temukan. \\n\\nDi dalam labirin raksasa ini terdapat &7Forgottens&r, peti tersembunyi, dan sang bos: &aForgotten Guardian&r. \\n\\nSemoga kamu sudah bersiap menghadapinya!"]
	quest.00CB8D60E7831A57.title: "Catacombs"
	quest.00D7BCC68D971A53.quest_desc: ["Makhluk hidup di sekitar akan dilacak secara otomatis, bahkan menembus dinding. Jika itu adalah mob agresif, kamu akan mendapat peringatan saat mereka membidikmu."]
	quest.00D7BCC68D971A53.quest_subtitle: "Maks: 1"
	quest.00D80AA4CDD8335C.quest_desc: ["&6&lPriest&r tidak cukup &6Suci&r untukmu? Kamu bisa Craft &6Lightbringer Chestplate&r! \\n\\nPertama, kamu perlu &6Priest Robes&r yang bisa di-Craft. \\n\\nKamu butuh 3 &bMithril Weave&r yang dibuat dari &bMithril&r dan Rantai. \\n\\nLalu, kamu harus mendapatkan &dDivine Soulshard&r dan kamu bisa Craft &6Chestplate&r-nya. \\n\\n&6Chestplate&r ini punya Armor Points yang sama dengan &6Priest Robes&r, tapi yang lainnya jadi jauh lebih baik! \\n\\nKamu dapat Armor Toughness, Knockback Resistance, dan tentu saja lebih banyak &3Spell Power&r dan Mana."]
	quest.00D80AA4CDD8335C.title: "&6Lightbringer Chestplate"
	quest.00DB5495C3A44999.quest_desc: ["Shift+Klik Kanan pada inventaris untuk mengosongkan isi."]
	quest.00DEFA26F2B896D6.quest_subtitle: "Silver Lime + Oak/Birch"
	quest.00E19377BAE5DD6A.quest_desc: ["Yang ini nambah &7Gunting&r ke &dMeka-Tool&r kita! \\n\\nGak bisa dipake bareng &2Farming &7Unit&r atau &5Teleportation &7Unit&r."]
	quest.00E19377BAE5DD6A.quest_subtitle: "Meka-Tool"
	quest.00E19377BAE5DD6A.title: "&7Shearing Unit"
	quest.00E1F1279F97557B.quest_desc: ["Mirip dengan Extruder MK1 tetapi yang ini lebih canggih! Bisa digunakan dengan Pattern sehingga saat blok diletakkan, mereka akan mengikuti pola tersebut!"]
	quest.00F00B0B66059996.quest_desc: [
		"Oke, satu lagi &lMultiblock&r! Yang satu ini butuh port lebih banyak daripada pangkalan angkatan laut mana pun!\\n\\nKita butuh hatch &3Fluid Input &fdan &3Output&r, serta hatch &6Item Input &fdan &6Output&r.\\n\\nProsesnya bakal agak panjang, jadi ikuti pelan-pelan ya!\\n\\nPertama, kita butuh &7Unrefined Liquid Souls&r yang didapat dari Fluid Extractor (dari &lIF&r) pada Soul Tree.\\n\\nLanjut, kita butuh &dLiquefied Source&r yang bisa didapat pakai &9Source Condenser&r. Alat ini bakal narik Source dari Source Jar terdekat dan mengubahnya jadi &dLiquefied Source&r!\\n\\nTerus, kita pakai &b&lRunic Crucible&r untuk menggabungkan Souls, &7Unrefined Liquid Souls&r, dan &dLiquefied Source&r jadi Liquid Souls!\\n\\nTerakhir, pakai Liquid Souls, &dLiquefied Source&r, dan beberapa item dari &l&5Mekanism&r untuk membuat &5Obsidiansteel&r."
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap3/creative_crucible1.png width:125 height:100 align:center}"
		"Lapisan pertama &l&bRunic Crucible&r punya &6Gilded Chiseled Polished Darkstone&r di tengah, dikelilingi &9Polished Darkstone&r. Lalu, di sisi-sisinya ada &9Polished Darkstone Stairs&r terbalik, dengan &7Rune Blocks&r di sudut-sudutnya."
		"{image:atm:textures/questpics/chap3/creative_crucible2.png width:125 height:100 align:center}"
		"Tepat di tengah-tengah, pasang &bArcane Crystal&r dengan &9Polished Darkstone Stairs&r di sekelilingnya. Di sisinya ada &6Arcane Polished Darkstone Pillars&r, &9Polished Darkstone&r (yang nanti diganti sama Hatch), dan &6Arcane Polished Darkstone&r."
		"{image:atm:textures/questpics/chap3/creative_crucible3.png width:125 height:100 align:center}"
		"Tinggal pasang &bArcane Crystal Blocks&r di tiap sudut dan selesai!"
		"{image:atm:textures/questpics/chap3/creative_crucible4.png width:125 height:100 align:center}"
		"Terakhir, beri jarak satu blok, lalu pasang &7Quantum Injector&r di atas &bArcane Crystal Block&r bagian tengah."
		"{image:atm:textures/questpics/chap3/creative_crucible5.png width:150 height:100 align:center}"
		"{image:atm:textures/questpics/chap3/creative_crucible6.png width:150 height:100 align:center}"
		"Blok &9Polished Darkstone&r di lapisan tengah adalah tempat kita memasang Hatch!"
	]
	quest.00F00B0B66059996.title: "&b&lRunic Crucible"
	quest.00FD36C207845895.quest_desc: ["Letakkan Obsidian Nest di dimensi The End untuk memancing lebah ini."]
	quest.00FD36C207845895.quest_subtitle: "&9Membutuhkan Obsidian Nest"
	quest.00FD36C207845895.title: "Draconic Bee"
	quest.00FF2CA7BA326007.quest_subtitle: "Mandarin + Wild Cherry"
	quest.01046CFBD7411AA6.quest_subtitle: "Tingkat: &54"
	quest.0104C2E2E30B966B.quest_desc: [
		"Apa &cBlood Chest&r kerja kurang cepat? Kamu punya terlalu banyak item yang perlu diperbaiki? Kamu bisa bikin &cColossal Blood Chest&r buat selesaiin masalah ini.\\n\\nBuat bikin satu, kamu butuh bikin 25 &9Reinforced Undead Planks&r. Pakai ini, kamu mau bikin kubus hollow 3x3x3, terus taro &cColossal Blood Chest&r blok buat nutup struktur multiblock. Kalau bener, kamu bakal punya &cBlood Chest&r gede yang sekarang bisa kamu pake. Beberapa orang mungkin bilang ini kolosal.\\n\\nIni juga bikin kamu bisa upgrade pakai &6Promises&r.\\n"
		"{image:atm:textures/questpics/evilcraft/bloodchest.png width:250 height:200 align:1}"
	]
	quest.0104C2E2E30B966B.quest_subtitle: "Blood Chest Kakak"
	quest.0104C2E2E30B966B.title: "&aPerbaikan Kolosal"
	quest.010607466D565B53.quest_desc: ["Ayo menyatu dengan alam, kawan. \\n\\nDengan &aRooted Boots&r, alam adalah sahabat terbaikmu! Saat berdiri di atas rumput (Grass), kamu akan meregenerasi HP. Selain itu, saat kamu makan sambil berdiri di atas rumput, efeknya akan seperti memberikan Bonemeal ke rumput tersebut."]
	quest.010607466D565B53.quest_subtitle: "Kaki"
	quest.010607466D565B53.title: "&aRooted Boots"
	quest.0107D516E038E0DB.quest_desc: ["&eLich Tower&r adalah rumah bagi sang &eLich&r! Pertarungannya memiliki 3 fase:\\n\\nFase 1: &eLich&r mengelilingi dirinya dengan perisai, dan menyerangmu dengan &5Ender Pearl&r yang ditembakkan seperti bola api Ghast. Pantulkan kembali ke arah &eLich&r untuk menghancurkan perisainya! Saat perisainya hancur, ia akan mengirim duplikat untuk mengalihkan perhatianmu.\\n\\nFase 2: &eLich&r mengganti tongkatnya untuk memanggil Zombie guna membantunya bertarung. Saat pertahanannya turun, kamu bisa menyerangnya dengan jarak dekat (melee)!\\n\\nFase 3: Setelah semua muatan tongkatnya habis, ia akan beralih ke &eGolden Sword&r dan mengamuk. Bunuh dia secepat mungkin!"]
	quest.0107D516E038E0DB.title: "&eBawa Keluar Mayatmu"
	quest.0108F3EFDFD6DFD0.quest_desc: ["Storage Link memungkinkanmu menghubungkan beberapa penyimpanan yang tidak menempel pada Storage Controller atau blok apa pun yang terhubung dengannya.\\n\\nJadi ini adalah cara untuk menghubungkan \"multiblock\" penyimpanan secara nirkabel tanpa perlu mengklik kanan satu per satu.\\n\\nBatas jarak 14 blok masih berlaku."]
	quest.010A970FC91BD617.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.010A970FC91BD617.title: "Soularium Bee"
	quest.01119871B1D5C576.quest_desc: [
		"Hampir setiap &6Village&r bisa punya &6&lPriest&r. Ini termasuk &6Village&r dari mod lain. \\n\\nBiasanya mereka nongkrong di tengah &6Village&r seperti di dekat Market. Tidak setiap &6Village&r akan punya."
		"{image:atm:textures/questpics/iron_spells/spells_village.png width:200 height:100 align:center}"
	]
	quest.01119871B1D5C576.title: "&6Village"
	quest.011B8BD02D80DDD4.quest_desc: ["Kamu bisa menemukan &#6E2D6ETungsten Ore&r di seluruh dunia dengan mudah. Menghancurkannya akan menghasilkan &#A140A1Raw Tungsten&r."]
	quest.011D8CADA29C9C70.quest_desc: ["&eQIO Drive&r nentuin Storage di &e&lQIO Drive Array&r. \\n\\nMereka ditaro di Inventory &5Mesin&r buat dipake. Bisa masukin sampe 12 buah. \\n\\n&eQIO Drive&r nyimpen &eItem&r dan bakal otomatis ngisi &eQIO Drive&r pertama duluan. \\n\\nMasing-masing punya limit &eItem Storage&r sama &eItem Type&r. Makin bagus &eQIO Drive&r-nya, makin banyak &eItem&f sama &eItem Type&r yang bisa disimpen! \\n\\n&aQIO Drive&r: yang paling basic, bisa 16k Item sama 128 Type. Ini satu-satunya yang gak butuh &2&lFission Reactor&r buat Crafting. \\n\\n&cHyper-Dense QIO Drive&r: yang ini sama selanjutnya butuh &2&lFission Reactor&r. Bisa nyimpen 128k Item sama 256 Item Type. \\n\\n&bTime-Dilating QIO Drive&r: bisa nyimpen 1,048k Item sama 1,024 Item Type. \\n\\n&dSupermassive QIO Drive&r: butuh &dAntimatter&r buat Craft tapi jelas kasih Storage paling banyak. Bisa 16b Item sama 8,192 Item Type."]
	quest.011D8CADA29C9C70.title: "&eQIO Drive"
	quest.011F787E620DE9E8.quest_desc: ["Untuk mengatur Mob Filter, kamu hanya perlu mengklik mob yang tidak ingin kamu lihat lagi menggunakan item Mob Filter tersebut. \\n\\nSetiap filter hanya bisa menampung 1 jenis mob, jadi jika kamu ingin agar Zombie, Skeleton, Laba-laba, Creeper, dan Enderman tidak muncul lagi, kamu butuh 5 buah Mob Filter. \\n\\nKamu bisa mengganti jenis mob di dalamnya cukup dengan mengklik mob lain menggunakan filter yang sama."]
	quest.011F787E620DE9E8.quest_subtitle: "Dia tidak diundang!"
	quest.012912FDAFCD1C66.quest_desc: ["&e&lCaliburn&r pada awalnya tidak jauh lebih baik dari &bDiamond Sword&r tapi setelah di-upgrade; &bDiamond Sword&r lebih mirip Stick biasa dibanding &e&lCaliburn&r! \\n&4&lMorgan&r dan &e&lCaliburn&r punya Damage sebenarnya dan Innate Cap mereka. \\n\\nInnate Cap adalah Damage maksimal yang bisa ditingkatkan. Untuk meningkatkan Innate Cap &e&lCaliburn&r, enchant dengan &5Smite&r lalu lempar ke &3Lake&r dengan Nether Star. \\n\\nUntuk dapat Max Cap butuh 6 Nether Star. Setelah di-upgrade tidak bisa di-upgrade lagi jadi pastikan melempar semua 6 sekaligus! \\n\\nUntuk meningkatkan Damage normal perlu enchant dengan &5Smite&r lalu kembali ke &3Lake&r! Butuh lebih banyak damage untuk..."]
	quest.012912FDAFCD1C66.title: "Meng-upgrade &l&eCaliburn"
	quest.0133DA323E24A455.quest_desc: ["Ngomongin soal ganti-gantian (&6Hazmat Suit&r jadi &aRadiation Shielding &7Unit&r) yuk ganti &eScuba Gear&r! \\n\\nPake &7Module Unit&r ini di &a&lMekaSuit Helmet&r, kita bisa berenang &9Underwater&r sambil napas! \\n\\nKalo punya &cJetpack &7Unit&r di &a&lMekaSuit Bodyarmor&r bakal ngasih &7Hydrogen&r pas lagi di &9Air&r."]
	quest.0133DA323E24A455.quest_subtitle: "Helmet"
	quest.0133DA323E24A455.title: "&9Electrolytic Breathing &7Unit"
	quest.0145727E40D7F674.quest_subtitle: "Cempedack + Breadfruit"
	quest.01516BC726013B7C.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.0152938EE5651409.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.01612963DBBAC9A1.quest_desc: ["Semoga ini bisa melindungimu."]
	quest.01612963DBBAC9A1.title: "Chaotic Chestplate"
	quest.01748C2CD9C97523.quest_desc: ["&cReappearing Block&r itu seperti pintu yang keren. Saat diklik kanan, mereka akan menghilang dalam waktu singkat.\\n\\n&cVanishing Block&r akan menghilang saat diklik kanan, tapi tidak akan kembali lagi."]
	quest.01748C2CD9C97523.title: "Blok &cMuncul Kembali \\& Lenyap"
	quest.019CA0E35F888222.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.019CA0E35F888222.title: "&eAdvanced Restock Upgrade"
	quest.019CC48531E7759B.quest_subtitle: "Dibuat di Dragonsteel Forge"
	quest.019CC48531E7759B.title: "Ice Dragonsteel Bee"
	quest.01A90E2541C91DB2.quest_desc: ["Kebanyakan &5Mesin&r, setidaknya yang simpel, bisa pakai &8Upgrade&r! \\n\\n&8Upgrade&r ada di pojok kanan atas GUI. Tampilan ini mungkin membingungkan tapi jangan khawatir, aku jelasin! \\n\\nPertama, bagian bawah nunjukin &8Upgrade yang Didukung&r. &8Upgrade&r yang kelihatan jelas itu berarti &aDidukung&r, sedangkan yang transparan itu &4nggak bisa&r! Kamu juga bisa arahkan mouse ke sana buat lihat namanya dan apa mereka &aDidukung&r. \\n\\n&8Upgrade&r dimasukkan lewat Slot Atas, nanti bakal muncul di sebelah kanan. Di sini kamu bisa klik buat lihat berapa banyak yang ada di dalam mesin dan lihat efeknya! \\n\\nKalau mau ambil lagi &8Upgrade&r-nya, klik yang mau diambil, terus tekan tombol Uninstall. Nanti &8Upgrade&r-nya bakal pindah ke Slot Bawah."]
	quest.01A90E2541C91DB2.title: "&8Machine Upgrades"
	quest.01AFC11EAAB6CB3B.quest_desc: ["&eBone Reptile Armor&r terbuat dari &eKoboleton Bone&r, &eAncient Metal&r, dan untuk Helm-nya menggunakan &eKobolediator Skull&r. \\n\\nArmor ini tidak memiliki kemampuan spesial, tapi memberikan statistik yang sangat bagus untuk harga yang tergolong murah!"]
	quest.01AFC11EAAB6CB3B.title: "&eBone Reptile Armor"
	quest.01B13BBB41BBB460.quest_desc: ["&cUtherium Armor&r memiliki statistik yang sama dengan Armor Netherite! \\n\\nTanpa perlu menggunakan Smithing Template!"]
	quest.01B13BBB41BBB460.title: "Armor &cUtherium&r"
	quest.01B2DDD81065B4EF.quest_subtitle: "Jungle + Cherry"
	quest.01C169A7FA424F6E.quest_subtitle: "Tingkat: &a2"
	quest.01C5D8357D8B0D62.quest_desc: ["Jika kamu tahu cara kerja Detector Rail, maka Module ini akan sangat mudah dimengerti. \\n\\nIntinya, jika item tertentu ada di dalam Router, ia akan memancarkan sinyal Redstone. \\n\\nDi dalam Module ini, kamu bisa mengatur item apa yang dideteksi, dari arah mana sinyal berasal, dan seberapa kuat sinyalnya."]
	quest.01CF1A9D9F29AFF7.quest_subtitle: "Pomelo + Orange"
	quest.01ECFBB5F0574C24.quest_desc: [
		"Quest ini dibuat oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. "
		""
		"Karena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak diperbolehkan untuk digunakan dalam pack publik yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. "
		""
		"Quest ini sengaja disembunyikan, jika kamu melihat ini, kamu sedang dalam mode editing."
	]
	quest.01EE2526B43B6502.quest_subtitle: "Tingkat: &b3"
	quest.01F18150EC923482.quest_desc: ["&3Refined Storage&r (RS atau RS2) adalah mod penyimpanan massal yang menawarkan sistem penyimpanan berbasis jaringan.\\\\n\\\\nUntuk memulai mod ini, kamu harus membuat &3Controller&r.\\\\n\\\\nController adalah 'Jantung' dari jaringan penyimpananmu. Saat diberikan daya, ia akan menghidupkan semua komponen RS yang terhubung."]
	quest.01F18150EC923482.quest_subtitle: "Versi 2"
	quest.01F18150EC923482.title: "&3Refined Storage"
	quest.01F322AEFCC6109E.quest_desc: ["Tangled Skull bisa di-drop dari... ya Tangled Skull. \\n\\nMereka bisa dipake sebagai proyektil kayak Wither Head yang dilempar Wither. \\n\\nTapi bakal abis kalau kamu pake."]
	quest.01F3F0C25BA72BDA.quest_desc: [
		"Selain penyimpanan item dan cairan, AE2 juga menyediakan cara untuk menyimpan seluruh &estruktur&f di dalam storage cell, mirip dengan mod Compact Machines. "
		""
		"&bSpatial IO Port&f memungkinkan struktur yang berada di dalam &bSpatial Containment Structure&f ditangkap ke dalam storage cell khusus yang dirancang khusus, diaktifkan melalui sinyal redstone. "
		""
		"Jika ada mob atau pemain yang berdiri di dalam SCS saat ruang tersebut ditangkap, mereka juga akan ikut berpindah ke tempat ruang tersebut disimpan, yaitu di dimensi khusus. Pastikan kamu punya jalan keluar jika kamu sendiri yang tertangkap."
	]
	quest.01F3F0C25BA72BDA.title: "Spatial IO"
	quest.01F51EBFEC660549.quest_subtitle: "Silver Lime + European Larch"
	quest.01F7F3589EBD8872.quest_subtitle: "Berikan Shroombee sebuah Brown Mushroom"
	quest.01F7F3589EBD8872.title: "Brown Shroombee"
	quest.020E6AF37A0421C8.quest_desc: [
		"Water Tank seperti memiliki drum air raksasa di luar ruangan. Alat ini mengumpulkan air hujan dan bisa menyimpannya untuk keperluan Steam Locomotive. \\n\\nJumlah air yang dihasilkan bergantung pada biome dan harus memiliki akses langsung ke langit. \\n\\nMesin ini dibuat dengan blok Water Tank berukuran 3x3x3 dengan bagian tengah yang kosong."
		"{image:atm:textures/questpics/railcraft/rail_tank.png width:100 height:100 align:center}"
	]
	quest.020E6AF37A0421C8.title: "Tangki Air (Water Tank)"
	quest.022C38096F79EF07.quest_desc: ["&6&lForbidden \\& Arcanus&r itu semua tentang pake Arcane buat ngelakuin ritual dengan Forge supaya jadi lebih kuat! \\n\\nAtau yang kebanyakan orang tau, Eternal Stella. Mod ini lebih dari itu tau! "]
	quest.022C38096F79EF07.title: "&6&lForbidden \\& Arcanus"
	quest.024BD22824C7F53A.quest_desc: ["Menyuling &#F0C87DSteam-Cracked Naptha&r akan memberimu &#8FD5E3Toluene&r."]
	quest.0252B8F77A038D17.title: "Wyvern Auto Feed Module"
	quest.02593CD4B4AE814C.quest_desc: [
		"&bSalt&r (Garam) sangat penting untuk proses Inkubasi &eAlchemical Sulfur&r! \\n\\nUntuk mendapatkan &bGaram&r, kita perlu membakar beberapa item. Item yang berbeda akan menghasilkan jenis &bGaram&r yang berbeda pula. &bGaram&r memiliki tingkatan (Tier) yang semakin tinggi seiring dengan kelangkaannya. \\n\\nUntuk mengekstrak &bGaram&r, kita perlu memasukkan item ke dalam Oven dan menggunakan sumber panas (Heat) untuk memanaskannya. Kemudian ambil &bGaram&r hasil pembakaran dari Oven!"
		"{image:atm:textures/questpics/theurgy/theurgy_oven.png width:100 height:100 align:center}"
	]
	quest.02593CD4B4AE814C.title: "Instalasi Desalinasi"
	quest.02643BAD1AE747C6.quest_desc: ["&3Advanced Liquid Compressor&r bekerja sama seperti Liquid Compressor, hanya saja jauh lebih baik!"]
	quest.026A71F98A52E3A5.quest_desc: ["Di dalam desa, ada villager &omenarik&r yang kebetulan adalah &dWerewolf&r.\\n\\nBunuh binatang ini bakal kasih kamu &dWerewolf Flesh&r."]
	quest.026C63594F813BCC.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Menghapus semua debuff negatif dari pemain saat diaktifkan, memiliki cooldown."
	]
	quest.0272E58516A0C284.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penambang Bijih"
		"- Pemindai Bijih &4&lDINONAKTIFKAN&r&f"
		"- Pemotong Rumput"
		"- Penyapu Langit"
		"- Penebang Pohon"
		"- Penghancur Daun"
		"- Pelebur Otomatis"
		"- Palu"
		"- Teleporter Barang Jatuhan"
	]
	quest.027E6E294D9E1375.quest_desc: ["Catat ini &lCorail&r! Beginilah cara merayakan hari raya! (Aku bilang begini dengan penuh rasa sayang, kami mencintaimu &lCorail&r!) \\n\\nTambahan ini memberikan banyak dekorasi untuk Natal dan Halloween. \\n\\nMulai dari Pohon Natal, Kado, dan Lampu Natal, hingga Labu, Laba-laba, dan Topi Penyihir untuk Halloween."]
	quest.027E6E294D9E1375.title: "&b&lMacaw's Holidays&r"
	quest.027EF5C8A74B1596.quest_desc: [
		"Senjata utama &6L&8e&6b&8a&6h&r adalah sengat mereka. \\n\\nJadi kenapa kita tidak menggunakannya untuk senjata kita sendiri! Kamu bisa membuat, menemukan, atau menukarkan Stinger Spear dan cara kerjanya mirip dengan Trident. \\n\\nHanya saja jauh lebih lemah dan memberikan efek Poison (Racun) ke musuh!"
		"{image:atm:textures/questpics/bumblezone/bumble_spear.png width:100 height:150 align:center}"
	]
	quest.027FD9135DEC4949.quest_subtitle: "Memancing Ghostly Bee saat diletakkan di Nether dan diberikan Ghast Tear"
	quest.0298A17C2AAC5765.quest_desc: ["Meningkatkan ukuran stack di dalam Tas sebanyak 8 kali lipat."]
	quest.0298A17C2AAC5765.title: "&bStack Upgrade Tingkat 3"
	quest.029AA03790F055E8.quest_subtitle: "Crystalline + Mason"
	quest.029AA03790F055E8.title: "Gold Bee"
	quest.02B0CCD5607FF3B5.quest_desc: ["Pengakses pemain berfungsi seperti peti yang terhubung dengan inventori pemain. Melalui antarmuka, pengakses pemain dapat dikonfigurasi sisi-sisinya untuk terhubung dengan inventori pemain, tangan kedua, atau slot armor."]
	quest.02B574B09AB45D09.quest_desc: [
		"Freeze kerjanya mirip kayak Blaze, mereka bakal terbang ke atas dan nembak bola ke kamu. \\n\\nCuma Freeze cuma lempar 1 bola dan bakal bikin kamu kedinginan bukan kepanasan. \\n\\nMereka punya 16 Heart dan bakal drop Frozen Tube kalau mati."
		"{image:atm:textures/questpics/eternal/starlight_freeze.png width:150 height:100 align:center}"
	]
	quest.02B574B09AB45D09.title: "Freeze"
	quest.02B8F50721F12CFF.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:"
		""
		"Mencegah pemain dari kerusakan jatuh."
	]
	quest.02C6132919DEAF2A.quest_desc: ["Sebelum mulai bikin &aEnergi&r, mari kita sebarin Steam kemana-mana. Bisa dilakuin dengan ngelilingin &9Rotational Complex&r pake &9Pressure Disperser&r! \\n\\nDi atas layer itu kita butuh layer baru, yang ini penuh &aElectromagnetic Coil&r. Ini bakal digerakin sama &9Rotational Complex&r, mereka gerak bareng itu yang bikin &aEnergi&r lewat Gaya Magnetnya. Sama kayak di Pembangkit Listrik Tenaga Air! \\n\\nDi atas &aElectromagnetic Coil&r bisa pake &9Saturating Condenser&r yang bakal daur ulang Steam jadi &9Air&r! &9Air&r-nya bakal dikeluarin lewat &9Vent&r."]
	quest.02C6132919DEAF2A.title: "Bikin &aEnergi&r pake &9&lTurbine&r"
	quest.02D45E3FB37ED0AD.quest_subtitle: "Tingkat: &63"
	quest.02DEAB3F1198BFBE.quest_desc: ["&bHutan Warped Kuno&r adalah Hutan lain di dalam &b&lThe Other&r. \\n\\nLantainya terbuat dari &bNylium Warped&r dengan &cNetherrack&r di bawahnya. \\n\\nDaripada &bPohon Warped&r/Jamur/apalah, hutan ini punya &bPohon Soul&r!"]
	quest.02DEAB3F1198BFBE.title: "&bHutan Warped Kuno"
	quest.02F2DF9D9DA7833A.quest_desc: ["Untuk dapet &9Corrupt Soul&r kita perlu &5Enchanting&r! \\n\\nKita cari &5Soul Looting Enchantment&r. Ini masuk di Senjata, dan setiap kali kamu bunuh Mob ada kemungkinan spawn &9Corrupt Soul&r. \\n\\nIni kemudian bisa dibunuh untuk dapetin sebagai Item. Coba lakukan dengan cepat karena mereka suka terbang kabur. \\n\\nMungkin mereka tau kamu mau bunuh mereka?"]
	quest.02F2DF9D9DA7833A.title: "&5Soul Looting Enchantment"
	quest.02F3133A9006BC1E.quest_subtitle: "Tuangkan Molten Steel ke atas Telur Spawn Iron/Coal Bee"
	quest.02F3133A9006BC1E.title: "Steel Bee"
	quest.02F4C3BEBD8427AD.quest_desc: [
		"Percayalah, kamu akan tahu saat melihatnya. \\n\\nLusinan taman yang tergantung dari atap Hive. Berisi ratusan jenis bunga dan pohon, bahkan beberapa dari mod lain seperti Eternal Starlight atau Regions Unexplored!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_garden.png width:200 height:100 align:center}"
	]
	quest.02F4C3BEBD8427AD.title: "Taman Gantung"
	quest.0306D25C7407FE88.quest_desc: ["Komponen lain yang dibutuhin buat nyalain &c&lFusion Reactor&r adalah &6Panas&r! Bisa pake &4Laser&r atau &cPort &6Panas&r ke dalamnya. \\n\\nKita bakal pake &4Laser&r aja. Lebih spesifik &4Laser Amplifier&r yang nembak jumlah tertentu ke &cLaser Focus Matrix&r. \\n\\nKita butuh &4Laser Amplifier&r dengan &aEnergi&r 1GFE yang ditembakkin ke &cLaser Focus Matrix&r. Kedengerannya banyak banget &aEnergi&r-nya tapi tenang aja kita bakal dapetin balik! \\n\\nMengikuti Quest &4Laser Amplifier&r, kita perlu nembakkin &4Laser&r ke &4Laser Amplifier&r. Tapi tiap laser cuma ngasih sekitar 1MFE tiap beberapa detik... \\n\\nDaripada nunggu setahun, bisa pake banyak &4Laser&r yang nembak ke banyak &4Laser Amplifier&r yang nembak ke satu yang ngarah ke &cLaser Focus Matrix&r. \\n\\nTaro &4Laser Amplifier&r biar ada satu di belakang masing-masing, sambil semuanya punya 4 &4Laser&r yang nembak dari arah lain!"]
	quest.0306D25C7407FE88.title: "&cLaser Focus Matrix"
	quest.030AC1AF8F735550.quest_desc: ["Untuk memasukkan cairan ke dalam Tank, kamu butuh semacam Pipa.\\n\\nHydro Pump bisa memasukkan Air secara otomatis dengan kecepatan lambat, tapi ini gratis!"]
	quest.030AC1AF8F735550.title: "Pipa"
	quest.03164C4C7813CE2B.quest_desc: [
		"Quantum Computer adalah CPU Crafting yang sangat kuat. Dapat menjalankan job crafting tanpa batas, dan berbagi thread co-processing di antara mereka, selama memiliki storage yang tersedia untuk digunakan."
		""
		"Harus berbentuk kuboid minimal 3x3x3 dan maksimal 7x7x7. Alternatif: Satu Quantum Computer Core dapat berfungsi sebagai Quantum Computer sendiri."
		""
		"Multiblock Quantum Computer membutuhkan:"
		"- Tidak boleh ada ruang kosong di dalam multiblock. Bisa diisi dengan Quantum Crafting Unit tanpa benefit tambahan."
		"- Tepat satu Quantum Computer Core"
		"- Maksimal satu Quantum Data Entangler"
		"- Maksimal satu Quantum Computer Multi-Threader"
		"- Semua blok di lapisan luar harus Quantum Computer Structural Glass"
		"- Tidak ada blok di dalam yang boleh jadi Quantum Computer Structural Glass."
		""
		"Siap-siap bikin banyak Singularities."
	]
	quest.03164C4C7813CE2B.title: "Job Crafting Tanpa Batas: Quantum Computer"
	quest.03250A0202C25E80.quest_desc: ["Setelah kamu berhasil membunuh setan &9Unbound Marid&r yang dipanggil dengan &4Abras' Fortified Conjure&r, kamu bisa menggunakan &9Marid Essence&r yang dijatuhkannya untuk membuat kasta kapur warna \"tertinggi\", yaitu Blue Chalk."]
	quest.03250A0202C25E80.title: "&9Blue Chalk (Kapur Biru)"
	quest.032B654201E71618.quest_desc: ["&cTrack Kit&r ini digunakan untuk berinteraksi dengan entitas (mob) menggunakan &7Cart&r kamu. \\n\\n&cEmbarking Kit&r akan mengambil mob di sekitar dan memasukkannya ke dalam &7Cart&r. \\n&cDisembarking Kit&r akan mengeluarkan mob dari &7Cart&r. \\n&c精Dumping Kit&r akan menjatuhkan mob yang ada di dalam &7Cart&r ke bawah &6rel&r tempat ia berada."]
	quest.032B654201E71618.title: "&cTrack Kit&r untuk Memindahkan Entitas"
	quest.03326C2FF16F64C3.quest_desc: ["&8Armor Kulit Troll&r dibuat dari &8Troll&r yang ada di Bioma tertentu. Perbedaan Biomanya cuma mengubah tampilan doang. \\n\\nSetiap set lengkap bakal kasih &7Armor Points&r di antara Iron dan &bDiamond&r, total 17 &7Armor Points&r. \\n\\nSetiap &8Armor&r-nya bakal ngurangin Damage dari Projectile! Kayak punya Projectile Protection di semua Armor sambil tetep bisa dapet Protection! \\n\\nPlus kamu bakal keliatan kayak &8Troll&r!"]
	quest.03326C2FF16F64C3.title: "&8Armor Kulit Troll"
	quest.0342248394E40B6A.quest_desc: ["Quest ini dibuat oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r buat dipake di Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensiin di bawah &eAll Rights Reserved&r, Quest ini gak boleh dipake di pack publik manapun yang gak dirilis sama &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyiin, kalau kamu liat ini, berarti kamu lagi di mode editing."]
	quest.034A9FBCA6D79BB6.quest_desc: ["Harvester Pylon membutuhkan Cangkul (Hoe) agar bisa bekerja. \\n\\n(Cangkul yang tidak bisa hancur akan bekerja selamanya, sedangkan cangkul biasa harus diganti jika durabilitasnya habis)."]
	quest.034AB493E1EC2E63.quest_desc: [
		"Assembler Matrix Core menentukan kapasitas pattern, job crafting, dan kecepatan multiblock."
		""
		"Craft Core menambah 8 job crafting paralel maksimal ke multiblock."
		"Pattern Core menambah 36 slot pattern ke multiblock."
		"Speed Core bekerja seperti Acceleration Card, meningkatkan kecepatan job crafting. Pasang lebih dari 5 Speed Core tidak ada efeknya."
	]
	quest.034AB493E1EC2E63.title: "Assembler Matrix Core"
	quest.034DB3C64F24C7B7.quest_desc: ["&6&lAllTheOres&r adalah mod buatan internal kami yang dibuat untuk membantu menyatukan berbagai jenis bijih.\\n\\nMod ini juga menghadirkan banyak blok dekoratif yang sangat berguna!\\n\\n&dFluorite&r dan &9Sapphire&r keduanya terlihat sangat keren!"]
	quest.034DB3C64F24C7B7.title: "Blok &l&6AllTheOres&r"
	quest.034F2CDF0830254B.quest_desc: [
		"Bekerja persis seperti Item Importer, pasang &eFluid Importer&r pada Tangki berisi Cairan. Kemudian pasang &eFluid Interface&r di tempat tujuan dan hubungkan dengan Logic Cable. Terakhir, pasang Variable Card seperti sebelumnya! \\n\\nAlat ini juga bisa menarik Cairan hingga batas Integer Limit. \\n\\nTidak meletakkan atau mengambil Fluid Source dari dunia luar, ia hanya memindahkan Cairan dari satu Tangki ke Tangki lainnya."
		"{image:atm:textures/questpics/logistics/id_fluid.png width:200 height:50 align:center}"
	]
	quest.034F2CDF0830254B.title: "&eFluid Importing"
	quest.035495984F84FB44.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.035495984F84FB44.title: "Pulsating Alloy Bee"
	quest.03564837ECB5CC79.quest_desc: ["Ritual lagi tentunya, yang ini namanya &2Ihagan's Enthrallment&r. (BTW buat ngorbanin Kuda kamu perlu dia deket pas ritual berlangsung) \\n\\nSetelah selesai kamu bakal dapet Spawn Egg buat &2Dragon Familiar&r. Ini bisa dipake di crafting buat dapetin &6&lATM Star&r, atau kamu bisa spawn si &2Familiar&r-nya. \\n\\nYang ini bakal ngikutin kamu kemana-mana dan bisa dielus pake Shift Right Click."]
	quest.03564837ECB5CC79.title: "Spawn Egg &2Dragon Familiar&r"
	quest.035C52EF63AD23A7.quest_desc: ["Sesuai nama modnya, &lRailCraft&r, dan fokus utamanya yaitu &5Kereta Api&r, maka &6Rel&r sangatlah penting. \\n\\nRel &2Vanilla&r memang berfungsi, tapi jujur saja, kinerjanya kurang memuaskan. Rel yang ditingkatkan akan membutuhkan material khusus untuk resepnya! Ayo buat! (Mungkin memerlukan mesin untuk membuat komponennya, jadi cek bagian quest mesin!)"]
	quest.035C52EF63AD23A7.title: "&6&lRel&r!"
	quest.036D5767E07005BC.quest_desc: ["&bDrain&r adalah apa yang akan kita gunakan untuk mengeluarkan &7Logam Cair&r. Ya, sayangnya cairan ini terlalu panas untuk tangan atau Ember (Bucket) kita. \\n\\nHubungkan &7Tap&r (Keran) &c&lFoundry&r ke &bDrain&r untuk mengalirkan &7Logam Cair&r keluar dengan cara Klik Rikan pada keran tersebut. \\n\\nKamu juga bisa melihat jumlah cairan di dalam &c&lFoundry&r saat melihat blok &bDrain&r!"]
	quest.036D5767E07005BC.title: "&bDrain&r &c&lFoundry&r"
	quest.037415D5B965E214.quest_desc: ["Upgrade ini membuat Tas (Backpack) tidak bisa hancur atau hilang."]
	quest.037488EF1F3581CE.quest_desc: ["Secara standar, jaringan ME tanpa ME Controller hanya memiliki buffer internal sebesar 800AE, sedangkan controller menambah 8kAE per blok. Untuk jaringan besar, ini mungkin tidak cukup dan bisa menyebabkan jaringan mati mendadak saat mencoba mengisi daya semua perangkat.\\n\\n&bEnergy Cell&f memungkinkan jaringan ME menampung lebih banyak energi, menambah 200kAE per Energy Cell biasa dan 1.6MAE per &bDense&f Energy Cell. Ini bisa diletakkan di mana saja dalam jaringan."]
	quest.037E0DAA5ECC5AB8.quest_desc: ["Kenai 24 mob berbeda dengan &ePollen Puff&r. \\n&6L&8e&6b&8a&6h&r adalah yang paling seru untuk dilempari benda ini!"]
	quest.037FBF06E59E1027.quest_subtitle: "Dibuat di Clibano"
	quest.037FBF06E59E1027.title: "Deorum Bee"
	quest.03840E4C74731E0C.quest_desc: ["Dengerin, gue udah bilang kalian pake &9Electric Pump&r buat kebanyakan Quest &5&lMekanism&r. \\n\\nTapi jujur aja gue harus lulusin kalian. &2&lReaktor&r bakal butuh lebih banyak &9Air&r jadi gue kasih, &9Sink&r! \\n\\n&9Sink&r punya &9Air&r Unlimited dan bisa di-&bPipe&r keluar dari hampir semua Mod. Gue saranin pake &9&lID&r kalo ada soalnya bisa narik lebih dari 2 Miliar mB &9Air&r tiap Tick! \\n\\nAlasan gue pake &9Electric Pump&r bukan karena gue gak percaya kalian pake &9Sink&r tapi karena alasan ini. 1. bakal tetep ada di Modpack yang gak punya &9Sink&r dan 2. ini dari &5&lMekanism&r. "]
	quest.03840E4C74731E0C.title: "&9Water &bCoolant"
	quest.038812A14456236C.quest_desc: ["Dengan nyombain beberapa Processor, Energy Cell, dan Dense Cable apapun kita dapet ME Quantum Ring. \\n\\nBiasanya kita pake ini buat nyambungin sistem ME kita lintas Dimensi tapi kita cuma peduli sama &6&lATM Star&r!"]
	quest.03B40AB768FC0161.quest_desc: [
		"Shimmer River adalah sungai yang ramah. Mereka gak bakal nyoba bunuh kamu. \\n\\nKadang mereka nyambungin Laut dan melewati Hutan. \\n\\nJelas mereka punya Air tapi di dalam Airnya ada banyak barang bagus!"
		"{image:atm:textures/questpics/eternal/starlight_river.png width:200 height:100 align:center}"
	]
	quest.03B40AB768FC0161.title: "Shimmer River"
	quest.03C40D6A5D722543.quest_desc: ["Variable Card sangat penting untuk memulai interaksi seperti Mengimpor Item. Kamu harus memasukkannya ke salah satu slot pada Importer untuk menambahkannya. \\n\\nDari sana kamu bisa mengedit semuanya melalui tombol +. Kamu bisa mengubah jumlah yang diimpor, slot item yang mana, channel yang mana, praktis semuanya hanya dengan kartu itu. \\n\\nJika kamu seperti aku yang cuma ingin memindahkan item tanpa ribet, cukup masukkan kartunya dan mungkin ubah Limit jumlah yang dipindahkan."]
	quest.03C54B07106091DD.quest_desc: ["&cSmelter Prism&r mungkin Item paling sering dipakai dari Ritual ini, seperti gimana dibutuhkan buat &6&lATM Star&r! \\n\\nKamu butuh 4 &cBlaze Powder&r, 2 &8Coal&r, dan blok &bArcane Crystal&r untuk bikinnya. Dan jangan lupa &3Elementarium&r Relic! \\nJelas dan yang paling mungkin kamu mau &cSmelter Prism&r untuk adalah &6&lATM Star&r. Juga bisa dipakai dengan Tool untuk Smelt Item yang mereka pecahkan: Raw Ore jadi Ingot, Log jadi Charcoal, Sand jadi Glass. \\n\\nKamu juga bisa pakai buat Furnace Fuel, tapi agak jelek. Yang aneh karena namanya suggest lebih bagus!"]
	quest.03C54B07106091DD.title: "&cSmelter Prism"
	quest.03C78165C5CBD9E1.title: "&aKomponen Penyimpanan 16k"
	quest.03DCDFB32CD4BD85.quest_desc: ["&e&lCaliburn&r membutuhkan beberapa hal, sebagian sudah disebutkan di quest, sebagian belum. \\nPertama, butuh &3Mahou Lake&r dan 5000 &4Mahou&r. \\n\\nKemudian, butuh Enchanted &bDiamond Sword&r dengan &5Smite&r (semakin tinggi level, semakin baik). \\n\\nTerakhir, lempar &bSword&r ke &3Lake&r dan akan menemukan &e&lCaliburn&r di dasarnya!"]
	quest.03DCDFB32CD4BD85.title: "&e&lCaliburn"
	quest.03E05018D64DDEE1.quest_desc: ["&eTier 5&r pada dasarnya hanya untuk menambang Bijih Allthemodium, tidak banyak kegunaan lainnya."]
	quest.03E05018D64DDEE1.title: "&eHarvest Tier 5"
	quest.03E6FA4DCB71162E.quest_desc: ["&bColor Applicator&f adalah alat bertenaga baterai yang memungkinkan pewarnaan kabel langsung di dunia. Alat ini berfungsi sebagai &estorage cell&f khusus yang diisi dengan pewarna vanilla atau &epaint ball&f, serta &esnowball&f untuk membersihkan warna dan mengembalikan kabel ke varian Fluix.\\n\\nMewarnai satu bagian kabel membutuhkan 100AE, dengan total 3400 segmen kabel dalam satu kali pengisian daya."]
	quest.03E6FA4DCB71162E.title: "Color Applicator"
	quest.03ED9B0DFE8B4574.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kabut Pikiran"
		"- Membingungkan"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.041365A540BF5A03.quest_desc: ["&7Dictionary&r ini nggak terlalu berguna buat pemain biasa: dia nggak bisa nambang, naruh blok, crafting, bakar, atau interaksi sama apa pun. \\n\\nTapi kegunaannya itu buat cari Tag! \\n\\nKita bisa Klik Kanan sebuah blok pakai &7Dictionary&r dan Tag blok itu bakal muncul di chat. Kita bisa lakuin hal yang sama ke Entity. \\n\\nMasih kurang? Kita juga bisa Shift Klik Kanan buat buka &7Dictionary&r kita! \\n\\nDi sini kita bisa lihat item di inventory dan cek semua tag yang beda-beda. Dari Tag Item, Potion, sampai Tag Enchantment, nggak ada yang bisa sembunyi dari &7Dictionary&r!"]
	quest.041365A540BF5A03.title: "&7Dictionary"
	quest.041CDB45450A67E0.quest_subtitle: "Padukan (Alloy) Telur Spawn Platinum Bee dengan Telur Spawn Ancient Bee"
	quest.041CDB45450A67E0.title: "Duratium Bee"
	quest.041D16DA96BC4253.quest_desc: [
		"&e&lPollinated Pillar&r adalah apa yang menghubungkan &e&lPollinated Fields&r ke &6&lHive Walls&r. \\nMereka adalah campuran yang pas dari keduanya! Dinding &6Madu&r curam yang besar sekaligus berlapis &eSerbuk Sari (Pollen)&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_pollenpillar.png width:200 height:100 align:center}"
	]
	quest.041D16DA96BC4253.title: "&e&lPilar Serbuk Sari"
	quest.041ED280691BB05D.quest_desc: ["&9Froststeel&r adalah bijih (Ore) yang umum ditemukan di biome dingin dalam dimensi &2&lUndergarden&r. "]
	quest.041ED280691BB05D.quest_subtitle: "18"
	quest.041ED280691BB05D.title: "&9Froststeel Armor"
	quest.0436DF3308681913.quest_desc: [
		"Duduk di Tahta tergeletak sisa-sisa &4&lRaja&r masa lalu. Tapi begitu kamu mendekat dan menyentuh mereka, kamu akan melihat mereka bangkit kembali; &4&lRaja&r tidak lagi mati! Tapi hanya pembunuhan yang akan membuatnya tetap hidup... dan kamu adalah makhluk hidup terdekat. \\n\\n&4&lThe Dead King&r adalah Boss tersulit, dia punya 400 &cHeart&r dan satu-satunya yang punya Boss Bar (dan musik). Dia bisa pakai berbagai &3Spell&r dari kelas mana pun, &2Poison Arrow&r dari &2Nature&r sampai &6Blight&r dari &6Holy&r bahkan &aFang&r dari &aEvokation&r! Dia juga bisa teleport, memanggil yang mati, dan memukulmu dengan &4Blood Staff&r. \\n\\nKalau kamu bisa membunuhnya dia akan menjatuhkan &3Scroll&r berbagai jenis, &7Blank Rune&r, dan mungkin menjatuhkan &4Blood Staff&r dan Necronomicon."
		"{image:atm:textures/questpics/iron_spells/spells_king.png width:100 height:200 align:center}"
	]
	quest.0436DF3308681913.title: "&4&lThe Dead King"
	quest.04440BB2EFFD6DD9.quest_desc: ["Di kedalaman Labirin Rawa terdapat seekor &cMinoshroom&r raksasa.\\n\\nSetelah dikalahkan, ia akan menjatuhkan &eMeef Stroganoff&r. Untuk membuka area selanjutnya, kamu harus memakannya."]
	quest.04440BB2EFFD6DD9.title: "&cMeef Stroganoff yang Perkasa"
	quest.0447551EF7FB171B.quest_desc: ["Gak perlu processing lagi, ini bukan Tes &4Darah&r, ini cuma fuel! \\n\\nCukup Pipe &4Pedestal&r ke &c&lForge&r dan liat &4Darah&r mengalir!"]
	quest.0447551EF7FB171B.title: "&4Blood"
	quest.0450060852F290CA.quest_desc: [
		"&9Deeplands&r paling mirip dengan &3Deep Dark&r. \\n\\nTempat ini penuh dengan &3Sculk &fbeserta &3Shriekers &fdan &3Sensors&r, yang ya masih bisa memunculkan &9&lWarden&r. \\n\\nDi sini kamu juga akan menemukan lebih banyak &3Makhluk Sculk&r dan Tanaman, bahkan satu-satunya Struktur yang dimiliki &3&lOtherside&r!"
		"{image:atm:textures/questpics/deepndark/dnd_land.png width:200 height:100 align:center}"
	]
	quest.0450060852F290CA.title: "&9Deeplands"
	quest.0460DDEEFDEB0AAF.quest_desc: ["Divination Rod adalah alat yang kita gunakan untuk menghubungi roh guna menemukan item tertentu. \\n\\nPertama, kamu perlu memilih Blok atau Item dengan cara Shift+Klik Kanan pada blok tersebut menggunakan Rod, atau men-craft Rod tersebut bersama &eAlchemical Sulfur&r-nya!\\n\\nDengan memegang dan menahan Klik Kanan, Rod akan mencari item yang dipilih. Alat ini akan mengeluarkan suara dan menyala tergantung seberapa dekat posisi blok atau item tersebut. \\n\\nJika sudah cukup dekat, sebuah bola cahaya akan muncul menunjukkan jalan menuju item tersebut."]
	quest.0460DDEEFDEB0AAF.title: "Tongkat Divinasi"
	quest.0465094C2D31B898.quest_subtitle: "Iron + Creebee"
	quest.0465094C2D31B898.title: "Uraninite Bee"
	quest.04665EFC3A37250E.quest_desc: ["Kalahkan 8 &7Silverfish&r."]
	quest.04695DA1BD3BF1B2.title: "Chaotic Damage Module"
	quest.046C417B2ADF3AA7.quest_desc: ["Kartu memiliki batasnya sendiri. Item Extraction hanya bisa mengambil 8 item per Operasi. Fluid Extract hanya 5 Bucket. Entahlah kalau Chemical dan Energy. \\n\\nIni adalah &2&lMinecraft&r Modded, batas ini tidak akan cukup sehingga kita perlu melakukan Overclock. \\n\\nMasukkan beberapa Overclocker di pojok kanan atas Kartu dan itu akan meningkatkan kapasitas transfernya!"]
	quest.046C417B2ADF3AA7.quest_subtitle: "Maks: 4"
	quest.0474C15D3AE3C2C9.quest_desc: ["&cDecrepit Scythe&r adalah senjata yang digunakan &c&lEcho of Tyrus&r untuk Membunuhmu. Versi kita jauh lebih kecil. \\n\\nStatnya sangat mirip dengan &5Decrepit Flamberge&r, cuma Attack Speed-nya sedikit, maksudku sedikit banget, lebih cepat. \\n\\nIni juga bisa di-upgrade dengan &6Pyrium&r, ini akan memberinya lebih banyak Damage plus &3Spell&r! \\n\\n&3Spell&r yang didapat &cHellrazer&r adalah &cRaise Hell&r. Ini akan mengirim Gelombang &cApi&r ke semua arah di sekitarmu. Ini tidak akan menyebar &cApi&r tapi akan memberikan Damage besar ke semua Mob di dekat!"]
	quest.0474C15D3AE3C2C9.title: "&cDecrepit Scythe"
	quest.047F3F99035CE623.quest_subtitle: "Jiwa penambangku meronta-ronta"
	quest.0480DF316ACF12DA.quest_subtitle: "Western Hemlock + Jungle"
	quest.0481E975F317F64D.quest_desc: ["&bNaga Es&f butuh &bEs&r, &cNaga Api &fbutuh &cApi&r, terus &5Telur Naga Petir&r butuh apa? Ditinggal di luar pas Hujan! \\n\\nEh tunggu beneran gitu? \\n\\nTinggal taro &5Telur Naga Petir&r di tanah yang kena &bLangit&r, terus pas Hujan dia bakal mulai Menetas. \\n\\nSetelah 6 Menit Hujan terus-terusan, &5Petir&r bakal Nyamber &5Telur&f-nya dan &5&lNaga Petir&r bakal Menetas. \\n\\n&5Petir&r-nya bisa nyalain &cApi&r, yang bisa Nyakitin &5&lBayi&r-nya, jadi hati-hati ya!"]
	quest.0481E975F317F64D.title: "Tinggalin &5Telur&r kamu pas Hujan"
	quest.0484051446480B54.quest_desc: ["Menghasilkan damage yang besar dan menebang pohon dengan sangat cepat! Apa lagi yang kamu butuhkan?"]
	quest.0484051446480B54.title: "&6Allthemodium &5Alloy &3Axe"
	quest.0496E8E786262464.quest_desc: ["Apa aku benar-benar perlu menjelaskan tentang &2Overworld&r padamu?"]
	quest.0496E8E786262464.title: "&2Overworld&r: Tanah dengan &m3 4&r 5 Bos"
	quest.0498A578D0EC3254.quest_desc: ["Item terakhir yang penting dari hasil Infused adalah &aBasic Control Circuit&r. \\n\\nIni dibuat dengan gabungin 20mB &4Redstone&r sama satu &7Osmium Ingot&r. \\n\\nCek &cQuest Infused Alloy&r buat tahu cara masukin &4Redstone&r ke &9&lMetallurgic Infuser&r!"]
	quest.0498A578D0EC3254.quest_subtitle: "Basic Control Circuit"
	quest.0499A372F55D04C8.title: "Draconic Projectile Velocity Module"
	quest.04A1D582003A0D9A.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kecepatan Lari"
		"- Kecepatan Jalan"
	]
	quest.04A7AA70C23830FF.quest_desc: ["Sabit adalah alat yang bisa dipakai buat ngebebasin material organik dalam jumlah banyak. Sabit bisa ngebantu ngehancurin blok di area sekitar blok yang kamu tambang."]
	quest.04B31A600004F7CB.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.04B40BB107F14330.quest_desc: ["&4Meat Shredder&r adalah senjata jarak dekat yang bisa kamu buat dari &4Witherite&r. \\n\\nIa memiliki dua jenis serangan, menggunakan Klik Kiri atau Klik Kanan. \\n\\nSaat Klik Kiri, kamu akan menggunakannya seperti Kapak, menebas musuh satu kali dari jarak yang cukup jauh. \\n\\nSaat Klik Kanan, gergajinya akan terus mencabik-cabik musuh, memberikan damage yang jauh lebih cepat dari jarak dekat."]
	quest.04B40BB107F14330.quest_subtitle: "Mirip dari Fallout 3 DLC The Pitt"
	quest.04B40BB107F14330.title: "&4Meat Shredder"
	quest.04B6E31120663EB2.quest_subtitle: "Tingkat: &a2"
	quest.04BE9F63E6003475.quest_desc: ["&3LPG&r dapat digunakan untuk membuat Molten Plastic (Plastik Cair)."]
	quest.04BE9F63E6003475.quest_subtitle: "Yang kita butuhkan"
	quest.04BE9F63E6003475.title: "LPG"
	quest.04BF68E4554D69AA.quest_desc: [
		"Terakhir dan yang terbaik, Tier 8! Kamu butuh 378 Awakened Draconium Blocks dan 786 Draconium Ingot Blocks! Apakah sepadan?"
		"{image:atm:textures/questpics/draconic/draconic_core_8off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_8on.png width:100 height:100 align:1}"
	]
	quest.04BF68E4554D69AA.quest_subtitle: "Menyimpan: Hampir Tak Terbatas"
	quest.04BF68E4554D69AA.title: "Tier 8"
	quest.04D0543FE2820F64.quest_desc: ["Flax String bisa dipakai sebagai pengganti String biasa."]
	quest.04D0543FE2820F64.quest_subtitle: "Siapa butuh Laba-laba?"
	quest.04D0543FE2820F64.title: "Flax String"
	quest.04D9F6587EF8D9B7.quest_desc: ["&9Potion Jar&r dapat menyimpan hingga 100 ramuan (potion). Kamu bisa mengambilnya menggunakan botol kosong atau potion flask pada toples tersebut. \\n\\nWixie akan menggunakan toples ini saat melakukan Pembuatan Ramuan Otomatis (Potion Autocrafting)."]
	quest.04D9F6587EF8D9B7.quest_subtitle: "Menyimpan Ramuan"
	quest.04DD3F761C210822.quest_desc: [
		"&c&lTungku Blast Sederhana&r adalah cara paling sederhana (dan kasar) untuk memproduksi &8Baja&r. \\n\\nKamu perlu memberinya &7Batang Besi&r dan &0Arang&r atau &0Kokas&r. \\n\\nSetiap &8Batang Baja&r membutuhkan waktu 60 detik untuk dipanggang. &0Arang&r memberikan 15 detik sedangkan &0Kokas&r memberikan 60 detik penuh. Ini juga bisa dikalikan dengan bentuk Blok mereka. \\n\\nKita juga mendapatkan Terak... tidak terlalu berguna."
		"{@pagebreak}"
		"Ini adalah 3x3x3 lainnya, sekarang dengan &cBata Blast&r."
		"{image:atm:textures/questpics/immersive/immersive_crude1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_crude2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_crude3.png width:100 height:100 align:center}"
		"Sekali lagi Klik Kanan pada Blok Tengah Depan dengan &6Palu&r andalan kita!"
		"{image:atm:textures/questpics/immersive/immersive_crude.png width:100 height:100 align:center}"
	]
	quest.04DD3F761C210822.title: "&l&cTungku Blast Sederhana"
	quest.04DEC6E210F06D65.quest_subtitle: "Balsa + Cocobolo"
	quest.04F5846E2468E807.quest_desc: ["&b&lMacaw's Doors&r menambahkan berbagai macam Pintu dan varian pintu lainnya. \\nKamu ingin desain Ek (Birch) tapi dengan kayu Spruce? Tentu bisa! \\n\\nBahkan mod ini punya Pintu Rumah Sakit!"]
	quest.04F5846E2468E807.title: "&b&lMacaw's Doors"
	quest.05056CAA64E3971B.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Membuat anak panah yang ditembakkan oleh busur memberikan efek ramuan berdasarkan Tabung Ramuan kamu."
	]
	quest.050CCE5D1DD6B21E.quest_desc: [
		"Salah satu &lMutliblock&r paling penting, terutama karena kita butuh ini untuk &lMultiblock&r lainnya. \\n\\nDi sini kamu butuh &bFluid Input&r (setiap &bInput&r cuma bisa nampung 1 jenis &bFluid&r jadi kamu butuh beberapa), &cEnergy Input&r, serta hatch &eItem Input&r dan Output. \\n\\nPakai Hatch tersebut untuk memasukkan semua &eItem&r, &bFluid&r, dan &cEnergy&r, dan alat ini bakal membuat item kita, mirip kayak &5Multiblock Controller&r lainnya! \\n\\nAtau buat item yang dibutuhin untuk &6Star Parts&r! Kamu bakal butuh banyak &4Blood&f, &bAureal&f, Souls, dan &cEnergy&r untuk itu!"
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap3/creative_forge1.png width:150 height:100 align:center}"
		"Lapisan pertama cukup simpel. Cuma beberapa &9Polished Darkstone Block &fdan &9Stairs&r. Barengan sama &7Rune Blocks&r dan &6Arcane Polished Darkstone&r. Oh tunggu, hampir lupa blok paling pentingnya! &5Forge Block&r."
		"{image:atm:textures/questpics/chap3/creative_forge2.png width:150 height:100 align:center}"
		"Lapisan berikutnya bakal punya lebih banyak &9Darkstone&r dalam bentuk &9Block&f, &9Stair&f, dan &9Slab&r, bahkan ada &6Gilded Arcane Polished Darkstone&r dan &6Chiseled Polished Arcane Darkstone&r. Jangan lupa 4 &bArcane Crystal Obelisk&r-nya!"
		"{image:atm:textures/questpics/chap3/creative_forge3.png width:150 height:100 align:center}"
		"Yang ini gampang banget! Cukup taruh &9&lTier 5 &6Forge&r tepat di tengah dengan 8 &6Darkstone Pedestal&r berjarak 2 blok di sekitarnya."
		"{image:atm:textures/questpics/chap3/creative_forge4.png width:150 height:100 align:center}"
		"Kita lewati satu lapisan karena nggak ada tambahan apa-apa di sana! Sebagai gantinya, beri jarak satu blok kosong, lalu pasang &7Quantum Injector&r di atas &9&lTier 5 &6Forge&r. "
		"{image:atm:textures/questpics/chap3/creative_forge5.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/chap3/creative_forge6.png width:200 height:100 align:center}"
		"Terakhir, pasang beberapa Hatch lagi! Kita bakal butuh banyak!"
	]
	quest.050CCE5D1DD6B21E.title: "&c&lAutomatic Hephaestus Forge"
	quest.050CD33E92601651.quest_desc: [
		"&c&lTier 1&r gak cukup buat kamu? Kalau gitu, kamu perlu upgrade! \\n\\nTaruh Edelwood Plank di Slot tengah &6&lForge&r dan taruh 4 &bArcane Crystal&r dan 4 Spawner Scrap ke Pedestal. \\n\\nPukul dengan Gavel dan &c&lTier 1&r kamu akan upgrade jadi &3&lTier 2 &6Forge&r! \\n\\nSekarang, Ritual baru akan tersedia, &6&lForge&r bisa tahan lebih banyak Essence, dan kamu bisa pakai Relic kedua!"
		"{image:atm:textures/questpics/forbidden/forbidden_tier1.png width:100 height:100 align:center}"
	]
	quest.050CD33E92601651.title: "&l&3Tier 2 &6Forge"
	quest.050D8480EE9D8E62.quest_desc: [
		"Wigglewood Forest adalah hutan seperti hutan lainnya. \\n\\nHanya saja pohon-pohon di sini suka tumbuh sesuka hati."
		"{image:atm:textures/questpics/undergarden/undergarden_wiggle.png width:200 height:100 align:center}"
	]
	quest.050D8480EE9D8E62.title: "Wigglewood Forest"
	quest.05113AC92BC1B192.quest_desc: [
		"&a&lHydra&r adalah salah satu monster paling tangguh yang ditawarin &b&lIce &fdan &cFire&r. \\n\\nMereka bisa Hijau, Teal, atau Merah. Semuanya Kadal Berkepala 3 tanpa tangan atau kaki. \\n\\n&a&lHydra&r punya lebih dari 450 &4Hearts&r tapi cuma 2 &7Armor Points&r. \\n\\nMereka punya lumayan banyak Serangan, yang paling simpel ya Gigitan. Mereka juga bisa pake &aNapas Racun&r di depan mereka, mirip kayak &dNapas Naga&r. Yang paling bahaya itu pas mereka pake &aBisa&r-nya, yang bikin Serangan lain mereka sekarang kasih efek &aRacun&r! \\n\\nPas kena Damage yang cukup banyak, &a&lHydra&r bakal kehilangan Kepala. Kecuali mereka lagi &cTerbakar&r, Kepala yang hilang bakal numbuh 2 lagi. Makin banyak Kepala, makin besar Damage yang mereka bisa kasih... ayo kita cegah itu! Karena Regenerasi itu juga mereka sembuh dari hampir semua Damage yang mereka terima, jadi kamu pasti butuh &cApi&r! \\n\\nNgomong-ngomong, mereka bisa punya sampai 9 Kepala. Udah gue bilang bawa &cApi&r kan?"
		"{image:atm:textures/questpics/iceandfire/iaf_hydra.png width:200 height:100 align:center}"
	]
	quest.05113AC92BC1B192.title: "&a&lHydra"
	quest.0518551637F76C50.quest_desc: ["Untuk upgrade &9Echoing&r, kita butuh beberapa item berbeda. \\n\\nLilin (Candle) yang relatif mudah didapat, dan &9Echo Shard&r... yang jelas-jelas sulit dicari... \\n\\nKesempatan terbaik mendapatkannya adalah dengan menjarah &6Ancient City&r, tapi kamu bisa men-craft-nya dengan beberapa Ritual berbeda. \\n\\n(Atau nanti bisa lewat &5Enchanting&r!) \\n\\n&9Echoing Deepshelf&r memberikan jauh lebih banyak &5Arcana&r sebesar &515%&r! Serta meningkatkan batas maksimal &aEterna&r menjadi &a75&r."]
	quest.0518551637F76C50.title: "&9Echoing Deepshelf"
	quest.051E0C85E7B71CE0.quest_desc: ["Sudah keluar mining kan? Ini MINEcraft kok.\\n\\nBakal nemuin banyak ore baru yang mungkin bikin bingung, tapi tetap bisa pakai material vanilla untuk memulai!\\n\\nCopper sangat banyak dan punya banyak kegunaan untuk hal seperti &aOre Hammer&r atau &eDrawer Upgrade&r, jadi pastikan ambil banyak!\\n\\nIron mungkin salah satu ore terpenting yang harus diambil setiap kali ketemu. Dunia modded MC pada dasarnya berjalan dengan Iron."]
	quest.051E0C85E7B71CE0.title: "Zaman &9Metal&r"
	quest.052BE1D845794702.quest_subtitle: "Teak + Acacia"
	quest.052E261F934AB439.quest_desc: ["Juga bisa membuat Pathways!"]
	quest.052E261F934AB439.title: "Chaotic Shovel"
	quest.053483E3349B2F8A.quest_desc: [
		"Struktur ini mirip dengan Taman Gantung, tapi hanya ada satu taman dan ukurannya masif. Kamu akan tahu ini &bBlue Sempiternal Sanctum&r dari warna &bBiru&r pada &bLuminescent Ancient Wax&r. \\n\\nMasuklah ke struktur ini dan ikuti jalan ke ruangan paling bawah (hati-hati dengan Sentry Watcher), di sana kamu akan menemukan &bBlue Essence&r. \\n\\nMasuklah ke dalamnya dan bersiaplah menahan napas. Kamu harus melawan gerombolan Drowned, Guardian, dan Elder Guardian di bawah air. Setelah semuanya mati kamu akan mendapatkan..."
		"{image:atm:textures/questpics/bumblezone/bumble_blue1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_blue2.png width:200 height:100 align:center}"
	]
	quest.053483E3349B2F8A.title: "&bBlue Sempiternal Sanctum"
	quest.0539AF15A10B2859.quest_desc: ["&lCompact Machines&r memungkinkanmu masuk ke dalam dimensi yang dipadatkan. Setelah meletakkan &lCompact Machine&r, kamu bisa masuk ke dalamnya menggunakan Personal Shrinking Device.\\n\\nUkuran &lCompact Machine&r bergantung pada resepnya, mulai dari 5x5x5 hingga 45x45x45!\\n\\nKamu tidak bisa menghancurkan dinding &lCompact Machine&r, dan kamu bisa keluar dengan Klik Kanan menggunakan Personal Shrinking Device."]
	quest.0539AF15A10B2859.title: "&lCompact Machines"
	quest.05422E444126FDA6.quest_subtitle: "Iron + Blaze"
	quest.05422E444126FDA6.title: "Crimson Iron Bee"
	quest.05428EA120583BD0.quest_subtitle: "Dibuat dengan Energizer"
	quest.05428EA120583BD0.title: "Nitro Crystal Bee"
	quest.0542FE108089A0A2.quest_desc: ["&l&6Theurgy&r adalah seni menggunakan sihir untuk Alkimia! Atau dalam artian kita menggunakan mesin dan item untuk memproduksi lebih banyak item atau mengubahnya menjadi item lain! \\n\\nBanyak mesin yang kita butuhkan untuk &l&6Theurgy&r memerlukan Tembaga (Copper), jadi mulailah dari sana!"]
	quest.0542FE108089A0A2.title: "&l&6Theurgy"
	quest.054F3A0499F8A0D8.quest_subtitle: "Sweet Chestnut + Capoazu"
	quest.055CCAE237DF3EEF.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_ironwood.png width:100 height:150 align:center}"]
	quest.055CCAE237DF3EEF.title: "&8Ironwood"
	quest.056E1E3B1ED14917.quest_subtitle: "Teak + Dark Oak"
	quest.0573B6F1BE5110FD.quest_desc: ["Lebah &2&lMinecraft&r itu lucu banget tapi hal terbatas yang Honey kasih ke kita gak cukup buat justifikasi kerja keras dapetin itu. \\n\\nYa kecuali kamu bisa dapetin hampir apapun dari Lebah, itu baru beda cerita!"]
	quest.0573B6F1BE5110FD.title: "&e&lProductive Bees&r"
	quest.0576C32B0FB360B0.quest_desc: [
		"Lunar Monstrosity punya 200 Heart dan cuma bakal kena 1 damage dari setiap hit kecuali kamu pake Api. \\n\\nDia punya beberapa serangan termasuk Ground Spike, Proyektil, dan Tangled Head yang meledak! \\n\\nKalau kamu bunuh dia, dia bakal drop Arrow, Ingot, Tangled Skull, Tenacious Petal, Trapped Soul, dan kemungkinan Senjata langka!"
		"{image:atm:textures/questpics/eternal/starlight_lunar.png width:100 height:125 align:center}"
	]
	quest.0576C32B0FB360B0.title: "Lunar Monstrosity"
	quest.0583862ED0114442.quest_subtitle: "&f4 &cAttack Damage"
	quest.0584073A7383E0EA.quest_desc: [
		"Beberapa misi &5Ratu Lebah (Queen Bee)&r mungkin terasa menyebalkan karena tidak banyak tempat untuk farm &dEndermite&r dan &7Silverfish&r. \\n\\nNah, itu dulu sebelum update terbaru! Selamat datang di Benteng Tungau (Mite Fortress)! \\n\\nDi struktur &7Batu&r besar yang runcing ini kamu akan menemukan &7Silverfish&r berlimpah (plus loot, terutama di dalam &5Obsidian&r). \\n\\nDi tengah struktur, dengan segalanya berwarna &5Ungu&r, akan ada &dEndermite&r. \\n\\nNgomong-ngomong, tahukah kamu kalau &8L&6e&8b&6a&6h&r akan menyerang &dEndermite&r dan &7Silverfish&r! Majulah berperang bersama mereka untuk memenangkan hati &5Ratu&r mereka!"
		"{image:atm:textures/questpics/bumblezone/bumble_mite.png width:200 height:100 align:center}"
	]
	quest.0584073A7383E0EA.title: "Benteng Tungau"
	quest.05850541675B2493.quest_desc: ["Iya. \\n\\nKamu udah bikin &6&lATM Star&r, itu artinya kamu udah ngebeatin modpack ini!\\n\\nJadi apa selanjutnya?"]
	quest.05850541675B2493.quest_subtitle: "Ini berarti kamu menang?"
	quest.05850541675B2493.title: "&6&lATM Star"
	quest.0589911EB4D30FAD.quest_desc: ["&l&cRegions Unexplored&r juga menambahkan kemampuan bagimu untuk mengecat Papan Kayu (Plank) seolah-olah itu adalah Wol atau Kaca!"]
	quest.0589911EB4D30FAD.title: "Papan Kayu Berwarna"
	quest.0591CAFD665CE151.quest_subtitle: "Tingkat: &b4"
	quest.0596F6C70758EEC0.quest_desc: ["Meskipun paling mahal, blok ini juga yang paling indah! \\n\\nDan itulah yang terpenting untuk sebuah bangunan!"]
	quest.05A4496705B6C6AF.quest_desc: [
		"Beehemoth adalah &6L&8e&6b&8a&6h&r unik yang lebih mirip dengan Kuda Terbang Liar. \\n\\nMereka bisa dijinakkan dengan memberi mereka makan &6Madu&r cair baik dalam Botol maupun Ember. \\n\\nMereka memiliki tingkat pertemanan yang menentukan apakah mereka sudah jinak, seberapa cepat mereka terbang, dan berapa banyak HP yang mereka miliki! Memberi makan akan meningkatkan level, sedangkan jika terkena damage levelnya akan turun. \\n\\nSetelah tingkat pertemanan maksimal, mereka akan menjadi &5Queen Beehemoth&r! \\n\\nMereka akan mengikuti &6Ember Madu&r seperti sapi mengikuti gandum (coba juga gunakan Royal Jelly pada mereka). "
		"{image:atm:textures/questpics/bumblezone/bumble_beehemoth.png width:100 height:100 align:center}"
	]
	quest.05A4496705B6C6AF.title: "Beehemoth"
	quest.05B0A7D0B991050F.title: "Reaktor (Hardened)"
	quest.05B5E640F1B68A28.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_golem.png width:100 height:150 align:center}"]
	quest.05B5E640F1B68A28.title: "&3Golem Steel&r"
	quest.05B6DB75AEC01187.quest_desc: ["RFTools Power memiliki &9Powercells&r untuk menyimpan daya, yang merupakan unit penyimpanan multi-blok yang dapat dikustomisasi dan ditingkatkan.\\n\\nKamu akan membutuhkan Wrench untuk menentukan sisi input (masuk) dan output (keluar) daya."]
	quest.05B6DB75AEC01187.title: "&9RFTools Power: &cPowercells"
	quest.05D8C6EF8FCD6250.quest_desc: [
		"Lendir Primogel adalah tingkat pertama dari lendir yang ditambahkan oleh JDT dan membutuhkan material dasar Dunia Atas untuk kerajinan."
		""
		"Kerajinan yang Terbuka:"
		"- Ferricore"
		"- Batu Bara Purba"
		""
		"Contoh Penyebaran Lendir:"
		""
		"{image:atm:textures/questpics/justdirethings/goo_spread_ferricore.png width:200 height:200 align:center}"
	]
	quest.05DA7F48E2A1B77F.quest_desc: ["Kenalan sama &a&lRobit&r! Dia Temen Robot baru lo! \\n\\nTaro dia di &aChargepad&r buat set jadi Rumahnya! Ini penting soalnya &a&lRobit&r butuh &aEnergi&r buat jalan sama kerja. Dia bisa nyimpen 40kFE. \\n\\nKita bisa Klik Kanan dia buat buka GUI-nya (dengan izinnya tentunya!). Di tengah ada Layar yang ngajarin kita fakta tentang dia: Namanya, &aEnergi&r-nya, Pekerjaannya, sama Pemiliknya! \\n\\nDi kiri ada beberapa Tombol. Dari Atas ke Bawah: Teleport Home bakal bawa dia ke &aChargepad&r-nya, Rename buat ganti Nama Mob-nya, sama Appearance buat kosmetik &a&lRobit&r! \\n\\nDi bawah &aEnergy Slot&r ada Tombol buat set Pekerjaannya. Pickup: bikin &a&lRobit&r ngambil &eItem&r dari tanah terus taro di Inventory-nya. Follow: bikin &a&lRobit&r ikutin lo atau berhenti di tempat dia. \\n\\nDi kanan banget, ada Tombol lagi! Yang pertama, bakal munculin menu utama &a&lRobit&r. Crafting bakal buka Crafting Table di dalam &a&lRobit&r! Inventory bakal buka Inventory &a&lRobit&r. Di sini lo bisa nyimpen &eItem&r atau tempat &eItem&r yang diambil. Smelting bakal pake &aEnergi&r buat Smelt &eItem&r kayak Furnace. Repairing bakal bikin lo gabungin dua &eItem&r buat Repair Durability-nya."]
	quest.05DA7F48E2A1B77F.title: "&a&lRobit"
	quest.05DBDD86FCFF3BA8.title: "&5Lightning&r Upgrade Orb"
	quest.05DE9E1CDFBC22DE.quest_desc: ["&dVoid Scatter Arrow&r dibuat dengan Spectral Arrow dan &dVoid Jaw&r. \\n\\nBisa ditembakkan oleh Busur atau Crossbow mana pun. Saat mengenai mob atau blok, anak panah ini akan pecah berkeping-keping. \\n\\nSaat pecah, banyak serpihan akan terlempar di sekitar area, melukai apa pun yang terkena!"]
	quest.05DE9E1CDFBC22DE.title: "&dVoid Scatter Arrow"
	quest.05E668CE6687AC64.quest_desc: ["&bToken of Joy&r adalah Token pertama yang harus kamu buat. Token merupakan material crafting penting untuk item-item di &aNature's Aura&r."]
	quest.05E668CE6687AC64.title: "&bToken of Joy"
	quest.05F428C34DD00B61.quest_subtitle: "Blue Yonder + Rippling Willow"
	quest.05F8458AB4A6950B.quest_subtitle: "Berikan Voidshimmer Goo ke Diamond Bee"
	quest.05F8458AB4A6950B.title: "Celestigem Bee"
	quest.06044B4452A6B720.quest_desc: ["Saat diletakkan di biome Gurun (Desert), Sand Nest akan menarik Chocolate atau Ashy Mining Bee."]
	quest.06044B4452A6B720.quest_subtitle: "Memancing lebah di biome Gurun"
	quest.06094615950AC062.title: "Upgrade Conveyor Lainnya"
	quest.061A51A0EC13CA0F.quest_desc: ["Sekarang setelah kita punya &aController&r, &bDrains&r, dan &4Tanks&r, kita butuh beberapa blok lagi. \\n\\nPertama adalah &6Liquid Heating Coil&r. Blok ini akan menjadi lantai dari &c&lFoundry&r dan dibutuhkan untuk memanaskannya. \\n\\nTerakhir adalah &c&lFoundry Window&r atau &cFire Brick&r. Blok-blok inilah yang akan kita gunakan untuk sisa strukturnya! Secara harfiah adalah blok bangunannya. \\n\\n&c&lFoundry&r tidak membutuhkan kerangka luar, jadi setiap sudut bisa dibiarkan kosong; tetapi ia harus memiliki 4 dinding dan lantai agar selesai. &aController&r akan memberitahumu jika ada blok yang hilang. \\n\\n&c&lFoundry&r bisa berukuran sekecil 1x1 di bagian dalam, asalkan memiliki &aController&r, &6Liquid Heating Coil&r, dan dinding lainnya terisi! \\n\\nAku tidak menyarankan membuatnya sekecil itu, karena semakin besar &c&lFoundry&r, semakin banyak ruang penyimpanan di dalamnya! \\n\\nKamu tahu &c&lFoundry&r sudah terbentuk saat &aController&r menyala seperti tungku dan &6Liquid Heating Coil&r berubah warna menjadi &6Oranye&r."]
	quest.061A51A0EC13CA0F.title: "Membangun &c&lFoundry&r"
	quest.06210B6FD0F9989B.quest_desc: ["&d&lUltimate Tier&r adalah yang paling bagus yang bisa kita dapat dari &5&lMekanism&r! Ya setidaknya di Survival. \\n\\nIni bakal kasih slot paling banyak, nampung paling banyak &eItem&r, dan mindahin paling banyak &eItem&r! \\n\\nSetiap &d&lUltimate Tier&r butuh &dAtomic Alloy&f, &dUltimate Control Circuit&f, dan &bDiamond&r. \\n\\n&dAtomic Alloy&r butuh &5Refined Obsidian&r buat bikinnya, ikuti &7Quest Osmium Compressor&r buat dapat itu. Tapi intinya kita perlu Infuse &bReinforced Alloy&r pakai 20mb &5Refined Obsidian&r. \\n\\nTerus, gabungin 2 &dAtomic Alloy&r sama 1 &bElite Control Circuit&r buat bikin &dUltimate Control Circuit&r!"]
	quest.06210B6FD0F9989B.title: "&d&lUltimate Tier"
	quest.062AA943A1629A86.quest_desc: ["Kamu meledakkan &zRainbow Furnace&r?!?! Langsung pasang TNT di sebelahnya? Gila ya? Itu butuh banyak Furnace dan resources terus kamu ledakkan aja!!! Setidaknya dapat yang bagus kan? &zRainbow Coal&r? Batu bara yang tahan lama banget? Oke sih sebenernya worth it juga."]
	quest.062AA943A1629A86.title: "&zRainbow Coal"
	quest.063241B72BB3403E.quest_desc: ["&0&lPerisai Berlapis Berat&r digunakan seperti Perisai normal, pegang di Tangan Kedua dan gunakan untuk bertahan. \\n&0&lPerisai Berlapis Berat&r memiliki Daya Tahan lebih banyak dan melindungi dari Kerusakan lebih besar. \\n\\nYa, dia juga punya Upgrade! Upgrade ini bisa ditambahkan dengan &6Meja Kerja Insinyur&r. \\n\\nPerisai bisa menampung 2 Upgrade."]
	quest.063241B72BB3403E.title: "&8&lPerisai Berlapis Berat"
	quest.0650996C7818ADB5.quest_desc: ["&6&lHeat Generator&r punya 2 mode buat hasilkan &aEnergi&r. \\n\\nPasif: Kelilingi &6&lGenerator&r pakai &cLava Source&r atau blok lava mengalir biar dapat &aEnergi&r pasif lewat &6Panas&r. \\n\\nTaruh satu &cLava Source Block&r di atas, terus biarin ngalir ke samping. \\n\\nPastikan sambungin &bPipes&r dulu ya!\\n\\nAktif: Masukin bahan bakar kayak &0Coal&r atau &6Kayu&r ke dalam &6&lGenerator&r nanti dia bakal bakar bahan bakarnya buat bikin &cEnergi&r. \\n\\nSekarang ini bisa hasilkan 320FE/t."]
	quest.0650996C7818ADB5.quest_subtitle: "Power Gen Dasar"
	quest.0650996C7818ADB5.title: "&6&lHeat Generator"
	quest.065196033249A0AA.quest_subtitle: "Padukan (Alloy) Raw Biopolymer dengan Telur Iron Bee"
	quest.065196033249A0AA.title: "Biosteel Bee"
	quest.0661E9669E639621.quest_desc: ["Beberapa bibit (sapling) tidak bisa diserbuksarikan. Bibit-bibit ini memiliki peluang acak untuk tumbuh menjadi pohon jenis lain.\\n\\nMisalnya, jika kamu ingin mendapatkan &4Red Crepe Myrtle Sapling&r, pertama tumbuhkan dulu Purple Crepe Myrtle Sapling. Kamu akan memiliki peluang untuk mendapatkan &4Red Crepe Myrtle Tree&r dari sana."]
	quest.0661E9669E639621.quest_subtitle: "Berkembang Biak Sendiri?"
	quest.066438B01655D866.quest_desc: ["Meskipun &dEssence&r mereka berguna, kita juga bisa tangkap Spirit ini buat dipake nanti. Kedengerannya jahat ya?\\n\\nBuat jadi Pemburu Spirit, kamu harus bikin &dVengeance Focus&r dulu. Ini dipake buat &aMembekukan Spirit&r di tempat, terus kamu taro &9Box of Eternal Closure&r deket Spirit. Ini bakal nyedot Spirit masuk buat dipake nanti."]
	quest.066438B01655D866.title: "Menangkap &dSpirit"
	quest.066B8A75B299AED8.quest_desc: [
		"&9&lPemeras&r adalah Mesin sederhana yang memeras &eBarang&r untuk membuat &eBarang&r atau &bCairan&r lain. \\n\\nKita bisa menggunakan 2 Port di Belakang untuk &9Memasukkan &eBarang&r. Kemudian perlu menggunakan Port di Sisi Kanan Tong untuk mengeluarkan &eBarang&r. Port di bawahnya akan &6Mengeluarkan &bCairan&r. \\n\\nIni terutama digunakan untuk memeras Minyak Tanaman dari Biji-bijian seperti Biji Gandum atau Biji Rami! \\n\\nBeberapa Biji memberikan lebih banyak Minyak, periksa &6Panduan&r untuk melihat apa yang diberikan masing-masing. \\n\\nKita juga perlu menggunakan &9&lPemeras&r untuk mendapatkan &0Debu Grafit HOP&r dari 8 &0Debu Kokas&r."
		"{@pagebreak}"
		"Persis sama dengan awal &2&lFermenter&r."
		"{image:atm:textures/questpics/immersive/immersive_squeezer1.png width:100 height:100 align:center}"
		"Sama seperti &2&lFermenter&r juga, hanya saja gunakan Tong bukan Kuali!"
		"{image:atm:textures/questpics/immersive/immersive_squeezer2.png width:100 height:100 align:center}"
		"Di atas Tong antara &eBlok Teknik Ringan&r dan &4Blok Teknik Redstone&r letakkan Piston. Di atas 3 Tong lainnya letakkan &8Pagar Baja&r!"
		"{image:atm:textures/questpics/immersive/immersive_squeezer3.png width:100 height:100 align:center}"
		"Sangat mudah, Klik Kanan &6Palu&r pada Tong di bawah Piston."
		"{image:atm:textures/questpics/immersive/immersive_squeezer.png width:100 height:100 align:center}"
	]
	quest.066B8A75B299AED8.title: "&9&lPemeras"
	quest.066F78936C8F943B.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Kontributor Komunitas&r buat dipake di AllTheMods Modpack. \\n\\nKarena semua pack &6AllTheMods&r dilisensiin dengan &eAll Rights Reserved&r, Quest ini gak boleh dipake di public pack manapun yang gak dirilis sama &6AllTheMods Team&r tanpa izin. \\n\\nQuest ini sengaja disembunyiin, kalo lo liat ini berarti lo lagi di mode editing."]
	quest.0672462DA3599484.quest_subtitle: "512,000mb"
	quest.06767BA0AFE8C1EE.quest_desc: ["1... 2... ada angka 4 juga di suatu tempat. \\n\\nUntuk mengatur Angka, masukkan Item lalu kamu bisa Klik Kiri atau Kanan untuk mengubah jumlahnya. Tahan Shift dan lakukan hal yang sama untuk mengubah per 10 angka. Setelah angkanya pas, masukkan ke dalam Kartu! \\n\\nAlat ini akan menunggu sampai jumlah Item tersebut tercapai sebelum mulai mengambilnya. Ia juga akan menyisakan jumlah tersebut di Inventaris pertama."]
	quest.067AB3E4C4492F0D.quest_desc: [
		"Malas menambang tumpukan bijih (ore) yang kamu punya? Kenapa tidak biarkan Router melakukannya untukmu? \\n\\nKamu bisa menggunakan Placer untuk meletakkan bijih, lalu biarkan Breaker yang sudah diberi mantra (Enchanted) untuk menambangnya. Breaker membutuhkan Beliung (Pickaxe) yang sudah diberi mantra saat proses crafting-nya, karena Module itu sendiri tidak bisa diberi mantra. \\n\\nKamu mungkin butuh Router lain untuk mengambil item yang jatuh."
		"{image:atm:textures/questpics/router/router_break.png width:150 height:80 align:center}"
	]
	quest.067AB3E4C4492F0D.title: "Router untuk Menambang"
	quest.068128395837AF4F.quest_subtitle: "Sama seperti versi uap"
	quest.068294A7C21DE550.quest_desc: ["&cTrack Kit&r digunakan bersama &6rel&r untuk membuat &6rel khusus&r. \\n\\nRel-rel ini akan membantu segala hal terkait &5Kereta&r seperti: menghentikan &5Kereta&r, menggerakkan &5Kereta&r, dan memancarkan sinyal redstone."]
	quest.068294A7C21DE550.title: "&c&lJalur Rel (Tracks)&r!"
	quest.0682DC1F2417DAEB.quest_desc: ["Functional Storage adalah mod penyimpanan yang menambahkan berbagai item berguna untuk membantu menyimpan tumpukan (stack) item yang sama.\\n\\nIni sangat berguna untuk item seperti Cobblestone, Tanah, dan lainnya."]
	quest.0682DC1F2417DAEB.quest_subtitle: "Saudara Jauh Storage Drawers"
	quest.0682DC1F2417DAEB.title: "Functional Storage"
	quest.0691BDE968724213.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.0691BDE968724213.title: "Vibrant Alloy Bee"
	quest.06A7A3FC8634D2DA.quest_subtitle: "Tingkat: &c5"
	quest.06AD25DB96F3A1CC.quest_desc: [
		"Seperti termometer, wadah ini menampung &cMercury&r! \\n\\nBaik dalam bentuk &cMercury Crystal&r maupun &cShard&r, wadah ini tetap menampung &cMercury&r."
		"{image:atm:textures/questpics/theurgy/theurgy_vessel_1.png width:100 height:125 align:center}"
	]
	quest.06AD25DB96F3A1CC.title: "Wadah &cMercury&r"
	quest.06B352AE90DD0D3E.quest_desc: ["&8BlazBee&r yang melakukan polinasi pada sebuah &4Obsidian Bee Spawn Egg&r akan mengubahnya menjadi &2Infinity Bee Spawn Egg&r."]
	quest.06B352AE90DD0D3E.title: "Bee Of Infinity"
	quest.06B6786122F3DAF9.quest_desc: ["Mempengaruhi waktu kerja lebah. Ada 3 tingkat: &aDiurnal&r, &dNocturnal&r, &cMetaturnal&r. Lebah &aDiurnal&r hanya bekerja siang hari, &dNocturnal&r hanya malam hari, dan &cMetaturnal&r bisa bekerja kapan saja. Kita mengincar &cMetaturnal&r. BeeBee secara alami memiliki sifat &cMetaturnal&r. Seperti disebutkan di quest &a&lProductivity&r, lebah ini ditemukan di dimensi The Other dan sangat mematikan.\\n\\nJika kamu tidak ingin berurusan dengan lebah berbahaya itu, ada pilihan lain. Kita bisa mengikat (leash) lebah ke pagar saat malam hari untuk membuatnya menjadi &dNocturnal&r, lalu membiarkan mereka terikat di pagar saat siang hari untuk membuatnya menjadi &cMetaturnal&r. Kita bisa melewati salah satu langkah ini dengan Ghostly Bee, yang secara alami bersifat &dNocturnal&r."]
	quest.06B6786122F3DAF9.quest_subtitle: "Tidur hanya untuk yang lemah"
	quest.06B6786122F3DAF9.title: "&e&lPerilaku (Behavior)"
	quest.06B85804163DD18B.quest_desc: ["Soaryn Box (Soaryn adalah pembuat mod XyCraft) adalah peti khas dari XyCraft.\\n\\nPeti ini tidak akan menjatuhkan isinya saat bloknya dihancurkan! Kira-kira apa ya fungsi kotak-kotak di atasnya?"]
	quest.06D13E319C26C949.quest_desc: [
		"Blood Mushroom Bog adalah rumah bagi Jamur Darah raksasa. \\n\\nDarah membuatku tidak nyaman, jadi aku akan mempersingkat deskripsi ini."
		"{image:atm:textures/questpics/undergarden/undergarden_blood.png width:200 height:100 align:center}"
	]
	quest.06D13E319C26C949.title: "Blood Mushroom Bog"
	quest.06EA86F9F6C9DECF.quest_subtitle: "Plum + Peach"
	quest.06EAA74E0A10CBB6.quest_subtitle: "Jangkauan: &b36&r Blok"
	quest.06EAA74E0A10CBB6.title: "&9Imperium Pemacu Pertumbuhan"
	quest.06ECF443FBCC12FC.quest_desc: ["Kita bisa Jinakkin &eCacing Maut&r dengan dapetin &eTelur Cacing Maut&r, dari Bunuh &eCacing Maut&r. Tinggal lempar &eTelur&r-nya kayak Telur Ayam dan dia bakal spawn jadi &eCacing Maut yang Jinak&r. \\n&eCacing Maut yang Jinak&r gak bakal berkelakuan kayak Pet biasa, mereka gak bakal ngikutin atau ngelindungin kamu... terus mereka ngapain? \\n\\nPertama, mereka bakal tumbuh gede seiring waktu dan dapet lebih banyak &4Hearts&r dan ukurannya makin besar! \\n\\nJuga mereka bakal ngider dalam jarak tertentu dari tempat mereka di-Spawn. Di area itu mereka gak bakal Nyerang kamu atau Mob yang Pasif, tapi bakal Nyerang yang Hostile! \\n\\nKita juga bisa pake Fishing Rod di kedua Tangan, buat Naik &eCacing Maut&r, bahkan kalo mereka gak Jinak! \\n\\nKita bisa Naik mereka kayak Kuda tapi kita juga dapet Serangan yang bisa kita pake dengan Pencet (G). Serangan ini sama kayak cara &eCacing Maut Raksasa&r nyerang!"]
	quest.06ECF443FBCC12FC.title: "Surfing &eCacing Maut&r!"
	quest.06F2C42E6408149E.quest_desc: [
		"Aku harap kamu tidak mencuri ini dari &c&lPyromancer&r, dia orangnya baik!"
		"{image:atm:textures/questpics/iron_spells/spells_outfit_pyromancer.png width:50 height:100 align:center}"
	]
	quest.06F2C42E6408149E.title: "&cPyromancer Outfit"
	quest.06F8EDF7513F8611.title: "&dEpic&r Ink"
	quest.06FFBB12CFA87815.quest_desc: ["Batang Kayu (Log) dari &2Vanilla &lMinecraft&r, ditemukan di berbagai biome &2Vanilla&r! \\n\\nAku tidak perlu menjelaskan lebih dari itu!"]
	quest.06FFBB12CFA87815.title: "Batang Kayu &2Vanilla&r"
	quest.07084582F9562740.quest_desc: ["&5&lMekanism&r punya beberapa &5Mesin&r khusus buat pewarnaan! \\n\\nAda 3 &5Mesin&r yang perlu kita pakai dan ya, harus urut! \\n\\n&c&lPigment Extractor&r bakal ambil warna dari blok yang sudah &cD&ey&ae&bd&r (diwarnai) dan dijadiin Pigmen! Pigmen itu bentuknya &cChemical&r, dan cara pakainya sama kayak &cChemical&r lainnya: dipindahin lewat &cTubes&f dan disimpan di &cChemical Tank&r. \\n\\n&e&lPigment Mixer&r bakal ambil 2 Pigmen dan digabungin jadi warna Pigmen baru. Ini bahkan bisa bikin warna baru khusus buat item &5&lMekanism&r! \\n\\n&b&lPainting Machine&r bakal ambil Pigmen itu dan dipakaikan ke blok atau item yang bisa &cD&ey&ae&bd&r buat &cD&ey&be&r (mewarnai) mereka. Ini bahkan bisa buat item yang sudah diwarnai, sesuatu yang nggak bisa kamu lakuin di &2&lVanilla&r!"]
	quest.07084582F9562740.title: "&cD&ey&ae&bs&r dan Pigmen"
	quest.070CAEAD49B8DBA3.quest_desc: ["Tukarkan 8 stack &7Compressed Iron Block&r dan satu &6&lATM Star&r untuk dapetin &5Creative &7Compressed Iron Block&r! \\n\\nBlok ini bisa diatur ke suhu berapapun yang kamu mau, yang kemudian bisa dipakai di mesin-mesinmu. \\n\\n8 stack &7Compressed Iron Block&r itu setara dengan 4.608 &7Compressed Iron Ingot&r... semangat ya!"]
	quest.070CAEAD49B8DBA3.title: "&5&lCreative &7Compressed Iron Blocks"
	quest.070F8045CC14B50D.title: "Draconic Projectile Penetration Module"
	quest.072FBEB0F6F1BC48.quest_desc: ["Digunakan untuk menghubungkan Drawer ke Controller dan untuk menghubungkan antar Ender Drawer.\\n\\nUntuk menghubungkan Drawer ke Controller, klik kanan blok Controller untuk memulai konfigurasi. Klik kanan pada Drawer akan menambahkannya ke jaringan.\\n\\nMemegang alat ini akan menunjukkan Drawer mana saja yang sudah terhubung ke Controller."]
	quest.073BA8470EA37A00.quest_desc: [
		"Lautan lainnya, hanya saja yang satu ini jauh lebih dingin."
		"{image:atm:textures/questpics/undergarden/undergarden_icey.png width:200 height:100 align:center}"
	]
	quest.073BA8470EA37A00.title: "Icy Sea"
	quest.0741FABE57CA1A7D.quest_desc: ["&9Hippocamtus&r adalah prajurit kuda laut perkasa yang menjaga &9Acropolis&r. \\n\\nMereka mengenakan banyak armor dan memegang Tombak serta Perisai. \\n\\nMereka punya 85 &4HP (Darah)&r dan 18 Poin Armor. \\n\\nPerisai mereka akan menahan serangan dan tombak mereka digunakan untuk menghabisimu. Mereka bisa mengayun, menusuk, bahkan melakukan jurus spesial yang akan mengunci posisimu sementara mereka menusukmu berkali-kali. \\n\\nSama seperti &9Cindaria&r, mereka akan menjatuhkan &9Lacrima&r."]
	quest.0741FABE57CA1A7D.title: "&9Hippocamtus"
	quest.074EC1E636CD6605.quest_desc: ["&cNetherite Armor&r adalah set terbaik yang bisa kamu dapatkan di &l&2Vanilla&r. Poin Armor-nya sama dengan &bDiamond&r, tapi memiliki Armor Toughness yang lebih tinggi. \\n\\nMungkin karena kamu butuh &bDiamond&r untuk membuatnya!"]
	quest.074EC1E636CD6605.quest_subtitle: "20"
	quest.074EC1E636CD6605.title: "&cNetherite Armor"
	quest.07564DBB023EE2A6.quest_subtitle: "Tingkat: &b4"
	quest.0759CA52EECF3B49.quest_desc: ["&6Bajak Mekanik&r akan membajak apapun yang ada di depannya! Yah, selama bisa digerakkan tentunya. \\n\\nBlok dengan sambungan lemah akan langsung patah ketika terkena &6Bajak&r. Seperti Obor, Tombol, dan Tanaman Rambat. \\n\\nKalau dipakai di atas Tanah atau Rumput, akan mengubahnya jadi Lahan Pertanian! Cocok banget untuk Mega-Farm! \\n\\nKamu juga bisa pakai &6Bajak&r untuk mendorong Mob tanpa membunuhnya. Yah, &6Bajak&r-nya sih nggak akan bunuh mereka, tapi apa yang mereka tabrak belum tentu berbaik hati."]
	quest.0759CA52EECF3B49.title: "&6Bajak Mekanik"
	quest.07655CA904354E9E.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:"
		""
		"Menghancurkan rumput dan bunga di sekitar saat diaktifkan."
	]
	quest.076A648E3E3245C9.quest_desc: ["Kecepatan produksi Energi dari Fuel sangat cepat jadi efisien banget. Masalahnya cuma ga bisa di-upgrade lagi. Masih pakai Fuel Furnace biasa kok."]
	quest.076A648E3E3245C9.title: "&aEmerald Generator"
	quest.07751E1BE48C6024.quest_subtitle: "Tingkat: &b4"
	quest.07753C5D94312A50.quest_desc: [
		"&3Augment&r: Generator adalah kebalikan dari &3Augment&r: Factory, daripada pakai Energi buat Smelt, ini Smelt buat Energi. Kamu ga akan smelt item lagi di dalamnya, setiap Fuel yang dipakai akan jadi Energi!"
		""
		"(Kayaknya lebih bagus konek-in Generator sama Factory Furnace daripada cuma pakai Fuel di satu aja ya)"
	]
	quest.07753C5D94312A50.title: "&3Augment&r: Generator"
	quest.077A214422FEFF02.quest_subtitle: "&f6.5 &cAttack Damage"
	quest.077B2D62FA7650FB.quest_subtitle: "Jangkauan: &627&r Blok"
	quest.077B2D62FA7650FB.title: "&cTertium Pemacu Pertumbuhan"
	quest.078B69E9362A5496.quest_desc: ["Iya, &5&lMekanism&r segede itu! \\n\\nKalo lo mau &2&lReaktor&r sama Armor yang gak bisa dihancurin, lo udah di tempat yang bener! \\n\\nPertama, kita butuh &2&lFission Reactor&r dan itu butuh &2Fissile Fuel&r. Buat bikin &2Fissile Fuel&r kita butuh &cSulfuric Trioxide&r. \\n\\nMulai dengan masukin &eSulfur&r ke &c&lChemical &eOxidizer&r buat bikin &eSulfur Dioxide&r. \\n\\nTerus, bikin &bOxygen&r dengan proses &9Air&r lewat &9&lElectrolytic Separator&r. \\n\\nSekarang kita bisa &cTubing&r &bOxygen&r sama &eSulfur Dioxide&r ke &c&lChemical Infuser&r buat bikin &cSulfur Trioxide&r."]
	quest.078B69E9362A5496.title: "&5&lMekanism: Reaktor"
	quest.078C5B50CDC174CB.quest_desc: ["&aBantalan Mekanik&r adalah bentuk paling sederhana dari pergerakan &aKontraption&r. \\n\\nKetika diberi &dTenaga Rotasi&r dari bawah, ia akan memutar Blok di atasnya dengan Kecepatan dan Arah yang sama. \\nBlok akan otomatis &aditempel&r ke &aBantalan Mekanik&r, tapi Blok lainnya perlu di-&aGlue&r ke Blok tersebut agar ikut bergerak! \\n\\nKalau kamu pakai &aBantalan Mekanik&r di dalam &aKontraption&r itu sendiri, ia akan mencoba menahan Blok yang ditempel agar tetap diam, bukan berputar."]
	quest.078C5B50CDC174CB.title: "&aBantalan Mekanik"
	quest.0790D3BB481162A6.quest_desc: [
		"Butuh Meja Crafting (Crafting Table) portabel? Atau mungkin Meja Smithing (Smithing Table) portabel?"
		""
		"&l&8Crafting On A Stick&r menambahkan versi portabel dari beberapa stasiun kerja favoritmu! Ini adalah barang wajib di awal permainan."
	]
	quest.0790D3BB481162A6.quest_subtitle: "Kurangi Menaruh Blok, Perbanyak Crafting"
	quest.0790D3BB481162A6.title: "Crafting... Pakai Tongkat!"
	quest.079A415488A32076.quest_desc: ["Bara Blaze adalah material baru yang ditambahkan oleh JDT. Bara Blaze didapatkan dengan melakukan Penyebaran Lendir pada Balok Batu Bara Purba menggunakan lendir tingkat dua atau lebih tinggi. Bijih Bara Blaze dipengaruhi oleh keberuntungan."]
	quest.07AF1D5C24B069DD.quest_desc: ["&0Hantu Cockatrice&r dibuat dari &0Mata Cockatrice&r dan bagian &0Wither&r. Tunggu Mata lagi? Kenapa kita ngumpulin Mata sih? \\n\\nDengan &0Hantu&r ini kita bisa kasih (beberapa) Mob efek &0Wither&r III selama 2 Detik. \\n\\nJangkauannya sekitar 20 Blok dan ada Cooldown-nya."]
	quest.07AF1D5C24B069DD.title: "&8Hantu Cockatrice"
	quest.07BEB974DF1E5AD3.quest_desc: ["Bikin Energi dengan kecepatan yang sama kayak &aEmerald Generator&r tapi Transfer Rate-nya jauh lebih tinggi. Bisa dibilang lebih murah karena butuh item lebih sedikit tapi itemnya &5Netherite&r sih jadi..."]
	quest.07BEB974DF1E5AD3.title: "&5Netherite Generator"
	quest.07BEE6FEC14765DC.quest_desc: ["Resep cukup simpel butuh Clay, Iron, Slimeball, dan lainnya... \\n\\nLodestone paling bagus diloot, Mod nambah ini di Loot Pool di seluruh &c&lNether&r jadi jangan craft cari aja! \\n\\nWax adalah Item baru yang ditambah &6&lForbidden \\& Arcanus&r yang merupakan campuran Bottle of Honey dan Slimeball! \\n\\nKamu bisa pakai di &6Darkstone Pedestal&r untuk dapet &7Magnetized Pedestal&r yang kerja sama dengan Hopper (dan Item mirip Hopper seperti Pipe). \\n\\nKamu juga bisa pakai dengan Boot untuk nambah seberapa dekat Item bisa buat ditarik ke Inventory kamu!"]
	quest.07CC809B6482AB09.quest_subtitle: "Tingkat: &a2"
	quest.07E5B0BF7D8E055A.quest_subtitle: "+30% Peluang Evasion"
	quest.07FDA46D83F8360D.quest_desc: ["Dengan 4 &6Allthemodium Nugget&r dan satu Ender Pearl, kamu mendapatkan Teleport Pad. \\n\\nLetakkan di salah satu dimensi Minecraft untuk menteleportasimu ke dimensi lain. \\n\\nUntuk menteleportasi, kamu harus melakukan shift-klik kanan dengan tangan utama dan tangan kiri (offhand) yang kosong! Ini penting, tolong dibaca! \\n\\nKEDUA tangan harus KOSONG!"]
	quest.07FDA46D83F8360D.title: "Teleport Pad"
	quest.0813CEDCC201216A.quest_subtitle: "Kapok + Old Fustic"
	quest.0817FD6E45C127E8.quest_desc: ["Secara teknis ini opsional tapi direkomendasikan! Kamu bisa pakai lebih banyak Pylon untuk memasukkan dan mengeluarkan lebih banyak OP!"]
	quest.0817FD6E45C127E8.title: "Lebih Banyak Pylon {opsional}"
	quest.081DC030A0546549.quest_desc: ["&2Bio Fuel&r dibuat dengan cara &4Crushing &f(menghancurkan) beberapa &2Tanaman&r! Tiap jenis &2Tanaman&r kasih jumlah yang beda-beda! \\n\\n&6Pumpkin Pie&r kasih paling banyak &2Bio Fuel&r tapi &aMelon Slice&r yang paling efisien. \\n\\n&2Bio Fuel&r bisa dipakai buat banyak hal! Kita bisa kasih &aTenaga&r ke &2&lBio-Generator&r, &9&lInfuse&r item pakai &2Chemical Bio Fuel&r, atau..."]
	quest.081DC030A0546549.title: "&4Hancurkan &2Tanaman&f dapat &2Bio Fuel"
	quest.08245411AFDB63DB.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.0830195863384CF0.quest_desc: ["&bStrata&r adalah jenis garam pertama dan paling dasar yang dibuat dari blok biasa seperti Batu, Pasir, atau Obsidian. \\n\\nKamu bisa menggunakan 5 &bStrata Salt&r untuk men-craft &bMineral Salt&r."]
	quest.0830195863384CF0.title: "&bGaram Strata"
	quest.083ABBA1C45FF960.quest_subtitle: "Cuma pemotong rumput"
	quest.083D458032F0325C.quest_desc: ["&bME Export Bus&f secara berkala mengeluarkan item yang ada di filter whitelist-nya ke penyimpanan eksternal yang dihadapinya. Berbeda dengan Import Bus, Export Bus tidak bisa bekerja tanpa adanya filter."]
	quest.083D458032F0325C.quest_subtitle: "Output (Keluar)"
	quest.08457BEED799E600.quest_desc: ["&7Cart&r baru ini sebagian besar digunakan untuk memasang &6Jalur Rel&r.\\n\\n&7Track Layer&r memasang &6rel&r, sedangkan &7Track Remover&r melepasnya.\\n\\n&7Track Relayer&r mengganti &6rel&r dengan jenis lain, dan &7Track UnderCutter&r mengganti blok yang ada di bawah &6rel&r."]
	quest.08457BEED799E600.title: "&7Cart&r dan &6Jalur Rel"
	quest.0848056FDD3F9BDA.quest_desc: ["&9Singularity&r adalah titik teoretis dari kepadatan ultimate. Ilmuwan percaya Alam Semesta yang kita tinggali dulunya adalah &9Singularity&r. Setiap molekul di Alam Semesta kita, dalam satu titik lebih kecil dari butiran pasir. \\n\\nTentu aja dengan &l&bAE2&r yang mengikuti garis ilmu teoretis mereka punya &9Singularity&r sendiri. \\n\\nAda 2 cara buat crafting-nya tapi masing-masing butuh mengondensasikan banyak banget Item jadi satu titik!"]
	quest.0848056FDD3F9BDA.title: "&9Singularity"
	quest.0850F88E2205623F.quest_desc: ["&3Sculk Tendrils&r itu kayak &bTwisting Vines&r... cuma versi &3Sculk&r. \\n\\nMereka jarang muncul di &9Deeplands&r."]
	quest.0850F88E2205623F.title: "&3Sculk Tendrils"
	quest.0853917693A259C2.quest_desc: ["&3The Annihilator&r adalah senjata yang sangat seru, terbuat dari &3Cursium&r dan Black Steel. \\n\\nKamu bisa menghajar musuh dengannya seharian! Tapi tahu apa yang lebih seru dari satu &3Annihilator&r? \\n\\nDua &3Annihilator&r! \\n\\nJika kamu memegang &3Annihilator&r di masing-masing tangan, kamu bisa Menahan Klik Kanan untuk melakukan serangan hantaman tanah yang kuat, melukai semua di sekitarmu!"]
	quest.0853917693A259C2.title: "&3The Annihilator"
	quest.0854AD352218E1C3.quest_desc: ["Sebal nggak sih kalau punya banyak energi tapi mesin nggak panas-panas? \\n\\nSekarang kamu bisa mengubahnya dengan Caloric Flux Emitter! Shift+Klik Kanan pada alat ini untuk menghubungkannya ke sebuah mesin. Kemudian letakkan dan beri daya listrik untuk mengirimkan panas (Heat). \\n\\nAlat ini tidak bisa dihubungkan ke banyak mesin sekaligus!"]
	quest.0854AD352218E1C3.quest_subtitle: "Kok bisa?"
	quest.0854AD352218E1C3.title: "Panas Nirkabel"
	quest.08697EB269B011FD.quest_desc: [
		"Dengan &dRonaza's Contact&r, kamu bisa meningkatkan &bIesnium Ritual Bowl&r menjadi Eldritch Chalice. Saat digunakan dalam ritual, ia akan memangkas waktu penyelesaian... sepenuhnya. "
		""
		"Ya, Eldritch Chalice membuat semua ritual selesai secara instan!"
	]
	quest.08697EB269B011FD.title: "Eldritch Chalice"
	quest.08767A1E6D48A5EA.quest_desc: ["&7Graybeard Staff&r adalah Staff yang sangat murah. Murah dari segi harga dan kualitas. \\n\\nIni hanya akan memberikan 3 &4Damage&r tapi memberikan 25% Mana Regeneration dan 10% &3Spell Power&r. \\n\\nLumayan membantu kalau kamu hanya menggunakan &3Spell&r untuk Membunuh!"]
	quest.08767A1E6D48A5EA.quest_subtitle: "Kapan ini jadi Whitebeards?"
	quest.08767A1E6D48A5EA.title: "&7Graybeard Staff"
	quest.087F6C09CB5B2D1A.quest_desc: ["&bPipa Fluida Cerdas&r memberikan fitur Filter untuk &bPipa Fluida&r. \\n\\nKalau dipasang di Mesin tempat &bPipa&r mengambil cairan, bisa diatur agar hanya mengambil satu jenis &bCairan&r. Caranya dengan menaruh Ember berisi &bCairan&r tersebut di Slot Filter. \\n\\nKamu juga bisa menaruh &bPipa Fluida Cerdas&r di tengah-tengah &bsistem Pipa&r untuk hanya meneruskan &bCairan&r tertentu ke &bPipa&r setelahnya. \\n\\nSangat berguna untuk menyortir banyak &bTangki Fluida&r sekaligus!"]
	quest.087F6C09CB5B2D1A.title: "&bPipa Fluida Cerdas"
	quest.088CA7B6D4899846.quest_desc: ["&#65C2A6Packer&r digunakan untuk membuat &#53E67BDouble Ingot&r, &#53E67BBlade&r, dan &#53E67BCable&r. Selain itu, ada banyak kegunaan lain untuk mesin ini, tetapi fungsi-fungsi tersebut adalah yang paling utama bagimu."]
	quest.088FCB5267CB7A89.quest_desc: ["Sabuk ini akan memberikan efek ramuan positif secara acak dalam durasi singkat. Kekuatan efeknya akan bervariasi."]
	quest.0893EFCAC7031FEA.quest_desc: ["Saatnya bikin kue, kalau kamu sudah siap susu dan telur."]
	quest.0893EFCAC7031FEA.quest_subtitle: "Punya Kue dan Makan Juga"
	quest.0894EB1F3FCFCECA.quest_desc: ["&3Draugr&r mirip dengan &5Deepling&r karena mereka memiliki tingkatan. Tingkatan &3Draugr&r adalah: &3Draugr&r, &3Royal Draugr&r, dan &3Elite Draugr&r. \\n\\n&3Draugr&r normal punya 14 &4HP&r dan membawa Pedang serta Kapak Black Steel. Mereka menjatuhkan Rotten Flesh, Bone, dan terkadang Black Steel Nugget. \\n\\nSelanjutnya adalah &3Royal Draugr&r. Mereka punya 15 &4HP&r dan membawa Black Steel Targe bersama dengan senjata mereka. Drop item-nya sama dengan Draugr normal. \\n\\nTerakhir adalah &3Elite Draugr&r. Mereka berganti-ganti antara Pedang dan Crossbow Black Steel tergantung jarakmu. Punya 16 &4HP&r dan menjatuhkan loot yang sama!"]
	quest.0894EB1F3FCFCECA.title: "&3Draugr"
	quest.089B1B9837AF4938.title: "Peralatan &5Unobtainium"
	quest.08A3292277D2FDE2.quest_subtitle: "Dibuat dengan Enchanting Apparatus"
	quest.08A3292277D2FDE2.title: "Water Essence Bee"
	quest.08AC2D81A1004984.title: "&6Allthemodium &5Alloy &3Trident"
	quest.08B60D8A25008CCC.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.08C66BCA3AAE765B.quest_desc: ["Yang satu ini menambahkan blok Non-&2&lMinecraft&r jadi aku lebih baik tidak membahasnya."]
	quest.08C66BCA3AAE765B.title: "&b&lMacaw's Roofs"
	quest.08C6B7D2DAE87222.quest_subtitle: "Oak + Birch"
	quest.08C870DC50CA49FC.quest_desc: [
		"&#5C5C5CCrude Oil&r (Minyak Mentah) saja tidak banyak berguna bagi kita, tetapi jika dimasukkan ke dalam distillery, kita akan mendapatkan hasil yang bisa digunakan untuk banyak tujuan."
		""
		"Kita bisa menghasilkan &#C4C241Sulfuric Heavy Fuel&r, &#CECC5FSulfuric Light Fuel&r, dan &#D9D782Sulfuric Naptha&r dengannya."
	]
	quest.08C870DC50CA49FC.title: "Pengolahan &#5C5C5CCrude Oil"
	quest.08CE14FFED813992.quest_subtitle: "13 Blok Pink Tua Basah"
	quest.08D1CC753F6B4283.quest_desc: ["Elder Guardian sempat dianggap sebagai Bos ketiga Minecraft sebelum adanya Warden, tapi aku menganggapnya sebagai Minibos. \\n\\nElder Guardian muncul di Ocean Monument. Ada tiga dari mereka yang muncul di sana dan akan memberikan efek Mining Fatigue kepada siapa pun di sekitarnya. \\n\\nJika kamu menginginkan harta karun di Ocean Monument, kamu harus menemukan dan membunuh mereka! (Tips: Aku selalu menemukan 1 di ruangan atas, 1 di sisi kiri jauh, dan 1 di sisi kanan jauh!) \\n\\nMereka punya 80 HP dan menyerang seperti Guardian normal, yaitu dengan Laser dan Thorns! \\n\\nSaat mati mereka akan menjatuhkan: Sponge, Prismarine, dan jatah makan siang mereka..."]
	quest.08D1CC753F6B4283.title: "Kalahkan Elder Guardian"
	quest.08D9C809CF4062E8.quest_desc: ["Makan mentah, panggang, atau tusuk seperti sate. \\n\\nApa sih yang nggak bisa dilakukan dengan Underbean!"]
	quest.08DB91D079C5B715.quest_subtitle: "Red Maple + Mahogany"
	quest.08DDE018A804BFE7.quest_desc: ["&d&lEnrichment Chamber&r bakal &dEnrich &eItem&r yang lewat di dalamnya. Tinggal taruh &eItem&r di &4Slot Merah&r dan hasil &dEnriched Item&r bakal keluar di &9Slot Biru&r. \\n\\nApa sih &dEnriched Item&r itu? Atau apa yang terjadi pas &eItem&r di-&dEnrich&r? Antara kita dapat lebih banyak item dari bahan dasarnya atau ngerubah &eItem&r itu sendiri! \\n\\nKita bisa dapat 2 Dust dari 1 Ore. Kita bisa dapat lebih banyak Dye dari satu Bunga. Kita bahkan bisa ngerubah fase &6Copper&r atau bersihin &2Lumut&r dari &7Cobblestone&r! \\n\\nDengan Tier &d&lEnrichment Chamber&r yang lebih tinggi, kita dapat slot lebih banyak buat &dEnrich&f banyak &eItem&r sekaligus. \\n\\nKita juga dapat fitur Auto-Sort lewat tombol ini! Kita bisa atur supaya tumpukan &eItem&r dibagi rata ke tiap slot biar &d&lMesin&r-nya lebih efisien."]
	quest.08DDE018A804BFE7.quest_subtitle: "Hancurkan Raw Ore jadi Dust"
	quest.08DDE018A804BFE7.title: "&d&lEnrichment Chamber"
	quest.08E47A27EFFB7C6B.quest_subtitle: "5 Blok Pink Kering"
	quest.08E484DD3E751697.quest_subtitle: "Huruf B dalam Roy G. Biv (Me-Ji-Ku-Hi-Bi-Ni-U)"
	quest.08E484DD3E751697.title: "&bBlue Xychorium Gems"
	quest.0903F0D8642449B7.quest_desc: ["Beralih dari &6sirkuit analog&r, kita sekarang bisa memproses lebih dari 2 bit informasi. Ini membuka peluang bagi beberapa mesin baru."]
	quest.090B564935D7A8F5.quest_desc: ["Nggak suka bongkar pasang &5Mesin&r buat Upgrade? Pakai &eItem&r aja! \\n\\nDengan &7Tier&r Installer, kamu tinggal pakai &eItem&r-nya ke &5Mesin &rbuat Upgrade mereka! \\n\\nPakai &a&lBasic Tier &r&aInstaller&r ke mesin standar buat upgrade ke &a&lBasic Tier&r. \\n\\nNggak, kamu nggak bisa skip upgrade. Nggak bisa ngerubah &a&lBasic&r langsung jadi &d&lUltimate&r cuma pakai satu &dInstaller&r."]
	quest.090B564935D7A8F5.title: "&lTier&r Installers"
	quest.0910C28A609ECBC1.quest_desc: ["&6Honey Compass&r adalah alat yang sangat berguna ditambahkan oleh &6&lBumblezone&r. \\n\\nKamu bisa membuatnya atau menukarkannya. \\n\\nKamu bisa Shift+Klik Kanan pada &eBeehive&r untuk melacak &eHive&r tersebut (termasuk &lProductive Beehives&r) atau Klik Kanan di udara untuk mencari lokasi Labirin Sel (Cell Maze)."]
	quest.0910C28A609ECBC1.title: "&6Kompas Madu"
	quest.09223F02621781BF.quest_subtitle: "Iron + Mason"
	quest.09223F02621781BF.title: "Silver Bee"
	quest.0923C941A9696122.quest_desc: ["Buat jaga-jaga kamu harus bawa 256 Juta Item dalam Petualangan! \\n\\nKamu butuh beberapa Item simpel kayak &8MEGA Item Cell Housing&r, &5ME Chest&r, dan &5Dense Energy Cell&r. \\n\\nTerus kita butuh &d256M MEGA Storage Component&r... yang ini jauh lebih susah dibikin. \\n\\nKalo Crafting berulang bikin kamu benci &2&lMinecraft&r, kamu mungkin mau Craft &2Blastproof Casing&r! \\n\\nKita butuh antara 2 256M Portable Item Cell, 2 &2Blastproof Casing&r, atau campuran keduanya buat Craft &3&lImprobable Probability Device&r."]
	quest.0923C941A9696122.title: "256M Portable Item Cell"
	quest.09282E3864752CEE.quest_subtitle: "Tingkat: &63"
	quest.092A23FDA5D50812.quest_subtitle: "Tingkat: &a2"
	quest.092BB595F75D5536.quest_desc: ["Selamat datang di &6&lForbidden \\& Arcanus&r! \\n\\nUntuk mulai Mod ini kita perlu Mining underground... deep underground. \\n\\nSeperti Y Level 1 ke bawah. "]
	quest.092BB595F75D5536.title: "&6&lForbidden \\& Arcanus"
	quest.0945EC53626F58E6.quest_desc: ["Selain item dan cairan, &3Refined Storage&r juga bisa digunakan untuk menyimpan &aKimia (Chemicals)&r, berkat mod integrasi Refined Storage - Mekanism.\\n\\nKamu juga bisa menyimpan &4Energi&r, &5Source&r, dan &9Soul&r melalui mod Refined Types."]
	quest.0945EC53626F58E6.title: "&5Komponen Penyimpanan Lainnya"
	quest.0947B4ED95B0267E.quest_desc: ["Melapisi item dan peralatan.\\n\\nNetherite adalah material pelapis (coating) yang sangat bagus."]
	quest.0947B4ED95B0267E.quest_subtitle: "Sumpah, bukan cuma buat Netherite"
	quest.09485B63483B7A15.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:"
		""
		"Sementara membuat monster jahat di sekitar kehilangan perhatian terhadap pemain, memiliki cooldown."
	]
	quest.094D28B7A0170039.quest_desc: [
		"Akan mengambil item dan membawanya kembali ke sarang (hive)."
		""
		"Tidak sebaik Hoarder Bee."
	]
	quest.094D28B7A0170039.quest_subtitle: "Berikan lebah Vanilla sebuah Hopper"
	quest.094D28B7A0170039.title: "Collector Bee"
	quest.09733948CBCB3FB9.quest_desc: ["&dTier 6&r adalah tingkatan tertinggi, apa pun yang bisa hancur dapat ditambang dengan tingkat ini, termasuk Vibranium dan Unobtainium."]
	quest.09733948CBCB3FB9.title: "&dHarvest Tier 6"
	quest.097DE7038A746847.quest_subtitle: "Muncul dari Reed Nest"
	quest.097FDC136BC843A7.quest_desc: ["&lWorld Tier: &6Summit&r mewajibkanmu untuk meng-upgrade &eArmor&r dan &ePeralatan/Senjata&r dari &aUncommon&r ke &9Rare&r (atau lebih baik)! Kamu juga harus membunuh &0&lThe Wither&r. \\n\\n&0&lThe Wither&r tidak harus berstatus &4Invader&r, dan jujur saja, akan lebih mudah jika dia bukan Invader. \\n\\nDi &6&lSummit&r, &5Epic&r &eItem &fdan &2Gem&r akan sangat umum ditemukan. Untuk &eItem&r kamu sekarang bisa mendapatkan &6Mythic&r, dan untuk &aGem&r kamu bisa menemukan tingkat &zPerfect&r. Sekali lagi, keduanya sangatlah langka! \\n\\nSekarang kita akan mendapatkan bonus 75% Experience dan 50% Luck. \\n\\n&4Monster&r juga akan diperkuat dengan 12 Armor Point, 10 Armor Toughness, 15 Armor Pierce, dan 10 Protection Pierce. \\n\\nCuma perasaanku saja atau upgrade mereka lebih bagus daripada punya kita?"]
	quest.097FDC136BC843A7.title: "&lWorld Tier: &6Summit"
	quest.0980661B2F7FBC10.quest_desc: [
		"Lompatlah di atas lilin-lilin untuk mencapai puncak! \\n\\nSesampainya di atas, kamu bisa menemukan beberapa Honey Cocoon. \\n\\nHati-hati jangan sampai kakimu terbakar.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_candle.png width:200 height:100 align:center}"
	]
	quest.0980661B2F7FBC10.title: "Parkour Lilin"
	quest.09830BB2A23E94B4.quest_desc: ["Beberapa &5Mesin&r pakai &cChemical&r khusus buat ditambahin ke &eItem&r. Kayak &9&lMetallurgic Infuser&r, &c&lChemical Injector&r, dan &b&lPurifier&r. \\n\\nUpgrade ini intinya bikin pemakaian &cChemical&r jadi lebih irit buat tugas yang sama! \\n\\nAku nggak janji ini bakal jalan di semua &eItem&r dan &5Mesin&r. Dan nggak, aku nggak bakal tes ke semua mesin!"]
	quest.09830BB2A23E94B4.title: "&cChemical &8Upgrade"
	quest.0990D6CEE042F44E.quest_desc: ["Peta ini wajib dimiliki di &9Twilight Forest&r.\\n\\nMenggunakan &eBlank Magic Map&r akan memberimu peta yang menunjukkan ikon-ikon bos dan struktur di sekitar."]
	quest.0990D6CEE042F44E.title: "&eMagic Map"
	quest.09936F8FCEA72C5C.quest_desc: [
		"&aPerakit Gerbong&r bisa dipasang di atas rel. Apapun yang kamu bangun di atasnya akan diangkat oleh &7Minecart&r kalau &aPerakit&r mendapat &4sinyal Redstone&r."
		""
		"Blok-blok harus di-&aGlue&r satu sama lain, dan Blok yang membutuhkan &dTenaga Rotasi&r akan otomatis berfungsi."
		""
		"Untuk \"melepas\" Blok dari &7Minecart&r, cukup matikan &4sinyal Redstone&r dan biarkan &7Minecart&r melintas."
	]
	quest.09936F8FCEA72C5C.title: "&aPerakit Gerbong"
	quest.09955CF85F579E0F.quest_desc: ["Kamu pasti akan mendapatkan ini pada akhirnya, ini secara harfiah adalah blok yang paling melimpah di &2&lMinecraft&r."]
	quest.09955CF85F579E0F.title: "Blok Batu"
	quest.099C2A9B9CA138F8.quest_desc: ["&6Mythic&r adalah salah satu tingkatan terbaik yang bisa kita dapatkan! \\n\\n&6Mythic&r hanya ditemukan di &lWorld Tier: &6Summit&r dan &lWorld Tier: &4Pinnacle&r (tempat mereka paling sering muncul). \\n\\n&6Godforged Pearl&r dibuat dengan menghancurkan &eItem&r &6Mythic&r di &c&lSalvaging Table&r."]
	quest.099C2A9B9CA138F8.quest_subtitle: "&6Mythic"
	quest.099C2A9B9CA138F8.title: "&6Godforged Pearl"
	quest.09ABD5D978373A54.quest_desc: ["&aJantung Hydra&r adalah Drop yang sangat langka dari &a&lHydra&r tapi percaya deh, ini sepadan! \\n\\nPas ada di Hotbar kamu, termasuk Tangan Utama, dia bakal kasih Regeneration. \\nTapi tunggu, Regeneration itu bakal naik Level-nya makin dikit &4Hearts&r kamu!"]
	quest.09ABD5D978373A54.title: "&aJantung Hydra"
	quest.09BA45CBBFB4AE26.quest_desc: ["Tahap selanjutnya dari mod ini mengharuskanmu membangun &3Assembly Line&r (Lini Perakitan). Komponen utama dari &3Assembly Line&r adalah &3Assembly Controller&r.\\n\\nDi sinilah tekanan udara akan dialirkan."]
	quest.09BA45CBBFB4AE26.quest_subtitle: "Selalu Dibutuhkan"
	quest.09BE81548CD81068.quest_desc: ["Kamu akhirnya sampai pada komponen yang dibutuhkan untuk membuat &#FFEB6EAllTheMods Star&r!!"]
	quest.09C82CDDA800D8C9.quest_desc: ["Wither adalah bos kedua Minecraft, yang ini lebih bersifat pilihan (elective). \\n\\nKamu harus membangun tubuh Wither untuk memunculkannya. Gunakan 4 Soul Sand dalam bentuk T dan letakkan 3 Wither Skeleton Skull di atasnya! \\n\\nIa punya 300 HP dan akan terbang berkeliling menembakkan Wither Skull ke arah pemain atau mob. \\n\\nSaat HP-nya mencapai setengah, ia akan mendapatkan pelindung terhadap proyektil dan harus dibunuh menggunakan Pedang atau Kapak. \\n\\nBegitu kamu mengalahkannya, ia akan menjatuhkan: Nether Star, peluang mendapatkan Withering Soul, dan banyak item dari mod Corail."]
	quest.09C82CDDA800D8C9.title: "Kalahkan Wither"
	quest.09D18512037386C1.quest_desc: ["Untuk memasukkan efek ramuan ke dalam Pylon, kamu harus mengisi Potion Filter terlebih dahulu. \\n\\nCaranya: pastikan kamu sedang memiliki efek ramuan aktif pada dirimu, lalu klik kanan menggunakan Potion Filter untuk memindahkan efek tersebut dari dirimu ke dalam filter. Ulangi sampai filter terisi penuh dan aktif. \\n\\nIni juga berfungsi untuk efek ramuan dari mod lain atau efek yang biasanya tidak didapat dari botol ramuan biasa seperti Haste atau Resistance."]
	quest.09D2137B4F42006E.quest_desc: ["Bara Gerhana adalah material baru yang ditambahkan oleh JDT. Bara Gerhana didapatkan dengan melakukan Penyebaran Lendir pada Balok Batu Bara Apikegelapan menggunakan lendir tingkat empat. Bijih Bara Gerhana dipengaruhi oleh keberuntungan."]
	quest.09D76E9B8CABC31E.quest_desc: ["Buat &5&lCreative Essence&r kamu butuh 4 &5Insanium Essence Block&r. Setiap Block itu 9 &5Essence&r sekarang coba gue itung... \\n\\nKamu butuh 9,216 &aInferium Essence&r buat dapetin satu Block ini aja. Jadi total kamu butuh 36,864 &aInferium Essence&r!"]
	quest.09D76E9B8CABC31E.title: "4 &5Insanium Block"
	quest.09D7D3CF61E156B1.quest_desc: ["&2Fission Fuel Assembly&r adalah yang bikin storage buat &2Fissile Fuel&r. Mereka juga bantu nentuin Efisiensi. \\n\\n&2Fission Fuel Assembly&r harus ditaro di &2&lFission Reactor&r biar bisa kerja. \\n\\nBisa ditumpuk ke atas sama samping, tapi tiap tumpukan butuh... \\n\\n&2Control Rod Assembly&r di atasnya! &2Control Rod Assembly&r gak ngubah apa-apa kayak Efisiensi tapi &2Fission Fuel Assembly&r gak bakal kerja kalo gak ada &2Control Rod Assembly&r di atasnya dalam &2&lFission Reactor&r!"]
	quest.09D7D3CF61E156B1.title: "Storage dan penggunaan &2Fissile Fuel&r"
	quest.09E25B1CD6CABD5A.quest_desc: ["Upgrade ini membuat Router mirip dengan Framed Block. \\n\\nShift+Klik Kanan pada sebuah blok untuk mengubah penampilan Router menjadi blok tersebut. \\n\\nJangan sampai hilang ya!"]
	quest.09E34E1F9C751458.quest_desc: ["&dGearbox Vertikal&r sama seperti &dGearbox&r biasa, hanya saja posisinya diputar. \\n\\nPunya 4 &8Poros&r internal, tapi kali ini bukan arah Kardinal, melainkan (dari tempat kamu memasangnya) Depan, Belakang, Atas, dan Bawah. \\n\\nSama seperti &dGearbox&r biasa, Kecepatan dan Satuan Stres dari &8Poros&r asli tetap terjaga!"]
	quest.09E34E1F9C751458.title: "&dGearbox Vertikal"
	quest.09F43EB79DDBD127.quest_desc: [
		"Quantum Data Entangler memungkinkan item disimpan di beberapa dimensi, efektif menggandakan crafting storage di Quantum Computer Multiblock sebanyak 6x. Contoh, 256M quantum crafting storage jadi 1.5G Crafting Storage."
		""
		"&lKamu cuma bisa punya 1 ini di Quantum Computer Multiblock."
	]
	quest.09F43EB79DDBD127.title: "Storage Gede Banget: Quantum Data Entangler"
	quest.09F49ED309152E24.quest_desc: ["&l&cChisel Reborn&r adalah mod lain yang berbasis pada &lChiseled&r. \\n\\nInti dari mod ini adalah menggunakan alat Chisel untuk mengubah desain beberapa blok. \\n\\nKamu bisa Klik Kanan dengan Chisel untuk membuka GUI-nya, di sana kamu bisa memasukkan hingga satu tumpukan (stack) blok ke dalamnya, lalu pilih desain yang kamu inginkan, dan ambil kembali. Atau kamu bisa membiarkannya di dalam Chisel, walau aku tidak tahu kenapa kamu ingin melakukannya. \\n\\nKamu juga bisa Klik Kiri sebuah blok dengan Chisel untuk mengubah desainnya tanpa membuka GUI Chisel! \\n\\nTenang saja, alat ini tidak memiliki durabilitas."]
	quest.09F49ED309152E24.title: "&l&cChisel Reborn"
	quest.09FD3D0B9BCAEB5A.quest_desc: [
		"Gravel Nest akan menarik lebah di biome Sungai (River) atau Pantai (Beach)."
		""
		"Ia menarik Ashy Mining Bee, Chocolate Mining Bee, dan Digger Bee."
	]
	quest.09FD3D0B9BCAEB5A.quest_subtitle: "Memancing lebah di biome Sungai dan Pantai"
	quest.0A02DBE226C3F44E.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kabut Pikiran"
		"- Membingungkan"
		"- Penglihatan Malam"
		"- Penghapus Debuff"
		"- Penghancuran Mental"
	]
	quest.0A0A991BAC99092C.quest_desc: [
		"Indigo Mushroom Bog adalah rawa yang jauh lebih padat dibanding Blood Mushroom Bog. \\n\\nTentu saja ada Jamur Indigo, tapi juga ada Pohon Smogstem Kecil dan kolam Virulent Mix. Penasaran apa fungsinya..."
		"{image:atm:textures/questpics/undergarden/undergarden_indigo.png width:200 height:100 align:center}"
	]
	quest.0A0A991BAC99092C.title: "Indigo Mushroom Bog"
	quest.0A11725B41AB45F6.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.0A1ABE9CF7740AAA.quest_desc: ["Rings of Discount memberikan bonus kecil untuk mana maksimal dan regenerasi mana. Cincin ini juga mengurangi total biaya mana untuk merapal mantra."]
	quest.0A1ABE9CF7740AAA.title: "Rings of Discount"
	quest.0A1C2A7A8617D3E4.quest_subtitle: "Speedrunner Suka Banget Ini"
	quest.0A1C2A7A8617D3E4.title: "Gandum"
	quest.0A1D4228271DECA3.quest_desc: ["Ke mana kamu pergi?\\n\\nOh, ternyata ukuranmu cuma jadi setengah dari biasanya. Cukup kecil untuk masuk ke celah setinggi 1 blok."]
	quest.0A1D4228271DECA3.quest_subtitle: "Kalung"
	quest.0A1D4228271DECA3.title: "&5Charm of Shrinking&r"
	quest.0A1D6E233C0ECC8E.quest_desc: [
		"&dNargoyle&r adalah mob jahat dan agresif yang muncul di bawah tanah. \\n\\nMereka punya 7 setengah HP dan akan terus mengejarmu tanpa henti. \\n\\nMereka tidak menjatuhkan apa pun dan hanya menjadi pengganggu saat kamu sedang menambang dengan tenang. "
		"{image:atm:textures/questpics/undergarden/undergarden_nargoyle.png width:100 height:100 align:center}"
	]
	quest.0A1D6E233C0ECC8E.title: "&dNargoyle&r"
	quest.0A1FBDA0C1314DE1.quest_desc: ["Attuned &bDiamond&r/&aEmerald&r adalah baterai &4Mahou&r dan butuh banyak &4Mahou&r untuk mendapat &4&lMorgan&r. \\n\\nAttuned &bDiamond&r menampung 2000 &4Mahou&r dan Attuned &aEmerald&r menampung 1000. \\n\\nButuh 5000 &4Mahou&r untuk Ritual, jadi mungkin butuh beberapa!"]
	quest.0A1FBDA0C1314DE1.title: "Cukup &4Mahou&r? Mungkin!"
	quest.0A207A437AF153AA.quest_desc: ["&2Phantom Armor&r berpeluang ditemukan di dalam peti &2Knight Phantom&r."]
	quest.0A207A437AF153AA.title: "Armor &2Phantom"
	quest.0A21773B773F34F8.quest_desc: ["Warna adalah salah satu bagian terpenting untuk membuat bangunan lebih hidup! \\n\\nIa memberikan nyawa, kepribadian, dan warna! \\n\\nMulailah dengan Pewarna (Dye)!"]
	quest.0A21773B773F34F8.title: "Blok Berwarna"
	quest.0A25276925EB0CBA.quest_desc: [
		"Setelah kamu mengumpulkan setiap warna Kapur dan Kapur Fondasi, kamu bisa melakukan ritual jenis &dTanpa-Setan&r kedua, yaitu &dRonaza's Contact&r. Ini adalah ritual pamungkas yang menggunakan semua yang telah kamu pelajari sejauh ini!"
		""
		"Penggunaannya terbatas, tapi semua yang dibuat dengan ritual ini sangatlah kuat!"
	]
	quest.0A25276925EB0CBA.quest_subtitle: "Dengan harta suci ini aku memanggil..."
	quest.0A25276925EB0CBA.title: "&dRonaza's Contact"
	quest.0A354B4707894A62.quest_subtitle: "Sampai +3 Tinggi Lompat"
	quest.0A3C464EF7CDD5F6.quest_desc: [
		"&4Hellshelf&r adalah pengenalanmu terhadap &cQuanta&r. Rak ini memberikan &c3% Quanta&r dan &a3 Eterna&r. \\n\\nJauh lebih baik dari rak buku normal, kan? \\n\\nKamu akan butuh 16 buah untuk langkah selanjutnya: 15 &4Hellshelf&r di sekitar &5Enchantment Table&r, dan 1 di inventory-mu. \\n\\nBuatlah 11 buah pertama, dan aku akan memberimu 5 &4Hellshelf&r sisanya!"
		"{image:atm:textures/questpics/apothic/enchant_hellshelf.png width:100 height:100 align:center}"
	]
	quest.0A3C464EF7CDD5F6.title: "&4Hellshelves"
	quest.0A43FD0B5C76C1C5.quest_desc: [
		"&l&7RailCraft&r menambahkan Blast Furnace multiblock bagi kita untuk mengubah Besi menjadi Baja (Steel)! \\n\\nUntuk membangunnya, kamu butuh 34 Blast Furnace Brick. Ukurannya 3 blok lebar, 3 blok panjang, dan 4 blok tinggi. Dua blok tepat di tengah harus kosong. Kamu tahu mesin ini jadi saat strukturnya menyatu dan GUI bisa diakses. \\n\\nDi sana kamu bisa memasukkan Besi dalam bentuk apa pun untuk mendapatkan Baja dan Granulated Sand."
		"{image:atm:textures/questpics/railcraft/rail_furnace.png width:100 height:100 align:center}"
	]
	quest.0A43FD0B5C76C1C5.title: "Blast Furnace (Baja)"
	quest.0A467A0CFFCF1490.quest_subtitle: "Beech + Luck"
	quest.0A4962728C98DAD9.quest_desc: ["&eVault Item&r, meski bukan hal baru, akan sangat sering dipakai di Update terbaru! \\n\\n&eVault Item&r berfungsi seperti Peti, hanya saja kita nggak bisa memasukkan atau mengambil &eItem&r semudah dari Peti... \\n\\nUntuk memindahkan &eItem&r kita butuh &eCorong&r! Pasang ke &eVault&r untuk memasukkan dan mengeluarkan &eItem&r. Sebaiknya pakai &eCorong Kuningan&r untuk Filter &eItem&r yang lebih canggih. \\n\\nSetiap &eVault&r punya banyak ruang penyimpanan, dan bisa disusun bersebelahan untuk menggabungkan Inventaris. \\n\\nBisa disusun 1x1, 2x2, atau 3x3, dan panjangnya bisa sampai 3 kali lebarnya! Jadi ukuran terbesar yang bisa dibuat adalah 3x3x9."]
	quest.0A4962728C98DAD9.title: "&eVault Item"
	quest.0A64D0937A5F7513.title: "Pancing Emas"
	quest.0A7B0D0B81E138DE.quest_desc: ["&e&lKotak Peralatan Insinyur&r bekerja sebagai Shulker terpisah. \\n\\nMemiliki bagian: Makanan, yang hanya bisa diisi Makanan. Peralatan, yang bisa menampung &8&lIE&r Peralatan atau Peralatan lain hanya bukan &bEmber&r. &cKabel&r, yang bisa berisi &cKabel&r, &cKonektor&r, atau &cRelay&r. Dan Apa Saja, yang tidak diskriminatif. Cobalah lebih seperti bagian Apa Saja! \\n\\nBeberapa Barang tidak bisa ditampung di dalamnya, seperti &bEmber berisi Cairan&r atau Ransel Akumulator. \\n\\nKamu bisa Shift Klik Kanan untuk meletakkan &e&lKotak Peralatan&r agar berfungsi seperti Peti, kemudian bisa melakukan hal yang sama untuk mengambilnya."]
	quest.0A7B0D0B81E138DE.title: "&e&lKotak Peralatan Insinyur"
	quest.0A8F44B9B3C8FC0F.quest_subtitle: "Tingkat: &63"
	quest.0A912B2E2BE34920.quest_desc: [
		"Meskipun kamu bisa menemukan Crude Oil (Minyak Mentah) di permukaan, melakukan pengeboran adalah cara terbaik untuk mendapatkan banyak minyak. Pertama, gunakan &3Seismic Sensor&r sampai kamu menemukan minyak di bawahmu, lalu gunakan &3Gas Lift&r yang diisi dengan pipa bor untuk mengambil minyak tersebut. (Membutuhkan tekanan udara untuk bekerja).\\n"
		"{image:pneumaticcraft:textures/patchouli/oil_pumping.png width:200 height:200 align:right fit:true}"
	]
	quest.0A912B2E2BE34920.quest_subtitle: "Mengebor Minyak"
	quest.0A9ADDE68342B987.quest_desc: [
		"Untuk membuat &#43DEC2Polyethylene&r, kamu harus mengikuti rantai kimia seperti ini:"
		""
		"&8Crude oil&r -> &#D2CD2DSulfuric Light Fuel&r -> &#DBD658Light Fuel&r -> &#E2DF78Steam Cracked Light fuel&r -> &#44D1DBEthylene&r -> &#43DEC2Polyethylene&r."
	]
	quest.0A9D5C5D2F4CDCC3.title: "&5Unobtainium Mace"
	quest.0AA9EF3981E9BA37.quest_desc: ["&aEnergy Tablet&r nggak cukup nampung &aEnergi&r? Kalau gitu kamu butuh &aEnergy Cube&r! \\n\\n&aEnergy Cube&r bisa dialirin &aEnergi&r masuk dan keluar pakai kabel. Masing-masing punya batas simpan &aEnergi&r sesuai Tier-nya. \\n\\nSemua sisi &aEnergy Cube&r bisa terima atau keluarin &aEnergi&r, tergantung Kabelnya narik atau dorong. \\n\\n&a&lBasic&r: nampung 1.6mFE. \\n\\n&c&lAdvanced&r: nampung 6.4mFE. \\n\\n&b&lElite&r: nampung 25.6mFE. \\n\\n&d&lUltimate&r: nampung 102.4mFE."]
	quest.0AA9EF3981E9BA37.title: "&aEnergy Cubes"
	quest.0ABB2264CBB82470.quest_desc: ["Armor tingkat Besi (Iron) untuk set armor &d&lArs&r."]
	quest.0ABB2264CBB82470.quest_subtitle: "15"
	quest.0ABB2264CBB82470.title: "&5Arcanist Outfit"
	quest.0AC8FE3B59D1B09D.quest_desc: ["Quantum Catcher adalah Tool sangat berguna untuk pindahin Mob. \\n\\nCukup Klik Kanan Mob untuk \"catch\" mereka, lalu Klik Kanan lagi untuk lepasin. \\n\\nKamu butuh jumlah tertentu &bAureal&r untuk pakai ini, tergantung Health Mob. Lebih banyak Health, lebih banyak &bAureal&r yang dibutuhkan! Gak ada biaya untuk lepasin Mob, itu gratis. \\n\\nOh tunggu, mungkin harus kasih tau cara Craft-nya! Kamu butuh &7Quantum Core&r yang dicraft dengan &7Rune&r, &cMundabitur Dust&r, dan &8Flint&r! \\n\\nSpawner Scrap adalah drop dari Mining Spawner tanpa Silk Touch, jadi akan pecahkan Spawner."]
	quest.0ACC0092A8F722C6.quest_desc: ["Sebagian besar Mesin di &8&lIE&r memerlukan &cEnergi&r untuk bekerja, dan &cKabel&r adalah cara kita memindahkannya! \\n\\n&cKabel&r dipasang dengan Klik Kanan satu bagian dengan &cGulungan Kabel&r, lalu Klik Kanan bagian kedua dengan &cGulungan&r yang sama. Jalurnya tidak boleh terhalang atau tidak akan terhubung. \\n\\nUntuk mengambil &cKabel&r kita bisa merusak apa yang terhubung dengannya, atau gunakan &6Pemotong Kabel&r andalan kita! \\n\\nTingkat &cKabel&r yang berbeda mempengaruhi seberapa banyak yang ditransfer, &5HV&r memindahkan paling banyak."]
	quest.0ACC0092A8F722C6.title: "&cGulungan Kabel"
	quest.0ACE573560A19309.quest_desc: ["Hampir tiap &5Mesin&r butuh &aEnergi&r, dan pas kita punya puluhan mesin... pasti bakal berat banget buat jaringan listrik kita. \\n\\nKalau kita pasang &aEnergy &8Upgrades&r, &5Mesin&r bakal lakuin tugas yang sama tapi pakai &aEnergi&r yang lebih dikit! \\nCoba aja kita bisa pasang ini di &d&lS.P.S.&r!"]
	quest.0ACE573560A19309.title: "&aEnergy &8Upgrade"
	quest.0AD2B11565B484E7.quest_desc: ["Kamu butuh semua Furnace sebelum &5Netherite&r buat ini. Iya semua, bahkan &6Copper&r! Bahkan &7Silver&r! Bahkan &3Crystal&r!"]
	quest.0AD2B11565B484E7.title: "&zRainbow Plating"
	quest.0ADBE90B33ACC9FB.quest_desc: ["&zRainbow Generator&r adalah boost buat &zRainbow Furnace&r pas pakai &3Augment&r: Generator. Kalau semua 9 Furnace lainnya (ga termasuk AllTheModium Furnace ke atas) ada di sekitar &zRainbow Furnace&r, punya &3Augment&r: Generator, dan lagi aktif bikin Energi (ada fuel-nya dan belum penuh) bakal kasih boost ke &zRainbow Furnace&r yang punya &3Augment&r: Generator dan lagi kerja. Bakal bikin 2kFE per tick lebih banyak!"]
	quest.0ADBE90B33ACC9FB.title: "&zRainbow Generator"
	quest.0AE28C998A3BF136.quest_subtitle: "531,441 Netherrack"
	quest.0AE6AD813928DE4F.quest_desc: ["Pemanas Eksternal bisa digunakan dengan Tungku, seperti yang &2&lVanilla&r, bukan &c&lTungku Blast Sederhana&r! \\n\\nMengambil &cEnergi&r dari Bawah dan menggunakannya untuk Panas. \\n\\nPanas keluar dari sisi lainnya, ke Blok yang berdekatan. \\n\\nSecara teknis digunakan untuk &4&lTungku Blast yang Ditingkatkan&r, dengan Crafting Pemanas Awal tetapi aku tidak menghitungnya!"]
	quest.0AE83A6CC21F96D4.quest_desc: ["Melakukan elektrolisis pada sebuah &#3127F5Singularity&r akan menghasilkan &#DA27F5UU Matter&r. Dalam proses ini, &#3127F5Singularity&r &n&atidak&r akan terkonsumsi."]
	quest.0AE8B51D63327EC3.title: "Chaotic Shield Recovery Module"
	quest.0AE930BA037DC565.quest_desc: ["Lihat Modules untuk belajar lebih tentang cara menggunakan dan upgrade item DE! Bekerja seperti Bow normal dengan menembak Arrow. Setiap tembakan mengambil sejumlah Energy dari Bow itu sendiri, jadi ya kamu butuh Energy Modules setidaknya."]
	quest.0AE930BA037DC565.title: "Wyvern Bow"
	quest.0AEAEA976ED0C470.quest_desc: ["&3Charging Station&r digunakan untuk mengisi daya berbagai alat dan gadget di mod &aPneumaticCraft&r menggunakan tekanan udara."]
	quest.0AEAEA976ED0C470.quest_subtitle: "Mana kabelnya?"
	quest.0AEC181F5E21A299.quest_desc: ["Jika kamu pernah mendengar orang membicarakan \"Melon Power\", inilah dia. &dGas-Burning Generator&r dari Mekanism dapat menghasilkan daya yang besar dengan memompakan &9Ethylene&r yang terbuat dari Melon Slice.\\n\\nUntuk memproduksi &dEthylene&r, mulailah dengan menghancurkan bahan organik di dalam &eCrusher&r untuk membuat &6Bio Fuel&r. Biasanya yang digunakan adalah Melon Slice! Bio Fuel ini kemudian dipompakan ke dalam &dPressurized Reaction Chamber&r (disingkat PRC).\\n\\nPRC membutuhkan Air, Bio Fuel, dan Hidrogen untuk membuat Ethylene. Kamu bisa mendapatkan Hidrogen dengan memisahkan air di dalam &9Electrolytic Separator&r.\\n\\nSetelah kamu mulai memproduksi Ethylene, pompakan ke dalam Gas-Burning Generator untuk mulai menghasilkan daya!"]
	quest.0AEC181F5E21A299.quest_subtitle: "KEKUATAN MELON!"
	quest.0AEC181F5E21A299.title: "&9Mekanism: &dGas-Burning Generator"
	quest.0AF2460579C6BD8C.quest_subtitle: "Osmium + Obsidian"
	quest.0AF2460579C6BD8C.title: "Refined Obsidian Bee"
	quest.0AF5FB1B5AA5AA11.quest_subtitle: "Tingkat: &b4"
	quest.0B0BDC37185AF9EC.quest_desc: [
		"Ancient Hoop adalah menara tinggi yang terbuat dari Ancient Wax. \\n\\nDi puncaknya terdapat lingkaran-lingkaran dengan hembusan angin kencang. \\n\\nDi sanalah kamu juga akan menemukan Kepompong (Cocoon)! \\n\\nSepertinya tempat yang bagus untuk menggunakan Elytra!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_hoops.png width:200 height:100 align:center}"
	]
	quest.0B0BDC37185AF9EC.title: "Lingkaran Kuno"
	quest.0B11EAB8D76529E0.quest_desc: [
		"&6Ancient City&r adalah Struktur paling berbahaya di &2&lVanilla Minecraft&r. Jadi tentu saja ini baru permulaan untuk &3&lDeeper and Darker&r! \\n\\nDi sini kita bisa menemukan &3Sculk&r berlimpah, bersama dengan Jarahan dan &9&lWarden&r. Kita juga akan menemukan Portal Frame yang terbuat dari &8Reinforced Deepslate&r. \\n\\nTapi sampai saat itu, jarah semua yang bisa! Dan hati-hati dengan..."
		"{image:atm:textures/questpics/allthemodium/all_city.png width:200 height:100 align:center}"
	]
	quest.0B11EAB8D76529E0.title: "Kunjungi &6Ancient City&r"
	quest.0B1DF8A040826D87.quest_desc: ["Sekarang kamu punya &cRossinite&r, bisa dicampur dengan &aBenitoite&r untuk bikin ingot &dInsanite&r.\\n\\n&aBenitoite Ore&r bisa ditemukan di Nether."]
	quest.0B1DF8A040826D87.title: "Insanite"
	quest.0B218DD73FE8D985.quest_desc: ["Jika kamu menyelesaikan quest sebelumnya dengan benar, kamu seharusnya sudah mengubah singularity tersebut menjadi sepasang &bQuantum Entangled Singularities&f. Singularity baru ini digunakan untuk menghubungkan perangkat berbentuk cincin yang dikenal sebagai &eQuantum Network Bridge&f.\\n\\nSaat dua cincin ini telah dihubungkan menggunakan Quantum Entangled Singularities dan dipancing dengan daya AE (misal: energy cell), jaringan ME dapat diperluas secara nirkabel (wireless) ke sisi lain jembatan, baik dalam jarak jauh maupun lintas dimensi."]
	quest.0B218DD73FE8D985.title: "Quantum Network Bridge"
	quest.0B2210804594E7B8.quest_subtitle: "Cukup di-craft saja"
	quest.0B2210804594E7B8.title: "Arcane Essence Bee"
	quest.0B37355262121DD5.quest_desc: ["&aAltar Infus&r adalah cara kamu buat bikin semua benih. Taro dulu Altarnya terus nanti dia bakal nunjukin dimana kamu harus naro Pedestalnya.\\n\\nBiar proses Infus mulai, Altar butuh &4sinyal Redstone&r."]
	quest.0B37355262121DD5.quest_subtitle: "Bikin Benih"
	quest.0B37355262121DD5.title: "&4Altar Infus"
	quest.0B3AC4E923332AC6.quest_desc: ["&b&lNaga Es&r yang paling tangguh adalah yang spawn di &bGua Naga Es&r, ini yang &lStage&r-nya paling tinggi yaitu &lStage 4&r dan &l5&r! \\n\\n&bGua Naga Es&r-nya gede banget dengan banyak Blok &bEs&r yang runcing, jadi hati-hati pas jalan. \\n\\nOh iya plus &b&lNaga Es&r, yang satu itu paling banyak makan tempat! Tenang aja mereka gak bakal Terbang atau Berenang di sini, cuma Berantem! \\n\\n&bSerangan Elemental&r-nya ngasih Damage lebih banyak dan &bBekuin&r lebih banyak Blok dan Mob. Serangan biasa mereka juga ngasih Damage lebih banyak dari sebelumnya. \\n\\nKalo Damage-nya belum cukup parah, mereka juga punya ratusan &4Hearts&r dan sampai 20 &7Armor Points&r! Nih bos-bos gak main-main! \\n\\nKalo &b&lNaga&r yang kamu bunuh itu &lStage 4&r atau &l5&r, Betina, dan kamu gak pake Botol Kosong kamu mungkin dapet &bTelur Naga Es&r. Ini bisa dipake buat..."]
	quest.0B3AC4E923332AC6.title: "&lStage 4-5 &bNaga Es"
	quest.0B3EA604C5172D98.quest_desc: [
		"Agar kita bisa menentukan &9Teman&r &c&mSetan&r mana yang ingin dipanggil, kita perlu membuat &bBook of Binding&r yang spesifik.\\n\\nUntuk membuatnya, kamu perlu memurnikan Pewarna Hitam (Black Dye) di dalam &dSpiritfire&r untuk mendapatkan Purified Ink. Dengan ini, kita akan membuat Book of Binding pertama kita untuk memanggil setan &aFoliot&r."
		""
		"Sebagai alternatif, kamu bisa membuat Empty Book of Binding, yang bisa diwarnai nanti sesuai dengan tingkat ritual yang kamu butuhkan."
	]
	quest.0B3EA604C5172D98.title: "&bBooks of &dBinding"
	quest.0B485DB737A036E9.quest_desc: ["Penyalin Pengaturan Mesin memungkinkan pemain untuk menyalin pengaturan antar mesin."]
	quest.0B4CE3969067FA31.quest_desc: [
		"Quantum Armor bisa di-upgrade dengan berbagai upgrade."
		""
		"Untuk upgrade Quantum Armor kamu, buka Quantum Armor Configuration Menu dengan menekan keybind-nya (default N)."
	]
	quest.0B4CE3969067FA31.title: "Upgrade untuk Quantum Armor"
	quest.0B60DA8F65E5DF06.quest_desc: ["Kamu bisa menghancurkan &#A140A1Raw Tungsten&r dengan berbagai cara untuk mendapatkan &#C452C4Tungsten Dust&r."]
	quest.0B6D35F5B3A11FD2.quest_desc: ["&9Aura Cache&r dapat digunakan untuk menyimpan &aAura&r!"]
	quest.0B6D35F5B3A11FD2.quest_subtitle: "Simpan dulu!"
	quest.0B6D35F5B3A11FD2.title: "&9Aura Cache"
	quest.0B70D40FA951E13B.quest_subtitle: "Oak + Birch"
	quest.0B718FC37699B822.quest_desc: ["&aEcho Logs&r dibuat dari &aEcho Trees&r yang tumbuh di &5Echoing Forest&r... kok ada gema di sini ya, kenapa aku sering dengar? \\n\\n&aEcho Trees&r punya &5Daun Ungu&r dan Sculk Gleam di dalamnya. Sementara Batangnya punya &7Kulit Abu-abu Terang&r dan warna Log yang sangat &aHijau Muda&r. \\n\\nSemua Planks dan item Kayu yang dibuat darinya semuanya berwarna &aHijau Muda&r, hampir seperti Mint. \\n\\nBahkan Trapdoors dan Doors-nya punya pola unik yang keren!"]
	quest.0B718FC37699B822.title: "&aEcho Trees"
	quest.0B7F2B63D867D221.quest_desc: ["Untuk menemukan ini kita butuh sedikit arkeologi! \\n\\nDi lorong raksasa menuju &e&lAncient Remnant&r, terdapat 3 ruangan di sisi-sisinya. \\n\\n2 dari ruangan ini memiliki Suspicious Sand yang bisa kamu sikat dengan Brush untuk mendapatkan loot, termasuk &eNecklace of Desert&r. \\nLalu, Klik Kanan pada &e&lAncient Remnant&r menggunakan &eNecklace of Desert&r untuk membangkitkannya!"]
	quest.0B7F2B63D867D221.quest_subtitle: "Membangkitkan Ancient Remnant"
	quest.0B7F2B63D867D221.title: "&eNecklace of the Desert"
	quest.0B9BBE2A764631BF.quest_desc: ["Penukar sederhana bisa teleport barang, balok, monster, atau pemain di atasnya ke penukar sederhana lain yang sudah dihubungkan. Untuk menghubungkan penukar gunakan kunci pas Ferricore."]
	quest.0B9F2B443813F43C.quest_desc: ["Kamu pernah pengen bisa nyerang dengan Sekop, dan sakitin? Aku mau tanya kenapa, tapi ini EvilCraft.\\n\\nGak usah cari lagi! Ini berfungsi sebagai senjata, dan alat buat ngehancurin benda yang lembut!"]
	quest.0BB0DF36B079558F.quest_desc: ["Kalau &6Entangled Chalice&r ditaro di dunia, dia bisa pompa Blood. Kalau diaktifin di inventory kamu, dia bakal coba ngisi item kamu yang pake &cBlood&r sebagai resource.\\n\\nKalau kamu mau bikin Chalice lebih banyak pakai jaringan yang sama, tinggal pake resep crafting yang pake Chalice bukan Gold Ingot"]
	quest.0BB0DF36B079558F.title: "&6Entangled Chalice"
	quest.0BB367839D28607D.quest_desc: ["&8Coal Generator&r adalah salah satu generator yang paling mudah dibuat.\\n\\nAlat ini sangat simpel digunakan dan menghasilkan daya yang lumayan berdasarkan bahan bakar yang kamu masukkan. Alat ini juga otomatis menyalurkan daya ke blok di sekitarnya."]
	quest.0BB367839D28607D.quest_subtitle: "Bahan Bakar Fosil"
	quest.0BB367839D28607D.title: "&8Coal Generators"
	quest.0BB42C5861B22D32.quest_desc: ["&bMycelial Reactor&r terdiri dari semua Mycelial Generator yang bekerja secara bersamaan di dekat blok reaktor, dan menghasilkan total daya sebesar &a25MFE/t&r.\\n\\nTerdengar hebat, tapi kamu harus mengotomatisasi banyak hal agar reaktor ini bekerja. Lihat apa yang dikonsumsi setiap Mycelial Generator; sebagian besar mudah, tapi ada juga yang sulit... &oseperti Disenchanting Mycelial Generator&r.\\n\\nSetelah kamu berhasil mengotomatisasi semuanya, kamu bisa membuat lebih dari satu reaktor."]
	quest.0BB42C5861B22D32.quest_subtitle: "Bukan Yourcelial Reactor"
	quest.0BB42C5861B22D32.title: "&9Industrial Foregoing: &bMycelial Reactor"
	quest.0BB562FB44B0AAA7.quest_desc: ["Bukan cuma Kartu yang punya batas, jadi mereka juga bukan satu-satunya yang bisa dipasang Overclocker! \\n\\nOverclocker ini dimasukkan ke &cNode&r itu sendiri di bagian bawah kanan dan akan mempercepat seberapa sering operasi dilakukan."]
	quest.0BB562FB44B0AAA7.quest_subtitle: "Maks: 8"
	quest.0BB8D556305EB307.quest_desc: [
		"Ether River itu sesuatu yang bakal kamu langsung tau kalau kamu lihat. \\n\\nTerang banget, sangat terang dan mungkin keliatan merah di Map kamu, itu bug abaikan aja. "
		"{image:atm:textures/questpics/eternal/starlight_ether.png width:200 height:100 align:center}"
	]
	quest.0BB8D556305EB307.title: "Ether River"
	quest.0BC106B34AD386E5.quest_desc: ["&l&cRegions Unexplored&r adalah mod biome lainnya, yang baru ada di &l&6AllTheMods!&r \\n\\nTentu saja dengan biome baru, hadir pula pepohonan baru!"]
	quest.0BC106B34AD386E5.title: "Kayu &l&cRegions Unexplored&r"
	quest.0BCB7E97BC566683.quest_subtitle: "Olahlah 6 Telur Spawn Iron Bee di Centrifuge untuk mendapatkan 1 Telur Spawn Manganese Bee"
	quest.0BCB7E97BC566683.title: "Manganese Bee"
	quest.0BCC79C1D002F532.quest_desc: ["Untuk bikin &bArcane Crystal Dust&r jadi &bLiquid Aureal&r, kita butuh liquid! Sebenarnya kita butuh THE Liquid... yaitu &9Air&r! \\n\\nCukup pipe &9Air&r dari &9Sink&r, itu unlimited."]
	quest.0BCC79C1D002F532.title: "&9Air&r Unlimited!!!"
	quest.0BCCDE24D378F260.quest_subtitle: "Tier: &d3"
	quest.0BCCDE24D378F260.title: "&dAdvanced Machine Frame"
	quest.0BD6365534BF04D5.quest_desc: [
		"Dengan Lime Chalk, saatnya mendalami &5Ritual Perasukan (Possession)&r. Ritual ini sedikit berbeda karena membutuhkan tumbal hidup, biasanya mob kecil seperti Ayam, Lebah, Kelelawar, dll. Namun, seiring ritual menjadi lebih rumit, tumbal yang dibutuhkan akan semakin besar. "
		""
		"Bahkan jika kamu sudah menaruh semua item yang dibutuhkan dan Book of Binding ke dalam Golden Sacrificial Bowl, Ritual tidak akan dimulai sampai kamu membunuh tumbal di atas simbol rune."
		""
		"Disarankan untuk membuat item penangkap mob seperti Empty Soul Gem, Toples, Mob Imprisonment Tool, atau Quantum Catcher!"
		""
		"Tingkat pertama &5Ritual Perasukan&r adalah &eHeidryn's Lure&r, yang hanya digunakan untuk mendapatkan item biasa seperti Kepala Skeleton dan End Stone. Karena itu, kamu bisa langsung melompat ke tingkat ritual kedua, &aIhagan's Enthrallment&r. "
	]
	quest.0BD6365534BF04D5.quest_subtitle: "Siapa yang akan kamu panggil?"
	quest.0BD6365534BF04D5.title: "&aIhagan's Enthrallment"
	quest.0BD908937BC6E97B.quest_subtitle: "Kapok + Rosewood"
	quest.0BE2E7C9454058C3.quest_desc: [
		"Bagian dari &d&lFloral Meadow&r yang indah adalah sebuah &dPohon Ceri&r yang jauh lebih tua dan lebih besar dari yang lain. \\n\\nPara &6L&8e&6b&8a&6h&r tampaknya menyukai &dPohon-pohon&r ini dan telah membangun &eHive&r kecil di sampingnya yang penuh dengan anak-anak mereka!"
		"{image:atm:textures/questpics/bumblezone/bumble_cherry.png width:200 height:100 align:center}"
	]
	quest.0BE2E7C9454058C3.title: "&dPohon Ceri Veteran"
	quest.0BE6CE2C264140AD.quest_subtitle: "Tingkat: &a2"
	quest.0BFAF1499415DD68.quest_subtitle: "Silver Lime + Cherry"
	quest.0C096EE635645E43.quest_desc: ["Crystal Crossbow di-craft kayak Mechanical Crossbow cuma pakai Kristal bukan tongkat. \\n\\nDia nembak Arrow dan damage-nya sama kayak Crossbow biasa tapi yang ini ngasih Crystal Infection. Crystal Infection ngasih 1 damage tiap detik sama Kristal yang spawn di mereka! Dan ya itu bakal bunuh mereka."]
	quest.0C176F04D32B75DD.quest_desc: ["&cBaja Naga Api&r dibuat dengan kombinasi &cDarah Naga Api&r dan &7Besi&r di &c&lPemalsuan Naga Api&r. \\n\\nKita bisa bikin Senjata dari ini! Senjata-senjata ini bakal kasih Damage gede, plus bakal Knockback Mob dan nyalain mereka &cApi&r. \\n\\nSelain Senjata juga ada Armor. Armor ini kasih Stats yang banyak, dan keren! Plus ngelindungin kita ekstra dari &cSerangan Elemental Naga&r! \\n\\nKenapa cuma dapetin Armor buat kita doang? Gimana &c&lNaga&r kita juga! Ini lebih mahal banyak, tapi bakal kasih Proteksi yang banyak buat &c&lNaga&r kamu apalagi kalo lawan &c&lNaga&r lain."]
	quest.0C176F04D32B75DD.title: "&cBaja Naga Api"
	quest.0C1D55AA9CC902BD.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemotong Rumput"
		"- Penyapu Langit"
		"- Pelebur Otomatis"
		"- Palu"
		"- Teleporter Barang Jatuhan"
	]
	quest.0C229BE9B57269EF.quest_desc: ["&#EBA844Kanthal Dust&r harus dibakar di dalam &#816DF7Electric Blast Furnace&r."]
	quest.0C25F73C0E0FB22A.quest_desc: ["Essence lain yang diperlukan untuk &c&lAutomatic Forge&r adalah &aExperience&r! Well itu &aFluid XP&r dari &3&lJust Dire Things&r. \\n\\nUntuk dapet &aXP Fluid&r kita butuh &aExperience Holder&r, ini bisa di-set untuk collect &aXP&r di area tertentu dengan opsi Collect XP. \\n\\nJangan khawatir, Mob yang dibunuh &7Spiked Plate&r masih drop &aXP&r, jadi taruh ini di samping Farm kamu! \\n\\nKamu juga bisa deposit bentuk &aFluid XP&r lain ke sini atau bahkan &aXP&r level kamu sendiri!"]
	quest.0C25F73C0E0FB22A.title: "Auto &aExperience"
	quest.0C2EC56133D3CC6C.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Sementara membuat pemain kebal terhadap kerusakan saat diaktifkan, memiliki cooldown."
	]
	quest.0C7491BA5857AA00.quest_subtitle: "Teak + Jungle"
	quest.0C7D96DB3573EF9C.quest_desc: [""]
	quest.0C7D96DB3573EF9C.quest_subtitle: "&oKemampuan untuk menciptakan kehidupan."
	quest.0C7D96DB3573EF9C.title: "&5&lCreative Essence"
	quest.0C8180524757B238.quest_desc: [
		"&7Floater&r secara teknis bukanlah struktur dalam file Minecraft, tapi sering dianggap struktur oleh pemain. \\n\\nMereka bisa muncul di biome mana pun, tapi selalu ada banyak di &7&lHowling Constructs&r! \\n\\nBentuknya seperti piringan melayang yang terbuat dari Ancient Wax. Jika kamu belum menggunakan Essence of Bees, kamu akan terkena efek Weakness, Slowness, dan Mining Fatigue saat menyentuh Ancient Wax. Ada juga &6Honey Cocoon&r atau &5Kristal&r di atasnya!"
		"{image:atm:textures/questpics/bumblezone/bumble_floaters.png width:200 height:100 align:center}"
	]
	quest.0C8180524757B238.title: "&7Piringan Melayang"
	quest.0C82CE3AFBD48C1E.quest_desc: ["&l&aSushi Go Crafting&r tidak menambahkan banyak blok, tetapi yang ada sangat aku rekomendasikan untuk digunakan di Dapurmu! \\n\\nTerutama Rice Cooker; tidak perlu lagi pakai microwave untuk memasak nasi."]
	quest.0C82CE3AFBD48C1E.title: "&l&aSushi Go Crafting&r"
	quest.0C856BBB1679A7DD.quest_desc: ["Di halaman ini, kamu akan menemukan beberapa item dan informasi berguna untuk membantumu dalam petualangan!"]
	quest.0C856BBB1679A7DD.quest_subtitle: "Dan Item Bermanfaat Lainnya!"
	quest.0C93D7A607AB8B83.quest_desc: ["Untuk mengklaim chunk, buka peta menggunakan tombol &6M&r, lalu klik ikon &aClaimed Chunks&r di pojok kiri atas.\\n\\nUntuk mengklaim chunk, klik kiri dan tahan untuk menarik area yang ingin diklaim.\\n\\nUntuk memaksa pemuatan (force load) suatu chunk, gunakan shift-klik kiri pada chunk tersebut. Jika berhasil, kamu akan melihat garis-garis di seluruh chunk tersebut."]
	quest.0C94D76B87E49FFD.title: "Pengolahan Besi"
	quest.0C98503A2F20484D.quest_desc: [
		"Di dekat Frostfields, kamu mungkin menemukan Frosty Smogstem Forest. \\n\\nTempat ini mirip Frostfields tapi dipenuhi dengan Pohon Smogstem!"
		"{image:atm:textures/questpics/undergarden/undergarden_frostytrees.png width:200 height:100 align:center}"
	]
	quest.0C98503A2F20484D.title: "Frosty Smogstem Forest"
	quest.0C9C5639D76FDF65.quest_desc: ["Selamatkan 12 &6L&8e&6b&8a&6h&r dengan memasangkan kembali sengat mereka. \\n\\nSaat seekor &6L&8e&6b&8a&6h&r menyengat mob atau kamu, mereka akan kehilangan sengatnya dan terkena Fatal Poison (Racun Mematikan). \\n\\nJika kamu Klik Kanan mereka dengan item Stinger (Sengat), kamu bisa memasangnya kembali dan menyelamatkan nyawa mereka!"]
	quest.0C9DD8E53A1B92C0.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penambang Bijih"
		"- Pelebur Otomatis"
		"- Palu"
		"- Teleporter Barang Jatuhan"
		"- Tembus Pandang"
		"- Hancur Seketika"
	]
	quest.0CBFE2CE53DCACD5.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Meningkatkan tinggi lompatan pemain."
	]
	quest.0CC0632E8276C787.quest_desc: ["Letakkan Teleport Pad di &l&cThe Nether&r untuk pergi ke &b&lThe Other&r."]
	quest.0CC0632E8276C787.title: "&c&lThe Nether"
	quest.0CC48C2AA553A314.quest_desc: ["&3Drill Bit&r (Mata Bor) dapat digunakan pada Pneumatic Jackhammer."]
	quest.0CD04A00529FE1C9.quest_desc: ["Copper Chest bisa dibuat tetapi tidak wajib untuk membuat Iron Chest. Bisa digunakan jika kamu ingin menghemat Besi (Iron)."]
	quest.0CD04A00529FE1C9.title: "&6Copper Chest"
	quest.0CD36928116E868E.quest_desc: ["&#F783F3Vinyl Chloride&r dapat dicampur dengan &#9683F7Lead Tiny Dust&r atau &#FEA8FFChromium Tiny Dust&r untuk mendapatkan &#F36EF5PolyVinyl Chloride (PVC)&r."]
	quest.0CD6F30BBEE20E15.quest_subtitle: "Glowstone + Osmium"
	quest.0CD6F30BBEE20E15.title: "Refined Glowstone Bee"
	quest.0CE1F6DE5FD6A6D9.title: "&aEvocation&r Upgrade Orb"
	quest.0CE236731DF15DFF.quest_desc: ["Kenapa harus menunggu? Biasanya item yang jatuh di Minecraft butuh waktu satu detik sebelum bisa diambil kembali. \\n\\nTapi kenapa harus menunggu?\\n\\nUpgrade ini membuat Vacuum Module tidak perlu menunggu dan langsung mengambil item tersebut secara instan. \\n\\nSangat bagus untuk mengurangi lag!"]
	quest.0CF69DBA9573A7B3.quest_desc: [
		"Meja Skematik akan membaca dan menulis struktur dari/ke file skematikmu."
		""
		"Bisa dipakai untuk menyalin bangunan atau berbagi dengan orang lain!"
	]
	quest.0D01524F249E25D7.quest_subtitle: "Siapa yang matiin lampunya?"
	quest.0D01524F249E25D7.title: "&8Dark Xychorium Gems"
	quest.0D18BBB04693885A.quest_desc: ["Strigeor's Higher Binding adalah tingkat kedua dari &6Ritual Infusi&r. Ini digunakan untuk banyak hal, tapi yang paling utama kita butuhkan adalah Infused Pickaxe dan Gray Paste."]
	quest.0D18BBB04693885A.quest_subtitle: "Ritual \"Segalanya\""
	quest.0D18BBB04693885A.title: "&aStrigeor's Higher Binding"
	quest.0D19FB62C2C1D9F7.quest_desc: ["Setelah punya setidaknya 200 &4Mahou&r mungkin ingin membuat Boundary of Life Drain. \\n\\nSetiap Mob yang mati di boundary itu, dapat 10 &4Mahou&r kembali, tapi ini proses yang LAMBAT."]
	quest.0D19FB62C2C1D9F7.title: "Boundary of Life Drain"
	quest.0D212038C0A45E0B.quest_desc: ["Kartrid Casull adalah Peluru default. Memberikan 5 Hati Kerusakan, dan itu saja! \\n\\nKartrid Penusuk Armor akan memiliki peluang lebih tinggi mengabaikan Poin Armor. Sempurna melawan Mob seperti Bulwark. \\n\\nCangkang Buckshot akan menembakkan beberapa Proyektil, bukan 1 Proyektil. Gunakan dalam jarak dekat untuk efek terbaik! \\n\\nKartrid Perak akan bertindak seperti Kartrid Casull tetapi dengan Kerusakan lebih tinggi terhadap Mob Undead: Zombie dan Kerangka!"]
	quest.0D212038C0A45E0B.title: "Proyektil Umum"
	quest.0D26E5EF6CFCFDBF.quest_desc: ["Durabilitas lebih tinggi dari Belati (Dagger), tapi damage dan kecepatannya lebih rendah."]
	quest.0D26E5EF6CFCFDBF.quest_subtitle: "Tusuk-tusuk"
	quest.0D2D1F99945BA209.quest_desc: ["Seharusnya Melengkapi &8&lPerisai Berlapis Berat&r saat kamu Tekan S dua kali... penekanan pada seharusnya. \\n\\nIngat bahwa &8&lIE&r masih dalam versi Beta! Pengembangan Mod membutuhkan banyak waktu dan usaha, hormati itu!"]
	quest.0D2F5CC96269F9E3.quest_desc: ["Langkah selanjutnya dalam pembuatan PCB melibatkan penggunaan &3Etching Tank&r dengan Etching Acid. Membutuhkan panas agar bisa berjalan."]
	quest.0D2F5CC96269F9E3.quest_subtitle: "Waktunya Proses Etching!"
	quest.0D31CD79BE6CC8D2.quest_desc: ["Kenapa roti biasa nggak butuh ragi (yeast)?"]
	quest.0D31CD79BE6CC8D2.quest_subtitle: "Masalah Ragi yang Sepele"
	quest.0D31CD79BE6CC8D2.title: "Ragi (Yeast)"
	quest.0D330FAD6C993DBC.quest_desc: ["Inilah upgrade berikutnya untuk Spellbook milikmu! \\n\\nUpgrade ini akan meningkatkan total mana dan regenerasi mana, serta memungkinkanmu untuk membuat dan menggunakan Glyph Tingkat 2."]
	quest.0D4C64DD58567758.quest_desc: ["Menambahkan tangki cairan ke dalam Tas."]
	quest.0D4FE97640F2CA60.quest_desc: ["&bUltra Destructor&r memiliki 36 slot filter, bekerja 5x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.0D4FE97640F2CA60.title: "&bUltra Destructor"
	quest.0D5015B8FF482D0A.quest_desc: [
		"Kita perlu memesan beberapa barang dari &3Amadron&r menggunakan &3Amadron Tablet&r untuk melanjutkan progres. Untuk menggunakannya, Shift+Klik Kanan pada sebuah Peti dan Tangki Cairan, masukkan mata uangmu ke kontainer yang terhubung (Emerald, dll), lalu pesanlah sesuatu. Kamu akan melihat Drone Amadron datang mengambil uangmu dan drone lainnya datang mengantar pesananmu."
		""
		"{image:atm:textures/questpics/pneumaticcraft/amadron_drone.png width:300 height:150 align:center}"
	]
	quest.0D5015B8FF482D0A.quest_subtitle: "Kira-kira ada paket pengiriman sehari sampai nggak ya?"
	quest.0D5015B8FF482D0A.title: "Amadron"
	quest.0D50BDEFA0319EA1.quest_desc: ["Ini akan menaruh produk jadi ke dalam peti output (keluaran) kamu."]
	quest.0D50BDEFA0319EA1.quest_subtitle: "Selalu Dibutuhkan"
	quest.0D5691403AEC25A8.quest_desc: [
		"Router juga bisa digunakan untuk Bertani!\\n\\nPertama, mulailah dengan kebun sederhana. Kemudian kamu butuh Activator Module dan arahkan ke tanaman. Setelah itu, pasang Vacuum Module di Router untuk mengumpulkan hasil panen. Terakhir, pasang semuanya, beri tenaga Redstone, dan biarkan ia bekerja!"
		"{image:atm:textures/questpics/router/router_farm.png width:60 height:150 align:center}"
	]
	quest.0D5691403AEC25A8.title: "Router untuk Bertani"
	quest.0D5D76B3551CD5A7.quest_desc: ["Ya, namanya Aluminium Bee."]
	quest.0D5D76B3551CD5A7.quest_subtitle: "Crystalline + Ashy Mining"
	quest.0D5D76B3551CD5A7.title: "Aluminium Bee"
	quest.0D61473D7A09CD48.quest_desc: [
		"Salah satu &lMultiblock&r paling penting, terutama karena kita butuh ini untuk &lMultiblock&r lain. \\n\\nDi sini kamu butuh &bFluid Input&r (tiap &bInput&r cuma bisa tahan 1 tipe &bFluid&r jadi kamu butuh beberapa), &cEnergy Input&r, dan &eItem Input&r dan Output Hatch. \\n\\nPakai Hatch tersebut kita bisa input semua &eItem&r, &bFluid&r, dan &cEnergy&r dan akan craft Item kita, seperti &5Multiblock Controller&r lain! \\n\\nAtau craft Item yang diperlukan untuk &6Star Part&r! Kamu butuh banyak &4Blood&f, &bAureal&f, Soul, dan &cEnergy&r untuk mereka!"
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap3/creative_forge1.png width:150 height:100 align:center}"
		"Layer pertama cukup simpel. Cuma beberapa &9Polished Darkstone Block &fdan &9Stair&r. Sama dengan &7Rune Block&r dan &6Arcane Polished Darkstone&r. Oh tunggu, hampir lupa Blok paling penting! &5Forge Block&r"
		"{image:atm:textures/questpics/chap3/creative_forge2.png width:150 height:100 align:center}"
		"Layer berikutnya akan ada lebih banyak &9Darkstone&r dalam &9Block&f, &9Stair&f, dan &9Slab&r dan bahkan &6Gilded Arcane Polished Darkstone&r dan &6Chiseled Polished Arcane Darkstone&r. Jangan lupa 4 &bArcane Crystal Obelisk&r!"
		"{image:atm:textures/questpics/chap3/creative_forge3.png width:150 height:100 align:center}"
		"Yang ini sangat gampang! Cuma kotak &9&lTier 5 &6Forge&r di tengah dengan 8 &6Darkstone Pedestal&r 2 Blok dari sana."
		"{image:atm:textures/questpics/chap3/creative_forge4.png width:150 height:100 align:center}"
		"Kita skip layer karena gak ada yang ditambah di sana! Sebagai gantinya, dengan Blok space di antaranya. Taruh &7Quantum Injector&r di atas &9&lTier 5 &6Forge&r. "
		"{image:atm:textures/questpics/chap3/creative_forge5.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/chap3/creative_forge6.png width:200 height:100 align:center}"
		"Terakhir taruh beberapa Hatch lagi! Kita butuh mereka!"
	]
	quest.0D6D45DBA64E612D.quest_desc: ["Maximum Spawn Delay adalah batas waktu maksimal yang dibutuhkan untuk memunculkan mob. Sama seperti batas Minimum, nilainya bisa serendah 20 hingga setinggi 32.767. Setiap Clock akan mengubah kecepatan spawner sebanyak 10. Kecepatan ini dinyatakan dalam 'ticks', di mana 20 ticks sama dengan 1 detik. Jadi, delay spawn tercepat adalah 1 detik di antara setiap pemunculan."]
	quest.0D6D45DBA64E612D.title: "Maximum Spawn Delay"
	quest.0D888A4C5EF0073E.quest_subtitle: "Mahogany + Kapok"
	quest.0D8B4DAB82ABEF9D.quest_desc: ["Quantum Accelerator menambah 12 thread co-processing masing-masing ke multiblock Quantum Computer. Penting dicatat bahwa semua job crafting yang dijalankan Quantum Computer bisa berbagi semua co-processor, jadi investasi banyak di ini ide bagus."]
	quest.0D8B4DAB82ABEF9D.title: "Co-Processing Luar Biasa: Quantum Computer Accelerator"
	quest.0D91A6B36BD2F526.quest_desc: ["Tingkatkan &7Cloggrum Battleaxe&r milikmu untuk membuat senjata terhebat yang bisa diberikan &2&lUndergarden&r!"]
	quest.0D91A6B36BD2F526.title: "Senjata Pamungkas!"
	quest.0D9560C8E247F9E7.quest_desc: ["Klik Kanan pada suatu tempat dan kamu akan bisa melacak jalan pulang. Jika kamu cukup dekat dan memiliki rute langsung, sebuah jalur akan muncul di layar."]
	quest.0D9560C8E247F9E7.quest_subtitle: "Maks: 1"
	quest.0D97CDE92F3B1A83.quest_subtitle: "Tuangkan Molten Enderium ke atas telur lebah lead/diamond/platinum"
	quest.0D97CDE92F3B1A83.title: "Enderium Bee"
	quest.0DABAD0803DCEA0E.title: "Ngomando &c&lNaga&r kamu"
	quest.0DABAD0803DCEA0F.quest_desc: ["&c&lNaga&r sekarang jadi punya kita! Gimana cara pakenya? \\n\\nPertama, kita butuh beberapa Alat! &7Tongkat Komando Naga&r, buat kasih instruksi. &7Terompet Naga&r buat pegang dan transportasi &c&lNaga&r. Dan &7Seruling Naga&r buat manggil &c&lNaga yang Terbang&r turun. \\n\\nLo bisa Shift Klik Kanan &c&lNaga&r buat liat Inventory dan UI-nya. Di sini kita liat Umur, &4Health&f, &lStage&r dan ubah Inventory-nya. Armor apa yang dipake dan apakah pake Banner! \\n\\nKita bisa pake &7Tongkat Komando Naga&r ke mereka buat ubah apakah mereka Mengawal, Berkeliaran, atau Diam. Mengawal berarti mereka bakal ngikutin kamu dan Berantem sama kamu. Berkeliaran berarti mereka bakal Terbang keliling area tertentu, Nyerang Monster apapun di dalamnya. Diam ya berarti dia bakal Duduk di tempatnya dan gak ngapa-ngapain! \\n\\n&7Terompet Naga&r bisa dipake ke &c&lNaga&r buat masukin mereka ke dalamnya. Di sini mereka bakal aman dan ringkas tersimpan di Item-nya dimana kamu bisa liat Umur, Jenis Kelamin, dan Namanya. \\n\\nItem terakhir, &7Seruling Naga&r dipake buat semua Mob Terbang yang Jinak. Kalo mereka Terbang pas kamu pake &7Seruling&r, mereka bakal turun ke tanah."]
	quest.0DAF5D42694EA8C9.quest_desc: [
		"&#6E6D6D&nForge Hammer&r adalah awal dari perjalananmu. Alat ini memiliki banyak kegunaan, mulai dari mendapatkan &#B53A3Ahasil produksi yang lebih banyak&r dari bijihmu hingga membuat &#DBD25Akomponen&r untuk kebutuhan crafting di masa depan."
		""
		"&7Palu (Hammer)&r yang kamu craft tidak wajib ada dalam resep, tetapi ia akan memberikan hasil produksi yang lebih baik pada &#DBD25Akomponen&r yang kamu buat."
	]
	quest.0DAF5D42694EA8C9.title: "&#949494Forge Hammer"
	quest.0DC0E236C8213050.quest_desc: ["Dengan gabungin 500mB Unrefined Liquid Soul dengan satu Soul, kita bisa bikin 500mB Liquid Soul! \\n\\nIni butuh dua kali jumlah &dSource&r yang dibutuhkan &bLiquid Aureal&r, di 2000 &dSource&r."]
	quest.0DC0E236C8213050.title: "Liquid Soul"
	quest.0DC8B68CDF945348.quest_desc: ["Router memberi dan Router mengambil. \\n\\nModule ini sangat membantu bagi pembangun (Builder) atau penambang! Ia bisa diatur untuk mengirim item dari Buffer ke inventarismu atau mengambil item dari inventarismu ke dalam Buffer-nya. \\n\\nSempurna untuk Strip-Mining; biarkan ia mengambil semua Cobblestone dan Deepslate dari inventarismu lalu buang ke tempat sampah."]
	quest.0DF4B01CC5B49E4E.quest_desc: ["Dengan Cast ini, kamu bisa membuat pedang standar! Damage dan kecepatan yang bisa diandalkan."]
	quest.0DF4B01CC5B49E4E.quest_subtitle: "Andalan yang Terpercaya"
	quest.0E02CE4469FCA4C9.quest_desc: ["Redstone Activation memberikan spawner kamu saklar on/off. Tanpa daya Redstone, spawner tidak akan memunculkan mob."]
	quest.0E02CE4469FCA4C9.title: "Redstone Active"
	quest.0E03F5EAE4963ECB.quest_subtitle: "8 Blok Hijau Kering"
	quest.0E057B7F76401421.quest_subtitle: "Upgrade Pertama"
	quest.0E057B7F76401421.title: "&6Copper Backpack"
	quest.0E06F323BF8C1D73.quest_desc: [
		"Mengingat Budding Entroized Fluix pasti decay, kamu mungkin mau cara lain buat farm otomatis."
		""
		"Untungnya, ada bee buat itu. Dan ada seed juga."
	]
	quest.0E06F323BF8C1D73.quest_subtitle: "Buat yang males sama decay"
	quest.0E06F323BF8C1D73.title: "Automasi Entro Crystal"
	quest.0E0CAA31480EC0A1.quest_desc: ["Memungkinkan Tas untuk mengambil item yang jatuh secara otomatis."]
	quest.0E0CAA31480EC0A1.quest_subtitle: "Memungkinkan tas mengambil item otomatis."
	quest.0E175356D43E6A10.quest_desc: [
		"Bagus-bagus, sekarang kita punya &eChlorine&r. Apalagi yang kita butuh buat &3Hydrogen Chloride&r? Oh iya, Hydrogen! \\n\\nKasih &9Air&r ke &9&lElectrolytic Separator&r, kayak di Tier 1, buat dapat Hydrogen dan &bOxygen&r. Cuma kali ini kita harus simpan Hydrogen-nya. \\n\\nPakai &a&lChemical Infuser&r kita bisa gabungin Hydrogen dan &eChlorine&r buat bikin &3Hydrogen Chloride&r. \\n\\nAlirkan &3Hydrogen Chloride&r itu ke &c&lChemical Injection Chamber&r buat &cInject (suntik) &7Ore&r biar jadi &7Shard&r. \\n\\n&7Ore Block&r bakal jadi 4 &7Ore Shard&r sedangkan 3 &7Raw Ore&f bakal jadi 8 &7Ore Shard&r."
		"{image:atm:textures/questpics/mek/mek_tier3_2.png width:150 height:100 align:center}"
	]
	quest.0E175356D43E6A10.quest_subtitle: "Pengolahan Bijih Tier 3"
	quest.0E175356D43E6A10.title: "&cInjecting &3Hydrogen Chloride"
	quest.0E1ABCAA87120367.quest_subtitle: "Tingkat: &c5"
	quest.0E20A9B79D1C6637.quest_desc: ["Warden adalah bos yang ditambahkan pada versi 1.20. \\n\\nIa muncul jika ada 3 Sculk Shrieker alami yang berbunyi berturut-turut, atau Shrieker mana pun yang berbunyi setelah Warden pertama muncul. \\n\\nIa adalah mob paling kuat di Minecraft, dengan 500 HP dan damage serangan lebih dari 20 HP. \\n\\nSerangannya termasuk pukulan jarak dekat dan Sonar Blast untuk musuh yang jauh. \\n\\nSatu-satunya kelemahannya adalah buta, tapi seperti Daredevil, itu justru membuat indra lainnya jauh lebih kuat! Jika kamu dekat, ia bisa mencium baumu, jadi hati-hatilah saat mengeluarkan suara! \\n\\nJika kamu entah bagaimana berhasil membunuhnya, ia akan menjatuhkan: Sculk Catalyst, Warden Carapace, dan Heart of the Deep."]
	quest.0E20A9B79D1C6637.title: "Kalahkan Warden"
	quest.0E2515424291BB59.quest_desc: ["Versi &bDiamond&r untuk armor &d&lArs&r!"]
	quest.0E2515424291BB59.quest_subtitle: "20"
	quest.0E2515424291BB59.title: "&5Battlemages Outfit"
	quest.0E2AD156E5EF263A.quest_desc: ["Digunakan untuk menuliskan mantra pada Scribe's Table."]
	quest.0E32DB6B8E023764.quest_desc: ["&6&lProductive Bees&r? Apa yang kamu lakukan di sini? \\n\\nTerkadang di sepanjang &6&lHive Wall&r atau &6&lPillar&r kamu mungkin menemukan tumpukan Sarang (Combs) dari mod &l&6Productive Bees&r! \\n\\nMirip seperti menambang bijih di &2Overworld&r."]
	quest.0E32DB6B8E023764.title: "Kolaborasi Mod?"
	quest.0E345B5B625E6235.quest_subtitle: "Dibuat dengan Enchanting Apparatus"
	quest.0E345B5B625E6235.title: "Earth Essence Bee"
	quest.0E3FDD8BB6D17A30.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Menghancurkan dedaunan di sekitar saat diaktifkan."
	]
	quest.0E487EACA837EA9B.title: "Chaotic Shield Control Module"
	quest.0E4DA8EE961D443F.quest_subtitle: "Sycamore + Sugar Maple"
	quest.0E594BC58CC7476F.quest_desc: [
		"Dia mungkin jahat, tapi dia tetap modis."
		"{image:atm:textures/questpics/iron_spells/spells_outfit_archevoker.png width:60 height:100 align:center}"
	]
	quest.0E594BC58CC7476F.title: "&aArchevoker Outfit"
	quest.0E5AE195158CF344.quest_subtitle: "Upgrade Penyimpanan x32"
	quest.0E5AE195158CF344.title: "&dNetherite Upgrade"
	quest.0E65BE9460B74000.quest_desc: [
		"Logistic Frame harus terhubung ke sebuah &3Logistics Module&r agar bisa berfungsi."
		""
		"{image:pneumaticcraft:textures/patchouli/logistics_module.png width:100 height:100 align:left fit:true}"
	]
	quest.0E716B90E60C486B.quest_desc: ["Kadang cara terbaik untuk bertarung adalah dengan tidak bertarung sama sekali... alias kabur! \\n\\nDengan &4Panic Necklace&r, saat terkena pukul kamu akan mendapatkan efek Speed dalam waktu singkat. Cukup waktu untuk melarikan diri!"]
	quest.0E716B90E60C486B.quest_subtitle: "Kalung"
	quest.0E716B90E60C486B.title: "&4Panic Necklace&r"
	quest.0E809747193ED3A9.quest_desc: ["Tingkat MEGA ketiga dari komponen penyimpanan, menyediakan &e16.777.216&f (16384k) byte penyimpanan."]
	quest.0E809747193ED3A9.quest_subtitle: "x4^2"
	quest.0E809747193ED3A9.title: "Komponen Penyimpanan 16M"
	quest.0E8647B8EB4AAC41.quest_desc: ["Passive Mob -> Pink Slime Lebih Banyak.\\nHostile Mob -> Meat Lebih Banyak."]
	quest.0E8647B8EB4AAC41.title: "Pink Slime \\& Liquid Meat"
	quest.0E9CE6241CDBC420.quest_desc: ["&9Ranged Pump&r sangatlah spesial hingga ia memiliki mod-nya sendiri! \\n\\n&9Pompa&r ini akan mengumpulkan &9Sumber Air (Water Source)&r di bawahnya dan menggantinya dengan Batu (Stone). \\nIa membutuhkan energi untuk bekerja, tapi sangat sepadan karena jangkauannya yang sangat luas! \\n\\n&9Air&r yang terkumpul di dalamnya harus disalurkan keluar menggunakan pipa."]
	quest.0E9CE6241CDBC420.title: "&l&9Ranged Pump"
	quest.0E9DE6293DF611E1.quest_desc: ["Apakah kamu ingin membuat &aOverworld&r terasa lebih seperti &9Twilight Forest&r?\\n\\nKamu bisa menggunakan bubuk ini pada hewan di Overworld untuk mengubah mereka menjadi varian &9Twilight Forest&r.\\n\\nKamu bisa menemukan ini di peti dungeon di &9Twilight Forest&r."]
	quest.0EA327E405EDFF02.quest_desc: ["&#9C6C35Acetylene&r yang dicampur dengan &#DEAB6DHydroChloric Acid&r akan menghasilkan &#F783F3Vinyl Chloride&r."]
	quest.0EA9E52B67B533DF.quest_desc: ["Saat Rubber di-smelt berubah jadi Plastic, yang merupakan resource utama di Industrial Foregoing."]
	quest.0EADCEA9AB001FC7.quest_desc: [
		"Sumber panas yang sangat simpel. Letakkan di bawah mesin dan beri bahan bakar tungku: Batu Bara, Batang Kayu, atau Blok Kelp Kering."
		"{image:atm:textures/questpics/theurgy/theurgy_brazier.png width:100 height:100 align:center}"
	]
	quest.0EADCEA9AB001FC7.title: "Panas Layaknya Tungku"
	quest.0EAF01037BB20BCB.quest_subtitle: "Memanggil Zombie"
	quest.0EB6ED88895366D0.quest_desc: ["Ingat saat pilihannya cuma Batu (Stone) dan Cobblestone?"]
	quest.0EB6ED88895366D0.title: "Batu &2Vanilla&r"
	quest.0EBE20E44A7AEC7E.quest_desc: ["&7Unit&r ini bakal bikin Kaki lo dan hampir seluruh Kaki lo, lebih panjang dan kuat! \\n\\nLo bisa Sprint Jump lebih tinggi dan naik tangga lebih tinggi. \\n\\nLo bisa Jump sama step lebih tinggi dengan lebih banyak &7Unit&r yang di-Install dan lo bisa ubah Config &7Unit&r buat lebih tinggi lagi!"]
	quest.0EBE20E44A7AEC7E.quest_subtitle: "Sepatu"
	quest.0EBE20E44A7AEC7E.title: "&eHydraulic Propulsion &7Unit"
	quest.0EC2053B191C55C6.quest_desc: ["Mengekstrak latex dari log, berjalan lebih cepat saat diberi power.\\n\\nCek JEI untuk log yang diterima dan jumlah Latex. Log terbaik untuk dipakai adalah Acacia."]
	quest.0ED11FCF6298CE85.quest_desc: ["&4Blood Armor&r dari mod &e&lIron's Spells&r!"]
	quest.0ED11FCF6298CE85.quest_subtitle: "20"
	quest.0ED11FCF6298CE85.title: "&4Cultist Outfit"
	quest.0ED7B25DC1AA767B.quest_desc: ["Di dalam &9Twilight Forest&r, terdapat peti loot yang bisa memberimu bibit pohon (sapling) langka.\\n\\nKumpulkan semuanya!"]
	quest.0ED7B25DC1AA767B.quest_subtitle: "Menumbuhkan Pohon"
	quest.0ED7B25DC1AA767B.title: "&aBos Terakhir yang Sebenarnya"
	quest.0EE0946240B41A00.quest_desc: ["&bIgnitium&r adalah upgrade untuk Netherite. Kamu butuh &bIgnitium Upgrade&r yang dibuat lewat crafting, dan &bIgnitium Ingot&r yang dijatuhkan oleh &b&lIgnis&r. \\n\\n&bIgnitium Helmet&r memungkinkanmu melihat dengan jelas di bawah Lava. \\n\\n&bIgnitium Chestplate&r bisa digabung dengan Elytra. \\n\\n&bIgnitium Leggings&r tidak membuatmu kebal api, melainkan membuat api yang membakar tubuhmu padam lebih cepat! \\n&bIgnitium Boots&r memungkinkanmu berjalan di atas Lava. Seperti sepatu kulit di atas salju bubuk, kamu bisa Menahan Shift untuk menyelam ke dalam lava."]
	quest.0EE0946240B41A00.title: "&bIgnitium Armor"
	quest.0EED5D755D2C866A.quest_desc: ["&d&lEnder&r digunakan untuk mengambil semua kekuatan &dEnderman&r dan &dEnder Dragon&r, dan tentu saja menggunakannya untuk diri kita sendiri. &dTeleport&r, &dFireball&r, dan &dDragon's Breath&r hanya beberapa di antaranya! \\n\\n&d&lEnder&r menggunakan &dEnder Pearl&r sebagai Material Fokusnya. \\n\\nDan &dScroll&r-nya berwarna &5Ungu&r dengan teks &dPink&r."]
	quest.0EED5D755D2C866A.title: "&d&lEnder"
	quest.0EF9C391EE42824A.quest_desc: ["Yang ini agak lebih mahal tapi juga lebih seru! \\n\\n&bDiamond&r bisa didapat dari mod apa aja. \\n\\n&7Flint&r (batu api) bisa didapat lewat banyak cara pengolahan Gravel: Squeezing, Crushing, Enriching...? \\n\\nDripstone dan Dripstone Block (gabungan 4 Dripstone) bisa dibuat pakai Extractor atau Mixer, tapi keduanya butuh Dripstone asli buat pancingan awal."]
	quest.0EF9C391EE42824A.title: "&7Terrastomp Prism"
	quest.0EFD0A4AE82153E8.quest_desc: ["Kamu juga perlu men-craft Token ini untuk membuat item lainnya."]
	quest.0EFD0A4AE82153E8.title: "Token Lainnya"
	quest.0EFEDB0DD90DFC81.quest_desc: ["Harvester bisa auto-panen tanaman dan nanem ulang. Item yang dikumpulin Harvester bakal masuk ke inventori internalnya."]
	quest.0EFF1AA37772156B.quest_desc: ["Blok ini kasih air ke multi-block kitchen.\\n\\nJuga bisa kasih air unlimited dengan pompa air keluar via kabel atau pipe."]
	quest.0EFF1AA37772156B.quest_subtitle: "1 Blok sudah cukup!"
	quest.0EFF1AA37772156B.title: "Sink = Air Unlimited"
	quest.0F00BBDF3618B3BA.quest_desc: ["&3Crafting Grid&r memungkinkanmu mengakses penyimpananmu, tetapi lengkap dengan antarmuka crafting!\\n\\nJujur saja, tidak ada yang memakai &3Grid&r biasa."]
	quest.0F00BBDF3618B3BA.title: "&3Grid yang Lebih Baik"
	quest.0F026D5A17CCCF51.quest_desc: ["Item &dNetherite&r lebih bagus secara keseluruhan, dan tidak akan terbakar di lava! Tapi tetap akan terbakar meskipun pakai armornya. Jangan coba-coba.\\n\\nItem ini bisa dipakai untuk membuat beberapa tool dan armor terbaik di game."]
	quest.0F026D5A17CCCF51.title: "Tier &dNetherite"
	quest.0F03E75CF79BADD7.quest_desc: ["&fMEGA Cells&f menawarkan &bBulk Item Storage Cell&f, yang dibatasi hanya untuk &osatu&r jenis item per cell tetapi dapat menyimpan jumlah yang secara praktis &o&lTAK TERHINGGA&r* dari jenis item tersebut. Sebelum bisa menerima item, cell ini harus difilter terlebih dahulu menggunakan Cell Workbench.\\n\\n*&oSecara teknis batas maksimal variabel 'long'.&r"]
	quest.0F03E75CF79BADD7.quest_subtitle: "Penyimpanan Masal"
	quest.0F03E75CF79BADD7.title: "Bulk Item Storage"
	quest.0F0D41F29386333A.quest_desc: ["Scarlet Tree bervariasi ukuran dan bentuknya bahkan kadang roboh! \\n\\nTapi semuanya punya daun pink! Termasuk yang di tanah."]
	quest.0F14270F0A718C01.quest_desc: ["&cMagma&r- 1300 K \\n&cLava&r- 1300 K \\n&aUranium&r- 2000 K"]
	quest.0F14270F0A718C01.title: "&cBarang Hangat"
	quest.0F16498769DFB3B0.quest_desc: ["Untuk apa semua &8Andesit&r itu? Kita butuh &8Paduan Andesit&r! \\n\\n&8Paduan Andesit&r dibuat dengan menggabungkan 2 &8Andesit&r dengan 2 &7Nugget Besi&r atau 2 &7Nugget Seng&r. \\n\\n&8Paduan Andesit&r tidak banyak berguna sendirian, melainkan menjadi bahan dasar hampir semua Mesin dan Item. Jadi ya, kita butuh banyak."]
	quest.0F16498769DFB3B0.title: "&8Paduan Andesit"
	quest.0F1CA44520BDEFEA.quest_subtitle: "6,561 Diamond Block"
	quest.0F1D6F4729CC38F3.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_rib.png width:100 height:150 align:center}"]
	quest.0F1D6F4729CC38F3.quest_subtitle: "Nether Fortress"
	quest.0F1D6F4729CC38F3.title: "Rib Armor Trim"
	quest.0F326EEEC2EBE4E5.quest_desc: [
		"Pakai &d&lEnrichment Chamber&r, kamu bisa &dEnrich &eItem&r buat ngerubah mereka jadi varian &dEnriched&r."
		""
		"&dEnriched Item&r ini kasih 8x jumlah mb di &9&lMetallurgic Infuser&r."
		""
		"&dEnriched &0Coal&r bakal bantu bikin lebih banyak &8Steel&r. &dEnriched &4Redstone&r bantu buat &cInfused Alloy&r dan &aBasic Control Circuit&r. Dan &dEnriched &5Refined Obsidian&r bakal bantu bikin item &dUltimate&r!"
	]
	quest.0F326EEEC2EBE4E5.quest_subtitle: "Enrich item kamu dulu!"
	quest.0F326EEEC2EBE4E5.title: "&dEnriched Items"
	quest.0F3A0A4DC18E5E55.quest_desc: ["&aEterna&r menentukan &5Enchantment Level&r yang mendasari &5Enchantment&r apa yang bisa atau akan kamu dapatkan! \\n\\nNilai standarnya adalah &a0&r dan maksimal &a50&r. \\n\\nHampir semua rak buku memberikan &aEterna&r, tapi masing-masing punya batas maksimalnya sendiri."]
	quest.0F3A0A4DC18E5E55.title: "&aEterna"
	quest.0F3D51FFD2FE8DCB.quest_desc: [
		"Dengan pickaxe tier Diamond, bisa menambang &dObsidian&r. Obsidian bisa dipakai untuk membuat portal ke &cNether&r.\\n\\nFrame portal bisa berbagai ukuran berbeda, tapi kebanyakan pakai bentuk 'Pintu' dasar. Ini adalah bentuk hollow 4x5 menggunakan minimal 10 Obsidian. Tidak harus pakai Obsidian untuk sudutnya, hanya frame portal saja!\\n"
		"{image:atm:textures/questpics/gettingstarted/example_netherportal.png width:175 height:201 align:1}"
	]
	quest.0F3D51FFD2FE8DCB.title: "&cKe Nether&r!"
	quest.0F4783FA019C4567.quest_desc: ["Amaraber ditemuin jarang dengan nge-strip Torreya Log. \\n\\nBisa di-craft jadi Ingot buat bikin Armor dan Tool atau dipake di resep lain kayak campfire yang bakal kasih kamu regen!"]
	quest.0F49E9167B5E97C9.quest_desc: ["Setiap damage yang kamu terima saat jatuh (mengabaikan armor) juga akan diberikan kepada mob di sekitarmu."]
	quest.0F49E9167B5E97C9.quest_subtitle: "Maks: 1"
	quest.0F5549B02D1B383B.quest_desc: ["Kalahkan 16 Cave Spider. \\n\\nJangan khawatir, ada banyak hal di &6&lBumblezone&r yang bisa membantu menangani racun."]
	quest.0F55D0B4D5094EDB.quest_desc: ["Saat membuat banyak alur quest untuk ATM7, si Pedagang Keliling (Trader Villager) merasa lucu jika terus-menerus mendorongku di layar quest.\\n\\n\"Habisi mereka. Semuanya.\"\\n\\n- AlfredGG \\n\\n\"Aku setuju!\" \\n\\n- Toshiba"]
	quest.0F55D0B4D5094EDB.quest_subtitle: "\"Ini Masalah Pribadi\" - AlfredGG"
	quest.0F55D0B4D5094EDB.title: "Kalahkan Pedagang Keliling dan Llama-nya yang Menyebalkan"
	quest.0F7BB4ECCA5C082C.quest_desc: ["Di sinilah tempat kamu memasukkan &eAlchemical Sulfur&r. \\n\\nItem apa pun yang terkandung dalam &eAlchemical Sulfur&r akan diubah kembali menjadi item tersebut melalui proses Inkubasi!"]
	quest.0F7BB4ECCA5C082C.title: "Wadah &eSulfur&r"
	quest.0F89BFD4A3F63A48.quest_desc: ["Beberapa mob (terutama monster) butuh Tingkat Cahaya (Light Level) tertentu untuk muncul. Mob agresif butuh tingkat cahaya rendah, sedangkan yang pasif butuh yang tinggi. Menggunakan Soul Lantern membuatmu tidak perlu khawatir lagi soal cahaya karena spawner akan mengabaikannya! Ini tidak mengabaikan syarat lain, seperti hewan ternak yang tetap butuh rumput (Grass)."]
	quest.0F89BFD4A3F63A48.title: "Abaikan Cahaya"
	quest.0F8B349EBC9110D6.quest_desc: ["Yang ini seru untuk didapatkan! Kita perlu &5Lightning Rod&r dan juga &5Energized Core&r. \\n\\nLalu, saat sedang Badai, Klik Kanan &5Energized Core&r ke &5Lightning Rod&r. Jika benar, &5Lightning&r akan Menyambar. Ini akan mengubah &5Lightning Rod&r menjadi &5Rod o' Lightning&r! \\n\\nRod ini memberikan 5 &4Damage&r dan tetap mempertahankan 15% Cast Time Reduction. Tapi sekarang hanya memberikan 5% &3Spell Power&r dan memberikan 15% &3Spell Power&f untuk &5Lightning Spell&r."]
	quest.0F8B349EBC9110D6.title: "&5Rod o' Lightning"
	quest.0F8F0F7880235BA2.quest_desc: [
		"&cThe Soul BlackSmith&r berada di dimensi Nether. Jangan abaikan tempat ini dan mengira ini cuma Bastion, tempat ini jauh lebih berbahaya. \\n\\nKamu bisa menemukan Emas, Blackstone, dan Netherite di sini. \\n\\nSatu-satunya mob agresif yang muncul di sini adalah sang bos... &c&lNetherite Monstrosity&r!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_blacksmith.png width:200 height:100 align:center}"
	]
	quest.0F8F0F7880235BA2.title: "&cSoul BlackSmith&f: Rumah sang &c&lNetherite Monstrosity&r"
	quest.0F8F37D7E12078F5.quest_subtitle: "Selesaikan semua tips!"
	quest.0F97EFAFD6E68F8D.quest_desc: ["Dengan &7Unit&r ini &dMeka-Tool&r bakal Nambang Blok lebih cepet! \\n\\nMakin banyak yang lo punya, makin cepet! \\nPersis kayak Enchantment Efficiency."]
	quest.0F97EFAFD6E68F8D.quest_subtitle: "Meka-Tool"
	quest.0F97EFAFD6E68F8D.title: "&eExcavation Escalation &7Unit"
	quest.0F9DCF36112C9922.quest_desc: ["&9Armor Penjaga Pasang&r dibuat dari &bSisik Mengkilap&r dan &9Sisik Ular Laut&r. \\n\\nWarna &9Sisik Ular Laut&r bakal nentuin Warna &9Armor Penjaga Pasang&r. Dan gak bisa campur Warna! \\n\\nTotal Armor Points dari &9Armor Penjaga Pasang&r itu 23, yang lebih banyak dari &cNetherite&r! \\n\\nSetiap bagian Armor juga kasih kamu &9Water Breathing&r. Bahkan kalo kamu cuma pake &9Boots&r-nya. Mereka juga kasih level &4Strength&r buat setiap bagian Armor yang dipake. Set lengkap kasih &4Strength IV&r!"]
	quest.0F9DCF36112C9922.title: "&9Armor Penjaga Pasang"
	quest.0FA77C28A57E06F1.quest_desc: ["Veiled Mushroom hanya bisa ditemukan di rawanya sendiri. \\n\\nJamur ini punya tudung cokelat yang jika ada celah udara di bawahnya, akan menumbuhkan tudung jamur menjuntai (Mushroom Veil). Itulah asal namanya!"]
	quest.0FAAE744E156D8EF.quest_desc: ["&bMycelial Reactor&r terdiri dari semua Mycelial Generator yang bekerja bersamaan, dekat block reactor, dan menghasilkan total &a25MFE/t&r.\\n\\nSemuanya terdengar bagus, tapi perlu mengotomasi beberapa hal untuk membuatnya bekerja, lihat apa yang dikonsumsi setiap Mycelial Generator untuk bekerja, dan otomasi itu, kebanyakan hal sederhana, tapi yang lain, tidak terlalu... &olihat Disenchanting Mycelial Generator&r.\\n\\nTapi setelah semua diotomasi, tidak perlu berhenti di satu, bisa membuat lebih banyak reactor."]
	quest.0FAAE744E156D8EF.quest_subtitle: "Mycelial Reactor, huh?"
	quest.0FAF274ADA65B26A.quest_desc: ["Cairan Portal adalah cairan hijau misterius yang vital untuk pengoperasian Pistol Portal Tingkat Lanjut.\\n\\nMenjatuhkan Katalis Cairan Portal ke dalam Cairan Polimorfik akan membuat Cairan Portal Tidak Stabil TAPI Cairan Portal Tidak Stabil hanya bisa ada di Akhir. Melakukan Penyebaran Lendir dengan lendir Tingkat Tiga atau lebih tinggi akan mengubah Cairan Portal Tidak Stabil menjadi Cairan Portal."]
	quest.0FB1FC640471363A.quest_subtitle: "Lapis + Emerald"
	quest.0FB1FC640471363A.title: "Experience Bee"
	quest.0FD26FD88E801C0E.quest_desc: ["Kamu bisa membuat banyak jenis mob vanilla menggunakan &2Altar of Birthing&r. &dSpirits of Birthing&r dibuat dengan cara mengawinkan hewan di area yang memiliki jumlah aura yang besar. "]
	quest.0FD26FD88E801C0E.quest_subtitle: "Membuat Bayi dengan Sihir"
	quest.0FD26FD88E801C0E.title: "&2Altar of Birthing"
	quest.0FD62827710F0AC6.quest_desc: ["&cMagmator&r akan menghasilkan energi FE saat disuplai dengan Lava."]
	quest.0FD638380EECFFBD.quest_desc: [
		"{image:atm:textures/questpics/forbidden/forbidden_forge1.png width:100 height:100 align:center}"
		"Untuk mulai bikin Forge, taruh &9Polished Darkstone&r, &6Arcane Polished Darkstone&r, dan &6Gilded Chiseled Polished Darkstone&r dengan pola ini. "
		"{image:atm:textures/questpics/forbidden/forbidden_forge2.png width:100 height:100 align:center}"
		"\"Lalu taruh Smithing Table kita di &6Gilded Chiseled Polished Darkstone&r dalam dan pukul dengan &cMundabitur Dust&r, kamu akan dapet &6&lHephaestus Forge&r!\\n\\nTerakhir taruh &6Darkstone Pedestal&r kita di atas 8 &6Gilded Chiseled Polished Darkstone&r luar!\""
	]
	quest.0FD638380EECFFBD.title: "Bangun &6&lForge"
	quest.0FE30548F25FEDB1.quest_desc: ["Jika kamu sepertiku dan tidak suka tinggal di dalam kotak (itu mengingatkanku pada sekolah), maka kamu akan suka memasang Kaca di bangunanmu untuk melihat ke luar. \\n\\nMeskipun kaca Vanilla normal sudah bagus, tentu kita bisa membuatnya jauh lebih baik! \\n\\nKita bahkan bisa mendapatkan kegunaan lain darinya!"]
	quest.0FE94BE5ADB6E595.quest_desc: [
		"Tersembunyi di dalam &bHutan Warped Kuno&r kita bisa nemuin &aGua Hydra&r. kamu paling mungkin nemuin satu secara gak sengaja pas lagi ngider, karena mereka tersembunyi banget. \\n\\nMereka itu bukit kecil yang berongga di dalam &bHutan Warped Kuno&r dengan &7Bata Batu&r dan Tengkorak Skeleton di dalamnya. \\n\\nLo gak bakal nemuin banyak Loot di dalamnya, kebanyakan cuma &7Manuskrip&r dan Tengkorak. Jarang &eEmas &fatau &aEmerald&r!"
		"{image:atm:textures/questpics/iceandfire/iaf_struct_hydra.png width:200 height:100 align:center}"
	]
	quest.0FE94BE5ADB6E595.title: "&aGua Hydra"
	quest.0FEAD3CA2CC4A8B1.title: "Katalis Starlight Charger Tingkat 3"
	quest.0FF050EC1EA6EAED.quest_desc: ["&3Liquid Hopper&r adalah Hopper, tapi untuk cairan. Bukan pengganti pipa."]
	quest.0FF050EC1EA6EAED.quest_subtitle: "Siapa butuh pipa?"
	quest.0FFF2BEE5D8EBE12.title: "Reaktor (Niotic)"
	quest.10098A4B38BBF0B1.quest_subtitle: "Tingkat: &a2"
	quest.100ACB5C8A359BF0.quest_desc: ["Kawinkan Redstone Bee dengan Blue Banded Bee untuk mendapatkan Lapis Bee!"]
	quest.100ACB5C8A359BF0.quest_subtitle: "Redstone + Blue Banded"
	quest.100ACB5C8A359BF0.title: "Lapis Bee"
	quest.10162AD188CB3327.quest_subtitle: "Plum + Red Delicious Apple"
	quest.101E3A21FEE00E3F.quest_subtitle: "Padukan Telur Nickel Bee dengan Telur Fluxite Bee"
	quest.101E3A21FEE00E3F.title: "Energite Bee"
	quest.1036837C9AD3F301.quest_desc: ["&#6E6D6DForge Hammer&r akan memungkinkanmu untuk menghancurkan Ingot atau bijih &#FFAC3BTembaga (Copper)&r menjadi bentuk Debu (Dust) dengan mudah."]
	quest.103728F2BAD5AE84.title: "Komponen Tingkat Lanjut"
	quest.103834774B57D611.quest_desc: ["Mini End Portal bakal butuh lumayan banyak &dEndshelf&r. Ini tier terakhir dari Shelf yang bakal kamu dapetin dari &5&lApotheosis&r. Kamu butuh &dInfused Dragon's Breath&r buat craft mereka. \\n\\nSetelah itu kamu cuma butuh Eyes of Ender yang harus kamu bikin dulu buat bener-bener dapetin &dEndshelf&r-nya. \\n\\nKalo entah gimana kamu nyampe &d&lThe End&r dan dapet Shelf tanpa Eyes of Ender, gue impressed!"]
	quest.104049993CC62E7F.quest_desc: ["Advanced Item Loader memiliki fungsi yang sama dengan versi reguler, tetapi bisa digunakan dari posisi mana pun di dekat &6Rel&r. Di samping, di atas, atau di sisi seberangnya. Gunakan &4Crowbar&r untuk mengubah arahnya."]
	quest.104049993CC62E7F.title: "Advanced Item Loader"
	quest.1042A0DC0A9321BB.quest_desc: ["kamu yakin ada &5&lNaga&r di sini? Yang gue liat cuma &9Biru Listrik&f/&5Amethyst&f/&6Tembaga&f/&0Hitam&r? \\n\\nTunggu... itu &lStage 4&r atau &l5 &5Naga&r di dalam &5Gua Naga Petir&r! \\n\\n&5Gua&r-nya mungkin gede, tapi &5&lNaga&r-nya hampir sama gedenya! Ini berarti &5&lNaga&r-nya gak bakal terlalu banyak Terbang, tapi itu berarti dia bakal fokus lebih ke Serangan-nya. \\n\\nYa, ngelihat dari fakta bahwa &5&lNaga Petir&r ngasih Damage dasar paling gede, dan sekarang mereka ngasih Damage lebih banyak lagi... kamu mungkin bakal kacau. \\n\\nSantai aja lawan mereka, kamu bisa regen dan respawn! Mereka gak bisa! \\n\\nPas kamu Bunuh mereka dan kamu gak pake Botol ke mereka, mereka mungkin Drop &5Telur Naga Petir&r. Oh iya mereka harus Betina buat itu juga... emang gue harus ngasih tau cuma Betina yang bisa bertelur?"]
	quest.1042A0DC0A9321BB.title: "&lStage 4-5 &5Naga Petir"
	quest.104BF57D4A006688.quest_subtitle: "Berikan sebuah blok Sculk ke Digger Bee"
	quest.104BF57D4A006688.title: "Sculk Bee"
	quest.104EBBC08B4733F5.quest_desc: ["&dSimulation Chamber&r adalah mesin utama di HNN.\\n\\nKalau diberi power, akan menjalankan simulasi berdasarkan &bData Model&r yang dimasukkan. Power yang dibutuhkan juga tergantung Data Model yang dipasang, dan bisa dilihat di tooltip Model. \\n\\nMesin ini juga butuh setidaknya satu &9Prediction Matrix&r untuk menjalankan simulasi.\\n\\nHasil simulasi akan keluar ke Matrix. Simulasi akan selalu menghasilkan semacam &eGeneralized Prediction&r, yang bisa dipakai di berbagai resep crafting. Hasilnya juga bervariasi tergantung asal mob di Data Model.\\n\\nKalau simulasi berhasil, akan dapat &dMob Prediction&r berdasarkan modelnya. Semakin tinggi tier Data Model yang dipakai, semakin tinggi tingkat keberhasilan simulasi."]
	quest.104EBBC08B4733F5.title: "&aMensimulasikan Kematian"
	quest.1054168AFD8520D4.quest_desc: [
		"&aForgotten Guardian&r adalah Golem raksasa yang terbuat dari &aForgotten Ingot&r. \\n\\nIa akan menyerang pemain dan melakukan apa pun untuk menghabisi mereka. \\n\\nMereka punya 80 HP dan jika kamu berhasil membunuhnya, ia akan menjatuhkan &aForgotten Nugget&r."
		"{image:atm:textures/questpics/undergarden/undergarden_guardian.png width:100 height:200 align:center}"
	]
	quest.1054168AFD8520D4.title: "&aForgotten Guardian&r"
	quest.105442DA79829777.quest_desc: ["Dengan 8 &7Book&r dan sebuah Anvil, kita bisa membuat &8Tome of Scrapping&r. Sebenarnya hasilnya jadi 8 buah, tapi kamu paham lah maksudnya! \\n\\nDengan menggabungkan sebuah item dengan &8Tome&r ini di Anvil, kita bisa mengambil setengah dari &5Enchantment&r yang ada pada item tersebut. \\n\\nProses ini akan menghancurkan dan melenyapkan item aslinya setelah selesai. Aku tidak menyarankan memakainya, lebih baik kamu upgrade saja!"]
	quest.105442DA79829777.quest_subtitle: "Mengambil setengah Enchantment, menghancurkan item"
	quest.105442DA79829777.title: "&8Tome of Scrapping"
	quest.10642351AD9A9907.quest_desc: ["&3Anak Panah Amphithere&r dibuat dengan ganti Bulu Ayam dengan &3Bulu Amphithere&r. \\n\\n&3Anak Panah&r ini pada dasarnya Punch II di dalam dirinya sendiri! \\n\\nPas Mob kena Hit sama ini, mereka bakal ke-Knockback dan terlempar ke atas. \\n\\nGue pernah denger kalo kamu pake &3Anak Panah Amphithere&r di Busur Punch II, Mob-nya bakal meledak pas ke-Hit! (Ini bohong)."]
	quest.10642351AD9A9907.title: "&3Anak Panah Amphithere"
	quest.10672B5991E5FC34.quest_desc: ["Ini barangku, jangan dipegang. \\n\\nHanya kamu yang bisa menggunakan dan mengatur Router setelah memasang Upgrade ini."]
	quest.106884349C9FF3BA.quest_desc: ["Duh, beberapa sumber cahaya itu jelek sekali tampilannya! \\n\\nAyo kita ubah!"]
	quest.106884349C9FF3BA.title: "Lampu &l&bChipped&r"
	quest.10690FDB9E892250.quest_desc: ["Lihat Modules untuk belajar lebih tentang cara menggunakan dan upgrade item DE! Ayunkan dan pukul sesuatu dengannya. Ayolah, ini pedang aku gak bisa jelasin lebih lagi."]
	quest.10690FDB9E892250.title: "Wyvern Sword"
	quest.1069244EB72F64CA.quest_desc: ["Membutuhkan lebih banyak energi dengan Energy Module!"]
	quest.106C4EB6002B8B41.quest_desc: ["&9&lElectrolytic Separator&r ini sangat membantu buat &2&lFission Reactor&r sama &c&lFusion Reactor&r... jadi kita butuh banyak banget! Gimana kalo kita pake 1 Multiblock aja. \\n\\nLo butuh &aEnergi&r Input (jelas) plus &cChemical&r sama &bFluid&r Input Hatch. Tenang, Output gampang, tinggal &cChemical&r Output. \\n\\nIni ngebagi &9Air&r sama &9Heavy Water&r lebih cepet!"]
	quest.106C4EB6002B8B41.title: "&9&lElectrolytic Separator Multiblock"
	quest.106C552DDD95543C.quest_subtitle: "&f10.5 &cAttack Damage"
	quest.106D08542AAFA166.quest_desc: [
		"Tahap pertama pertarungan melibatkan menghancurkan Crystal yang menahan Shield Chaos Guardian. Kamu tidak bisa menyakitinya sampai mereka dihancurkan. Menghancurkan crystal ini tidak mudah tanpa senjata Draconic. Bola api Chaos Guardian bisa melemahkan shield ini memungkinkanmu menghancurkannya. (Ya, dia perlu menembak ke arahmu/mengenai crystal). Kamu akan melihat partikel yang diproduksi saat rentan terhadap damage dan saat dipukul akan membuat suara. Semakin dekat ke kehancuran semakin dalam suaranya dan semakin redup Crystal-nya. Setelah mereka dihancurkan kamu akhirnya bisa melukai dia!"
		"{image:atm:textures/questpics/draconic/draconic_end_crystal.png width:150 height:100 align:1}"
	]
	quest.106D08542AAFA166.title: "Temukan dan Hancurkan 14 Guardian Crystals"
	quest.109310AF19AAC482.quest_desc: ["&4Flamethrower&r adalah salah satu senjata jarak jauh yang ada di &5&lMekanism&r. \\n\\nKayak &cJetpack&r, alat ini pakai Hydrogen sebagai bahan bakar dan cara isinya sama kayak &cJetpack&r. \\n\\nKita bisa tekan (N) buat ganti modenya. \\n\\n&eCombat&r: bakal bakar mob dan kasih damage, tapi nggak bakal bakar blok atau item. \\n&6Heat&r: setahuku fungsinya sama aja. \\n\\n&4Inferno&r: Bakar semuanya!"]
	quest.109310AF19AAC482.title: "&4Flamethrower"
	quest.109AD73F016D576B.quest_desc: ["Gunakan metode vanilla, buatlah sebuah &9Beehive&r untuk memulai setup kecilmu!\\n\\nIni bisa menampung 3 lebah, tapi kita tidak akan menggunakannya lama-laki...\\n\\nLebah hanya akan menghasilkan Madu dan Sarang Madu (Honeycomb) jika ada bunga yang tepat. Lebah vanilla bisa menggunakan bunga apa saja, tapi kebanyakan lebah di mod ini butuh blok spesifik! Pastikan cek JEI untuk info lebih lanjut."]
	quest.109AD73F016D576B.title: "Sarang Lebah Pertamamu"
	quest.10A2E758D7743DD0.quest_desc: ["&5&lEternal Starlight&r adalah rumah bagi banyak item, mob, dan blok unik. \\n\\nTermasuk pepohonan juga! \\n\\nKamu bisa menemukan pohon-pohon ini di seluruh dimensi di hampir setiap biome."]
	quest.10A2E758D7743DD0.title: "Pohon &5&lEternal Starlight&r"
	quest.10AA2B20D86747F7.quest_desc: ["&bFerricore&r memiliki statistik yang sama dengan Besi, tapi punya kemampuan lain yang bikin Besi iri! \\n\\nCek deskripsi item untuk mempelajari apa saja yang bisa dilakukannya!"]
	quest.10AA2B20D86747F7.quest_subtitle: "15"
	quest.10AA2B20D86747F7.title: "&bFerricore Amor"
	quest.10AB188AC6FB24D3.quest_desc: [
		"Starlight Golem punya 220 Heart dan 2 Mode. \\n\\nMode pertama adalah attack mode-nya, di sini dia gak bisa kena damage, kamu harus nunggu serangannya selesai sebelum nyerang dia. Dia nyerang dengan Fireball, Ground Pound, atau Laser Beam yang dahsyat! \\n\\nMode kedua adalah charging mode-nya; di sini dia bakal mulai ngambil daya dari Energy Block yang harus dimatiin biar bisa damage dia. \\n\\nKalau mati dia bakal drop banyak Ingot dan Arrow, Golem Steel, Forge Armor Trim, dan mungkin Energy Sword!"
		"{image:atm:textures/questpics/eternal/starlight_golem.png width:150 height:100 align:center}"
	]
	quest.10AB188AC6FB24D3.title: "Starlight Golem"
	quest.10CA52D15EAB71A3.quest_desc: ["&eGurun The Other&r adalah Bioma paling gampang dikenali di &b&lThe Other&r. Datar, &ePasir&r, dan datar. \\n\\nTerbuat dari &ePasir&f, &eBatu Pasir&r, dan apapun yang ada di bawahnya. Plus kamu bisa nemuin &4Gua Cyclops&r di sini. \\n\\nGak ada Kaktus atau Semak Mati tapi ada lebih banyak Mob &b&lIce &fdan &cFire&r di sini daripada Bioma lain!"]
	quest.10CA52D15EAB71A3.title: "&eGurun The Other"
	quest.10DF9DE4B6C03D6B.quest_subtitle: "Dibuat dengan Nature Altar"
	quest.10DF9DE4B6C03D6B.title: "Tainted Gold Bee"
	quest.10E025288BB00657.quest_desc: [
		"&bSludges&r muncul di &bBlooming Caverns&r dan bertindak seperti Slime! \\n\\nBentuk terbesarnya punya 8 &4Hearts&r dan memberikan banyak Damage. Saat mati mereka akan memunculkan 2-4 &bSludges&r Medium. \\n\\nBentuk medium-nya punya 2 &4Hearts&r dan memberikan Damage jauh lebih sedikit. Saat mati mereka akan memunculkan 2-4 &bSludges&r kecil. \\n\\nBentuk kecilnya hanya punya setengah &4Heart Health&r dan tidak memberikan Damage apapun."
		"{image:atm:textures/questpics/deepndark/dnd_sludge.png width:100 height:100 align:center}"
	]
	quest.10E025288BB00657.title: "&bSludge"
	quest.10E4ADA1D0063EB7.title: "Chaotic Projectile Velocity Module"
	quest.10E8BC20D406D9FB.quest_subtitle: "Membuat berbagai Material Nether"
	quest.10EF30B919EBA5C6.quest_desc: ["Ini pickaxe dengan Fortune V. Itu aja.\\n\\nPasti gak bakal manggil spirit kalau kamu lagi nambang. &o&5&lPasti gak bakal&r."]
	quest.110BF3A2BE85F911.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Community contributor&r untuk dipakai di AllTheMods Modpack.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan dengan &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik manapun yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan, kalau terlihat, berarti sedang di editing mode."]
	quest.110D27EA86CDA62B.quest_desc: ["Menarik item di sekitar (magnet) masuk ke dalam Tas."]
	quest.111649D7E16D869F.quest_desc: ["&9Caster's Wand&r hanya bisa menampung satu mantra, yang dituliskan menggunakan Scribe's Table. \\n\\nMantra tongkat sihir ini selalu dimulai dengan Projectile > Accelerate, dan WAJIB dituliskan dengan mantra yang tidak memiliki metode lain (seperti touch, self, dll). \\n\\nIni memungkinkanmu merapal mantra di luar batas 10 slot mantra. Jika kamu ingin menggunakan Break, cukup tuliskan mantra Break saja pada tongkat ini."]
	quest.111E4ACF7D570EE8.quest_desc: [
		"Struktur paling sulit di &2&lVanilla Minecraft&r. Jadi, tentu saja di sanalah kamu harus mencari &6Allthemodium&r!\\n\\nKamu bisa menemukan bijihnya (Ore) di dinding gua sekitar Ancient City. Bijih ini bercahaya (glowing) jadi mudah terlihat, tapi sangat langka!\\n\\n Kamu juga bisa menemukannya di biome &5Deep Dark&r mana pun."
		"{image:atm:textures/questpics/allthemodium/all_city.png width:200 height:100 align:center}"
	]
	quest.111E4ACF7D570EE8.title: "Ancient City"
	quest.111F2EE85FB0A455.quest_desc: ["Menggunakan &cFiery Blood&r dari Hydra, kamu bisa membuat beberapa peralatan.\\n\\nFiery Sword sudah dilengkapi dengan Fire Aspect II.\\n\\nFiery Pickaxe dilengkapi dengan kemampuan auto-smelt (otomatis membakar bijih)."]
	quest.111F2EE85FB0A455.title: "Peralatan &cFiery"
	quest.11374A3B5BD644F5.quest_desc: ["&lIndustrial Foregoing&r adalah Tech Mod dengan banyak banget Mesin dan Tool. Semua ngikutin Kode Warna yang sama! \\n\\nKamu harus mulai dari Rubber dan iya ada Quest page buat itu!"]
	quest.11374A3B5BD644F5.title: "&lIndustrial Foregoing"
	quest.114D668C691A2BDF.quest_subtitle: "Ashy Mining + Crystalline"
	quest.114D668C691A2BDF.title: "Iron Bee"
	quest.117241986C99E475.quest_desc: ["Kawinkan Glowing Bee dengan Chocolate Mining Bee untuk mendapatkan Redstone Bee!"]
	quest.117241986C99E475.quest_subtitle: "Glowing + Chocolate Mining"
	quest.117241986C99E475.title: "Redstone Bee"
	quest.1178E4123E8818E2.quest_desc: ["Maaf, kamu tidak bisa memakai ini lagi, sekarang ini hanya sebuah item! \\n\\nDengan Klik Kanan, 2 &eSandstorm&r akan muncul. Badai pasir ini akan mengelilingimu dan bergerak bersamamu. \\n\\nApa pun yang terkena badai ini akan menerima Damage dan Knockback."]
	quest.1178E4123E8818E2.title: "&eBottle O' Sandstorm"
	quest.1187F9D4F4E0D254.quest_desc: ["&3Wrench&r adalah alat yang bisa melakukan dua hal:\\n- Memutar blok.\\n- Menghancurkan cover Refined Storage.\\n\\nCukup tekan sneak + klik kanan saat menggunakan Wrench."]
	quest.1187F9D4F4E0D254.quest_subtitle: "Putar-putar terus"
	quest.1187F9D4F4E0D254.title: "&3Wrench"
	quest.1190BB433EFA3945.quest_desc: ["Slingshot (Ketapel) adalah senjata seru dari &2&lUndergarden&r. Ada 4 jenis amunisi yang bisa ditembakkan: \\n\\nScintling Goo bisa ditembakkan dan memberikan efek Gooey ke mob. \\n\\nDepthrock hanyalah proyektil normal. \\n\\nRotten Blisterberry akan meledak saat mengenai target. \\n\\nDan &eGronglet&r tidak memberikan damage, mereka hanya berisik saat ditembakkan!"]
	quest.119242549BD21764.quest_desc: [
		"&eBrute&r muncul di beberapa biome dan bersifat Netral. \\n\\nJika dipukul, semua yang ada di area akan menyerangmu. Mirip seperti Serigala atau Zombified Piglin. \\n\\nSaat mati, mereka mungkin menjatuhkan gadingnya yang bisa digunakan sebagai pengganti Tulang (Bone)!"
		"{image:atm:textures/questpics/undergarden/undergarden_brute.png width:100 height:100 align:center}"
	]
	quest.119242549BD21764.title: "&eBrute&r"
	quest.119BED334E331C25.quest_desc: [
		"Pengolahan bijih (&lOre Processing&r) yang paling awal dan simpel cuma butuh 2 &5Mesin&r! &d&lEnricher&r dan &6&lSmelter&r! \\n\\nKita bisa pakai &7Ore Block&f buat dapat dua kali lipat &7Dust &fatau pakai &7Raw Ore&r buat dapat sepertiga lebih banyak. Jadi 3 &7Raw Ore&f dapat 4 &7Dust&r. \\n\\nTaruh &7Ore&r-nya ke &d&lEnricher&r nanti dapat &7Dust&r! Terus, &6Smelt &f(bakar) &7Dust&r itu biar jadi &7Ingot&r! \\n\\nSelamat, kamu baru aja lakuin &lOre Processing&r!"
		"{image:atm:textures/questpics/mek/mek_tier1_1.png width:150 height:50 align:center}"
	]
	quest.119BED334E331C25.quest_subtitle: "Pengolahan Bijih Tier 1"
	quest.119BED334E331C25.title: "&dEnrich &fterus &6Smelt"
	quest.11A0593C0E2E6A35.quest_desc: ["Menggunakan &eEziveus' Spectral Compulsion&r, kita bisa menyerap energi dari berbagai blok alam untuk membentuk &2Nature Paste&r. Gabungkan pasta ini dengan Impure White Chalk untuk menciptakan Green Chalk."]
	quest.11A0593C0E2E6A35.title: "&2Green Chalk (Kapur Hijau)"
	quest.11B0B93D725ABE43.quest_desc: ["Peralatan Silent Gear bisa diperbaiki menggunakan &9Repair Kit&r.\\n\\nUntuk memperbaiki item, letakkan Repair Kit ke dalam grid crafting, lalu masukkan material yang dibutuhkan untuk memperbaiki alat tersebut. Ini akan \"mengisi\" Repair Kit.\\n\\nUntuk memperbaiki alat, gabungkan Repair Kit yang sudah terisi dengan alat yang ingin kamu perbaiki di dalam grid crafting."]
	quest.11B0B93D725ABE43.quest_subtitle: "Tanpa perlu Anvil"
	quest.11B1FB0AB2677902.quest_subtitle: "Balsa + Silver Lime"
	quest.11C43962B06D5092.quest_desc: ["Apakah ini perlu?"]
	quest.11C43962B06D5092.title: "Sekarang Kamu Cuma Pamer"
	quest.11C5F17C6BB1237B.quest_desc: ["Selama memakai &5Withered Bracelet&r, serangan jarak dekat (Melee) berpeluang memberikan efek Wither ke musuh.\\n\\nMaaf ya buat pengguna busur panah!"]
	quest.11C5F17C6BB1237B.quest_subtitle: "Pergelangan Tangan"
	quest.11C5F17C6BB1237B.title: "&5Withered Bracelet&r"
	quest.11D09E918015355C.quest_desc: ["&cHeat Generator&r dari Mekanism adalah pendekatan berbeda untuk produksi daya dasar. Alat ini memiliki dua mode produksi daya:\\n\\n&9Pasif:&r Mengelilingi generator dengan sumber Lava atau aliran lava akan menghasilkan daya pasif seiring waktu melalui panas. Letakkan satu blok sumber Lava di atas dan biarkan mengalir ke samping. Pastikan kabel energi sudah terhubung terlebih dahulu!\\n\\n&9Aktif:&r Memasukkan bahan bakar seperti Batu Bara atau Kayu ke dalam generator akan membakar bahan bakar tersebut untuk menghasilkan daya. Cara ini tidak terlalu efisien."]
	quest.11D09E918015355C.title: "&cHeat Generator"
	quest.11D4EEAC61C7E530.quest_desc: ["Collector Upgrade akan membuat Drawer menyedot item dari salah satu sisinya."]
	quest.11D57C768032E3F7.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.11D57C768032E3F7.title: "&eAdvanced Magnet Upgrade"
	quest.11E957CDEFA0CAAB.quest_desc: ["Selamat datang di &5&lThe Beyond&r! \\n\\nTidak ada apa-apa di sini! \\n\\nKamu mungkin akan membutuhkan Angel Block."]
	quest.11E957CDEFA0CAAB.title: "&5&lThe Beyond"
	quest.120572510F525930.quest_desc: [
		"&6&lThermal Evaporation Plant&r itu Multiblock yang narik &9Air&r, terus pakai &6Panas&r buat dijadiin &eBrine&r. Alat ini juga pakai &6Panas&r buat ubah &eBrine&r jadi &6Liquid Lithium&r! \\n\\nBuat mulai kamu butuh banyak banget &6Thermal Evaporation Block&r. Dasarnya harus 4x4 dan nggak boleh beda ukurannya. \\n\\nTemboknya minimal tinggi 3 blok dan maksimal 18. Bagian dalam dan atas harus kosong kayak kebanyakan Multiblock lainnya. &9Air &fdan &eBrine&r harus ditampung di suatu tempat. \\n\\nDi area tembok (bukan di sudut) kita bisa pasang &6Valve &fdan &6Controller&r! &6Controller&r itu cara kita akses GUI alat ini. Di sana kita bisa lihat &6Panas&r yang ada. Kita cuma butuh 1 &6Controller&r. \\n\\n&6Valve&r itu cara kita masukin &9Air &fdan &eBrine&f, keluarin &eBrine &fdan &6Liquid Lithium&r, dan kalau mau, masukin &6Panas&r juga! Kamu nggak perlu setting &6Valve&r-nya, cuma &bPipes &fdan &6Conductor&r-nya aja yang perlu diset. \\n\\nLapis paling atas &6&lPlant&r ini sudutnya nggak boleh diisi &6Thermal Evaporation Block&r. Tapi kamu bisa pasang &e&l&oAdvanced Solar Generator&r di sudut lapis paling atas kalau mau dapat &6Panas&r lebih!"
		"{@pagebreak}"
		"{image:atm:textures/questpics/mek/mek_thermal1.png width:125 height:100 align:center}"
		"Bikin 4x4 &6Thermal Block&r buat dasarnya."
		"{image:atm:textures/questpics/mek/mek_thermal2.png width:125 height:100 align:center}"
		"Bagian ini bisa ukuran berapa pun asal tinggi total &6&lThermal Evaporation Plant&r antara 3 sampai 18 blok. Di sini juga tempat naruh &6Valve &fdan &6Controller&r kita."
		"{image:atm:textures/questpics/mek/mek_thermal3.png width:110 height:100 align:center}"
		"Sudut-sudutnya harus Kosong atau diisi &l&e&oAdvanced Solar Generator&r di level paling atas."
		"{image:atm:textures/questpics/mek/mek_thermal4.png width:110 height:100 align:center}"
		"Kamu tahu kalau sudah bener pas &6Controller&r-nya nyala!"
	]
	quest.120572510F525930.title: "&6&lThermal Evaporation Plant"
	quest.1207E5C3E7BD0584.title: "Pola Spanduk Lebah"
	quest.120B403D56EE5C79.title: "Wyvern Energy Module"
	quest.120BDCB70AD352AC.quest_desc: [
		"Jika kamu ingin mengubah Peternakan Lebahmu menjadi pabrik sumber daya, kamu harus mulai dengan memunculkan lebah menggunakan &6Nest (Sarang Alami)&r."
		""
		"Nest harus diletakkan di biome spesifik, yang bisa kamu temukan di JEI (cari ikon 'I' di bagian atas)."
		""
		"Untuk memancing lebah masuk ke Nest, klik kanan padanya menggunakan &9Honey Treat&r. Nest tidak akan bekerja tanpa makanan tersebut!!"
		""
		"&9Catatan Penting&r: Lebah tertentu hanya akan tinggal di Nest dan tidak mau masuk ke Advanced Hive. Jika mereka tidak menghasilkan Honeycomb, berarti mereka harus tinggal di Nest."
	]
	quest.120BDCB70AD352AC.quest_subtitle: "Membutuhkan Honey Treat"
	quest.120DCA89A919C7AF.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memberikan pemain Penglihatan Malam."
	]
	quest.121DE9824813D558.quest_desc: [
		"&2Kuil Gorgon&r adalah tempat yang aman menahan salah satu dari &2&lsaudara Gorgon&r. \\n\\n&2Kuil&r-nya adalah Struktur &7Bata Batu&r yang gede banget yang spawn di &7Lembah Soul Sand The Other&r. \\n\\nDi dalamnya kamu harus tarik Tuas yang bener supaya bisa buka Tangga ke Basement dimana &2&lGorgon&r-nya ada."
		"{image:atm:textures/questpics/iceandfire/iaf_struct_gorgon.png width:200 height:100 align:center}"
	]
	quest.121DE9824813D558.title: "&2Kuil Gorgon"
	quest.122282C288EAD366.quest_subtitle: "&f6 &cAttack Damage"
	quest.12256A90B1CE3F90.quest_desc: ["Ya kamu bisa pakai Quarry atau Void Miner untuk dapet Ore tapi kalau kamu beneran mau cara terbaik automasi &bArcane Crystal&r maka kamu butuh &6&lBee&r! \\n&bDiamond Bee&r lebih tepatnya. Cukup kasih makan &bDiamond Bee&r dengan &bBlock of Arcane Crystal&r dan mereka akan jadi &bArcanus Bee&r! \\n\\n&bArcanus Bee&r butuh &bBlock of Arcane Crystal&r sebagai Flowering Block juga, lalu mereka akan bikin &bArcanus Comb&r! Yang bisa dibuat jadi &bArcane Crystal&r."]
	quest.12256A90B1CE3F90.title: "Automasi &bArcane Crystal"
	quest.12274935C3D20C74.quest_desc: ["Sama seperti semua Tips Bangunan di &6&lATM10&r, aku nggak bisa ngajarin kamu desain &5Kereta&r yang bagus... tapi bisa kasih Tips! \\n\\nAda banyak Blok bangunan yang bisa dipakai, banyak Casing &6&lCreate&r yang terlihat rapi, dan Beton bisa memberi tampilan yang lebih sleek. \\n\\nKamu juga bisa pakai Pintu dan Jebakan dalam &5Kereta&r yang tetap bisa dibuka saat &5Kereta&r sedang berjalan. \\n\\nBagaimana supaya terlihat keren? Tangga, Lempengan, dan Jebakan membantu membentuk siluetnya, dan Roda Gila atau &dCogs&r memberikan tepi yang membulat. \\n\\nBahkan kamu bisa taruh Api Unggun di atasnya supaya terlihat seperti Mesin Uap!"]
	quest.12274935C3D20C74.title: "Mendekorasi &5Kereta&r-mu"
	quest.122E6E7CABCB17E7.quest_desc: ["Entah kenapa Creeper takut sama Kucing. Creeper itu sangat bodoh dan percaya kalau &7Slippers&r yang kamu pakai itu kucing beneran. \\n\\nSemua Creeper akan lari darimu dan tidak akan menyerang selama &7Slippers&r ini dipakai. \\n\\nJuga mengeluarkan suara kucing pas kamu kena damage! (Tapi nggak menjamin kamu bakal selalu mendarat dengan kaki duluan ya)."]
	quest.122E6E7CABCB17E7.quest_subtitle: "Kaki"
	quest.122E6E7CABCB17E7.title: "&7Kitty Slippers&r"
	quest.122EDEC12C9A05D2.quest_desc: ["Apa aku lupa bilang kalau semuanya bisa meledak? ...\\n\\nUntungnya ada solusi mudah! &3Security Upgrade&r saat dipasang di mesin akan memastikan mereka tidak meledak; masukkan ini ke mesin apa pun yang mendukungnya."]
	quest.122EDEC12C9A05D2.quest_subtitle: "Seandainya ada solusi yang mudah..."
	quest.122EDEC12C9A05D2.title: "Mencegah Ledakan?"
	quest.122FBF5110E4CFF2.quest_desc: ["Iron Downgrade akan menurunkan kapasitas maksimal Drawer menjadi hanya satu stack. Ini berguna untuk menjaga stok item agar tidak terlalu banyak."]
	quest.123807F4BBE75120.title: "&bKomponen Penyimpanan 16384k"
	quest.123C0417D85B9DB2.quest_desc: ["&eSolar Recharging &7Unit&r masuk ke &a&lMekaSuit Helmet&r dan bakal nge-charge &a&lMekaSuit&r! \\n\\nMakin banyak yang ditambah, makin banyak FE yang dihasilin. \\n\\nIya, kerjanya persis kayak &eSolar Generator&r biasa... &eSiang hari&r dan kena langsung sama &bLangit&r!"]
	quest.123C0417D85B9DB2.quest_subtitle: "Helmet"
	quest.123C0417D85B9DB2.title: "&eSolar Recharging &7Unit"
	quest.12449D23295CF9ED.quest_desc: ["Meskipun mungkin tidak ada &9Ubur-ubur&r di &2Minecraft&r, kita bisa mendapatkan kekuatan mereka! Dengan &9Jellyfish Necklace&r! Saat memakainya, kemampuan pasif pertamanya memungkinkanmu untuk tidak tenggelam di air, melainkan berjalan di atasnya. \\n \\nKemampuan kedua yang juga pasif membuatmu bisa menyengat mob yang mendekat. Ini bisa di-upgrade untuk memberikan damage lebih besar. \\n \\nKemampuan terakhir memberikan efek tambahan pada kemampuan kedua: mob yang tersengat akan mengalami kelumpuhan (paralyzed)! Agak lega juga ya tidak ada &9Ubur-ubur&r di &2Minecraft&r sekarang..."]
	quest.12449D23295CF9ED.quest_subtitle: "Ditemukan di Bangkai Kapal dan Reruntuhan Laut"
	quest.12449D23295CF9ED.title: "&9Jellyfish Necklace"
	quest.1245126B4338C019.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_vex.png width:100 height:150 align:center}"]
	quest.1245126B4338C019.quest_subtitle: "Woodland Mansion"
	quest.1245126B4338C019.title: "Vex Armor Trim"
	quest.12469CC0CCFBA1C5.quest_desc: ["Sword terbaik ditambah Pickaxe tercepat ditambah Shovel?!?! Apa lagi yang kamu mau!"]
	quest.12469CC0CCFBA1C5.title: "Chaotic Staff"
	quest.12498F8B5740F66E.quest_desc: ["&bWizard Gear&r adalah Armor default untuk &lIron's Spells&r! \\n\\nSetiap Armor lain akan di-Craft dengannya, atau di-Craft dari sesuatu yang di-Craft darinya! \\n\\nIni hanya butuh &5Arcane Cloth&r untuk di-Craft. \\n\\nIni akan memberikan boost besar di Max Mana, Armor Points yang sama dengan &bDiamond Armor&r, dan memberikan Spell Power Boost!"]
	quest.12498F8B5740F66E.title: "&bWizard Gear"
	quest.1256F280F3669DDA.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Membuat Anak Panah memantul ke musuh terdekat."
	]
	quest.12749A25600C7FF3.quest_desc: [
		"Quantum Crafter adalah auto-crafter yang kuat dan bisa dikonfigurasi. Dengan seluruh inventory network ME di genggaman, crafting non-stop jadi hal sepele. Bisa menjalankan job crafting dengan sangat cepat. Juga bisa substitusi fluid dan recursive craft (seperti Smithing Template Duplication)."
		""
		"Kamu juga bisa atur berapa banyak tiap ingredient yang mau disimpan, dan sampai berapa banyak produk yang mau di-stock."
		""
		"Tapi gak nerima crafting request dari Pattern Provider."
	]
	quest.12749A25600C7FF3.title: "Crafting Otomatis Penuh: Quantum Crafter"
	quest.127D085D6C9DB690.quest_desc: ["Saltpeter bisa ditemuin dimana aja di Underground tapi sangat umum di Warm Shore Biome. \\n\\nButuh Stone Pickaxe buat nambang dan kalau ditambang bakal drop beberapa Saltpeter Powder. Ya, Fortune work! \\n\\nPowder-nya bisa dipake sebagai pengganti Niter lain."]
	quest.127F9EAC7C305BF5.quest_desc: ["Percayalah, kamu akan butuh &6Kunci Inggris&r! \\n\\n&6Kunci Inggris&r adalah alat serba bisa untuk &6&lCreate&r. Bisa memutar Blok, menghancurkannya, mengatur konfigurasinya — apa yang nggak bisa dilakukan! \\n\\nUntuk menghancurkan Blok, cukup Shift + Klik Kanan Blok &6&lCreate&r mana saja dan Blok itu akan hancur. \\n\\nUntuk memutar Blok, Klik Kanan saja dengan &6Kunci Inggris&r. Sayangnya ini nggak memberikan &dTenaga Rotasi&r gratis, tapi tetap berguna untuk memperbaiki kesalahan! \\n\\nJuga akan sangat berguna untuk mengatur &aKontraption&r, tapi itu untuk nanti."]
	quest.127F9EAC7C305BF5.title: "&6Kunci Inggris"
	quest.128A14A3842325FE.quest_desc: ["Saat dipasang di Advanced Beehive, lebah tidak lagi keluar secara fisik dari sarang. Perjalanan mereka ke blok bunga akan disimulasikan.\\n\\nPastikan untuk menaruh blok bunga yang dibutuhkan atau Feeding Slab di depan sarang yang berisi blok bunga atau item yang dibutuhkan lebah tersebut. Untuk cara setup yang benar, cek quest Feeding Slab.\\n\\nAku sangat menyarankan ini agar lebahmu tidak menghilang dan lebih mudah untuk memasukkan/mengeluarkan lebah dari sarang."]
	quest.128A14A3842325FE.quest_subtitle: "Apakah lebahnya masih nyata?"
	quest.128A14A3842325FE.title: "Simulation Upgrade"
	quest.129E09C03E40BA57.quest_desc: ["Reactor menggunakan Awakened Draconium sebagai Bahan Bakar, jangan khawatir efisien kok! Fuel Conversion menentukan kapan Awakened Draconium akan berubah jadi Chaos. Hanya bisa mengambil 8 Block sekaligus dan hanya bisa di-Fuel atau Refuel saat Reactor mati. Mode SAS membantu membuat itu lebih mudah! Juga Fuel masuk ke Slot kanan bawah."]
	quest.129E09C03E40BA57.title: "Bahan Bakar untuk Reactor kita"
	quest.12A43F82FC67A289.quest_desc: ["Untuk menyimpan item, kamu perlu membuat disk, yang nantinya bisa disimpan di dalam &9Disk Drive&r yang terhubung ke jaringanmu.\\n\\nDisk Drive ini memiliki 8 slot untuk Storage Disk."]
	quest.12A43F82FC67A289.quest_subtitle: "Waktunya Disket!"
	quest.12A63C5F8E918266.quest_desc: ["&aSepatu amfibi&r ini membantumu berenang lebih cepat dengan kemampuan pertamanya. Tingkatkan untuk berenang sedikit lebih kencang!\\n\\nKemampuan kedua juga berkaitan dengan &9Air&r, tapi yang jatuh dari langit. Kamu akan lari lebih cepat saat hujan.\\n\\nKemampuan terakhir entah bagaimana mempengaruhi paru-parumu; kamu berpeluang tidak mengonsumsi gelembung oksigen saat berada di dalam air."]
	quest.12A63C5F8E918266.quest_subtitle: "Ditemukan di Bangkai Kapal dan Reruntuhan Laut"
	quest.12A63C5F8E918266.title: "&aAmphibian Boots"
	quest.12AE2856444996F6.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Community contributor&r untuk dipakai di AllTheMods Modpack.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan dengan &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik manapun yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan, kalau terlihat, berarti sedang di editing mode."]
	quest.12BDE512C734D19A.quest_desc: ["Draconium Cores adalah Bahan penting dalam banyak resep di Draconic Evolution. Terutama untuk item Tier Basic."]
	quest.12BDE512C734D19A.title: "Basic (Draconium) Core"
	quest.12D3C7FC4B3DAB23.quest_desc: ["&bEnvironmental Eye&r dapat dibuat menggunakan &aRitual of the Forest&r dan bisa dipakai di slot Charm untuk memantau tingkat aura di pojok kiri atas layar."]
	quest.12D3C7FC4B3DAB23.quest_subtitle: "Mengawasi Lingkungan"
	quest.12ED1EE85E146A4B.quest_desc: [
		"Harvester Pylon berfungsi sebagai sistem pertanian otomatis yang sangat simpel. Letakkan Pylon ini di atas atau di dalam sumber air, dan ia akan otomatis memanen serta menanam kembali tanaman yang sudah matang di area sekitarnya."
		""
		"Luas area bisa diatur menjadi 3x3, 5x5, 7x7, atau 9x9 blok di sekitar Pylon."
		""
		"Alat ini membutuhkan Cangkul (Hoe) untuk digunakan pada tanaman dan membutuhkan inventaris seperti peti di atasnya untuk menampung hasil panen. Lakukan semua itu dan jika statusnya dinyalakan (On), ia akan mulai bertani!"
	]
	quest.12EF38830108D02B.quest_desc: ["Kalahkan 32 Laba-laba normal."]
	quest.12F3A604329EC604.quest_subtitle: "Meningkatkan Efisiensi Mesin"
	quest.12F9705ACB8FB300.quest_desc: [
		"&#EDD653&nCutting Machine&r memungkinkanmu melakukan banyak jenis crafting. Yang terpenting adalah Bolt. "
		""
		"&#EDD653&nCutting machine&r bekerja menggunakan &#E3993DLubricant&r (Pelumas) yang didapatkan melalui penggunaan &#EDD653&nMixer&r."
	]
	quest.12FB3990CA1653A4.quest_desc: [
		"&#DBA15ASteam Drill&r akan menjadi sahabat terbaikmu untuk menambang di awal permainan. Alat ini mampu menambang area berukuran &53x3&r serta memiliki fitur &#EEF768silk touch yang bisa dinyalakan-matikan&r."
		""
		"Kamu bisa beralih ke mode menambang &53x3&r dengan menekan tombol \"Toggle 3x3 Mining\" yang secara standar disetel ke tombol &7'Y'&r."
		""
		"&#EEF768Silk Touch&r dapat diaktifkan dengan cara &7Sneak + Klik Kanan&r pada Steam Drill."
		""
		"Untuk mengisi daya &#DBA15ASteam Drill&r, kamu bisa menahan bor di atas &6bahan bakar&r di inventarismu lalu &7Klik Kanan&r. &9Air&r bisa diisi dengan cara &7Klik Kanan&r pada sumber air di dunia atau dengan membawa ember air."
	]
	quest.130577AD1A1A8222.quest_desc: ["&7Cloggrum&r punya statistik sedikit di bawah Armor Besi, tapi karena ia praktis tumbuh di pepohonan, kurasa itu cukup adil. \\n\\nSepatunya juga membantumu berjalan melewati Scintling Goo!"]
	quest.130577AD1A1A8222.title: "Armor &7Cloggrum&r"
	quest.1310C1E14C259807.quest_desc: ["Ingin Drawer dengan tampilan kustom? Rak ini bisa meniru tekstur blok lain di bagian luar dan tekstur berbeda di bagian depan.\\n\\nIkuti instruksi pada tooltip untuk cara melakukannya."]
	quest.131164DA08BB87B3.quest_desc: ["Hippogryth bisa di-Tame! \\n\\nTinggal dari jarak jauh pake Kaki Kelinci. Lempar beberapa Kaki Kelinci deket mereka dan mereka bakal Makan. \\n\\nMereka kayak kebanyakan Mob yang di-Tame pake Makanan, entah mereka cuma butuh 1 Kaki Kelinci atau mungkin butuh satu Stack penuh Kaki Kelinci! \\n\\nPas mereka rebahan, itu tandanya mereka udah Jinak. Terus, kamu bisa Shift Klik Kanan buat buka Inventory-nya. Sekarang kita bisa kasih Sadel buat Naik dia, Chest buat Nyimpen Barang, dan bahkan Armor! \\n\\nPas Terbang kamu bisa pake Space Bar buat Terbang ke atas, ini butuh waktu buat akselerasi. WASD buat gerak maju, mundur, kiri, atau kanan. Dan (X) buat turun. \\n\\nKita bahkan bisa pake (G) buat Nyerang Mob kayak sama &eCacing Maut&r!"]
	quest.131164DA08BB87B3.title: "Kuasai &bLangit&r dengan Hippogryth"
	quest.13124A7E22999850.quest_subtitle: "Tingkat: &e1"
	quest.131AA933D59D3017.quest_desc: [
		"Tier 5 butuh 90 Draconium Ingot Blocks dan 80 Redstone Blocks, bersama dengan 4 Advanced Stabilizers atau 36 Stabilizers."
		"{image:atm:textures/questpics/draconic/draconic_core_5off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_5on.png width:100 height:100 align:1}"
	]
	quest.131AA933D59D3017.quest_subtitle: "Menyimpan: 59,300,000,000 RF"
	quest.131AA933D59D3017.title: "Tier 5"
	quest.131EC039435B8878.quest_desc: [
		"Di Productive Bees, kamu tidak menghabiskan waktu terbang berkeliling mencari lebah tertentu."
		""
		"Sebaliknya, kamu memunculkan mereka menggunakan Nest dengan &6Honey Treat&r."
		""
		"Beberapa Nest membutuhkan item spesial sebagai pengganti Honey Treat, jadi pastikan cek JEI!"
		""
		"Pastikan kamu berada di biome yang benar untuk memancing lebah yang diinginkan!"
	]
	quest.1322907FDFF08ADA.quest_subtitle: "Walnut + Wild Cherry/Silver Lime"
	quest.132DF9ECEFFB3B71.quest_desc: ["&3Module Expansion Card&r membuat Charging Module menjadi lebih baik."]
	quest.132F4671E121C7B8.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Meningkatkan kecepatan berjalan."
	]
	quest.1338EED4F26F3EFF.quest_desc: ["&3Spellbreaker&r adalah Senjata mahal dan kuat yang bisa kita Craft. \\n\\nKita butuh &bWeapon Parts&r, &bDiamond&f, dan 2 &bMithril Ingot&r untuk membuatnya. \\n\\n&3Spellbreaker&r memberikan 10 &4Heart Damage&r dan sedikit lebih cepat dari Pedang. \\n\\nIni juga punya &3Spell&r di dalamnya, &3Counterspell&r. Saat Mob menggunakan &3Spell&r terhadapmu, gunakan ini untuk menghentikan mereka!"]
	quest.1338EED4F26F3EFF.title: "&3Spellbreaker"
	quest.133CA315A1443A49.quest_desc: ["&bPompa Mekanik&r menggunakan Tenaga Rotasi untuk menggerakkan &bCairan&r melalui &bPipa&r. \\n\\nPertama, ganti salah satu &bPipa&r dengan &bPompa Mekanik&r. Pastikan arahnya sesuai dengan arah &bCairan&r yang ingin dipindahkan. Tanda Panah di samping &6Roda Gigi&r internal menunjukkan arah gerakannya, bisa diubah dengan Kunci Inggris. \\n\\nKemudian, pasok &dTenaga Rotasi&r dengan &6Roda Gigi&r di dekatnya. Arahnya tidak berpengaruh, tapi Kecepatan akan mempengaruhi seberapa cepat &bCairan&r dipindahkan. \\n\\n&bPompa Mekanik&r juga dibutuhkan untuk Mesin lain seperti &bKatrol Selang&r!"]
	quest.133CA315A1443A49.title: "&bPompa Mekanik"
	quest.134608BB2B04D96E.quest_desc: ["Peti (Chest) memiliki 27 slot dan bisa dijadikan peti ganda (double chest) untuk menyimpan jumlah dua kali lipat."]
	quest.134608BB2B04D96E.quest_subtitle: "Peti Biasa"
	quest.134608BB2B04D96E.title: "Penyimpanan Vanilla"
	quest.13471E64CDE49D27.quest_desc: [
		"&a&lKilang&r akan mengambil 2 &bCairan&r dan menggabungkan serta menyulingnya menjadi 1 &bCairan&r yang lebih baik! \\n\\n2 &bCairan&r bisa &9Dimasukkan&r dari Port dan sisi Kiri dan Kanan. Output Cairan akan keluar dari Port Depan. \\n\\nKamu bisa menggunakan &bEmber&r untuk menyimpan &bCairan&r ke dalam Tangki juga! Jangan lupa Klik Kanan &a&lKilang&r untuk membuka GUI-nya. Di sana kita perlu menempatkan Katalis, untuk memulai Mesin. \\nBersama dengan Katalis, diperlukan &cEnergi&r yang bisa ditambahkan melalui Port di Belakang!"
		"{@pagebreak}"
		"Untuk memulai, buat garis 5 &bPipa Cairan&r. Di tengah letakkan &eBlok Teknik Ringan&r di satu sisi, dan &7Blok Teknik Berat&r di sisi lain. Di samping &bPipa Cairan&r lainnya letakkan &8Perancah Baja&r."
		"{image:atm:textures/questpics/immersive/immersive_refinery1.png width:150 height:100 align:center}"
		"Letakkan lebih banyak Blok Teknik pada yang sebelumnya. Di kanan &7Blok Teknik Berat&r, lewati 1 Blok dan letakkan &4Blok Teknik Redstone&r. Di samping &eBlok Teknik Ringan&r letakkan 2 2x2 &7Lembar Besi&r."
		"{image:atm:textures/questpics/immersive/immersive_refinery2.png width:150 height:100 align:center}"
		"Sekarang beberapa &7Lembar Besi&r lagi!"
		"{image:atm:textures/questpics/immersive/immersive_refinery3.png width:150 height:100 align:center}"
		"Untuk yang satu ini perlu Klik Kanan &7Blok Teknik Berat&r atas dengan &6Palu&r."
		"{image:atm:textures/questpics/immersive/immersive_refinery.png width:100 height:100 align:center}"
	]
	quest.13471E64CDE49D27.title: "&l&aKilang"
	quest.1348995F64A94396.quest_desc: ["&bCrafting Monitor&f menampilkan item yang sedang dibuat, beserta jumlah sisa dari item tersebut yang masih dalam proses.\\n\\nBaik monitor AE2 dasar maupun monitor MEGA berfungsi identik, hanya disediakan untuk tujuan estetika."]
	quest.1348995F64A94396.quest_subtitle: "Pantau Progres"
	quest.1348995F64A94396.title: "Crafting Monitor"
	quest.13517D17E6BF015F.quest_desc: ["Dengan &bDiamond Armor&r dan beberapa &aInferium Item&r, kita bisa membuat &aInferium Armor&r! \\n\\nArmor ini juga bisa ditingkatkan melalui Tinkering!"]
	quest.13517D17E6BF015F.quest_subtitle: "21"
	quest.13517D17E6BF015F.title: "&aInferium Armor"
	quest.1351D0594F1E6551.quest_desc: ["&#55EDA4Komponen dasar&r ini akan membawa kita ke terobosan berikutnya dalam proses produksi."]
	quest.1351D0594F1E6551.title: "Komponen Sirkuit"
	quest.135A16EDEEE27FA9.quest_desc: ["Semua yang terkait dengan &cKabel&r dan &cDaya&r di &8&lIE&r bisa Berjenjang. &6Tegangan Rendah&r (&6LV&r), &eTegangan Menengah&r (&eMV&r), dan &5Tegangan Tinggi&r (&5HV&r). \\n\\nSemakin tinggi Tegangan, semakin banyak &cEnergi&r yang bisa dipindahkan dan digunakan. Beberapa Mesin memerlukan Tegangan lebih tinggi untuk digunakan. \\n\\nUntuk mentransfer Tegangan berbeda, kamu memerlukan &cTransformator&r, periksa Quest mereka!"]
	quest.135A16EDEEE27FA9.title: "Tegangan Berjenjang"
	quest.1366B946928C873B.quest_desc: ["Cek halaman quest &6&lBumblezone&r untuk info lebih lanjut!"]
	quest.1366B946928C873B.quest_subtitle: "10"
	quest.1366B946928C873B.title: "Bee Armor 1"
	quest.13681866CE6A831C.title: "Pola Spanduk Pedang"
	quest.136C40D8350651DC.quest_desc: [
		"&cPulau Siren&r muncul di &7Lembah Soul Sand The Other&r. \\n\\nMereka pada dasarnya cuma Pulau kecil yang terbuat dari &7Blok Batu&r, satu-satunya bagian yang unik adalah &cSiren&r-nya! \\n\\nLo mungkin mau pake Penutup Telinga dulu... Lagu mereka lumayan catchy!"
		"{image:atm:textures/questpics/iceandfire/iaf_struct_siren.png width:200 height:100 align:center}"
	]
	quest.136C40D8350651DC.title: "&cPulau Siren"
	quest.13A0714444BA79AB.quest_desc: ["&bUltra Importer&r memiliki 36 slot filter, bekerja 5x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.13A0714444BA79AB.title: "&bUltra Importer"
	quest.13A5748DF69D832E.quest_desc: ["&e&lQIO Drive Array&r gak bisa apa-apa sendiri, kita butuh tambahin &eQIO Dashboard&r! \\n\\n&e&lQIO Dashboard&r, kayak semua &eItem &lQIO&r lainnya, harus diset ke Network yang sama. \\n\\nKalo udah siap kita bisa masukin dan akses &eItem&r ke &e&lQIO System&r. \\n\\nKita mulai dari bagian paling penting! Slot di tengah adalah tempat &eItem&r bisa ditaro, disimpen, sama diambil. Kita bisa tambahin berapa banyak Slot yang ditampilin pake Tombol di Kiri buat Naikin atau Turunin Tinggi. Dari 2 Baris, sampe 7. \\n\\nDi atas Slot ada Search Bar buat cari nama &eItem&r, Tag, sama Mod. Di bawah Slot ada opsi Sorting. Entah Item dari A ke Z atau dari paling sedikit ke paling banyak &eItem&r dalam stack. \\n\\nTombol Kanan bakal bikin pas kita buka &eQIO Dashboard&r, Typing kita mulai di &lEMI&r atau &e&lQIO&r Type Bar. \\n\\nSekarang buat bagian berguna lain dari &e&lQIO System&r, Crafting! Di Kiri ada Tombol Crafting! Ini bakal munculin, sampe 3 Jendela Crafting. Masing-masing punya Grid Crafting 3x3 yang bisa kita pake. \\n\\nTombol di bawah Tombol Crafting ngaruhin Shift Click &eItem&r dari Inventory kita. Antara bakal kirim ke Jendela Crafting yang terbuka, atau ke &e&lQIO System&r. \\n\\nTombol terakhir dipake sama &lEMI&r buat otomatis nge-set Recipe. Blok yang diganti bakal ditaro di Inventory lo, atau balik ke &e&lQIO System&r."]
	quest.13A5748DF69D832E.title: "&eQIO Dashboard"
	quest.13AA91D39A2CABF2.quest_desc: ["Selamat datang di &6Productive Bees&r!\\n\\nUntuk memulai, kamu butuh mencari Honeycomb dan Honey Bottle! Temukan sebuah sarang lebah (Beehive) dan biarkan mereka bekerja. Mencukur sarang yang penuh akan memberimu Honeycomb, dan botol kaca akan memberimu Honey Bottle!\\n\\n&9Catatan Penting&r: Karena quest lebah membutuhkan sarang (combs), resepnya tidak akan ditampilkan. Pastikan cari sendiri di JEI!"]
	quest.13AA91D39A2CABF2.title: "Productive Bees!"
	quest.13AEBC331F29BC3D.quest_desc: ["&eLogistik Item&r sangat penting untuk &6&lCreate&r. &6Batu Giling&r butuh &eItem&f, &6Penyebar&f butuh &eItem&f, &6Pengaduk Mekanik&f butuh &eItem&r, dan seterusnya. \\n\\nLalu bagaimana &6&lCreate&r ingin kita memindahkan &eItem&r? Dengan &eSabuk&r! \\n\\n&eSabuk&r bisa disambungkan ke dua &8Poros&r untuk terhubung dan bergerak bersamanya. Kalau &8Poros&r pertama bergerak &e&oSearah Jarum Jam&r, yang kedua akan bergerak dengan Kecepatan dan Arah yang sama. \\n\\nBegitu pula &eSabuk&r yang dipasang pada &8Poros&r tersebut — bergerak sesuai Kecepatan dan Arah &8Poros&r yang menjadi tumpuannya. \\n\\nSaat pemasangan, &8Sabuk&r bisa dipasang tepat Horizontal, Vertikal, atau diagonal di sudut 45%. \\n\\nSetelah terpasang dan bergerak, semua &eItem&r atau Entitas di atasnya akan ikut terbawa. Entitas bisa melangkah turun dari &eSabuk&r jadi hati-hati. Untungnya &eItem&r tidak bisa jatuh atau bahkan menghilang saat berada di atasnya! \\n\\n&eItem&r akan dibawa ke mana saja &eSabuk&r pergi. Kalau berakhir tiba-tiba, &eItem&r akan jatuh. Kalau menuju &ePenampang&r, &eItem&r akan ditempatkan di sana. Kalau melewati bawah &6Mesin&r, &6Mesin&r tersebut akan menggunakannya. \\n\\nKalau ingin mengambil &eItem&r dari &eSabuk&r, cukup Klik Kanan!"]
	quest.13AEBC331F29BC3D.title: "&e&lLogistik Item"
	quest.13AF35A3108B02AF.quest_desc: ["Harus cepat!"]
	quest.13AFCD3B6F62B986.quest_desc: ["Kasih resep Ice dan Snow!"]
	quest.13AFCD3B6F62B986.quest_subtitle: "Ice, Ice, Baby!"
	quest.13AFCD3B6F62B986.title: "Upgrade Ice"
	quest.13B338F377951032.quest_desc: ["Pernah berharap kamu bisa pakai &bSonic Blast&r milik &9&lWarden&r? \\n\\nDengan &bSonorous Staff&r kamu bisa! Tinggal Tahan Klik Kanan untuk mengisi dayanya, lalu lepaskan untuk mengirim &bSonic Blast&r. \\nAda cooldown sedikit dan punya Durability, jadi gunakan dengan risiko! \\n\\nUntuk Craft-nya kamu butuh &9Heart of the Deep&r dari &9&lWarden&r, 2 &3Soul Crystals&r dari &3&lStalker&r, dan 2 &3Sculk Bones &fdari &3Shattereds&r."]
	quest.13B338F377951032.title: "&bSonorous Staff"
	quest.13BB75A7E1973488.quest_desc: ["Lunar Monstrosity adalah Bos pertama yang ditambahkan di Eternal Starlight. \\n\\nMakhluk ini tinggal di tengah Cursed Garden, semoga beruntung menemukan dan melawannya!"]
	quest.13BB75A7E1973488.title: "Kalahkan Lunar Monstrosity"
	quest.13C5C06278DD9C95.quest_subtitle: "Padukan Telur Diamond Bee dengan Telur Nickel Bee"
	quest.13C5C06278DD9C95.title: "Adamant Bee"
	quest.13CAD46F4B229AB4.quest_subtitle: "Dibuat dengan Nature Altar"
	quest.13CAD46F4B229AB4.title: "Infused Iron Bee"
	quest.13D5F689E6884281.quest_desc: ["&eKobolediator&r adalah salah satu dari dua mini-bos di dalam &eCursed Pyramid&r. \\n\\nMereka akan tetap diam sampai ada pemain (dalam mode Survival) yang mendekat, barulah mereka bangun. \\n\\nMereka punya 1080 &4HP&r dan akan memberikan efek Mining Fatigue padamu. \\n\\nMereka akan mengayunkan pedang jika kamu terlalu dekat! Jika kamu menjauh, mereka akan menyerudukmu seolah-olah mereka adalah pemain rugbi yang sedang mengejar touchdown! \\n\\nSaat mati mereka menjatuhkan Koboleton Bone, Ancient Metal Ingot, dan tengkorak mereka!"]
	quest.13D5F689E6884281.title: "&eKobolediator"
	quest.13E3DE157B89E847.quest_desc: [
		"Struktur yang sangat sederhana, beberapa &6L&8e&6b&8a&6h&r dan barang lainnya membeku di dalam es."
		"{image:atm:textures/questpics/bumblezone/bumble_ice.png width:200 height:100 align:center}"
	]
	quest.13E3DE157B89E847.title: "Ice Monolith"
	quest.13F68CA518CD287C.quest_desc: ["&3Diesel&r dapat digunakan untuk membuat lebih banyak Kerosene (Minyak Tanah) atau membuat Lubricant (Pelumas)."]
	quest.13F68CA518CD287C.quest_subtitle: "Nasib si Diesel"
	quest.13F68CA518CD287C.title: "Diesel"
	quest.13F77C38AC015E9F.quest_desc: [
		"Tinggi di atas Gunung, tinggi di atas Awan terdapat &bMenara&r lain. Yang satu ini membuatmu merinding. \\n\\n&bMenara&r ini terbuat dari Batu, Dark Oak, dan Deepslate. Ada Menara kedua yang bercabang darinya. Ada tangga di luar yang menuju ke lantai pertama. Dari sana kamu bisa naik tangga dalam untuk naik ke kamar tidur atau menara kedua. \\n\\nAtau kamu bisa menjelajah di belakang tangga itu turun ke Ladder ke Basement, di mana &b&lCryomancer&r kemungkinan besar berada. \\n\\nDi &bMenara&r kamu bisa menemukan Inscription Table, Amethyst, dan Loot Chest!"
		"{image:atm:textures/questpics/iron_spells/spells_mountaintower.png width:200 height:100 align:center}"
	]
	quest.13F77C38AC015E9F.title: "&bMountain Tower"
	quest.1403D677CF2815C3.quest_desc: ["&5&lReforging Table&r ini melakukan semua yang bisa dilakukan meja &9&lSimple&r, tapi jauh lebih baik! \\n\\nMeja ini bisa memberikan kita &eAffix&r tingkat &5Epic&r dan &6Mythic&r beserta tingkat-tingkat sebelumnya!"]
	quest.1403D677CF2815C3.title: "(Lebih Baik) &5&lReforging Table&r"
	quest.1404BB8956D5F8C7.quest_desc: ["Mempengaruhi kemampuan lebah untuk bekerja di cuaca buruk. Ada 3 tingkat: &aNone&r, &dRain&r, &cAny&r. Kita mengincar &cAny&r (Cuaca Apa Pun). Kamu bisa mengikat lebah ke pagar saat badai jika mau, tapi itu kejam sekali.\\n\\nAku tawarkan solusi mudah: Memancing. Benar sekali, kamu bisa memancing lebah. Water atau Prismarine Bee secara alami punya kemampuan menahan cuaca apa pun. Kita bisa memanfaatkan ini!"]
	quest.1404BB8956D5F8C7.quest_subtitle: "Sifat yang paling penting"
	quest.1404BB8956D5F8C7.title: "&9&lKetahanan Cuaca"
	quest.1409C17773B6A131.quest_desc: ["Semua Upgrade meningkatkan jumlah yang bisa dipindahkan oleh &e&lPipez&r, namun masing-masing memberikan opsi tambahan untuk digunakan.\\n\\nBasic Upgrade memungkinkan aktivasi Redstone.\\n\\nImproved Upgrade memungkinkanmu mengubah distribusi: Terdekat Dulu, Terjauh Dulu, Round-Robin, atau Acak.\\n\\nAdvanced Upgrade memberimu opsi untuk menambahkan Filter.\\n\\nUltimate tidak memberikan fitur baru, hanya saja kapasitas transfernya sangat besar!"]
	quest.1409C17773B6A131.title: "&9Pipez: &aUpgrades"
	quest.140DADB32EF10D58.quest_desc: ["Benih Telur Naga butuh Telur Naga Crux yang ditaro di bawah biar bisa numbuh."]
	quest.140DADB32EF10D58.quest_subtitle: "Tingkat: &56"
	quest.140DE53DC0FCD9F4.quest_desc: [
		"&bME Annihilation Plane&f dapat digunakan untuk menghancurkan blok di depannya secara otomatis dan memasukkan hasil jatuhan blok tersebut langsung ke jaringan ME. "
		""
		"Sebagai bonus, Annihilation Plane dapat diberi enchant seperti alat gali biasa, memberikan efek yang sama pada hasil jatuhan blok. Ini sangat ideal untuk memproses bijih (ore) jika diberi enchant Fortune. "
		"Setiap enchant yang ditambahkan akan meningkatkan konsumsi energi secara signifikan. Memberi enchant &eEfficiency&f akan mengurangi penggunaan energi secara keseluruhan, sementara &eUnbreaking&f memberikan peluang bagi plane untuk tidak mengonsumsi energi saat bekerja."
	]
	quest.140DE53DC0FCD9F4.quest_subtitle: "Sedot Masuk"
	quest.140DE53DC0FCD9F4.title: "ME Annihilation Plane"
	quest.140DF670162C68DA.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_steeleaf.png width:100 height:150 align:center}"]
	quest.140DF670162C68DA.title: "&aSteeleaf"
	quest.141681FE9E524FB0.quest_desc: [
		"&7Forgotten&r adalah prajurit yang muncul di dalam struktur Catacomb. \\n\\nMereka memakai Ancient Armor dan memegang peralatan Cloggrum, semuanya bisa dijatuhkan saat mereka mati. \\n\\nMereka juga akan menyerang dan membunuh para &cRot Mobs&r."
		"{image:atm:textures/questpics/undergarden/undergarden_forgotten.png width:100 height:200 align:center}"
	]
	quest.141681FE9E524FB0.title: "&7Forgotten&r"
	quest.141D68BAD039784B.quest_desc: ["&6&lThermoelectric Boiler&r bisa dipake buat dapetin &6Superheated Sodium&r sama &9Air&r terus daur ulang jadi Sodium sama Steam! \\n\\nTapi gimana cara masukin &6Superheated Sodium&r sama &9Air&r ke &6&lBoiler&r? \\n\\nPake &6Boiler Port&r! Kita perlu pake &3Configurator&r buat ngubah config &6Port&r. \\n\\n&6Superheated Sodium&r sama &9Air&r bakal dimasukin lewat Input &6Port&r (Port Input terpisah). \\n\\nSodium yang udah dingin, bakal dikeluarin lewat Output &6Port&r. Dan Steam dapet &6Port&r Output Steam sendiri!"]
	quest.141D68BAD039784B.title: "&6Boiler Port"
	quest.1427B3AB09510D20.quest_desc: ["Crafting bersama Unassembled PCB milikmu dengan 2 Kapasitor dan 2 Transistor untuk mendapatkan &3Finished PCB&r (PCB Jadi)."]
	quest.1427B3AB09510D20.quest_subtitle: "Kamu berhasil!"
	quest.142C67218BD16867.quest_desc: ["Isi Minigun milikmu dengan &3Minigun Ammo&r ini untuk menggunakannya."]
	quest.14385D3D359224BC.quest_desc: ["&dMeka-Tool&r adalah Tool terbaik yang ditawarin &5&lMekanism&r, makanya namanya gitu! \\n\\nBisa lakuin semua yang bisa &bAtomic &cDisassembler&r lakukan tapi lebih bagus! Dari segi ngehancurin Blok, dengan lebih banyak Damage sama Attack Speed. \\n\\nTapi daripada punya Mode, dia bisa pake Modification Unit! Cek Quest masing-masing. \\n\\nMeski pake &3Configurator&r buat Craft, dia gak niru fungsinya sama sekali."]
	quest.14385D3D359224BC.title: "&dMeka-Tool"
	quest.143AE6889BDA9EF5.quest_desc: ["Module hanya punya sedikit slot untuk filter item. Jika butuh lebih, gunakan ini! Bulk Item Filter. \\n\\nKamu bisa memasukkan jauh lebih banyak item untuk masuk ke daftar Whitelist atau Blacklist. Lalu pasang di slot filter biasa! \\n\\nDibutuhkan juga untuk men-craft filter-filter unik lainnya."]
	quest.144BB025516E0994.quest_desc: [
		"&3Vibranium&r adalah bijih setelah &6Allthemodium&r, jadi tentu saja membutuhkan &6Allthemodium Pickaxe&r (atau tingkat yang sama) untuk menambangnya.\\n\\nKamu bisa menemukannya dengan sangat langka di &c&lThe Nether&r atau melimpah di &b&lThe Other&r.\\n\\nSangat disarankan untuk memproses bijihnya (Ore Process) agar mendapatkan hasil lebih banyak.\\n\\nSayangnya, meskipun bijih ATM ini punya warna yang keren, ia memiliki kegunaan paling sedikit untuk pembuatan item yang berbeda."
		"{image:atm:textures/questpics/allthemodium/all_2.png width:100 height:100 align:center}"
	]
	quest.144BB025516E0994.title: "&3Vibranium Ingot&r"
	quest.144ECED643031A9A.quest_desc: ["Glowing Mushroom adalah tanaman Jamur gede yang bisa kamu temuin di Scarlet Forest! \\n\\nMereka fungsi kayak Brown atau Red Mushroom cuma yang ini Glow lebih terang! \\n\\n(Kalau kamu gak tau Brown dan Red Mushroom sebenernya ngeluarin Light Source level 1)."]
	quest.1452D9CF827782B5.quest_desc: ["Arctic Gear dibuat menggunakan Arctic Fur. Arctic Fur dijatuhkan oleh Winter Wolf dan Yeti! \\n\\nNggak, kamu nggak bisa mencukur (shear) mereka berdua. \\n\\nGear ini bisa diwarnai seperti &7Leather Armor&r!"]
	quest.1452D9CF827782B5.quest_subtitle: "16"
	quest.1452D9CF827782B5.title: "&fArctic Gear"
	quest.145C8235BCCB9BA8.quest_desc: [
		"Jika kita ingin mengumpulkan semua jenis Kapur, kita harus memanggil dan membunuh setan &cAfrit&r yang tidak terlalu ramah."
		""
		"Meskipun ini bukan &5Ritual Perasukan&r, kamu tetap butuh tumbal hidup. Dalam hal ini, kita akan mengorbankan seekor Sapi. Maaf ya, si Moo!"
	]
	quest.145C8235BCCB9BA8.quest_subtitle: "Selamat jalan, Moo!"
	quest.145C8235BCCB9BA8.title: "&cRed Chalk (Kapur Merah)"
	quest.145E7D1A88B83DDD.quest_desc: ["Ke mana kamu pergi?"]
	quest.145E7D1A88B83DDD.quest_subtitle: "Syal (Kalung)"
	quest.145E7D1A88B83DDD.title: "&9Scarf of Invisibility&r"
	quest.14623D25561BA61B.quest_desc: ["Terutama untuk Catcher."]
	quest.14623D25561BA61B.quest_subtitle: "Meningkatkan Jarak Jangkauan Mesin"
	quest.1464D45C474464DB.quest_subtitle: "Penyapu Daun yang Mewah"
	quest.146AF0937D9C63DE.quest_desc: ["Pegang Bow di off hand dan &7Scroll of Strengthening&r di main hand lalu tahan Right Click."]
	quest.146AF0937D9C63DE.title: "Strong Bow"
	quest.148A33CC36B2563A.quest_desc: ["&dDraconic Shelf&r adalah rak terakhir yang kita butuhkan untuk setup yang sempurna. \\n\\nMeski cuma memberikan &aEterna&r, rak ini punya batas maksimal &aEterna&r hingga &a100&r. \\n\\nUntuk membuatnya, kita butuh 5 &3Ender Pearl&r dan satu &dDragon Head&r. Itulah yang membuatnya jadi &dDraconic&r! \\n\\nUntuk mendapatkannya, kamu bisa pakai &a&lMA&r atau mencarinya di &dEnd Ship&r. &dEnd Ship&r adalah struktur di &d&lThe End&r, dan &dDragon Head&r ada di bagian haluan (depan) kapal."]
	quest.148A33CC36B2563A.title: "&dDraconic Endshelf"
	quest.149BD1A9F82FA19A.quest_subtitle: "&f6 &cAttack Damage"
	quest.149C260C10B34BB0.quest_subtitle: "5/5"
	quest.149C260C10B34BB0.title: "Bagian Kiri &6&lATM Star&r"
	quest.14B3542ECB59869C.quest_desc: ["&5Loot Fabricator&r adalah mesin yang menghasilkan loot dari Mob Prediction.\\n\\nKalau diberi power dan Mob Prediction yang berhasil, bisa memilih item mana yang ingin didapat dari Data Model mob tersebut. Mesin akan mengingat pilihan yang dibuat, jadi bisa diotomasi.\\n\\nContoh Mob Prediction:\\n\\n- &dEnder Dragon&r untuk &dDragon Egg\\n - &2Zombie&r untuk Iron\\n - &0Wither&r untuk &5Nether Star"]
	quest.14B3542ECB59869C.title: "Membuat &dLoot"
	quest.14B7EEBE0F6C2776.quest_desc: ["&dInfused Dragon's Breath&r didapetin dengan... ya Infusing &dDragon's Breath&r. \\n\\nKamu bisa pake 2 &9Soul-Touched Sculkshelf&r, 3 &bHeart-Forged Seashelf&r, 8 Bookshelf biasa, dan 1 &6Geode-Encased Bookshelf of Stability&r. \\n\\nIni juga bakal dibutuhin buat resep lain tapi kita gak ngomongin itu!"]
	quest.14B7EEBE0F6C2776.title: "&dInfused Dragon's Breath"
	quest.14C27D44D3C8EDF5.quest_desc: ["1. Paling gampang ya tinggal nge-loot &dEnd City&r buat nyari ini. \\n\\n2. Untuk otomatisasinya, kamu harus kumpulin semua itemnya. \\n\\nBonemeal, &7Gunpowder&r, &4Redstone&r, &cBlaze Powder&r, dan Phantom Membrane semuanya bisa diotomatisasi pakai &b&lHNN&r atau &2&lMA&r. \\n\\n&bArcane Crystal&r butuh antara &6&lBees&r atau &2&lMA&r, lalu bakar jadi &bDust&r."]
	quest.14C27D44D3C8EDF5.title: "&cMundabitur Dust"
	quest.14CF23064A6035CD.quest_desc: [
		"H-h-h-h-&aHantu&r! bakal spawn entah dari &aPeti Terkutuk&r yang dibuka, atau dari &aTanah Kuburan&r pas &9Malam&r. \\n\\nMereka bercahaya, transparan, dan entah Putih, &aHijau&f, atau &bBiru&r. \\n\\n&aHantu&r punya 140 &4Hearts &fdan 2 &7Armor Points&r. \\n\\nMereka kebanyakan cuma bakal Pukul kamu kayak Zombie buat Nyerang tapi beda sama Zombie, &aHantu&r bisa Terbang dan tembus Blok buat terus Pukul kamu!"
		"{image:atm:textures/questpics/iceandfire/iaf_ghost.png width:100 height:150 align:center}"
	]
	quest.14CF23064A6035CD.title: "&aHantu"
	quest.14D9C071E184DE3B.quest_subtitle: "Purple Crepe Myrtle + Luck"
	quest.14DB8A515CA50932.quest_desc: ["&9Enchanter's Sword&r memungkinkanmu memasangkan mantra tipe sentuh (Touch Spell) ke pedang. \\n\\nSemua mantra pada pedang ini mendapatkan 1 tambahan augment Amplify pada efek terakhir mantra tersebut. \\n\\nUntuk memasang mantra ke pedang, gunakan Scribe's Table. Buatlah mantranya tanpa menggunakan 'form'."]
	quest.14E5349DD740D026.quest_desc: [
		"Untuk masukin fuel ke reactor, kamu harus pilih salah satu sisi yang ada &9Reactor Solid Access Port&r dan pompa &eUranium&r dari inventory.\\n\\nCara paling gampang adalah pakai &aStorage Drawer&r atau bahkan cuma &aChest&r dengan &9Item Pipe&r yang konek di atas, seperti gambar di bawah.\\n"
		"{image:atm:textures/questpics/extremereactors/importexample.png width:150 height:150 align:1}"
	]
	quest.14E5349DD740D026.title: "Ngisi Bahan Bakar Passive Reactor"
	quest.14F6ED7F0C1DC503.quest_desc: ["Minum 8 &6Botol Madu&r. \\n\\nIni misi tersulit bagiku karena aku tidak tahan dengan suara saat meminum &6Botol Madu&r."]
	quest.14F7F256DA863280.quest_subtitle: "Membuat berbagai Material Twilight Forest"
	quest.14F856E0D32FBB5B.quest_subtitle: "Teak + Balsa"
	quest.14FC9E4A3C80C0AE.quest_desc: [
		"Reaction Chamber bisa mempercepat berbagai Reaksi In-World di dalamnya, pakai fluid katalis dan energi besar. Karena lingkungan terkontrol, mesin ini bisa bikin reaksi lebih efisien, jadi kamu dapet lebih banyak material."
		""
		"Mesin ini boros power, jadi power generation bagus dan energy cell di ME Network sangat disarankan."
		""
		"Mesin ini juga diperlukan untuk resep Quantum di Advanced AE."
	]
	quest.14FC9E4A3C80C0AE.title: "Efisiensi Reaksi: Reaction Chamber"
	quest.15006CF73F8CAB7C.quest_desc: ["Sama seperti &cCharm of Life I&r, &eCharm of Life II&r akan dikonsumsi untuk mencegah kematianmu. Saat digunakan, kamu akan memulihkan semua HP dan mendapatkan efek Regen IV, Resistance, dan Fire Resistance selama 30 detik.\\n\\nItem ini bisa dibuat dengan 4 buah &cCharm of Life I&r."]
	quest.15006CF73F8CAB7C.title: "&eCharm of Life II"
	quest.15007DCAF701B361.quest_desc: ["Mengisi daya item lain yang membutuhkan tekanan udara di inventarismu menggunakan cadangan energi dari chestplate."]
	quest.15007DCAF701B361.quest_subtitle: "Maks: 6"
	quest.150FB369BEFFCBBF.quest_subtitle: "Tuangkan Molten Lumium ke atas telur lebah Silver/Tin"
	quest.150FB369BEFFCBBF.title: "Lumium Bee"
	quest.1515B32545F51266.quest_desc: ["Memungkinkan kamu pasang power ke Stove."]
	quest.1515B32545F51266.title: "Upgrade Heating"
	quest.151648179684B088.quest_desc: ["Runic Chalk digunakan untuk menggambar Rune permanen di tanah. Rune ini akan merapal mantra pada entitas yang menginjaknya. \\n\\nUntuk memasang mantra ke rune, tuliskan pada &eSpell Parchment&r menggunakan Scribe's Table.\\n\\nCatatan: Rune membutuhkan Source untuk bekerja."]
	quest.151648179684B088.quest_subtitle: "Mantra yang Bisa Dipasang"
	quest.15195F456D8AD4C8.quest_desc: ["Kalau Ether kena Air, Thioquartz bakal terbentuk. Ini bisa terjadi natural dengan generasi random atau kamu bisa bikin sendiri! \\n\\nIni bukan cara kita dapetin Shard, itu dari Budding Thioquartz!"]
	quest.151D836C7B0E6FAF.title: "&3Vibranium Shield"
	quest.15279CAC2FFE6B35.quest_subtitle: "Tingkat: &c5"
	quest.15288215A4BA2596.quest_subtitle: "Berikan sebuah blok Rose Quartz ke Diamond Bee"
	quest.15288215A4BA2596.title: "Rose Quartz Bee"
	quest.1533D98B3B2A758E.quest_desc: ["Shattered Sword bisa di-drop dari Lonestar Skeleton atau di-craft pakai Blade yang di-drop. \\n\\nShattered Sword dipake lebih kayak Trident daripada Sword, daripada mukul kamu bakal lempar dia. Terus, kamu bisa Right Click buat balikin Blade-nya kayak Loyalty Trident, dan Right Click lagi buat reload kalau perlu."]
	quest.1540A9CDE2ED77E8.quest_subtitle: "Dibuat dengan Energizer"
	quest.1540A9CDE2ED77E8.title: "Spirited Crystal Bee"
	quest.154D9EA863FD2A32.title: "Chaotic Projectile Penetration Module"
	quest.15540271BF17C2E4.quest_desc: ["&lSelamat datang di XyCraft!&r\\n\\nSeri mod ini didedikasikan untuk XyCraft: World dan Machines!\\nXyCraft World menghadirkan berbagai jenis Gem yang bisa kamu temukan saat menambang."]
	quest.15540271BF17C2E4.title: "&lXyCraft"
	quest.15564C11744D6AA0.quest_desc: ["Setelah kamu mendapatkan set lengkap &eInscriber Press&r yang dibutuhkan, saatnya mulai membuat &eProcessor&f. Ini adalah bahan crafting penting yang digunakan untuk membuat sebagian besar perangkat yang terhubung ke ME."]
	quest.15564C11744D6AA0.title: "Processor"
	quest.1556777B07BD7C2B.quest_subtitle: "European Larch + Sugar Maple"
	quest.155A843A562DB7C4.quest_subtitle: "Tingkat: &63"
	quest.156605859D553276.quest_desc: ["Jendela, kaca jendela, penutup jendela, tirai, kerai, sampai ke parapet! \\n\\nAku bahkan tidak tahu apa itu parapet!"]
	quest.156605859D553276.title: "&l&bMacaw's Windows&r"
	quest.1568CBFA09827137.quest_desc: ["Sama seperti Logic Programmer, cuma yang ini bisa dipakai di mana saja."]
	quest.156FF8B7B724DC38.quest_desc: ["Menambahkan filter untuk item yang dipompa masuk atau keluar dari Tas."]
	quest.15849165CA8C00F9.quest_desc: [
		"&6&lForge&r paling kuat terakhir jadi tentu saja artinya ini paling mahal! \\n\\nKamu butuh 2 &5Dark Nether Star&r yang dibuat dari gabungin 4 &5Obsidiansteel&r dan Nether Star. \\n\\n2 &dDragon Scale&r yang drop saat &dEnder Dragon&r mati. \\n\\n4 &3Sculk Catalyst&r yang drop dari &3Warden&r, atau bisa di-Silk-Touch di Deep Dark. \\n\\nDan &2Stellarite Block&r yang cuma 9 &2Stellarite Piece&r! \\n\\nIni memungkinkan lebih banyak Essence dan Resep End Game."
		"{image:atm:textures/questpics/forbidden/forbidden_tier5.png width:100 height:100 align:center}"
	]
	quest.15849165CA8C00F9.title: "&l&9Tier 5 &6Forge"
	quest.158B24939A269D83.quest_desc: ["Tip Upgrade digunakan untuk meningkatkan tingkat penambangan (mining level) sebuah alat.\\n\\nContoh: Jika kamu punya Beliung Besi (Iron Pickaxe), dengan 1 buah Diamond kamu bisa membuat Diamond Tip Upgrade dan memasangnya pada beliungmu. Ini akan memungkinkannya menambang Obsidian, sekaligus memberikan peningkatan statistik."]
	quest.158B24939A269D83.quest_subtitle: "Buat kamu yang nggak nemu 3 biji Diamond"
	quest.158F872A3A2C3650.quest_desc: ["Sekarang karena batas maksimal &aEterna&r kita sudah mencapai &a80&r, kita bisa mulai melakukan &d&lInfusing&r &dDragon's Breath&r! \\n\\n&dDragon's Breath&r bisa didapat saat melawan &d&lEnder Dragon&r. Saat naga tersebut bertengger di atas sarangnya, ia akan menyemburkan kabut &dmerah muda&r. Gunakan botol kosong (Empty Bottle) dan klik kanan pada kabut tersebut untuk mendapatkan &dDragon's Breath&r! \\n\\nCara terbaik untuk mendapatkan level ini adalah dengan 4 &9Echoing Sculkshelves&r, 4 &9Soul-Touched Sculkshelves&r, dan 6 &6Geode-Encased Bookshelves of Stability&r. \\n\\nIni akan memberikan kita &a80 Eterna&r, &c25% Quanta&r, dan &5100% Arcana&r. Sempurna untuk &d&lInfusion&r!"]
	quest.158F872A3A2C3650.title: "&dInfused Dragon's Breath"
	quest.1591013DDD4766E1.quest_desc: ["&l&cCooking for Blockheads&r adalah tentang membuat Dapur menjadi rumahmu. \\n\\nAku merekomendasikan untuk menggunakan semua yang diberikan karena setiap item memiliki kegunaan dan terlihat luar biasa!"]
	quest.1591013DDD4766E1.title: "&l&cCooking for Blockheads&r"
	quest.15978093237448FE.quest_desc: ["Kenapa harus upgrade &cNetherite&r ke &6Allthemodium&r kalau kamu bisa meng-upgrade-nya menjadi &3Warden Armor&r! \\n\\nTapi kamu butuh beberapa drop dari Warden untuk membuatnya!"]
	quest.15978093237448FE.quest_subtitle: "24"
	quest.15978093237448FE.title: "&3Warden Armor"
	quest.15A8F04BC10E619E.quest_desc: [
		"Beberapa orang benci menjelajahi banyak biome berbeda hanya untuk mencari semua jenis bibit pohon. \\n\\nSepertinya pembuat &2&lUndergarden&r juga merasakannya, jadi ia menaruh hampir semuanya di Dense Forest!"
		"{image:atm:textures/questpics/undergarden/undergarden_dense.png width:200 height:100 align:center}"
	]
	quest.15A8F04BC10E619E.title: "Dense Forest"
	quest.15C9CCCC8E06D430.quest_subtitle: "Berikan blok Black Quartz ke Crystalline Bee"
	quest.15C9CCCC8E06D430.title: "Black Quartz Bee"
	quest.15CD4BFDC56E9510.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.15CD4BFDC56E9510.title: "&eAdvanced Tool Swapper Upgrade"
	quest.15D355EB164EBE68.quest_subtitle: "Dibutuhkan untuk PCB Jadi"
	quest.15D355EB164EBE68.title: "Kapasitor"
	quest.15D764CAF047EA7A.title: "&cArmor Tertium&r"
	quest.15DC6770B112EE69.quest_desc: [
		"Dissolution Chamber adalah mesin dari mod &l&7Industrial Foregoing&r. Ini juga cara kita menggabungkan &3Vibranium&r dan &5Unobtainium&r. \\n\\nKamu butuh &dPink Slime&r yang didapat dari Mob Slaughter Factory, mesin lain dari mod IF. \\n\\nKamu juga butuh Soul Lava yang bisa ditemukan di &b&lThe Other&r, biasanya ada di Piglin Village. \\n\\nSetelah itu, masukkan Ingot dan Piglich Heart dengan urutan yang tepat, beri daya listrik, dan selesai!\\n"
		"{ \"text\": \"QUESTLINE INDUSTRIAL FOREGOING\", \"color\": \"#55FF55\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"193F91842D2ED7D9\" } }"
	]
	quest.15ECBC8E174FA39B.quest_desc: ["Memungkinkanmu mengakses penyimpanan jaringan secara nirkabel (wireless)."]
	quest.15ECBC8E174FA39B.quest_subtitle: "Grid Portabel"
	quest.15ECBC8E174FA39B.title: "Wireless Grid"
	quest.15FEA03A2CDBA33B.quest_desc: ["&b&lThe Other&r telah mengalami lusinan perubahan selama bertahun-tahun, tapi tetap selalu menjadi alam bagi para petualang! \\n\\nAda puluhan biome, blok, dan tentu saja struktur baru! \\n\\nStrukturnya meliputi: Piglin Village, Ancient Pyramid, dan Dungeon. Semuanya berisi loot yang luar biasa dengan beberapa barang unik di tiap strukturnya! \\n\\nKamu juga bisa menambang &3Vibranium&r (dan bijih lainnya!) atau menemukannya di dalam struktur! \\n\\nKamu tidak bisa memasang Quarry atau banyak jenis blok lainnya di &b&lThe Other&r; tidak ada cara curang (cheesing) di sini."]
	quest.15FEA03A2CDBA33B.title: "&l&bThe Other&r"
	quest.15FF9D19FBC873CF.quest_subtitle: "Plum + Peach"
	quest.1609BF52108238B0.quest_subtitle: "Tingkat: &e1"
	quest.160BD0185954C891.quest_desc: ["Alih-alih Honey Treat, sarang ini butuh Gold Ingot untuk menarik lebah."]
	quest.160BD0185954C891.quest_subtitle: "Memancing Gold Bee saat diletakkan di Nether"
	quest.161477ABCC437BD2.quest_desc: ["&bBoreal Blade&r adalah Pedang yang keren! Baik dari segi kepribadian maupun suhu. \\n\\nIni dibuat dari &bWeapon Parts&r, &bEs&r, &bMithril Ingot&r, dan &bIce Venom Vial&r. \\n\\nLihat Quest &b&lIce Spider&r untuk mendapatkan &bIce Venom&r! \\n\\nPedang ini memberikan Damage yang besar! 16 &4Heart&r. Tapi lambat untuk diayunkan, kecepatan yang sama dengan Kapak. \\n\\n&3Spell&r yang datang dengan &bBoreal Blade&r adalah &bFrostbite&r. Ini Effect lain... tidak yakin apa fungsinya."]
	quest.161477ABCC437BD2.title: "&bBoreal Blade"
	quest.161878AB4236C58B.quest_subtitle: "&f6.5 &cAttack Damage"
	quest.161A90E134592D0E.quest_desc: ["Sama seperti daging sapi mentah biasa, kamu bisa memasak &cEverlasting Beef&r untuk mendapatkan &4Eternal Steak&r!\\n\\nFungsinya sama dengan &cEverlasting Beef&r tapi memberikan poin lapar dan saturasi yang lebih banyak."]
	quest.161A90E134592D0E.quest_subtitle: "Unik"
	quest.161A90E134592D0E.title: "&4Everlasting Steak"
	quest.161E7D934A21F849.quest_desc: [
		"Reformation (Reformasi) adalah proses mengubah satu &eAlchemical Sulfur&r menjadi jenis lainnya atau menggunakan &3Alchemical Niter&r untuk memperbanyaknya! \\n\\nLangkah pertama adalah Source Pedestal, di sinilah kamu menaruh &eSulfur&r yang ingin kamu ubah menjadi jenis lain."
		"{image:atm:textures/questpics/theurgy/theurgy_reform_1.png width:100 height:100 align:center}"
	]
	quest.161E7D934A21F849.title: "Langkah 1: Source Pedestal"
	quest.16255FB20F35A9D9.quest_desc: ["&3Snorkel&r memberimu sedikit kemampuan bernapas di dalam &9Air&r. Mirip kayak Turtle Helmet! Tapi hati-hati ya, durasinya bisa habis."]
	quest.16255FB20F35A9D9.quest_subtitle: "Kepala"
	quest.16255FB20F35A9D9.title: "&3Snorkel"
	quest.1625C3A30E69D634.quest_desc: ["Kamu bisa menemukan batu-batu baru ini di biome &l&cRegions Unexplored&r! \\n\\nTidak, Mossy Stone ini tidak sama dengan yang ada di &l&aOh The Biomes We've Gone&r. \\n\\nTidak, ini juga tidak sama dengan Mossy Stone Brick."]
	quest.1625C3A30E69D634.title: "Batu &l&cRegions Unexplored&r"
	quest.162807D14C173CB4.quest_desc: ["&#5599EDCentrifuge&r mengonfirmasi teori kita bahwa jika kita memutar sesuatu dengan sangat cepat, material baru akan muncul darinya. Alat ini punya banyak kegunaan, tetapi kamu akan membutuhkannya terutama untuk pengolahan &#F2AAE5Chromium&r dan &#AD3497Monazite&r."]
	quest.162807D14C173CB4.quest_subtitle: "Putar terus sampai pusing.."
	quest.16299B9AE87257DC.quest_desc: ["&bWireless Terminal&f berfungsi identik dengan terminal biasa, tetapi secara nirkabel.\\n\\nSebelum bisa digunakan untuk mengakses jaringan, terminal ini harus &edihubungkan&f (link) terlebih dahulu dengan menaruhnya di slot kanan atas pada &eWireless Access Point&r. Jika tidak terhubung, atau berada di luar jangkauan atau kehabisan daya, terminal tidak akan berfungsi.\\n\\nWireless terminal juga dapat di-upgrade dengan &eEnergy Card&f untuk memberikan kapasitas baterai yang lebih besar."]
	quest.16299B9AE87257DC.quest_subtitle: "Inilah yang kamu cari"
	quest.16299B9AE87257DC.title: "Wireless Terminal"
	quest.162CE44400A63575.quest_desc: ["&5Mesin&r pertama dan yang paling penting adalah &9&lMetallurgic Infuser&r! \\n\\n&9&lMetallurgic Infuser&r bakal gabungin sebuah &eItem&r sama &cChemical&r buat bikin &eItem&r dan Alloy baru. \\n\\n&cChemical &fatau &aInfuse Type&r masuk ke &eKotak Kuning&r dan bakal muncul di &eBar&r sebelah kirinya. \\n\\n& Kotak Merah&r itu tempat naruh Item yang mau di-Infuse. \\n\\n&9Kotak Biru Tua&r itu tempat hasilnya keluar! \\n\\nDi sebelah kanan, &aSlot Hijau Muda&r dan &aBar&r-nya itu buat &aEnergi&r! \\n\\nKalau perlu kosongin &eChemical Bar&r, pakai tombol &lDUMP&r. Ini bakal buang semua &aChemical&r di dalamnya!"]
	quest.162CE44400A63575.quest_subtitle: "Mesin Awal"
	quest.162CE44400A63575.title: "&9&lMetallurgic Infuser"
	quest.162D2286A69D6E07.quest_desc: [
		"Statistiknya mirip dengan &6Allthemodium Armor&r biasa, tapi set ini dilengkapi dengan tambahan Mana Boost, Regen, dan Spell Power untuk mantra-mantra Ars!"
		"{image:atm:textures/questpics/allthemodium/all_armor_allarcane.png width:100 height:175 align:center}"
	]
	quest.162D2286A69D6E07.title: "&6Allthemodium Arcanist Armor"
	quest.16359196D49A6223.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_froststeel.png width:100 height:150 align:center}"]
	quest.16359196D49A6223.title: "&bFroststeel&r"
	quest.1636F3F12E92CAEA.quest_desc: [
		"Buat pake Kaleng Penyiram kamu harus isi dulu pakai Air dengan klik kanan di blok sumber Air. Kalau udah keisi Air kamu bisa tahan klik kanan di tanaman buat nyiram tanaman dalam area AOE Kaleng Penyiram."
		""
		"Kaleng penyiram Essence punya kemampuan nyiram otomatis. Tinggal shift-klik kanan Kaleng Penyiram di udara buat nyalain atau matiin auto-nyiram. Nanti keliatan kayak Kaleng Penyiram lagi di-enchant kalau lagi nyala."
	]
	quest.164BBBD98163F64C.quest_desc: ["Lihat Modules untuk belajar lebih tentang cara menggunakan dan upgrade item DE! Bisa membuat farmland atau mengambil uangmu. Oh tunggu Minecraft Hoe maaf aku pikir yang lain."]
	quest.164BBBD98163F64C.title: "Wyvern Hoe"
	quest.165030137EF59299.title: "Wyvern Area-Of-Effect Module"
	quest.1659A59303C15CC9.quest_desc: ["Barrel (Tong) bekerja sama seperti Peti, hanya saja mereka tidak bisa digabung menjadi satu. Tapi tampilannya cukup keren."]
	quest.166971866A9234C7.quest_desc: ["Salah satu dari 3 item Infused paling penting adalah &cInfused Alloy&r. \\n\\nBuat bikinnya kita perlu Infuse &6Copper Ingot&r pakai 10mB &4Redstone&r. \\n\\nGimana cara dapat 10mB &4Redstone&r? Tinggal taruh &4Item Redstone&r ke &eKotak Kuning&r di &9&lMetallurgic Infuser&r! \\n\\nNanti &4Item Redstone&r-nya hilang dan tiap &4Item&r kasih jumlah yang beda. &4Redstone Dust&r kasih 10mB, &4Enriched Redstone&r kasih 80mB, dan satu &4Block of Redstone&r kasih 90mB."]
	quest.166971866A9234C7.quest_subtitle: "Alloy Dasar buat Crafting Item"
	quest.166971866A9234C7.title: "&cInfused Alloy"
	quest.166CE4243896A0CD.quest_desc: ["Nggak suka dengan &aGem&r milikmu? Kalau begitu, ubah saja! \\n\\nUntuk mengubah Rarity dari &aGem&r-mu, kamu perlu menggunakan &a&lTable&r ini. \\n\\nDengan menggunakan 2 &aGem&r yang sama dan material Rarity, kamu bisa meningkatkan Rarity &aGem&r tersebut yang otomatis meningkatkan kekuatannya."]
	quest.166CE4243896A0CD.title: "Mendapatkan &aGem yang Lebih Baik"
	quest.166D2A191871F80E.quest_desc: ["Versi upgrade dari Wyvern Pickaxe."]
	quest.166D2A191871F80E.title: "Draconic Pickaxe"
	quest.167E1474644C9908.quest_desc: ["Quartz memberikan efek kebalikan dari item modifikasi spawner lainnya. Dengan Quartz di tangan kiri (offhand) dan item modifikasi lain di tangan utama, efeknya akan terbalik. Contohnya, menggunakan Quartz dan Blaze Rod akan mengurangi Spawn Range, bukannya menambah. Begitu juga dengan Ghast Tear yang akan mengurangi Max Entities jika digabung dengan Quartz."]
	quest.167E1474644C9908.title: "Hari Kebalikan"
	quest.1682CED78D9D4BA7.quest_desc: ["&9&lTwilight Forest&r adalah salah satu Mod paling terkenal dan dikenal, dan ada alasannya. Mod ini praktis udah ngedefine Adventure Mod! \\n\\nBuat kesana tinggal bikin kolam Air 2x2, kelilingin sama Bunga, dan lempar Diamond ke dalamnya! \\n\\nTerus, Portal-mu bakal kebuka, dan kamu bisa masuk &l&9Twilight Forest&r. \\n\\nDi sini kamu harus ngikutin urutan Boss yang ketat buat dibunuh dan progres!"]
	quest.1682CED78D9D4BA7.title: "&9&lTwilight Forest"
	quest.1697CC05D08B388D.quest_subtitle: "Ayam Goreng Enak!"
	quest.1697CC05D08B388D.title: "Ayam Harus Pergi"
	quest.1698565EBB68DC85.quest_desc: [
		"&6Wye Track&r adalah jenis jalur kedua yang dibuat menggunakan Spike Maul. Ia mengarahkan dua &6Jalur&r menjadi satu. Jika kamu memiliki satu &6Jalur&r yang berpotongan dengan yang lain, &6Wye&r akan memindahkan &7Cart&r dari jalur pertama ke jalur yang memotong tersebut."
		"{image:atm:textures/questpics/railcraft/rail_wye.png width:100 height:100 align:center}"
	]
	quest.1698565EBB68DC85.title: "&6Jalur Wye"
	quest.16987C41D4F5BA47.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.16987C41D4F5BA47.title: "Copper Alloy Bee"
	quest.16A04B2FC3F0D902.quest_desc: ["Peralatan &7Cloggrum&r berfungsi seperti peralatan Besi, hanya saja warnanya lebih mirip lumpur dibanding besi! \\n\\nTapi pedangnya menghasilkan damage lebih besar dibanding Pedang Besi."]
	quest.16A04B2FC3F0D902.title: "Peralatan &7Cloggrum&r"
	quest.16A2CC83C99B1F86.quest_desc: [
		"&9Angler Fish&r muncul di &9Kolam Air&r dalam &bBlooming Caverns&r. \\n\\nMereka bertindak seperti Ikan normal, jelas butuh &9Air&r untuk bernapas. \\n\\nMereka punya 3 &4Hearts&r dan akan menyerangmu saat kamu dekat. \\n\\nMereka sayangnya tidak drop apa-apa saat mati... maaf ya Ikan!"
		"{image:atm:textures/questpics/deepndark/dnd_fish.png width:100 height:120 align:center}"
	]
	quest.16A2CC83C99B1F86.title: "&9Angler Fish"
	quest.16AAC61729C44881.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.16B0C1F7B951C19D.quest_desc: ["Sekarang kita sudah punya &ePengemasan&r, kita bisa membuat &ePaket&r! \\n\\nAda 4 varian tapi itu nggak mengubah fungsionalitasnya, hanya tampilannya. Varian mana yang kamu dapat sepenuhnya acak. \\n\\n&ePaket&r adalah &eItem&r dan ketika diletakkan di tanah akan menjadi Entitas. Kamu bisa Klik Kanan setelah diletakkan untuk mengambilnya, atau Hancurkan untuk mengambil &eItem&r di dalamnya. Bisa juga dipindahkan seperti Entitas lainnya! \\n\\n&ePaket&r juga bisa berinteraksi dengan &6Mesin&r lain. Seperti diletakkan di &8Konveyor Rantai&f atau &eSabuk&r!"]
	quest.16B0C1F7B951C19D.title: "&ePaket Kardus"
	quest.16B4A00948D1F60D.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.16B88F46021E956D.quest_desc: ["&l&6Theurgy&r memiliki mesin, jadi tentu saja butuh sistem Logistik!\\n\\n(Cek halaman Logistik Dasar untuk mempelajari lebih lanjut soal logistik).\\n\\nDengan &cMercury&r, kamu bisa memindahkan Item dan Cairan dari satu tempat ke tempat lain menggunakan &cMercury Wire&r dan item pendukung lainnya! Kabel inilah yang akan memindahkan item-item tersebut."]
	quest.16B88F46021E956D.title: "Logistik dengan &cMercury&r"
	quest.16C74B5F99AD6724.quest_desc: ["&8Common&r adalah Rarity yang paling dasar. Ini membuatnya paling sering ditemukan di awal game, tapi juga yang paling lemah. \\n\\n&8Common&r paling banyak muncul di &lWorld Tier: &9Haven&r, dan akan berhenti muncul setelah &lWorld Tier: &6Summit&r. \\n\\n&8Mysterious Scrap Metal&r dibuat dengan menghancurkan &eItem&r &8Common&r di &c&lSalvaging Table&r."]
	quest.16C74B5F99AD6724.quest_subtitle: "&8Common"
	quest.16C74B5F99AD6724.title: "&8Mysterious Scrap Metal"
	quest.16D0F1E3CEB60ABF.title: "Pancing Besi"
	quest.16DDAE318535D0F9.quest_desc: ["&bAtomic &cDisassembler&r adalah Paxel-nya &5&lMekanism&r! \\n\\nBisa Nambang Blok apapun yang bisa ditambang &6AllTheModium Paxel&r! Bisa juga dipake sebagai Sword... ya lebih kayak Axe sih, gak ada Sweeping Edge. \\n\\nPunya Mode yang beda-beda, masing-masing dengan Efisiensi sama penggunaan &aEnergi&r yang berbeda. Bisa diganti dengan hold Shift sambil Scroll. \\n\\nNormal: adalah Mode default. Dengan Efisiensi 20 yang artinya sekitar Efficiency II. \\n\\nSlow: kayak Paxel tanpa Efficiency, tapi bakal pake lebih sedikit &aEnergi&r! \\n\\nFast: pake &aEnergi&r jauh lebih banyak tapi jauh lebih cepet! Kayak Efficiency V. \\n\\nOff: gak bakal ngehancurin Blok, tapi tujuan utamanya cuma buat BUNUH!"]
	quest.16DDAE318535D0F9.title: "&bAtomic &cDisassembler"
	quest.16E02F671FBE9148.quest_desc: ["Pistol Portal adalah barang yang menggunakan tenaga untuk membuat dua portal untuk teleportasi antara dua titik. Klik Kiri menembak portal biru, Klik Kanan portal oranye, dan Shift Klik Kanan menghapus kedua portal."]
	quest.16E3031D800B40D5.quest_desc: ["Soulium Spawner pakai essence mob buat spawn mob. Contohnya kalau kamu masukin Ghast Essence kamu bisa spawn Ghast."]
	quest.16FA120455D36B58.quest_subtitle: "Orange + Mangrove"
	quest.16FF2219F110F50A.quest_desc: ["Undying bertindak seperti hal yang membuatnya, Recovery Totem! Saat heart-mu turun ke 0 daripada mati Module akan aktif, memberimu Absorption dan Regeneration, menyelamatkan nyawamu. Ada Cooldown dan perlu pakai OP untuk mengisi daya lagi. Coba jangan mati selama waktu itu! Upgrade yang lebih baik berarti cooldown lebih sedikit."]
	quest.16FF2219F110F50A.title: "Wyvern Undying Module"
	quest.170118E3C3C072E5.quest_desc: [
		"&6Junction&r adalah jenis &6Rel&r terakhir yang dibuat dengan Spike Maul. Ia berfungsi sebagai persimpangan normal untuk &6Jalur Rel&r. &7Cart&r akan tetap melaju di arah yang sama, namun sekarang &6Jalur&r bisa saling bersilangan. Apa yang terjadi jika 2 &7Cart&r bertabrakan di sana? MEREKA AKAN MELEDAK!!! Aku bercanda, tapi &eElectric Locomotive&r benar-benar bisa meledak sih."
		"{image:atm:textures/questpics/railcraft/rail_junction.png width:100 height:100 align:center}"
	]
	quest.170118E3C3C072E5.title: "&6Jalur Persimpangan (Junction)"
	quest.1705175C20CE91DD.quest_desc: ["Paduan Gerhana adalah material baru yang ditambahkan oleh JDT. Paduan Gerhana didapatkan dengan melakukan Penyebaran Lendir pada Balok Netherite menggunakan lendir tingkat empat. Bijih Paduan Gerhana dipengaruhi oleh keberuntungan."]
	quest.1705175C20CE91DD.title: "Paduan Gerhana"
	quest.170C31F3BAF050BC.quest_subtitle: "Dibuat di Reprocessor"
	quest.170C31F3BAF050BC.title: "Blutonium Bee"
	quest.1710B3D05215A71E.quest_desc: [
		"&bP2P&f (peer-to-peer) adalah sistem yang sangat kuat dalam AE2, memungkinkan transfer item, cairan, dan bahkan lebih banyak lagi tanpa perlu penyimpanan perantara ME. "
		""
		"Klik kanan pada P2P tunnel dengan item tertentu akan &emelaraskan&f (attune) tunnel tersebut agar mampu mentransfer sesuatu yang lain, seperti item melalui pipa, energi melalui kabel, sinyal redstone, dan bahkan koneksi ME itu sendiri. "
		""
		"P2P tunnel harus dihubungkan satu sama lain menggunakan &eMemory Card&f, yang dijelaskan di quest berikutnya."
	]
	quest.1710B3D05215A71E.quest_subtitle: "Tanpa Perantara"
	quest.1710B3D05215A71E.title: "P2P Tunnel"
	quest.1712C3B3CF158843.quest_desc: ["Untuk membuat &eMekanisme Presisi&r kita butuh 3 &6Penyebar&r, 3 &ePenampang&f/&eSabuk&r, 1 &ePelat Emas&r, 5 Roda Gigi, 5 Roda Gigi Besar, dan 5 &7Nugget Besi&r, serta sedikit keberuntungan! \\n\\nAmbil &ePelat Emas&r-mu (yang bisa dibuat dengan menekan Gold Ingot) dan letakkan di bawah setiap Penyebar secara berurutan. \\n\\nYang pertama membutuhkan Roda Gigi, yang kedua Roda Gigi Besar, dan yang ketiga Nugget Besi. \\n\\nSetelah melewati ketiga Penyebar, ulangi lagi! Dan lakukan sebanyak 5 kali berturut-turut. \\n\\nDi akhir, hanya ada kemungkinan 80% berhasil. Sisanya 20% dan semua kerja kerasmu akan LENYAP!"]
	quest.1712C3B3CF158843.title: "&eMekanisme Presisi"
	quest.1713E5D74658F095.quest_desc: [
		"&cSiren&r keliatan kayak Putri Duyung, setengah Wanita setengah Ikan. \\n\\nBagian atasnya yang Wanita ya. Dan mereka bakal ubah bentuk pas kesal. \\n\\nMereka spawn berkelompok di &cPulau Siren&r. Tenang, bahkan jadi setengah Ikan mereka tetep bisa gerak di Darat buat Bunuh kamu... cuma lebih lambat. \\n\\nMereka punya 150 &4Hearts&r dan gak ada Armor. Buat ngegantin kurangnya Armor mereka bakal &cHipnotis&r kamu dengan Lagu mereka kalo kamu gak pake Penutup Telinga. \\n\\nSelain &cHipnotis&r, mereka juga punya beberapa Serangan. Di &9Air&r mereka bakal nyerbu kamu dan Gigit kamu. Di darat mereka bakal tampar kamu pake Cakar mereka."
		"{image:atm:textures/questpics/iceandfire/iaf_siren.png width:250 height:100 align:center}"
	]
	quest.1713E5D74658F095.title: "&cSiren"
	quest.171DB70D0D19A942.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Otomatis melebur barang yang dijatuhkan dari balok yang ditambang."
	]
	quest.172D2A634E849562.quest_desc: ["Dengan kemampuan kita memanen &cIesnium&r, kita bisa memanggil para Setan untuk menuruti perintah kita di tambang... maksudku.... membantu kita mengumpulkan bijih. Jelas bukan mengeksploitasi Setan atau semacamnya.\\n\\nUntuk ini, kita perlu membuat &dDimensional Mineshaft&r untuk mengakses Dunia Tambang Setan. Kamu juga butuh Setan Penambang (Mining Demon) yang dikurung dalam lampu, yang diletakkan di dalam Mineshaft agar bisa bekerja. Walau tingkat mana pun bisa menyelesaikan quest ini, tingkat yang lebih tinggi bekerja lebih cepat dan punya peluang lebih besar menambang Iesnium untukmu.\\n\\nMineshaft tidak mengeluarkan hasil secara otomatis. Kamu perlu mengeluarkan item menggunakan Hopper, Setan Transportasi, atau metode lain seperti Pipa Item. Alat ini akan menghapus item apa pun yang melebihi kapasitas penyimpanannya."]
	quest.172D2A634E849562.title: "Penambangan Setan"
	quest.173541B0765DA13E.quest_desc: ["Menurutku ini yang paling gampang diotomatisasi. \\n\\nPhantom Membrane, Feather, dan Wool bisa pakai &b&lHNN&r. \\n\\nCuma &7Bat Wing&r yang agak susah karena harus di-farming lewat spawner!"]
	quest.173541B0765DA13E.title: "&fWhirlwind Prism"
	quest.17419401147B5C02.quest_desc: [
		"Selain memancing lebah dengan Nest, kebanyakan lebah butuh &eBreeding (Perkawinan)&r atau &9Conversion (Konversi)&r untuk dibuat."
		""
		"&eBreeding&r butuh 2 lebah dan item makanan spesifik untuk membuat mereka kawin."
		""
		"&9Conversion&r butuh kamu memberi makan lebah item spesifik untuk mengubahnya menjadi lebah baru."
	]
	quest.17419401147B5C02.quest_subtitle: "Tentang Lebah dan Lebah"
	quest.1744E700CF742CE2.quest_desc: ["&5The Coralssus&r bertugas sebagai penjaga sekaligus tunggangan bagi &5Sunken City&r. \\n\\nMereka bisa ditunggangi oleh &5Deepling&r agar bisa bergerak lebih cepat dan menyerang bersama! \\n\\nPunya 160 &4HP&r dan serangan dasar berupa pukulan serta lemparan. \\n\\nSaat dikalahkan, ia akan menjatuhkan Coral Chunk yang digunakan untuk membuat &5Abyssal Sacrifice&r."]
	quest.1744E700CF742CE2.title: "&5Coralssus&r"
	quest.1745124F83D033B9.title: "Komponen Dasar"
	quest.174D18D9D732EC10.quest_subtitle: "8 Blok Hijau Basah"
	quest.17542D7633FBF098.quest_desc: [""]
	quest.17542D7633FBF098.quest_subtitle: "&oSayang SpongeBob bukan Bintang."
	quest.17542D7633FBF098.title: "&d&lPatrick &aStar&r"
	quest.1756F81ACFC56C58.quest_subtitle: "Tingkat: &e5"
	quest.17598C171E610752.quest_desc: ["Gue bahkan gak tau harus ngomong apa buat ini. Gue kesasar liat resep-resepnya. Gue lebih milih nyebut semua Pohon Keluarga buat &l&2Productive Trees&r. \\n\\nDapetin &6Advanced Motor&r dan gabungin sama &dTitanium Rod&r dan &9Processing Unit&r buat bikin &6Large Advanced Motor&r. \\nAtau kamu bisa pake &6Mechanical Arm&r, tapi gue gak bisa janjiin itu lebih gampang di-Craft!"]
	quest.17598C171E610752.title: "&6Large Advanced Motor"
	quest.1759A4E2AF0D2C88.quest_desc: ["Pikirkan &eBlok Teknik Ringan&r, sekarang buat semua komponennya jauh lebih sulit dibuat! \\n\\n1. Kita perlu &eElektrum&r, yang merupakan Paduan &eEmas&r dan &7Perak&r yang dibuat di &6&lKiln Paduan&r. \\n\\n2. Kita perlu 4 &8Lembar Baja&r, yang seperti &7Lembar Besi&r, memerlukan 4 &8Pelat&r digabungkan. \\n\\n3. Adalah &8Komponen Mekanik Baja&r yang merupakan satu &6Batang Tembaga&r dan 4 &8Pelat Baja&r di Meja Crafting, atau dibuat lebih murah di &6Meja Kerja Insinyur&r."]
	quest.1759A4E2AF0D2C88.title: "&7Blok Teknik Berat"
	quest.175D943160C10646.quest_desc: [
		"&l&7RailCraft&r menggunakan banyak mesin untuk berbagai hal, terutama pembuatan sumber daya."
		""
		"Semuanya dimulai dari Ingot Besi!"
	]
	quest.175D943160C10646.title: "&l&7Mesin-Mesin"
	quest.176A1CC43467EF23.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Bantuan Tangga"
		"- Dorongan Lompat"
		"- Injakan Tanah"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.176ACC61DC206E55.quest_subtitle: "Berikan Shroombee sebuah Crimson Fungus"
	quest.176ACC61DC206E55.title: "Crimson Shroombee"
	quest.176D31AF1B0925AA.quest_desc: [
		"&c&lPemalsuan Naga Api&r adalah Multiblock 3x3x3 dari &cBagian Naga&r! \\n\\nLayer pertama mulai dengan Salib dari &cBata Pemalsuan Naga Api&r. Terus, isi pojoknya dengan &7Blok Tulang Naga&r. "
		"{image:atm:textures/questpics/iceandfire/chap3_fire1.png width:100 height:100 align:center}"
		"Layer kedua bakal ada &cInti Pemalsuan Naga Api&r di tengah dengan &cAperature Pemalsuan Naga&r di sampingnya di tengah dinding. Dan isi sisa layer-nya dengan &cBata Pemalsuan Naga Api&r. "
		"{image:atm:textures/questpics/iceandfire/chap3_fire2.png width:100 height:100 align:center}"
		"Layer terakhir ulang layer pertama!"
		"{image:atm:textures/questpics/iceandfire/chap3_fire4.png width:100 height:100 align:center}"
		"{@pagebreak}"
		"&c&lPemalsuan Naga Api&r adalah Multiblock. Tunggu, bukannya kita harusnya Berantem dan main sama Monster? \\n\\nPas udah Dibangun kita bisa taro Item kita di &c&lPemalsuan Naga Api&r. Entah &7Besi &fdan &cDarah Naga Api&r atau Material Alloy. \\n\\nTerus, kita bakal butuh &cPanas&r! Lebih baik dari &c&lNaga Api&r! \\n\\nKita bisa pake &c&lNaga Api yang Jinak&r yang deket buat &cPanasin&r, atau Rantai &c&lNaga Api Liar&r deket &c&lPemalsuan Naga&r. \\n\\nLiar atau Jinak, &cNapas Api&r bakal Sakit kalo kamu jalan lewat situ."
	]
	quest.176D31AF1B0925AA.title: "&c&lPemalsuan Naga Api"
	quest.177199FED92C3B5B.quest_subtitle: "Berikan sebuah Infused Diamond ke Diamond Bee"
	quest.177199FED92C3B5B.title: "Dimensional Bee"
	quest.177396B9C4F9B3E2.quest_desc: ["Kenapa harus menunggu? Oh, kamu punya alasan valid? Seperti item yang mungkin menghilang (despawn). Hehe, aku tidak terpikir soal itu. \\n\\nDengan Pickup Delay Augment, Vacuum Module akan menunggu selama 10 tick untuk setiap augment yang terpasang sebelum mengambil item!"]
	quest.17920C436DDBBD07.title: "&2Komponen Penyimpanan Cairan 262kB"
	quest.1796E08BBDC09B84.quest_desc: ["&b&lDynamic &cTank&r itu Multiblock yang bisa dibuat ukuran berapa pun minimal 3x3x3! \\n\\n&b&lDynamic &cTank&r bakal nampung banyak banget satu jenis &bCairan &fatau &cChemical&r. Berapa banyak Bucket yang bisa ditampung? Tergantung ukurannya. \\n\\n&b&lDynamic &cTank&r dibuat pakai &bDynamic &cTank &fBlock&r dengan bagian dalam struktur yang kosong. Temboknya bisa dibuat pakai Structure atau Reactor Glass tapi rangkanya harus pakai blok &bDynamic &cTank&r. \\n\\nKamu juga butuh &bDynamic &cTank&r Port di temboknya buat masukin dan keluarin cairan atau kimia. Apakah dia masuk atau keluar ditentukan dari dia dorong (Push) atau tarik (Pull)."]
	quest.1796E08BBDC09B84.title: "&b&lDynamic &cTank&r Multiblock"
	quest.17989643018D00C1.quest_desc: ["Apakah sarang lebah yang menetes-netes mengganggumu? Jika ya, solusinya mudah.\\n\\nKamu bisa menaruh sebuah &eSponge&r (Spons) di slot botol pada Advanced Hive untuk menghentikan tetesannya."]
	quest.17989643018D00C1.quest_subtitle: "Biar sarangmu nggak 'becek'"
	quest.17989643018D00C1.title: "Menghentikan Tetesan"
	quest.17A322C3B309A4D4.quest_subtitle: "Sepertinya Gold Bee suka piringan hitam (Music Disc)"
	quest.17A322C3B309A4D4.title: "Regalium Bee"
	quest.17A68C4E9E9EA2B7.quest_desc: ["&eGolden Armor&r berada tepat di antara Besi dan &7Kulit (Leather)&r. Tapi durabilitasnya jauh lebih dekat ke &7Kulit&r. \\n\\nNggak banyak gunanya selain membuat Piglin bersikap Netral padamu saat kamu memakainya."]
	quest.17A68C4E9E9EA2B7.quest_subtitle: "11"
	quest.17A68C4E9E9EA2B7.title: "&eGolden Armor"
	quest.17A9D2CA160561D9.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memberikan bantuan tangga kepada pemain."
	]
	quest.17B18040EFA37F86.quest_subtitle: "Berikan sebuah Polonium Pellet ke Radioactive Bee"
	quest.17B18040EFA37F86.title: "Wasted Radioactive Bee"
	quest.17C2C8F64B4AE6EE.quest_desc: [
		"&2Dweller&r adalah 'Sapi' di dimensi &2&lUndergarden&r. \\nMereka bersifat Pasif dan menjatuhkan Leather serta Dweller Meat saat mati. \\n\\nSyukurlah mereka tidak bisa diperah, aku tidak mau meminum susu yang dihasilkan para &2Dweller&r ini."
		"{image:atm:textures/questpics/undergarden/undergarden_dweller.png width:100 height:100 align:center}"
	]
	quest.17C2C8F64B4AE6EE.title: "&2Dweller&r"
	quest.17C4F6EC1AFBC3AA.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		"Menyorot monster di sekitar dengan partikel saat diaktifkan."
	]
	quest.17CA9D80D8EC3EF7.quest_desc: [
		"&4&lThe Harbinger&r mengambil banyak inspirasi dari apa yang memberinya tenaga, yaitu Nether Star. \\n\\nIa memiliki 15.600 &4HP&r dan akan menyerang setiap mob serta pemain yang tidak berasal dari &4Ancient Factory&r. \\n\\nIa akan terbang berkeliling dan bahkan menyerudukmu. Seperti &0The Wither&r, &l&4The Harbinger&r akan menghancurkan hampir setiap blok di jalurnya. \\n\\nUntuk menyerang, ia bisa menembakkan &4Wither Missile&r yang memberikan efek &0Wither&r atau menembakkan &4Wither Howitzer&r dari punggungnya ke segala arah. \\n\\nIa juga punya &4Laser&r, &4Laser Gatling&r, dan &4sinar mulut besar&r. \\n\\nIa punya kelemahan besar, seperti mesin hidup lainnya, ia lemah terhadap &4EMP&r! Jika kamu menggunakannya padanya, ia akan terdiam (stun), tidak bisa bergerak atau menyerang selama beberapa detik."
		"{image:atm:textures/questpics/cataclysm/cataclysm_harbinger.png width:100 height:100 align:center}"
	]
	quest.17CA9D80D8EC3EF7.title: "&4&lThe Harbinger&r"
	quest.17D7D34F519F7E5F.quest_desc: ["Untuk membuat tingkat terakhir dari Spellbook, kamu harus sudah membunuh &6Wilden Chimera&r. \\n\\nIni adalah sebuah Ritual yang harus kamu selesaikan menggunakan &9Ritual Brazier&r."]
	quest.17D82EEA20D02EC8.quest_desc: ["Di dasar Laut ada Dusted Gravel. \\n\\nBisa dipake sebagai pengganti Gravel biasa dan jarang bisa drop Dusted Shard yang bisa bikin Blok lain!"]
	quest.17DC77F7F8C68AE6.quest_desc: ["Trash Can berfungsi sebagai tempat untuk memusnahkan item, cairan, atau energi yang tidak diinginkan."]
	quest.17DC77F7F8C68AE6.quest_subtitle: "Membuang Sampah Berlebih"
	quest.17DC77F7F8C68AE6.title: "Tempat Sampah"
	quest.17E2C05C48B03043.quest_desc: ["Sodium bisa dipake sebagai &bCoolant&r selain &9Air&r. Sodium lebih Efisien, dapet &6Temperature&r lebih tinggi, tapi lebih susah dapetin sama dipake ulang. \\n\\nSekarang gimana cara dapetinnya? \\n\\nKita butuh &6&lThermal Evaporation Plant&r. Gue udah bikin kayak 3 Quest yang jelasin cara Bikin sama pakenya, ini gak bakal jadi yang ke-4. \\n\\nKita bakal pake &6&lThermal Evaporation Plant&r buat ambil &9Air&r kita dan bikin &eBrine&r. \\n\\nTerus, kita bisa pake &9&lElectrolytic Separator&r buat hancurin &eBrine&r buat dapetin Sodium! \\n\\nDan &cChemical&r lain tapi kita gak peduli!"]
	quest.17E2C05C48B03043.title: "Sodium &bCoolant"
	quest.17EC65B33AC5F0B4.quest_desc: [
		"Thirst Walker adalah Mob netral yang spawn di permukaan Crystallized Desert. \\n\\nKalau di-aggro mereka bakal mukul kamu dan kasih kamu Hunger. \\n\\nMereka punya 20 Heart dan bisa drop Tooth of Hunger kalau mati."
		"{image:atm:textures/questpics/eternal/starlight_thirst.png width:100 height:125 align:center}"
	]
	quest.17EC65B33AC5F0B4.title: "Thirst Walker"
	quest.17F3AC15ADCFB175.title: "&l&9The End Bounty:&r&e Endermen"
	quest.17F7964611D893BE.quest_desc: ["Fluid Loader akan berguna untuk menjaga &3Steam Locomotive&r tetap berjalan. Alat ini harus diletakkan beberapa blok di atas &6Rel&r dan akan mengisi cairan ke dalam &5Lokomotif&r atau &7Cart&r."]
	quest.17F7964611D893BE.title: "Fluid Loader"
	quest.17FE0C7748DD65CA.quest_desc: ["&5Tier 4&r setara dengan peralatan Diamond, digunakan untuk mendapatkan Obsidian dan Netherite. Juga bisa digunakan untuk beberapa bijih modded seperti Uranium dan Platinum."]
	quest.17FE0C7748DD65CA.title: "&5Harvest Tier 4"
	quest.18032636A60D0B2C.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Versi tingkat lanjut dari Pemindai Bijih yang menampilkan bijih terdekat saat diaktifkan."
	]
	quest.1815661333016983.quest_subtitle: "Date Palm + Black Cherry"
	quest.1815A439BA9879B7.quest_desc: [
		"Warm Shore adalah Biome yang cukup membosankan dan kebanyakan buat nyambungin Starlit Sea dan daratan. \\n\\nPunya Twilight Sand dengan Stone di bawahnya. Aku juga nemuin, lebih dari biasanya, Saltpeter di sini."
		"{image:atm:textures/questpics/eternal/starlight_shore.png width:200 height:100 align:center}"
	]
	quest.1815A439BA9879B7.title: "Warm Shore"
	quest.1823CC81D613892B.quest_desc: [
		"Passive Mob -> Pink Slime Lebih Banyak"
		"Hostile Mob -> Meat Lebih Banyak"
	]
	quest.18246A48C20B29D8.quest_desc: ["Infusion Pylon bekerja mirip dengan Beacon, tapi jauh lebih baik dan murah! \\nSaat efek ramuan dimasukkan melalui Potion Filter, ia akan terus-menerus memberimu efek tersebut di mana pun kamu berada! \\n\\nKamu tidak salah dengar, tidak ada lagi batasan radius untuk Infusion Pylon; efeknya akan menjangkaumu di mana saja."]
	quest.1827DEEA2DF1B144.quest_desc: ["Selamat datang di chapter Food and Farming!\\n\\nDi sini, kamu akan nemuin cara berbeda untuk tanam dan bikin makanan!"]
	quest.1827DEEA2DF1B144.title: "Food and Farming"
	quest.1830412AB77E9526.quest_desc: ["Dengan sesuatu yang primitif seperti Bow kamu tidak bisa mengharapkan Accuracy sempurna. Ya kamu bisa kalau pakai Module ini. Arrow jauh lebih mungkin mengenai targetnya dan tidak melenceng."]
	quest.1830412AB77E9526.title: "Wyvern Projectile Accuracy Module"
	quest.1834B5C1F8435D7A.quest_desc: [
		"Mechanical Pipe adalah cara mod &5&lMeka&r mengalirkan Cairan.\\n\\nBeberapa mesin di &5&lMeka&r membutuhkan Cairan seperti Electrolytic Separator yang butuh Air atau Evaporation Plant untuk membuat Lithium."
		"{image:atm:textures/questpics/logistics/meka_pipe.png width:200 height:50 align:center}"
	]
	quest.1834B5C1F8435D7A.quest_subtitle: "Cairan"
	quest.183F6A790EC006B8.quest_desc: ["&bBlooming Stems&r bukan seperti Pohon, lebih seperti kalau Chorus dan Bamboo punya anak. \\n\\nMereka tumbuh di &bBlooming Caverns&r dan butuh &bBlooming Stems&r lain untuk tetap berdiri! Ini satu-satunya cara untuk menemukannya. \\n\\nKamu masih bisa Strip atau membuat Planks darinya. Planks-nya punya warna &bBiru Muda&r, dan begitu juga apapun yang kamu buat darinya!"]
	quest.183F6A790EC006B8.title: "&bBlooming Wood"
	quest.1843C79133DFB024.quest_desc: ["Generator paling kuat dan efisien, Netherstar Generator. Coba tebak pakai apa buat bikin Energi!"]
	quest.1848F431D0380DA9.quest_desc: [
		"Mirip dengan fungsi perbaikan kapur pada &aStrigeor's Higher Binding&r, &cSevira's Permanent Confinement&r dapat digunakan untuk memperbaiki item menggunakan kekuatan setan Afrit."
		""
		"Ritual ini bisa memperbaiki hampir apa saja, jadi &eSetan Penambang&r, peralatan, dan armor semuanya bisa dipulihkan ke durabilitas aslinya! "
		""
		"Semua item yang diperbaiki menggunakan ritual ini tetap mempertahankan properti aslinya (afiks, mantra, dll), jadi jangan khawatir soal mantra berhargamu!"
	]
	quest.1848F431D0380DA9.quest_subtitle: "Durabilitas gratis (hampir)!"
	quest.1848F431D0380DA9.title: "Memperbaiki Item"
	quest.18499D33BA12A8A9.quest_desc: ["Pernah mikir Formation Plane yang kerja kayak Storage Bus terlalu ribet buat automasi? Coba Active Formation Plane. Kerja kayak ME Export Bus tapi treat dunia sebagai mediumnya. Gak perlu subnet buat ini."]
	quest.18499D33BA12A8A9.quest_subtitle: "KELUAR: Edisi Aktif"
	quest.18499D33BA12A8A9.title: "Taruh Aktif dari Network: Active Formation Plane"
	quest.184F98BE0F6710E2.quest_desc: ["Kedua &cTrack Kit&r ini digunakan untuk interaksi antara &7Cart&r dan Redstone.\\n\\n&cActivator Kit&r akan mengaktifkan &7Cart&r apa pun yang melintas di atasnya. \\n&cDetector Kit&r akan memancarkan sinyal redstone setiap kali ada &7Cart&r yang lewat. \\n\\nKeduanya mirip dengan versi &2Vanilla&r untuk &6rel&r biasa."]
	quest.184F98BE0F6710E2.title: "&cTrack Kit&r untuk Redstone"
	quest.185074907753AE77.quest_desc: ["Jika kamu menggunakan Router, aku harap kamu sudah paham mekanisme game ini. \\n\\nSekadar jaga-jaga, 'void' item berarti menghapusnya. \\n\\nItem apa pun yang masuk ke Router ini akan dihapus selamanya! \\n\\nSangat disarankan memakai Filter dengan module ini..."]
	quest.185DBBDD252CBA0C.quest_desc: [
		"&6&lForge&r adalah Blok paling penting di &6&lForbidden \\& Arcanus&r! Sekarang kamu sudah bikin Multiblock kamu bisa pecahkan blok &6&lForge&r dan pindahkan, meskipun cuma kerja saat di Multiblock. \\n\\nKamu perlu isi dengan semua 4 Essence: &bAureal&r, Soul, &4Blood&r, dan &aExperience&r! \\n\\nLalu, masukkan Relic kalau perlu. \\n\\nSetelah itu, taruh Item tengah di Resep, di Slot tengah &6&lForge&r, dan Item luar di &6Pedestal&r."
		"{image:atm:textures/questpics/forbidden/forbidden_gui.png width:135 height:100 align:center}"
		"{image:atm:textures/questpics/forbidden/forbidden_tier3.png width:100 height:100 align:center}"
	]
	quest.185DBBDD252CBA0C.title: "&l&cTier 1 &6Forge"
	quest.18601369F049D10D.quest_subtitle: "Ceylon Ebony + Purple Crepe Myrtle"
	quest.186593EBCE3FE8D8.quest_desc: ["Spawn Range adalah luas area di mana mob bisa muncul. Semakin besar areanya, semakin banyak ruang bagi mereka untuk muncul. Semakin kecil areanya, semakin hemat tempat untuk pabrik mob kamu."]
	quest.186593EBCE3FE8D8.title: "Spawn Range"
	quest.186731580B14F9D2.quest_desc: ["Untuk berinteraksi dengan Turbine, kita butuh beberapa &6Port&r.\\n\\n&9Fluid Port&r dipakai buat masukin vapor kayak &bSteam&r, atau ngeluarin exhaust, kayak &9air&r. Karena itu, kamu butuh dua buat Turbine.\\n\\n&cPower Tap&r ngeluarin power, dan diperlukan buat ngelengkapin multiblock."]
	quest.186731580B14F9D2.title: "Turbine Port"
	quest.1873205CF5247E3E.quest_desc: [
		"Rak buku terakhir dan yang paling hebat, &dEndshelves&r! \\n\\nIni dibuat dengan 6 &eEndstone Brick&r, 1 &3Ender Pearl&r, 1 &7Bookshelf&r, dan tentu saja &dInfused Dragon's Breath&r. \\n\\nStatistiknya saat ini mungkin bukan yang terbaik (hanya memberikan 5 poin untuk masing-masing), tapi batas maksimal &aEterna&r-nya yang mencapai &a90&r sungguh luar biasa! \\n\\nOh ya, rak ini juga bisa di-craft dengan item lain untuk di-upgrade!"
		"{image:atm:textures/questpics/apothic/enchant_endshelf.png width:100 height:100 align:center}"
	]
	quest.1873205CF5247E3E.title: "&dEndshelves"
	quest.187816477B732517.quest_desc: ["&3Transfer Gadget&r berfungsi seperti Hopper yang bisa diletakkan di celah antar blok."]
	quest.187816477B732517.quest_subtitle: "Hopper Lebih Kecil"
	quest.18783C62009934DB.quest_desc: ["&9&lElectrolytic Separator&r bakal ambil 1 &bCairan&r terus dipisah jadi 2 &cChemical&r! \\n\\n&bCairan&r masuk di &4Bar Merah&r dan &cChemical&r-nya bakal muncul di &9Bar Biru &fdan &3Bar Cyan&r. \\n\\nKita juga dapat dua tombol di tiap sisi bawah GUI. Tombol ini buat ganti fungsi dari dua Bar Output tadi. \\n\\nIdle: cuma bakal sampai batas maksimalnya terus berhenti. Jadi kalau Hydrogen sudah penuh, dia nggak bakal pakai &9Air&r lagi. \\n\\nDumping Excess: bakal penuh sampai atas tapi bakal buang sisanya biar tetep bisa produksi tiap &cChemical&r. Ini berguna buat yang butuh banyak &bOxygen&r tapi nggak butuh Hydrogen. \\n\\nDumping: bakal hapus semua &cChemical&r yang dibuat itu."]
	quest.18783C62009934DB.title: "&9&lElectrolytic Separator"
	quest.189018F641FBB44E.quest_desc: ["&4Mega Autocrafter&r memiliki 54 slot Pattern, bekerja 8x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.189018F641FBB44E.title: "&4Mega Autocrafter"
	quest.18914FDF9CF9EEA8.quest_desc: ["&aBantalan Jam&r bergerak berdasarkan Waktu dalam Hari ketika diberi &dTenaga Rotasi&r. \\n\\nBlok di depan &aBantalan Jam&r akan otomatis &aditempel&r padanya, tapi Blok lain bisa di-&aGlue&r ke Blok tersebut agar ikut! \\n\\nKalau kamu ingin lebih dari satu Jarum, tambahkan lebih banyak Blok di depan Blok pertama, tapi pastikan Blok-blok ini tidak saling &aditempel&r satu sama lain. \\n\\nKamu bisa mengubah Jarum mana yang mana dengan menahan &aBantalan&r untuk mengatur apakah Jarum pertama (Blok terdekat) adalah Jarum Jam atau Menit. "]
	quest.18914FDF9CF9EEA8.title: "&aBantalan Jam"
	quest.18A2F6BA778D96B1.quest_desc: ["Bisa ditemukan di dalam peti di Bastion."]
	quest.18A2F6BA778D96B1.quest_subtitle: "Peti Bastion"
	quest.18A2FBE2D4133FA2.quest_desc: ["Arcane Pedestal dibutuhkan untuk Ritual Brazier dan membuat item menggunakan Enchanting Apparatus. \\n\\nBuatlah setidaknya 8 buah!"]
	quest.18A2FBE2D4133FA2.quest_subtitle: "Meja Mewah"
	quest.18A2FBE2D4133FA2.title: "Arcane Pedestal"
	quest.18A9392BBCF5A871.quest_desc: ["Seperti setiap Mod Mesin, &8&lImmersive Engineering&r memerlukan cara memindahkan &eBarang&r, &bCairan&r, dan lainnya! \\n\\nSebagian besar Mesin akan memiliki &6Output&r dan &9Input&r yang ditetapkan secara default tetapi ini bisa dikonfigurasi, seperti dengan &6Obeng Insinyur&r! Kamu mungkin juga perlu menggunakan &6Palu Insinyur&r tapi itu berbeda."]
	quest.18A9392BBCF5A871.title: "Logistik &8&lImmersive Engineering&r"
	quest.18C0EF38430C3E67.quest_subtitle: "Zaman Digital"
	quest.18D4BE3AF7869DE2.quest_subtitle: "Ceylon Ebony + Persimmon"
	quest.18DB8C875F2331B2.quest_desc: ["Apakah Roket terasa terlalu mahal? Kamu bisa menggunakan &7Elytra Booster&r sebagai penggantinya. Pakailah Elytra dan &7Elytra Booster&r secara bersamaan, lalu isi bahan bakar Booster tersebut. Alat ini menerima bahan bakar tungku apa pun: Batu Bara, Lava, Batang Kayu, bahkan Blok Kelp Kering. Saat terbang dengan Elytra, tekan Alt Kiri untuk berakselerasi! Sekarang kamu terbang dengan bahan bakar ramah lingkungan yang jauh lebih murah!"]
	quest.18DB8C875F2331B2.quest_subtitle: "Ditemukan di End City dan End Ship"
	quest.18DFB25DC48D8BF7.quest_desc: [
		"Spatial Containment Structure (SCS) terdiri dari sangkar &bSpatial Pylon&f yang menutupi volume yang ingin kamu masukkan ke dalam Spatial IO cell. Minimal, sebuah SCS membutuhkan tiga baris blok pylon, satu untuk setiap dimensi ruang (panjang, lebar, tinggi). "
		""
		"Namun, Spatial IO sangat boros energi, terutama saat menangkap ruang yang besar (hingga 128x128x128). Memiliki lebih banyak pylon di sekitar volume yang diinginkan akan meningkatkan &eefisiensi&f secara keseluruhan, sehingga menggunakan lebih sedikit energi untuk menangkap. "
		""
		"Juga, ingatlah bahwa setiap pylon (terlepas dari panjangnya) memakan satu channel. Untuk ruang yang sangat besar, kamu mungkin ingin membangun jaringan khusus dengan controller sendiri."
	]
	quest.18DFB25DC48D8BF7.title: "Spatial Pylon"
	quest.18E0F5A78F696FA3.quest_desc: ["Echo Shard memberikan efek spesial pada spawner. Setiap mob yang muncul akan memiliki jumlah loot yang berlipat ganda saat dijatuhkan."]
	quest.18E0F5A78F696FA3.title: "Echoing"
	quest.18EADBAFC932F864.quest_desc: ["Untuk gunting Domba kamu butuh Shears, gak akan dapet Wool dengan cara lain...kan?"]
	quest.18EADBAFC932F864.quest_subtitle: "Pacifist Run"
	quest.18EADBAFC932F864.title: "Saatnya Gunting"
	quest.18EB2170CAC48E99.quest_desc: ["&5Teleportation &7Unit&r adalah &7Unit&r yang cukup unik. \\n\\nPake &dMeka-Tool&r dengan &5Teleportation&r yang ditambah kita bisa liat Blok terus Klik Kanan buat Teleport ke sana. \\n\\nPake &aEnergi&r dan punya jangkauan terbatas, tapi tenang jangkauannya masih lumayan jauh! \\n\\n&7Unit&r ini gak bisa kerja sama &2Farming &7Unit&r atau &7Shearing Unit&r."]
	quest.18EB2170CAC48E99.quest_subtitle: "Meka-Tool"
	quest.18EB2170CAC48E99.title: "&5Teleportation &7Unit"
	quest.18EB86F91CBBCCC6.quest_desc: ["Tidak semua dungeon Cataclysm mudah ditemukan seperti &eCursed Pyramid&r. \\n\\nJadi, sebuah 'Eye' (Mata) khusus mungkin bisa membantumu! \\n\\nSetiap jenis Mata akan menuntunmu ke strukturnya masing-masing; dan tenang saja, Mata ini sangat jarang rusak."]
	quest.18EB86F91CBBCCC6.title: "Mata yang Melihat"
	quest.18F948FF9FE015FB.quest_subtitle: "Berikan sebuah TNT ke lebah Vanilla"
	quest.18F948FF9FE015FB.title: "CreeBee"
	quest.18FAD56CDE05646A.quest_desc: ["Dulu, Quarry di &7&lMining Dimension&r used to mine everything but leave &6Allthemodium Ore&r. \\n\\nSekarang, Quarry akan menambang &6Allthemodium&r tapi menghapus (void) drop-nya... jadi berhati-hatilah dengan Quarry milikmu! \\n\\nAku merekomendasikan menambang manual dengan Ore Sight Potion jika kamu benar-benar mencari &6Allthemodium&r!"]
	quest.191A7F3C9FBA4C13.quest_desc: ["Kita bisa men-craft &bInfused Seashelf&r dengan &bPrismarine Crystal&r untuk mendapatkan &bCrystalline Seashelf&r. \\n\\n&bCrystalline Seashelf&r tetap memiliki &a5 Eterna&r dan &55% Arcana&r yang sama, tapi sekarang memiliki &c3% Quanta&r. \\n\\nDengan 12 buah rak ini, kita bisa mendapatkan level yang cukup untuk melakukan &d&lInfuse&r &9Dormant Deepshelf&r menjadi &9Deepshelf&r biasa!"]
	quest.191A7F3C9FBA4C13.title: "&bCrystalline Seashelf"
	quest.1922623A26E08078.quest_desc: ["Kayak &bFluid Tank&r tapi lupakan &bCairan&r, kita mau yang lainnya! \\n\\nSemua yang bisa dipindahin sama &cPressurized Tube&r bisa ditampung di &cChemical Tank&r. \\n\\n&a&lBasic&r: nampung 64 Bucket Chemical. \\n\\n&c&lAdvanced&r: nampung 256 Bucket Chemical. \\n\\n&b&lElite&r: nampung 1,024 Bucket Chemical. \\n\\n&d&lUltimate&r: nampung 8,192 Bucket."]
	quest.1922623A26E08078.title: "&cChemical Tanks"
	quest.19341B01E048ACAB.quest_desc: ["&a&lBasic Tier&r itu yang paling simpel, murah, dan &lTier&r paling rendah dari &5Mesin&r dan blok! \\n\\nKecuali kalau kamu anggap mesin tanpa upgrade itu Tier sendiri, tapi aku sih nggak. Aku masukin itu ke &a&lBasic&r aja. \\n\\n&5Mesin&r bakal mulai dari kondisi standar dan bisa di-upgrade ke &a&lBasic&r. Sedangkan blok lain kayak &bPipes&f atau &aEnergy Cube&r bakal mulai langsung dari &a&lBasic&r. \\n\\nSemua ini dibuat pakai &4Redstone&f, &aBasic Control Circuit&f, dan kadang &7Besi&r!"]
	quest.19341B01E048ACAB.title: "&a&lBasic Tier"
	quest.19542103E042BDB5.quest_desc: ["{image:atm:textures/questpics/iron_spells/spells_outfit_shadow.png width:60 height:100 align:center}"]
	quest.19542103E042BDB5.title: "&dShadow-Walker Outfit"
	quest.195729280394ABFB.quest_desc: ["&7&lMesin&r ini bikin dua ingot yang kuat banget: &eRefined Glowstone&f dan &5Refined Obsidian&r.\\n\\nDia bakal &7Infuse&r satu &eItem&r pakai &7Osmium&r buat bikin Ingot yang lebih kuat. \\n\\nKita perlu taruh &7Osmium Ingot&f, &7Osmium Block&f, atau &cChemical Tank&f isi &7Osmium Chemical&r buat kasih makan si &l&7Compressor&r ini!"]
	quest.195729280394ABFB.quest_subtitle: "Sebenernya cuma bagus buat 2 hal"
	quest.195729280394ABFB.title: "&7&lOsmium Compressor"
	quest.196003E1486ABB31.quest_desc: ["Untuk upgrade dari &cNetherite&r ke &9Warden Gear&r, kamu butuh &9Smithing Template&r! \\n\\nIni ditemukan di Chest di &6Ancient Cities&r. \\n\\nMereka bisa diduplikasi dengan 7 Diamond dan &3Sculk Block&r!"]
	quest.196003E1486ABB31.title: "&9Warden Upgrade Template"
	quest.196312DF0D2E2CB6.quest_desc: ["&4Invader&r adalah apa yang kita kenal sebagai &4Boss&r &6&lApotheosis&r. \\n\\nMereka adalah Mob yang bisa spawn di dimensi mana pun; mereka selalu diperkuat (buff) dan memakai &eAffixed Item&r. \\n\\nKebanyakan memiliki HP, Damage, dan efek yang lebih banyak dari mob normal! Saat dibunuh, mereka akan menjatuhkan &eAffixed Item&f dan &aGem&r. \\n\\nMereka punya sistem Rarity sendiri yang selaras dengan Rarity &6&lApotheosis&r. Rarity mereka menentukan equipment dan statistik saat mereka spawn. \\n\\nRarity tersebut ditentukan oleh &lWorld Tier&r! &lWorld Tier&r adalah fitur baru di &6&lApotheosis&r yang akan mengubah Rarity dari Loot dan &4Boss&r yang bisa kamu temukan. \\n\\nUntuk mengakses Menu &lWorld Tier&r, tahan CTRL dan tekan T."]
	quest.196312DF0D2E2CB6.title: "&4Invader/Boss&r dan &lWorld Tier"
	quest.196E55B64667AE35.quest_desc: [
		"Kamu bisa meletakkan Bunga Lebah (Bee Flowers) di atas Feeding Slab yang ditaruh di depan sarang, seperti pada gambar di bawah.\\n"
		"{image:atm:textures/questpics/bees/feeder.png width:175 height:100 align:center fit:true}"
	]
	quest.196E55B64667AE35.quest_subtitle: "Memasang Slab untuk Makan"
	quest.1972B36F72808D55.quest_desc: ["Cuma beberapa dari batu ini yang dipahat (chipped)."]
	quest.1972B36F72808D55.title: "Batu &l&bChipped&r"
	quest.1985CFD1F0425E88.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.1985CFD1F0425E88.title: "&eAdvanced Pickup Upgrade"
	quest.198E9E90CC9606C4.quest_desc: ["Kita sudah dapat Item di Pedestal, kita sudah dapat &bAureal&r, Soul, &4Blood&r, dan &aExperience&r... dan gak selesai? Kenapa gak selesai? \\n\\nUntuk benar-benar finalisasi Ritual kita perlu pakai Gavel! \\n\\nIni kerja seperti Pickaxe tapi juga punya jumlah uses terbatas untuk selesaiin Ritual, cukup Klik Kanan &6&lForge&r dengannya!"]
	quest.198E9E90CC9606C4.title: "Selesaikan Ritual"
	quest.198EDBAC1D6E2339.quest_desc: ["Kamu butuh ini untuk Ender Bee."]
	quest.198EDBAC1D6E2339.quest_subtitle: "Mencegah lebah menteleportasi diri ke dalam sarang"
	quest.198EDBAC1D6E2339.title: "Anti-Teleportation Upgrade"
	quest.199388A311FAC14C.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penambang Bijih"
		"- Pemindai Bijih &4&lDINONAKTIFKAN&r&f"
		"- Pelebur Otomatis"
		"- Palu"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.199932BF623A6785.quest_desc: ["Forgotten Guardian adalah Bos dari Undergarden. \\n\\nIa bersemayam di dalam struktur Catacomb."]
	quest.199932BF623A6785.title: "Kalahkan Forgotten Guardian"
	quest.199E7C89584C3DB1.quest_subtitle: "Menghilangkan Efek Potion Buruk"
	quest.19A2016B54C6FA34.quest_desc: ["Beberapa mesin di &l&6Theurgy&r butuh panas (Heat) untuk mulai bekerja! Bedanya, &l&6Theurgy&r sangat pemilih soal sumber panasnya; kamu hanya bisa menggunakan dua jenis mesin ini sebagai sumber panas. \\n\\n(Mesin yang membutuhkan panas adalah: Liquefaction Cauldron, Calcination Oven, &cMercury&r Distiller, dan Incubator.)"]
	quest.19A2016B54C6FA34.quest_subtitle: "Panas Banget, Cuy!"
	quest.19A2016B54C6FA34.title: "Panas Banget, Cuy!"
	quest.19AAC139177442C1.quest_subtitle: "Tingkat: &63"
	quest.19B057DFF331E41C.quest_desc: ["&4Scarecrow Outfit&r sedikit lebih baik dari &9Wandering Magician&r, dengan 3 kali lipat Mana dan lebih banyak Armor Points. \\n\\nYang ini butuh lebih banyak Item untuk di-Craft. \\n\\nSekarang butuh &5Arcane Cloth&r bukan &5Essence&r, serta &eHay Bale&r dan &6Pumpkin&r."]
	quest.19B057DFF331E41C.title: "&4Scarecrow Outfit"
	quest.19B393433FB0C62F.quest_desc: ["Rahasia Strider bisa jalan di atas &cLava&r ada di kaki mereka. Jadi kami ambil kaki mereka dan biarkan kamu yang pakai! \\n\\nSaat berjongkok (Sneaking), kamu bisa berjalan aman di atas &cLava&r! Tapi kalau kamu berhenti berjongkok, kamu bakal tenggelam. Sepatu ini juga bikin kamu aman jalan di atas Magma Block dan blok panas lainnya!"]
	quest.19B393433FB0C62F.quest_subtitle: "Kaki"
	quest.19B393433FB0C62F.title: "&4Strider Shoes&r"
	quest.19C22C5B247F4D7D.quest_subtitle: "Ceylon Ebony + Kapok"
	quest.19D02325579F2AA8.quest_desc: ["Volcanic Sourcelink menghasilkan Source dengan membakar item yang mudah terbakar. Batang kayu Archwood akan menghasilkan bonus Source. \\n\\nSaat membakar item, alat ini akan mengubah batu di sekitarnya menjadi lava. \\n\\nProses ini juga menghasilkan Lava Lily."]
	quest.19DE6EBEA8219E8E.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Kontributor Komunitas&r untuk dipakai di AllTheMods Modpack. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan, kalau kamu lihat ini, kamu lagi di mode editing."]
	quest.19DFAEB6D88F3580.quest_desc: ["Pusher Upgrade memungkinkan Drawer untuk mendorong item keluar ke sisi mana pun."]
	quest.19E356E67EF17E4A.quest_desc: ["Peralatan paling hebat dalam sejarah! Seperti pisau lipat (Swiss army knife) tapi jauh lebih baik! \\n\\nTingkat penambangan (Mining Tier) tertinggi, menebang pohon seperti mentega, membuat jalan setapak, dan tentu saja sangat kuat untuk memukul apa pun!"]
	quest.19E356E67EF17E4A.title: "&6Allthemodium &5Alloy &3Paxel"
	quest.19E6757F04098A0C.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemotong Rumput"
		"- Penyapu Langit"
	]
	quest.19E678E6EF9539DC.quest_desc: ["Sensor sederhana yang mengeluarkan sinyal redstone dan punya satu slot penyaring."]
	quest.19F58E291A543228.quest_desc: ["Versi &eEmas&r untuk armor &d&lArs&r!"]
	quest.19F58E291A543228.quest_subtitle: "11"
	quest.19F58E291A543228.title: "&5Sorceror's Outfit"
	quest.19FFD64154AFC89D.quest_subtitle: "Tingkat: &b4"
	quest.1A0368CB49B8CBFF.quest_desc: ["&eSpell Book&r ini adalah drop langka dari &cBlaze&r. Aku ingat karena aku bingung saat mendapat 1 dari Farm &cBlaze&r ku. \\n\\nIni memberikan Boost untuk &cFire Spell&r dan punya 10 &3Spell&r Slot."]
	quest.1A0368CB49B8CBFF.quest_subtitle: "Panas! Panas! Panas!"
	quest.1A0368CB49B8CBFF.title: "&cBlaze Instruction Manual"
	quest.1A05C605A52A4218.quest_desc: ["&5Unobtainium&r yang digabungkan dengan &6Allthemodium&r!"]
	quest.1A05C605A52A4218.title: "Alloy Ingot &5Unobtainium&r - &6Allthemodium&r"
	quest.1A0672C7509271B3.quest_subtitle: "Berikan Fluorite ke Diamond Bee"
	quest.1A0672C7509271B3.title: "Fluorite Bee"
	quest.1A09AF508EFAE0EC.quest_subtitle: "Citron + Key Lime"
	quest.1A13039D6302ADA5.quest_desc: ["Kamu bisa memeriksa Quest sebelumnya untuk mempelajari cara membuat beberapa di antaranya: &7Komponen Mekanik Besi&r di &eBlok Teknik Ringan&r dan &8Lembar Baja&r di &7Blok Teknik Berat&r. \\n&eKumparan Elektrum&r akan sedikit berbeda... \\n\\n&eKumparan Elektrum&r memerlukan Batang Besi dan 8 Gulungan Kabel MV. Untuk mendapatkan Gulungan Kabel MV, kita perlu memotong beberapa &eElektrum&r dengan Pemotong Kabel Insinyur."]
	quest.1A13039D6302ADA5.title: "&6Blok Generator"
	quest.1A20BBBAFBEDF911.quest_desc: [
		"Quantum Computer Multi-Threader menggandakan thread co-processing di Quantum Computer Multiblock sebanyak 6x. Contoh: Quantum Computer Accelerator kasih 72 thread co-processing dengan blok ini di multiblock."
		""
		"&lKamu cuma bisa punya satu Quantum Computer Multi-Threader di Quantum Computer Multiblock.&r"
		""
		"Ini juga ingredient buat ATM Star."
	]
	quest.1A20BBBAFBEDF911.title: "Co-Processing ke Infinity: Quantum Computer Multi-Threader"
	quest.1A2EA742FDED54FF.quest_desc: ["&5Echo Soil&r menutupi lantai &5Echoing Forests&r. \\n\\nMereka tidak bertindak seperti &2Grass&r atau Dirt normal selain membolehkan &5Echoing Saplings&r tumbuh di atasnya. \\n\\nTidak untuk Saplings normal."]
	quest.1A2EA742FDED54FF.title: "&5Echo Soil"
	quest.1A3F053E0F693002.quest_desc: ["Sistem Pelumasan Lanjutan akan bertindak seperti Unbreaking untuk &8Kepala Bor&r dan &8Bilah Gergaji&r kita. \\n\\nMereka akan kehilangan lebih sedikit Daya Tahan saat digunakan."]
	quest.1A3F053E0F693002.quest_subtitle: "Berhenti tertawa pada namanya!"
	quest.1A46A97A00A31C03.quest_desc: [
		"Langkah kedua adalah Target Pedestal. Di sinilah kamu menaruh &eSulfur&r contoh (target) yang kamu inginkan, agar sulfur pertama berubah menjadi jenis tersebut. \\n\\nAtau tempat di mana kamu menaruh &3Alchemical Niter&r."
		"{image:atm:textures/questpics/theurgy/theurgy_reform_2.png width:100 height:100 align:center}"
	]
	quest.1A46A97A00A31C03.title: "Langkah 2: Target Pedestal"
	quest.1A4B1CA7EC15348E.quest_desc: ["Menggunakan &aLinking Tool&r, kamu bisa menghubungkan 2 Ender Drawer agar isinya tersinkronisasi.\\n\\nIni bekerja persis seperti Ender Chest, tapi dalam bentuk Drawer.\\n\\nUntuk menghubungkan, klik kiri Ender Drawer pertama dengan &aLinking Tool&r (di bagian luar), lalu shift+klik kanan pada Ender Drawer kedua."]
	quest.1A4B1CA7EC15348E.quest_subtitle: "Drawer Antar Dimensi..."
	quest.1A4FAE5705B53753.quest_subtitle: "Dibuat dengan Enchanting Apparatus"
	quest.1A4FAE5705B53753.title: "Air Essence Bee"
	quest.1A53B6544782442E.quest_desc: ["Shield Control mengubah Shield yang kamu punya dan kapan regenerasi."]
	quest.1A53B6544782442E.title: "Wyvern Shield Control Module"
	quest.1A67F4F87B3D456C.quest_desc: [
		"&6B&8e&6e&r Cannon bisa dibuat, ditemukan di struktur, atau ditukarkan dengan &5Bee Queen&r. \\n\\nCara pakainya simpel: Klik Kanan pada &6L&8e&6b&8a&6h&r untuk memasukkannya, lalu Tahan Klik Kanan dan lepaskan untuk menembakkan lebah tersebut! \\n\\nMereka tidak akan marah karena ditembakkan, bahkan kurasa mereka menikmatinya."
		"{image:atm:textures/questpics/bumblezone/bumble_cannon2.png width:75 height:150 align:center}"
	]
	quest.1A6A383B4EF26B20.quest_desc: ["&4&lBor Pertambangan&r tidak memiliki banyak pilihan, kita punya &7Kepala Bor Besi&r atau &8Kepala Bor Baja&r. \\n\\n&7Kepala Bor Besi&r Menambang di Area 2x2 pada Tingkat &7Beliung Besi&r. Juga memberikan 6 Kerusakan dan memiliki Daya Tahan lebih rendah daripada... \\n\\n&8Kepala Bor Baja&r Menambang di Area 3x3 pada Tingkat yang sama dengan &bBeliung Berlian&r. Ini memberikan 7 Kerusakan dan memiliki lebih banyak Daya Tahan!"]
	quest.1A6A383B4EF26B20.title: "&8Kepala Bor"
	quest.1A739D36D5E3B1AD.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.1A739D36D5E3B1AD.title: "&eAdvanced Feeding Upgrade"
	quest.1A806C1A54B26EB5.quest_desc: ["Tidak ingin module-mu bekerja dalam jarak yang terlalu luas? Ingin Vacuum-mu menyisakan ruang untuk item yang jatuh? Kurasa kamu bisa menurunkan jarak jangkauannya."]
	quest.1A815711703E4A24.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Kontributor Komunitas&r untuk dipakai di AllTheMods Modpack.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan, kalau kamu lihat ini, kamu lagi di mode editing."]
	quest.1A83615B7E1D3540.quest_desc: ["Memasukkan &9Air&r ke dalam &#45BF56Reaktor&r bersama bahan bakar akan menghasilkan &#8F49C4Deuterium&r. Ada cara lain untuk mendapatkannya, tetapi &#45BF56Reaktor&r adalah cara tercepat yang memungkinkan."]
	quest.1A8440C0048EEB02.quest_desc: ["&cBlazegold&r memiliki statistik yang sama dengan Besi, tapi punya kemampuan lain yang bikin Besi iri! \\n\\nCek deskripsi item untuk mempelajari apa saja yang bisa dilakukannya!"]
	quest.1A8440C0048EEB02.quest_subtitle: "15"
	quest.1A8440C0048EEB02.title: "&cBlazegold Armor"
	quest.1A84DF4478D55C41.quest_subtitle: "Sama seperti versi uap"
	quest.1A8F2408970BFCCF.quest_desc: ["&eElektrum&r adalah Paduan yang terbuat dari &eEmas&r dan &7Perak&r. \\n\\nKamu bisa menebak dari namanya, digunakan banyak dalam segala hal yang berhubungan dengan listrik. Kabel, Konektor, Transformator, DLL!"]
	quest.1A8F2408970BFCCF.title: "&eBatang Elektrum&r"
	quest.1A8F438DB8508276.quest_desc: [
		"&3Frosted Prison&r adalah struktur raksasa mirip Kastel di atas dan di dalam Pegunungan Bersalju. \\n\\nDi dalamnya kamu akan menemukan lusinan sel, gudang senjata, dan sebuah ruangan besar tempat &3Cursed Tombstone&r berada. \\n\\nKamu bisa menemukan banyak peti penuh loot, termasuk Black Steel. Ada Decorated Pot di mana-mana yang bisa kamu ambil! \\n\\nDan tentu saja ada musuh yang menghalangi jalanmu: &3Draugr&r dan &3Aptrgangr&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_prison.png width:200 height:100 align:center}"
	]
	quest.1A8F438DB8508276.title: "&3Frosted Prison&r: Rumah sang &3&lMaledictus"
	quest.1A96C595CBA42840.quest_desc: ["Kivi Seed bisa digunakan untuk menanam Kivi Essence yang nantinya bisa di-craft menjadi Kivi!"]
	quest.1A96C595CBA42840.title: "Otomatisasi Kivi"
	quest.1AA81C41431FD145.quest_desc: ["Tarik..! Tarik..! Tarik..! \\n\\nPuller adalah kebalikan dari Sender; ia menarik item dari inventaris luar ke dalam Buffer milik Router. \\n\\nInventaris tersebut harus menempel (bersebelahan) dengan Router."]
	quest.1AAF0B31B47AF23D.quest_desc: ["Perangkat ME individu juga dapat dikonfigurasi untuk merespons sinyal redstone. Saat ditingkatkan dengan &bRedstone Card&f, perangkat dapat diatur untuk bekerja hanya saat diberi daya redstone atau sebaliknya.\\n\\nPerilaku ini juga bisa diterapkan pada seluruh &obagian&r jaringan ME menggunakan &bME Toggle Bus&f. Ini memungkinkan bagian jaringan di sisi lain bus online hanya saat bus diberi daya redstone, atau offline jika menggunakan &einverted&f toggle bus."]
	quest.1AAF0B31B47AF23D.title: "ME Terkendali Redstone"
	quest.1AB17923F87AE264.quest_desc: [
		"Yeti adalah nama yang bikin semua orang yang eksplorasi dingin jadi takut! Makhluk berbulu mengerikan yang hidup di iklim paling dingin dan makan apapun yang berani ke sana! \\n\\nTapi bukan Yeti ini, yang ini lucu dan ramah! Mereka lebih suka guling-guling daripada makan kamu. \\n\\nBahkan mereka gak ngelawan balik dan cuma punya 10 Heart. \\n\\nKalau mati mereka bakal drop Fur dan String, yang pertama bisa dipake sebagai pengganti Wool."
		"{image:atm:textures/questpics/eternal/starlight_yeti.png width:100 height:100 align:center}"
	]
	quest.1AB17923F87AE264.title: "Yeti"
	quest.1ABD22AA58E093A6.quest_desc: ["Cuma mesin &5Mesin&r yang paling hebat yang butuh bahan terbaik. \\n\\nPakai item &d&lUltimate&r buat bikin mesin-mesin ini dan lainnya! \\n\\nYa, kamu bakal mau mesin-mesin ini, mereka sebanding sama waktu dan bahan yang dikeluarin!"]
	quest.1ABD22AA58E093A6.title: "Beberapa &5Mesin&r terbaik!"
	quest.1ABEC7DE47BD6286.quest_desc: ["&5Ender Crate&r adalah &5Ender Chest&r yang bisa digunakan untuk mentransfer item.\\n\\n&5Ender Ocular&r adalah versi genggam dari &5Ender Crate&r."]
	quest.1ABEC7DE47BD6286.quest_subtitle: "Di Sini dan Di Sana!"
	quest.1ABEC7DE47BD6286.title: "&5Ender Crates dan Oculars"
	quest.1ACB3EDBCB732514.quest_subtitle: "Berikan satu blok Monazite ke Sulfur Bee"
	quest.1ACB3EDBCB732514.title: "Monazite Bee"
	quest.1AD87CB3226ED224.quest_desc: ["Wool cuma punya satu fungsi buat spawner: bikin dia diam. Nggak suka dengar suara berisik dari spawner? Pakai Wool! Bisa warna apa saja, jenis apa saja, atau desain apa saja!"]
	quest.1AD87CB3226ED224.title: "Diam! Nanti Mob-nya Bangun!"
	quest.1AEFF93A398B8BBF.quest_desc: ["&b&lElite Tier&r datang tepat setelah &c&lAdvanced&r. Punya buff yang sama kayak &c&lAdvanced&r... cuma lebih kuat! \\n\\n&b&lElite&r dibuat pakai &bReinforced Alloy&f, &bElite Control Circuit&f, dan biasanya pakai &eGold Ingot&r. \\n\\nKamu bisa dapat &bReinforced Alloy&r dari Infuse &cInfused Alloy&r pakai 20mb &bDiamond&r. Itu setara 2 &bDiamond Dust&r atau 1/4 &bEnriched Diamond&r! \\n\\nTerus pakai &bReinforced Alloy&r itu (butuh 2) sama satu &cAdvanced Control Circuit&r buat bikin &bElite Control Circuit&r. "]
	quest.1AEFF93A398B8BBF.title: "&b&lElite Tier"
	quest.1B0087400B0B8B49.quest_desc: ["&9Reaktor&r adalah generator multiblock berukuran 3x4x3 yang membakar &aUraninite&r sebagai bahan bakar untuk menghasilkan FE.\\n\\nUntuk membangunnya, kamu butuh total 36 Reactor Block. Saat memegang 36 blok di tangan, menaruh satu blok akan otomatis membangun seluruh struktur reaktor. Pastikan kamu sudah menyiapkan ruang yang cukup sebelumnya!\\n\\nKamu perlu mendinginkan reaktor agar menghasilkan lebih banyak FE, dan kamu bisa melakukannya dengan &bpendingin (coolant)&r padat maupun cair. Untuk menggunakan pendingin padat, kamu juga perlu memberikan sedikit pendingin cair. &bDry Ice&r adalah pilihan pendingin padat yang sangat bagus! (Catatan: 1 Ember Air sudah cukup).\\n\\nKamu juga bisa meningkatkan produksi FE dengan menjaga buffer bahan bakar tetap penuh, serta menambahkan Batu Bara (Coal) dan Redstone ke dalam Reaktor. Menggunakan bentuk Blok dari keduanya juga bisa dilakukan!"]
	quest.1B0087400B0B8B49.title: "Reaktor (Starter)"
	quest.1B173E7533E1171F.quest_desc: ["Pengumpul cairan sederhana."]
	quest.1B182A30604655E2.quest_desc: ["&cPembakar Blaze&r cukup mudah dibuat, hanya butuh beberapa &7Pelat Besi&r dan satu Blok &4Netherrack&r. \\n\\nKemudian kamu perlu melakukan &oKonversi Misterius&r agar tidak kosong! Caranya dengan Klik Kanan &cBlaze&r menggunakan &cPembakar Blaze Kosong&r. \\n\\nTapi ketika sudah diletakkan, sepertinya dia kecil dan... tidak terlalu panas... \\n\\nKita perlu memberinya makan! Bukan Steak ya, &cBlaze&r nggak suka Steak. Dia butuh Bahan Bakar Tungku seperti Kayu atau Batu Bara, atau favoritnya: &cKue Blaze&r! \\n\\nBahan Bakar Tungku hanya sedikit memanaskannya, tapi &cKue Blaze&r akan membuatnya &bSuper Panas&r! Ya, &bSuper Panas&r itu lebih panas dari panas &6Oranye&r. \\n\\nBeberapa Resep dan &6Mesin&r perlu dipanaskan, seperti &6Pembuatan Ramuan Otomatis&r, &6Pencampuran&r, dan Steam Boiler! "]
	quest.1B182A30604655E2.title: "&cPembakar Blaze"
	quest.1B4CD5AC8F6C3307.quest_desc: ["&#4497DBOverdrive module&r menjaga efisiensi mesin tetap stabil bahkan saat resep tidak sedang berjalan. Sebagai gantinya, ia akan mengunci mesin tersebut khusus untuk resep tersebut."]
	quest.1B4ED65C614B102F.quest_desc: ["&bIgnited Revenant&r menghalangi jalan kita untuk membunuh &b&lIgnis&r. \\n\\n&bRevenant&r ini terlihat dan bertindak seperti Blaze, tapi bukannya dikelilingi batang api, ia dikelilingi Perisai! \\n\\nPerisai ini membuatnya kebal terhadap semua serangan, kamu harus menunggu sampai ia mengangkat perisainya untuk menyerang! \\n\\nIa punya 1200 &4HP&r dan 2 jenis serangan: satu di mana ia melayang ke udara dan melempar batang Blaze ke sekitarnya, dan yang lain di mana ia memutar perisainya seperti sedang melakukan jurus Spinjitzu. \\n\\nSaat mati ia menjatuhkan &bBurning Ashes&r."]
	quest.1B4ED65C614B102F.title: "&bIgnited Revenant&r"
	quest.1B5177A774FCEF64.quest_desc: ["Sebelum kita mulai meminta bantuan teman Setan kita, kita perlu membuat item terpenting untuk Ritual: &aKapur (Chalk)&r.\\n\\nAda beberapa warna kapur yang dibutuhkan, di mana Ritual tingkat tinggi membutuhkan beberapa warna sekaligus untuk aktif. Sebagai permulaan, &bWhite Chalk&r adalah yang paling mudah didapat.\\n\\nMulailah dengan membakar Otherstone di tungku, dan melemparkan Batang Kayu Otherworld ke dalam &dSpiritfire&r. Dengan item yang dihasilkan, kamu bisa membuat Impure White Chalk.\\n\\nUntuk memurnikan kapur, cukup lemparkan ke dalam &dSpiritfire&r. Menggunakan kapur murni pada tanah akan menggambar simbol-simbol cantik yang &msetan&r banget. Simbol ini sulit dihapus, kecuali jika kamu membuat &aChalk Brush&r (Sikat Kapur). Buatlah, sangat sepadan."]
	quest.1B5177A774FCEF64.title: "Persiapan Ritual: &eKapur"
	quest.1B5C86AE05678420.quest_desc: ["Saat klik kanan pada interface, akan muncul beberapa opsi, ini fungsinya:\\n\\n&lSet Side&r: Di bagian atas layar, bisa mengatur sisi yang \"bertindak\" seperti interface. Berguna untuk mesin dengan sisi input/output tertentu.\\n\\n&lTicks/Operation&r: Kalau interface diatur 10 ticks/operation, akan import/export sekali setiap 10 tick (0.5 detik).\\n\\n&lPriority&r: Mengirim item ke inventory dengan interface prioritas lebih tinggi.\\n\\n&lItem/Energy Channels&r: Ini akan membagi sistem menjadi beberapa channel. Bisa push dan pull dari tempat berbeda di network."]
	quest.1B686954D34A0F23.quest_desc: ["&bQuartz Wrench&f berfungsi seperti kunci inggris pada mod teknologi lainnya. Ia memutar blok dan perangkat di sisi yang kamu klik kanan, serta membongkarnya jika diklik kanan sambil berjongkok (sneak).\\n\\nWrench ini tersedia dalam varian Certus Quartz dan Nether Quartz."]
	quest.1B686954D34A0F23.quest_subtitle: "Sesuai Fungsinya"
	quest.1B686954D34A0F23.title: "Quartz Wrench"
	quest.1B700DB77B970E35.quest_subtitle: "Tingkat: &b4"
	quest.1B72E95569B07E18.quest_subtitle: "Upgrade Penyimpanan x24"
	quest.1B72E95569B07E18.title: "&bDiamond Upgrade"
	quest.1B79F794EDAA810A.quest_desc: ["Breeding Chamber bisa digunakan untuk mengawinkan dua lebah secara otomatis. Alat ini mampu melakukan perkawinan mandiri (self breeding), maupun mengawinkan 2 jenis lebah untuk menghasilkan jenis ketiga (Contoh: Ashy Mining + Crystalline -> Iron).\\n\\nSediakan item makanan di setiap slot (biasanya bunga, tahan SHIFT pada kandang lebah untuk melihat item apa yang ia gunakan) dan beberapa kandang lebah (bee cage).\\n\\nPokoknya... jangan lakukan apa pun yang bisa bikin intel 'lebah' (F.Bee.I) mengejarmu. Aku bakal pastikan namamu masuk Hall of Shame kalau sampai ketahuan!"]
	quest.1B79F794EDAA810A.quest_subtitle: "Membuat Bayi 2: Electric Beegaloo"
	quest.1B90B94D07BBDD09.quest_desc: [
		"Buat bikin semua device ExtendedAE ini, palu dan tang Crafting Table gak cukup."
		""
		"Saatnya upgrade ke Crystal Assembler, mesin yang bisa handle operasi kompleks ini."
		""
		"Dengan ini, kamu bisa rakit berbagai device ExtendedAE."
		""
		"Ini juga bisa handle Reaksi In-World, tapi gak sebagus Reaction Chamber, dan bisa rakit processor, 4 sekaligus."
		""
		"Sisi yang ada layarnya gak bisa konek ke ME Network."
	]
	quest.1B90B94D07BBDD09.title: "Crafter Kompleks: Crystal Assembler"
	quest.1BA11428DF7541AD.quest_desc: ["Karena &eGearshift Berurutan&r menggunakan &eItem&r yang jauh lebih canggih, jelas ini &6Mesin&r yang jauh lebih canggih pula! \\n\\nMelihat betapa membingungkannya GUI-nya, aku setuju... Semoga aku bisa membuatnya sedikit lebih mudah dipahami! Nggak ada jaminan sih. \\n\\nSeperti &dGearshift&r biasa, ini butuh &4Sinyal Redstone&r untuk melakukan apa yang dirancang. Kita perlu mengatur GUI-nya untuk membuat sebuah \"skrip\". \\n\\nPertama, adalah Instruksi — tugas-tugas yang sebenarnya akan dilakukan. Di sini bisa diatur untuk memutar &8Poros&r, mengontrol Katrol, menunggu, atau berhenti. Harus berhenti di akhir, itu pasti. \\n\\nBerikutnya, adalah Sudut. Sudut yang akan diputar oleh &8Poros&r atau Katrol. Dari 360 hingga 1 derajat! \\n\\nTerakhir adalah Kecepatan dan Arah. Mengubah seberapa cepat Poros atau Katrol bergerak, apakah &e&oSearah Jarum Jam&r atau &9&oBerlawanan Jarum Jam&r."]
	quest.1BA11428DF7541AD.title: "&eGearshift Berurutan"
	quest.1BA3D15FFE7DBE59.quest_desc: ["Di &bIndustrial Foregoing&r, salah satu resource utama adalah &fLatex.&r Dipakai untuk craft Machine Frame, yang diperlukan untuk membuat mesin dan upgrade.\\n\\nMembuat Latex cukup sederhana, &aFluid Extractor&r mengekstrak Latex dari &6Log&r (Acacia memberikan paling banyak).\\n\\n------------------------\\n\\nSekarang tentang membuat Plastic: Plastic dihasilkan dari smelting Dry Rubber - yang dibuat di &aLatex Processing Unit&r, yang mengubah Latex jadi Dry Rubber.\\n\\n&bJadi pada dasarnya Latex -> Dry Rubber -> Plastic."]
	quest.1BA3D15FFE7DBE59.quest_subtitle: "Latex dan Plastic? Huh?"
	quest.1BA3D15FFE7DBE59.title: "Latex dan Plastic? Huh?"
	quest.1BAE1519E44E40CE.quest_desc: [
		"Bayangkan Ancient Sea. Oke, sekarang hilangkan semua Kelp dan semua &bGwib&r serta &bGwibling&r dari sana. \\n\\nItulah yang namanya Dead Sea!"
		"{image:atm:textures/questpics/undergarden/undergarden_dead.png width:200 height:100 align:center}"
	]
	quest.1BAE1519E44E40CE.title: "Dead Sea"
	quest.1BC611E39465B026.quest_subtitle: "Wenge + Silver Lime"
	quest.1BDB369FD243D4C6.quest_desc: [
		"Bisa dibilang item paling berguna yang bisa kamu buat di Occultism, &bIesnium Anvil&r adalah versi super kuat dari Anvil Vanilla."
		""
		"Dibuat menggunakan &9Uphyxes' Inverted Tower&r, alat ini:"
		""
		"- Tidak bisa hancur."
		"- Meningkatkan level maksimal semua mantra (enchant) sebesar satu tingkat."
		"- Membutuhkan biaya XP setengah dari estimasi (dibulatkan ke bawah, jadi jika tertulis 25, hanya bayar 12)."
		"- Kenaikan biaya XP lebih kecil untuk pengeditan berulang pada item yang sama."
		"- Meningkatkan batas level XP maksimal untuk mengedit item (titik di mana sistem bilang \"Too Expensive!\")."
	]
	quest.1BE26A00A420DAE3.quest_desc: ["Dalam mod ini, kamu butuh &aFlux Core&r dan &aFlux Block&r untuk membuat bagian inti dari jaringanimu. Buatlah beberapa untuk stok!"]
	quest.1BE26A00A420DAE3.quest_subtitle: "Inti dari Segalanya"
	quest.1BE26A00A420DAE3.title: "Bahan Crafting \"Inti\""
	quest.1BE69992D2C5085B.quest_desc: ["&n&aEvocation:&r\\nMemanggil Roh atau Dewa. \\n\\n&a&lEvokation&r adalah tentang apa yang dilakukan &aEvoker&r, terutama memanggil. Entah itu &aFang&r atau &aVex&r jika dipanggil kemungkinan besar itu &aEvokation&r. \\n\\n&a&lEvokation&r menggunakan &aEmerald&r sebagai Material Fokusnya. Kamu bisa craft Rune-nya atau mendapatkannya dari &a&lArchevoker&r. \\n\\n&aEvokation Scroll&r berwarna &fPutih&r dengan teks &0Hitam&r."]
	quest.1BE69992D2C5085B.title: "&a&lEvocation"
	quest.1BE8F864AB9147C0.quest_desc: ["Atalphaite Ore bisa ditemuin kalau Mining dimana aja underground di Starlight. \\n\\nGak bisa dibuat jadi Tool atau Armor tapi bisa bikin berbagai jenis Lampu!"]
	quest.1BF02D43986ABB03.quest_desc: ["&eSabuk&r datang dalam berbagai bentuk, ukuran, dan kegunaan! \\n\\nPertama, semua &eSabuk Konveyor&r bisa dibuat dengan &8Perancah Baja&r untuk memberi mereka penutup. &eSabuk Tertutup&r akan membuat &eBarang&r tidak bisa diambil dari Pemain saat berada di atasnya. \\n\\nVersi pertama dan paling sederhana dari &eSabuk&r adalah &eSabuk Vertikal&r. Hanya mengambil &eBarang&r ke atas! \\n\\n&eSabuk Pemisah&r... memisahkan arah &eBarang&r yang masuk. Akan berganti untuk setiap &eBarang&r: 1 ke Kiri, 1 ke Kanan, 1 ke Kiri, 1 ke Kanan. \\n\\n&eSabuk Penjatuh&r akan menjatuhkan &eBarang&r baik ke Inventaris di bawahnya, atau jika ada ruang terbuka akan menjatuhkan &eBarang&r. Ini bisa dikonfigurasi dengan &4Redstone&r untuk tidak menjatuhkan &eBarang&r. \\n\\nYang terakhir adalah &eSabuk Pengekstrak&r, yang satu ini akan otomatis mengambil &eBarang&r dari Inventaris dan menyebarkannya di &eSabuk&r-nya. Ini juga bisa digunakan dengan beberapa Mesin!"]
	quest.1BF02D43986ABB03.title: "Jenis &eSabuk"
	quest.1BFE6745F49B4AB0.quest_desc: ["Sculk Gleam punya sifat seperti Shroomlight. Mereka tidak butuh Tool untuk diambil, tapi pecah paling cepat dengan Hoe. \\n\\nMereka tumbuh di dalam &5Echoing Trees&r dan jarang di bawah tanah."]
	quest.1C0F4D1610530FEC.quest_subtitle: "Dibuat di Dragonsteel Forge"
	quest.1C0F4D1610530FEC.title: "Fire Dragonsteel Bee"
	quest.1C2309DB4B890E71.quest_desc: ["&bCerat&r digunakan dalam sistem untuk mengisi &eItem&r dengan &bCairan&r. \\n\\nPertama, isi &bCerat&r dengan &bMenghubungkan Pipa Cairan&r ke dalamnya! \\n\\nKemudian, jika ada &eItem&r yang bisa menampung &bCairan&r — Ember atau Botol — maka akan diisi dengan &bCairan&r yang ada di Cerat. \\n\\nPengisian terjadi otomatis, tidak butuh Tenaga Rotasi karena menggunakan Gravitasi!"]
	quest.1C2309DB4B890E71.title: "&bCerat"
	quest.1C232674CD04024D.quest_desc: ["Dimensi &2&lUndergarden&r penuh dengan biome yang beragam dan menjijikkan, lengkap dengan banyak vegetasi, mob yang ramah maupun tidak, serta tentu saja bijih dan item unik. \\n\\nSemoga kamu siap bertarung!"]
	quest.1C232674CD04024D.title: "Selamat Datang di &2&lUndergarden&r!"
	quest.1C273D9E046FD18A.quest_desc: ["Digunakan untuk memberikan energi (energize) pada item menggunakan Energizing Orb."]
	quest.1C27C74722A19FC1.quest_desc: ["Dengan banyak item super mahal dari &l&5Mekanism&r, kamu bisa meningkatkan &5Unobtainium Armor&r menjadi &aMekaSuit&r! \\n\\nSekarang armor ini bisa menyimpan Energi; alih-alih kehilangan darah saat terkena damage, energinya yang akan berkurang. \\n\\nKamu bisa menggunakan Upgrade Unit untuk membuatnya lebih hebat lagi!"]
	quest.1C27C74722A19FC1.quest_subtitle: "Sebanyak energi yang bisa kamu suplai"
	quest.1C27C74722A19FC1.title: "&aMekaSuit"
	quest.1C40B30823B2A254.quest_subtitle: "Pancing saja di laut"
	quest.1C40B30823B2A254.title: "Prismarine Bee"
	quest.1C474B46AECCCFE9.quest_subtitle: "Muncul menggunakan Gravel atau Stone Nest"
	quest.1C4ABF4518638A82.quest_desc: ["Buff:\\n\\n - Absorption II (3:00)\\n - Speed II (3:00)\\n - Resistance II (3:00)\\n - Regeneration II (3:00)\\n - Strength II (3:00)"]
	quest.1C4ABF4518638A82.title: "&4Apel Supremium"
	quest.1C566975C4EC5D93.quest_desc: ["Jujur, mending pakai &2&lMA&r aja buat yang satu ini. Cara paling gampang buat dapet semuanya. \\n\\nPlis, jangan bikin peternakan &2Turtle&r atau pembantaian &bGuardian&r masal. TPS server itu penting!"]
	quest.1C566975C4EC5D93.title: "&9Sea Prism"
	quest.1C5EA7D62BAF2108.quest_desc: ["Untuk melawan &5&lThe Leviathan&r, kamu butuh sebuah tumbal. Spesifiknya adalah &5Abyssal Sacrifice&r. \\n\\nItem dasar yang dibutuhkan adalah Blok Ingot dan Amethyst yang merupakan item &2&lVanilla&r biasa. \\n\\nLalu, kamu butuh Nautilus Shell dan Heart of the Sea. Ini adalah item &2&lVanilla&r yang langka... kecuali jika kamu membunuh &5Deepling&r yang bisa menjatuhkannya! \\n\\nKamu juga butuh Athame, senjata yang digunakan oleh &5Deepling Warlock&f dan &5Priest&r. \\nBagian terakhir memberikan pilihan antara Crystallized Coral atau Coral Chunk, keduanya adalah drop dari &5Coral Golem&r dan &5Coralssus&r."]
	quest.1C5EA7D62BAF2108.quest_subtitle: "Membangunkan The Leviathan"
	quest.1C5EA7D62BAF2108.title: "&5Abyssal Sacrifice"
	quest.1C6B815C0F43312D.quest_desc: [
		"Suasana yang berbeda untuk &6&lBumblezone&r. \\n\\n&d&lFloral Meadow&r memiliki rumput, pohon ceri, dan lebih banyak &dBunga&r dari yang bisa dibayangkan. \\n\\nTunggu, jika &6L&8e&6b&8a&6h&r sudah punya &dBunga&r di dalam &eHive&r mereka, kenapa kita perlu menaruh bunga di luar juga?!?!?!?!"
		"{image:atm:textures/questpics/bumblezone/bumble_meadow.png width:200 height:100 align:center}"
	]
	quest.1C6B815C0F43312D.title: "&d&lFloral Meadow"
	quest.1C70D739CE464E25.quest_desc: ["Bekerja persis seperti &2Item Card&r, kamu butuh Extract dan Insert Card. Hanya saja kali ini kamu mengambil dari Tangki berisi &9Cairan&r ke Tangki lainnya. Tidak, alat ini tidak memindahkan blok sumber (source) &9Cairan&r masuk atau keluar dari dunia."]
	quest.1C70D739CE464E25.title: "&9Fluid Card"
	quest.1C73E60FC70408D4.quest_desc: ["Akhirnya Generator yang unik! Culinary itu nama buat seni Makanan. Generator ini ga pakai Coal, Lava, atau bahkan kayu, mereka pakai Makanan. Apapun yang punya Food Points bisa dipake buat bikin Energi, jumlahnya tergantung dari berapa banyak Food Points yang ada di Makanan itu. Steak bakal kasih Energi lebih banyak daripada Wortel."]
	quest.1C76E244AE3582E6.quest_desc: [
		"&5&lPerakit&r, tidak seperti kebanyakan Mesin, bekerja sebagian besar di GUI-nya. \\n\\nKlik Kanan Mesin dan atur 3 Resep, dengan memasukkannya ke dalam Kisi di bagian atas layar. Urutan mereka, adalah urutan yang akan diikuti untuk prioritas. \\n\\nKamu bisa &9Memasukkan &eBarang&r dari &eSabuk&r dan akan &6Mengeluarkan&r dari &aSabuk&r belakang. Kamu juga bisa &6Memasukkan &bCairan&r yang akan digunakan untuk mengisi ulang &bEmber&r atau &bTangki&r yang digunakan dalam Crafting! \\n\\nKamu juga perlu mengisi dayanya dengan &cEnergi&r dari Atas."
		"{@pagebreak}"
		"Letakkan 2 garis paralel 3 &8Perancah Baja&r dengan jarak Blok di antara mereka. Di antaranya letakkan &eBlok Teknik Ringan&r di tengah, dan &4Blok Teknik Redstone&r di sekitarnya."
		"{image:atm:textures/questpics/immersive/immersive_assembler1.png width:100 height:100 align:center}"
		"Di sisi dengan &4Blok Teknik Redstone&r letakkan &7Lembar Besi&r. Kemudian, di atas &eBlok Teknik Ringan&r tentu saja perlu yang lain. Setelah itu, letakkan &eSabuk Konveyor&r menuju dan melewati &eBlok Teknik Ringan&r!"
		"{image:atm:textures/questpics/immersive/immersive_assemble2.png width:100 height:100 align:center}"
		"Yang satu ini mungkin membingungkan hanya dengan melihatnya; letakkan &7Lembar Besi Setengah&r pada &7Lembar Besi&r yang sebelumnya ditempatkan. Kemudian, di antara mereka letakkan &7Lembar Besi&r penuh."
		"{image:atm:textures/questpics/immersive/immersive_assembler3.png width:100 height:100 align:center}"
		"Untuk membangun &5&lPerakit&r Klik Kanan &eSabuk Konveyor&r pertama dengan &6Palu&r keren kita!"
		"{image:atm:textures/questpics/immersive/immersive_assembler.png width:100 height:100 align:center}"
	]
	quest.1C76E244AE3582E6.title: "&5&lPerakit"
	quest.1C8210712349A2E3.quest_desc: ["Premis cukup sederhana, Axes dan Swords bisa memberikan lebih banyak Damage. Ya, ini stack!"]
	quest.1C8210712349A2E3.title: "Basic Damage Module"
	quest.1C829609915E0012.quest_desc: ["Masukkan &cMercury&r, \\nHasilkan Energi. \\n\\nMF di sini adalah singkatan dari &cMercury&r Flux, bukan nama penyanyi rap atau kata kasar untuk memanggil seseorang!"]
	quest.1C829609915E0012.title: "Menghasilkan Daya dengan &cMercury"
	quest.1C87535D3CDCDA5F.quest_desc: ["&4Laser Amplifier&r punya Internal &aEnergi&r Storage sendiri, tapi mereka gak di-charge kayak kebanyakan &5Mesin&r. \\n\\nCara kerja &4Laser Amplifier&r adalah dengan ngambil Charge dari &4Laser&r lain yang nembak ke mereka! \\n\\nEntah itu &4Laser Amplifier&f lain atau &4Laser&r, begitulah cara mereka dapet &aEnergi&r. \\n\\nMereka terus pake &aEnergi&r itu jadi sinar yang lebih fokus lewat Config yang lo set di GUI-nya. Delay, Minimum, sama Maximum. \\n\\nDelay adalah berapa banyak Tick yang ditunggu setelah mencapai &aEnergi&r Minimum sebelum nembak. Paling sedikit 0 Tick dan paling banyak 9,999! \\n\\nMinimum adalah jumlah &aEnergi&r yang ditahan sebelum nembak &4Laser&r yang lebih kuat! Paling sedikit FE yang ditunggu adalah 800mFE sedangkan paling banyak 2GFE. \\n\\nMaximum kerjanya mirip dengan berapa banyak yang ditahan sebelum nembak &4Laser&r. "]
	quest.1C87535D3CDCDA5F.title: "&4Laser Amplifying"
	quest.1C9D3FC67D58AC02.quest_desc: ["&#EDD653&nMixer&r memungkinkan kita untuk menggabungkan item dan cairan. Alat ini bisa digunakan untuk mewarnai item atau bahkan menggandakannya."]
	quest.1CACE201C6AA0913.quest_desc: ["Upgrade ini akan memusnahkan item berlebih yang masuk saat Drawer sudah penuh.\\n\\nSangat berguna untuk mencegah sistem macet karena penyimpanan penuh."]
	quest.1CAEC4C273EDDB99.quest_desc: ["Ada di sini! Ada di sana! Ada di mana-mana dan busuk! Kamu bisa menemukan ini di kebanyakan Chest. \\n\\nIni bisa menampung 8 &3Spell&r tapi memberimu Spell Resistance yang lebih sedikit."]
	quest.1CAEC4C273EDDB99.title: "Rotten Spell Book"
	quest.1CB063BBEC35712B.quest_desc: [
		"Gue bisa ngelihat dari percikan di Udara, ini bukan &dGeode Amethyst&r, ini &5Gua Naga Petir&r. \\n\\nLebih spesifiknya &lStage 4&r dan &l5 &5Naga Petir&r. \\n\\n&5Gua&r ini penuh dengan &6Tembaga &fdan &dAmethyst&r dan Chest buat banyak Loot. \\n\\nJuga Monster dan &5&lNaga&r-nya. Ya, susah banget buat lupa mereka!"
		"{image:atm:textures/questpics/iceandfire/iaf_struct_lightningcave.png width:200 height:100 align:center}"
	]
	quest.1CB063BBEC35712B.title: "&5Gua Naga Petir"
	quest.1CBA0D7DA0558EBC.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kekebalan"
		"- Padamkan Api"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.1CC4F8570A7A99EB.quest_desc: ["&dEssence&r adalah titik awal buat semua kebutuhan bercocok tanam kamu di Mystical Agriculture.\\n\\n&eInferium Essence&r adalah tingkat dasar dari semua essence. Kamu bisa dapetin ini dari nambang, bunuh mob, atau bikin benih buat nanemnya! \\n\\nBuat bikin essence yang lebih besar dan bagus, kamu harus bikin &9Kristal Infus&r. "]
	quest.1CC4F8570A7A99EB.quest_subtitle: "Tingkat: &e1"
	quest.1CC4F8570A7A99EB.title: "&aInferium"
	quest.1CC627D3FB348C89.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_shaper.png width:100 height:150 align:center}"]
	quest.1CC627D3FB348C89.quest_subtitle: "Trail Ruins"
	quest.1CC627D3FB348C89.title: "Shaper Armor Trim"
	quest.1CD05CB4A3DB112A.quest_desc: ["&c&lSalvaging Table&r akhirnya memungkinkanmu mendapatkan Material dan &9Gem Dust&r tanpa harus menggunakan &7Anvil&r. \\n\\nKamu bisa mendaur ulang &ePeralatan&f dan &eArmor&f yang memiliki &eAffix&r untuk mendapatkan materialnya. \\n\\nMaterial yang didapat berdasarkan Rarity item tersebut; item &8Common&r akan memberikan material &8Common&r. \\n\\nDan entah kenapa meja ini juga bisa menghancurkan Armor Kuda/Anjing."]
	quest.1CD05CB4A3DB112A.title: "&c&lSalvaging Table"
	quest.1CD2C6AFD788C35E.quest_desc: ["Memadatkan item di dalam Tas ke resep 2x2 (contoh: Sandstone)."]
	quest.1CD5ABD827CEB3AE.quest_subtitle: "Brazil Nut + Balsa"
	quest.1CE7B24E7E62C25B.quest_desc: [""]
	quest.1CE7B24E7E62C25B.quest_subtitle: "&oYang tidak diketahui tapi justru itu semua yang kita tau."
	quest.1CE7B24E7E62C25B.title: "&d&lPulsating &8Black Hole"
	quest.1CF8263756EE8F2A.quest_desc: ["&eDebu&r spesial ini drop dari Wither dan Ender Dragon kalau dibunuh pakai &dSenjata Essence&r yang di-enchant dengan &dMystical Enlightenment&r."]
	quest.1CF8263756EE8F2A.title: "&5Debu Cognizant&r"
	quest.1D1ABA9BD978E8A1.quest_subtitle: "Citron + Wild Cherry"
	quest.1D1FAA2F86695781.quest_desc: ["Untuk &l&2Frontier&r, Rarity dari &eAffix&r mungkin tidak terlalu penting, tapi sekarang untuk &l&eAscent&r kamu butuh semuanya berada di tingkat &aUncommon&r atau lebih baik. \\n\\nKamu juga harus membunuh seorang &4Invader&r (Boss Apothic) untuk meng-upgrade &lWorld Tier&r-mu. Rarity boss-nya tidak berpengaruh! \\n\\n&eAffix&r hanya akan bertahan sampai tingkat &5Epic&r, tapi sekarang &9Rare&r jauh lebih umum ditemukan. Kita juga bisa mendapatkan &aGem&r tingkat &6Mythic&r... tapi cuma kalau Dewi Keberuntungan berpihak padamu! \\n\\nBicara soal keberuntungan, Luck kita akan meningkat sebesar 30% dan Experience melonjak ke 55%. \\n\\nSebagai gantinya, &4Monster&r sekarang akan memiliki 8 Armor Point dan 5 Armor Pierce."]
	quest.1D1FAA2F86695781.title: "&lWorld Tier: &eAscent"
	quest.1D23F53C585185B7.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_naga.png width:100 height:150 align:center}"]
	quest.1D23F53C585185B7.title: "&2Naga Scales"
	quest.1D2700821045CCF2.title: "&5Komponen Penyimpanan 65536k"
	quest.1D27EE427ECFD6CE.quest_desc: ["Versi peningkatan dari &cTertium&r."]
	quest.1D27EE427ECFD6CE.quest_subtitle: "27"
	quest.1D27EE427ECFD6CE.title: "&9Imperium Armor"
	quest.1D2EF12FD7FDD217.quest_desc: ["Ayam akan bertelur secara alami. Kayaknya gak beneran dianggap alami sih...\\n\\nKayaknya ayamnya cuma lagi... &oEggs-ercise!!!&r."]
	quest.1D2EF12FD7FDD217.quest_subtitle: "...atau iya?"
	quest.1D2EF12FD7FDD217.title: "Gak akan bikin pun Telur"
	quest.1D31C515533DAD36.quest_subtitle: "Cave Dweller + Soul Tree"
	quest.1D39634260A47C9A.quest_desc: ["Jika kamu menggunakan &2Infused Iron Ingot&r atau &6Tainted Gold Ingot&r pada Offering Table, kamu akan mendapatkan &bIngot of the Skies&r."]
	quest.1D39634260A47C9A.title: "&bIngot of the Skies"
	quest.1D3E2363CFD4C5E0.quest_desc: ["Fusion Crafting punya Tier yang ditentukan oleh Injector. Tier-nya naik berurutan: Draconium (Aku menyebutnya Basic untuk membantu membedakan), Wyvern, Draconic, dan Chaotic. Injector perlu ditempatkan di Kiri dan Kanan Fusion Crafting Core, beberapa block jauh darinya. Mereka bisa ditempatkan dalam bentuk salib maksimal 5 di setiap sisi Crafting Core. Untuk memberi mereka Energy menempatkan Relay IO Crystals yang terhubung dengannya akan bekerja, lihat Crystal Binding untuk belajar lebih."]
	quest.1D3E2363CFD4C5E0.title: "Tier Basic"
	quest.1D3F11194EA3BB73.quest_subtitle: "Tingkat: &b3"
	quest.1D48298525EEADC9.quest_desc: ["Kamu harusnya sudah punya semua yang dibutuhkan."]
	quest.1D48298525EEADC9.quest_subtitle: "Tuang Gula ke aku!"
	quest.1D48298525EEADC9.title: "Kamu manis banget"
	quest.1D4973B187284CBB.quest_desc: ["Item yang sangat damai dan membantu, pegang di tangan kiri (offhand) untuk menggunakannya. Saat berada di tangan kiri, ia akan memupuk tanaman dan bibit pohon. \\n\\nIa juga akan menyembuhkan pemain dan mob jinak di sekitar. \\n\\nSerta menghilangkan efek Poison dan Wither dari pemain dan mob jinak. Aku tidak tahu bagaimana mob kamu bisa terkena Wither, tapi sekarang kita bisa menyembuhkannya! \\n\\nSetelah melakukan cukup banyak penyembuhan atau pemupukan, ia akan masuk ke masa tunggu (cooldown) selama 10 menit."]
	quest.1D4973B187284CBB.title: "&aEssence of Life"
	quest.1D4E7F548431263A.quest_desc: ["Paling mudah dari Blok ini untuk dibuat. \\n\\nBesi dan &4Redstone&r akan didapat dari gameplay &2&lVanilla&r, satu-satunya Barang \"sulit\" adalah &7Lembar Besi&r."]
	quest.1D4E7F548431263A.title: "&4Blok Teknik Redstone"
	quest.1D56D3B444A4B2D4.quest_desc: ["&dGauntlet of &bBulwark&r bekerja secara berbeda dari yang kamu bayangkan. \\n\\nBukannya menarik mob mendekat, ia justru mendorong mereka menjauh saat Menahan Klik Kanan, dan memberikan efek &bBlazing Brand&r. \\n\\nLalu saat kamu melepas Klik Kanan, kamu akan menyeruduk ke arah yang kamu lihat. \\n\\nDibuat dengan menggabungkan &dGauntlet of Guard&r dengan &bBulwark of Flame&r di dalam &4Mechanical Fusion Anvil&r."]
	quest.1D56D3B444A4B2D4.title: "&dGauntlet of &bBulwark"
	quest.1D6FAF0E25A0D596.quest_subtitle: "Clove + Allspice"
	quest.1D720AC88431BD70.quest_desc: ["Kawinkan Ender Bee dengan Lapis Bee untuk membuat Diamond Bee!"]
	quest.1D720AC88431BD70.quest_subtitle: "Ender + Lapis"
	quest.1D720AC88431BD70.title: "Diamond Bee"
	quest.1D794DE95C9FF6C7.quest_subtitle: "Meningkatkan Kecepatan Mesin"
	quest.1D86B2E553503E53.quest_desc: ["Dominion Wand digunakan untuk mengendalikan makhluk yang mungkin kamu temui di dunia! Setiap makhluk merespons secara berbeda terhadap tongkat ini, jadi pastikan baca detailnya di Worn Notebook!"]
	quest.1D86B2E553503E53.title: "Memanggil Bantuan!"
	quest.1D87415343E65AA7.quest_desc: ["&5Creative &8Compressor&r membolehkanmu memilih tekanan Bar berapapun! Positif, Negatif, bahkan 0! Bisa dipakai di dalam mesin. \\n\\nKamu butuh 4 stack Advanced Pressure Tube, Advanced Liquid Compressor, Advanced Air Compressor, Electrostatic Compressor, dan Flux Compressor. \\n\\nAku nggak tahu mana yang lebih susah: dapetin &6&lStar&r-nya atau ngingetin semua item yang dibutuhin buat bikin ginian!"]
	quest.1D87415343E65AA7.title: "&5&lCreative &8Compressor"
	quest.1D91E37BFD8CC911.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_emerald.png width:100 height:150 align:center}"]
	quest.1D91E37BFD8CC911.title: "&2Emerald&r"
	quest.1D94F59F13667DCF.quest_desc: ["Untuk dapet Unrefined Liquid Soul kita perlu pakai Fluid Extractor di Soul Tree Log! \\n\\nSoul Tree Sapling gak bisa di-breed, itu treasure Sapling. Kamu perlu cari di &dEnd City&r untuk Sapling-nya."]
	quest.1D94F59F13667DCF.title: "Unrefined Liquid Soul"
	quest.1D995548A159F291.quest_subtitle: "Berikan sebuah Soulium Dagger ke Ghostly Bee"
	quest.1D995548A159F291.title: "Soulium Bee"
	quest.1DA0A87C471A38AC.quest_desc: [
		"&cEvilCraft&r punya Farm Mob sendiri!\\n\\nBuat mulai ini, kamu butuh craft minimal 33 &cDark Blood Bricks&r. Dengan ini, kita bakal bangun struktur yang cukup kuat buat nahan spirit yang dipanggil.\\n\\nKamu juga butuh spirit yang terperangkap di &9Box of Eternal Closure&r. Ini bakal tentuin drop yang kamu dapet.\\n\\nBuat bangun ini, kamu harus bikin struktur cuboid dengan ruang cukup buat mob spawn. Ukuran minimum 3x4x3, yang cukup buat spawn mob kayak Zombie. Pastiin taro &9Spirit Furnace&r di salah satu sisi biar kamu bisa interaksi dengan struktur.\\n\\nKalau kamu mau spawn mob lebih gede, kamu harus bikin struktur lebih gede.\\n"
		"{image:atm:textures/questpics/evilcraft/evilcraft_spiritfurnace.png width:125 height:150 align:1}"
	]
	quest.1DA0A87C471A38AC.title: "&aFarm Mob pakai &cDarah"
	quest.1DAA5DD81EF96469.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemotong Rumput"
		"- Penyapu Langit"
		"- Pelebur Otomatis"
		"- Palu"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.1DC407272D9D9CCE.quest_subtitle: "Awakened Crafting"
	quest.1DC407272D9D9CCE.title: "Awakened Supremium Bee"
	quest.1DCAA0310AA55F1C.quest_desc: ["Tapi dia biasanya tutup jam 5, jadi siapa peduli?"]
	quest.1DCAA0310AA55F1C.quest_subtitle: "Willy Pasti Bangga"
	quest.1DCAA0310AA55F1C.title: "Awal Seorang Pemancing"
	quest.1DE0F289821F55D1.quest_desc: ["Sekarang karena kita sudah punya Foliot Crusher, kita bisa meminta &msecara paksa&r dengan sopan agar ia menghancurkan &eEnd Stone&r, &9Obsidian&r, dan &7Calcite&r untuk kita. Kita akan menggunakannya untuk membuat Kapur baru!"]
	quest.1DE0F289821F55D1.title: "Berurusan dengan Kapur"
	quest.1DF026030780AE96.quest_subtitle: "Mengekstrak Gen dari lebah yang ada di dalam sarang"
	quest.1DFC9F33D9FD6357.quest_subtitle: "Cacao + Candlenut"
	quest.1E00DBAACDF4404F.quest_desc: ["Collector berfungsi sebagai Absorption Hopper yang sangat murah.\\n\\nAlat ini akan mengambil semua item dalam radius 3 blok dan memasukkannya ke inventaris di bawahnya atau ke dalam dirinya sendiri. Bisa dimatikan dengan Redstone!"]
	quest.1E0C6409B2573CCA.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Versi tingkat lanjut dari Injakan Tanah yang mendorong dan memperlambat monster di sekitar, memiliki cooldown."
	]
	quest.1E0EF28175A7424F.quest_desc: ["Karena kamu sudah memproduksi uap (steam), kenapa tidak menggunakannya untuk membuat listrik? Cukup pasang sebuah &#6363DBTurbine&r, masukkan &7steam&r, dan tarik keluar energi &#DBDB63listrik&r."]
	quest.1E0EF28175A7424F.quest_subtitle: "Uap -> Listrik"
	quest.1E0F92F07FDD162E.quest_desc: ["Kamu butuh &bProsperity Seed Bases&r buat bikin tanaman resource."]
	quest.1E0F92F07FDD162E.quest_subtitle: "Ini semua tentang Seed Base"
	quest.1E0F92F07FDD162E.title: "&bBasis Benih Prosperity"
	quest.1E13D7CE5A9EFF74.quest_desc: [
		"Frostfields adalah salah satu biome dingin di &2&lUndergarden&r. Kamu bisa tahu itu dingin dari bongkahan es masif, Powdered Snow, dan Frozen Deepturf! \\n\\nSelain itu, alih-alih Depthrock biasa, di bawah tanah sini kamu akan menemukan Shiverstone. \\n\\nShiverstone bertindak lebih seperti Es daripada batu sungguhan, setidaknya saat kamu berdiri di atasnya!"
		"{image:atm:textures/questpics/undergarden/undergarden_frosty.png width:200 height:100 align:center}"
	]
	quest.1E13D7CE5A9EFF74.title: "Frostfields"
	quest.1E1EB7DC19DDCFB7.quest_desc: ["Untuk membuat tool dan armor Netherite perlu menemukan &6Netherite Smithing Template&r di chest yang ada di dalam Bastion.\\n\\nIni bisa digabungkan dengan ingot &cNetherite&r dan tool atau armor Diamond di &aSmithing Table&r untuk upgrade ke &cNetherite&r.\\n\\nTip: Jangan pakai semua template sekaligus! Bisa membuat duplikat dengan menggunakan resep untuk membuat yang lain."]
	quest.1E1EB7DC19DDCFB7.title: "&6Netherite Template&r"
	quest.1E22A0D5F4B2EB0D.quest_subtitle: "Membekukan Argon dengan Helium"
	quest.1E2A9446594638E2.quest_desc: ["&5Chorus Inhibitor&r adalah &6Relic&r simpel lainnya. Alat ini bisa menteleportasimu ke blok yang sedang kamu lihat jika masih dalam jangkauan. Jarak jangkauannya bisa ditingkatkan melalui &6Research Window&r."]
	quest.1E2A9446594638E2.quest_subtitle: "Ditemukan di End City dan End Ship"
	quest.1E2A9446594638E2.title: "&5Chorus Inhibitor"
	quest.1E2B363E3365A62F.quest_desc: ["Benih Allthemodium butuh Tanah Ajaib yang ditaro di bawah biar bisa numbuh."]
	quest.1E2B363E3365A62F.quest_subtitle: "Tingkat: &bAjaib"
	quest.1E3471513C75CC54.quest_desc: ["Kalau kamu taro Bucket Blood di tanah cukup lama atau taro di Drying Basin, dia bakal kering jadi &cHardened Blood&r.\\n\\nSelain sangat tidak higienis, kita butuh segala jenis darah buat kita maju. Bahkan darah kering.\\n\\nIni bakal balik jadi darah kalau hujan, atau dengan hancurin pakai alat biasa. Kalau kamu hancurin dengan &9Flint and Steel&r, kamu bakal dapet &dBlood Shards&r."]
	quest.1E3471513C75CC54.title: "Mengeringkan... &cDarah?"
	quest.1E3E688B3B52C4D2.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_raiser.png width:100 height:150 align:center}"]
	quest.1E3E688B3B52C4D2.quest_subtitle: "Trail Ruins"
	quest.1E3E688B3B52C4D2.title: "Raiser Armor Trim"
	quest.1E40ACF3E69A4100.quest_desc: ["Apa harus diminum? Entahlah, pokoknya alat ini cuma nempel di situ dan berfungsi... \\n\\nDengan &6Antidote Vessel&r, durasi efek negatif (seperti Wither atau Poison) akan dipotong jadi lebih singkat! Sangat berguna saat melawan Witch atau Wither Skeleton."]
	quest.1E40ACF3E69A4100.quest_subtitle: "Sabuk"
	quest.1E40ACF3E69A4100.title: "&6Antidote Vessel&r"
	quest.1E414D285E7A5FE2.title: "&cPeralatan Tertium"
	quest.1E41A5071854DEC8.title: "Wyvern Damage Module"
	quest.1E499F94A2A193E1.quest_desc: ["Menambahkan fungsi Blast Furnace ke dalam Tas."]
	quest.1E4E462928F2A71C.quest_desc: [
		"&7&nCoke Oven&r akan digunakan untuk mengubah &#787777Batu Bara (Coal)&r menjadi &#696464Coke&r. &#696464Coke&r memiliki efisiensi bahan bakar 4 kali lipat lebih baik daripada &#787777Batu Bara&r biasa. "
		""
		"Struktur multiblock dapat dilihat pratinjaunya dengan memegang sebuah &#D1D15Ewrench&r di tangan utama atau tangan kiri. Memegang &#B4D95Dhatches&r di tanganmu akan memberitahu posisi yang memungkinkan untuk meletakkannya."
		""
		"&7&nCoke Oven&r adalah struktur multiblock berongga yang sebagian besar terbuat dari bata (brick)."
	]
	quest.1E535784A9D3DE89.quest_desc: ["Ini adalah hal-hal dari ExtendedAE yang gak butuh Entro Crystal."]
	quest.1E7DC8E0493BE99E.quest_subtitle: "Tingkat: &e1"
	quest.1E81B903137BB62A.quest_desc: ["Peralatan normal tidak akan cukup, terutama saat berhadapan dengan mob berbahaya di &2&lUndergarden&r. \\n\\nKita bisa men-craft &7Cloggrum Shield&r yang berfungsi seperti perisai normal. \\n\\nTapi kamu harus mendapatkan &7Battleaxe&r sebagai drop langka dari &7Forgotten&r."]
	quest.1E81B903137BB62A.title: "Senjata &7Cloggrum&r"
	quest.1E9B2D814F50A265.quest_desc: ["&6Kipas Berselubung&r adalah salah satu Mesin yang paling kurang diapresiasi di &6&lCreate&r. \\n\\nKamu bisa meletakkannya dan ia akan menghadapmu, atau Shift + Klik Kanan untuk memasangnya menghadap menjauhimu. \\n\\nKetika diberi &dTenaga Rotasi&r &e&oSearah Jarum Jam&r, ia akan meniup udara menjauhinya. Ketika diberi &dTenaga Rotasi&r &9&oBerlawanan Jarum Jam&r ia akan menyedot udara ke arahnya. \\n\\nHisapan dan tiupan ini juga mempengaruhi &eItem&r dan Entitas di dekatnya — semakin cepat berputar, semakin kuat hisap dan tiupnya! \\n\\nKita juga mendapat Resep tambahan dengan menaruh Blok di depan &6Kipas&r. Ini akan mempengaruhi &eItem&r yang terkena tiupan &6Kipas&r. \\n\\nGunakan &cLava&r untuk &6Membakar&e Item&r seperti Tungku — menghasilkan Ingot dari Bijih, Batu dari Cobble, dan Nugget dari Peralatan. \\n\\nKalau taruh Api di depan Kipas, bisa mengasapi Item. Seperti memasaknya! \\n\\nSelain Lava, bisa juga taruh Air di depannya. Ini akan mencuci apapun yang ada di depannya, seperti mengubah Bubuk Beton menjadi Beton. \\n\\nDan terakhir, taruh Api Jiwa sebagai pengganti Api untuk merasuki Item! Ini akan mengubah Item menjadi varian Nether atau Item yang benar-benar berbeda."]
	quest.1E9B2D814F50A265.quest_subtitle: "Ini benar-benar meniup!"
	quest.1E9B2D814F50A265.title: "&6Kipas Berselubung"
	quest.1E9BD4B74DAEA9FC.quest_desc: ["Untuk menarik lebah ke sarang ini, kamu butuh Popped Chorus Fruit sebagai pengganti Honey Treat."]
	quest.1E9BD4B74DAEA9FC.quest_subtitle: "Memancing Ender Bee saat diletakkan di dimensi End"
	quest.1EA02BA24AF02256.quest_desc: ["Templat Paduan Gerhana digunakan untuk meningkatkan armor dan alat Celestigem ke Paduan Gerhana sambil mempertahankan mantra dan upgrade yang terpasang."]
	quest.1EABF2E7AE7B8F22.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_netherite.png width:100 height:150 align:center}"]
	quest.1EABF2E7AE7B8F22.title: "&8Netherite&r"
	quest.1EB04FE105ACA4BE.quest_desc: ["Waktu &9Warden&r mati dia punya kemungkinan drop &9Heart of the Deep&r. \\n\\nIni bisa dipake buat &6&lATM Star&r, atau buat ngaktipin Portal di Ancient City! \\n\\nGak boleh ada apapun di Portal buat ngaktifinnya, termasuk &9Sculk&r!"]
	quest.1EB04FE105ACA4BE.title: "&9Heart of the Deep"
	quest.1EB887F8072439A3.quest_desc: ["Setelah menggunakan &9Fatma's Incentivized Attraction&r untuk memanggil &9Marid Crusher&r, kamu bisa mengubah Ice, Packed Ice, dan Blue Ice menjadi bentuk hancurannya, lalu gunakan untuk menciptakan Light Blue Chalk."]
	quest.1EB887F8072439A3.title: "&bLight Blue Chalk (Kapur Biru Muda)"
	quest.1EBD5E4410A6DF34.quest_subtitle: "Berikan Ghostly Bee sebuah Soulium Dagger"
	quest.1EBD5E4410A6DF34.title: "Soulium Bee"
	quest.1EBF234015B26F15.quest_desc: ["Armor dasar yang ditambahkan oleh &a&lRoots Classic&r, kamu butuh sebuah Ritual untuk mendapatkannya!"]
	quest.1EBF234015B26F15.quest_subtitle: "14"
	quest.1EBF234015B26F15.title: "&2Sylvan Gear"
	quest.1ECD4331DDFBBB52.quest_desc: ["Torreya Tree adalah Pohon ungu/pink gede yang tingginya sekitar 40 Blok. \\n\\nDaunnya bakal tumbuh ke semua arah dan Torreya Vine menggantung dari mereka."]
	quest.1ECFA72CF2BA4B45.quest_desc: ["Penjatuh sederhana dan kamu bisa atur jumlah yang dijatuhkan sekaligus."]
	quest.1EECA19DF9CF6A0C.quest_desc: ["Flux Dust juga bisa diotomatisasi menggunakan &6XyCraft&r!\\n\\nLetakkan charged redstone crystal block di atas bedrock, kelilingi kristal tersebut dengan 4 obsidian di semua sisi, lalu pasang extractor di atasnya.\\nKemudian cukup pasang penyimpanan di atas extractor dan selesai!"]
	quest.1EECA19DF9CF6A0C.title: "Otomatisasi Flux Dust"
	quest.1F114EB0AAB86DB4.quest_desc: ["Market kasih kamu villager yang bisa jual apapun kalau kamu punya emerald yang cukup.\\n\\nSpoiler: Biasanya cuma 1 Emerald per item, untungnya, mereka punya SEMUA."]
	quest.1F114EB0AAB86DB4.quest_subtitle: "Villager punya lebih dari satu cara untuk Spawn"
	quest.1F114EB0AAB86DB4.title: "Beli Perlengkapan Farm"
	quest.1F146FE1002643B2.quest_subtitle: "Brazilwood + Rose Gum"
	quest.1F18B64C84C8809D.title: "&l&9Overworld Bounty:&r&e Spiders"
	quest.1F1B4948FCC14BB4.quest_subtitle: "Silver Fir + Spruce"
	quest.1F21B578FAF4CCAC.quest_subtitle: "Sama seperti versi uap"
	quest.1F31EBF49079F9D3.quest_desc: ["Overhauled Creepers memberikan kita banyak varian Creeper yang berbeda untuk biome yang berbeda pula. \\n\\nMasing-masing punya drop yang berbeda dan bahkan ada yang jinak! \\n\\nTapi semuanya tetap takut pada kucing..."]
	quest.1F31EBF49079F9D3.title: "Perombakan Creeper"
	quest.1F3E18129B871C49.quest_subtitle: "Sama seperti versi uap"
	quest.1F55A483008F74FE.quest_desc: ["&bUltra Constructor&r memiliki 36 slot filter, bekerja 5x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.1F55A483008F74FE.title: "&bUltra Constructor"
	quest.1F6C8117F3CED939.title: "&6Allthemodium Bow"
	quest.1F7591DB6D8EC1E7.quest_desc: ["Buff:\\n\\n - Absorption II (3:00)\\n - Speed II (3:00)\\n - Resistance II (3:00)\\n - Regeneration II (3:00)\\n - Strength II (3:00)\\n - Haste II (3:00)"]
	quest.1F7591DB6D8EC1E7.title: "&5Apel Insanium"
	quest.1F7D147C9AF6A4FC.quest_desc: [
		"Tier 4 berbeda. Pertama, butuh 26 Redstone Blocks menutup Core. Lalu di atas Redstone butuh 56 Draconium Ingot Blocks."
		"{image:atm:textures/questpics/draconic/draconic_core_4off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_4on.png width:100 height:100 align:1}"
	]
	quest.1F7D147C9AF6A4FC.quest_subtitle: "Menyimpan: 9,880,000,000 RF"
	quest.1F7D147C9AF6A4FC.title: "Tier 4"
	quest.1F7DA060792D716A.quest_desc: [
		"&d&lPengaduk&r sama seperti yang digunakan Ibu/Nenek untuk mencampur telur ke dalam tepung dan gula untuk memanggang apa pun yang lezat! \\n\\n&d&lPengaduk&r akan mencampur &eBarang&r dan &bCairan&r. Untuk memasukkan &bCairan&r, kita perlu menggunakan Port di Sisi Kiri &d&lPengaduk&r. Untuk memberinya &eBarang&r, kita perlu menggunakan Port di belakang. \\n\\nAgar berfungsi, diperlukan &cEnergi&r yang dimasukkan dari Port di Atas Depan &d&lPengaduk&r. \\n\\nSetelah dicampur, hasilnya akan keluar dari Port di Depan Mesin!"
		"{@pagebreak}"
		"Lapisan pertama &d&lPengaduk&r dibangun seperti Simbol Wifi! Pertama adalah &eBlok Teknik Ringan&r, lalu &bPipa Cairan&r, dan &8Perancah Baja&r."
		"{image:atm:textures/questpics/immersive/immersive_mixer1.png width:100 height:100 align:center}"
		"Di atas &eBlok Teknik Ringan&r kita akan meletakkan yang lain dan satu di sebelah kiri yang baru ditempatkan. Di &8Perancah&r kanan jauh kita akan meletakkan &4Blok Teknik Redstone&r. Kemudian, kita akan meletakkan 2x2 &7Lembar Besi&r di bagian belakang Mesin kita."
		"{image:atm:textures/questpics/immersive/immersive_mixer2.png width:100 height:100 align:center}"
		"Di atas &eBlok Teknik Ringan&r ketiga kita akan meletakkan satu &8Pagar Baja&r, dan di sebelah kanannya akan menjadi &eBlok Teknik Ringan&r keempat."
		"{image:atm:textures/questpics/immersive/immersive_mixer3.png width:100 height:100 align:center}"
		"Untuk membuat &d&lPengaduk&r Klik Kanan &7Lembar Besi&r antara &eBlok Teknik Ringan&r dan &4Blok Teknik Redstone&r dengan &6Palu Insinyur&r!"
		"{image:atm:textures/questpics/immersive/immersive_mixer.png width:100 height:100 align:center}"
	]
	quest.1F7DA060792D716A.title: "&l&dPengaduk"
	quest.1F7DFA5AA65F2812.quest_desc: ["&bAcceleration Card&f, tergantung pada perangkat yang ditingkatkan, akan meningkatkan kecepatan operasi perangkat atau memungkinkan perangkat melakukan lebih banyak operasi sekaligus.\\n\\nDalam kasus &eMolecular Assembler&f, set lengkap isi 5 kartu akan mengurangi waktu pembuatan dari satu detik menjadi hanya satu &otick&r."]
	quest.1F7DFA5AA65F2812.title: "Acceleration Card"
	quest.1F81EA5E45424308.quest_desc: ["Jika kamu mencari berbagai cara untuk menyalurkan daya dari mesinmu, di sinilah tempatnya!\\n\\nAda beberapa opsi, baik &akabel&r maupun &9nirkabel&r, untuk mentransfer daya."]
	quest.1F81EA5E45424308.title: "&f&lTransfer Daya"
	quest.1F88C697817A7680.quest_desc: ["Buff:\\n\\n - Absorption II (3:00)"]
	quest.1F88C697817A7680.title: "&aApel Inferium"
	quest.1F8B4F648EB5A0DC.quest_desc: ["Lagi nggak suka pakai Drawer? Lebih suka Backpack? Kalau gitu kamu butuh Personal Chest/Barrel! \\n\\nKeduanya fungsinya sama persis. Setelah crafting, Klik Kanan barangnya buat atur kamu sebagai pemiliknya. \\n\\nNanti cuma kamu yang bisa buka Chest/Barrel ini. Oh iya, kamu bisa buka ini langsung dari Inventory atau ditaruh kayak Chest biasa. \\n\\nPunya 54 Slot tapi nggak bisa dipasang upgrade..."]
	quest.1F8BC2A4CF055038.quest_subtitle: "Ender Pearl yang Bisa Dipakai Ulang"
	quest.1FA44E8FEE004AB4.quest_desc: ["Tali Rami dan &8Kabel Baja&r ditempatkan seperti &cKabel&r normal pada &cKonektor &fdan &cRelay&r tetapi tidak akan mentransfer &cEnergi&r. \\n\\nSebaliknya untuk Dekorasi atau menggunakan &6&lSkyhook Insinyur&r!"]
	quest.1FA44E8FEE004AB4.title: "Aman untuk penggunaan &6&lSkyhook&r!"
	quest.1FAFDB20F504688E.quest_desc: ["Sistem &5Enchanting&r mendapat beberapa perubahan dengan mod &5&lApotheosis&r. \\n\\nSingkatnya, 15 &7Rak Buku&r biasa saja tidak akan cukup lagi sekarang. \\n\\nAda rak buku baru dan tindakan baru yang bisa kamu lakukan pada &5Enchantment Table&r, dan semoga quest-quest ini membantumu memahaminya."]
	quest.1FAFDB20F504688E.title: "&5&lApothic Enchanting"
	quest.1FC1588A131B6A4A.quest_desc: ["Sama kayak bikin &6&lATM Star&r biasa, otomatisasinya harus dilakukan di dalam &6&lRunic Star Altar&r! \\n\\nCek quest di Chapter 3 buat belajar cara bangun dan pakainya."]
	quest.1FC1588A131B6A4A.title: "&6&lRunic Star Altar"
	quest.1FC7ABEAB5018E79.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_redstone.png width:100 height:150 align:center}"]
	quest.1FC7ABEAB5018E79.title: "&4Redstone&r"
	quest.1FC88A3BFCE6C9D7.quest_desc: ["Ini cuma Enchantment Swift Sneaking... tapi jadi &7Unit&r sekarang!"]
	quest.1FC88A3BFCE6C9D7.quest_subtitle: "Celana"
	quest.1FC88A3BFCE6C9D7.title: "&8Motorized Servo &7Unit"
	quest.1FCC474860587169.quest_desc: ["Buat dapetin resep selanjutnya kamu kemungkinan besar butuh &6Smelter Prism&r dan jangan khawatir kita cuma butuh Tier 1 Forge buat dapetin! \\n\\nKamu bisa cek berapa banyak Stat yang dibutuhin di Forge lewat JEI! Plus kamu butuh 4 &6Blaze Powder&r, 2 &8Coal&r, dan &bArcane Crystal&r. \\n\\nTerakhir, kamu butuh &9Elementarium&r yang bisa ditemuin di Jungle Temple, Desert Pyramid, dan Underwater Ruins!"]
	quest.1FCC474860587169.title: "&6Smelter Prism"
	quest.1FCF946B7BE3C0BD.quest_desc: ["Peralatan &cUtherium&r mirip dengan peralatan Diamond, tapi senjatanya jauh lebih efektif melawan &cRot Mobs&r! \\n\\nKamu menggunakan material mereka untuk memberikan damage lebih besar kepada mereka!"]
	quest.1FCF946B7BE3C0BD.title: "Peralatan &cUtheric&r"
	quest.1FD60B7448CED1EB.quest_desc: ["Mod &b&lMacaw&r ini menambahkan tipe baru untuk Pagar, Gerbang, dan Dinding. \\n\\nYa, kawat berduri itu akan melukaimu. \\n\\nTidak, kamu tidak bisa melompati mereka secara normal."]
	quest.1FD60B7448CED1EB.title: "Pagar dan Dinding &b&lMacaw's"
	quest.1FDC8725105D822A.quest_desc: ["Set Dapur memiliki banyak blok yang bisa menyimpan, mengawetkan, dan memasak makanan! \\n\\nSebagian besar blok yang memasak atau menyiapkan makanan membutuhkan energi, jadi cek Set Elektrik untuk mempelajari lebih lanjut!"]
	quest.1FDC8725105D822A.title: "Set Dapur"
	quest.1FE052F643401232.quest_desc: ["Kamu akan membutuhkan item ini untuk membuat berbagai Upgrade Tas."]
	quest.1FE052F643401232.quest_subtitle: "Bahan Dasar Upgrade"
	quest.1FE17B1C7C639F88.quest_desc: ["Storage Controller memungkinkanmu mengelola banyak penyimpanan seolah-olah mereka adalah satu kesatuan besar.\\n\\nIni memungkinkan jaringan penyimpanan yang sangat luas, yang bisa digabung dengan mod seperti Applied Energistics atau Integrated Dynamics, karena Storage Controller bertindak sebagai titik masuk/keluar untuk semua penyimpanan yang terhubung.\\n\\nMenghubungkannya cukup dengan menaruh penyimpanan di sebelah Storage Controller atau di sebelah penyimpanan lain yang sudah terhubung (berlaku hingga jarak 14 blok)."]
	quest.1FE47F03B5DF492D.quest_desc: ["{image:atm:textures/questpics/allthemodium/all_armor_unoarcane.png width:100 height:175 align:center}"]
	quest.1FE47F03B5DF492D.title: "&5Unobtainium Arcanist Armor"
	quest.1FE7C52491E7499B.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Bantuan Tangga"
		"- Dorongan Lompat"
		"- Injakan Tanah"
		"- Tolak Kerusakan Jatuh"
	]
	quest.1FF5906DF721D091.quest_desc: ["&2Hydra&r menjatuhkan &cFiery Blood&r yang bisa digunakan untuk membuat &cFiery Armor&r.\\n\\nSaat memakai satu set lengkap, musuh yang menyerangmu akan terbakar selama 10 detik."]
	quest.1FF5906DF721D091.title: "Armor &cFiery"
	quest.1FF82E21F1C0C73B.quest_subtitle: "Tingkat: &c5"
	quest.1FFA1DA6A5EA4E70.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Bantuan Tangga"
		"- Dorongan Lompat"
		"- Injakan Tanah"
		"- Tolak Kerusakan Jatuh"
		"- Gempa Bumi"
	]
	quest.1FFF00B5D90C3905.quest_desc: ["Kamu bisa dapet &cMundabitur Dust&r lewat banyak cara, jadi aku kasih info singkat soal &bArcane Crystal&r aja! \\n\\nYa, ini bahan crafting kalau kamu mau bikin sendiri. \\n\\nKamu harus nambang &bArcane Crystal&r dulu; setelah itu, baru bisa pakai &2&lMA&r atau &6&lBees&r buat dapet lebih banyak!"]
	quest.1FFF00B5D90C3905.title: "&bArcane Crystals"
	quest.2001998045ABC04C.quest_desc: ["Tangled Hatred adalah Minibos di Eternal Starlight. \\n\\nIa muncul di Cursed Garden bersama dengan Lunar Monstrosity."]
	quest.2001998045ABC04C.title: "Kalahkan Tangled Hatred"
	quest.2002AB7D061007FA.quest_desc: ["&6Artisan Relic&r ditemukan di beberapa Bangunan di Village. \\n\\nSaat dipakai di &l&bClibano&r akan memungkinkan kamu bikin &5Obsidiansteel&r. \\n\\nSaat dipakai di &6&lForge&r akan kasih diskon &aExperience&r yang dipakai!"]
	quest.2002AB7D061007FA.title: "&6Artisan Relic"
	quest.2002C7EB13626AE7.quest_desc: ["&6&lAugmenting Table&r butuh bahan bakar khusus, yaitu &6Sigil of Enhancement&r. \\n\\nSetiap Reroll membutuhkan 1 &6Sigil of Enhancement&r, sedangkan setiap Upgrade membutuhkan 2! \\n\\nKamu butuh satu &6Godforged Pearl&r untuk membuat 4 buah Sigil ini."]
	quest.2002C7EB13626AE7.title: "&6Sigil of Enhancement"
	quest.20054D077AFE3F56.quest_desc: ["Kita udah dapet &3Plutonium&r dan sisanya yang harusnya kita udah punya! \\n\\nYaitu &2&lP.R.C.&r, &9Air&r, sama &dFluorite Dust&r! \\n\\nGabungin 1,000mB &9Air&r, dengan 1,000mB &3Plutonium&r, sama 1 &dFluorite Dust&r buat bikin 1 &3Plutonium Pellet&r dan 1,000mB &8Spent Nuclear Waste&r. \\n\\n&dFluorite Dust&r bisa dibuat kayak Metal Dust pada umumnya: &4&lCrusher&r, &d&lEnrichment Chamber&r, atau bahkan Ore Hammer!"]
	quest.20054D077AFE3F56.title: "&3Plutonium Pellet"
	quest.2007EF64F0406090.quest_subtitle: "&f24 &cAttack Damage"
	quest.200ECDC70E97D254.quest_desc: ["Tabung Bahan Bakar adalah tangki yang bisa mengisi wadah dengan cairan yang ada di dalamnya.\\n\\nTabung Bahan Bakar punya tiga mode pengisian:\\n\\n - Tidak Ada\\n - Apa Saja\\n - Just Dire Things"]
	quest.2011638351B67396.quest_desc: ["Dengan 2 &9Essence of the Storm&r dan 3 &9Lacrima&r kita bisa membuat &9Astrape&r. \\n\\n&9Astrape&r adalah gabungan dari senjata yang digunakan &9Hippocamtus&r dan &9Cindaria&r. \\n\\nIa bisa menusuk seperti Trident, namun dengan Damage dan Jarak yang lebih besar. Plus kamu bisa Menahan Klik Kanan untuk melempar &9Tombak Petir&r, sama seperti &9Cindaria&r! \\n\\n&9Tombak Petir&r ini tetap memantul di dinding! Cuma sekarang ada Cooldown-nya..."]
	quest.2011638351B67396.title: "&9Astrape"
	quest.201E3E41018F9521.quest_desc: ["&6Gloomy Cacti&r sama seperti &2Cacti&r normal, cuma ini tumbuh di &cOvercast Columns&r. \\n\\nMaksudku mereka suka Panas, tidak butuh &9Air&r untuk tumbuh, sakit kalau disentuh, emang ada bedanya? \\n\\nOh ya, ini bisa di-Smelt jadi &6Orange Dye&r bukan &2Green&r!"]
	quest.201E3E41018F9521.title: "&6Gloomy Cacti"
	quest.201EE3566D4D3123.quest_desc: [
		"Untuk menambang &6Allthemodium&r, kamu butuh Pickaxe tingkat &cNetherite&r atau lebih tinggi! \\n\\nSetelah akhirnya mendapatkan Ore-nya (aku sarankan memprosesnya dulu lewat Fortune, Occultism, atau Mekanism agar dapat lebih banyak), kamu punya beberapa pilihan. \\n\\nAku sarankan buatlah 2 Teleport Pad dengan &6Nugget&r-nya! Kamu bisa memakainya untuk pergi ke &7&lMining Dimension&r guna mencari lebih banyak &6Allthemodium&r, atau ke &b&lThe Other&r untuk petualangan lain. \\n\\nSetelah itu, aku sarankan tingkatkan Pickaxe-mu agar bisa menambang &3Vibranium&r. Sisanya terserah padamu!"
		"{image:atm:textures/questpics/allthemodium/all_1.png width:100 height:100 align:center}"
	]
	quest.201EE3566D4D3123.title: "&6Allthemodium Ingot"
	quest.202B1F54D3F06DAB.quest_desc: ["Ini adalah Essence Tingkat 6, dibuat dengan nggabungin 4 Supremium dengan Kristal Infus."]
	quest.202B1F54D3F06DAB.quest_subtitle: "Tingkat: &56"
	quest.202B1F54D3F06DAB.title: "&5Insanium"
	quest.203C91B992BA8CF9.quest_desc: ["Untuk membuat ulang &6&lATM Star&r, kita butuh Infused &dPatrick &aStar&r, yang juga butuh &dPatrick &aStar&r biasa. Keduanya dibuat lewat &6&lRunic Star Altar&r. \\n\\nItem lain yang dibutuhin buat Infused &dPatrick &aStar&r adalah 4 &5Mending Book&r dan &dInfused Dragon's Breath&r yang didapat dari &5&lRunic Enchanting&r. \\n\\n&6Star Shards&r didapat dari lebah (Bees) kita! \\n\\nDan Ingot Alloy: &3Vibranium&f-&6Allthemodium&r, &5Unobtainium&f-&6Allthemodium&r, dan &5Unobtainium&f-&3Vibranium&r Ingot. \\n\\nKetiganya dibuat dengan cara unik masing-masing yang dijelasin di chapter &6&lAllthemodium&r! \\n\\nCemplungin semuanya ke &6&lRunic Star Altar&r, tambah 85MFE, dan jadilah Infused &dPatrick &aStar&r!"]
	quest.203C91B992BA8CF9.title: "Infused &dPatrick &aStar"
	quest.20436AFCC7E6855D.quest_desc: ["Dengan Magic Bean dan Uberous Soil, carilah awan besar di biome dataran tinggi (highland).\\n\\nTanam magic bean di tanah tersebut untuk menumbuhkan pohon kacang yang menjulang ke atas. Di sana, kamu akan menemukan para Raksasa (Giant).\\n\\nKamu perlu membunuh Miner Giant dan mengambil beliungnya untuk melanjutkan perjalanan."]
	quest.20436AFCC7E6855D.quest_subtitle: "Para raksasa terlihat mirip denganku, tapi sama sekali TIDAK sepertiku"
	quest.204B969DA081056A.quest_desc: [
		"Mereka bisa spawn hampir di mana saja Mob Hostile &2Vanilla&r spawn. Mereka bukan boss, hanya Musuh tambahan! \\n\\nMereka punya 25 poin &cHealth&r dan punya beberapa serangan: &aFang&r dari tanah seperti yang dilakukan &aEvoker&r dan &bSnowball&r yang bisa mereka tembakkan padamu. \\n\\nMereka juga bisa memanggil Zombie dan Skeleton untuk membantu melawanmu. Mereka tidak akan menjatuhkan apa-apa dan spawn dengan Armor dari tanah. \\n\\nMereka akan menjatuhkan Arcane Essence saat mati bersama dengan kadang-kadang &3Scroll&r!"
		"{image:atm:textures/questpics/iron_spells/spells_necromancer.png width:100 height:200 align:center}"
	]
	quest.204B969DA081056A.title: "Necromancer"
	quest.205DE46ABA1CCC8F.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.205DE46ABA1CCC8F.title: "Conductive Alloy Bee"
	quest.206918773B0BD7A0.title: "Yang Terakhir yang Pertama"
	quest.2077D64428E9C067.quest_desc: [
		"Konsep penting dalam AE2 adalah teknik yang dikenal sebagai '&esubnetting&f', di mana jaringan ME tambahan yang terpisah (sebuah &esubnetwork&f) bekerja bersama jaringan utama untuk melakukan fungsi khusus. "
		""
		"Yang membedakan subnetwork dari jaringan terpisah sepenuhnya adalah penggunaan &bQuartz Fiber&f. Saat diletakkan di antara dua kabel yang tidak terhubung, Quartz Fiber tidak mentransfer data atau channel sama sekali, melainkan hanya menyalurkan daya listrik. "
		""
		"Dengan demikian, subnetwork di sisi lain Fiber dapat ditenagai sepenuhnya oleh sumber daya jaringan utama tanpa memerlukan pembangkit listrik tambahan."
	]
	quest.2077D64428E9C067.quest_subtitle: "Bukan Cuma Buat Crafting Kabel"
	quest.2077D64428E9C067.title: "Tentang Subnetwork"
	quest.2086C73688C8BA51.quest_subtitle: "Berikan satu ember Sulfuric Acid ke Lava Bee"
	quest.2086C73688C8BA51.title: "Sulfuric Acid Bee"
	quest.2094D1CE4BA66091.quest_desc: ["Cahaya adalah bagian yang sangat penting dari setiap markas. \\n\\nIa menjaga agar monster tidak muncul, membantumu melihat, dan bahkan menambah lebih banyak warna dan kehidupan pada bangunanmu! \\n\\nAtau kamu bisa saja pakai Night Vision, tapi di mana serunya kalau begitu!"]
	quest.209DC1E9AD4C5A84.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.20C3AADEE2D4800D.quest_desc: [
		"Kamu juga bisa memindahkan Cairan dari satu tangki ke tangki lain dengan &cMercury&r. \\n\\nPasang Fluid Extractor di tempat asal cairan, seperti wastafel (Sink). Kemudian pasang Fluid Inserter di tempat tujuan, seperti &dSal Ammoniac&r Accumulator. Hubungkan keduanya dengan Kabel dan cairan akan mulai mengalir!"
		"{image:atm:textures/questpics/theurgy/theurgy_fluid.png width:200 height:75 align:center}"
	]
	quest.20C3AADEE2D4800D.title: "Pemindahan Cairan"
	quest.20D4568857887D38.quest_desc: ["Terkadang Router berada di situasi berbahaya, seperti saat memunculkan Wither. \\n\\nAgar terlindungi, kamu butuh Blast Upgrade. \\n\\nTNT tidak akan menghancurkannya, Wither tidak akan menghancurkannya, cuma kamu yang bisa."]
	quest.20D8DA523E900A52.quest_desc: ["Wireless Energy Links membantu membuat Wireless Crystals bisa mengisi item-mu. Semakin banyak module, semakin banyak OP yang bisa diambil dengan rate lebih baik."]
	quest.20D8DA523E900A52.title: "Wireless Energy Link"
	quest.20DDAC076A2479A8.quest_subtitle: "Purple Spiral + Sparkle Cherry"
	quest.20E5C888891FBCFE.quest_desc: ["Saat dipegang di tangan kiri, semua mob di sekitar akan berhenti menyerangmu. \\n\\nBaik kamu yang memancing kemarahan mereka atau mereka memang pemarah dari sananya, mereka akan tenang. \\n\\nMemiliki 600 kali penggunaan dan setelah habis atau terinterupsi, ia butuh 10 menit di inventarismu untuk mengisi daya kembali. \\n\\nEfeknya bisa terhenti jika kamu terkena damage saat aktif atau jika kamu memukul mob."]
	quest.20E5C888891FBCFE.title: "&bEssence of Calming"
	quest.20EC8001A05CE2C8.quest_desc: ["Wireless Heat adalah cara yang seru dan gampang buat ngasih power ke Furnace. Pertama taro Wireless Heat Transmitter dan masukin Energi ke dalamnya. Terus masukin Receiver ke Transmitter buat nge-bind. Terakhir taro Receiver ke bagian Fuel Furnace buat mulai ngasih power!"]
	quest.20F9EF925DB1CE05.quest_desc: ["&2Natural Altar&r adalah struktur multiblock yang terbuat dari 1 blok Natural Altar, 20 Papan Kayu (Plank), 16 Stone Brick, 8 &eGolden Stone Brick&r, dan 4 Chiseled Stone Brick.\\n\\nNatural Altar akan mengonsumsi aura untuk setiap resep dan dibutuhkan untuk melanjutkan progres di mod ini.\\n\\nGambar di sebelah kanan quest ini menunjukkan cara menyusun multiblock-nya."]
	quest.20F9EF925DB1CE05.title: "&2Natural Altar"
	quest.210542B036255FBF.quest_desc: [
		"Semoga kamu punya Sarung Tangan Karet buat Bangun Multiblock 3x3x3 ini! Gak punya? Ya udah! \\n\\nPertama, taro salib dari &5Bata Pemalsuan Naga Petir&r dengan &7Blok Tulang Naga&r di sampingnya. "
		"{image:atm:textures/questpics/iceandfire/chap3_light1.png width:100 height:100 align:center}"
		"Terus, taro &5Blok Inti Pemalsuan Naga Petir&r di tengah. Di sampingnya, taro &5Aperature Pemalsuan Naga Petir&r dan isi sisanya dengan &5Bata Pemalsuan Naga&r! "
		"{image:atm:textures/questpics/iceandfire/chap3_light2.png width:100 height:100 align:center}"
		"Layer terakhir familiar... Mungkin karena ini cuma layer pertama!"
		"{image:atm:textures/questpics/iceandfire/chap3_light4.png width:100 height:100 align:center}"
		"{@pagebreak}"
		"Beberapa Item harus di-&5Setrum&r dengan Energi buat dipaksa jadi satu! Bukan, bukan FE, AE, atau MF... kita butuh apa? \\n\\nJadi kenapa gak pake &dSihir &fdari &5&lNaga&r! Dengan &5&lPemalsuan Naga Petir&r! \\n\\nTaro Item-nya ke &5&lPemalsuan Naga&r dan &5Setrum&r dengan &5Serangan Petir&r dari &5&lNaga Petir&r. \\n\\n&5&lNaga&r-nya bisa Jinak atau Liar, tapi yang Liar gak terlalu baik atau tenang... jadi pastiin mereka gak bisa kabur dengan pake Rantai!"
	]
	quest.210542B036255FBF.title: "&5&lPemalsuan Naga Petir"
	quest.21147C8CBF98AEB4.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penebang Pohon"
		"- Penghancur Daun"
		"- Pelebur Otomatis"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.211FD55DEB635A98.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_copper.png width:100 height:150 align:center}"]
	quest.211FD55DEB635A98.title: "&6Copper&r"
	quest.212EC1F41227184D.quest_desc: ["Apakah kamu ingin menembakkan Ender blast seperti sang &eLich&r? Jika ya, &9Scepter of Twilight&r adalah tongkat yang tepat untukmu!.\\n\\nUntuk mengisinya kembali, gabungkan dengan &5Ender Pearl&r di meja crafting."]
	quest.212EC1F41227184D.quest_subtitle: "Menembakkan Ender Blast"
	quest.212EC1F41227184D.title: "&9Scepter of Twilight"
	quest.212EF8601746C500.quest_desc: ["Buff:\\n\\n - Absorption II (3:00)\\n - Speed II (3:00)\\n - Resistance II (3:00)\\n - Regeneration II (3:00)"]
	quest.212EF8601746C500.title: "&9Apel Imperium"
	quest.21398F45428CD1D1.quest_desc: ["&6Bloom Berries&r tumbuh dari &bGlowing Vines&r di atap &bBlooming Caverns&r. \\n\\nDi dalam &bGlowing Vines&r, &6Bloom Berries&r mungkin muncul dan akan menunggu kamu memetiknya dari &bVine&r dengan Klik Kanan! \\n\\nIni satu-satunya Sumber Makanan di &3&lOtherside&r."]
	quest.21398F45428CD1D1.title: "&6Bloom Berries"
	quest.2149833F65D523E5.quest_desc: [
		"Mirip dengan &6B&8e&6e&r Cannon, Crystal Cannon bisa dibuat, ditemukan di struktur, atau ditukar dengan &5Bee Queen&r. \\n\\nAlat ini digunakan seperti Crossbow. Jika kamu punya &5Honey Crystal Shard&r di inventaris, Tahan Klik Kanan untuk memasukkan &5Kristal&r dan lepaskan untuk menembakkannya!"
		"{image:atm:textures/questpics/bumblezone/bumble_cannon1.png width:75 height:150 align:center}"
	]
	quest.2156C00E30424844.quest_desc: ["&4Tank&r dibuat untuk memasukkan cairan ke dalam &c&lFoundry&r kita. \\n\\nTerutama Bahan Bakar. \\n\\nTerutama &cLava&r! \\n\\nSepertinya itu adalah satu-satunya cara untuk memberi bahan bakar pada &c&lFoundry&r."]
	quest.2156C00E30424844.title: "&4Tank&r &c&lFoundry&r"
	quest.2158A566C2F54AA9.title: "Draconic Shield Control Module"
	quest.215AD616E6847E9A.quest_desc: ["Setiap &5Insanium Gemstone&r itu 2 &5Insanium Essence&r. Jadi setiap &5Gemstone Block&r itu 18 &5Insanium Essence&r. \\n\\nItu artinya kita bisa ambil 9,216 &aInferium Essence&r buat &5Insanium Block&r dan dobelin jadi 18,432 &aInferium Essence&r cuma buat 4 &5Insanium Gemstone Block&r."]
	quest.215AD616E6847E9A.title: "4 &5Insanium Gemstone Block"
	quest.215C9C2B2240FAA1.quest_desc: ["&5Electric Armor&r dari mod &e&lIron's Spells&r!"]
	quest.215C9C2B2240FAA1.quest_subtitle: "20"
	quest.215C9C2B2240FAA1.title: "&5Electromancer Outfit"
	quest.21624A6500545C42.quest_desc: [
		"&3Crop Support&r dapat diletakkan di atas tanamanmu agar tumbuh lebih cepat."
		""
		"{image:atm:textures/questpics/pneumaticcraft/crop_support.png width:200 height:100 align:center}"
	]
	quest.21624A6500545C42.quest_subtitle: "Tanaman Lebih Cepat"
	quest.21693C4DE6531D73.quest_desc: [
		"Crusher bekerja sesuai namanya (Penghancur). Alat ini bisa menghancurkan blok untuk mendapatkan material crafting, seperti brick dari tangga brick, atau debu (dust) dari ingot. \\n\\nMesin ini butuh energi untuk bekerja! \\n\\nStrukturnya berukuran 3x2x2 blok Crusher."
		"{image:atm:textures/questpics/railcraft/rail_crusher.png width:100 height:100 align:center}"
	]
	quest.21693C4DE6531D73.title: "Crusher"
	quest.216DA9782EBDFF34.quest_desc: ["Menurut gue Mod ini gak realistis. Gue gak peduli Buku atau Item apa yang kamu punya, gue gak percaya yang Demonic bakal nurut perintah kamu dan kerja kayak budak. \\n\\nTerlepas dari itu kamu bisa ikutin Quest buat ngelakuinnya."]
	quest.216DA9782EBDFF34.title: "&b&lOccultism"
	quest.2171DC0B13C4BD43.quest_desc: ["&a&lRoots Classic&r mungkin keliatan kecil di JEI tapi gue janjiin ada banyak banget di dalamnya! \\n\\nRoots itu semua tentang pake hadiah alam buat bikin ritual.\\n\\nPercaya deh kamu bakal nemuin item-item ini di mana-mana!"]
	quest.2171DC0B13C4BD43.title: "&a&lRoots Classic"
	quest.217DB12EA32E1724.quest_desc: ["&bKristal Infus&r dibutuhin buat \"naik tingkat\" benih. Contohnya kalau kamu gabungin kristal sama 4 Inferium Essence kamu bakal dapet 1 Prudentium Essence.\\n\\nNanti kamu bisa craft Kristal Infus yang gak bakalan rusak."]
	quest.217DB12EA32E1724.title: "&bKristal Infus"
	quest.217DF3B66A07A8DE.quest_desc: [""]
	quest.217DF3B66A07A8DE.quest_subtitle: "&oTaman Eden cuma dalam satu Biji."
	quest.217DF3B66A07A8DE.title: "&3&lDimensional &2Seed"
	quest.2182492BCC1B33D8.quest_desc: ["Saat dipasang di sarang, memberikan 5% peluang bayi lebah baru muncul setiap kali madu dikirimkan.\\n\\nSaat ditaruh di Catcher, alat tersebut hanya akan menangkap bayi lebah.\\n\\nUpgrade ini bisa ditumpuk (stack) untuk peluang yang lebih besar."]
	quest.2182492BCC1B33D8.quest_subtitle: "Memproduksi Bayi"
	quest.2188C52C1F384DE4.quest_desc: [""]
	quest.2188C52C1F384DE4.quest_subtitle: "&oBahan bakar yang selalu terbakar (enggak juga)."
	quest.2188C52C1F384DE4.title: "&c&lPhilosopher's Fuel"
	quest.219932CB19258C16.quest_desc: ["Tingkat ketiga dari komponen penyimpanan, menyediakan &e16.384&f byte penyimpanan."]
	quest.219932CB19258C16.quest_subtitle: "x4^2"
	quest.219932CB19258C16.title: "Komponen Penyimpanan 16k"
	quest.219A5BDA5A01A420.quest_desc: ["&4Kristal Infus Master&r kerjanya sama kayak Kristal Infus tapi gak pernah rusak."]
	quest.219A5BDA5A01A420.title: "&4Kristal Infus Master"
	quest.219AA017149C36E2.quest_desc: ["Trapped Trader Carpet akan membunuh setiap Wandering Trader (Pedagang Keliling) yang muncul di dekatnya secara instan!\\n\\nMungkin ini adalah item terbaik di seluruh modpack ini."]
	quest.219AA017149C36E2.quest_subtitle: "Tidak Ada Lagi Pedagang yang Mengganggu!"
	quest.21A0FD474FBB49F7.quest_desc: [
		"Satu lagi struktur untuk mengisi kekosongan di dimensi &5The End&r, yaitu &dRuined Citadel&r. \\n\\n&dRuined Citadel&r adalah sebuah Istana yang terbuat dari &5Obsidian&r, Endstone, dan &dPurpur&r. \\n\\nDi dalam istana kamu akan menemukan Peti, Shulker Box, Shulker, dan bahkan blok unik &dVoid Stone&r! \\n\\nBerhati-hatilah terhadap Shulker, &dEndermaptera&r, dan &dEnder Golem&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_citadel.png width:200 height:100 align:center}"
	]
	quest.21A0FD474FBB49F7.title: "&dRuined Citadel&r: Rumah sang &d&lEnder Guardian&r"
	quest.21A4FE1741E4E78C.quest_desc: [
		"&#65C2A6Quarry&r adalah struktur multiblock untuk menghasilkan sumber daya secara otomatis. Ia membutuhkan &aDrill&r dan &7Uap (Steam)&r untuk berfungsi."
		""
		"Setiap proses iterasi memiliki peluang untuk mengonsumsi &aDrill&r tersebut. &aDrill&r yang lebih baik akan memberikan sumber daya yang lebih berkualitas."
		""
		"Steam Quarry hanya bisa menggunakan &#DEA14BCopper Drill&r dan &#DE9531Bronze Drill&r. Alat ini juga bisa menggunakan &#8A5C1ETanah (Dirt)&r untuk menghasilkan batu-batuan."
	]
	quest.21A4FE1741E4E78C.quest_subtitle: "Sumber Daya Tak Terbatas"
	quest.21A90474590FCDB8.quest_desc: ["\"Tungku\" adalah versi upgrade dari Tungku vanilla yang bisa di-upgrade buat kecepatan lebih cepat dan efisiensi lebih baik."]
	quest.21A90474590FCDB8.title: "\"Tungku\""
	quest.21AB14A8553896E9.quest_desc: ["Guys kayaknya kalian salah denger gue bilang &e&lProductive Bees&r! Oh tunggu ada Mod lain! \\n\\nYang ini berhubungan sama &e&lProductive Bees&r karena kamu butuh mereka buat breeding Pohon. \\n\\nEnggak, Pohon gak pake Gandum buat breeding, mereka pake Lebah. \\n\\n&oThe Trees and the Bees&r."]
	quest.21AB14A8553896E9.title: "&2&lProductive Trees"
	quest.21B8116BDADD7476.quest_subtitle: "Papaya + Cacao"
	quest.21B96130EA516B82.quest_desc: ["\"Aku adalah Compressed Iron Man!\" \\n\\nArmor ini bisa digunakan dan ditingkatkan menggunakan udara bertekanan (Compressed Air)!"]
	quest.21B96130EA516B82.quest_subtitle: "15"
	quest.21B96130EA516B82.title: "&8Pneumatic Armor"
	quest.21BEE9867796933A.quest_desc: ["Yang satu ini sangat simpel. Pakai &9Sarung Tangan wol&r milikmu, ambil &fSalju&r, kepal jadi satu, dan Boom! Kamu baru saja membuat &fSnowball&r! Ini lebih baik daripada &fSnowball&r &2Vanilla&r, karena ini dibuat dengan &9Sarung Tangan&r!"]
	quest.21BEE9867796933A.quest_subtitle: "Ditemukan di Desa di Taiga atau Snowy Taiga"
	quest.21BEE9867796933A.title: "&9Wool Mittens"
	quest.21BFDE6AD1C0F62A.quest_desc: ["Tentu saja di dunia nyata ada lebih banyak jenis lebah daripada sekadar lebah madu, jadi &6&lBumblezone&r menambahkan lebih banyak &8L&6e&8b&6a&6h&r yang unik! \\n\\nMulai dari &4&lRedtail&r lebah, lebah &9Biru&r, hingga lebah Neopolitan!"]
	quest.21BFDE6AD1C0F62A.title: "Varian &8L&6e&8b&6a&6h&r"
	quest.21D323D95F5A7DB3.quest_desc: ["Pegang Stick di off hand dan &7Scroll of Strengthening&r di main hand lalu tahan Right Click."]
	quest.21D323D95F5A7DB3.title: "Strong Stick"
	quest.21D8B88155648EA6.quest_desc: [
		"Ayo lah, kita semua tahu kamu ke sini buat apa... &5&lMESIN&r! \\n\\n&5Mesin&r itu pabrik kecil kita, masing-masing bakal lakuin hal unik buat kasih kita lebih banyak &eItem&r. Ikuti quest masing-masing buat tahu fungsinya. \\n\\nDi sini aku bakal lebih banyak bahas soal Konfigurasi dan &8Upgrade&r! "
		"{@pagebreak}"
		"Semua &5Mesin&r itu beda-beda tapi warna slot dan bar bakal kasih tahu itu buat apa! &aHijau Muda&f: &aEnergi&r. &4Merah&f: &4Item/Cairan/Kimia Awal&f. &9Biru&f: &9Hasil&f. &3Cyan&f: &3Hasil Kedua&f. &eKuning&f: &eTipe Infuse&r. \\n\\nSetiap &5Mesin&r punya setelan sisi (Side Config) bawaan. Di situ tempat &eItem&r bakal masuk (Input) dan keluar (Output). Kamu bisa ganti di GUI mesin di bagian Side Configs. \\n\\nSetelannya beda-beda buat &eItem&f, &bCairan&f, &cChemical&f, dan &aEnergi&r tapi tiap bagian punya sisi mirip yang bisa diganti. &4Merah&f: &5Input&f. &6Oranye&f: &6Input Kedua&f. &9Biru&f: &9Output&f. &3Cyan&f: &3Output Kedua&f. &5Ungu&f: &5Bisa Input dan Output&f. &aHijau Muda&f: &aEnergi&f. &eKuning&f: &eEkstra&f kayak &cTipe Infuse&r. \\nKamu perlu setel GUI-nya ke Auto-Eject kalau mau &eItem&r otomatis masuk dan keluar! "
		"{@pagebreak}"
		"Beberapa &5Mesin&r juga bisa pakai &8Upgrade&r! Ini ada di pojok kanan atas GUI. \\n\\nDi sini kamu bisa lihat &8Upgrade&r apa yang bisa dipakai mesin itu. Pas dipasang, dia bakal kasih tahu berapa banyak yang bisa ditampung. &8Upgrade &eSpeed&r bisa dipasang banyak, sedangkan Muffling nggak perlu banyak-banyak!"
	]
	quest.21D8B88155648EA6.title: "&l&5Mesin"
	quest.21EA29A8C7F950CE.quest_desc: ["&bDiamond&r andalannya &2Minecraft&r, dan upgrade Furnace juga kayaknya...\\n \\nIni kerja lebih cepat cuma butuh 80 Tick atau 4 Detik buat smelt item. Lebih cepat dari Blast Furnace! \\n \\nIni cuma bisa di-craft dari &eGold Furnace&r dan bisa di-craft jadi &3Crystal&r atau &aEmerald Furnace&r."]
	quest.21EA29A8C7F950CE.title: "&bDiamond Furnace"
	quest.21F3379C904BFD50.quest_desc: ["&6Resistive Heater&r juga bakal hasilkan &6Panas&r, tapi bukannya pakai bahan bakar tungku, dia pakai &aEnergi&r! \\n\\nDengan kasih dia &aEnergi&r, kita bisa pilih seberapa banyak &6Panas&r yang bakal dia buat. \\n\\nMakin banyak &6Panas&r yang dibuat, makin banyak &aEnergi&r yang dipakai! \\n\\nPanas maksimalnya sekitar 9,999,999 gitu."]
	quest.21F3379C904BFD50.title: "&6Resistive Heater"
	quest.21F4CFF171246537.quest_subtitle: "Tingkat: &b4"
	quest.21F654C968722841.quest_subtitle: "Tingkat: &b4"
	quest.21FDF07571B5DCA7.quest_subtitle: "Berikan Primogel Goo ke Iron Bee"
	quest.21FDF07571B5DCA7.title: "Ferricore Bee"
	quest.22151D56616559CB.quest_desc: ["Bisa ditemukan di dalam peti di Bangkai Kapal (Shipwreck)."]
	quest.22151D56616559CB.quest_subtitle: "Peti Bangkai Kapal"
	quest.2215FB0777D7029D.quest_desc: ["Duri kaki, cleat, atau apa pun namanya! \\n\\n&7Steadfast Boots&r menjaga pijakanmu tetap kokoh. Kamu nggak akan terpental (knockback) saat diserang dan nggak bakal terpeleset lagi di atas Es."]
	quest.2215FB0777D7029D.quest_subtitle: "Kaki"
	quest.2215FB0777D7029D.title: "&7Steadfast Boots&r"
	quest.22171982D22CE15F.quest_desc: ["Daripada tiap &a&lMekaSuit Part&r punya Charge masing-masing, sekarang mereka bakal berbagi satu Charge. \\n\\nIni penting buat jaga semua &a&lPart&r tetep Charged. \\n\\nDan itu penting buat jaga lo tetep hidup!"]
	quest.22171982D22CE15F.quest_subtitle: "Bodyarmor"
	quest.22171982D22CE15F.title: "&aCharge Distribution &7Unit"
	quest.221C9EDA651144BA.quest_desc: ["&9Air&r apa? \\n\\nDengan &3Charm of Sinking&r, kamu bisa bergerak di dalam &9Air&r selancar di udara! Tapi tetep nggak bisa napas di dalam air ya..."]
	quest.221C9EDA651144BA.quest_subtitle: "Kalung"
	quest.221C9EDA651144BA.title: "&3Charm of Sinking&r"
	quest.2224AA108FC006F3.quest_desc: ["Speedloader Revolver sebenarnya bukan Upgrade, melainkan Barang terpisah yang digunakan untuk membantu. \\n\\nIsi dengan Kartrid seperti &d&lRevolver&r, tetapi sekarang setiap kali perlu Reload &d&lRevolver&r, bisa Klik Kanan dengannya untuk langsung reload!"]
	quest.2224AA108FC006F3.quest_subtitle: "Apakah aku menembak 6 kali? Atau hanya 5?"
	quest.2226555D9552236E.quest_subtitle: "Muncul dari kebanyakan Wood Nest"
	quest.222739E77C745519.quest_subtitle: "Tingkat: &b4"
	quest.222D08F43B995FED.quest_subtitle: "Coba aja kalau bisa penyok"
	quest.224716A537F2FFA0.quest_desc: ["&8Armor Tome&r digunakan untuk mendapatkan &5Enchantment&r yang khusus untuk Armor. Semua jenis &8Tome&r ini bisa mendapatkan &5Protection&f, &5Blast Protection&f, dan &5Fire Protection&r. \\n\\nMasing-masing juga memberikan enchant yang dikhususkan untuk bagian armor tertentu. Boots akan memberikan &5Depth Strider&r dan Helmet akan memberikan &5Aqua Affinity&r. \\n\\nJika kamu mengincar &5Protection&r murni, cobalah pakai &8Chestplate Tome&r!"]
	quest.224716A537F2FFA0.title: "&8Armor Tomes"
	quest.224CE21E56703F6E.quest_desc: ["Tongkat bisa dipakai buat ngaktifin Altar Infus, tinggal klik kanan di altar buat ngaktifin proses infus."]
	quest.224CE21E56703F6E.quest_subtitle: "Kamu seorang Penyihir (Masukin nama kamu)!"
	quest.224CE21E56703F6E.title: "&2Tongkat"
	quest.22572456571C3F8D.quest_desc: ["&3Charging Module&r melepaskan tekanan udara ke item apa pun yang mendukung tekanan di dalam kontainer yang dituju."]
	quest.226187AA3F1B6DB1.quest_desc: ["Mencampur &#D4C35DPasir&r, &8Flint&r, &#8DF0EENitrogen&r, dan &#69C9C7Toluene&r akan menghasilkan &#D66D40Industrial TNT&r."]
	quest.2262AB9F934165D0.quest_desc: ["Aku tidak peduli bagaimana mendapatkannya, aku hanya perlu kamu mendapatkannya! \\n\\n&8&lImmersive Engineering&r menambahkan lebih banyak kegunaan untuk &8Baja&r daripada sekadar bangunan sederhana, hampir semuanya memerlukan &8Baja&r untuk membuatnya! \\n\\nPeralatan, Bagian Mekanik, dan Blok Bangunan terutama. Banyak dibuat dengan &8Pelat Baja&r atau &8Perancah&r. \\n\\nKamu akan membutuhkan banyak tetapi &l&cTungku Blast Sederhana&r dan &l&6Kiln Paduan&r tidak bisa diotomatisasi jadi kita mungkin perlu..."]
	quest.2262AB9F934165D0.title: "&8Batang Baja"
	quest.22647504C37E547C.quest_subtitle: "Berikan sebuah blok Cyanite ke Radioactive Bee"
	quest.22647504C37E547C.title: "Cyanite Bee"
	quest.226B8B60AF864FEF.quest_desc: [
		"Untuk meningkatkan &6Allthemodium&r ke &3Vibranium&r, kamu butuh Smithing Template lain. \\nTemplate yang ini bisa ditemukan dengan menyikat (brushing) Suspicious Soul Sand. \\n\\nBisa ditemukan di Bastion di &l&cThe Nether&r.\\n"
		"{image:atm:textures/questpics/allthemodium/all_bastion.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/allthemodium/all_soul.png width:200 height:100 align:center}"
	]
	quest.226B8B60AF864FEF.title: "&3Vibranium Smithing Template&r"
	quest.22739522F0D33D7B.quest_desc: ["Gloomgourd tumbuh dan difarm seperti Labu (Pumpkin). \\n\\nSama seperti labu, mereka bisa dibuat menjadi Pie atau Jack-O-Lantern! \\n\\nBedanya, labu yang satu ini bisa dibuat menjadi bahan peledak..."]
	quest.2278A98DCDF713D7.quest_desc: ["Sekarang saatnya membuat Tank! Pertama, kamu butuh Building Block dan setidaknya 1 Valve. Kaca dan Item IO bersifat opsional.\\n\\nTank harus dibuat dengan kerangka dari building block. Building block adalah blok apa pun yang tidak transparan, tidak terpengaruh gravitasi, dan bukan Dirt atau Grass alami.\\n\\nItem seperti batu, kayu, atau logam harus membentuk kerangka dan tepiannya. Kaca, Valve, dan Item IO diletakkan di dinding dan bagian dalamnya harus kosong.\\n\\nUkuran maksimalnya adalah 13x13x13. Setelah selesai, klik kanan pada Valve dan ia akan memberikan pesan 'Formed' atau memberitahu masalahnya."]
	quest.2278A98DCDF713D7.title: "&lThe Tank"
	quest.227BEFEF59977CC4.quest_subtitle: "Rosewood + Teak"
	quest.227DBA8836021B0B.quest_desc: ["Dalam Ars Nouveau, sistem tenaga untuk mesin disebut &9Source&r. \\n\\nUntuk mulai mengumpulkan Source, kita butuh sebuah Source Jar. \\n\\nSource juga bisa dipindahkan dengan ember (bucket), atau dengan menghancurkan dan mengambil kembali Source Jar."]
	quest.227DBA8836021B0B.quest_subtitle: "Menyimpan Source"
	quest.227E9783382527CA.quest_desc: ["&cFree Runners&r itu beda dari armor lainnya, ini pakai &aEnergi&r bukannya bahan bakar kimia. \\n\\nPas sudah diisi tenaga dan dipakai di kaki, kamu bisa tekan (B) buat aktifin dan tekan lagi buat ganti modenya. \\n\\n&2Regular&r: &cFree Runners&r bakal lindungin kamu dari Fall Damage dan otomatis loncat ngelewatin blok buat kamu. \\n\\n&6Safety&r: bakal cegah Fall Damage tapi nggak bakal otomatis loncat. (Ini cara yang lebih enak). \\n\\n&4Disabled&r: Free Runners nggak bakal lindungin atau loncat, cuma buat gaya aja! \\n\\nKamu juga bisa upgrade &cFree Runners&r biar punya proteksi armor, kayak &cJetpack&r."]
	quest.227E9783382527CA.title: "&cFree Runners"
	quest.228CB313BAB6406E.quest_desc: ["Ternyata item ini nggak punya resep bawaan! Kayaknya dev mod-nya nggak mau kamu pakai lokomotif &5Creative&r di Survival. \\n\\nTapi menurutku ini nggak terlalu OP, jadi selamat menikmati &5Kereta&r barumu! \\n\\nCara kerjanya kayak &3Locomotive&r biasa, cuma nggak butuh bahan bakar atau energi! Tinggal taruh di &6Rail&r."]
	quest.228CB313BAB6406E.title: "&5&lCreative &8Locomotive"
	quest.2296CE4418AE62D4.quest_desc: ["&6Allthemodium Armor&r tapi dengan buff untuk mantra-mantra &d&lArs Nouveau&r!"]
	quest.2296CE4418AE62D4.quest_subtitle: "24"
	quest.2296CE4418AE62D4.title: "&6Allthemodium Arcanist Gear"
	quest.22A0A9C81A5C85A1.quest_subtitle: "Menahan semuanya agar tetap menyatu"
	quest.22AD9DF2BCC04575.quest_subtitle: "Menciptakan energi"
	quest.22AD9DF2BCC04575.title: "Pembangkit Listrik"
	quest.22ADCF96AE3E609B.quest_desc: ["&dAncient Sapling&r dibuat menggunakan &aRitual of the Forest&r. Saat tumbuh besar, pohon ini akan berusaha menjaga tingkat aura agar tetap normal (tidak terlalu tinggi atau terlalu rendah).\\n\\nJika aura turun drastis, daun-daunnya akan mulai membusuk untuk membalikkan proses tersebut."]
	quest.22ADCF96AE3E609B.quest_subtitle: "Bukan bibit pohon Ancient yang biasa"
	quest.22ADCF96AE3E609B.title: "Pohon Ancient"
	quest.22B8D57337944D9C.quest_desc: ["&#DF9DE0Titanium Hot Ingot&r sekarang bisa didinginkan di dalam &#5CD1CFVacuum Freezer&r untuk mendapatkan &#F069F0Titanium Ingot&r yang siap pakai."]
	quest.22B8D57337944D9C.title: "Ingot &#F069F0Titanium"
	quest.22BB55249EF2E819.quest_desc: ["&l&6The Bumblezone&r adalah mod eksplorasi yang menambahkan dimensi baru di dalam &eBeehive&r kita. \\n\\nPernah penasaran apa yang dilakukan para &6L&8e&6b&8a&6h&r di sarang mereka? Kamu bisa mengetahuinya dengan berpetualang ke dalamnya!"]
	quest.22BB55249EF2E819.quest_subtitle: "Selamat datang di dunia lebah!"
	quest.22BB55249EF2E819.title: "&l&6The Bumblezone!"
	quest.22C4318523A43B49.quest_desc: ["&eTerminal&f memberikan akses ke semua konten dalam jaringan ME. &eME Terminal&f standar mencantumkan semua yang ada di jaringan sebagai satu kotak besar untuk diambil atau dimasukkan, seperti inventaris tunggal.\\n\\n&eME Crafting Terminal&f adalah ekstensi dari ME Terminal yang juga menyediakan kotak crafting bawaan, memungkinkan pembuatan barang dengan nyaman menggunakan item apa pun yang ada di jaringan."]
	quest.22C4318523A43B49.quest_subtitle: "Pusat Kontrol Inventaris"
	quest.22C4318523A43B49.title: "Terminal"
	quest.22CF5AD56C1BB8D5.quest_subtitle: "Berikan sebuah blok Dark ke Diamond Bee"
	quest.22CF5AD56C1BB8D5.title: "Dark Gem Bee"
	quest.22D0C3F454F5E8F1.quest_subtitle: "Tingkat: &b4"
	quest.22D2CFDDB06C720C.quest_desc: ["Alat sangat penting di &2&lMinecraft&r, begitu juga dengan ruang inventaris. Jadi kenapa tidak menghemat ruang dengan membuat Paxel! \\nPaxel adalah kombinasi dari Beliung (P-ickaxe), Kapak (axe), dan Sekop (shov-el). \\n\\nMereka bisa mengelupas kayu, membuat jalan, dan menambang blok apa pun sesuai tingkat (tier) beliung/kapak/sekop tersebut!"]
	quest.22D2CFDDB06C720C.title: "Paxel"
	quest.22D383BAEF8A2B39.quest_desc: ["Kamu tahu Paxel legendaris? Kombinasi dari Pick, Axe, dan Shovel? Ini mirip, menjadi kombinasi dari Sword, Pickaxe, dan Shovel! Melakukan semua yang Tools Draconic lakukan!"]
	quest.22D383BAEF8A2B39.title: "Draconic Staff"
	quest.22E007025C19EC0A.quest_desc: ["&l&7Railcraft&r, selain Kereta Api, juga menambahkan beberapa batu untuk dekorasi! \\n\\nBatu Quarried dan Abyssal bisa di-craft bersama untuk membuat versi Polished, Chiseled, atau Brick! \\n\\nJuga jangan lupakan versi Tangga (Stair) dan Slab-nya!"]
	quest.22E007025C19EC0A.title: "Batu &l&7Railcraft&r"
	quest.22E57BF23B9BA2C5.quest_desc: ["&6&lApotheosis&r sekarang terintegrasi dengan &aGateway&r.\\n\\nAda &aGateway&r berdasarkan setiap &lWorld Tier&r (kecuali &l&9Haven&r), yang menyajikan gelombang monster dan &4Invader&r. &aGateway&r ini hanya bisa digunakan di dalam &lWorld Tier&r-nya masing-masing. Begitu kamu mengalahkan gelombang terakhir, kamu akan mendapat berbagai hadiah yang berguna untuk menyelesaikan World Tier tersebut.\\n\\nBerbeda dengan Gateway lain, di sini kamu punya total 3 nyawa."]
	quest.22F5F931D38E5187.quest_desc: ["Crimson Stone ditemukan di Pillager Outpost, agak langka tapi gak membantu mereka cuma kasih 2 Chest! \\n\\nMereka gak dipakai untuk Resep baru melainkan akan kurangi penggunaan Soul di &6&lForge&r."]
	quest.22F5F931D38E5187.title: "&cCrimson Stone"
	quest.22F80D267321BFC5.quest_desc: ["&3Autocrafter Manager&r memungkinkanmu mengakses semua &3Autocrafter&r milikmu dari satu blok saja.\\n\\nSemoga kamu tidak pusing saat mencoba merapikan semuanya."]
	quest.22F80D267321BFC5.title: "&3Mengelola Autocrafter"
	quest.230463E830D6FFEB.quest_desc: ["Sekarang setelah kita punya plastik, langkah selanjutnya adalah membuat PCB jadi; pertama buatlah beberapa &3Empty PCB&r di dalam Pressure Chamber."]
	quest.230463E830D6FFEB.quest_subtitle: "Jalan menuju PCB"
	quest.230582AAFC0A1632.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.230EEE4671B46D0C.quest_desc: ["&9Darkstone&r muncul deep underground di dekat Lava Lake, seperti di Y Level -54. \\n\\nIni Blok paling sering dipakai untuk &6&lForbidden \\& Arcanus&r, semua Multiblock akan pakai mereka untuk base. \\n\\nPastikan ambil banyak!"]
	quest.230EEE4671B46D0C.title: "&9Darkstone"
	quest.231E0C0A9B0C0509.quest_desc: ["Yang satu ini bisa dipasang ke &c&lRansel Akumulator&r. \\n\\nKetika &c&lRansel&r dikenakan, &eBarang&r di dekatnya akan tersedot ke Inventaris!"]
	quest.23254CE8487D2E68.quest_desc: ["&8Wither Builder&r adalah salah satu Mesin terhebat yang bisa kamu dapetin dari &lIndustrial Foregoing&r, dan karena itu mahal banget. \\n\\nPertama kamu butuh part yang bikin &8Wither&r dan drop dari &8Wither&r. \\n\\nTerus, kamu butuh &6Supreme Machine Frame&r yang butuh &bEther Gas&r buat bikinnya. Coba tebak kamu butuh apa buat &bEther Gas&r? Bener! &8Wither&r! Kamu butuh Laser Drill yang kerja di &8Wither&r buat dapetin. \\n\\n&8Wither&r suka pergi dan bunuh sesuatu jadi Stasis Chamber bakal bikin mereka lebih gampang di-milk! "]
	quest.23254CE8487D2E68.title: "&8Wither Builder"
	quest.2329AA0AFBEF1E13.quest_desc: [
		"&e&lPipez&r adalah mod &f&lLogistik&r yang paling simpel. Saking simpelnya, seluruh mod ini muat di satu halaman Quest ini sambil menyisakan ruang untuk mod lainnya!"
		""
		"Pasang pipa spesifik ke tempat yang ingin kamu pindahkan itemnya dan gunakan Pipe Wrench untuk mengatur sisi mana yang Menarik (Pull), Mendorong (Push), atau yang tidak terhubung."
		""
		"Kunci Inggris (Wrench) dari mod lain juga bisa digunakan untuk &e&lPipez&r!"
		""
		"(Bisa menyebabkan lag jika digunakan dalam jumlah masal, tapi masih tidak se-laggy pipa &5&lMekanism&r)."
	]
	quest.2329AA0AFBEF1E13.title: "&l&ePipez"
	quest.232A06C9FF0EE7B2.quest_desc: ["Menril Seeds bisa dipakai untuk mengotomasi Menril Berries, Menril Logs dan Menril Saplings."]
	quest.232A06C9FF0EE7B2.quest_subtitle: "Mengotomasi Menril"
	quest.2338E5269CA23C91.quest_desc: ["&3Netherite Drill Bit&r adalah mata bor terbaik, bahkan lebih baik dari Diamond Drill Bit."]
	quest.2338E5269CA23C91.quest_subtitle: "Mata Bor Terbaik"
	quest.233C7CAA573D6045.quest_desc: ["Module menentukan aksi apa yang dilakukan oleh Router.\\n\\nMereka bisa membuat Router menarik item dari peti, memasukkan item ke peti, atau bahkan keduanya! Dan banyak lagi!\\n\\nModule dipasang langsung ke Router dan kamu bisa memasang beberapa sekaligus.\\n\\nSistem penyaringan (filtering) dan Upgrade dipasang ke dalam Module tersebut."]
	quest.233C7CAA573D6045.title: "&lModule"
	quest.234C2C3144817018.quest_desc: ["Yep, bahkan &2&lP.R.C.&r punya Multiblock! Dan iya, kerjanya sama. \\n\\nLo butuh &eItem&r, &cChemical&r, &bFluid&r, sama &aEnergi&r Input Hatch. Semuanya kecuali &6Heat&r. Plus &eItem&r Output sama &cChemical&r Output Hatch! \\n\\nPake &2&lP.R.C.&r yang lebih bagus buat bikin 32 &bPolonium Pellet&r sekaligus, atau bikin 8 &aSubstrate&r jadi 64!"]
	quest.234C2C3144817018.title: "&2&lPressurized Reaction Chamber Multiblock"
	quest.234DC1702333EB18.quest_desc: ["Add-on &dAEInfinityBooster&f menyediakan dua booster nirkabel khusus yang memungkinkan jangkauan koneksi tak terbatas, dengan dukungan lintas dimensi opsional."]
	quest.234DC1702333EB18.quest_subtitle: "Menuju Tak Terbatas"
	quest.234DC1702333EB18.title: "Infinity Booster"
	quest.235273F7C9A9B0D0.quest_subtitle: "3/5"
	quest.235273F7C9A9B0D0.title: "Bagian Kanan Bawah &6&lATM Star&r"
	quest.2354BC5330350DF6.quest_desc: ["Kalau &aEmerald&r bukan seleramu, &3Crystal Furnace&r mungkin yang kamu mau! \\n \\nKerja sama kayak &aEmerald Furnace&r di 40 Tick. \\n \\nDibuat dari &bDiamond Furnace&r dan bisa dibuat jadi &dObsidian Furnace&r. \\n \\n(Ga, kamu ga bisa liat Item yang lagi di-smelt di dalamnya, emang transparan aja)"]
	quest.2354BC5330350DF6.title: "&3Crystal Furnace"
	quest.235E3C386E8D36A3.quest_desc: [
		"Di sinilah pemisahan antara &4Hellshelf&r dan &bSeashelf&r berakhir! \\n\\nPertama, kita perlu membuat &9Dormant Deepshelf&r. Bahannya cuma 6 &8Cracked Deepslate Tile&r dan 3 &7Book&r. \\n\\nLalu, kita butuh &a60 Eterna&r, &c40% Quanta&r, dan &540% Arcana&r. Kita bisa mendapatkannya dengan 12 &bCrystalline Seashelves&r atau 12 &4Glowing Hellshelves&r! \\n\\nAkhirnya, kita bisa melakukan &d&lInfuse&r pada &9Dormant Deepshelf&r kita menjadi &9Deepshelf&r biasa!"
		"{image:atm:textures/questpics/apothic/enchant_deepshelf.png width:100 height:100 align:center}"
	]
	quest.235E3C386E8D36A3.title: "&9Deepshelf"
	quest.23631A4A743D4F0C.quest_desc: ["Jangan mengeluh soal yang satu ini. \\n\\nAda lusinan cara untuk mendapatkan Besi dan itu dibutuhkan bahkan untuk progresi normal. \\n\\nKamu akan mendapatkan Besi, kamu akan menjadikannya sebuah blok, dan kamu akan membuatnya terlihat cantik!"]
	quest.23631A4A743D4F0C.title: "Logam &l&bChipped&r"
	quest.236C936FE3BA8396.title: "Chaotic Flight Module"
	quest.236EA8D18ECD5FE8.quest_desc: ["Mob ini cukup unik dalam pemunculannya! Setelah kamu membunuh &b&lIgnis&r, ada peluang &bIgnited Berserker&r akan muncul di Nether Fortress. \\n\\nMereka mirip dengan &bRevenant&r tapi bukannya perisai, mereka membawa Pedang! Pedang mereka tidak akan menahan damage, tapi mereka memberikan damage yang lebih besar. \\n\\nMereka punya darah yang jauh lebih sedikit, yaitu 65 &4HP&r dan akan menjatuhkan Dying Ember saat mati. 4 Dying Ember bisa di-craft menjadi 1 &bBurning Ashes&r."]
	quest.236EA8D18ECD5FE8.title: "&bIgnited Berserker"
	quest.23708582B1064C9D.quest_desc: ["Sebuah &#46DBBBSirkuit (Circuit)&r akan membutuhkan beberapa komponen dasar ini untuk berfungsi. Mengotomatisasi bagian-bagian ini akan sangat berguna di masa depan."]
	quest.23708582B1064C9D.title: "Kapasitansi dan Resistansi"
	quest.23737103592776C2.quest_desc: ["&3Kerosene Lamp&r adalah sumber cahaya hebat yang menggunakan bahan bakar (Kerosene adalah yang terbaik) untuk menghasilkan cahaya."]
	quest.23737103592776C2.quest_subtitle: "Mega Torch nggak ada apa-apanya!"
	quest.237D11FF5B09BA88.quest_desc: [
		"Kemampuan Intrinsik:"
		"- Tidak Menginjak Tanaman"
		"- Panen Otomatis"
		"- Pertumbuhan Tanaman Dipercepat III"
		""
		"Upgrade yang Tersedia:"
		"- Teleporter Barang Jatuhan"
	]
	quest.23820B0DCEC022D1.quest_subtitle: "Resin + Lumber"
	quest.23820B0DCEC022D1.title: "Plastic Bee"
	quest.23A5F5C9BC7B5CC7.quest_subtitle: "Plum + Walnut"
	quest.23AE395433AED3C0.quest_desc: ["&6&lATM Star&r butuh beberapa Block buat nge-hold berbagai Item, dan bikin bentuk bintangnya! \\n\\nBlock pertama adalah &5Unobtainium&r - &6Allthemodium&r &5Alloy&r &6Block&r. Kamu harus pake Enchanting Apparatus dari &d&lArs Nouveau&r buat bikin mereka! Bikin 28 tepatnya. \\n\\nBuat 17 X3 Netherstar Block kamu butuh 111,537 Netherstar. (Tolong gue mohon pake &l&bHNN&r jangan spawn dan bunuh 111,537, tolong!)"]
	quest.23AE395433AED3C0.title: "Casing &6&lThe Star&r"
	quest.23B68F19A04AF5D7.quest_desc: ["Banyak &a&lMekaSuit Pants&r &7Unit&r ini kerjanya kayak Enchantment. \\n\\nYang ini 2 dalam 1! Air Affinity sama Aqua Affinity. \\n\\nLo gak bakal kena penalti Mining lagi pas Berenang atau Terbang atau Jatuh."]
	quest.23B68F19A04AF5D7.quest_subtitle: "Celana"
	quest.23B68F19A04AF5D7.title: "Gyroscopic Stabilization &7Unit"
	quest.23C36E4B5DCEBFDD.quest_desc: ["Quest ini dibuat oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r buat dipake di Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensiin di bawah &eAll Rights Reserved&r, Quest ini gak boleh dipake di pack publik manapun yang gak dirilis sama &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyiin, kalau kamu liat ini, berarti kamu lagi di mode editing."]
	quest.23DB52ECA259F36D.quest_desc: [
		"Heavy Water (Air Berat) di dalam &#45BF56Reaktor&r menghasilkan &#EB5266Tritium&r dan &#C09EDEHeavy Water Steam&r."
		""
		"&#EB5266Tritium&r digunakan untuk komponen tingkat lanjut, sementara &#C09EDEHeavy Water Steam&r dapat didaur ulang menjadi &#8C47C9Heavy Water&r kembali menggunakan &#DEAB47Heat Exchanger&r."
	]
	quest.23DE60E57136C207.quest_desc: ["Penyimpanan energi tak terbatas paling gampang, cuma butuh 4 &3Energy Battery&r (dari &3&lID&r) dan sebuah &6&lStar&r! \\n\\nKamu harus isi energinya sebanyak yang &2&lMinecraft&r bisa tampung... beneran sampe batas limit integer!"]
	quest.23DE60E57136C207.title: "&5&lCreative &3Energy Battery"
	quest.23F691FC053F2319.quest_desc: ["Disk Interface memungkinkanmu mengambil item dan cairan dari satu disk dan memindahkannya ke disk di jaringan grid lain."]
	quest.23F691FC053F2319.quest_subtitle: "Tidak perlu manipulasi lagi!"
	quest.23F691FC053F2319.title: "Disk Interface"
	quest.23FDFA44A162023A.quest_desc: ["&6Meja Kerja Insinyur&r adalah Blok yang diperlukan untuk banyak Kerajinan dan Upgrade. \\n\\nKita bisa menggunakannya dengan &9Cetak Biru&r untuk Membuat Barang khusus yang tidak bisa kita Buat di tempat lain. Masukkan &9Cetak Biru&r di Slot Kiri, dan &eBarang Crafting&r ke Slot Kanan. \\n\\nAtau kita bisa melempar Peralatan kita ke dalamnya, untuk menambahkan Upgrade, seperti Revolver atau Bor Pertambangan! \\n\\nJuga ketika menambahkan &eBarang&r dan &9Cetak Biru&r, bisa melihatnya di &6Blok&r itu sendiri, cukup keren!"]
	quest.23FDFA44A162023A.title: "&6Meja Kerja Insinyur"
	quest.24042326B4632DD4.quest_desc: ["Untuk memulai dengan Logistik, buatlah &3Logistics Core&r. Aku menyarankan untuk membaca Manual PNC:R untuk tutorial lengkap cara menggunakan item-item ini."]
	quest.24042326B4632DD4.quest_subtitle: "Transportasi Item/Cairan"
	quest.24042326B4632DD4.title: "Logistik"
	quest.2405663C033CBDF1.quest_desc: ["MK3 tidak peduli soal koordinat XYZ, pandangan mata, atau Dimensi. \\n\\nAsalkan inventaris tujuan ada di dunia Minecraft yang sama, ia bisa mengirim item ke sana. \\n\\nBahkan aku tidak yakin apakah inventarisnya harus ada di dalam game Minecraft untuk bisa dikirimkan!"]
	quest.2409EAD96CE3BDF7.quest_desc: ["Templat Blazegold digunakan untuk meningkatkan armor dan alat Ferricore ke Blazegold sambil mempertahankan mantra dan upgrade yang terpasang."]
	quest.24150DE600C2D761.quest_desc: ["Yang satu ini sendiri membawa kita dari rating E10 ke Teen. &4&lBlood&r adalah tentang membantai musuh untuk &cHealth&r mu sendiri! Kebanyakan serangan akan menyembuhkanmu kembali. \\n\\n&4&lBlood&r menggunakan &4Blood Vial&r sebagai Material Fokusnya yang kamu dapatkan dari memasak Mob atau Player di Cauldron. \\n\\n&4Scroll&r-nya berwarna Coklat (tidak ada kode warna untuk Coklat) dengan teks &4Merah Gelap&r."]
	quest.24150DE600C2D761.title: "&4&lBlood"
	quest.24285F25F9563B02.quest_desc: ["&#467FDB&nAnalog Circuit&r, ah! akhirnya kamu berhasil membuatnya. Biasanya orang lain hanya butuh waktu setengah dari yang kamu habiskan, tapi aku tidak akan mempermasalahkan itu..."]
	quest.24285F25F9563B02.quest_subtitle: "Dasar-Dasar Elektronika"
	quest.242F74010488F261.quest_desc: ["Tabung Bahan Bakar adalah barang yang memungkinkan penggunaan bahan bakar lebih efisien. Bisa menyimpan 50.000 bahan bakar, setiap barang yang bisa dibakar punya nilai bahan bakar berbeda tergantung jumlah barang yang dilebur. Satu bahan bakar cukup untuk melebur satu barang."]
	quest.243008D4DCD789D0.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_wild.png width:100 height:150 align:center}"]
	quest.243008D4DCD789D0.quest_subtitle: "Jungle Temples"
	quest.243008D4DCD789D0.title: "Wild Armor Trim"
	quest.24391162F4FF0587.quest_desc: ["Dengan 15 &bSeashelf&r di sekitar &5Enchanting Table&r, kita bisa melakukan &d&lInfuse&r pada satu &bSeashelf&r terakhir! \\n\\n&bInfused Seashelf&r memberikan &aEterna&r lebih tinggi (5 poin) dengan batas maksimal &a60&r. Juga memberikan &5Arcana&r lebih besar yaitu &55%&r. \\n\\nIni bisa di-craft menjadi rak buku yang berbeda; yang kita cari untuk &6Max Enchanting&r adalah &bCrystalline Seashelf&r. \\n\\nKita butuh 12 buah, jadi kita butuh 12 &bInfused Seashelf&r. Buatlah 8 buah, dan aku akan memberikan sisanya sebagai hadiah!"]
	quest.24391162F4FF0587.title: "&bInfused Seashelf"
	quest.2447208F1DC74FFE.quest_desc: ["Router bisa sangat berisik, dan suara itu akan menumpuk jika kamu punya ratusan Router.\\n\\nMungkin ada baiknya berinvestasi pada Muffler Upgrade!"]
	quest.244ACD7024566001.quest_subtitle: "Berikan Es (Ice) ke Sweat Bee"
	quest.244ACD7024566001.title: "Frosty Bee"
	quest.24599D45F5D1606E.quest_desc: ["&bAura Trove&r adalah versi peningkatan dari &9Aura Cache&r."]
	quest.24599D45F5D1606E.quest_subtitle: "Gudang Harta!"
	quest.24599D45F5D1606E.title: "&bAura Trove"
	quest.247DAE5B4E1AC7F1.quest_desc: ["Air masuk. \\nAir keluar. \\n\\nFluid Module akan mengambil sumber cairan di dekat Router dan memasukkannya ke tangki di dalam Buffer, atau mengambil cairan dari tangki Buffer dan meletakkannya di depannya. \\n\\nHanya berfungsi untuk blok yang menempel. Jika ingin jarak lebih luas, kamu butuh..."]
	quest.24846776077B52C3.quest_subtitle: "Infusion Crafting"
	quest.24846776077B52C3.title: "Supremium Bee"
	quest.24888CAD50B32B04.quest_subtitle: "Muncul menggunakan Stone Nest"
	quest.248AEF5537E48B1A.quest_subtitle: "Tingkat: &b4"
	quest.24934231538B6492.quest_desc: [
		"Ancient Pyramid adalah salah satu dari 3 struktur di &b&lThe Other&r. \\n\\nJelas ini adalah sebuah Piramida, dan tidak, yang ini tidak punya ruang bawah tanah! \\n\\nSebagai gantinya, di sini ada Piglich.\\n"
		"{image:atm:textures/questpics/allthemodium/all_pyramid.png width:200 height:100 align:center}"
	]
	quest.24934231538B6492.title: "Ancient Pyramid"
	quest.249E5C6893387E15.quest_desc: ["&cJalur&r ini dibuat untuk menghentikan &5Lokomotif&r dan &7Cart&r. \\n\\n&cLocking Kit&r menghentikan &7Cart&r dan hanya akan menjalankannya kembali saat diberi sinyal redstone. \\n&cBuffer Kit&r digunakan untuk ujung &6rel&r, akan menghentikan kereta dan tidak menjalankannya lagi. \\n&cGated Kit&r hanya memasang Gerbang Pagar (Fence Gate) yang terhubung dengan &6rel&r."]
	quest.249E5C6893387E15.title: "&cTrack Kit&r untuk Menghentikan Kereta"
	quest.24A7B2902E7430A1.quest_desc: ["&7Leather Armor&r yang sedikit ditaburi kekuatan Arcane. \\n\\nMemberikan sedikit bonus Mana untuk mantra sihir."]
	quest.24A7B2902E7430A1.quest_subtitle: "15"
	quest.24A7B2902E7430A1.title: "&9Wandering Magician Gear"
	quest.24B147D251D0CFFF.quest_subtitle: "Berikan Blazebloom Goo ke Gold Bee"
	quest.24B147D251D0CFFF.title: "Blazegold Bee"
	quest.24BA4B4EED0A9DBD.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kabut Pikiran"
	]
	quest.24BA664B60E49461.quest_desc: ["Cuma salah satu alat paling sakti di semua dunia &2&lMinecraft&r Mod! &6Cardboard Box&r! \\n\\nIni dibuat pakai bahan yang simpel banget, cuma 4 &6Sawdust&r. &6Sawdust&r didapat dari masukin &7Stick&r ke dalam &e&lPrecision Sawmill&r. \\n\\nNah sekarang kalau sudah punya satu, tinggal Klik Kanan sebuah blok pakai kotak ini dan bloknya bakal masuk ke dalam &6Cardboard Box&r. Sekarang kita bisa hancurin &6Cardboard Box&r-nya dan pindahin bloknya dengan cara naruh lagi terus Shift Klik Kanan buat lepas kotaknya. \\n\\nBeberapa blok nggak bisa kayak &8Bedrock&r atau &dEnd Portal Frame&r... tapi banyak banget yang bisa! Kayak &5Obsidian&f, &3Reinforced Deepslate&r, bahkan Spawner!"]
	quest.24BA664B60E49461.title: "&6Cardboard Box"
	quest.24BAC1C0392E950E.quest_desc: [
		"Aku dengar sekarang kamu bisa ambil kelas online untuk jadi satu."
		"{image:atm:textures/questpics/iron_spells/spells_outfit_priest.png width:60 height:100 align:center}"
	]
	quest.24BAC1C0392E950E.title: "&6Priest Outfit"
	quest.24C757B8AA6841F6.quest_desc: ["&5&lApotheosis&r tahu betapa menyebalkannya mendapatkan &3Trident&r, jadi mereka mempermudahnya... yah, agak mudah lah! \\n\\nKamu sekarang bisa membuat &3Inert Trident&r dan melakukan &d&lInfuse&r padanya untuk mendapatkan &3Trident&r normal. \\n\\n&3Trident&r membutuhkan antara &a40 Eterna&r, &c20%-50% Quanta&r, dan setidaknya &535% Arcana&r. \\n\\nKamu bisa mendapatkan ini dengan 1 &7Bookshelf&r biasa, 4 &9Echoing Sculkshelf&r, dan 1 &2Melonshelf&r."]
	quest.24C757B8AA6841F6.title: "Membuat Trident Asli"
	quest.24C9BA6DC32CFAD9.quest_desc: ["Coal adalah sumber power pertama yang sebenarnya. Kalau hampir habis dan tidak bisa menemukan Coal, alternatifnya bisa pakai Charcoal."]
	quest.24C9BA6DC32CFAD9.quest_subtitle: "Smelt log yang ada"
	quest.24D11ED5F4EEDC48.quest_desc: ["Bagi yang baru mengenal &6&lApotheosis&r, &9Socket&r bisa jadi membingungkan dan menjengkelkan. \\n\\nSingkatnya, Senjata dan Armor butuh &9Socket&r agar bisa dipasangi &aGem&r. \\n\\nTapi gimana kalau item-nya nggak punya &9Socket&r? \\n\\nKamu butuh &9Sigil of Socketing&r! \\n\\nGabungkan item dan &9Sigil&r di &8&lSmithing Table&r, dan boom, kamu bisa mendapatkan hingga 2 &9Socket&r."]
	quest.24D11ED5F4EEDC48.title: "&9Sigil of Socketing"
	quest.24D38DA8E86DD897.quest_desc: [
		"Yang terkecil dan terlemah di antara para &cRot Mobs&r. \\n\\nMereka punya 5 HP. \\n\\nSeperti semua &cRot Mobs&r, mereka akan menyerang &2Stoneborn&r serta &7Forgotten&r dan menjatuhkan &cUtheric Shard&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotling.png width:100 height:100 align:center}"
	]
	quest.24D38DA8E86DD897.title: "&cRotling&r"
	quest.24D3F605315ADB03.quest_desc: ["&9Wireless Universal Grid&r memungkinkanmu mengakses penyimpanan jaringan, antarmuka crafting bawaan, dan antrean crafting, semuanya secara nirkabel."]
	quest.24D3F605315ADB03.title: "&dWireless Universal Grid"
	quest.24E658BA47367A44.quest_desc: ["&aKatrol Tali&r akan menggerakkan Blok yang terhubung ke &aTali&r di bagian bawahnya. Blok yang di-&aGlue&r ke Blok tersebut juga ikut bergerak! \\n\\nKetika digerakkan &e&oSearah Jarum Jam&r oleh &dTenaga Rotasi&r, &aTali&r akan turun hingga menyentuh Blok lain, atau sampai batas yang ditentukan. \\n\\nKetika diberi &dTenaga Rotasi&r &9&oBerlawanan Jarum Jam&r, &aTali&r akan ditarik ke arah &aKatrol&r hingga mencapainya atau sampai batas yang ditentukan. \\n\\nKenapa terus bilang \"sampai batas yang ditentukan\"? Karena ada pengaturan tujuan dengan Mode Gerak! \\n\\nIni menentukan di mana Blok-blok berhenti!"]
	quest.24E658BA47367A44.title: "&aKatrol Tali"
	quest.24E800EEC2CAD626.quest_desc: ["&2Geiger &7Unit&r bakal kerja kayak &aDosimeter &7Unit&r tapi bukan &aRadiasi&r di dalam lo, melainkan &aRadiasi&r di sekitar lo! \\n\\nBiar lo bisa tau di mana dia bersembunyi. \\n\\nLo juga bisa enable sama disable!"]
	quest.24E800EEC2CAD626.quest_subtitle: "Bodyarmor"
	quest.24E800EEC2CAD626.title: "&2Geiger &7Unit"
	quest.24F3E90C14BFD1B4.quest_desc: ["&7&lModern Industrialization&r adalah mod sebesar namanya! \\n\\nIni punya beberapa tier mesin dan untungnya kita gak perlu sampe yang terakhir buat &6&lStar&r. \\n\\nMalah sekarang, ini opsional sepenuhnya! Kalo kamu lebih suka main sama &6&lCreate&r buat create (paham kan?) &6&lATM Star&r kamu bisa!"]
	quest.24F3E90C14BFD1B4.title: "&7&lModern Industrialization"
	quest.24FCFF18296ED907.quest_desc: ["Untuk meningkatkan &9Deepshelf&r lebih jauh lagi, ternyata kita tidak butuh &d&lInfusion&r! Melainkan butuh lebih banyak Crafting! \\n\\nPertama, siapkan 5 &3Sculk Block&r dan satu &3Sculk Catalyst&r. Keduanya bisa ditemukan di &9Deep Dark&r dan butuh &5Silk Touch&r untuk mengambilnya. \\n\\nTerakhir adalah &9Warden Tendril&r... ini adalah drop dari &9&lWarden&r... Ya, kamu harus membunuh &9&lWarden&r. \\n\\nSetelah punya semuanya, kamu bisa membuat salah satu rak buku terbaik! Memberikan &a10 Eterna&r, &c15% Quanta&r, dan &510% Arcana&r. \\n\\nDan yang terpenting, memberikan kita batas maksimal &aEterna&r hingga &a80&r! Hampir mencapai 100!"]
	quest.24FCFF18296ED907.title: "&9Soul-Touched Sculkshelf"
	quest.24FDA15A7ACDF021.quest_desc: ["&5Unobtainium Armor&r tapi dengan buff untuk mantra dari mod &e&lIron's Spells&r!"]
	quest.24FDA15A7ACDF021.quest_subtitle: "40"
	quest.24FDA15A7ACDF021.title: "&5Unobtainium Mage Outfit"
	quest.25080E3295B1DF01.quest_desc: ["&5Unobtainium Furnace&r smelt item lebih cepat dari Furnace manapun di pack ini!"]
	quest.25080E3295B1DF01.title: "&5Unobtainium Furnace"
	quest.251464B43353D4C6.quest_desc: ["Garden Cloche kesayangan kita! Ini adalah Pertanian otomatis, dan dengan Quest ini sederhana untuk digunakan! \\n\\nUntuk memulai, diperlukan &cEnergi &6Input&r dari Kiri, Kanan, atau Atas! \\n\\nKemudian memerlukan &9Air&r dari Port Belakang, (coba gunakan &9Wastafel&r). \\n\\nSelanjutnya, perlu Memasukkan Biji, Tanah Pertanian, dan Pupuk opsional dengan &eBarang &6Input&r di Bawah! \\n\\nDiperlukan Tanah Pertanian yang benar untuk Biji, bisa memeriksa ini semua dengan Klik Kanan Cloche untuk melihat GUI-nya! \\n\\nSetelah memiliki semua itu, akan dengan cepat tumbuh dan memanen Tanaman dan &6Mengeluarkan&r mereka di Depan Kubah. \\n\\nCatatan terakhir: akan menyimpan Biji dan Tanah Pertanian asli dan tidak akan menggunakannya, Tanah akan dibuat menjadi Tanah Pertanian, dan Pupuk adalah Belerang, Terak, Nitrat, dan Pupuk Industri."]
	quest.25213DBA6E6CEDD2.quest_desc: [
		"Lendir Shadowpulse adalah tingkat keempat dan terakhir dari lendir yang ditambahkan oleh JDT dan membutuhkan material Kota Kuno dan Warden untuk kerajinan."
		""
		"Kerajinan yang Terbuka:"
		"- Paduan Gerhana"
		"- Bara Gerhana"
		"- Kristal Waktu"
	]
	quest.252169A6EB4DD75B.quest_subtitle: "&f9 &cAttack Damage"
	quest.252A24CED69C1882.quest_desc: ["Generator Termoelektrik, yang akan kusebut Thermo, adalah Generator unik. \\n\\nSendirinya tidak akan melakukan apa-apa, yang perlu dilakukan adalah menempatkan Blok atau Cairan dengan Suhu berbeda di sisi berbeda Thermo. \\n\\nSemakin besar perbedaan Suhu, semakin banyak Energi yang dihasilkan!"]
	quest.252A24CED69C1882.title: "Energi dari Suhu"
	quest.252AD9C886DE45C8.quest_desc: [
		"Twilight Gaze adalah Ikan netral yang ada di The Abyss. \\n\\nKalau kamu mukul satu, semua bakal nyerang kamu, mirip kayak Wolf atau Zombified Piglin. Kalau kamu terlalu jauh dari The Abyss mereka bakal berhenti ngikutin kamu dan berenang balik ke dalam. \\n\\nMereka gak drop apa-apa kalau mati jadi mungkin jangan mukul mereka..."
		"{image:atm:textures/questpics/eternal/starlight_gaze.png width:150 height:100 align:center}"
	]
	quest.252AD9C886DE45C8.title: "Twilight Gaze"
	quest.253657BE5D9D9162.quest_desc: ["External Storage adalah jenis kabel interface yang merupakan salah satu item terpenting dalam perjalanan &3Refined Storage&r milikmu.\\n\\nKabel ini menghubungkan penyimpanan eksternal ke jaringanmu. Secara dasar, RS akan 'mengintip' ke dalam kontainer penyimpanan tersebut agar kamu bisa mengakses isinya melalui &3Grid&r!\\n\\nIni berfungsi pada banyak hal, termasuk: Peti (Chest), Barrel, Drawer, Drawer Controller, dan lainnya!\\n\\nJika kamu belum bisa membuat drive dan punya banyak peti di mana-mana, ini adalah pilihan terbaik untuk membuat jaringan penyimpanan!"]
	quest.253657BE5D9D9162.title: "External Storage"
	quest.253822C64BBBB1EB.quest_desc: ["&#6E6D6DForge Hammer&r akan memungkinkanmu untuk menghancurkan Ingot atau bijih &#9AD5EDTimah (Tin)&r menjadi bentuk Debu (Dust) dengan mudah."]
	quest.253957D992A88C88.quest_desc: [
		"Shield (Perisai) ini bisa ditemukan di struktur, dibuat, atau ditukar dengan &5Bee Queen&r. \\n\\nCara kerjanya seperti perisai &2Vanilla&r biasa, pegang di tangan kiri dan tahan serangan. \\n\\nYang membuatnya berbeda (dan lebih baik) adalah setelah kamu memperbaikinya dengan &5Honey Crystal&r, ia akan tumbuh semakin kuat."
		"{image:atm:textures/questpics/bumblezone/bumble_shield.png width:100 height:150 align:center}"
	]
	quest.2542D8A6894816C6.quest_desc: ["&eEye of Desert&r akan menuntunmu ke &eCursed Pyramid&r untuk melawan &e&lAncient Remnant&r."]
	quest.2542D8A6894816C6.title: "&eEye of Desert&r"
	quest.2559201BCF5D497C.quest_subtitle: "Membuat berbagai Material Overworld"
	quest.256C3DBA392B4236.quest_desc: ["Melakukan elektrolisis pada Larutan Asam (Acidic Solutions) untuk Manganese dan Chromium akan menghasilkan bentuk Debu (Dust) yang bisa digunakan untuk resep masa depan."]
	quest.256C3DBA392B4236.quest_subtitle: "9 Tiny Dust menghasilkan 1 Dust"
	quest.257C80468B080B3C.quest_desc: ["Elektromagnet adalah versi &8&lIE&r dari Absorption Hopper. \\n\\nYah, sepertinya! Tidak akan menahan &eBarang&r, melainkan akan dipindahkan paling dekat ke wajah Atas Elektromagnet. \\n\\nIni bisa digunakan untuk memasukkannya ke &eSabuk&r atau hopper! \\n\\nDiperlukan &cEnergi&r untuk digunakan."]
	quest.257D8912FC58DB59.quest_subtitle: "Brazilwood + Mahogany"
	quest.2581B7D8E6C6E510.quest_subtitle: "Tingkat: &63"
	quest.258B4890CF13D199.quest_desc: ["&aMagehunter&r adalah Senjata yang sangat aneh untuk didapatkan. Aneh dalam arti cara mendapatkannya sangat spesifik. \\n\\nUntuk mendapatkannya, kamu harus pergi ke &aEvoker Fort&r dan &aVindicator&r di lantai 2 akan memilikinya. Bunuh dia untuk mendapatkannya. \\n\\n&aPedang&r ini adalah Pedang yang bagus, memberikan 10 &4Heart Damage&r dengan kecepatan Pedang normal. \\n\\nSaat Memegangnya kamu akan mendapat sedikit &3Spell Resistance&r. Plus beberapa mungkin datang dengan Enchantment, punyaku begitu!"]
	quest.258B4890CF13D199.title: "&aMagehunter"
	quest.25906B43A198B72F.quest_desc: ["&rKnightmetal Armor&r bisa dibuat dengan Knightmetal Ingot dan berpeluang ditemukan di dalam peti &2Knight Phantom&r."]
	quest.25906B43A198B72F.title: "Armor Knightmetal"
	quest.2598273041353196.quest_desc: ["Saat bangun &aReprocessor&r, kamu butuh minimal satu &eCollector&r dan &9Waste Injector&r.\\n\\n&eReprocessor Collector&r harus ditaruh di tengah sisi bawah struktur.\\n\\n&9Waste Injector&r harus di tengah sisi atas, dimana kamu akan pompa atau masukin waste kayak &9Cyanite Ingot&r."]
	quest.2598273041353196.title: "Import Waste"
	quest.25A3E30F722B38B6.quest_desc: ["Kenapa kaget kalau &eGold&r ternyata dipake di mod? Kamu udah liat di real life kan fungsinya banyak! Juga buka jalan buat Generator unik yang ga cuma pakai Fuel Furnace biasa!"]
	quest.25A3E30F722B38B6.title: "&eGold Generator"
	quest.25ACB08E4F12CE79.quest_desc: ["&cNetherite Ministrosity&r adalah peliharaan (Pet) yang diberikan oleh mod &4&lCataclysm&r! \\n\\nPertama, kamu perlu membuat &cNetherite Effigy&r. \\n\\nLalu, kita bisa membunuh &c&lNetherite Monstrosity&r untuk mendapatkan &cLava Power Cell&r. \\n\\nTerakhir, letakkan &cEffigy&r dan beri makan &cPower Cell&r untuk menjinakkannya! \\n\\nSetelah jinak, ia bisa di-Shift+Klik Kanan untuk mengatur apakah ia mengikuti, diam, atau berkeliaran. \\n\\nKamu juga bisa Klik Kanan padanya untuk membuka inventarisnya (alias membelah kepalanya seperti Monster Batu di Lego Power Miners). Ia punya 15 slot inventaris. \\n\\nIa punya 3000 &4HP&r dan aku belum menemukan cara untuk menyembuhkannya..."]
	quest.25ACB08E4F12CE79.title: "&cNetherite Ministrosity"
	quest.25AFD10D008DF30B.quest_desc: ["Semua Ender Chest berbagi inventaris yang sama, dan inventaris ini berbeda untuk setiap pemain. Mereka tidak bisa digabung menjadi satu."]
	quest.25D4406CB86C8CBB.quest_desc: ["Sekarang kita ngumpulin &9waste&r dari reactor, bagian dari progres mengharuskan kamu \"Fluidize\" beberapa ingot yang didapat. Tau artinya apa?\\n\\nKita butuh bikin &aFluidizer&r! Komponen utamanya adalah &aFluidizer Controller&r. Setelah dibangun, kamu bisa klik kanan untuk buka interface. Di sini, kamu bisa nyalain atau matiin, lihat isinya, dan level power saat ini."]
	quest.25D4406CB86C8CBB.title: "Fluidizer"
	quest.25D84D82DBADA0DB.quest_subtitle: "Tingkat: &b4"
	quest.25D8BE0280B6E7F1.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.25DBA00422301EDC.quest_desc: ["Tingkat MEGA kedua dari komponen penyimpanan, menyediakan &e4.194.304&f (4096k) byte penyimpanan."]
	quest.25DBA00422301EDC.quest_subtitle: "x4"
	quest.25DBA00422301EDC.title: "Komponen Penyimpanan 4M"
	quest.25E782DB4309A1B8.quest_desc: ["Aurora Deer Antler di-drop sama Aurora Deer kalau mati. \\n\\nBisa dipake sebagai Sword atau Hoe."]
	quest.25E915AE1FC53254.quest_desc: ["Templat Celestigem digunakan untuk meningkatkan armor dan alat Blazegold ke Celestigem sambil mempertahankan mantra dan upgrade yang terpasang."]
	quest.25EFC21A3C48E0B6.title: "Tingkat: &2Spirited"
	quest.25F4D4A723B298A4.quest_subtitle: "Red Delicious Apple + Birch"
	quest.25F79B40579B3909.quest_desc: ["&5Decrepit Flamberge&r adalah Pedang pilihan untuk &5Ancient Knight&r dan beberapa &5Cursed Armor Stand&r. \\n\\nDi situlah juga kita bisa mendapatkannya, dengan Membunuh orang-orang itu! \\n\\nTerlihat seperti &5Netherite Sword&r, cuma seperti sedang bergoyang saat dibuat. \\n\\nIni memberikan 11 &4Heart Damage&r tapi sedikit lebih lambat dari Pedang. \\n\\nIni bisa di-upgrade dengan &6Pyrium&r untuk meningkatkan Attack Speed-nya."]
	quest.25F79B40579B3909.title: "&5Decrepit Flamberge"
	quest.2607F3DC07049785.quest_desc: ["Kenapa harus repot-repot duduk buat makan masakan rumah kalau kamu bisa makan dan minum dengan cepat! \\n\\nDengan &6Topi&r yang sangat bergaya ini, durasi makan dan minum jadi jauh lebih cepat."]
	quest.2607F3DC07049785.quest_subtitle: "Kepala"
	quest.2607F3DC07049785.title: "&6Plastic Drinking Hat"
	quest.260C7F3C1F51221D.quest_desc: ["&aEvocation Armor&r dari mod &e&lIron's Spells&r!"]
	quest.260C7F3C1F51221D.quest_subtitle: "20"
	quest.260C7F3C1F51221D.title: "&aArchevoker Outfit"
	quest.260F9C98DC2E485B.quest_subtitle: "Tingkat: &b4"
	quest.262036FE8E87F50A.quest_subtitle: "Menambang area 3x3"
	quest.262B307753106817.title: "Tenggelam dalam Keputusasaan"
	quest.263C9A0FC04472AB.quest_desc: ["Yang ini bisa makan &cLava&r kayak gak ada besok, atau dipake buat &6&lStar&r. \\n\\nYang ini susah, gue lebih suka liat &cLava&r hilang daripada barang gue hilang ke &cLava&r."]
	quest.263C9A0FC04472AB.title: "&464x Magmatic Generator"
	quest.263FBD9ED2756190.quest_subtitle: "Walnut + Coconut"
	quest.264BFB8C5F79616F.quest_desc: ["Meletakkan Snow Nest di biome bersalju akan memancing Sweat Bee."]
	quest.264BFB8C5F79616F.quest_subtitle: "Memancing Sweat Bee di biome dingin"
	quest.265D0DB0E8CED73B.title: "Draconic Projectile Gravity Compensation Module"
	quest.266127E7947CB3D4.quest_desc: ["Semua bangunan indah yang kamu lihat di halaman Quest ini berasal dari orang-orang di Discord ATM! \\n\\nJangan khawatir, semuanya telah memberikan persetujuan untuk membagikan karya mereka dan telah diberikan kredit! \\n\\nJika kamu ingin membagikan bangunanmu juga, cek channel artwork-builds-showoff di Discord! \\n\\n(Aku tidak bisa menjamin semua bangunan dibuat di ATM10, hanya saja mereka dibuat oleh sesama pemain Minecraft. Beberapa mungkin menggunakan Shader, jadi jika bangunanmu tidak terlihat persis sama, mungkin itu alasannya!)"]
	quest.2664373E8977E7BE.quest_desc: ["Siapa yang tahu &4Darah&r seperti Vampir! Tidak ada yang lain! \\n\\n&eSpellbook&r ini tidak terlalu sulit dibuat selain Ruined Book. \\n\\nItem lainnya hanya &5Arcane Ingot&r dan &4Bloody Vellum&r. &4Bloody Vellum&r dibuat dengan mencelupkan &dHogskin&r ke dalam Alchemist Cauldron penuh &4Darah&r. \\n\\n&eSpellbook&r ini punya 10 Spell Slot, dan akan memberikan Level ekstra untuk &4Blood Slash&r dan &4Blood Step&r!"]
	quest.2664373E8977E7BE.title: "&4Vampiric Spellbook"
	quest.2664388EBA1E8F90.quest_subtitle: "&f8 &cAttack Damage"
	quest.267A357B28228694.quest_desc: ["&#4DB85ERandom Access Memory (RAM)&r dibuat di dalam &#5EC7E6Chemical Reactor&r menggunakan &#A1A1A1Styrene-Butadiene Rubber&r, &#D15EE6Argon&r, &7Antimony Dust&r, &#5ED2E6Aluminum Dust&r, dan &#5D76C2Silicon Wafer&r."]
	quest.268768465119632A.quest_subtitle: "Aspen + Alder"
	quest.268EA2DEC8840D13.quest_desc: ["Waktu kerja di &4Computer&r, terutama yang Quantum, Palu dan Tang di Crafting Table gak bakal bisa craft apa yang kita butuhin, kita butuh &bCrystal Assembler&r. \\n\\nBuat yang ini kita butuh banyak banget &9Singularity&r!"]
	quest.268EA2DEC8840D13.title: "&4Quantum Computer Multi-Threader"
	quest.268F6E67AA79A7BD.quest_subtitle: "&f69 &cAttack Damage"
	quest.26988330D3E5BF95.title: "Pola Spanduk Anak Panah"
	quest.26988E22BD019628.quest_desc: ["Membakar item secara otomatis di dalam Tas."]
	quest.26988E22BD019628.quest_subtitle: "Otomatis"
	quest.26988E22BD019628.title: "&eAuto-Blasting Upgrade"
	quest.26A7746051A4A079.quest_subtitle: "Tingkat: &63"
	quest.26A9F402DAE15EA2.quest_desc: ["Menambahkan fungsi Smoker ke dalam Tas."]
	quest.26B3AE1E77A84BCB.quest_desc: ["Jika kamu melempar sebuah &9Osmium Bee Spawn Egg&r, &bCharged Certus Quartz&r, dan &8Sky Stone&r ke dalam Lava, kamu akan menciptakan sebuah &eSky Osmium Bee Spawn Egg&r."]
	quest.26B3AE1E77A84BCB.title: "Sky Osmium Bee"
	quest.26B462F2F41A77C7.quest_desc: ["Semua anugerah dari alam... bisa dibakar tanpa ampun di dalam Oven hingga menjadi &bGaram&r! \\n\\nBatang Kayu, Daun, dan Hasil Panen bisa dipanggang menjadi &bPlant Salt&r (Garam Tumbuhan)."]
	quest.26B462F2F41A77C7.title: "&bGaram Tumbuhan"
	quest.26B9909717528D5E.quest_subtitle: "Ditemukan di dimensi Undergarden"
	quest.26B9909717528D5E.title: "Utheric Bee"
	quest.26BEA64C80ECE1A6.quest_desc: ["Setiap &3Logistic Frame&r dapat digunakan untuk berbagai jenis otomatisasi."]
	quest.26DF1427AC3966DE.quest_desc: ["Selamat datang di Draconic Evolution, mod yang sangat seru dan OP! Untuk memulai kamu perlu menambang Draconic Ore untuk mendapat Draconic Dust. Muncul di semua Dimension (Vanilla) tapi paling banyak di End!"]
	quest.26DF1427AC3966DE.title: "Draconic Evolution"
	quest.26F9DB31A835B69C.quest_desc: ["&nFoundry&r: &aSiap&r \\n&nLogam Cair di Foundry&r: &aSiap&r \\n\\nSekarang bagaimana cara mengeluarkannya? \\n\\nIngat teman kita tadi? &bDrain&r &c&lFoundry&r? Kita perlu memperkenalkannya dengan teman baru, yaitu &c&lFoundry&r &7Tap&r (Keran). \\n\\nPasang &7Tap&r pada &bDrain&r, sekarang kita bisa meletakkan blok di bawahnya untuk mengalirkan &7Logam Cair&r ke... \\n\\nBlok seperti &8Casting Bin&r, yang akan mengubah sekitar 900mB &7Logam Cair&r menjadi satu &7Metal Block&r utuh. \\n\\nAtau &8Casting Table&r yang kita butuhkan untuk membuat..."]
	quest.26F9DB31A835B69C.title: "Pencetakan Item"
	quest.26FADB78B04F592B.quest_desc: ["&l&aBuilding Gadgets 2&r adalah mod yang menambahkan beberapa item yang sangat membantu. \\n\\nSemuanya tentu saja untuk membangun! \\n\\nMasing-masing membutuhkan &cEnergi&r untuk bekerja dan memiliki menu yang bisa dibuka secara standar dengan tombol &lG&r."]
	quest.26FADB78B04F592B.title: "&l&aBuilding Gadgets&r"
	quest.26FB7A789981BD3C.quest_subtitle: "Berikan sebuah blok Graphite ke Coal Bee"
	quest.26FB7A789981BD3C.title: "Graphite Bee"
	quest.270498437D938DD4.quest_desc: ["Dengan membuat Super Candle menggunakan Royal Jelly dan Potion, kamu akan mendapatkan Potion Candle! \\n\\nSaat lilin ini dinyalakan, ia akan memberikan efek ramuan tersebut ke semua orang di sekitarnya."]
	quest.270498437D938DD4.title: "Lilin Ramuan"
	quest.27195E9A3482C158.quest_desc: ["&bInhalation Purification &7Unit&r sebenernya lakuin beberapa hal. \\n\\n1. Bakal pake &aEnergi&r buat blokir Magic Damage. Kayak Potion of Instant Harming! \\n\\n2. Bisa di-Configure buat blokir Efek Potion berdasarkan level bantuan atau bahayanya. Beneficial, Neutral, sama Harmful. \\n\\nBeneficial bakal bantu Player dengan cara apapun. Kayak Regeneration, Healing, Speed, sama Strength. Neutral gak ngapa-ngapain, kayak Glowing. Harmful bakal bikin Game lebih susah buat Player. Kayak Wither, Weakness, atau Blindness."]
	quest.27195E9A3482C158.quest_subtitle: "Helmet"
	quest.27195E9A3482C158.title: "&bInhalation Purification &7Unit"
	quest.271A112ABDD923A6.quest_desc: ["Kayak Mangrove biasa tapi yang ini gak jelek."]
	quest.272CF280BAE6870E.quest_desc: [
		"Statistiknya mendekati &6Allthemodium Armor&r biasa, tapi set ini memberikan lebih banyak kekuatan untuk mantra-mantra mod Iron's Spells. \\n\\nPlus it's own Max Mana and Mana Regen!"
		"{image:atm:textures/questpics/allthemodium/all_armor_allmage.png width:100 height:175 align:center}"
	]
	quest.272CF280BAE6870E.title: "&6Allthemodium Mage Armor"
	quest.2738184B6A688D2C.quest_desc: ["&8Bulu Stymphalian&r bisa dipake buat bikin Anak Panah daripada Bulu Ayam buat bikin &8Anak Panah Stymphalian&r. \\n\\nAnak Panah ini lebih susah di-Craft tapi bakal worth it! \\n\\nAnak Panah-nya terbang lebih cepat, lebih jauh, dan gak bakal jatuh secepat itu."]
	quest.2738184B6A688D2C.title: "&8Anak Panah Stymphalian"
	quest.2745297337E13E9E.quest_desc: ["&3Advanced Air Compressor&r bekerja sama seperti Air Compressor biasa, hanya saja jauh lebih hebat!"]
	quest.2745297337E13E9E.quest_subtitle: "Nggak butuh Air Compressor lama yang membosankan lagi!"
	quest.2746575C929B6C50.quest_desc: ["Drawer bisa berukuran 1x1, 2x1, atau 2x2. Drawer dapat menampung sangat banyak stack item tergantung pada tipenya."]
	quest.2746575C929B6C50.quest_subtitle: "Tumpukan demi Tumpukan"
	quest.2747AEE1F7F97848.quest_desc: ["Potion bagus tapi lo gak benci mereka punya batas waktu? \\n\\nGak, diem dulu soal Infusion Pylon! \\n\\nPake &7Unit&r ini lo bakal lari lebih cepet dan lompat lebih tinggi! (Tapi lo masih gak jago main Basket). \\n\\nMakin banyak yang lo punya, makin cepet dan tinggi lo!"]
	quest.2747AEE1F7F97848.quest_subtitle: "Celana"
	quest.2747AEE1F7F97848.title: "&eLocomotive Boosting &7Unit"
	quest.2748ACEAB96A5F60.quest_desc: ["Iron Furnace (Jangan bingung antara judul dengan &lIron Furnaces&r yang merupakan nama mod dan nama Item) kerja lebih cepat dari Normal dan Copper Furnace. Butuh 160 Tick buat kerja, atau 8 detik.\\n\\nIni bisa di-craft dari Furnace biasa atau &6Copper Furnace&r! Dan bisa dibuat jadi &7Silver Furnace&r atau &eGold Furnace&r."]
	quest.2748ACEAB96A5F60.title: "&fIron Furnace"
	quest.27512B0434531195.quest_desc: ["&c&lChemical Injection Chamber&r itu &5Mesin&r lain yang kerjanya gabungin &eItem &fsama &cChemical&r, tapi kali ini cuma 1 &eItem&r plus 1 &cChemical&r buat bikin 1 &eItem&r baru! \\n\\nKamu bisa dapat &bWater Vapor&r dari masukin &9Air&r ke &c&lRotary &bCondensator&r, terus suntikkan (&cInject&r) &bWater Vapor&r itu ke Dead Coral buat hidupin lagi. \\n\\nKamu bisa dapat &bOxygen&r dari &9&lElectrolytic Separator&r terus suntikkan &bOxygen&f itu ke &6Copper&r buat bikin karatan (Oxidize). \\n\\nDan yang paling penting, pakai &3Hydrogen Chloride&r ke Ore Block buat dapat Ore Shard buat pengolahan lanjut!"]
	quest.27512B0434531195.title: "&c&lChemical Injection Chamber"
	quest.275D97BF0CE9DCD4.quest_subtitle: "Tingkat: &b3"
	quest.2777FEB022346947.quest_subtitle: "Tingkat: &a2"
	quest.27826D74ADC73556.quest_desc: ["Membakar &#ED8C61Copper Dust&r dengan &#90F0E7Oxygen&r di dalam &#E3CE54Kanthal EBF&r akan memberimu &#E87848Annealed Copper Hot Ingot&r. Ini dapat didinginkan di dalam &#4CBBD9Vacuum Freezer&r untuk mendapatkan &#E87848Annealed Copper Ingot&r. Ingot ini dapat digiling (macerated) untuk menjadi &#E87848Annealed Copper Dust&r."]
	quest.2786D5AC19163524.quest_desc: ["Blok ini aktifkan resep smelting di multi-block kitchen kamu!"]
	quest.2786D5AC19163524.quest_subtitle: "Gak Perlu Timer"
	quest.2786D5AC19163524.title: "Sayang, ada Furnace di Kitchen"
	quest.278D34BBC13356DF.quest_desc: [
		"Rawa berwarna ungu! \\n\\nDi sini terdapat Jamur Tinta dan Virulent Mix di mana-mana!"
		"{image:atm:textures/questpics/undergarden/undergarden_ink.png width:200 height:100 align:center}"
	]
	quest.278D34BBC13356DF.title: "Ink Mushroom Bog"
	quest.27A0BCE75F198A82.quest_subtitle: "Tingkat: &e1"
	quest.27A4FA38992448A0.quest_desc: [
		"Flux Networks juga menyediakan cara untuk mengisi daya item kamu secara nirkabel, bahkan lintas dimensi!\\n\\nSetelah kamu memiliki Plug yang terhubung ke sistem daya, buatlah &9Flux Controller&r dan pasang. \\n\\nKlik kanan untuk membuka antarmuka, dan buka tab \"Wireless Charging\". Dari sana, kamu bisa memilih bagian inventaris mana yang ingin terus diisi dayanya. Untuk mengaktifkan, pastikan tekan tombol toggle di bagian bawah untuk menyalakan Wireless Charging, lalu klik apply!\\n"
		"{image:atm:textures/questpics/basic_power/wireless_ui.png width:125 height:150 align:center}"
	]
	quest.27A4FA38992448A0.title: "Pengisian Daya Nirkabel"
	quest.27B5D0329DD92126.quest_desc: ["Sup... yang terbuat dari lebah? Terdengar agak kejam... \\n\\nMemakan/meminum ini akan memberimu efek Beenergized untuk sementara waktu dan memberikan peluang mendapatkan Luck (Keberuntungan)! \\n\\nJuga ada peluang mendapatkan efek Levitation, Slow Falling, Poison, dan Paralyzed (Lumpuh). \\n\\nNgomong-ngomong soal lumpuh, kamu bisa membuat Potion Paralyzing menggunakan sup ini."]
	quest.27CF1A2587321A2C.quest_desc: ["&eSpell Book&r terbaik yang bisa kamu bayangkan! 15 &3Spell&r Slot! Apa ada 15 &3Spell&r?!?! Oh tunggu ya ada 15 tidak sebanyak itu... \\n\\nLakukan sama seperti sebelumnya: Book sebelumnya, Ingot, dan Template."]
	quest.27CF1A2587321A2C.title: "&5Unobtainium&r Spell Book"
	quest.27E34DCC9C94F4FF.quest_desc: ["Quest ini dibuat oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r buat dipake di Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensiin di bawah &eAll Rights Reserved&r, Quest ini gak boleh dipake di pack publik manapun yang gak dirilis sama &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyiin, kalau kamu liat ini, berarti kamu lagi di mode editing."]
	quest.27E8ED4B5F8127F9.quest_subtitle: "Tingkat: &b4"
	quest.27E951F4F4F6F847.quest_desc: ["Mirip kayak &aThorn Pendant&r, cuma sedikit lebih panas. Eh nggak, jauh lebih panas! \\n\\n&cFlame Pendant&r berpeluang membakar musuh yang menyerangmu! Saat mereka terbakar, &cPendant&r ini juga bakal memberimu Fire Resistance."]
	quest.27E951F4F4F6F847.quest_subtitle: "Kalung"
	quest.27E951F4F4F6F847.title: "&cFlame Pendant&r"
	quest.27FA2DB7839172BB.quest_desc: ["&c&lRansel&r secara default hanya akan mengisi &eBarang&r di Tangan dan Armor yang dikenakan. Tapi bagaimana jika ingin mengisi lebih dari itu! \\n\\nMaka perlu Pengisi Induksi! Dengan ini terpasang, setiap &eBarang&r di Inventaris yang bisa mengambil muatan, akan terisi."]
	quest.27FC0C092EE00532.quest_desc: ["ME Canner bisa ngisi atau ngosongkan container yang bisa isi fluid, chemical, energy, seperti bucket, chemical tank, dan lainnya. Otomatis output ke pattern provider kalau pakai pattern buat ngisi mereka."]
	quest.27FC0C092EE00532.quest_subtitle: "jangan disamain sama me caner"
	quest.27FC0C092EE00532.title: "Isi Liquid: ME Canner"
	quest.27FD46A8C958D259.quest_desc: ["Totem Pemanggilan Kematian adalah totem sekali pakai yang memungkinkan pemain teleportasi kembali ke lokasi kematian mereka."]
	quest.27FEF80A08AF43C2.quest_desc: [
		"Sanctum sewarna &6L&8e&6b&8a&6h&r! \\n\\nJelajahi struktur ini, aku sarankan jangan menyentuh Tuas, Tombol, Tripwire, atau Pressure Plate apa pun karena bisa berakibat fatal! \\n\\nSetelah kamu sampai ke &eYellow Essence&r, bersiaplah untuk berlari! \\n\\nKamu harus berlari dan melompat melewati &eElectric Ring&r. Setelah kamu melakukannya, lebih banyak lagi yang akan muncul! Teruslah lakukan sampai akhirnya selesai."
		"{image:atm:textures/questpics/bumblezone/bumble_yellow1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_yellow2.png width:200 height:100 align:center}"
	]
	quest.27FEF80A08AF43C2.title: "&eYellow Sempiternal Sanctum&r"
	quest.2801B7B6BF61E978.quest_desc: ["&3Kerosene&r dapat digunakan untuk membuat Gasoline (Bensin) atau sebagai bahan bakar di Kerosene Lamp."]
	quest.2801B7B6BF61E978.quest_subtitle: "Udah Kero-seen ini belum?"
	quest.2801B7B6BF61E978.title: "Kerosene (Minyak Tanah)"
	quest.282A23C3E7561796.quest_desc: [
		"&#94C0E3Processing Array&r adalah struktur multiblock besar yang memungkinkanmu menjalankan banyak mesin secara paralel. Batas maksimal operasi paralel adalah &#94E3A264&r."
		""
		"Untuk membangun multiblock ini, pertama-tama pilih jumlah mesin paralel yang ingin kamu simulasikan di GUI blok controller."
		""
		"{image:atm:textures/questpics/modernindustrialization/proc_array_gui.png width:175 height:100 align:center}"
		""
		"{@pagebreak}"
		"Untuk menggunakannya, kamu perlu menaruh jenis mesin yang ingin disimulasikan ke dalam slot di sisi kanan GUI. Kamu membutuhkan jumlah item mesin yang sama dengan jumlah operasi yang diinginkan."
		""
		"Selain itu, &#94C0E3Processing Array&r juga menerima semua jenis upgrade secara normal."
	]
	quest.282CE3A088AE5CFB.quest_desc: ["Sudah crafting kan? Ini MineCRAFT kok.\\n\\nTentu, bisa crafting di inventory menggunakan crafting grid 2x2, tapi itu tidak akan jauh. Perlu upgrade dengan membuat Crafting Table!"]
	quest.282CE3A088AE5CFB.title: "Memasukkan Craft di Minecraft"
	quest.283AB56F81EF03A5.quest_desc: ["Untuk menenagai &6Electric Rail&r dan &eElectric Locomotive&r, kamu butuh &eFrame. Frame&r harus diberi daya dan akan menyalurkan listrik ke setiap &eFrame&r yang terhubung."]
	quest.283AB56F81EF03A5.title: "&eFrame Energi"
	quest.283D7E65F2AD45F2.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Versi tingkat lanjut dari Pemindai Monster yang memberikan efek Bercahaya ke monster di sekitar saat diaktifkan."
	]
	quest.28408BFAA54E4FC6.quest_desc: ["&7Leather Armor&r (Armor Kulit) adalah set terburuk yang bisa kamu dapatkan. \\n\\nItu karena &c&lMojang&r mengharapkan kamu mendapatkannya sebelum yang lain. \\n\\nTapi aku hampir nggak pernah bikin ini karena susah nyari &8S&fa&8p&fi&r sebanyak itu, maaf ya &c&lMojang&r!"]
	quest.28408BFAA54E4FC6.quest_subtitle: "7"
	quest.28408BFAA54E4FC6.title: "&7Leather Armor"
	quest.285656AF1F870AF8.quest_desc: ["1 dari 2 Infusion Tier Basic tapi jangan remehkan Draconic Chest. Menyimpan lebih banyak ruang dari double chest, bisa smelt dan craft item, dan yang terbaik bisa ganti warna! Mudah Chest favoritku di mod manapun!"]
	quest.285656AF1F870AF8.title: "Draconium Chest"
	quest.285B3FB38B12F8CA.quest_desc: [
		"Kita butuh dua blok ini untuk membuat &dSal Ammoniac&r. Sebuah &dSal Ammoniac&r Tank di bagian bawah dengan &dSal Ammoniac Accumulator&r di atasnya. \\n\\n&dSal Ammoniac Accumulator&r adalah tempat &9Air&r dan &dKristal&r dimasukkan; ia bisa menampung 10.000mb Air (10 Bucket) dan satu stack &dSal Ammoniac Crystal&r. Tank di bawahnya akan menampung hasil &dSal Ammoniac&r dan memiliki kapasitas 2.000mb (2 Bucket)."
		"{image:atm:textures/questpics/theurgy/theurgy_sal_front.png width:100 height:200 align:center}"
	]
	quest.285B3FB38B12F8CA.title: "Membuat &dSal Ammoniac"
	quest.2869AB982799CF0C.quest_desc: ["&cOne Way Track Kit&r sangat simpel. &7Cart&r hanya bisa bergerak ke arah yang ditunjuk oleh anak panah."]
	quest.2869AB982799CF0C.title: "&cTrack Kit&r Satu Arah"
	quest.2875FACD3BFB0A8E.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memberikan sedikit penyembuhan saat diaktifkan, tapi hanya bisa diaktifkan jika pemain baru saja terkena kerusakan atau sedang terkena kerusakan."
	]
	quest.288406DE6DA31BA6.quest_desc: ["Banyak hal memerlukan &cEnergi&r, terutama di &8&lIE&r. Untuk memulai, kita memerlukan &6Pemotong Kabel Insinyur&r! \\n\\nKamu bisa menggunakannya untuk memotong beberapa Pelat menjadi &cKabel&r yang kemudian bisa dimasukkan ke dalam &cGulungan&r, siap digunakan. \\n\\nMereka juga digunakan untuk mengambil &cKabel&r dari &cKonektor&r."]
	quest.288406DE6DA31BA6.title: "Daya &8&lImmersive Engineering&r!"
	quest.28847A536C38EEA0.quest_desc: ["&cTransformator&r adalah cara kita pergi dari Koneksi &6LV&r ke Koneksi &eMV&r. &cKonektor&r kecil adalah &6LV&r dan yang lebih besar adalah &eMV&r! \\n\\nJika ingin pergi dari &eMV&r ke &5HV&r, kita memerlukan &5Transformator HV&r. Ini bekerja sama dengan &cTransformator&r lainnya, hanya &cKonektor&r yang lebih kecil adalah &eMV&r dan yang lebih besar adalah &5HV&r! \\n\\nTidak, kamu tidak bisa pergi dari &6LV&r ke &5HV&r tanpa &eMV&r!"]
	quest.28847A536C38EEA0.quest_subtitle: "Disutradarai oleh Michael Bay"
	quest.28847A536C38EEA0.title: "&cTransformator"
	quest.288A4A32CDBB14D5.quest_desc: [
		"Struktur lain yang sebagian besar terbuat dari Ancient Wax. \\n\\nBentuknya hampir seperti antena parabola! Penuh dengan &eSerbuk Sari (Pollen)&r jadi hati-hati bagi yang punya alergi. \\n\\nDi bagian tengah kamu bisa menemukan satu blok Emerald dan banyak Amethyst."
		"{image:atm:textures/questpics/bumblezone/bumble_dish.png width:200 height:100 align:center}"
	]
	quest.288A4A32CDBB14D5.title: "Kuil Kuno"
	quest.2893F483C10293E6.quest_desc: [
		"&lSelamat datang di &bApplied Energistics 2&f!\\n\\nApplied Energistics 2 (atau singkatnya &oAE2&r) adalah mod &bpenyimpanan digital&f yang sangat serbaguna, memungkinkan penyimpanan yang sangat efisien dan segala macam kemampuan otomatisasi untuk memperhebat pengalaman Minecraft modded kamu.\\n\\nUntuk informasi lebih lanjut, kunjungi wiki mereka di"
		"&o&bappliedenergistics.github.io&f&r."
	]
	quest.2893F483C10293E6.quest_subtitle: "Sistem Penyimpanan Virtual"
	quest.2893F483C10293E6.title: "Applied Energistics 2"
	quest.2897FA291E5A38D8.quest_desc: ["&bSpatial Anchor&f adalah perangkat pendamping dari lini Spatial IO yang berfungsi sebagai pemuat chunk (chunk loader). Saat terhubung ke jaringan ME, Anchor akan memaksa pemuatan semua chunk yang ditempati oleh jaringan ME di seluruh kabel dan perangkat, tidak termasuk subnetwork, selama jaringan tetap bertenaga."]
	quest.2897FA291E5A38D8.title: "Spatial Anchor"
	quest.289B30DAC960BFF2.quest_desc: ["Bisa ditemukan di dalam peti di End City."]
	quest.289B30DAC960BFF2.quest_subtitle: "Peti End City"
	quest.28AE3B536D23E138.quest_subtitle: "Infusion Crafting"
	quest.28AE3B536D23E138.title: "Inferium Bee"
	quest.28AF8DD34412CBAA.title: "Draconic Speed Module"
	quest.28BF66D1B8CD4D44.quest_desc: ["&dBroom&r bisa dibuat pakai Broom Part. Setiap Broom terdiri dari 3 bagian: Rod, Cap, dan Brush.\\n\\nSetiap bagian bisa di-craft dengan gabungin bagian kosong dengan item tertentu buat kasih modifier spesifik. Karena terlalu banyak modifier buat ditulis, pastiin cek buku panduan buat info lebih!\\n\\nBuat craft Broom kamu, tinggal taro tiap bagian ke crafting table. Broom butuh Blood buat fungsi dengan benar."]
	quest.28BF66D1B8CD4D44.quest_subtitle: "Broom Broom"
	quest.28BF66D1B8CD4D44.title: "&cBlood &dBroom"
	quest.28C9EDBF6607E180.quest_desc: ["Blok ini adalah bagian dari multi-block kitchen.\\n\\nIni akan tunjukin setiap resep yang tersedia dengan makanan yang ada di inventory kamu, atau disimpan di multi-block kitchen.\\n\\nAkhirnya kamu bisa bikin dapur bagus di Minecraft."]
	quest.28C9EDBF6607E180.quest_subtitle: "Betty White lahir sebelum Roti Iris"
	quest.28C9EDBF6607E180.title: "HAL TERBAIK SEJAK ROTI IRIS"
	quest.28DB59B20109D0D4.quest_desc: ["&6&lOritech&r adalah Tech Mod (ya iyalah!) yang terkenal buat banyak &lMultiblock Machine&r, Block Berbahaya, dan Block Berjudul Penuh Warna! \\n\\nKamu butuh banyak Mesin, berbagai Alloy dan Material, dan banyak waktu. \\n\\nKamu butuh &6Magnetic Coil&r buat mulai, dan semoga beruntung!"]
	quest.28DB59B20109D0D4.title: "&6&lOritech"
	quest.28E60192912BEBAD.quest_desc: ["Di &l&2Vanilla&r, berurusan dengan Villager bisa sangat menjengkelkan. Mengganti daftar dagangan tidaklah mudah, dan profesi terkadang sulit diatur.\\n\\n&l&2Easy Villagers&r adalah mod yang membuat semuanya jauh lebih mudah! Sebagai permulaan, kamu bisa mengambil Villager dengan cara shift-klik kanan pada mereka. Mereka kemudian bisa diletakkan dengan mudah di dunia, atau di blok spesifik dari mod &l&2Easy Villagers&r!\\n\\nKamu bisa mencari &d@EasyVillagers&r di JEI untuk melihat blok apa saja yang ditawarkan mod ini!"]
	quest.28E60192912BEBAD.quest_subtitle: "Villager Jadi Mudah"
	quest.28E60192912BEBAD.title: "&l&2Easy Villagers"
	quest.28E99A6E17E86709.quest_desc: ["Memindahkan &bCairan&r adalah bagian penting dari &8&lIE&r, pikirkan saja Minyak Kreosot dan Minyak Tanaman! \\n\\n&bPipa Cairan&r adalah cara dasar kita memindahkan &bCairan&r, jika ingin lebih cepat periksa &bPompa Cairan&r. \\n\\n&bPipa Cairan&r, seperti Konektor Energi, ditentukan di mana &9Input&r dan &6Output&r dari apa yang terhubung. Beberapa Mesin memerlukan &4Sinyal Redstone&r untuk &6Mengeluarkan&r ke &bPipa Cairan&r, seperti &b&lTangki&r! \\n\\nKita bisa menggunakan &6Palu Insinyur&r untuk mengubah apa yang terhubung dengan &bPipa&r, plus bisa menggunakan &8Perancah Baja&r untuk menutupinya, atau Pewarna untuk mewarnainya!"]
	quest.28E99A6E17E86709.title: "Memindahkan &bCairan"
	quest.28FB4B9DCC268404.quest_subtitle: "Plum + Cherry"
	quest.28FDB2D13D0DDE8E.quest_desc: ["&b&lChipped&r mirip dengan mod Chisel karena ia mengubah desain blok, tetapi &b&lChipped&r punya cara sendiri untuk melakukannya! \\n\\n&b&lChipped&r menggunakan stasiun (Station) yang harus kamu datangi untuk mengubah blok. \\n\\nAda 7 stasiun berbeda yang masing-masing mengubah blok yang berbeda: Carpenters Table mengubah Kayu, Glassblower mengubah Kaca. \\n\\nDan 6 dari stasiun tersebut bisa diubah menjadi item genggam agar lebih mudah diakses. \\n\\nBahkan ada upgrade Backpack untuk mereka!"]
	quest.28FDB2D13D0DDE8E.title: "&l&bChipped&r"
	quest.28FEB4C11AD1AE7C.quest_desc: ["&bDiamond&r biasanya mahal... buat Vanilla, tapi ini modded kamu pasti punya cukup setidaknya buat 1 &bDiamond Generator&r. Masih pakai Fuel Furnace biasa."]
	quest.28FEB4C11AD1AE7C.title: "&bDiamond Generator"
	quest.290FAB3DE8FD04E7.quest_desc: ["Tahan klik kanan bakal charge Mace buat ngasih serangan AoE pakai &cBlood&r. Sneak-klik kanan bakal ganti power level.\\n\\nMakin tinggi power level, makin banyak damage dengan biaya Blood lebih mahal.\\n\\nKamu butuh yang fully charged buat craft &6ATM Star&r."]
	quest.29131C3532610ADF.quest_desc: ["Ini adalah Pillar Cap Tingkat 2 untuk Starlight Charger."]
	quest.29131C3532610ADF.title: "Pillar Cap Starlight Charger Tingkat 2"
	quest.291C76140DE97E3C.quest_desc: ["&bIgnitium&r itu seperti Netherite tapi butuh keahlian sungguhan untuk mendapatkannya. \\n\\nSang &b&lIgnis&r hanya akan menjatuhkan 1 buah, jadi gunakanlah dengan bijak! \\n\\nKamu bisa menggunakannya untuk meng-upgrade Armor Netherite-mu atau untuk membuat senjata."]
	quest.291C76140DE97E3C.quest_subtitle: "Lebih baik dari Netherite?"
	quest.291C76140DE97E3C.title: "&bIgnitium"
	quest.291EE514A1602C46.quest_subtitle: "Balsa + Flowering Azalea"
	quest.29283BF1B6ED3634.quest_desc: ["Mechanical Crossbow dibuat kayak Crossbow biasa cuma pakai Golem Steel. \\n\\nKerjanya kayak Crossbow biasa cuma jauh lebih kuat! Dan bisa di-enchant buat lebih kuat lagi!"]
	quest.29434DB0CC2E30E6.quest_desc: ["Gabungin &cMundabitur Dust&r, &bArcane Crystal Dust&r, &8Charcoal&r, dan &eGold Ingot&r kita akan dapet Alloy pertama! &6Deorum Ingot&r! \\n\\nIni adalah Ingot dasar dari &6&lForbidden \\& Arcanus&r, kamu butuh puluhan! \\n\\nIni terutama dipakai untuk Building Block untuk Multiblock Machine kita."]
	quest.29434DB0CC2E30E6.title: "&6Deorum"
	quest.294418130521FDF4.quest_desc: ["&bMithril&r adalah Ore yang hanya spawn jauh di bawah &2&lOverworld&r. \\n\\nIni akan spawn di sekitar Y Level -40 sampai &8Bedrock&r. Tepat di sekitar mana &cLava Pool&r berada! \\n\\nKamu butuh &5Netherite Pickaxe&r untuk Menambangnya dan hanya akan Drop 1 &bRaw Mithril&r kecuali kamu pakai Fortune. \\n\\n&bRaw Mithril&r ini bisa di-Smelt untuk membuat &bMithril Scrap&r. Ini bisa digunakan di Resep, atau kita bisa menggabungkan 4 untuk membuat &bMithril Ingot&r!"]
	quest.294418130521FDF4.title: "Mendapatkan &bMithril"
	quest.29448D08C8777425.quest_desc: ["Malam ini dia bakal tidur bareng Ikan. \\n\\n&cAngler's Hat&r membantumu menarik ikan lebih cepat dan meningkatkan peluang dapet Rare Drop!"]
	quest.29448D08C8777425.quest_subtitle: "Kepala"
	quest.29448D08C8777425.title: "&cAngler's Hat"
	quest.2951B1D7080C5EF9.quest_desc: ["Menggunakan &6Lamp of Cinders&r, kamu bisa menghancurkan duri di Biome Thornland.\\n\\nKumpulkan beberapa &cThorn Rose&r untuk melanjutkan perjalanan ke &2Final Plateau&r."]
	quest.2951B1D7080C5EF9.title: "Setiap Duri Punya Mawarnya"
	quest.295C77EEC89000FC.quest_subtitle: "Menghasilkan Source dari Kematian Mob dan Pembiakan Hewan"
	quest.295EB6CFEC029AE2.quest_desc: ["Sebelum sampai sini pertama kamu butuh item yang perlu OP di dalamnya: Wyvern Bow, Chaotic Capacitor, Staff of Power apapun. Lalu kamu butuh Energy Module di item, itu menentukan penyimpanan OP di item dan itulah yang akan dipakai item untuk mengisi daya. Setelah itu, buat dan tempatkan Energy Transfuser, masukkan OP ke dalamnya, lalu masukkan item-mu! Kamu tahu berhasil saat OP di dalamnya menyala dan bergerak."]
	quest.295EB6CFEC029AE2.title: "Menambah OP ke item"
	quest.29605960803BE885.quest_desc: ["&dAmethyst Rapier&r lumayan murah untuk apa yang dilakukannya! \\n\\nIni hanya &bWeapon Parts&f, &dAmethyst&r, dan Rantai. \\n\\n&dAmethyst Rapier&r memberikan 8 &4Heart Damage&r, sama dengan &5Netherite Sword&r. Cuma yang ini Mengayun jauh lebih cepat dengan Attack Speed 2.3. \\n\\nBagian spesial dari &dAmethyst Rapier&r adalah Spell bawaan yang didapat! &dEchoing Strike&r. \\n\\nDengan menekan (V) sambil memegang &dRapier&r, kamu akan mendapat &dEchoing Strike Effect&r. Mob mana pun yang Dipukul dengan &dRapier&r akan mengeluarkan gelombang kejut. Ini akan memberikan Damage ke Mob lain di dekatnya."]
	quest.29605960803BE885.title: "&dAmethyst Rapier"
	quest.2960FFE0C53DFEB1.quest_desc: [
		"&cSevira's Permanent Confinement&r adalah tingkat ketiga dari &6Ritual Infusi&r. Kegunaan utamanya adalah menciptakan kapur fondasi tingkat lanjut, yaitu Black Chalk."
		""
		"Ritual ini juga digunakan untuk membuat beberapa item yang bisa mempercepat pembuatan dan pelaksanaan ritual secara signifikan."
	]
	quest.2960FFE0C53DFEB1.quest_subtitle: "Ritual \"Bahkan Lebih Segala-galanya\""
	quest.2960FFE0C53DFEB1.title: "&cSevira's Permanent Confinement"
	quest.2982D38BD5EE6349.quest_subtitle: "Berikan Shroombee sebuah Warped Fungus"
	quest.2982D38BD5EE6349.title: "Warped Shroombee"
	quest.298437197EA5680D.quest_subtitle: "Black Cherry + Cacao"
	quest.298963543B99734E.quest_desc: ["Starlit Sea spawn versi Coral mereka sendiri! \\n\\nCuma jangan kayak aku yang lupa Silk Touch buat ngambil mereka..."]
	quest.298A7BED5C2C7582.quest_desc: ["&aInduction Cell&r ditaro di dalam &a&lEnergized Induction Matrix&r dan bakal nambah jumlah storage. \\n\\nDan iya, total mereka bakal numpuk! \\n\\n&aBasic Induction Cell&r: bakal nyimpen 3.2GFE masing-masing. \\n\\n&cAdvanced Induction Cell&r: bakal nyimpen 25.6GFE masing-masing. \\n\\n&bElite Induction Cell&r: bakal nyimpen 204.8GFE masing-masing. \\n\\n&5Ultimate Induction Cell&r: bakal nyimpen 1.6TFE masing-masing."]
	quest.298A7BED5C2C7582.quest_subtitle: "Storage"
	quest.298A7BED5C2C7582.title: "&aInduction Cell"
	quest.29917E6196649F5D.quest_desc: ["Kecepatan adalah jarak per waktu, alias seberapa lama untuk sampai dari titik A ke titik B... yah... kita bekerja dengan &dRotasi&r, jadi lebih tepatnya seberapa lama untuk kembali dari titik A ke titik A dalam lingkaran sebesar ini. \\n\\nPokoknya ini menunjukkan seberapa cepat &6Mesin&r kita bergerak, termasuk &dRoda Gigi&r dan &8Poros&r! \\n\\nIni penting karena Kecepatan mempengaruhi cara kerja &6Mesin&r lainnya. Beberapa butuh Kecepatan tertentu dan yang lain bekerja lebih efisien pada Kecepatan tinggi. \\n\\nKita bisa pasang Speedometer (ya, seperti di mobil) ke Sistem Kinetik kita untuk melihat seberapa cepat semuanya bergerak."]
	quest.29917E6196649F5D.title: "Kecepatan"
	quest.2993EAB4850B7172.quest_subtitle: "White Willow + Cherry"
	quest.299F56B753286D0C.quest_subtitle: "Tingkat: &e5"
	quest.29A05589E96C0569.quest_subtitle: "Tingkat: &54"
	quest.29A1E1FF02BD9219.quest_desc: [
		"Hutan sebiru Samudra. \\n\\nStarlight Forest sejauh ini adalah biome paling umum di Starlight. \\n\\nPunya puluhan Lunar Tree yang nutupin semuanya dengan banyak Mob, pasif dan hostile, di bawahnya."
		"{image:atm:textures/questpics/eternal/starlight_forest.png width:200 height:100 align:center}"
	]
	quest.29A1E1FF02BD9219.title: "Starlight Forest"
	quest.29A71E780923874E.quest_subtitle: "Nomad + Reed"
	quest.29A71E780923874E.title: "Silicon Bee"
	quest.29AE69722AB4C75C.quest_subtitle: "Tingkat: &a2"
	quest.29BDCF3C1B11B4C6.quest_desc: ["&6Pyrium Staff&r adalah Staff paling kuat... ya dari segi &4Damage&r, bukan Power. \\n\\nIni butuh 2 &6Pyrium Ingot&r, &5Netherite Ingot&r, dan &5Arcane Cloth&r. \\n\\n&5Netherite Ingot&f dan &5Arcane Cloth&r mudah, &6Pyrium&r... tidak. Kamu harus Membuka 2 Vault di &cCitadel&r. \\n\\n&6Pyrium Staff&r akan memberikan 5% &3Spell Power&r dan 15% untuk &cFire Spell&r. Serta 10% lebih sedikit Cast Time!"]
	quest.29BDCF3C1B11B4C6.title: "&6Pyrium Staff"
	quest.29C78845B488EDF8.quest_desc: [
		"Banyaknya &5Bunga Ungu&r dan &5Purple Luminescent Ancient Wax&r menunjukkan bahwa ini adalah &5struktur Ungu&r. \\n\\nLewati terowongan angin ungu, tenggelam melewati saluran air ungu, jalan melalui ruangan penuh bunga ungu, amethyst, dan tirai benang untuk sampai ke &5Purple Essence&r. \\nBegitu sampai, kamu harus bertahan hidup selama batas waktu yang ditentukan untuk menang. Duri Ungu akan muncul dari tanah untuk membunuhmu, hindarilah!"
		"{image:atm:textures/questpics/bumblezone/bumble_purple1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_purple2.png width:200 height:100 align:center}"
	]
	quest.29C78845B488EDF8.title: "&5Purple Sempiternal Sanctum"
	quest.29C83B00AC4AFC23.quest_desc: [
		"Sekarang setelah sampai sejauh ini, kamu mungkin bertanya, apa selanjutnya? Yah, masih banyak hal yang bisa dijelajahi di Occultism! "
		""
		"Kamu bisa melihat daftar lengkap setiap ritual dan item di dalam &6Dictionary of Spirits&r milikmu. Cobalah telusuri semua hasil ritual untuk melihat apakah ada yang menarik minatmu!"
		""
		"Jika belum, kamu bisa menata dan mendekorasi tiga area ritual terpisah: satu untuk Pemanggilan (Summon), satu untuk Perasukan (Possession), dan satu untuk Infusi (Infusion)."
		""
		"Selalu ada cara baru untuk menggunakan setiap fitur yang terlihat biasa saja demi memaksimalkan pengalamanmu. Selamat ber-ritual!"
	]
	quest.29C83B00AC4AFC23.title: "Apa Selanjutnya?"
	quest.29C9F8719DA63D8D.quest_desc: ["&2&lGergaji&r bekerja mirip dengan &4&lBor Pertambangan&r, hanya untuk &2Pohon&r! \\n\\nMemerlukan &2Bio-Diesel&r sebagai Bahan Bakar, yang tidak akan dijelaskan cara mendapatkannya di sini! \\n\\nDan semacam &8Bilah Gergaji&r. Yang bisa dipasang melalui Slot Atas di &6Meja Kerja Insinyur&r. \\n\\nCukup hancurkan Log pada &2Pohon&r dan setiap Log, Daun, dan Sarang Burung akan turun dengannya! Bisa tahan Shift untuk tidak merusak semua yang terpasang. \\n\\n&2&lGergaji&r juga memberikan 10 Kerusakan! Wah, mengapa menggunakan Pedang? Oh ya, &8Gergaji&r memiliki Daya Tahan dan memerlukan &2Bio-Diesel&r. \\n\\n&2&lGergaji&r bisa menampung 1 &8Bilah&r atau &8Disk&r dan 2 Upgrade."]
	quest.29C9F8719DA63D8D.title: "&2&lGergaji"
	quest.29D28983E0200A3C.quest_desc: ["&l&dArs Nouveau&r itu semua tentang pake Glyph di Spellbook buat bisa cast mereka sebagai Spell!"]
	quest.29D28983E0200A3C.title: "&d&lArs Nouveau"
	quest.29D309F9740FAEEA.quest_subtitle: "Tingkat: &c5"
	quest.29DF2E7D0402284F.title: "Kecemerlangan"
	quest.29E2033EA65E706E.quest_desc: [
		"Di sini kamu bisa menemukan rumah seorang Slime Rancher yang sedang mencari nafkah... tunggu apa? Bagaimana bisa ada Villager di sini?\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_ranch.png width:200 height:100 align:center}"
	]
	quest.29E2033EA65E706E.quest_subtitle: "Seorang \"Slime Rancher\""
	quest.29E2033EA65E706E.title: "Peternakan &6Honey Slime&r"
	quest.29E9E361DDC8041B.title: "Pola Spanduk Matahari"
	quest.29EA8E178F8F8FDB.quest_desc: ["&9&lSimple Reforging Table&r digunakan mirip seperti &5&lEnchantment Table&r tapi untuk &eAffix&r! \\n\\nUntuk menambahkan &eAffix&r ke sebuah &eItem&r, letakkan item di slot tengah. Lalu, masukkan Material Rarity di slot kiri. \\n\\nMaterial Rarity akan menentukan tingkat &eAffix&r yang didapat. Ini bisa digunakan untuk meng-upgrade item, misalnya dari &8Common&r ke &aUncommon&r. \\n\\nKamu akan diberi 3 pilihan &eAffix&r; mirip dengan meja enchant, pilihan kedua dan ketiga jauh lebih mahal. \\n\\nDengan &9&lSimple Reforging Table&r, kita hanya bisa mendapatkan &eAffix&r hingga tingkat &9Rare&r."]
	quest.29EA8E178F8F8FDB.title: "&9&lSimple Reforging Table"
	quest.29EC143D7E0347DE.quest_desc: ["Dagger of Hunger dibuat dengan Teeth of Hunger. Bukan, aku gak bilang Tooths. \\n\\nDagger punya Hunger Value. Kalau kamu mukul Mob dia bakal naik, kalau inactive dia bakal turun. Kalau sampai 100% kamu dapet boost. Dan kalau sampai 0% dia bakal mulai bunuh kamu. \\n\\nKalau kamu mukul Mob (atau Player) dia juga bakal ngasih efek Hunger. \\n\\nGak nyalahin sih, aku juga marah kalau lagi laper."]
	quest.29EE878BC8D3A742.quest_desc: [
		"Untuk memulai peternakan lebah, kita harus menemukan lebah... lalu menangkap mereka."
		""
		"Klik kanan pada lebah dengan alat ini untuk menangkapnya!"
		""
		"Saat berpetualang kamu juga bisa menemukan &6Sturdy Bee Cage&r di peti harta karun!"
	]
	quest.29EE878BC8D3A742.title: "Menangkap Lebah!"
	quest.29FA0E9664935566.quest_subtitle: "Balsa + Cacao"
	quest.2A01CE9206DD4F8A.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Menambang balok bijih yang berdekatan sekaligus, tapi butuh waktu sedikit lebih lama untuk menambang."
	]
	quest.2A032EC573B5316C.quest_desc: ["Untuk mencapai &lWorld Tier: &2Frontier&r, kamu jelas harus menyelesaikan &9&lHaven&r, tapi juga butuh beberapa &eAffixed Item&r! \\n\\nBerapa banyak? Kamu butuh satu set lengkap &eAffixed Armor&r plus satu &ePeralatan &fatau &eSenjata&r yang memiliki Affix. \\n\\nSekarang &4Invader &fdan &aGem&r tingkat &aUncommon&r akan paling melimpah, diikuti oleh: &8Common&r, &9Rare&r, dan juga &5Epic&r. \\n\\nPemain di &lWorld Tier: &2Frontier&r akan mendapat bonus 35% Experience plus 20% Luck! \\n\\nTapi nggak semuanya mudah, sekarang &4Monster&r akan mendapatkan tambahan 4 Armor Point."]
	quest.2A032EC573B5316C.title: "&lWorld Tier: &2Frontier"
	quest.2A049419C78E96F4.quest_subtitle: "Tingkat: &a2"
	quest.2A0B3C91D72E8B75.quest_desc: ["Yeti kecil dan Winter Wolf menjatuhkan Arctic Fur, yang bisa digunakan untuk membuat &6Arctic Armor&r."]
	quest.2A0B3C91D72E8B75.quest_subtitle: "Bisa Diwarnai!"
	quest.2A0B3C91D72E8B75.title: "Armor &6Arctic"
	quest.2A196974431FCC42.quest_desc: ["&cInfernal Forge&r adalah drop dari &c&lNetherite Monstrosity&r dan secara teknis bukan senjata, melainkan beliung (pickaxe)! \\nBisa digunakan untuk menambang hingga tingkat Netherite, jadi bisa untuk menambang bijih Allthemodium. \\n\\nSaat Klik Kanan, ia akan menyerang dalam mode AOE (area), menghantam tanah dan melukai semua yang ada di dekatnya. \\n\\n(Senjata ini bisa diberi mantra Pedang maupun Beliung!)"]
	quest.2A196974431FCC42.title: "&cInfernal Forge"
	quest.2A1BFB2E0F1F3312.quest_desc: ["&dEnd Rod&r memberikan 10 Kerusakan serta mengenai Endermen. \\n&5Enderpearls&r tidak akan mengenai Mob, melainkan akan menteleportasi jauh lebih jauh saat ditembak. \\n&3Trisula&r bertindak seperti lemparan &3Trisula&r normal, memberikan 8 Kerusakan. \\n&cBlaze Rods&r memberikan 10 Kerusakan dan membakar Mob!"]
	quest.2A1BFB2E0F1F3312.title: "Ammo &5&lRailgun&r dari &2&lMinecraft"
	quest.2A20000FAEC2E16A.quest_desc: ["Untuk ngeluarin power atau item dari reactor, atau bahkan masukin fuel, kamu butuh blok &crequired&r ini.\\n\\n&cPower Tap&r kasih cara buat \"tap\" ke power yang dibuat reactor &9passive&r. Kamu bisa pasang pipe dan kabel buat ngeluarin power dari sini.\\n\\n&aAccess Port&r diperlukan buat setiap reactor, dan memungkinkan kamu masukin fuel ke reactor, atau ngeluarin waste. Biasanya ide bagus punya 2 per reactor, satu buat tiap job."]
	quest.2A20000FAEC2E16A.title: "Berinteraksi dengan Reactor"
	quest.2A26CE0E88B62002.quest_desc: ["Pas Mati &4&lCyclops&r bakal Drop beberapa Item yang berhubungan dengan Domba kayak Daging Domba dan Wool bahkan Kulit? \\n\\nSangat jarang dia mungkin Drop Tengkorak atau &4Mata&r-nya! \\n\\n&4Mata Cyclops&r, pas dipegang bakal bikin semua Musuh Hostile yang deket punya Weakness II. \\n\\nGue rekomen pegang di Offhand jadi Tangan Utama bisa pake Senjata kamu!"]
	quest.2A26CE0E88B62002.title: "&4Mata Cyclops"
	quest.2A2CC461B9620BDC.quest_subtitle: "Tingkat: &a2"
	quest.2A30595DC6DDBFF7.quest_desc: [
		"&6Electric Track&r digunakan untuk &eElectric Locomotive&r. Rel ini harus ditenagai oleh &eFrame&r dan ya, kamu akan kesetrum jika menyentuhnya."
		"{image:atm:textures/questpics/railcraft/rail_electric_rail.png width:150 height:100 align:center}"
	]
	quest.2A30595DC6DDBFF7.title: "&6Rel Elektrik"
	quest.2A3683BF7E50EF83.quest_desc: [
		"Sejauh ini, sebagian besar item yang kita butuhkan dari &3Otherworld&r hanya memerlukan Spiritfire. Namun, kita perlu bantuan &3Third Eye&r (Mata Ketiga) untuk menemukan bijih (ore) di &3Otherworld&r."
		""
		"Kita juga butuh beliung khusus untuk menambangnya. Untuk itu, kita perlu meng-infusi Setan ke dalam &dSpirit Attuned Pickaxe Head&r untuk menciptakan beliung yang bisa menghancurkan bijih jenis baru ini."
	]
	quest.2A3683BF7E50EF83.title: "Peralatan Profesi: Infused Pickaxe"
	quest.2A444F4CCC72545D.quest_desc: ["Item paling gampang yang kita butuhin buat &6&lATM Star&r dari &4&lCataclysm&r adalah &5Abyssal Sacrifice&r. \\n\\nItem paling dasar yang dibutuhin adalah Block of Ingot dan Amethyst yang cuma Item &2&lVanilla&r. \\n\\nTerus, kamu butuh Nautilus Shell dan Heart of the Sea. Ini Item &2&lVanilla&r yang langka... kecuali kamu bunuh &5Deepling&r yang bisa drop mereka! \\n\\nKamu juga butuh Athame yang merupakan senjata yang dipake &5Deepling Warlock &fdan &5Priest&r dan di-drop mereka waktu mati. \\nBagian terakhir kasih kita pilihan, antara Crystallized Coral atau Coral Chunk. Keduanya drop dari &5Coral Golem&r dan &5Coralssus&r."]
	quest.2A444F4CCC72545D.title: "&5Abyssal Sacrifice"
	quest.2A4FE9644F3B9DC1.quest_desc: ["Versi peningkatan dari &2Prudentium&r."]
	quest.2A4FE9644F3B9DC1.quest_subtitle: "26"
	quest.2A4FE9644F3B9DC1.title: "&cTertium Armor"
	quest.2A5004EB99AE4F96.quest_desc: [
		"Ada lebih banyak item Otherworld yang perlu kamu kumpulkan, dan memakan &cDemon's Dream Fruit&r setiap kali butuh efek &7Third Eye&r itu menjengkelkan."
		""
		"Inilah gunanya &dOtherworld Goggles&r! Saat dipakai (bahkan di slot Curios), ia akan memberikan efek Mata Ketiga secara permanen!"
	]
	quest.2A5004EB99AE4F96.quest_subtitle: "Berhenti makan buah itu!"
	quest.2A5004EB99AE4F96.title: "Peralatan Profesi: Spectral Goggles"
	quest.2A50A687C40DB864.quest_desc: [
		"&6&lHive Walls&r adalah fondasi dari &l&6Bumblezone&r. \\n\\nMereka adalah dinding raksasa dari &6Honey Combs&r dan &eWax&r yang membentang dari lantai hingga atap. \\n\\nMereka juga menyimpan Combs dari mod &lProductive Bee&r dan lubang-lubang di &6&lDinding&r tempat Brood Block muncul."
		"{image:atm:textures/questpics/bumblezone/bumble_hivewall.png width:200 height:100 align:center}"
	]
	quest.2A50A687C40DB864.title: "&6&lDinding Hive"
	quest.2A559D527BC88DEC.quest_desc: ["Jika kamu melempar sebuah &9Spatial Bee Spawn Egg&r dan sebuah &8Sky Steel Block&r ke dalam Lava, kamu akan menciptakan Sky Steel Bee Spawn Egg."]
	quest.2A559D527BC88DEC.title: "Sky Steel Bee"
	quest.2A5C5B44E9643A5D.title: "Chaotic Speed Module"
	quest.2A6753C806D2AF8D.quest_desc: ["Menghasilkan damage yang lebih besar dari yang pernah kamu butuhkan! Tapi ada beberapa sisi negatifnya."]
	quest.2A6753C806D2AF8D.quest_subtitle: "&f∞ &cAttack Damage"
	quest.2A6900E87DE8BAE0.quest_desc: ["Mod Filter adalah filter dasar lainnya. Di sini kamu memasukkan Item dan ia akan melakukan hal yang sama dengan Whitelist atau Blacklist. Namun, alih-alih hanya item itu saja, ia akan menyaring semua Item dari Mod tersebut. \\n\\nApotheosis Gem hanya akan mengizinkan item dari Apotheosis. Mekanism Alloy hanya akan mengizinkan item Mekanism, dan seterusnya."]
	quest.2A6FC21142E75DD5.quest_desc: [
		"Danau, Samudra, Kolam, dan Sungai di &l&6Bumblezone&r. \\n\\nMungkin asalnya hanya &bAir&r biasa, tapi karena terlalu lama berada di dalam &eHive&r, airnya berubah menjadi &bSugar Water (Air Gula)&r. \\n\\nTempat ini sangat membantu untuk navigasi keluar dari &l&6Bumblezone&r karena lebih sedikit blok yang menghalangi di biome ini. \\n\\nJuga &6Honey Slime&r terkadang muncul di sini."
		"{image:atm:textures/questpics/bumblezone/bumble_sugar.png width:200 height:100 align:center}"
	]
	quest.2A6FC21142E75DD5.title: "Danau Gula! (&bAir&r)"
	quest.2A72B262AF4F11C9.quest_desc: ["Buat dapetin Sapling &6Socotra Dragon&r kamu harus Breed &7Wenge&r sama &4Cocobolo&r. \\n\\nBuat dapetin &7Wenge&r kamu harus Breed &4Cocobolo&r sama &fBalsa&r. \\n\\nBuat dapetin &4Cocobolo&r kamu harus Breed Balsa sama &8Dark Oak&r. \\n\\nBuat dapetin &fBalsa&r kamu harus Breed &cAcacia&r sama &eTeak&r. \\n\\nBuat dapetin &fTeak&r kamu bisa Breed &2Jungle&r dan &8Dark Oak&r."]
	quest.2A72B262AF4F11C9.title: "Sapling &6Socotra Dragon&r"
	quest.2A787B99A8B0C767.quest_desc: [
		"Block yang sangat penting dan sangat umum! Bisa di-craft atau ditemukan di kebanyakan Struktur &lIron Spells&r. \\n\\nIni digunakan untuk menambah dan menghapus &3Scroll&r dari &eSpell Book&r! Lempar &eSpell Book&r ke Slot Book lalu &3Scroll&r di bawahnya. Jika kamu ingin menghapus &3Scroll&r, klik lalu ambil dari kanan dan ke Inventorymu."
		"{image:atm:textures/questpics/iron_spells/spells_table_gui.png width:150 height:100 align:center}"
	]
	quest.2A793B35FE25003C.quest_desc: ["&l&cRotary &bCondensator&r mungkin bikin &cGas&f dari &bCairan&r, tapi &c&lChemical &eOxidizer&r bisa ngerubah (beberapa) Item jadi Gas! \\n\\nIni termasuk &cInfuse Type&f kayak &0Coal &fjadi &0Carbon&r. \\n\\nIni juga bakal dibutuhin buat ngerubah Wasted Combs dan Lithium Combs jadi &cChemical&r mereka! \\n\\n&eItem&r masuk ke &4Slot Merah&r dan bentuk &cGas&r barunya bakal muncul di &9Bar Biru&r."]
	quest.2A793B35FE25003C.title: "&c&lChemical &eOxidizer"
	quest.2A7E3F2CD335EAD0.quest_desc: ["Buat mulai perjalanan kamu bikin &aPeralatan Essence&r, kamu harus bikin Armor Inferium dulu.\\n\\nPerlengkapan ini bisa di-upgrade ke tingkat lebih tinggi, persis kayak Essence. Kamu juga bisa &9nge-Augment&r mereka dengan &bMeja Tinkering&r!"]
	quest.2A7E3F2CD335EAD0.title: "&aArmor Inferium"
	quest.2A919F73CB09CF8B.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kecepatan Lari"
		"- Kecepatan Jalan"
		"- Kecepatan Berenang"
		"- Umpan"
		"- Fase"
	]
	quest.2A95F4F998835B43.quest_subtitle: "9 Nugget -> 1 Ingot"
	quest.2A976D41F79C34B1.quest_desc: ["&e&lPipez&r memiliki cara penyaringan (Filtering) item sendiri, tapi kamu butuh setidaknya Advanced Upgrade untuk mendapatkannya. Saat Advanced Upgrade terpasang, kamu bisa klik tombol Add untuk menambahkan Filter. \\nLalu kamu bisa menambahkan: Item, Tag, atau NBT ke dalam Filter. \\n\\nDi sana kamu juga bisa menambahkan filter tujuan (Destination). Untuk mengaturnya, Shift + Klik Kanan pada sebuah Inventaris dengan filter tersebut. \\n\\nKamu juga harus mengaturnya ke Whitelist (hanya mengizinkan filter tersebut) atau Blacklist (mengizinkan semuanya kecuali filter tersebut)."]
	quest.2AA08313F927981E.title: "Wyvern Speed Module"
	quest.2AA407EB0BF2922E.quest_subtitle: "Sweetgum + Loblolly"
	quest.2AAE61752728EA8D.quest_desc: ["Saat 'jatuh' Mining-mu melambat. Termasuk saat creative flying atau bahkan memantul di air. Untungnya kamu bisa pakai Enchantment Air Affinity untuk meniadakan itu! Bukan Enchantment vanilla tapi tetap membantu! Oh tunggu aku seharusnya bicara tentang Module... sama aja!"]
	quest.2AAE61752728EA8D.title: "Mining Stabilizer Module"
	quest.2AB0FA084739827A.quest_desc: ["Untuk menggunakan &9Tunnel Bore&r, kamu butuh &9Tunnel Bore Head&r. \\n\\nAda 4 jenis kepala bor dan kemampuannya menambang bergantung pada jenis &9Bore Head&r tersebut. \\n\\nAlat ini bisa diberi mantra (enchant) dan memiliki durabilitas, jadi sebaiknya beri mantra agar lebih awet!"]
	quest.2AB0FA084739827A.title: "Kepala Bor Tunnel Bore"
	quest.2ABAE97E992BB800.title: "Pola Spanduk Sarang Lebah"
	quest.2AC7BC448C007BDB.quest_desc: ["Perkuat Kivi dengan Aluminum dan kamu akan mendapatkan Machine Frame yang dibutuhkan untuk membuat mesin."]
	quest.2ACFD25B43F0499C.quest_subtitle: "Ipe + Luck"
	quest.2AD13B965611DC86.quest_desc: [
		"Bisa dibilang biome paling menarik di &l&6Bumblezone&r, yaitu &7&lHowling Constructs&r. \\n\\nDi tanah terdapat duri-duri dari Infused Sugar Stone, &eCarvable Wax&r, dan &6Madu&r. \\n\\nBagian yang menarik adalah apa yang ada di atas. Ada &7struktur melayang&r di seluruh penjuru &l&7Howling Constructs&r. \\n\\nMereka terbuat dari Ancient Wax yang akan kamu pelajari lebih lanjut nanti."
		"{image:atm:textures/questpics/bumblezone/bumble_constructs.png width:200 height:100 align:center}"
	]
	quest.2AD13B965611DC86.title: "&7&lHowling Constructs"
	quest.2AD68066C1948C90.quest_desc: [
		"&eFoliot Crusher&r pertama itu memang keren, tapi bagaimana jika aku bilang kamu bisa memanggil setan yang memberimu 6 debu untuk setiap satu bijih mentah yang dihancurkannya?"
		""
		"&9Marid Crusher&r melakukan tepat seperti itu. Untuk memanggilnya, kamu perlu menggunakan ritual &9Fatma's Incentivized Attraction&r. "
	]
	quest.2AD68066C1948C90.quest_subtitle: "Pemanggilan Maksimal"
	quest.2AD68066C1948C90.title: "&9Fatma's Incentivized Attraction"
	quest.2AD78E22988A92D3.quest_desc: ["Aku melihatmu! \\n\\nSaat memakai &2Night Vision Goggles&r, kamu bisa melihat di dalam kegelapan! Nggak ada fungsi lain sih..."]
	quest.2AD78E22988A92D3.quest_subtitle: "Kepala"
	quest.2AD78E22988A92D3.title: "&2Night Vision Goggles"
	quest.2ADA491A2485061C.quest_desc: [
		"&aExperience&r adalah Slot ke-4 dan material yang diperlukan untuk &6&lForge&r. \\n\\nUntuk tambah &aExperience&r kamu perlu taruh 1 dari 3 hal ke &aExperience Slot&r. \\n\\n1. &aXpetrified Orb&r, ini kasih paling banyak &aEXP&r. \\n\\n2. &aBottle 'O Enchanting&r, kasih sedikit &aEXP&r tapi gampang didapat! \\n\\n3. &5Enchanted Item&r, &6&lForge&r akan scrap &5Enchantment&r darinya simpan sebagai &aEXP&r!"
		"{image:atm:textures/questpics/forbidden/forbidden_experience.png width:135 height:100 align:center}"
	]
	quest.2ADA491A2485061C.title: "&aExperience"
	quest.2AEA51044AD44BE8.quest_desc: ["&ePenampang&r akan menampung &eItem&r. Bisa menampung untuk diproses, diteruskan ke &eSelokan&r, atau bahkan sekadar dekorasi! \\n\\nKamu bisa pasang &eSelokan&r di dekat ujung &eSabuk&r untuk membawa &eItem&f dari &eSabuk&f ke &ePenampang&r. \\n\\n&ePenampang&r juga bisa diletakkan di bawah &6Mesin&r untuk memproses &eItem&r di dalamnya. "]
	quest.2AEA51044AD44BE8.title: "&ePenampang"
	quest.2AEBE3F28996A6ED.quest_desc: ["Dengan metal baru, bisa upgrade Furnace menggunakan mod &aIron Furnaces&r!\\n\\nIron Furnaces (Furnace dari mod itu sendiri, bukan hanya versi Iron) memungkinkan menambahkan &aAugment&r untuk upgrade kecepatan Furnace, mengubah fungsinya, dan banyak lagi!\\n\\nFurnace ini membuat otomasi lebih mudah dengan memungkinkan auto-pull atau push dari samping menggunakan config di sebelah kiri interface."]
	quest.2AEBE3F28996A6ED.title: "&aUpgrade Furnace&r!"
	quest.2AEC294578952BFD.quest_subtitle: "Lapis + Skeletal"
	quest.2AEC294578952BFD.title: "Dye Bee"
	quest.2AECDD9E2DEA708C.quest_subtitle: "Tingkat: &a2"
	quest.2AED15E3AC0346FE.quest_desc: [
		"Di bawah ini adalah beberapa &3Upgrade&r yang bisa kamu gunakan di awal mod ini. Tahan Shift sambil mengarahkan kursor ke sebuah &3Upgrade&r untuk melihat di mana ia bisa digunakan, atau lakukan hal yang sama pada mesin untuk melihat upgrade apa saja yang didukung."
		""
		"Catatan: Subtitle akan memberitahumu jumlah maksimal &3Upgrade&r yang bisa dipasang."
	]
	quest.2AED15E3AC0346FE.quest_subtitle: "Barang yang sangat berguna"
	quest.2AED15E3AC0346FE.title: "Upgrade Sederhana"
	quest.2AEEDCC6826CF4AB.quest_subtitle: "Urusan Ikan"
	quest.2AEEDCC6826CF4AB.title: "Oily Bee"
	quest.2AF31F1769085641.quest_desc: [
		"&aReprocessor&r adalah struktur multiblock 3x3x7 yang punya aturan spesifik buat ngelengkapin konstruksi multiblock."
		""
		"Jantung multiblock ini adalah &aController&r, dan bisa ditaruh di sisi vertikal manapun selama bukan di frame."
	]
	quest.2AFBE48DA832FF02.quest_subtitle: "Tingkat: &c5"
	quest.2B0553F307A024F7.quest_subtitle: "Tingkat: &c5"
	quest.2B05A29C62676EB2.title: "&l&9Overworld Bounty:&r&e Zombies"
	quest.2B08B19B35EEBCBA.quest_desc: ["Relic ini dapat ditemukan di dimensi &cThe Nether&r!"]
	quest.2B08B19B35EEBCBA.title: "&cThe Nether"
	quest.2B0C3AAAA6D0B0D2.quest_desc: ["&aUranium Quad Fuel Rod&r adalah kombinasi dari beberapa Alloy tahan Blast dan Radioaktif dan tentu aja Material radioaktif. \\n\\nSemua ini bakal jadi satu buat bikin bahan bakar reaktor yang mantap! Atau &c&lPhilosphers Fuel&r!  \\n\\nAtau kamu bisa pake &cBlaze Burner&r... tapi ayolah itu gak seru!"]
	quest.2B0C3AAAA6D0B0D2.title: "&aUranium Quad Fuel Rod"
	quest.2B115519A21F9CB7.quest_desc: [
		"&d&lEnder Guardian&r adalah monster besar yang terbuat dari Endstone, &dPurpur&r, dan &5Obsidian&r yang menunggu di dalam &dVoid Altar&r. \\nIa punya 13.320 &4HP&r dan berhati-hatilah jangan terlalu dekat atau kamu akan tersedot ke arahnya! \\n\\nIa punya banyak jenis serangan, salah satunya adalah pukulan biasa bagi yang terlalu dekat, atau hantaman yang akan memantulkanmu jauh. \\n\\nJika kamu jauh, ia mungkin mengejar dengan menyerudukmu. Atau ia akan menghentakkan kaki dan memunculkan &dVoid Rune&r untuk mengenaimu! Ia juga bisa menembakkan rentetan &dShulker Ball&r. \\n\\nIngat saat aku bilang ia bisa menyedotmu? Ya, ia melakukannya dengan &dVoid Typhon&r, yang juga bisa ia panggil di kaki kamu agar kamu terjebak. Jika terlalu lama di sana, ia akan meledak dan melukaimu. \\n\\nSaat HP-nya mencapai setengah, topengnya akan pecah mengungkap wajah aslinya! Karena marah, ia akan menghancurkan lantai arena dan membawamu ke tingkat bawah. \\n\\nSekarang ia akan lebih sering menyedotmu, mengirim lebih banyak &dVoid Rune&r, serta menyerang lebih cepat dan kuat!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_guardian.png width:100 height:100 align:center}"
	]
	quest.2B115519A21F9CB7.title: "&d&lEnder Guardian&r"
	quest.2B1BAEC5DAAF9DAC.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penebang Pohon"
		"- Penghancur Daun"
		"- Pelebur Otomatis"
		"- Teleporter Barang Jatuhan"
	]
	quest.2B27E4E04A628C60.quest_desc: ["&eSpeed Upgrade&r melakukan persis seperti namanya. Ia meningkatkan kecepatan kerja interface atau blok. Butuh importer untuk menarik lebih cepat? Ingin crafter bekerja lebih gesit? Inilah upgrade-nya!\\n\\n&eStack Upgrade&r meningkatkan kecepatan transfer menjadi satu stack item sekaligus, alih-alih hanya satu per satu. Gabungkan dengan Speed Upgrade untuk jaringan yang lebih efisien!"]
	quest.2B27E4E04A628C60.title: "&eMempercepat Segalanya!"
	quest.2B29E9AB9447E1C6.quest_desc: [
		"Nah, ini baru namanya mesin Multiblock! \\n\\nUntuk mendapatkan item kembali dari &eAlchemical Sulfur&r, kita perlu melakukan proses Inkubasi. Ini membutuhkan sebuah Incubator dengan 3 Wadah (Vessel) di sekelilingnya. Urutannya bebas selama mereka menempel di bagian bawah mesin utama. \\n\\nSetelah semua item di Wadah siap dan ada panas (Heat), mesin akan mulai melakukan Inkubasi! Kamu bisa tahu mesin bekerja saat muncul partikel asap darinya."
		"{image:atm:textures/questpics/theurgy/theurgy_incubator.png width:200 height:200 align:center}"
	]
	quest.2B29E9AB9447E1C6.title: "Inkubator"
	quest.2B2BB53FA86A07B7.quest_desc: ["&bTelur Naga Es&r kebalikan dari &cNaga Api&r. \\n\\nDaripada butuh pelukan hangat &cApi&r, mereka butuh isolasi dingin &bEs&r! \\n\\nLempar &bTelur Naga Es&r ke &9Air&r dan dia bakal &bBekuin &f&9Air&r-nya. \\n\\nSetelah 6 Menit dia bakal Menetas dari &bTelur &fdan &bEs&r! \\n\\nTenang mereka bisa keluar dari keduanya tanpa bantuan."]
	quest.2B2BB53FA86A07B7.title: "Ice Bucket Challenge!"
	quest.2B31E6C1707D8195.quest_desc: ["Langkah selanjutnya untuk memungkinkan akses jaringan nirkabel adalah &bME Wireless Access Point&f. Access Point ini digunakan untuk membuka jaringan agar bisa diakses secara nirkabel melalui &ewireless terminal&f, dan memiliki jangkauan terbatas tergantung pada berapa banyak &bWireless Booster&f yang dimasukkan."]
	quest.2B31E6C1707D8195.title: "Wireless Access Point"
	quest.2B422B7E0CE3590D.quest_desc: ["Compacting Drawer dapat mengubah item di dalamnya ke bentuk nugget atau blok secara otomatis.\\n\\nContoh: Memasukkan Iron Ingot akan membuatmu bisa mengambil 9 nugget, atau jika Besi ditambah, akan berubah menjadi Iron Block."]
	quest.2B422B7E0CE3590D.quest_subtitle: "Otomatis Memadatkan/Menguraikan"
	quest.2B4801CD3E90BD40.quest_desc: ["&l&3Handcrafted&r adalah untuk segala hal yang berhubungan dengan dekorasi. \\n\\nAda tempat tidur (yang terlihat cukup nyaman untuk ditiduri, dan aku pemilih soal tidur!) dan nakas untuk Kamar Tidur. \\n\\nAda kursi dan meja untuk Ruang Tamu. \\n\\nAda oven, piring, dan mangkuk untuk Dapur. \\n\\nBahkan ada patung hanya untuk pamer!"]
	quest.2B4801CD3E90BD40.title: "&l&3Handcrafted&r"
	quest.2B4D4E741D855B5A.quest_desc: ["Menggabungkan 2 &bIngot of the Skies&r, 2 &6Tainted Gold Ingot&r, dan 1 &5Netherite Scrap&r di meja crafting akan menghasilkan &dIngot of the Depths&r."]
	quest.2B4D4E741D855B5A.title: "&dIngot of the Depths"
	quest.2B57C8D2F98A9279.quest_desc: ["&l&7Pocket Storage&r adalah mod yang nambah storage genggam simpel. \\n\\nKlik Kanan buat buka dan kamu bisa masukin Item. Mereka punya max count yang bisa ditampung, dan Item apapun yang dimasukin lebih dari itu bakal dihapus. Ini juga bakal nyedot Item di ground yang sama kayak di dalamnya. \\n\\nAda juga cara buat dump ke Chest atau ambil dari Chest dengan cepat. \\n\\nTier yang lebih tinggi makin banyak Slot dan Max Item-nya."]
	quest.2B57C8D2F98A9279.title: "&l&7Pocket Storage"
	quest.2B5E14A47062F83C.quest_subtitle: "Huruf R dalam Roy G. Biv"
	quest.2B5E14A47062F83C.title: "&cRed Xychorium Gems"
	quest.2B60D123123A5E8E.quest_desc: ["Kenapa harus repot mengatur lokasi tujuan energi? Biarkan saja ia bebas! \\n\\nSeperti melepaskan sekawanan lebah, energi akan menyebar ke mana-mana secara instan (tapi tanpa suara dengung). Blok apa pun di sekitar yang butuh energi akan terisi secara nirkabel."]
	quest.2B6D71DAF72EAFA4.quest_desc: ["Capacitor bertindak sebagai Batteries untuk Draconic Evolution. Mereka butuh Energy Modules untuk benar-benar menyimpan Energy dan ingat, 'Semakin banyak semakin baik!'."]
	quest.2B6D71DAF72EAFA4.title: "Wyvern Capacitor"
	quest.2B84A4377688B189.quest_desc: ["Kalo kamu cukup jago di laut buat bunuh &9Ular Laut&r mereka bakal Drop &9Taring&f-nya, juga &9Sisik&r sesuai Warna mereka. \\n\\n&9Taring &fdan &9Sisik&r bakal diperluin buat Craft &9Anak Panah Pasang &fdan &9Trisula Pasang&r tapi cuma &9Sisik&r yang dipake buat &9Armor Penjaga Pasang&r!"]
	quest.2B84A4377688B189.title: "&9Sisik &fdan &9Taring Ular Laut"
	quest.2B857941D7BBA0B8.quest_desc: ["Bisa ditemukan di struktur di &6&lBumblezone&r atau ditukar dengan &5Bee Queen&r! \\n\\nPernah benci terjebak di &6Honey Block&r? Atau saat &eSerbuk Sari (Pollen)&r memperlambat jalanmu? Jangan takut karena Honey Bee Leggings ada di sini! Mereka akan membantumu bergerak lebih baik melalui blok-blok tersebut. Semakin banyak Bee Armor yang kamu pakai, perjalanan akan semakin mudah! \\n\\nJuga kamu bisa menekan Shift di atas &ePollen&r untuk mengumpulkannya! "]
	quest.2B864D741F7C7549.quest_desc: ["&lProductive Trees&r adalah tentang pohon dan mengawinkan pohon untuk membuat lebih banyak pohon. \\n\\nJadi kamu bisa tebak kalau mod ini membawa lebih banyak tipe kayu ke &2&lMinecraft&r! \\n\\nBahkan beberapa kayu spesial!"]
	quest.2B864D741F7C7549.title: "&lProductive Trees"
	quest.2B901ECF97FFA181.quest_desc: ["Saat kamu akhirnya menggabungkan Ancient Knowledge Fragment kamu akan mendapat... &9Eldritch Manuscript&r! Itulah kelas terakhir! \\n\\n&9Eldritch&r adalah kelas terakhir, yang paling kuat dari semua &3Spell&r. Mereka di-craft dengan &9Echo Shard&r dan perlu dipelajari dari &9Manuscript&r untuk menggunakannya. Setiap &9Manuscript&r hanya sekali pakai."]
	quest.2B901ECF97FFA181.quest_subtitle: "Kelas ke-9"
	quest.2B901ECF97FFA181.title: "&9&lEldritch"
	quest.2B90982E3B1E545C.quest_desc: ["&4Bestiary&r adalah Guide buat &b&lIce &fdan &cFire&r... \\n\\nOke, punya gue rusak? Kenapa kosong? \\n\\nKita bakal butuh &4Lectern Bestiary&r buat nambahin &7Manuskrip&r ke dalamnya buat dapetin halaman tentang Monster. \\n\\nTinggal taro &4Bestiary&r dan beberapa &7Manuskrip&r ke &4Lectern Bestiary&r dan pilih yang mau kamu pelajarin. Ini bakal pake &7Manuskrip&r dan nambah ke Guide kamu."]
	quest.2B90982E3B1E545C.title: "Guide dalam game"
	quest.2B9AF0D6ED8BA628.quest_subtitle: "&f6 &cAttack Damage"
	quest.2BA0E5D48E234FE9.quest_desc: ["Alam sihir &d&lArs Nouveau&r membawakan kita Magelight! Sumber cahaya dari sihir murni! \\n\\nMereka bisa diletakkan secara normal menggunakan mantra atau kamu bisa men-craft Magelight Lantern dan meletakkannya."]
	quest.2BA0E5D48E234FE9.title: "Lampu &d&lArs Nouveau&r"
	quest.2BB3DB19D5EFC7E2.quest_desc: ["&dKopling&r bisa dihubungkan ke Sistem Kinetik kita dan berfungsi seperti pintu gerbang. \\n\\nDengan memberinya &4Sinyal Redstone&r, aliran &dTenaga Rotasi&r melaluinya akan terhenti. \\n\\nJadi semua putaran akan berhenti di &dKopling&r saat diberi &4Redstone&r. Tapi yang berputar sebelum &dKopling&r akan tetap berputar seperti biasa!"]
	quest.2BB3DB19D5EFC7E2.title: "&dKopling"
	quest.2BB5769119BA2472.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.2BB910B217DF3A12.quest_subtitle: "Kenapa basah? Apa ini ada di Danau?"
	quest.2BB910B217DF3A12.title: "&dEnder&r Upgrade Orb"
	quest.2BC325DEBDD2F5CA.quest_desc: ["Benih Vibranium butuh Tanah Ajaib yang ditaro di bawah biar bisa numbuh."]
	quest.2BC325DEBDD2F5CA.quest_subtitle: "Tingkat: &bAjaib"
	quest.2BCB788924BBD849.quest_desc: ["Favorit pribadiku dan salah satu yang terkuat. \\n\\n&bIncinerator&r bisa digunakan seperti Pedang biasa dan diberi mantra yang sama! \\nTapi saat Menahan Klik Kanan, ia melakukan hal yang tidak bisa dilakukan pedang biasa. Saat kamu menahan lalu melepas Klik Kanan setelah beberapa detik, lidah api raksasa akan muncul dari tanah ke arah yang kamu lihat, lalu meledak. \\n\\nUkurannya juga masif, yang tidak hanya terlihat keren, tapi juga memberikan jarak serang (Range) yang lebih jauh!"]
	quest.2BCB788924BBD849.title: "&bThe Incinerator"
	quest.2BD077EFE77B8EBB.quest_desc: ["Zombie punya varian berbeda yang muncul di biome lain. \\n\\nHusk - muncul di Gurun. \\nDrowned - muncul di dalam Air. \\nGelid - muncul di Biome Dingin. \\nThicket - muncul di Hutan Rimba (Jungle)."]
	quest.2BD077EFE77B8EBB.title: "Varian Zombie"
	quest.2BE538246C672689.quest_desc: ["Menggunakan smeltery, tuangkan &#9332D9Molten Unobtainium&r ke atas sebuah &#F2EB2EVibranium Bee Spawn Egg&r."]
	quest.2BE538246C672689.title: "Unobtainium Bee"
	quest.2BEBF66D7EA594FA.quest_desc: ["Armor ini sedikit lebih kuat dari armor &2Naga&r, dan sudah langsung memiliki mantra (enchanted).\\n\\nKamu bisa membuatnya dengan menemukan &2Steeleaf&r di dalam &9Twilight Forest&r."]
	quest.2BEBF66D7EA594FA.title: "Armor &2Steeleaf"
	quest.2BF119DD5D977409.title: "Katalis Starlight Charger Tingkat 2"
	quest.2C04B3BA507D5673.quest_desc: ["&bPattern&f adalah tempat menyimpan resep yang telah dikodekan untuk dikerjakan oleh Pattern Provider. Untuk memasukkan resep ke dalam Pattern, &bME Pattern Encoding Terminal&f harus digunakan.\\n\\nPattern dapat diatur untuk menyimpan resep &ecrafting&f biasa (membutuhkan &eMolecular Assembler&f), atau resep '&eprocessing&f' yang lebih umum di mana item input dikirim ke mesin lain untuk diproses."]
	quest.2C04B3BA507D5673.title: "Pattern"
	quest.2C0984E03F308959.quest_subtitle: "Pink Ipe + Luck"
	quest.2C2958E38293717E.quest_desc: ["Untuk mulai menggunakan &eItem&r baru dari &6&lCreate&r kita butuh &eKardus&r! \\n\\nDibuat dengan &6Menekan&r Pulp. \\n\\nPulp dibuat dengan &6Mencampur&r 4 Bibit dan &9Air&f dalam &6Pengaduk Mekanik&r dan &8Wadah&r. \\n\\nKamu bisa menggabungkan &eKardus&r untuk membuat &eBlok Kardus&r yang bisa digunakan untuk membuat &eItem&r baru di &6&lCreate&r... atau &eArmor Kardus&r!"]
	quest.2C2958E38293717E.title: "&6&lCreate&r 1.21"
	quest.2C29683DA28A8D47.quest_subtitle: "Dibuat di Reprocessor"
	quest.2C29683DA28A8D47.title: "Insanite Bee"
	quest.2C2EF4EBB3C9EAE3.quest_subtitle: "Tingkat: &a2"
	quest.2C387BFA6EE6FDB7.quest_desc: ["&cUtherium Crystal&r dijatuhkan oleh &cRotbeast&r di dalam &2&lUndergarden&r!"]
	quest.2C387BFA6EE6FDB7.quest_subtitle: "20"
	quest.2C387BFA6EE6FDB7.title: "&cUtherium Armor"
	quest.2C4299D33D419AA0.quest_desc: ["Letakkan Teleport Pad di &2&lOverworld&r untuk pergi ke &7&lMining Dimension&r."]
	quest.2C4299D33D419AA0.title: "&2&lOverworld"
	quest.2C4ECA4F5B1639F4.quest_desc: ["Light Field memang tidak memancarkan banyak cahaya, tapi fungsinya mirip seperti Mega Torch.\\n\\nMob tidak akan muncul di area tertentu di sekitarnya, dengan radius sekitar 32 blok."]
	quest.2C4ECA4F5B1639F4.title: "&fLight Field"
	quest.2C5A7E4CD8B57E08.quest_desc: ["Pohon Grongle adalah pohon tinggi mirip pohon hutan rimba yang hanya muncul di biome Gronglegrowth! \\n\\nDi pohon inilah para &eGronglet&r biasanya muncul."]
	quest.2C5D78630C7AD57F.quest_desc: ["Meningkatkan jangkauan, memberikan efek berbeda tergantung di mana ia dipasang."]
	quest.2C5D78630C7AD57F.quest_subtitle: "Sini Dekat!"
	quest.2C73E3C5113BF2AC.quest_desc: ["Beep beep aku Domba"]
	quest.2C73E3C5113BF2AC.quest_subtitle: "Tingkat: &a2"
	quest.2C7D62231AD6406A.quest_desc: ["XyCraft memiliki sistem multiblock tangki cairan (Fluid Tank) yang keren!"]
	quest.2C7D62231AD6406A.title: "&bPenyimpanan dan Manipulasi Cairan"
	quest.2C9C9CB71941DC01.quest_desc: ["Ini adalah Essence Tingkat 3, dibuat dengan nggabungin 4 Prudentium dengan Kristal Infus."]
	quest.2C9C9CB71941DC01.quest_subtitle: "Tingkat: &63"
	quest.2C9C9CB71941DC01.title: "&cTertium"
	quest.2CA2B3A1783B4040.quest_subtitle: "Aspen + Alder"
	quest.2CA3707BEE2E3C0D.quest_subtitle: "Berikan Diamond Bee sebuah blok Netherite"
	quest.2CA3707BEE2E3C0D.title: "Ancient Bee"
	quest.2CA4D7253DA1825F.quest_subtitle: "Muncul menggunakan Wood Nest"
	quest.2CA9394459C24012.quest_desc: ["Rotbeast adalah Minibos yang muncul di seluruh penjuru Undergarden."]
	quest.2CA9394459C24012.title: "Kalahkan Rotbeast"
	quest.2CB69634F6A6E53E.quest_desc: ["&0Dark Temple&r susah buat dilewatin, mengingat mereka punya beam cahaya gede dari tengah.\\n\\nDi tengah &9Dark Temple&r ada &aEnvironmental Accumulator&r.\\n\\nKita bisa pake ini buat nge-empower dan bikin beberapa item yang kita butuhin, termasuk &dLightning Bomb&r!"]
	quest.2CB69634F6A6E53E.title: "&l&0Dark Temple"
	quest.2CC56A4F06E53307.quest_desc: [
		"Letakkan Empty PCB milikmu di dalam &3UV Light Box&r untuk mengisinya. Membutuhkan tekanan udara dan akses ke sinar matahari."
		"{image:atm:textures/questpics/pneumaticcraft/uv_charging.png width:300 height:150 align:center}"
	]
	quest.2CC56A4F06E53307.quest_subtitle: "Semoga kamu punya Kacamata Hitam!"
	quest.2CC56A4F06E53307.title: "Mengisi Daya dengan UV"
	quest.2CCAA7C0FEDEB573.quest_desc: ["Kalau seperti kebanyakan orang ini adalah power yang dicari. Cukup letakkan setinggi mungkin dan dapat power gratis. "]
	quest.2CCAA7C0FEDEB573.title: "Wind Power"
	quest.2CCFEE98FE3B2E97.quest_desc: ["Mesin ini dipakai untuk mengotomasi penempatan/penghancuran block. Ini sangat berguna saat mengotomasi latex."]
	quest.2CCFEE98FE3B2E97.title: "Block"
	quest.2CD58FC229BC0C28.quest_desc: ["&dGauntlet of Guard&r adalah drop dari &d&lEnder Guardian&r. \\n\\nSaat kamu memegangnya di salah satu tangan, kamu bisa Menahan Klik Kanan untuk menarik semua mob di dekatmu agar semakin dekat! \\n\\nKamu juga bisa menghajar mob dengannya di tangan utama untuk memberikan damage. \\n\\nCobalah gunakan mekanik tarikan ini sambil terbang untuk menjatuhkan mob dari ketinggian!"]
	quest.2CD58FC229BC0C28.title: "&dGauntlet of Guard"
	quest.2CECCA9D05D3EF12.quest_desc: ["&2Eternal Stella&r lumayan mahal. Kamu butuh Tier 3 Forge dulu! \\n\\nTerus, kamu butuh &7Stellarite Piece&r yang bisa kamu tambang. Dan kamu harus dapetin 3 &aXpetried Orb&r yang gak bisa ditambang lagi. Sebaliknya kamu harus kasih makan Black Hole dengan &aEXP&r buat dapetin! \\n\\nTerakhir, kamu butuh &6AllTheModium Ingot&r buat dapetin &2Eternal Stella&r. Masuk akal kenapa ini mahal karena bisa digabungin sama Tool apapun buat bikin mereka Invincible!"]
	quest.2CECCA9D05D3EF12.title: "&2Eternal Stella"
	quest.2CF6EA138B53CE1B.quest_desc: ["&3Vibranium&r yang digabungkan dengan &5Unobtainium&r!"]
	quest.2CF6EA138B53CE1B.title: "Alloy Ingot &5Unobtainium&r - &3Vibranium&r"
	quest.2CF96A264EB5522C.quest_desc: [
		"&9Uphyxes' Inverted Tower&r adalah tingkat tertinggi dari &6Ritual Infusi&r. Ia tidak punya banyak kegunaan seperti tiga tingkat lainnya, tapi tetap diperlukan untuk fase \"akhir\" Occultism. "
		""
		"Terutama, ritual ini digunakan untuk menciptakan Dragonyst Dust, bahan utama untuk membuat Magenta Chalk."
	]
	quest.2CF96A264EB5522C.quest_subtitle: "Infusi Maksimal"
	quest.2CF96A264EB5522C.title: "&9Uphyxes' Inverted Tower"
	quest.2CFEE04BA574921E.quest_desc: ["&bConstructor&r adalah interface yang akan menaruh blok yang ditentukan ke arah yang ia hadapi.\\n\\nKamu bisa menentukan bloknya di dalam GUI. Ini sangat berguna untuk otomatisasi!"]
	quest.2CFEE04BA574921E.quest_subtitle: "Menaruh Blok!"
	quest.2CFEE04BA574921E.title: "Constructor"
	quest.2D00F85379A4D591.quest_desc: ["Item Loader adalah dispenser paling dasar dari RailCraft. Alat ini harus diletakkan di atas &6Rel&r dan bisa dikonfigurasi item apa saja yang ingin kamu masukkan ke dalam &7Cart&r di bawahnya."]
	quest.2D00F85379A4D591.title: "Item Loader"
	quest.2D08BCF993B241B8.quest_desc: ["Scroll kedua yang perlu diaktifkan untuk mendapat &8&lReplica&r adalah &7Scroll of Immunity Exchange&r. \\n\\nUntuk mendapatkannya butuh Ritual of Immunity Exchange; yang membutuhkan 1 &3Powdered Eye&r dan 2 &aPowdered Emerald&r."]
	quest.2D08BCF993B241B8.title: "&7Scroll of Immunity Exchange"
	quest.2D0BA4183DCA2751.quest_subtitle: "Tingkat: &a2"
	quest.2D0CF18C8B2ABB7D.quest_desc: ["Meletakkan alat ini di dekat tanaman yang tumbuh atau bibit pohon akan menghasilkan Source. Pohon Archwood memberikan lebih banyak Source! \\n\\nCatatan: Penggunaan Bonemeal tidak menghasilkan Source."]
	quest.2D0CF18C8B2ABB7D.quest_subtitle: "Menghasilkan Source Melalui Pertumbuhan Tanaman"
	quest.2D1CBCEC82F1B37D.quest_desc: ["&6Fuelwood Heater&r bakal hasilkan &6Panas&r pakai bahan bakar tungku (Furnace). \\n\\nLog kayu, &0Coal&f, &0Charcoal&r, bahkan pedang kayu! \\n\\nAku nggak bisa bilang seberapa &6Panas&r dia bisa capai, tapi kamu bakal tahu kalau dia sudah &6Panas&r dari warna &6Heater&r-nya yang berubah!"]
	quest.2D1CBCEC82F1B37D.title: "&6Fuelwood Heater"
	quest.2D3C8905B783A212.quest_desc: ["Untuk beberapa Mob Drop plus &bArcane Crystal Dust&r kamu bisa bikin &cMundabitur Dust&r! \\n\\nIni bagian sangat penting dalam crafting dan pembuatan Multiblock! \\n\\nDan kamu bisa temuin di &dEnd City&r yang kebanyakan orang lakukan..."]
	quest.2D3C8905B783A212.title: "&cMundabitur Dust"
	quest.2D41B04C75FA02BC.quest_desc: ["&6Pres Mekanik&r sangat berguna untuk membuat lebih banyak &6Mesin&r! \\n\\nKetika diberi &dTenaga Rotasi&r (dan banyak Satuan Stres), ia akan menekan &6Pres Logam&r ke bawah ke Blok di bawahnya. Seperti Hydraulic Press! \\n\\nItem apapun di bawahnya — di &eSabuk&r, &ePenampang&r, atau bahkan yang dijatuhkan — akan di-&6Pres&r. \\n\\nTerutama digunakan untuk mengubah &7Ingot&f menjadi &7Pelat&r tanpa biaya. Bisa juga membuat Kertas dari Tebu dan Jalur dari Tanah! \\n\\nKalau taruh &8Wadah&r di bawahnya, &6Pres&r bisa menggabungkan &bCairan&r, &eItem&r, dan Blok menjadi &eItem&r baru. \\n\\nOpsi lain dengan &8Wadah&r di bawah Pres adalah Pembuatan Otomatis. Untuk pemain biasa ini mungkin terdengar membingungkan tapi percayalah nggak sesulit itu. Pembuatan Tanpa Pola adalah Resep yang bisa dibuat dengan bahan dalam pola apapun. \\n\\nSeperti Mewarnai Wol, Pewarna dan Wol bisa ditempatkan di mana saja di Meja Kerajinan. Atau bahkan bagian dan pola Silent Gear!"]
	quest.2D41B04C75FA02BC.title: "&6Pres Mekanik"
	quest.2D457E53BB6D63C7.quest_desc: [
		"Titik tertinggi di Starlight adalah Permafrost Forest yang ada di atas Gunung. \\n\\nKarena tinggi banget jadi jauh lebih dingin dan ditutupin Salju dan Es! \\n\\nPaling gak Mob ramah kayaknya suka sama dingin!"
		"{image:atm:textures/questpics/eternal/starlight_permafrost.png width:200 height:100 align:center}"
	]
	quest.2D457E53BB6D63C7.title: "Permafrost Forest"
	quest.2D4749DF9642F334.quest_desc: [
		"&eDyson Cube&r adalah sumber daya mutakhir yang menghasilkan daya sebesar &l&a1GFE/t&r&r!"
		""
		"Siapkan &eEM Rail Ejector Controller&r untuk meluncurkan &bSolar Sail&r dan &bBeam&r ke orbit mengelilingi Matahari. Kamu bisa memasukkan item secara &botomatis&r melalui bagian tengah sisi bawah (kamu pasti butuh otomatisasi untuk mencapai output maksimal). Sayangnya, alat ini &otidak bisa menembak&r saat tengah hari, malam hari, atau saat hujan."
		""
		"Untuk mengumpulkan energi tersebut, bangunlah &bRay Receiver Controller&r. Alat ini mengeluarkan daya dari bagian tengah sisi bawahnya tetapi &otidak bisa menerima daya&r saat &emalam&r atau &ehujan&r."
		""
		"Kamu bisa &emembungkus (package)&r beam dan sail menjadi bundle agar peluncuran lebih cepat, jauh lebih mudah daripada mengirimnya satu per satu."
		""
		"Untuk output maksimal, kamu perlu mengirim &c8.333.333&r beam dan &c49.999.998&r sail ke orbit, jumlah yang sangat banyak."
		""
		"Sebelum mulai mengejar angka tersebut, pastikan kamu sudah memiliki &aproduksi sumber daya yang kuat&r."
	]
	quest.2D4749DF9642F334.quest_subtitle: "Kekuatan Matahari di genggamanmu"
	quest.2D4749DF9642F334.title: "&eDyson Cube"
	quest.2D474F8075E9DBD0.quest_desc: ["Pertama kamu harus taruh Casting Altar dan Standing Stone sesuai pola yang dijelasin di JEI. \\n\\nTerus, kamu harus masukin Diamond Block, Stick, dan Blaze Powder ke Altar. \\n\\nSetelah itu, taruh 4 Incense Blazier di sekitar Altar, masukin Block of Coal di satu, Acacia Bark di lain, Verdant Bark di ketiga, dan Birch Bark di terakhir. Terus nyalain semua pake Flint and Steel! \\n\\nTerus Shift Klik Kanan Altar buat mulai Ritual! Kalo gak jalan cek pola Standing Stone-nya."]
	quest.2D592669F4D41793.quest_desc: ["Sama kayak Reactor, frame harus dibuat dari &dCasing&r, tapi dinding bisa pakai &9Turbine Glass&r!"]
	quest.2D592669F4D41793.title: "Konstruksi Turbine"
	quest.2D64EF8D803AF9DA.quest_desc: ["Portal paling mahal yang bisa kita bikin. Pertama buat &dDragon Egg&r kamu gak harus terus milk &dDragon&r kamu bisa pake &l&bHNN&r atau &l&2MA&r buat dapetin atau Extractor buat bikin lebih banyak! \\n\\nTerus, kamu butuh &dInfused Dragon's Breath&r dari Enchanting. \\n\\nDi sana kamu butuh &9Soul-Touched Sculkshelf&r buat Enchant dan bikin Portal. \\n\\nKalo kamu tanya kenapa Portal gak jalan, itu karena kamu udah di &2&lOverworld&r! Becanda kamu gak bisa pake ini!"]
	quest.2D6FDCC948DB927D.quest_subtitle: "Mahogany + Teak"
	quest.2D71532A99C167AA.quest_desc: [
		"&3Amphithere&r adalah Monster Netral raksasa setengah Burung setengah Ular yang ditemuin di &eGurun The Other&r, kemungkinan dipuja sebagai Dewa dari Suku Mesoamerika. \\n\\nMereka punya tubuh Ular dengan sayap dan kepala Burung. Sayap ini bikin mereka bisa Terbang di atas &eGurun The Other&r. \\n\\nMereka juga dateng dalam Warna: Magenta, Merah, Oranye, Cyan, dan Biru. \\n\\nSemuanya punya 50 &4Hearts&r tanpa Armor. Mereka gak butuh Armor pas mereka punya Kecepatan! \\n\\nPas Terbang mereka gak bakal Nyerang kamu, bahkan kalo kamu provokasi mereka. Mereka bakal coba kabur. Kalo kamu pukul mereka pake Projectile, mereka bakal Jatuh dan dipaksa stay di Tanah. \\n\\nDi Tanah mereka bakal Gigit kamu, Cambuk kamu pake Ekor, dan bahkan pake sayap kuat mereka buat lempar angin ke kamu!"
		"{image:atm:textures/questpics/iceandfire/iaf_amphithere.png width:200 height:100 align:center}"
	]
	quest.2D71532A99C167AA.title: "&3Amphithere"
	quest.2D8026E10FBA7A72.quest_desc: ["Sebuah pickaxe yang sangat cepat."]
	quest.2D8026E10FBA7A72.title: "&6Allthemodium &5Alloy &3Pick"
	quest.2D84DA544D7A24FA.quest_desc: ["Quest ini telah dibuat oleh &6AllTheMods Staff&r, atau &2Kontributor Komunitas&r untuk digunakan di Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak diizinkan untuk digunakan di pack publik mana pun yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan, jika kamu melihat ini, kamu dalam mode editing."]
	quest.2D86D4403E0F4EB9.quest_desc: [
		"Blazegold adalah material baru yang ditambahkan oleh JDT. Blazegold didapatkan dengan melakukan Penyebaran Lendir pada Balok Emas menggunakan lendir tingkat dua atau lebih tinggi. Bijih Blazegold dipengaruhi oleh keberuntungan."
		""
		"Blazegold memberikan kemampuan intrinsik Perbaikan Lava ke alat dan Armor. Perbaikan Lava memperbaiki alat/armor saat dijatuhkan ke balok sumber lava, mengubah balok sumber menjadi obsidian sebagai ganti memperbaiki alat/armor."
	]
	quest.2D86D4403E0F4EB9.title: "Blazegold"
	quest.2D93888313B03029.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_blue.png width:100 height:150 align:center}"]
	quest.2D93888313B03029.title: "&9Blue Starlight Crystal&r"
	quest.2D96965317D3CFEC.quest_desc: ["Hore, topik yang rumit! Kali ini tentang &5Kondektur&r dan &5Jadwal Kereta&r. \\n\\nPertama, dapatkan &5Kondektur&r-mu — ini bisa berupa Mob yang bisa dituntun atau &cPembakar Blaze&r. Kalau ada Kursi di samping Kontrol Kereta, kita bisa menuntun Mob ke Kursi di mana ia akan menunggu jadi &5Kondektur&r. \\n\\n&cPembakar Blaze&r bekerja serupa, hanya tanpa perlu kursi — mereka punya sendiri. \\n\\nKemudian, berikan Mob atau &cPembakar Blaze&r-mu sebuah &5Jadwal&r yang sudah diisi, untuk memberi mereka tugas tersebut, ditambah &5Topi Kondektur&r. \\n\\n&5Jadwal&r adalah Item yang bisa \"Dikodekan\" untuk memerintahkan &5Kondektur&r melakukan tugas tertentu. Tugasnya bisa berupa: pergi ke &5Stasiun&r, mengambil atau mengantar Paket, mengganti nama, atau mengubah kecepatan maksimum. \\n\\nSetelah menambahkan tugas, kita bisa mengedit konfigurasinya untuk mengatur kapan tugas berikutnya dimulai! Bisa berdasarkan waktu tunggu, Waktu dalam Hari, jumlah barang di &5Kereta&r, atau bahkan &4Redstone&r!"]
	quest.2D96965317D3CFEC.title: "&5Kondektur"
	quest.2D9AF97C03C5AEC7.quest_desc: ["Untuk Tier 5-8 kamu butuh Advanced Stabilizers. Apa itu Advanced Stabilizer? Itu 9 Stabilizer semua dalam Area 3x1x3. Saat dibuat benar akan berubah jadi lingkaran! Lakukan dengan cara yang sama seperti 1 Stabilizer."]
	quest.2D9AF97C03C5AEC7.title: "Advanced Stabilizers"
	quest.2DA8CE213AC3869B.quest_desc: ["Starlight Crystal bisa ditemuin di mana-mana bahkan di bawah Crystallized Desert. \\n\\nMereka kerja mirip kayak Amethyst bahkan suaranya kayak itu!"]
	quest.2DB2A4A1182FE0BB.quest_desc: [
		"Tier 6 butuh 150 Draconium Ingot Blocks dan 178 Redstone Blocks (Jangan lupa 36 Stabilizers)."
		"{image:atm:textures/questpics/draconic/draconic_core_6off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_6on.png width:100 height:100 align:1}"
	]
	quest.2DB2A4A1182FE0BB.quest_subtitle: "Menyimpan: 356,000,000,000 RF"
	quest.2DB2A4A1182FE0BB.title: "Tier 6"
	quest.2DB53A77C3CD90F1.quest_desc: ["Botanist's Pickaxe mengubah blok yang berinteraksi dengannya menjadi varian berlumut (mossy), asalkan blok tersebut memilikinya."]
	quest.2DB53A77C3CD90F1.quest_subtitle: "Tingkat: &b3"
	quest.2DC4446A644A4079.quest_desc: ["&6Hazmat Suit&r adalah satu-satunya cara buat cegah &aRadiasi&r bunuh lo. \\n\\nLo harus pake satu set lengkap buat cegah &aRadiation Poisoning&r! \\n\\n&aRadiasi&r bakal bunuh Mob sama Player lain di dekatnya, Player bisa diselamatin pake &6Hazmat Suit&r... tapi Mob gak seberuntung itu!"]
	quest.2DC4446A644A4079.title: "&6Hazmat Suit"
	quest.2DC639C39AE90272.quest_subtitle: "Yellow Meranti + Rose Gum"
	quest.2DD5F0693780B10A.quest_desc: ["Digunakan bersama Extruder MK2; blok yang dikeluarkan akan meniru sifat aslinya. Blok Redstone akan memancarkan sinyal, Glowstone memancarkan cahaya, dan Rumput akan bersifat transparan. Tapi hanya dengan augment ini! \\nTidak berfungsi untuk Block Entity seperti Furnace atau mesin lainnya."]
	quest.2DDA04088C8220D2.quest_desc: ["Pecahan Prosperity adalah bahan crafting inti di mod ini. Buat nemuin Prosperity Ore, kamu harus nambang."]
	quest.2DDA04088C8220D2.quest_subtitle: "Akhirnya dapet Prosperity?"
	quest.2DDA04088C8220D2.title: "&bPecahan Prosperity"
	quest.2DE2E5A1275E4B20.quest_desc: ["Bisa ditemukan di struktur di &6&lBumblezone&r atau ditukar dengan &5Bee Queen&r! \\n\\n&6L&8e&6b&8a&6h&r memiliki cara unik untuk saling menemukan dan berkomunikasi. Aku tidak tahu bagaimana mereka melakukannya, jadi aku asumsikan saja antena mereka mengirim dan menerima sinyal radio. \\n\\nSambil memakai Stingless Bee Helmet, kamu bisa menekan Shift untuk menyoroti (highlight) semua &6L&8e&6b&8a&6h&r di sekitarmu. \\n\\nJuga saat memakainya, efek racun dan mual akan hilang lebih cepat."]
	quest.2DE7CC686B56881F.quest_desc: ["Melindungimu dari radiasi Mekanism."]
	quest.2DE7CC686B56881F.quest_subtitle: "Maks: 1"
	quest.2DFFEB29B6CBFD99.quest_subtitle: "Iron + Blue Banded"
	quest.2DFFEB29B6CBFD99.title: "Lead Bee"
	quest.2E0275C21D3F0DA3.quest_desc: ["Jangan tertukar dengan Draconic Bee."]
	quest.2E0275C21D3F0DA3.quest_subtitle: "Wyvern Fusion Crafting"
	quest.2E0275C21D3F0DA3.title: "Draconium Bee"
	quest.2E0F82F7E1B74033.quest_desc: ["&2Earth Armor&r dari mod &d&lArs Elemental&r!"]
	quest.2E0F82F7E1B74033.quest_subtitle: "15"
	quest.2E0F82F7E1B74033.title: "&2Geomancer Outfit"
	quest.2E0FBBE43D92CA42.quest_desc: ["Lead bisa membantu, tapi mereka Lemah banget! \\n\\nKenapa gak upgrade? \\n\\nRantai bakal Iket ke Mob (termasuk yang bahaya kayak &c&lNaga&r) dan bisa dipake buat gerakin mereka. \\n\\nAtau restrein mereka kayak Lead dengan ngaitkan Rantai ke Dinding. Ya, kayak Dinding Batu! \\n\\nGak peduli sebanyak apa Mob coba kabur Rantai gak bakal putus! \\n\\nKalo kamu pake ke &c&lNaga&r, pastiin dinding kamu gak bisa dihancurin sama &c&lNaga&r..."]
	quest.2E0FBBE43D92CA42.title: "Rantai"
	quest.2E2811D1A0F2A492.quest_desc: ["Untuk meningkatkan jangkauan koneksi nirkabel ke sistemmu, kamu bisa membuat &bRange Upgrade&r.\\n\\nWireless Transmitter hanya bisa menampung total 4 buah."]
	quest.2E2811D1A0F2A492.quest_subtitle: "Sinyal Lebih Kuat"
	quest.2E2811D1A0F2A492.title: "&bMeningkatkan Jangkauan Wifi"
	quest.2E29DC243E8AD61E.quest_desc: [
		"Shimmer Lacewing gak ngapa-ngapain atau drop apa-apa, mereka cuma nambah atmosfer. \\n\\nMereka juga mirip satu-satunya serangga yang aku tolerir!"
		"{image:atm:textures/questpics/eternal/starlight_shimmer.png width:150 height:100 align:center}"
	]
	quest.2E29DC243E8AD61E.title: "Shimmer Lacewing"
	quest.2E37997A065A29F1.quest_subtitle: "Tingkat: &c5"
	quest.2E51F09F6D9E5EF8.quest_desc: ["Ini adalah lebah khusus untuk perkawinan (Breeder)."]
	quest.2E51F09F6D9E5EF8.quest_subtitle: "Farmer + Rancher"
	quest.2E596B5A4EA2ABF4.quest_desc: [
		"Apakah lubang asap (Smogvent) itu bergerak? Bukan, itu cuma seekor &3S'Mog&r! Sepupu dekat dari &2Mog&r! \\n\\nMereka bertindak persis seperti &2Mog&r, hanya saja yang ini mungkin menjatuhkan Blue Mogmoss."
		"{image:atm:textures/questpics/undergarden/undergarden_smog.png width:100 height:100 align:center}"
	]
	quest.2E596B5A4EA2ABF4.title: "&3S'Mog&r"
	quest.2E5E129F25707C5D.quest_desc: ["&6Sigil of Supremacy&r!\\n\\nSigil lain yang tidak bisa di-craft, mirip dengan &cMalice&r. Seperti &cMalice&r, sigil ini bisa memperkuat affix. Bedanya, sigil ini memperkuat SETIAP affix pada gear tersebut tanpa mengorbankan affix lainnya.\\n\\nKamu bisa mendapatkannya dengan menyelesaikan 100 gelombang di Endless Gateway of Apothic Invaders."]
	quest.2E61219FC0BAB675.quest_subtitle: "Sampai +5 Jangkauan"
	quest.2E68E1D96B25336D.quest_desc: ["Setelah bertarung melawan beberapa Zombified Piglin yang dirasuki setan yang dipanggil oleh &6Odus' Open Convocation&r, kamu bisa menggunakan Demonic Meat yang dijatuhkan mereka untuk membuat Pink Chalk."]
	quest.2E68E1D96B25336D.title: "&dPink Chalk (Kapur Merah Muda)"
	quest.2E6D11A5F5626A6C.quest_subtitle: "Tingkat: &f2"
	quest.2E6F1C8718EB8C66.title: "&4Blood&r Upgrade Orb"
	quest.2E6F761585C1FB4D.quest_subtitle: "Ash + Silver Lime"
	quest.2E74B5149D4BD0A0.quest_desc: ["Basic (Energy Relay) Crystal adalah awal untuk memindahkan Energy dengan Draconic Evolution! "]
	quest.2E74B5149D4BD0A0.title: "Basic Energy Relay Crystal"
	quest.2E7D6A54B361B727.quest_desc: ["Dengan 2 &8Bulu Stymphalian&r (dan Stick) kita bisa Craft &8Belati Stymphalian&r! \\n\\nDamage-nya cuma sebanyak Pedang Besi tapi Attack Speed-nya jauh lebih cepat. \\n\\nHampir dua kali lebih cepat dari Pedang normal, dan tiga kali lebih cepat dari Kapak!"]
	quest.2E7D6A54B361B727.title: "&8Belati Stymphalian"
	quest.2E85D6E2CFCC356E.quest_desc: ["&3Vibranium Furnace&r lebih bagus dari &6Allthemodium Furnace&r!"]
	quest.2E85D6E2CFCC356E.title: "&3Vibranium Furnace"
	quest.2E88CCBC7B97A1F0.quest_desc: ["Andai aja portal gede di Ancient City bisa ngelakuin sesuatu! Oh tunggu sama &9&lDeeper and Darker&r bisa! \\n\\nKamu cuma butuh..."]
	quest.2E88CCBC7B97A1F0.title: "&9&lDeeper and Darker"
	quest.2E89A03BA809634E.quest_desc: ["Ini hanya bisa Diperdagangkan dengan Gunsmith. \\n\\nProyektil Khusus adalah yang melakukan hal unik! \\n\\nHoming, Explosive, dan Flares perlu dibuat dengan &9Cetak Biru&r ini."]
	quest.2E89A03BA809634E.title: "&9Cetak Biru Proyektil Khusus"
	quest.2E89ABF1A6145184.quest_subtitle: "Brazilwood + Kapok"
	quest.2E8F851A4E98F741.quest_desc: [
		"&3Pneumatic Armor&r saja sudah cukup hebat, namun jika ingin membuatnya luar biasa, kamu harus memasang upgrade. Tekan tombol 'U' (default) untuk membuka GUI Upgrade. Beberapa upgrade memakai tekanan udara, beberapa tidak."
		""
		"Sama seperti meng-upgrade alat lain di PneumaticCraft, untuk meng-upgrade &3Pneumatic Armor&r kamu butuh Charging Station yang memiliki tekanan udara."
		""
		"Catatan: Subtitle akan memberitahumu jumlah maksimal upgrade yang bisa dipasang."
	]
	quest.2E8F851A4E98F741.quest_subtitle: "Compressed Iron Man"
	quest.2E8F851A4E98F741.title: "Pneumatic Armor"
	quest.2E9C035EEE7E5C34.quest_desc: ["Lead klasik. Pakai ini untuk bawa hewan ke area farm kamu.\\n\\nIni bukan yang sama dengan ore."]
	quest.2E9C035EEE7E5C34.quest_subtitle: "Ayo jalan Doggy"
	quest.2E9C035EEE7E5C34.title: "Kita lakukan dengan Cara Lama"
	quest.2E9D1131DC21CC5B.quest_desc: ["&lIndustrial Foregoing&r memiliki desain futuristik yang ramping, &5&lMekanism&r memiliki desain modern yang kusam, dan &8&lImmersive Engineering&r mengambilnya jauh lebih retro! \\n\\nSemuanya &6Cokelat&r, &7Abu-abu&r, dan &8Abu-abu Gelap&r! \\n\\nMod semua dimulai dengan &6Palu Insinyur&r. Ini bisa digunakan untuk membuat Pelat, Debu, atau hanya membangun Multiblok kita! \\n\\nOmong-omong, sudah kubilang kita akan membuat banyak di Mod ini? Semoga suka!"]
	quest.2E9D1131DC21CC5B.title: "&8&lImmersive Engineering"
	quest.2EA0C74AE7366656.quest_desc: ["&aPortable Teleporter&r bakal bolehin kamu Teleport ke mana aja selama ada &a&lTeleporter&r yang punya daya. \\n\\nPastinya alat ini butuh &aEnergi&r juga, jadi kamu harus isi dayanya. Terus Klik Kanan buat atur alat ini jadi milikmu demi alasan keamanan. \\n\\nSetelah diisi daya dan jadi milikmu, kamu bisa Klik Kanan buat buka GUI-nya. Di sini kamu bisa klik Jaringan (Network) mana aja terus tekan tombol Teleport buat pindah ke &a&lTeleporter&r itu. \\n\\nNggak, kamu nggak bisa teleport ke &aPortable Teleporter&r, itu kan item... "]
	quest.2EA0C74AE7366656.title: "&aPortable Teleporter"
	quest.2EAA6BE598C83F24.quest_desc: ["&3Water Armor&r dari mod &d&lArs Elemental&r!"]
	quest.2EAA6BE598C83F24.quest_subtitle: "15"
	quest.2EAA6BE598C83F24.title: "&3Aquamancer Outfit"
	quest.2EB7784D5296F410.quest_desc: [
		"Klik kanan pada blok Flux Network yang aktif akan membuka antarmuka ini.\\n\\nSetiap Plug atau Point dapat diberi nama, level prioritas kustom, dan batas transfer daya kustom. Ini memungkinkan kontrol penuh atas seluruh bagian sistemmu.\\n\\n&aBypass Limit&r akan mengabaikan batas yang telah ditentukan.\\n\\nAda beberapa tab lain untuk dicek, terutama untuk statistik jaringanmu!\\n"
		"{image:atm:textures/questpics/basic_power/flux_ui.png width:125 height:150 align:center}"
	]
	quest.2EB96FF06627FD9A.quest_desc: ["Salvager memungkinkanmu untuk membongkar peralatan kembali menjadi material pembuatnya.\\n\\nContoh: Jika kamu memasukkan Sepatu Diamond (Diamond Boots), kamu akan mendapatkan kembali 4 buah Diamond."]
	quest.2EB96FF06627FD9A.quest_subtitle: "Membongkar (beberapa) item!"
	quest.2EB96FF06627FD9A.title: "Salvager"
	quest.2EC2FA680076C07D.quest_desc: ["Untuk meningkatkan &9Deepshelf&r lebih jauh lagi, ternyata kita tidak butuh &d&lInfusion&r! Melainkan butuh lebih banyak Crafting! \\n\\nPertama, siapkan 5 &3Sculk Block&r dan satu &3Sculk Catalyst&r. Keduanya bisa ditemukan di &9Deep Dark&r dan butuh &5Silk Touch&r untuk mengambilnya. \\n\\nTerakhir adalah &9Warden Tendril&r... ini adalah drop dari &9&lWarden&r... Ya, kamu harus membunuh &9&lWarden&r. \\n\\nSetelah punya semuanya, kamu bisa membuat salah satu rak buku terbaik! Memberikan &a10 Eterna&r, &c10% Quanta&r, dan &515% Arcana&r. \\n\\nDan yang terpenting, memberikan kita batas maksimal &aEterna&r hingga &a80&r! Hampir mencapai 100!"]
	quest.2EC2FA680076C07D.title: "&9Echoing Sculkshelf"
	quest.2EC9668ED4EA47CB.quest_desc: ["Quest ini hanya membutuhkan membuat satu tool atau armor Diamond, tapi mungkin bagus untuk dapat set lengkap!\\n\\nTool Diamond memiliki durability tinggi, dan armor menawarkan proteksi hebat secara keseluruhan.\\n\\nUntuk membuat tool dan armor lebih baik di game, butuh barang Diamond sebagai base!"]
	quest.2EC9668ED4EA47CB.title: "&9Bersiap-siap"
	quest.2EDE91023F7924FB.quest_desc: ["Letakkan Teleport Pad di &d&lThe End&r untuk pergi ke &5&lThe Beyond&r."]
	quest.2EDE91023F7924FB.title: "&d&lThe End"
	quest.2EE4E88FC814AFA4.quest_subtitle: "Tingkat: &91"
	quest.2EE8FCB63A338BC4.quest_desc: [
		"&zRainbow Furnace&r butuh literally semua Furnace lain buat Craft. 8 &zRainbow Plating&r dan 1 &zRainbow Core&r kasih kita Furnace terbaik yang bisa kita bayangkan!"
		""
		"Iya emang butuh 20 Tick buat smelt atau 1 Detik buat smelt, tapi ini ga smelt 1 item. Berapa item? Berapa jumlah item dalam satu stack?"
	]
	quest.2EE8FCB63A338BC4.title: "&zRainbow Furnace"
	quest.2EF0C033C540A7B1.title: "Pengolahan Ruby"
	quest.2F0D6267569F740B.quest_desc: ["Material Umum (Common) setingkat lebih tinggi dan lebih jarang dibanding Abundant. Ini biasanya berupa Ingot dan drop mob yang lebih langka seperti Ender Pearl atau Kulit Kelinci. \\n\\nSekali lagi, kamu bisa melihat daftar lengkapnya di bagian Tag."]
	quest.2F0D6267569F740B.title: "Material Umum"
	quest.2F16B6A173525277.quest_desc: [
		"Bagian terakhir dari teka-teki jaringan ME besar adalah &bME Controller&f. "
		""
		"Sebuah controller menyediakan jumlah channel yang jauh lebih besar daripada standar 8 channel pada jaringan ad-hoc, memberikan 32 channel dari setiap sisi blok dengan total 216 channel. "
		""
		"Namun, itu baru untuk controller satu blok, karena ME Controller sebenarnya adalah struktur multi-blok. Controller dapat berukuran hingga 7x7x7 blok. Setiap blok individu dapat menyediakan set channel-nya sendiri, selama tidak ada blok controller tunggal yang dikelilingi oleh 4 blok lainnya pada bidang yang sama. "
		""
		"Sebuah Jaringan ME hanya boleh memiliki satu multiblock controller dalam satu waktu. Mencoba menghubungkan lebih dari satu controller akan menyebabkan konflik dan mematikan seluruh jaringan."
	]
	quest.2F16B6A173525277.title: "ME Controller"
	quest.2F19529214CA9559.quest_desc: ["Seperti Thorns tapi tidak Merusak, hanya membingungkan Penyerang. \\n\\nHanya akan menghentikan Mob sebentar, jauh lebih efektif (dan menjengkelkan) untuk Pemain!"]
	quest.2F19529214CA9559.quest_subtitle: "Blitz?"
	quest.2F2597122C6202EF.quest_subtitle: "Dibuat di Atomic Forge"
	quest.2F2597122C6202EF.title: "Prometheum Bee"
	quest.2F37E284BB83BFF6.quest_desc: ["Wrench dipakai untuk memutar atau menghancurkan block tertentu, shift klik kanan di udara untuk ganti mode."]
	quest.2F3E7233129F2B89.quest_desc: [
		"Fungsinya persis kayak Luminofish cuma yang ini punya tanduk di kepalanya!"
		"{image:atm:textures/questpics/eternal/starlight_fish2.png width:100 height:100 align:center}"
	]
	quest.2F3E7233129F2B89.title: "Luminaris"
	quest.2F4458E9921DEB86.quest_desc: [
		"&e&lPipez&r ini ada terutama untuk &5&lMekanism&r. &5&lMekanism&r menambahkan wujud zat terakhir dalam bentuk &aGas&r. &aGas&r tidak bisa dipindahkan dengan &e&lPipez&r lainnya, jadi jika kamu perlu memindahkan Hidrogen atau Lithium, kamu butuh &aGas Pipez&r. \\n\\n(Aku sering kesulitan membedakan apakah item &5&lMekanism&r itu &aGas&r, &bFluid&r, atau bahkan Infuse Type. Saat berada di dalam mesin, biasanya akan tertulis &aGas&r atau &bFluid&r yang bisa membantumu. Jika tidak, kamu bisa cek JEI untuk resep lain yang melibatkannya!)"
		"{image:atm:textures/questpics/logistics/pipez_gas.png width:200 height:50 align:center}"
	]
	quest.2F4458E9921DEB86.title: "&aGas Pipez&r"
	quest.2F556E7919582D2D.quest_desc: ["&bCell Workbench&f memungkinkan cell untuk 'disekat' (partitioned) agar hanya menampung item tertentu, yaitu memberinya filter whitelist. Ini juga memungkinkan cell ditingkatkan dengan kartu tertentu seperti Inverter Card, yang mengubah whitelist menjadi blacklist.\\n\\nCell juga bisa diberi 'prioritas' lebih tinggi atau rendah, sehingga cell tersebut menjadi yang pertama menerima item tertentu sampai penuh, atau menunggu cell prioritas tinggi lainnya terisi terlebih dahulu."]
	quest.2F556E7919582D2D.title: "Cell Workbench"
	quest.2F62C290A5CE50F8.quest_desc: ["Tunggu, maksudmu hanya dengan sedikit &eAncient Metal&r kita bisa dapat senjata dengan damage lebih tinggi dari Pedang Netherite, jarak serang gila, dan bisa melempar &eSandstorm&r!? \\n\\nYa, itulah yang kamu dapatkan dari &eAncient Spear&r!"]
	quest.2F62C290A5CE50F8.title: "&eAncient Spear"
	quest.2F69010E1FA2787D.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Community contributor&r untuk dipakai di AllTheMods Modpack. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan dengan &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik manapun yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan, kalau terlihat, berarti sedang di editing mode."]
	quest.2F76D074AEA84A4D.quest_desc: ["Dengan Klik Kanan &dEnder Dragon&r pake &bData Model&r kosong, kamu bisa bikin &dEnder Dragon &bData Model&r. \\n\\nQuest butuh versi apapun, tapi &d&lDragon Soul&r butuh &bData Model&r yang &6Self Aware&r. \\n\\nBuat bikin &6Self Aware&r kamu harus terus bunuh &dDragon&r atau bikin banyak banget Prediction!"]
	quest.2F76D074AEA84A4D.title: "&dEnder Dragon &bData Model"
	quest.2F86FB9E4D49E4B0.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemindai Monster"
	]
	quest.2F8D117F802FEAF0.quest_desc: ["Komando adalah pasukan ringan. \\n\\nMereka memiliki 12 Hati dan tanpa Armor. \\n\\nSenjata mereka adalah &d&lRevolver&r dan Perisai yang mereka pegang di Tangan Kedua. \\n\\nSaat mati mereka akan menjatuhkan bagian Revolver dengan statistik berbeda, mirip dengan statistik Apotheosis!"]
	quest.2F8D117F802FEAF0.title: "Komando"
	quest.2F9B0C642A6BE30C.title: "&fIron Backpack"
	quest.2FA0F5B348322095.quest_desc: ["&7Cloggrum&r adalah 'Bijih Besi' versi &2&lUndergarden&r. Bijih ini muncul di mana-mana."]
	quest.2FA0F5B348322095.quest_subtitle: "14"
	quest.2FA0F5B348322095.title: "&7Cloggrum Armor"
	quest.2FA6B8A1C8713DE0.quest_desc: ["Buat nanem Benih Tingkat 6 atau Ajaib kamu harus taro Crux tertentu langsung di bawah Lahan Pertanian tempat mereka numbuh."]
	quest.2FA6B8A1C8713DE0.title: "&5Lahan Pertanian Insanium"
	quest.2FB231069D2E4E77.quest_desc: ["Setiap cell individu memiliki kapasitas tertentu yang ditentukan oleh &ekomponen&f yang digunakan saat pembuatannya.\\n\\nKomponen pertama adalah &bKomponen Penyimpanan ME 1k&f, yang menyediakan &e1024&f 'byte' penyimpanan untuk satu cell. Penjelasan lebih lanjut akan menyusul."]
	quest.2FB231069D2E4E77.quest_subtitle: "Kilobyte Pertama"
	quest.2FB231069D2E4E77.title: "Membuat Storage Cell Pertama"
	quest.2FC15D3916DBF4E4.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.2FC15D3916DBF4E4.title: "&eAdvanced Void Upgrade"
	quest.2FD22502E6481269.quest_desc: ["Menggunakan &dRonaza's Contact&r, kamu bisa meningkatkan Soul Gem milikmu untuk menciptakan Trinity Gem. Ini hanyalah versi kuat dari Soul Gem yang bisa menangkap musuh yang lebih besar, meski tetap tidak bisa menampung bos."]
	quest.2FD22502E6481269.title: "Trinity Gem"
	quest.2FE088899C1AF39B.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.2FE088899C1AF39B.title: "Dark Steel Bee"
	quest.2FE4B7B70D90A455.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.3003598CE8B1FAAA.quest_subtitle: "Teknologi Lebih Baik"
	quest.3003598CE8B1FAAA.title: "Komponen Lebih Canggih"
	quest.3009018DEC1EC952.quest_desc: ["Ada 6 struktur di &2Overworld&r di mana boss bisa spawn! (Ada yang ke-7 tapi tidak ada boss di sana)."]
	quest.3009018DEC1EC952.title: "&lWaktu Petualangan!"
	quest.300F2E45D185A9A1.quest_desc: ["&lIron&r telah membawa kita Mod Magic yang luar biasa dan sangat menyenangkan! &lIron's Spells 'N Spellbooks!&r \\n\\n&lIron's Spells&r adalah tentang membuat dan menggunakan &3Spell&r! Setiap &3Spell&r punya Rarity, Level, dan Class! Dan semuanya bisa digunakan di Spellbook. \\n\\nKamu tidak akan bisa membuat apa pun yang kamu mau dengan &7Iron&r dan &cRedstone&r, kamu harus bangkit, Berpetualang, dan Bertarung!"]
	quest.300F2E45D185A9A1.title: "&lIron's Spells 'N Spellbooks"
	quest.3025081DA6D2B398.quest_desc: ["Biasanya Router yang memerintah Module, tapi dengan augment ini, Module-nya membangkang! Anarki total! \\n\\nIa akan mengikuti aktivasi Redstone-nya sendiri daripada mengikuti pengaturan Router."]
	quest.3027584AA6138E6D.title: "Conveyor Insertion \\& Extraction"
	quest.3029E1E133B91ED8.quest_desc: ["&6Bor Mekanik&r bisa digunakan dalam &aKontraption&r atau secara langsung. Penggunaan langsung tetap butuh &dTenaga Rotasi&r tapi tugasnya sama. \\n\\n&6Bor Mekanik&r akan menambang Blok apapun di depannya (yang bisa ditambang). \\n\\nKecepatan penambangan sesuai dengan &dTenaga Rotasi&r yang diberikan. Dan kalau ada Inventaris yang terhubung ke &aKontraption&r, Blok yang ditambang akan masuk ke dalamnya, bukan jatuh ke lantai. \\n\\nYa, &6Bor&r punya batasan — hanya setingkat Diamond untuk Penambangan. Jadi, nggak bisa nambang &6AllTheModium&r!"]
	quest.3029E1E133B91ED8.title: "&6Bor Mekanik"
	quest.302E9BC711779A4A.quest_desc: ["Mari kita istirahat dari &eSulfur&r sama Acid dan fokus ke bagian &2Radioactive&r dari &2Fissile Fuel&r! \\n\\nSekarang coba lihat... apa yang &2Radioactive&r, banyak, dan dipake di &6&lATO&r jadi versi manapun bisa? \\n\\nOh iya &aUranium&r! \\n\\nTambang &aUranium Ore&r dan pake &aUranium Ingot&r di &d&lEnrichment Chamber&r buat bikin &eYellow Cake Uranium&r. \\n\\nGak, jangan dimakan. Ini bukan Kue beneran! \\n\\nPanggang &eYellow Cake Uranium&r di &c&lChemical &eOxidizer&r buat bikin &aUranium Oxide&r."]
	quest.302E9BC711779A4A.title: "Persiapan &aUranium"
	quest.3054D016D2EF25FF.quest_subtitle: "Tuangkan Molten Electrum ke atas telur lebah Gold/Silver"
	quest.3054D016D2EF25FF.title: "Electrum Bee"
	quest.30582B5FBED35FD1.quest_desc: ["&cUtherium&r bisa didapatkan dengan menambang atau sebagai drop dari &cRot Mobs&r. "]
	quest.30582B5FDED35FD1.title: "&cUtheric&r"
	quest.3061B67330367CE2.quest_desc: ["Jika kamu berhasil membunuh Hydra atau Ur-Ghast, kamu akan mendapatkan akses ke &4Fiery Tears/Blood&r! \\n\\nSekarang kamu bisa membuat &4Fiery Armor&r dengan meningkatkan Iron Armor-mu menggunakan salah satu dari &4Fiery Vial&r tersebut. \\n\\nKini armormu lebih kuat dari &cNetherite&r dan siapa pun yang berani memukulmu akan langsung terbakar!"]
	quest.3061B67330367CE2.quest_subtitle: "24"
	quest.3061B67330367CE2.title: "&4Fiery Armor"
	quest.3065EA195D0A36BA.quest_desc: ["Tag adalah bagian penting untuk mengelompokkan Item di Minecraft. Jadi tentu saja kita bisa memanfaatkannya untuk Filter! \\n\\nKamu bisa memasukkan Item dan memilih Tag-nya, atau jika kamu tahu kodenya, ketik sendiri secara manual. \\n\\nSangat berguna misalnya untuk mengeluarkan perlengkapan (Gear) dari sistem dengan menggunakan Tag untuk Tools. \\n\\n(Kamu juga bisa menemukan Tag dengan mengetik /kubejs hand untuk melihat apa Tag dari item yang kamu pegang.)"]
	quest.30700E99091B712A.quest_desc: ["&cRegulator Upgrade&r memungkinkanmu menjaga jumlah item tertentu di dalam blok atau mesin. Contoh bagusnya adalah memberitahu jaringanmu bahwa kamu ingin selalu ada 64 Batu Bara di dalam Furnace. Kamu cukup menaruh upgrade ini di Exporter yang menempel ke Furnace, lalu atur angkanya ke 64. Sistemmu akan berusaha menjaga Furnace tetap penuh bahan bakar!\\n\\nTapi bagaimana jika kamu butuh item hasil crafting? &6Crafting Upgrade&r melakukan hal tersebut. Jika kamu memiliki resepnya di dalam Autocrafter, menambahkan upgrade ini ke interface akan memberitahu sistem untuk men-craft item tersebut jika stok habis.\\n\\nMenggunakan contoh sebelumnya, katakanlah kita punya kebun &aMystical Agriculture&r dan punya Coal Essence. Kita bisa menaruh resep Batu Bara di Autocrafter, lalu pasang upgrade ini di Exporter yang sama. Jika Batu Bara habis, &6Crafting Upgrade&r membolehkan sistemmu men-craft lebih banyak!"]
	quest.30700E99091B712A.title: "&cRegulator Upgrade"
	quest.308935C85364B04D.quest_desc: ["Karena setiap Kartu menyimpan datanya sendiri, akan sangat menjengkelkan jika harus terus-menerus mengubah pengaturan tiap Kartu. Jadi, mari kita kloning saja! \\n\\nKlik Kiri pada Kartu dengan Cloner untuk menyalin Datanya, lalu Klik Kanan pada Kartu lain untuk memberikan Data tersebut!"]
	quest.309059DEDEE7AECD.quest_desc: ["Mengambil item yang ada di tanah dan membawanya kembali ke sarang."]
	quest.309059DEDEE7AECD.quest_subtitle: "Berikan Collector Bee sebuah Shulker Shell"
	quest.309059DEDEE7AECD.title: "Hoarder Bee"
	quest.309B0B2898893B4E.quest_desc: ["&b&lSteve's Carts&r itu semua tentang upgrade... ya Cart kamu! \\n\\nUpgrade apa? Hampir semuanya kecuali kitchen sink! \\n\\nDari Drill, sampe gun, sampe mesin arcade! Apa lagi yang kamu mau dari Cart?"]
	quest.309B0B2898893B4E.title: "&l&bSteve's Carts"
	quest.309B6B8368E535A0.quest_desc: ["Router melakukan aksinya setiap kali terjadi 'tick'. \\n\\nBawaan pabriknya adalah 20 Tick atau 1 Detik. \\n\\nIni bisa dikurangi agar lebih cepat dengan Speed Upgrade!"]
	quest.30A238E87F013CBB.quest_desc: ["Lebah punya berbagai sifat (Trait) yang mempengaruhi cara kerja, waktu kerja, agresi, dan peluang kehilangan sengat. Quest ini akan membahas cara mendapatkan sifat terbaik.\\n\\nUntuk mendapatkan Gene Sample, cek quest Bottler. Untuk menerapkannya, gabungkan Gene Sample dengan Honey Treat di crafting grid, lalu berikan ke lebahmu. Sifat 'Type' berbeda, ia harus digunakan di Incubator untuk membuat Spawn Egg lebah tersebut."]
	quest.30A238E87F013CBB.quest_subtitle: "Untuk membuat lebah pamungkas"
	quest.30A238E87F013CBB.title: "Gene Samples (Sampel Gen)"
	quest.30A61E1A1EFA81E6.quest_desc: ["&2Steeleaf&r secara teknis adalah Ingot yang ditemukan di dalam peti di &9&lThe Twilight Forest&r. \\nSetiap bagian armor memberikan Enchantment yang berbeda secara otomatis!"]
	quest.30A61E1A1EFA81E6.quest_subtitle: "20"
	quest.30A61E1A1EFA81E6.title: "&2Steeleaf Armor"
	quest.30AC43222FF9B18A.quest_desc: ["&5Sinyal Kereta&r digunakan bersama &5Kondektur&r yang bukan Pemain. \\n\\nDipasang seperti &5Stasiun Kereta&f dan &5Observer&r, tapi cara pemasangannya menentukan penempatan Panah. \\n\\nPanah membatasi di mana &5Kondektur&r boleh melewatkan &5Kereta&r mereka — kalau Panah menghadap berlawanan, &5Kereta&r tidak akan lewat. \\n\\nKamu bisa memasang dua Sinyal yang saling berlawanan arah agar &5Kondektur&r bisa melintas dari kedua arah. \\n\\nDengan banyak &5Sinyal&r kita bisa membuat Lampu Lalu Lintas untuk persimpangan &7Rel&r. Pasang &5Sinyal&r sehingga ada Panah di kedua sisi persimpangan. \\n\\nIni akan membuat &5Kereta&r berhenti kalau &5Kereta&r lain sedang berada di persimpangan. Ini mencegah tabrakan yang bisa Mendapatkan &5Kereta&r Tergelincir. Kereta yang tergelincir perlu Kunci Inggris untuk dikembalikan ke &7Rel&r!"]
	quest.30AC43222FF9B18A.title: "&5Sinyal Kereta"
	quest.30AD7B15682E4D0E.quest_desc: ["Papan tanda pintar yang bisa menyimpan dan menampilkan teks dalam jumlah bebas, skalanya otomatis menyesuaikan agar teks selalu pas.\\n\\nKlik Kanan dengan Pewarna apa pun untuk mewarnai ubinnya; kamu bisa mewarnai bingkai dan latar belakangnya secara terpisah."]
	quest.30AD7B15682E4D0E.quest_subtitle: "Papan tanda? Belum pernah dengar!"
	quest.30B0240543253EFB.quest_desc: ["Pylons adalah mod luar biasa yang dibuat oleh anggota tim kami sendiri, &aMutant Gumdrop&r!\\n\\nJangan biarkan ukuran mod yang kecil membuatmu meremehkannya! Mod ini menyediakan berbagai jenis Pylon yang bisa digunakan untuk banyak hal guna memudahkan permainan Minecraft-mu.\\n\\nUntuk memulainya, kamu butuh Polished Blackstone untuk membuat mereka."]
	quest.30B0240543253EFB.title: "&lPylons"
	quest.30B3BC91460C9B19.quest_desc: ["&bMacaw Sketch&r adalah pengembang mod yang sangat populer. Dia dikenal dengan mod dekorasinya. \\nMulai dari Jendela, Jalan, hingga Laci. Dia membuat hampir segalanya. \\n\\nBisakah kamu membuat semuanya?"]
	quest.30B3BC91460C9B19.title: "Mod Macaw"
	quest.30B7AF815D9D7553.quest_desc: [
		"&cBurned Tower&r milik &c&lPyromancer&r. Ada yang bilang jika kamu cukup dekat untuk melihat &cMenara&r, maka kamu cukup dekat untuk merasakan panasnya. \\n\\n&cPyromancer Tower&r adalah menara terbakar yang terutama terbuat dari jenis Batu dengan bagian dalam terbuat dari Spruce dan Oak. Ada juga Bangunan kedua dekat &cMenara&r yang merupakan bagian dari struktur juga. \\n\\nDi atas kamu akan menemukan apa yang menyebabkan asap serta &5Armor Pile&r. \\n\\nJika kamu ingin menemukan &c&lPyromancer&r kamu harus turun ke Basement!"
		"{image:atm:textures/questpics/iron_spells/spells_pyromancertower.png width:200 height:100 align:center}"
	]
	quest.30B7AF815D9D7553.title: "&cPyromancer Tower"
	quest.30C12E249F7E2D52.quest_desc: [
		"Salah satu struktur terbesar di &6&lBumblezone&r yang tentu saja berarti paling banyak loot!\\n\\nAda banyak ruangan berbeda yang terhubung dalam semacam desain teka-teki.\\n\\nJika kamu belum menggunakan Essence of Bees atau tidak memiliki efek Protection of the Hive, kamu akan terkena efek Wrath of the Hive saat berada di dalam Cell Maze. Jadi beri makan para Lebah!\\n\\nJuga &5Throne Pillar Compass&r akan selalu muncul di struktur ini.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_cell.png width:200 height:100 align:center}"
	]
	quest.30C12E249F7E2D52.title: "Labirin Sel"
	quest.30C5B597610F4AFB.quest_desc: ["Item pertama dan terpenting yang dibuat menggunakan Eziveus' Spectral Compulsion adalah Research Fragment Dust. Ini digunakan bersama dengan hancuran Emerald untuk menciptakan Lime Chalk!"]
	quest.30C5B597610F4AFB.title: "&aLime Chalk (Kapur Limau)"
	quest.30C5D432C810F904.quest_desc: ["&9Eye of Storm&r akan menuntunmu ke &9Acropolis&r untuk melawan &9&lScylla&r."]
	quest.30C5D432C810F904.title: "&9Eye of Storm"
	quest.30CC20E33EFA2EDA.quest_desc: ["&cBlaze Burner&r sebenernya mungkin salah satu Bahan &6&lStar&r paling gampang! \\n\\nPertama, kita butuh &cEmpty Blaze Burner&r. Ini cuma 4 &7Iron Plate&r dan satu &cNetherrack&r. \\n\\nTerus, ambil &cEmpty Blaze Burner&r-mu dan cari &cBlaze&r. Kamu harusnya tau di mana mereka spawn tapi kalo gak: &cBlaze&r spawn di Struktur di &c&lThe Nether&r. Tinggal Klik Kanan &cBlaze&r pake &cEmpty Blaze Burner&r buat nangkap! \\n\\nSetelah ditangkap, ini bisa dipake sebagai pengganti &aUranium Quad Fuel Rod&r buat bikin &c&lPhilosopher's Fuel&r."]
	quest.30CC20E33EFA2EDA.title: "&cBlaze Burner"
	quest.30DE4F5BC3EDB555.quest_desc: [
		"Logical Transporter adalah apa yang digunakan &5&lMeka&r untuk memindahkan Item dan Blok dalam jarak jauh. \\n\\nMereka perlu dikonfigurasi untuk Menarik (Pull) atau Mendorong (Push) ke Inventaris seperti Peti (Chest) atau Drawer."
		"{image:atm:textures/questpics/logistics/meka_transporter.png width:200 height:50 align:center}"
	]
	quest.30DE4F5BC3EDB555.quest_subtitle: "Blok+Item"
	quest.30DF8297FEEC9F22.quest_subtitle: "Tingkat: &63"
	quest.30E853CE699E669B.quest_desc: ["Sebelum kamu bisa menjalankan tugas otomatisasi crafting, kamu butuh perangkat untuk menyimpan permintaan itu sendiri beserta item perantara untuk proses yang panjang. Perangkat ini dikenal sebagai &ecrafting CPU&f.\\n\\nCrafting CPU adalah struktur multiblock yang membutuhkan setidaknya satu blok &bCrafting Storage&f. Multiblock ini bisa dibuat dalam berbagai ukuran, tetapi harus berbentuk balok solid agar berfungsi."]
	quest.30E853CE699E669B.quest_subtitle: "Instal RAM Jaringan"
	quest.30E853CE699E669B.title: "Crafting CPU"
	quest.30E9255DEC69C061.title: "&4Peralatan Supremium"
	quest.30EA16BB8C169F86.quest_desc: ["Yang satu ini adalah kombinasi &6Tembaga&r dan &7Timah&r! \\n\\nBanyak digunakan di &7&lModern Industrialization&r! Tapi di &8&lIE&r... tidak banyak..."]
	quest.30EA16BB8C169F86.title: "&6Batang Perunggu"
	quest.30EB438C66324213.quest_desc: ["Nether Star fungsinya sama seperti Prismarine Shard tapi jauh lebih hebat. Pemain tidak perlu lagi berada di dekat spawner. Selama chunk tersebut dimuat (chunk-loaded), spawner akan terus aktif."]
	quest.30EB438C66324213.title: "Abaikan Pemain"
	quest.30F97EB743B0A07F.quest_desc: ["Lihat Modules untuk belajar lebih tentang cara menggunakan dan upgrade item DE! Wyvern Axe mirip dengan Minecraft Axes setelah Combat Update. Bisa dirancang sebagai senjata untuk membunuh musuh, atau tool untuk menebang pohon."]
	quest.30F97EB743B0A07F.title: "Wyvern Axe"
	quest.31094CC16E710040.quest_desc: ["&4Crowbar&r (Linggis) adalah alat utama di RailCraft. \\n\\nSaat digunakan pada &5Lokomotif&r, ia akan mengubah arah hadapnya. \\n\\nDengan Shift+Klik, kamu bisa menyambungkan (couple) &5Lokomotif&r dan &7Cart&r. \\n\\nJika digunakan pada &7Cart&r, ia akan memberikan sedikit dorongan. \\n\\nDan pada rel khusus, alat ini digunakan untuk mengubah modenya. \\n\\nPerbedaan jenis &4Crowbar&r hanya pada tampilan dan jumlah damage-nya."]
	quest.31094CC16E710040.quest_subtitle: "\"Mau ngerampok ya?\""
	quest.310969B8FE0A94DE.quest_desc: ["Perubahan mekanisme lain yang dibawa oleh Apotheosis adalah pada Spawner. Ingat saat kita bisa menambang Spawner pakai Silk Touch? Nah, fitur itu balik lagi berkat Apotheosis! Ada juga banyak modifikasi baru yang bisa kamu tambahkan ke Spawner dengan klik kanan menggunakan item-item tertentu."]
	quest.310969B8FE0A94DE.title: "Apothic Spawner"
	quest.311F43D48B9C26FF.quest_desc: ["&dObsidian Generator&r lebih lambat dari &aEmerald&r dan &5Netherite Generator&r tapi punya upgrade lebih banyak dari semua itu digabungin!"]
	quest.311F43D48B9C26FF.title: "&dObsidian Generator"
	quest.312331F6DB0CE5F4.quest_desc: ["Lebih cepat daripada Tingkat I."]
	quest.312331F6DB0CE5F4.quest_subtitle: "Maks: 1"
	quest.31324A6F96CAC112.quest_desc: ["&bPompa Cairan&r tidak hanya digunakan untuk Bottler, juga bisa digunakan untuk memindahkan &bCairan&r... lebih cepat! \\n\\nMenggunakan &6Palu Insinyur&r, kita bisa mengatur Sisi &bPompa Cairan&r ke &9Input&r dan &6Output&r. \\n\\nKemudian, bisa Daya dengan &4Redstone&r atau &cEnergi&r, dengan &cEnergi&r memindahkan &bCairan&r jauh lebih cepat daripada &4Redstone&r."]
	quest.31324A6F96CAC112.title: "&bPompa Cairan"
	quest.3138B83ABC2930F9.quest_desc: [
		"Kemampuan Intrinsik:"
		"- Tidak Menginjak Tanaman"
		"- Panen Otomatis"
		"- Pertumbuhan Tanaman Dipercepat IV"
		""
		"Upgrade yang Tersedia:"
		"- Teleporter Barang Jatuhan"
	]
	quest.313F5AFF459201EB.quest_desc: ["&l&5Eternal Starlight&r adalah dimensi baru untuk dijelajahi! \\n\\nDan bagi mereka yang benar-benar mencari bahan bangunan di &2&lMinecraft&r, kamu bisa menemukan banyak batu baru di sana! \\n\\nUntuk menuju dimensi tersebut, kamu harus menemukan portalnya!"]
	quest.313F5AFF459201EB.title: "Batu &l&5Eternal Starlight&r"
	quest.3142A40E1EAEBAA3.quest_desc: ["&6Dowsing Rod&r memberikan efek Magic Find dan Scrying saat digunakan. \\n\\nIni memungkinkanmu melihat makhluk ajaib di sekitar serta membantumu menemukan amethyst!"]
	quest.3142A40E1EAEBAA3.quest_subtitle: "Pencari Sihir"
	quest.3145B847A15F97F2.quest_desc: ["Kamu bisa gabungin Essence dari &2&lMystical Agriculture&r buat bikin... &8Coal&r. \\n\\nJelas ini jadi sumber Fuel yang mantap tapi &5Insanium Coal&r kayaknya terlalu gila buat gue. "]
	quest.3145B847A15F97F2.title: "&5Insanium Coal Block"
	quest.3155E4212045BC8E.quest_desc: [
		"Obsidian Nest akan memancing Draconic Bee saat diletakkan di End."
		""
		"Lebah ini tidak menerima Honey Treat, melainkan butuh Dragon's Breath."
	]
	quest.3155E4212045BC8E.quest_subtitle: "Memancing Draconic Bee di dimensi End"
	quest.3157BD833FCE8CD3.quest_subtitle: "Berikan satu ember Sheol Fire ke Lava Bee"
	quest.3157BD833FCE8CD3.title: "Sheol fire Bee"
	quest.315913D32319F010.quest_desc: ["Jar bisa dipake buat tangkep dan perbudak &dPixie&r. Ya, tentu saja salah satu dari sedikit Mob Pasif di &b&lIce &fdan &cFire&r kita bakal perdagangkan! \\n\\nKalo bikin kamu merasa lebih baik, setidaknya mereka bikin 1 &dDebu Pixie&r setiap beberapa Hari. \\nPertama, tinggal pake Jar ke &dPixie&r dan mereka bakal Ketangkep di dalamnya. \\n\\nTerus, kamu bisa Pecahin buat bebasin mereka atau tinggalin dan tunggu buat dapet &dDebu Pixie&r. \\n\\nLo bakal tau &dDebu Pixie&r-nya udah siap pas mereka Duduk! Tinggal Klik Kanan mereka buat ambil."]
	quest.315913D32319F010.title: "Perbudakan &dPixie"
	quest.3166CA00032C18F7.quest_desc: ["Ada puluhan Pet dan Mob Jinak di &b&lIce &fdan &cFire&r. Untungnya hampir semua bisa dikontrol dengan cara yang sama! \\n\\nPake Stick! \\n\\nDengan Klik Kanan Mob Jinak pake Stick kita bisa ubah instruksi mereka. \\n\\nSemuanya punya instruksi berbeda tapi listnya: Duduk/Diam, Berkeliaran, Patroli, dan Mengikuti/Mengawal. \\n\\nDuduk bakal bikin Mob tetep di tempatnya. Mereka gak bakal Gerak atau Berantem sama Mob lain kecuali di-Hit dimana mereka bakal berhenti Duduk. \\nBerkeliaran bakal biarkan Mob gerak bebas di sekitar kamu. Kalo Mob Jinak-nya suka Nyerang Mob, mereka bakal lakuin itu pas Berkeliaran. \\n\\nPatroli bakal bikin Mob jalan cuma di jarak tertentu dari Home yang ditentukan. Jadi kayak Berkeliaran cuma gak di sekitar kamu, tapi di sekitar Home-nya! \\n\\nMengikuti bakal bikin Mob ikutin kamu kemanapun kamu pergi! \\n\\nLo bisa set Home Mob Jinak dengan Shift Klik Kanan mereka pake Stick."]
	quest.3166CA00032C18F7.title: "Jinakkin Mob &b&lIce &fdan &cFire"
	quest.316B513FE568EF57.quest_desc: [
		"Panas (Heat) adalah faktor lain di &5&lMekanism&r dan ia menjadi bahan bakar banyak mesin serta Multiblock. Thermal Evaporation Plant dan Fusion Reactor keduanya menggunakan Panas agar bisa bekerja. Dan Conductor adalah cara kamu memindahkan Panas tersebut!"
		"{image:atm:textures/questpics/logistics/meka_conductor.png width:200 height:50 align:center}"
	]
	quest.316B513FE568EF57.quest_subtitle: "Panas"
	quest.3182E8AF755104E4.quest_desc: ["Saat menahan serangan, &9Enchanter's Shield&r akan memberikan penggunanya regenerasi mana dan Spell Damage dalam durasi singkat. \\n\\nSelain itu, perisai ini akan memperbaiki dirinya sendiri seiring waktu dengan mengonsumsi mana pengguna."]
	quest.318A2CC03D1D0B04.quest_desc: ["Pernah rindu dengan &lConstruction Wands&r? \\n\\nAku rindu, begitu juga dengan &9Mrbysco&r! Jadi dia membuat &l&6Construction Sticks&r! \\n\\nAda beberapa tingkatan (Tier) untuk &6Construction Stick&r. Semakin mahal harganya, semakin tinggi durabilitasnya dan semakin banyak blok yang bisa diletakkan sekaligus. \\n\\nMereka akan mulai dengan hanya meletakkan blok untuk mengisi ruang, tetapi opsinya bisa diubah dengan membuka GUI-nya. Kamu perlu mengatur tombol (Keybind) sendiri untuk melakukannya. \\n\\nSetelah dibuka, kamu bisa mengubah segalanya. Di mana mereka meletakkan blok, dalam pola apa, dan bahkan blok apa yang akan diletakkan! \\n\\nMereka juga memiliki upgrade sendiri yang bisa kamu craft. Untuk menggunakannya, gabungkan upgrade tersebut dengan &6Construction Stick&r milikmu di Smithing Table."]
	quest.318A2CC03D1D0B04.title: "&l&6Construction Sticks"
	quest.3195A7AA874163CD.quest_desc: ["&bEqual Distribution Card&f adalah upgrade untuk storage cell yang mengalokasikan jumlah item tertentu yang bisa diambil oleh setiap jenis item.\\n\\nPerilaku ini sebanding dengan laci Functional Storage, di mana setiap kompartemen menampung jumlah stack yang ditentukan sehingga item dari satu kompartemen tidak memenuhi kompartemen lainnya."]
	quest.3195A7AA874163CD.quest_subtitle: "Manajemen Kapasitas Cell"
	quest.3195A7AA874163CD.title: "Equal Distribution Card"
	quest.31A370550BD592B6.quest_desc: ["Benih Kristal Nitro butuh Kristal Nitro Crux yang ditaro di bawah biar bisa numbuh."]
	quest.31A370550BD592B6.quest_subtitle: "Tingkat: &56"
	quest.31AD9826FB036C98.quest_desc: ["&7Rune&r bisa spawn dari Bedrock sampai Y Level 2. Itu termasuk di dekat &9Darkstone&r! \\n\\nMereka lebih berguna dari &2Stellarite&r tapi kurang berguna dari &bArcane Crystal&r."]
	quest.31AD9826FB036C98.quest_subtitle: "Ini dulu &5Ungu&r!"
	quest.31AD9826FB036C98.title: "&7Rune"
	quest.31B0267C47DB9D98.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Kontributor Komunitas&r buat dipake di AllTheMods Modpack.\\n\\nKarena semua pack &6AllTheMods&r dilisensiin di bawah &eAll Rights Reserved&r, Quest ini gak boleh dipake di pack publik apapun yang gak dirilis sama &6AllTheMods Team&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyiin, kalo kamu liat ini, berarti kamu di mode editing."]
	quest.31B73D16C0199785.quest_desc: ["Masukkan &5Refined Obsidian Dust&r ke dalam &7&lOsmium Compressor&r terus &7Compress &fpakai sedikit &7Osmium&r! \\n\\nKayaknya sih gitu cara kerja &7&lOsmium Compressor&r... \\n\\nSekarang kita punya &5Refined Obsidian Ingot&r, ini bisa dibuat jadi &5Mesin&r lain atau bahkan alat dan armor!"]
	quest.31B73D16C0199785.title: "&5Refined Obsidian"
	quest.31BAC57972148E1F.quest_subtitle: "Tingkat: &a2"
	quest.31BB7EB95CE73C1A.quest_desc: ["Setelah mengalahkan &cUr-Ghast&r, kamu akan membuka biome Snowy Forest (Hutan Bersalju).\\n\\nAda banyak makhluk untuk dilawan, tapi untuk melanjutkan progres, kamu harus membunuh Alpha Yeti.\\n\\nKamu bisa menemukan Alpha Yeti di dalam gua Yeti yang masif. Kalahkan dia untuk lanjut ke tahap berikutnya."]
	quest.31BB7EB95CE73C1A.quest_subtitle: "Dunia Salju Menantimu"
	quest.31BB7EB95CE73C1A.title: "Ke Biome Salju!"
	quest.31BCE63F5E016323.quest_desc: ["&3Solar Compressor&r menghasilkan tekanan udara menggunakan sinar matahari; semakin panas suhunya, semakin banyak tekanan yang dihasilkan.\\n\\nNamun hati-hati, jika terlalu panas ia akan rusak dan kamu harus memperbaikinya."]
	quest.31BCE63F5E016323.quest_subtitle: "Di telapak tanganku..."
	quest.31BCE63F5E016323.title: "Tekanan dari Matahari"
	quest.31CB278B4BA7B25E.quest_desc: ["Memproses &#B5E7F7Liquid Air&r di dalam centrifuge akan memberikan 3 hasil: &#A5CAD9Oksigen&r, &#78ADC2Nitrogen&r, dan &#DD91EDArgon&r. Kita akan menggunakan &#DD91EDArgon&r ini dalam waktu dekat."]
	quest.31CB278B4BA7B25E.quest_subtitle: "Masuk akal kan"
	quest.31CB278B4BA7B25E.title: "Memproses Udara di Centrifuge"
	quest.31E7F7464D79F881.quest_desc: ["Bukan cuma &7Rak Buku&r yang bisa di-&d&lInfuse!&r"]
	quest.31E7F7464D79F881.title: "Item Infusion Lainnya"
	quest.31EC6244E4A3CBD6.quest_subtitle: "Tingkat: &b4"
	quest.31ED0C236C41A837.quest_subtitle: "Berikan satu ember Lava ke Magmatic Bee"
	quest.31ED0C236C41A837.title: "Lava Bee"
	quest.31FD9EA513E0D010.quest_desc: ["&cEvilCraft&r adalah mod sihir berdasarkan hal-hal yang agak jahat. Kumpulin darah musuh kamu dan manfaatin kekuatan sumber kejahatan kuno!\\n\\nSemua di mod ini bisa ditemuin di buku panduan, &aOrigins of Darkness&r.\\n\\nBuat mulai, cari &9Dark Gem&r."]
	quest.31FD9EA513E0D010.title: "&aSelamat Datang di &cEvilCraft&r!"
	quest.320EE52EB022FAD3.quest_desc: ["Sekarang ini yang menyenangkan! \\n\\n&bOutlet Cairan&r bisa diatur untuk &9Memasukkan &bCairan&r, dan kemudian bisa membuatnya sehingga menempatkan &bCairan&r sebagai Blok Sumber di samping Sisi &6Output&r! \\n\\nIni berarti kita bisa mengotomatisasi penempatan &9Air&r, &cLava&r, atau hampir semua &bCairan&r!"]
	quest.320EE52EB022FAD3.title: "&bOutlet Cairan"
	quest.3215A3D706CECCEF.quest_desc: ["Dengan menggabungkan Liveroot, Ingot Besi, dan &eGold Nugget&r, kamu bisa men-craft &7Ironwood&r! \\n\\nSepertinya kamu butuh Kapak dan Pickaxe untuk mendapatkannya. \\n\\nSemua &7Ironwood Armor&r sudah dilengkapi dengan tingkat perlindungan (Protection) gratis!"]
	quest.3215A3D706CECCEF.quest_subtitle: "16"
	quest.3215A3D706CECCEF.title: "&7Ironwood Armor"
	quest.321F16645640C462.quest_desc: ["Enderpearl itu cara transportasi yang seru! (Sangat membantu di Bumblezone). Tapi sebel nggak sih kalau Enderpearl-nya habis pas dipakai dan kamu kena damage 2 heart tiap kali teleportasi? \\n\\nDengan &9Warp Drive&r, masalah itu hilang, bikin Enderpearl jadi alat transportasi terbaik! Bar lapar (Hunger) bakal berkurang sebagai ganti Enderpearl dan kamu nggak kena damage lagi. Kalau bar lapar habis, barulah dia mulai makan Enderpearl lagi."]
	quest.321F16645640C462.quest_subtitle: "Sabuk"
	quest.321F16645640C462.title: "&9Warp Drive&r"
	quest.321FA7348E532F4E.title: "Latex"
	quest.3227846235A60B58.quest_desc: ["Cara terbaik untuk automasi &aFluid XP&r dan &4Blood&r untuk fuel &c&lAutomatic Forge&r kita butuh Spawner! \\n\\nKita butuh Spawner yang kasih bang terbaik, gue rekomen pakai Piglin Brute karena mereka kasih banyak &aXP&r dan punya banyak &4Health&r. Tapi terserah kamu pakai apa! \\n\\nJuga jangan lupa kasih mereka No AI dengan &dChorus Fruit&r supaya gak kabur. \\n\\nBebas pakai Fan atau Entity Conveyor untuk pindahin Mob yang spawn."]
	quest.3227846235A60B58.title: "Farming untuk &4Blood&r dan &aExperience&r"
	quest.3235FBD9CE21D5EE.quest_desc: ["Lihat Modules untuk belajar lebih tentang cara menggunakan dan upgrade item DE! Aku tahu apa yang kamu Player benar-benar pedulikan tentang Wyvern Shovel. Kamu tidak perlu lagi menghabiskan malam tanpa tidur karena sekarang kamu tahu, DE Shovel bisa membuat pathway."]
	quest.3235FBD9CE21D5EE.title: "Wyvern Shovel"
	quest.32384DE59539557D.quest_desc: [
		"&4&lPenghancur&r adalah Mesin yang sangat berbahaya dan berisik. \\n\\nKamu bisa &9Memasukkan &eBarang&r (atau Mob) ke Kisi Atas, dan akan &4&lMenghancurkan&r mereka menjadi Drop mereka! \\n\\nIni bisa sangat membantu terutama dengan mengambil Bijih Mentah menjadi Debu. Jika kita menggunakan Blok Bijih Mentah, akan memberikan lebih banyak Debu daripada yang diberikan &6Palu&r, juga beberapa memiliki kesempatan memberikan jenis Debu yang sama sekali baru! \\n\\nSemua Drop akan keluar dari Blok Depan Bawah, otomatis &6mengeluarkan&r. Juga memerlukan &cEnergi&r Input dari Sisi Kanan Atas."
		"{@pagebreak}"
		"&4&lPenghancur&r cukup besar, perlu menempatkan tata letak &8Perancah Baja&r dan &eBlok Teknik Ringan&r ini. Arah &eBlok Teknik Ringan&r menghadap adalah sisi Depan!"
		"{image:atm:textures/questpics/immersive/immersive_crusher1.png width:100 height:150 align:center}"
		"Di atas 3 &eBlok Teknik Ringan&r kita akan meletakkan 3 lagi. Kita juga akan meletakkan &4Blok Teknik Redstone&r dan &eBlok Teknik Ringan&r di Sisi Kiri. Kemudian, letakkan &eBlok Ringan&r lain di tengah dan kelilingi dengan &8Pagar Baja&r."
		"{image:atm:textures/questpics/immersive/immersive_crusher2.png width:100 height:100 align:center}"
		"Akhirnya, kita hanya melempar 9 Hopper di atas &8Pagar Baja&r dan di tengah!"
		"{image:atm:textures/questpics/immersive/immersive_crusher3.png width:100 height:100 align:center}"
		"Perlu memukul &8Pagar&r tengah untuk membuat Multiblok."
		"{image:atm:textures/questpics/immersive/immersive_crusher.png width:100 height:100 align:center}"
	]
	quest.32384DE59539557D.title: "&l&4Penghancur"
	quest.325483DEB0C602F8.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.3260EDAD3A619479.quest_desc: ["&5Aethersent Ore&r ditemukan saat hujan meteor di dimensi &5&lEternal Starlight&r. Yang kecil akan hancur saat jatuh, kamu harus menunggu Meteor yang besar! \\n\\nAtau apakah itu Meteorit? Apa bedanya?"]
	quest.3260EDAD3A619479.quest_subtitle: "14"
	quest.3260EDAD3A619479.title: "&5Aethersent Armor"
	quest.326C63F7DC713E71.quest_desc: ["Distributor adalah saudara tiri dari Sender Module (MK3 versi ekonomis). \\n\\nAlih-alih mengirim ke 1 inventaris, ia akan mengirim ke beberapa inventaris yang dipilih. \\n\\nBisa mengirim dalam berbagai mode: Round Robin, Random, Terdekat Dahulu, atau Terjauh Dahulu. Round Robin membagi rata satu per satu seperti pembagi kartu poker. Random akan memilih acak. Sisanya ditentukan oleh jarak dari Router."]
	quest.327587EEEF6849BE.quest_subtitle: "Silver Fir + European Larch"
	quest.32992E3534B86521.quest_desc: [
		"&lStage 1&r sampe &l3 &cNaga Api&r bakal Spawn di &cSarang Naga Api&r. \\n\\n&c&lNaga Api&r dateng dalam Warna: &4Merah&f, &2Emerald&f, &6Perunggu&f, dan &8Abu-abu&r. Mereka juga punya 4 Tanduk di Kepala dan ekor kayak gada. \\n\\n&c&lNaga Api&r bisa ditemuin pas Siang Terbang keliling Ngeasapin semua Mob deket &cSarang&r mereka. Pas kamu deket, mereka bakal Nyerang kamu. Jadi apa yang harus kamu harapkan? \\n\\n&cSerangan Api&f mereka adalah &cNapas Api&r yang cuma bisa dipake &lStage 2&r ke atas. Ini bakal Nembak &cApi&r ke kamu Bakar apapun yang ada di jalannya. Mereka juga punya &cSerangan Bola Api&r ini kayak Bola Api Ghast... cuma jauh lebih parah! Cuma &lStage 3&r ke atas yang bisa pake. \\n\\nKalo kamu cukup deket mereka mungkin juga bakal Tampar kamu pake Ekor, Gigit kamu, atau goyang-goyangin kamu di Mulut mereka setelah Gigit kamu. \\n\\nMau coba kabur? Mereka bakal Terbang ngejar kamu. Mau coba sembunyi? Mereka bisa Hantamkan Blok pake Badan mereka! Kayaknya kamu harus Berantem! \\n\\n&lStage&r awal &cSerangan Elemental&r-nya bukan yang paling ditakutin, tapi kemampuan mereka buat Terbang dan ikutin kamu yang paling parah. Entah bawa sesuatu buat cegah mereka kabur kayak Rantai, atau pake Projectile buat Nyerang mereka!"
		"{@pagebreak}"
		"Pas kamu bunuh &c&lNaga Api&r dia bakal tergeletak gak bergerak di tanah sebagai Mayat. \\n\\nKlik Kanan dengan Tangan Kosong buat lepas &cSisik&r-nya. Terus, bakal lepas &cDaging &fdan &cJantung&r-nya. \\n\\nAtau kamu bisa pake Botol Kosong buat daripada dapet &cSisik&f, &cDaging&f, dan &cJantung&r kamu bakal isi setiap Botol dengan &cDarah Naga Api&r. \\n\\nPas semua udah dilepas dia bakal jadi &7Kerangka&r Naga. Kayak yang ada di Alam Liar, Klik Kanan dengan Tangan Kosong buat ambil &7Tulang&f dan &7Tengkorak&r-nya."
	]
	quest.32992E3534B86521.title: "&lStage 1-3 &cNaga Api"
	quest.32ABE5D734703B9C.quest_desc: ["&7Elytra&r atau &a&lMekaSuit Bodyarmor&r... \\n\\n&7Elytra&r atau &a&lMekaSuit Bodyarmor&r... \\n\\nKenapa gak dua-duanya?"]
	quest.32ABE5D734703B9C.quest_subtitle: "Bodyarmor"
	quest.32ABE5D734703B9C.title: "&7Elytra Unit"
	quest.32AE664113F01CF7.quest_desc: ["&eSpace Dissector&r harusnya dinamakan &ePencipta Lubang Cacing&r, karena ia membuat portal dari satu titik ke titik lainnya. Untuk menentukan titiknya, Tahan Klik Rikan untuk memasang portal pertama, lalu pindah dan lepaskan Klik Kanan untuk memasang portal kedua. Kamu bisa meng-upgrade-nya untuk meningkatkan jarak antar portal dan durasi aktifnya. Hehe, ruang dan waktu, portal... kalau kamu lebih pintar pasti kamu tertawa mendengar candaan ini. "]
	quest.32AE664113F01CF7.quest_subtitle: "Ditemukan di Ruined Portal, Nether Fortress, dan Bastion"
	quest.32AE664113F01CF7.title: "&eSpace Dissector"
	quest.32B01BD789F0B037.quest_desc: ["Awakened Supremium dan essence bertingkat lainnya bisa di-farm pakai mod &6Productive Bees&r."]
	quest.32B01BD789F0B037.title: "Otomatisasi Awakened Supremium"
	quest.32C3E14578D48E6C.quest_desc: ["Sama seperti &3Pressure Tube&r biasa, hanya saja yang ini bisa menahan tekanan hingga 10 bar."]
	quest.32C3E14578D48E6C.quest_subtitle: "Pipa Tekanan Upgrade"
	quest.32C45C6C811FB5F9.quest_desc: ["Ternyata &dPixie&r suka Kue. Kalo kamu kasih ke mereka dengan Drop tepat di mereka, mereka bakal jadi Teman kamu! \\n\\nPas mereka jadi Teman kamu, mereka bakal Ikutin kamu, kecuali disuruh Duduk dan diam. \\n\\nIni saat Warna mereka jadi penting, karena setiap Warna bakal kasih Efek berbeda ke kamu pas deket dan berteman! \\n\\n&bBiru&r: kasih Speed. \\n\\n&dPink&r: kasih Strength. \\n\\n&eKuning&r: kasih Haste. \\n\\n&aHijau&r: kasih Luck. \\n\\n&5Ungu&r: kasih Jump Boost."]
	quest.32C45C6C811FB5F9.title: "Berteman sama &dPixie"
	quest.32C7D8AE859BF89E.quest_desc: [
		"Mungkin &dObsidian&r tapi tenang aja ga perlu &bDiamond Pickaxe&r buat ambilnya, cuma buat craft-nya."
		""
		"Kerja tiap 20 Tick atau tiap Detik. Iya bukan Detik-Detik tapi Detik aja."
		""
		"Bisa di-craft dari &3Crystal Furnace&r atau &aEmerald Furnace&r, dan bisa di-craft jadi &5Netherite Furnace&r!"
	]
	quest.32C7D8AE859BF89E.title: "&dObsidian Furnace"
	quest.32D2CE292E088939.title: "&cFire&r Upgrade Orb"
	quest.32D585D9F73CD9FD.quest_desc: ["&#EDDF55Electric Blast Furnace&r akan memungkinkanmu membakar beberapa sumber daya yang berbeda. Resep-resepnya membutuhkan &#B8ED55coil spesifik&r untuk digunakan di dalam strukturnya."]
	quest.32E52AD6EF194A60.quest_desc: ["Expulsion Pylon berfungsi untuk menjaga agar orang lain tidak sembarangan masuk ke wilayahmu. \\n\\nSaat diletakkan, ia akan mengusir pemain mana pun yang tidak terdaftar di whitelist dari area Chunk di sekitarnya. \\n\\nJumlah Chunk bisa diatur melalui GUI di pojok kiri atas, mulai dari 1x1, 3x3, hingga 5x5 Chunk. \\n\\nDan tidak, alat ini tidak bisa dipasang terlalu dekat dengan titik Spawn. Kami tahu apa yang kalian para troll inginkan dan kami tidak akan memberikannya! \\n\\nUntuk memasukkan pemain ke Whitelist, cek Quest Player Filter!"]
	quest.32E52AD6EF194A60.quest_subtitle: "Dilarang masuk wilayah pribadi!"
	quest.32EBB3D53AA91E09.quest_desc: ["Kecuali kamu curang pakai Night Vision Texture Pack, kamu mungkin merasa gelap sedikit mengkhawatirkan. Untungnya Night Vision Module di DE Chestplate membantu mengatasi ketakutan tidak bisa melihat dalam gelap. Bukan ketakutan akan apa yang ada di dalam gelap..."]
	quest.32EBB3D53AA91E09.title: "Night Vision Module"
	quest.32ECD93A8F2FAB8F.quest_desc: ["&6Jetpack&r adalah cara favorit banyak orang untuk bepergian. \\n\\nUntuk mulai membuatnya, kamu butuh &6Wood Jetpack&r! Ini bisa di-upgrade terus sampai ke &5Creative Jetpack&r. \\n\\nMeskipun punya banyak versi, cara kerjanya tetap sama. Semuanya bisa dipasang di slot Chestplate, slot Back Curio, atau Curio biasa. \\n\\nSemuanya juga butuh energi FE untuk bekerja; kamu bisa pakai Item Charger apa pun untuk mengisinya! Energi FE akan terkonsumsi saat terbang, dan ya, kamu akan jatuh jika kehabisan energi. \\nUntuk terbang, kamu perlu menyalakan mesin (Engine - tombol V), lalu saat menahan spasi kamu akan terbang ke atas dan jatuh saat dilepas. \\n\\nBagi yang tidak suka jatuh bebas, kamu bisa menyalakan mode Hover. Saat aktif, kamu akan melayang pada ketinggian yang sama; bisa naik dengan (Spasi) dan turun dengan (Shift). \\n\\nUntuk mengatur kecepatan terbang, ubah Throttle kamu. Tombol standarnya adalah (,) untuk mengurangi dan (.) untuk menambah!"]
	quest.32ECD93A8F2FAB8F.title: "&l&6Iron Jetpacks"
	quest.32FDC5FFA000DAF8.quest_desc: ["Bangga dengan koleksi lebahmu?\\n\\nMau memamerkan mereka di dalam toples?\\n\\nLetakkan Bee Jar dan gunakan Pipa atau Hopper untuk memasukkan lebah yang ada di dalam kandang ke dalam toples."]
	quest.32FDC5FFA000DAF8.quest_subtitle: "Memamerkan Lebah"
	quest.33105698C75093C2.quest_desc: ["&4Mega Destructor&r memiliki 54 slot filter, bekerja 8x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.33105698C75093C2.title: "&4Mega Destructor"
	quest.33106E24A3B5DDD8.quest_desc: [
		"Langkah selanjutnya dalam perjalananmu adalah menemukan &eIesnium Ore&r di Nether."
		""
		"Tanpa efek &3Third Eye&r, bijih ini akan terlihat persis seperti Netherrack. Pastikan kamu memakai &dOtherworld Goggles&r!"
		""
		"Untuk melacak bijihnya, coba gunakan &aDivination Rod&r. Kamu harus menyelaraskannya ke Netherrack dulu, lalu tahan klik kanan. Setelah beberapa detik, kamu akan melihat partikel meluncur ke arah Iesnium Ore terdekat. Kamu hanya bisa menambang bijih ini menggunakan &dInfused Pickaxe&r!"
		""
		"Karena kamu tidak bisa menghancurkan bijih ini menjadi dua kali lipat debu dengan metode standar, coba gunakan Foliot Crusher untuk menggandakan ingot per bijih mentah!"
		""
		"Catatan: Jika kamu tidak melihat partikelnya, pastikan pengaturan partikelmu sudah dinyalakan!"
		""
		"{image:atm:textures/questpics/occultism/iesniumexample.png width:200 height:175 align:1}"
	]
	quest.33106E24A3B5DDD8.title: "&cIesnium: Bijih dari Otherworld"
	quest.3314FBC4FEAE1D08.quest_desc: ["&6Penyebar&r adalah &6Mesin&r yang sangat menyenangkan untuk mencolok-colok! \\n\\nMencolok yang kumaksud adalah &eInteraksi Item&r yang bisa kita lakukan. Taruh &eItem&r di &6Tangan Penyebar&r, lalu beri &dTenaga Rotasi&r. Ia kemudian akan menempatkan &eItem&r tersebut ke Blok di &ePenampang&f atau &eSabuk&r di bawahnya. \\n\\nIni akan meniru banyak tindakan yang bisa kita lakukan sendiri, seperti menambahkan &6Lilin&r ke &cTembaga&r. \\n\\nKemungkinan besar kamu akan sering menggunakannya untuk Casing &8Andesit&r/&cTembaga&r/&eKuningan&r dan &4Kuarsa Mawar Dipoles&r."]
	quest.3314FBC4FEAE1D08.quest_subtitle: "Colok"
	quest.3314FBC4FEAE1D08.title: "&6Penyebar"
	quest.3331EBE1BB4BF64D.quest_desc: ["Reaktor Nuklir bisa cukup serem buat sebagian orang terutama sama efek berbahayanya! \\n\\nUntungnya satu-satunya yang serem dari &a&lExtreme Reactors&r adalah betapa membingungkannya ngikutin resep-resepnya! \\n\\nBukan bagian meledaknya mereka gak ngelakuin itu."]
	quest.3331EBE1BB4BF64D.title: "&a&lExtreme Reactors"
	quest.3334D15766A47A46.quest_desc: ["Menggunakan Laser Assembly Program, kamu bisa mempercepat produksi &3Unassembled PCB&r. Cukup taruh Empty PCB di peti input, alirkan tekanan udara, dan tunggu."]
	quest.3334D15766A47A46.title: "Otomatisasi PCB"
	quest.333682022948E2F3.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_thioquartz.png width:100 height:150 align:center}"]
	quest.333682022948E2F3.title: "&2Thioquartz&r"
	quest.3339445194568D77.title: "&2Peralatan Prudentium"
	quest.33415CB421F7620A.quest_desc: ["&b&lPurification Chamber&r itu secara teknis adalah upgrade dari &d&lEnrichment Chamber&r. Yah... dia kehilangan banyak fungsi tapi dia meng-upgrade &lOre Processing&r-mu! \\n\\nCuma itu aja sih fungsinya, dia gabungin &7Ore&r sama &bOxygen&r buat dapat lebih banyak Ingot! \\n\\nYah... dia nggak langsung bikin &7Ingot&r sih tapi bikin &7Clump&r... ya sudahlah baca aja Quest &lOre Processing&r buat tahu lebih lanjut soal itu!"]
	quest.33415CB421F7620A.title: "&b&lPurification Chamber"
	quest.33422FBDAE11AE82.quest_subtitle: "Berikan sebuah Fluix Pearl ke Spatial Bee"
	quest.33422FBDAE11AE82.title: "Fluix Bee"
	quest.33433A443B65D252.quest_desc: [
		"&bAir&r=&bBiru&r &bAir&r=&bFluid&r maka dari itu &bBiru&r=&bFluid&r\\n\\nBanyak Mod memiliki &bCairan&r-nya sendiri, bahkan Minecraft juga punya, yaitu &bAir&r dan &cLava&r. Kamu kemungkinan besar perlu memindahkan &bCairan&r tersebut dan cara yang baik untuk melakukannya adalah dengan &bFluid Pipez&r. \\n\\nIni bisa dihubungkan ke Sink untuk memindahkan &bAir&r tak terbatas!"
		"{image:atm:textures/questpics/logistics/pipez_fluid.png width:200 height:50 align:center}"
	]
	quest.33433A443B65D252.title: "&bFluid Pipez"
	quest.33436ED0D9F128BD.quest_desc: ["&4Augment&r: Smoking ngubah Iron Furnace-mu jadi Iron Smoker. Sekarang cuma bakal smoke item Makanan tapi dua kali lebih cepat! Kayak &4Augment&r: Blasting yang satu ini juga nge-stack sama upgrade lain!"]
	quest.33436ED0D9F128BD.title: "&4Augment&r: Smoking"
	quest.3347CB6478F486C6.quest_subtitle: "Cell Workbench Kemana-mana"
	quest.33532408B21A5378.quest_desc: ["Pitiful Generator menghasilkan sedikit FE menggunakan fuel yang bisa dibakar seperti Coal."]
	quest.3365017C9B24C0A9.quest_desc: ["Gunakan Busur atau Crossbow untuk menembakkan 32 Stinger. \\n\\nYa, kamu bisa melakukan itu!"]
	quest.33682F4B44950123.quest_desc: ["Untuk memperdalam pengetahuan tentang mantra, kita butuh jenis kayu ajaib tertentu! \\n\\nPohon Archwood dapat ditemukan di Overworld."]
	quest.3371570F189DF994.quest_desc: ["&6Scepter of Fortification&r memanggil perisai di sekelilingmu untuk perlindungan.\\n\\nUntuk mengisinya kembali, gabungkan dengan &6Apel Emas (Golden Apple)&r di meja crafting."]
	quest.3371570F189DF994.quest_subtitle: "Memanggil Perisai"
	quest.3371570F189DF994.title: "&6Scepter of Fortification"
	quest.3371F9248D403664.title: "&l&cThe Nether Bounty:&r&e Wither Skeletons"
	quest.33732EE8110A0911.quest_desc: ["Dev &8&lIE&r lupa &4&lBor Pertambangan&r juga bisa digunakan untuk Menambang jadi menit terakhir dia memasukkan Fortune III. \\n\\nItu adalah Asam Pelembut Batu."]
	quest.33816AF0E699F19F.quest_desc: ["Blok ini akan menyedot energi FE dari item apa pun yang terisi daya."]
	quest.3384308C78D86059.quest_subtitle: "Tingkat: &a2"
	quest.33882172DA8021F6.quest_desc: ["Menjaga agar item di inventaris pemain tetap penuh dengan mengambil item dari dalam Tas."]
	quest.338BD467EBE6EE1F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_sentry.png width:100 height:150 align:center}"]
	quest.338BD467EBE6EE1F.quest_subtitle: "Pillager Outpost"
	quest.338BD467EBE6EE1F.title: "Sentry Armor Trim"
	quest.339384ADC9CDB944.title: "Pengetahuan"
	quest.33977CEF056F0A13.quest_subtitle: "Alder + Rowan"
	quest.339DF320DDCAD98B.title: "Item \\& Fluid Transport"
	quest.33A0E06FE5CFD8F3.quest_desc: ["&9Centrifuge&r digunakan untuk memproses sarang (combs) dari lebah menjadi item berguna dan madu! Walau bisa pakai yang biasa di awal, upgrade ke &6Powered Centrifuge&r (pakai energi) sangatlah wajib. \\n\\nUntuk performa terbaik, &cHeated Centrifuge&r jauh lebih cepat karena ia memproses &aComb Block&r sekaligus, bukan sarang satuan!"]
	quest.33A0E06FE5CFD8F3.quest_subtitle: "Memproses Sarang Madu"
	quest.33AADC1B97E9F7A9.quest_desc: ["Minecart with Chest adalah kereta tambang dengan peti di dalamnya. Kamu tidak bisa menaikinya, tapi sangat berguna untuk transportasi item melalui sistem rel."]
	quest.33ADE41526C39AFD.quest_desc: ["Item ini memiliki fungsi yang sama dengan laci Functional Storage, membantu dalam mengelola bagaimana item didistribusikan dalam penyimpanan digital."]
	quest.33ADE41526C39AFD.title: "Penyimpanan Terdistribusi"
	quest.33B1D3FD4C0B5514.quest_desc: [
		"&e&lAncient Remnant&r adalah penguasa wilayah &ePasir&r. \\n\\nIa punya 3.600 &4HP&r dan dibantu oleh &eWadjet&r serta &eKobolediator&r. \\n\\nIa punya beberapa jurus! Ia bisa mengibaskan ekor tulangnya, menggigitmu, atau menghentakkan kaki ke tanah untuk memicu Shockwave. \\n\\nIa juga bisa memanggil &eSandstorm&r dengan RAUNGAN yang dahsyat dan bahkan menjatuhkan &eSand Trap&r di kepalamu. \\n\\nSerangan lain untuk mendekatimu adalah serudukannya. Serudukannya akan melukaimu dan juga FPS-mu karena ia menghancurkan setiap blok di jalurnya. \\n\\nIa punya kelemahan, yaitu benda yang membangkitkannya! Jika kamu memukul &eNecklace&r-nya, ia akan terjatuh sementara, memberimu kesempatan sempurna untuk menghajarnya dan mengembalikannya ke liang kubur!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_remnant.png width:100 height:100 align:center}"
	]
	quest.33B1D3FD4C0B5514.title: "&e&lAncient Remnant&r"
	quest.33C69B5934BE4D64.quest_desc: ["&bMechanical Pipes&r bakal mindahin &bCairan&r. Bener banget! Nggak cuma &9Air&r aja! \\n\\n&bMechanical Pipes&r dibuat pakai 2 &8Steel Ingot&r dan 1 &7Empty Bucket&r. Cara upgrade-nya juga sama kayak &eLogistical Transporters&r. \\n\\n&a&lBasic&r: nampung 2 Bucket cairan dan pindahin 250mB cairan tiap Tick. \\n\\n&c&lAdvanced&r: nampung 8 Bucket cairan dan pindahin se-Bucket cairan tiap Tick. \\n\\n&b&lElite&r: nampung 32 Bucket cairan dan pindahin 8 Bucket tiap Tick. \\n\\n&d&lUltimate&r: nampung 128 Bucket dan pindahin 32 Bucket tiap Tick."]
	quest.33C69B5934BE4D64.quest_subtitle: "Cairan"
	quest.33C69B5934BE4D64.title: "&bMechanical Pipes"
	quest.33D23C65E7274A8F.quest_desc: ["Buat membangunkan Supremium Essence kamu, kamu harus bikin Altar baru dan 4 Pedestal baru, plus 4 &cEssence Vessel&r.\\n\\nEssence Vessel butuh starter Element Essence buat ngisi: Api, Air, Tanah, dan Udara."]
	quest.33D23C65E7274A8F.title: "&dKebangkitan&r"
	quest.33D2901594655A77.title: "Chaotic Area-Of-Effect Module"
	quest.33F4A7613764A016.quest_desc: ["Kerjanya seperti Importer, cuma ini export."]
	quest.33F4A7613764A016.quest_subtitle: "Exporting"
	quest.3403D7502F7BC897.quest_desc: ["Benar-benar tak terkalahkan, tidak ada yang bisa melukaimu. \\n\\nSaat ini kamu perlu meng-upgrade &cNetherite Armor&r dengan sebuah &eQuantum &bUpgrade&r, tapi teman-temanmu di &6&lTim ATM&r sedang berusaha membuat resepnya jadi lebih susah! \\n\\nDan kamu nggak bisa melakukan apa pun untuk menghentikannya! &lBWAHAHAHAHA"]
	quest.3403D7502F7BC897.quest_subtitle: "Tak Terkalahkan"
	quest.3403D7502F7BC897.title: "&eQuantum &bArmor&r (&l&7MI&r)"
	quest.340CDF4357E22A43.quest_desc: ["Iron udah ngeberkatin kita sama Mod Eksplorasi dan Sihir yang seru banget! Bertarung dengan dan untuk Sihir! Gak ada yang lebih keren dari itu! \\n\\nIni punya Quest Page yang kamu harusnya berterima kasih buat. "]
	quest.340CDF4357E22A43.title: "&e&lIron's Spells and Spellbooks"
	quest.340F93695FFF8D76.quest_desc: ["Dengan ini &b&lPelempar Kimia&r akan lebih seperti Penembak Kimia. \\n\\nJangkauan akan meningkat tetapi lebar semprot akan berkurang. Jadi lebih akurat!"]
	quest.341486C9F277FEB7.title: "Reaktor (Spirited)"
	quest.3416DB9F58D8AA2C.quest_desc: ["&3Neptunium&r adalah hadiah dari Neptune's Bounty yang didapat melalui memancing! \\nArmor ini memberikan buff saat berada di dalam air."]
	quest.3416DB9F58D8AA2C.quest_subtitle: "28"
	quest.3416DB9F58D8AA2C.title: "&3Neptunium Armor"
	quest.341BB1353A1E45EA.quest_desc: ["Menara Senjata akan bertindak sebagai &d&lRevolver&r dengan otak Komputer! \\n\\nMereka memerlukan &cEnergi&r dari bawahnya, dan &4Sinyal Redstone&r untuk menyala. Atau gunakan &6Obeng Insinyur&r untuk membuatnya selalu menyala. \\n\\nMenggunakan Ammo yang sama dengan &d&lRevolver&r, termasuk Proyektil Khusus! Bisa &9Memasukkan&r Peluru dan &6Mengeluarkan&r Selongsong, atau menjatuhkannya dengan Tombol Keluarkan Selongsong. \\n\\nSebelum mulai menembak, perlu mengatur targetingnya. Pertama, tidak akan menyerang orang yang menempatkannya. Kita juga memiliki Bilah Jenis yang bisa menambahkan nama Pemain atau Mob untuk Ditambahkan. Ini akan membuatnya mengampuni mereka! \\n\\nSecara otomatis diatur ke Daftar Hitam, jika Daftar Hitam berarti akan Menembak apa yang terdaftar. Kemudian kita memiliki Hewan yang berarti Mob Pasif. Pemain berarti hanya Pemain. Netral berarti Mob Netral dan Penduduk Desa. Jangan khawatir selalu menargetkan Mob Bermusuhan!"]
	quest.341DF467E3936E78.quest_desc: ["Kalahkan &dEnder Dragon&r sambil memakai set lengkap Armor &8L&6e&8b&6a&6h&r! \\n\\nNamamu akan dikenang selama berabad-abad!"]
	quest.342D1FA0BCBB847A.quest_subtitle: "Tingkat: &b4"
	quest.342EEB042DEC2B8C.quest_desc: ["Magma dan Geyser sama-sama spawn di dasar The Abyss. \\n\\nMagma bakal bantu kamu turun ke bawah dan bantu jaga nafas kamu. \\n\\nGeyser cuma keliatan keren!"]
	quest.3446803FB59D8875.quest_desc: ["Memberimu efek Thorns. Bukan di armor, tapi di badanmu sendiri! Kayak ikan buntal!"]
	quest.3446803FB59D8875.quest_subtitle: "Kalung"
	quest.3446803FB59D8875.title: "&aThorn Pendant&r"
	quest.3458F19FB41C7F0E.quest_subtitle: "Red Crepe Myrtle + Luck"
	quest.3459CAEB59CBD60E.quest_desc: ["Sepertinya kali ini ada yang menyalakan saklarnya! \\n\\n&4The Prowler&r adalah mini-bos yang menjaga &4Ancient Factory&r. Ia punya 640 &4HP&r. \\n\\nIa punya 3 jenis serangan: Gergaji untuk musuh jarak dekat, Rudal Bahu untuk musuh yang jauh (mirip WASW), dan Laser dari matanya. \\n\\nSaat mati ia menjatuhkan Redstone dan Besi. \\n(Tips: Ia juga lemah terhadap serangan EMP)"]
	quest.3459CAEB59CBD60E.title: "&4The Prowler&r"
	quest.3466C70EB256026B.quest_subtitle: "Dibuat dengan Enchanting Apparatus"
	quest.3466C70EB256026B.title: "Fire Essence Bee"
	quest.346860B8EBC4C28C.quest_desc: ["Sekarang punya semua lava ini mau diapakan? Power early game lagi! "]
	quest.346860B8EBC4C28C.title: "Lava Power"
	quest.346B9339E3D66478.quest_desc: ["Energi adalah sesuatu yang digunakan hampir oleh segalanya, jadi kamu perlu mengirimnya ke mana-mana. Untungnya Energy Module akan membantu hal itu! \\n\\nEnergy Module akan memindahkan energi apa pun yang masuk ke dalamnya ke tempat lain yang sudah kamu tentukan!"]
	quest.3497C2E05DF5A87C.quest_desc: ["&cRedstone&r, &9Lapis&r, Quartz, &5Amethyst&r, &aEmerald&r, dan &bDiamond&r semuanya adalah permata berharga. \\n\\nJadi tentu saja kita akan mengubahnya menjadi blok, blok berharga yang sangat cantik tepatnya!"]
	quest.3497C2E05DF5A87C.title: "Blok Permata &l&bChipped&r"
	quest.349D19F2FCC34B84.quest_desc: ["Meletakkan Nether Brick Nest di Nether akan memancing Magmatic Bee saat diberikan Magma Cream."]
	quest.349D19F2FCC34B84.quest_subtitle: "Memancing Magmatic Bee saat diletakkan di Nether"
	quest.34ABEF75AE1E5A0F.quest_desc: ["Staff of Ancient Knowledge menggunakan Aura untuk menyoroti &5Ancient Debris&r di sekitar."]
	quest.34ABEF75AE1E5A0F.quest_subtitle: "Pencari Netherite"
	quest.34CD54347E9821B5.quest_desc: ["Setelah membuat Data Model pertama, perlu di-level up agar berguna.\\n\\nData Model dimulai dari tier pertama: &7Faulty&r. Perlu setidaknya di-level ke &aBasic&r kalau ingin menjalankan simulasi!\\n\\nSetelah dimasukkan ke Deep Learner, HUD akan menunjukkan berapa kill yang dibutuhkan untuk level up. Info ini juga bisa dilihat di tooltip Model itu sendiri."]
	quest.34CD54347E9821B5.title: "Meningkatkan Level Data Model"
	quest.34CFE1439262AA72.quest_desc: [
		"&5&lMekanism&r adalah mod teknologi yang besar dan populer, jadi tentu saja ia menyertakan sistem &lLogistik&r."
		""
		"Mesin-mesinnya sangat pemilih soal Konfigurasi dan harus diubah di dalam GUI-nya agar item bisa berpindah dengan benar. Kemudian kamu bisa menggunakan &5&lPipa Meka&r untuk memindahkan apa pun yang kamu butuhkan!"
		""
		"Tapi tunggu, ini bukan cuma buat &5&lMekanism&r! Pipa ini juga berfungsi untuk banyak mesin lainnya! Hanya perlu dikonfigurasi dengan Wrench untuk Push dan Pull."
		""
		"(Pipa ini bisa menyebabkan sedikit lag jika digunakan dalam jumlah masal, jadi berhati-hatilah)."
	]
	quest.34CFE1439262AA72.title: "&5&lMekanism"
	quest.34D09336FA3E272A.quest_desc: ["Menara Chemthrower memiliki penargetan yang sama persis dengan Menara Senjata jadi periksa di sana untuk info lebih lanjut! \\n\\nSeperti Menara Senjata, Menara Chemthrower memerlukan &cEnergi&r dari portnya. Tapi juga memerlukan &bCairan&r yang Dipompa untuk ditahan dan ditembakkan. &9Masukkan &bCairan&r dengan Pipa karena tidak bisa menggunakan &bEmber&r untuk mengisinya, hanya &bPipa&r. \\n\\nMenara Chemthrower memiliki penyimpanan 4.000mB atau 4 &bEmber&r. Juga bisa menekan Tombol untuk Menyalakan &bCairan&r yang dilempar. Ini akan menyalakan &bCairan&r yang mudah terbakar!"]
	quest.34D14B807A2DAC0F.quest_desc: ["Kamu pikir cuma mod &5&lMekanism&r dan &l&7Modern Industrialization&r yang bisa pamer armor canggih? \\n\\n&5Quantum Armor&r ini punya statistik dasar mirip &cNetherite Armor&r, tapi seperti &aMekaSuit&r, armor ini menggunakan Energi sebagai tameng. \\nKamu juga bisa memasang upgrade agar lebih kuat, seperti kemampuan Terbang, Night Vision, bahkan pengisian daya otomatis. \\n\\nTapi bagian terbaiknya adalah armor ini bisa dihubungkan ke Sistem Penyimpananmu! Jadi kamu bisa menarik Energi dan mengambil item apa pun dari sistem di mana pun kamu berada."]
	quest.34D14B807A2DAC0F.quest_subtitle: "Sebanyak energi yang bisa kamu suplai"
	quest.34D14B807A2DAC0F.title: "&5Quantum Armor&r (&l&bAE2&r)"
	quest.34D3F6D54F5B26C2.quest_desc: ["Hoe yang di-upgrade, jadi akan jadi wanita baik dan cantik?"]
	quest.34D3F6D54F5B26C2.title: "Draconic Hoe"
	quest.34DACB973CBDE129.quest_desc: ["Gunakan Force-nya! \\n\\nIni &a&lStaff&r seru lainnya, bisa dipakai untuk melempar Entity! Termasuk diri sendiri! \\n\\nTahan Right Click pada apa yang ingin dilempar, kalau diri sendiri bidik ke tanah. Lalu, gerakkan Mouse ke arah yang diinginkan untuk lemparan! \\n\\nSemakin lama ditahan semakin kuat lemparannya! Setelah beberapa saat akan maksimal dan melempar."]
	quest.34DACB973CBDE129.title: "&a&lSpatial Disorientation"
	quest.34F7325C2AFA6DA7.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.34FBD04361657724.quest_desc: [
		"Di sepanjang ExtendedAE, kamu bakal sering pakai &aEntro Crystal &rsebagai resource."
		""
		"Buat dapet &aEntro Crystal&r, kamu butuh Fluix Block dan Entro Seed. Klik kanan Fluix Block pakai Entro Seed."
		""
		"Ini akan bikin &aBudding Entroized Fluix&r, yang mirip Budding Certus Quartz, bakal tumbuh Entro Bud di sekitarnya. Beda sama Certus, decay-nya pasti terjadi."
		""
		"&aBudding Entroized Fluix&r selalu drop &lsatu &r&aEntro Dust&r kalau dipecah, apapun kondisinya. Entro Bud drop Entro Shard kalau belum tumbuh penuh."
	]
	quest.34FBD04361657724.quest_subtitle: "jangan disamain sama time crystal"
	quest.34FBD04361657724.title: "Crystal Ruang dan Waktu: Entro Crystal"
	quest.34FC02F47F52887F.quest_desc: ["&eSpellbook&r ini pasti membuatmu bekerja keras untuk 12 &3Spell Slot&r! \\n\\nKamu butuh &bIce Venom Vial&r, yang dibuat dari &bIcy Fang&r atau Loot dari &bIce Spider Den&r. \\n\\n&5Arcane Cloth&r yang sangat mudah dibuat. Serta &bMithril Scrap&r yang harus kamu Tambang! \\n\\nDilihat dari seberapa dingin &eSpellbook&r terasa, aku pikir ini membantu dengan &bIce Spell&r."]
	quest.34FC02F47F52887F.title: "&bFrostbanded Spellbook"
	quest.351159C55159C316.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_spire.png width:100 height:150 align:center}"]
	quest.351159C55159C316.quest_subtitle: "End City dan End Ships"
	quest.351159C55159C316.title: "Spire Armor Trim"
	quest.3512A883CD4E007C.quest_subtitle: "Bull Pine + Spruce"
	quest.3512F47DADC07EAE.quest_desc: ["&5Unobtainium Armor&r tapi dengan buff untuk mantra &d&lArs Nouveau&r!"]
	quest.3512F47DADC07EAE.quest_subtitle: "40"
	quest.3512F47DADC07EAE.title: "&5Unobtainium Arcanist Gear"
	quest.3514E9C1A8C7400C.quest_subtitle: "Tier: &b2"
	quest.3514E9C1A8C7400C.title: "&bSimple Machine Frame"
	quest.351769579833FA9E.title: "Bersantai dengan Para Lebah"
	quest.3525D5DCC3A534D9.quest_desc: ["Nah, ini salah satu favoritku! \\n\\n&9Digging Claws&r akan: 1. Meningkatkan kecepatan menambang, kayak dapet efek Efficiency di semua Pickaxe, dan 2. Bikin tinjumu berfungsi kayak Stone Pickaxe! \\n\\nSangat membantu buat bangun-bangun atau sekadar main biasa!"]
	quest.3525D5DCC3A534D9.quest_subtitle: "Tangan"
	quest.3525D5DCC3A534D9.title: "&9Digging Claws&r"
	quest.3526D444F81AD6D9.quest_desc: ["&dMeka-Tool&r udah ngasih Damage lebih banyak dari &6AllTheModium Sword&r, tapi kenapa gak ditambahin dikit lagi! \\n\\nGue gak bisa bilang berapa banyak tambahan yang dikasih tiap &7Unit&r, tapi pasti nambah makin banyak yang ditambah. \\n\\nPersis kayak Sharpness!"]
	quest.3526D444F81AD6D9.quest_subtitle: "Meka-Tool"
	quest.3526D444F81AD6D9.title: "&4Attack Amplification &7Unit"
	quest.352A226915809E1B.quest_desc: ["&#A57DE3Packer&r sekarang memungkinkan kita menggabungkan &#7DD2E3Stainless Steel&r, &#B37DE3Tungsten&r, dan &#E37DDBTitanium Ingot&r menjadi &#3946E3Mixed Blastproof Ingot&r yang baru."]
	quest.3531B28F14CF72A2.quest_desc: ["Bos pertama yang harus kamu bunuh dalam petualanganmu di &9Twilight Forest&r dapat ditemukan di dalam Courtyard.\\n\\n&2Naga&r adalah ular hijau yang terdiri dari beberapa segmen; seiring kamu memberikan damage, segmen tubuhnya akan menghilang.\\n\\nMembunuh &2Naga&r akan menjatuhkan item bagus dan memberimu izin masuk ke rumah bos berikutnya, sang Lich."]
	quest.3531B28F14CF72A2.title: "&2Menyamakan Kedudukan"
	quest.353AEEC116A5DEEF.quest_desc: [
		"Ancient Sea adalah lautan luas yang terbuka di &2&lUndergarden&r. \\n\\nEntah bagaimana meski banyak polutan, airnya aman untuk diminum. \\n\\nAirnya juga menjadi rumah bagi &bGwib&r dan &bGwibling&r. Dan jangan lupakan Glitterkelp!"
		"{image:atm:textures/questpics/undergarden/undergarden_ancient.png width:200 height:100 align:center}"
	]
	quest.353AEEC116A5DEEF.title: "Ancient Sea"
	quest.354086C858E10154.quest_desc: [
		"Sekarang kita punya Cyanite dari baby reactor, kita mau cara buat reprocess waste itu jadi sesuatu yang berguna."
		""
		"Buat ini, kita perlu bangun multiblock lain: &aReprocessor&r."
		""
		"Ini butuh banyak Cyanite, jadi mulai stock up! Kamu mungkin juga mau upgrade ke reactor lebih besar. "
	]
	quest.354086C858E10154.title: "Reprocess Waste Kita"
	quest.3543563DF036D461.quest_desc: ["Untuk menciptakan Dragonyst Dust, kamu perlu melakukan ritual &9Uphyxes' Inverted Tower&r. Namun, untuk membuat Magenta Chalk, kamu juga butuh beberapa material yang hanya bisa didapat melalui &9Marid Crusher&r."]
	quest.3543563DF036D461.title: "&#AD00C8Magenta Chalk (Kapur Magenta)"
	quest.355244420EA47546.quest_desc: ["Fabricator adalah alat Auto-Crafter. Ia akan mengambil item dari inventaris di bawahnya dan membuat resep yang telah ditentukan.\\n\\nKamu bisa mengunci resep dengan CTRL + Klik. Kamu tetap perlu memindahkan item hasil crafting keluar menggunakan pipa."]
	quest.355244420EA47546.quest_subtitle: "Auto-Crafter"
	quest.356102D5B5F3CA1E.quest_desc: ["Alloy yang ditambah &6&lForbidden \\& Arcanus&r adalah &5Obsidiansteel&r. \\n\\nDibuat di &l&bClibano&r, dengan gabungin Raw Iron dan &5Obsidian&r. \\n\\nKamu butuh Artisan Relic untuk bisa bikin Alloy-nya! \\n\\nJuga kamu dapet &6Copper&r sebagai residue, yang mungkin gak seharusnya terjadi..."]
	quest.356102D5B5F3CA1E.title: "&5Obsidiansteel&r"
	quest.3561A33758A1E8C3.quest_desc: [
		"Pertama, kita bangun. Kedua, kita nyalain. Ketiga, kita pake. \\n\\nSemua sisi &c&lFusion Reactor&r pake bentuk Diamond 5 Blok. Frame-nya bakal dibuat dari &cFusion Reactor Casing&r dan dalemnya bisa dibuat dari Reactor Glass&r. \\n\\n&cFusion Reactor Port&r bisa ganti Blok Reactor Glass manapun di Struktur (selain di mana Blok lain dibutuhin) \\n\\n&cLaser Focus Matrix&r juga bakal ditaro di mana Reactor Glass berada. Mudah-mudahan gak terlalu deket sama Blok lain! \\n\\n&cFusion Reactor Controller&r, Blok paling penting, bakal ditaro di tengah persegi layer atas. \\n\\nTenang dalemnya bakal kosong... Gue gak saranin lo cek pas lagi nyala, itu bakal bunuh lo. "
		"{@pagebreak}"
		"BOOM! Udah jadi! Sekarang gimana cara nyalainnya? \\n\\nPertama, ambil &eHohlraum&r lo, yang harusnya udah diisi! Terus taro di GUI &c&lFusion Reactor&r. \\n\\nKita bisa buka GUI-nya dengan Klik Kanan &cController&r yang udah fully built. \\n\\nSekarang selain &eHohlraum&r yang udah diisi kita perlu masukin Fuel! \\n\\nTerus, kita bisa blast &4Laser Amplifier&r dengan minimal 1GFE, ke &cLaser Focus Matrix&r. \\n\\nSekarang udah siap dipake! "
		"{@pagebreak}"
		"Kebanyakan penggunaannya lewat &cController&r. Pertama, kita dapet menu utama. Ini cuma buat slot &eHohlraum&r, sama kasih tau lo kalo udah dibangun dengan bener! \\n\\nSelanjutnya, adalah menu Heat. Ini buat seberapa Panas &6Temperature&r di &c&lFusion Reactor&r. Ini nentuin jumlah &aEnergi&r atau Steam yang dibuat! Dan ditentuin sama &4Laser Amplifier&r yang ditembak ke dalamnya, sama kalo didinginkan. \\n\\nKita bisa ganti Unit &6Temperature&r atau bahkan &aEnergi&r dengan Tombol di bawah! \\n\\nMenu selanjutnya, buat Fuel! Bakal nunjukin berapa banyak &cDeuterium&r, &aTritium&r, sama &5D-T Fuel&r di dalam &c&lFusion Reactor&r. Kita juga bisa ganti Inject Rate, berapa banyak Fuel yang dipake tiap Tick. \\n\\nMenu Stats nunjukin banyak angka fancy! Itu cuma penting buat orang pinter jadi kita gak bakal fokus ke sana!"
		"{@pagebreak}"
		"(placeholder text halaman baru)"
		"{image:atm:textures/questpics/mek/mek_fusion1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion2.png width:110 height:90 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion3.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion4.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fusion5.png width:100 height:100 align:center}"
	]
	quest.3561A33758A1E8C3.quest_subtitle: "Gabungin 2 Elemen jadi 1"
	quest.3561A33758A1E8C3.title: "&c&lFusion Reactor"
	quest.35629CB10DBDE340.quest_desc: [
		"&6Ancient Temple&r adalah Struktur penting dan diperlukan yang ditemukan di &9Deeplands&r. \\n\\nTerlihat seperti Piramida Maya terbuat dari &8Deepslate &fdan &3Sculk&r. Ada banyak &3Sculk Sensors &fdan &3Shriekers&r serta Chest dan Ancient Vases. \\n\\nDi lantai atas kamu akan menemukan kebanyakan hanya Chest dan Ancient Vases tapi di dalam &6Pyramid&r kita akan menemukan bahkan &eBlocks of Gold&r dan Material lainnya."
		"{image:atm:textures/questpics/deepndark/dnd_temple.png width:200 height:100 align:center}"
	]
	quest.35629CB10DBDE340.quest_subtitle: "Satu-satunya struktur"
	quest.35629CB10DBDE340.title: "&6Ancient Temples"
	quest.3567306F2B66BD20.quest_subtitle: "Infusion Crafting"
	quest.3567306F2B66BD20.title: "Imperium Bee"
	quest.35767977FB9E0B1B.quest_desc: [
		"Tier 2 butuh 6 Draconium Ingot Blocks, 1 di setiap sisi Core. Lalu, jelas 4 Stabilizers untuk dibuat."
		"{image:atm:textures/questpics/draconic/draconic_core_2off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_2on.png width:100 height:100 align:1}"
	]
	quest.35767977FB9E0B1B.quest_subtitle: "Menyimpan: 273,000,000 RF"
	quest.35767977FB9E0B1B.title: "Tier 2"
	quest.357DDE894EB512F7.quest_desc: ["&#65C2A6Wiremill&r mampu memberikan tekanan yang pas untuk membuat &#53E67BKabel (Wire)&r bagi kita. Mengejutkan, bukan? Aku tahu..."]
	quest.358D4F507521075F.quest_desc: [
		"&eSarang&r di dalam &eSarang&r, &eHive&r-ception.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_shrine.png width:200 height:100 align:center}"
	]
	quest.358D4F507521075F.title: "Kuil &eHive&r"
	quest.359934E888495E5E.quest_desc: ["Ini bukan Mesin Cuci, ini &a&lChemical Washer Multiblock&r. \\n\\nBuat makenya lo butuh Hatch buat Input &aEnergi&r, &bFluid&r, sama &cChemical&r. Juga buat Output &cChemical&r. \\n\\nTinggal gabungin &9Air&r sama Dirty Ore Slurry. Entah kenapa kita mulai dengan 1,000mB Dirty Ore Slurry dan berakhir dengan 800mB Clean Ore Slurry... ke mana sisanya?"]
	quest.359934E888495E5E.title: "&a&lChemical Washer Multiblock"
	quest.35A674E2C6F66673.title: "Chaotic Projectile Accuracy Module"
	quest.35A78E04092767AD.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Panah Ramuan"
		"- Percikan"
		"- Berkelanjutan"
		"- Panah Pelacak"
	]
	quest.35ABB0DEE70DF7FD.quest_desc: ["Percaya atau tidak, mod &aPowah&r memiliki opsi hebat untuk mendapatkan... tenaga (power).\\n\\nPastikan untuk mengecek bab quest &cPowah&r untuk mempelajari lebih lanjut!"]
	quest.35ABB0DEE70DF7FD.title: "Lebih Banyak &aPowah&r!"
	quest.35C46E6E27C9CB1A.quest_desc: ["10 Batang Kayu &2Vanilla&r itu luar biasa, tapi desainnya cuma segitu-gitu saja! \\n\\nJadi tentu saja &l&bChipped&r ikut membantu dengan menambahkan lusinan desain baru untuk batang kayu tersebut!"]
	quest.35C46E6E27C9CB1A.title: "Batang Kayu &l&bChipped&r"
	quest.35CC898E0E49FE58.quest_desc: ["&9Flux Networks&r adalah mod yang bertujuan menjadi solusi untuk semua kebutuhan daya nirkabelmu.\\n\\nMod ini sendiri tidak memiliki cara untuk menghasilkan daya, tetapi dapat menyimpan dan mengirimkan daya secara nirkabel, bahkan lintas dimensi. Mod ini bahkan bisa mengisi daya item di inventarismu.\\n\\nKamu bahkan bisa mengisi daya Jetpack saat sedang terbang.\\n\\nUntuk memulai, kamu butuh Flux Dust. Pergilah ke Bedrock, lalu lempar Redstone ke atas Bedrock. Letakkan Obsidian tepat di atas Redstone yang melayang tersebut, lalu klik kiri pada Obsidian."]
	quest.35CC898E0E49FE58.quest_subtitle: "Solusi Daya Nirkabel Terbaik"
	quest.35CC898E0E49FE58.title: "&8Flux Networks"
	quest.35D9CD19EAADED6C.quest_desc: ["Lo tau &aRadiasi&r itu bisa mematikan! Dan semua orang bikin kesalahan. \\n\\nTapi pertanyaannya tetep, lo lebih pilih pake &6Hazmat Suit&r yang stylish tapi lemah banget atau... &a&lMekaSuit&r yang super kuat dengan &aRadiation Shielding &7Unit&r! \\n\\nKalo semua &a&lMekaSuit Part&r punya &aRadiation Shielding &7Unit&r yang diinstall, lo bisa jalan dengan aman di sekitar &aRadiasi&r!"]
	quest.35D9CD19EAADED6C.quest_subtitle: "Semua Armor"
	quest.35D9CD19EAADED6C.title: "&aRadiation Shielding &7Unit"
	quest.35E399D88D2EDCB6.quest_desc: ["Dengan Upgrade ini, setiap orang yang menyerang akan 1. terpukau yang akan menghentikan mereka sebentar 2. melukai mereka dan 3. menghancurkan Proyektil apa pun. \\n\\nMenurut sepadan dengan Upgrade!"]
	quest.35E399D88D2EDCB6.quest_subtitle: "Clash?"
	quest.35E42F7925CA097A.quest_desc: ["&dVoid Core&r dijatuhkan oleh &dEnder Golem&r! \\n\\nIni adalah senjata; saat Klik Kanan, &dVoid Rune&r akan muncul dari tanah. \\n\\n&dVoid Rune&r bertindak seperti gigi Evoker, muncul berbaris sepanjang 10 blok ke arah yang kamu gunakan. \\n\\nMemberikan damage sekitar 3 setengah &4HP&r setiap kali mengenai mob. Mereka juga memberikan efek knockback yang tidak dimiliki gigi Evoker. \\n\\nBisa digunakan dalam crafting senjata &4&lCataclysm&r lainnya!"]
	quest.35E42F7925CA097A.title: "&dVoid Core"
	quest.35E8F1CC0080E45E.quest_subtitle: "Berikan Diamond Bee sebuah Ruby"
	quest.35E8F1CC0080E45E.title: "RuBee"
	quest.35EAB77C195E594E.quest_subtitle: "Berikan Diamond Bee sebuah Amethyst"
	quest.35EAB77C195E594E.title: "Amethyst Bee"
	quest.35FA55BE8DF49EE8.quest_desc: ["Pakai kekuatan &9Vengeance Spirit&r yang terbunuh, kita bisa pake Blood Infuser buat bikin &dGarmonbozia&r.\\n\\nIni adalah &dPain&r dan &dSorrow&r yang terwujud. Ini juga material crafting high-end buat tool dan item kuat di EvilCraft."]
	quest.35FA55BE8DF49EE8.title: "&dGarmonbozia"
	quest.35FDC436DE07635F.quest_desc: ["&#DB62DEImplosion Compressor&r menggunakan kekuatan ledakan untuk memadukan sumber daya. Ini dapat digunakan untuk mendapatkan &#8762DEMixed Blastproof Alloy Ingot&r yang lebih efisien serta sumber daya berguna lainnya."]
	quest.35FE9C3395491433.quest_subtitle: "Berikan tekanan (Pressurize) pada Telur Spawn Iron Bee"
	quest.35FE9C3395491433.title: "Compressed Iron Bee"
	quest.3601DD545E1D11B4.quest_desc: [
		"Reaksi antara &#DD91EDArgon&r dengan &#83729ESilicon Dust&r dan &#AAA0BAIridium Tiny Dust&r akan menghasilkan &#919191Monocrystalline Silicon&r."
		""
		"&#AAA0BAIridium&r dapat ditemukan sebagai bijih (ore) di Overworld."
	]
	quest.360B150190A5C894.quest_desc: [
		"Satu hal yang bikin kesel banyak pemain modded adalah &5Enchanting&r nggak bisa diotomatisasi penuh! Dan kamu nggak bisa milih &5Enchant&r mana yang dimau, harus hoki-hokian! \\n\\nNah, sekarang kedua masalah itu beres berkat &5&lRunic Enchanter&r. \\n\\nPakainya nggak usah nyentuh &5Enchanting Table&r lagi, tinggal salurin item yang bener, &dSource&r, dan &aXP Fluid&r. \\n\\n&aXP Fluid&r didapat dengan membotolkan &aLiquid XP&r pakai Bottling Machine dari &8&lImmersive Engineering&r, lalu diproses lewat Canning Machine &7&lExtended Industrialization&r. \\n\\nKamu butuh bikin &dInfused Dragon's Breath&r dan &5Mending Book&r buat bikin ulang &6&lATM Star&r!"
		"{@pagebreak}"
		"(&bKarpet Biru Muda&r adalah &bSoul-Touched Deepshelf&r"
		"&5Karpet Ungu&r adalah &5Echoing Sculkshelf&r"
		"&9Karpet Biru&r adalah &9Soul-Touched Sculkshelf&r)"
		"{image:atm:textures/questpics/chap3/creative_enchanter1.png width:125 height:100 align:center}"
		"Dasar dari &5&lRunic Enchanter&r isinya macem-macem! Ada &9Darkstone&r, Bookshelf, &7Rune Blocks&r, dan &bArcane Crystal Blocks&r!"
		"{image:atm:textures/questpics/chap3/creative_enchanter2.png width:125 height:100 align:center}"
		"Kita lanjut dengan cara yang mirip, tinggal ganti &7Rune Blocks&r dan &bArcane Crystal Blocks&r dengan &6Gilded Chiseled Polished Darkstone&r dan &6Darkstone Pillar&r. Yap, kotak-kotak lucu itu adalah bagian atas &6Darkstone Pillar&r!"
		"{image:atm:textures/questpics/chap3/creative_enchanter3.png width:125 height:100 align:center}"
		"Tenang, makin lama makin gampang! Pasang beberapa Bookshelf lagi, tambahkan &6Darkstone Pedestal&r dan sebuah &5Enchanting Table&r."
		"{image:atm:textures/questpics/chap3/creative_enchanter4.png width:125 height:100 align:center}"
		"Bahkan yang ini lebih gampang lagi! Cuma 4 &bSoul Lantern&r di atas Bookshelf terakhir."
		"{image:atm:textures/questpics/chap3/creative_enchanter5.png width:125 height:100 align:center}"
		"Oke, ini kebangetan gampangnya! Tinggal pasang &7Quantum Injector&r satu blok di atas &5Enchanting Table&r."
		"{image:atm:textures/questpics/chap3/creative_enchanter6.png width:150 height:150 align:center}"
		"{image:atm:textures/questpics/chap3/creative_enchanter7.png width:150 height:150 align:center}"
		"Harusnya aku bilang dari tadi, tapi Hatch-nya dipasang di bagian bawah &5&lRunic Enchanter&r... maaf ya!"
	]
	quest.360B150190A5C894.title: "&5&lRunic Enchanter"
	quest.36149E69A8C264E4.quest_desc: ["&bIce Lilies&r adalah Tanaman yang tumbuh di &9Kolam Air&r dalam &bBlooming Caverns&r (Sudah kubilang banyak Tanaman). \\n\\nAda 2 bagian untuk Tanaman ini, &bLily&r dan &bIce Flower&r. &bLily Pad&r adalah yang mengapung di &9Air&r dan memungkinkan kamu berjalan di atasnya. &bIce Flower&r berada di atas &bLily Pad&r dan terlihat cantik!\\n\\nKamu butuh Shears untuk mengambilnya."]
	quest.36149E69A8C264E4.title: "&bIce Lilies"
	quest.361C9D90617E6D38.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_keeper.png width:100 height:150 align:center}"]
	quest.361C9D90617E6D38.quest_subtitle: "Didapat dari barter dengan Gatekeeper"
	quest.361C9D90617E6D38.title: "Keeper Armor Trim"
	quest.361CCBD353D6FF34.quest_desc: [
		"Dengan Komponen Penyimpanan 1k, kamu sekarang bisa membuat 1k ME Item Storage Cell. Kamu mungkin ingin sebagian besar penyimpananmu berupa item, jadi buatlah beberapa &bME Item Storage Cell&f. "
		""
		"ME Item Storage Cell masing-masing dapat menampung hingga 63 jenis item berbeda. Setiap jenis item baru akan memakan sebagian kapasitas cell dalam hitungan byte. Untuk setiap jenis yang sudah ada, 1 'byte' setara dengan 8 item dari jenis tersebut. "
		""
		"Sebagai contoh, 1k Item Storage Cell yang hanya berisi cobblestone dapat menampung hingga 8128 cobblestone (8*1024b - 8b/tipe * 1 tipe). "
		""
		"Jika cell kosong, kamu bisa membongkarnya kembali menjadi komponen dan housing-nya dengan cara berjongkok (sneak) dan klik kanan di udara saat memegang cell tersebut."
	]
	quest.361CCBD353D6FF34.title: "Penyimpanan Item"
	quest.361DFDB1E1352D6B.quest_desc: ["Cari Sugar Cane di dekat air."]
	quest.361DFDB1E1352D6B.title: "Sugar Sugar"
	quest.361EF9E4973E3522.quest_desc: ["&dEnder Armor&r dari mod &e&lIron's Spells&r!"]
	quest.361EF9E4973E3522.quest_subtitle: "20"
	quest.361EF9E4973E3522.title: "&dShadow-Walker Outfit"
	quest.3621155A4138EBCA.quest_desc: [
		"Void Cell perlu di-partition (filter) di Cell Workbench dulu sebelum dipakai. Akan menghapus apapun yang masuk ME system yang cocok filter (asumsi void cell diprioritaskan), atau memadatkan jadi Matter Ball atau Singularity, mirip Matter Condenser."
		""
		"Klik kanan buat buka GUI konfigurasi."
	]
	quest.3621155A4138EBCA.title: "Matter Condenser dalam Cell: Void Cell"
	quest.362F4CFD1B8B12B1.quest_desc: ["Semua makhluk hidup bakal mati di Ether seolah itu Lava. Lucunya kamu bisa masukin ke Bucket! \\n\\nSatu-satunya cara dapetin adalah nemuin di Ether River. \\n\\nKalau Air kena Ether bakal terbentuk Thioquartz Block!"]
	quest.36389696767EFB4E.quest_desc: [
		"Barren Abyss sesuai namanya, sangat gersang... Tidak ada apa pun kecuali Mob Agresif dan Pebble (Kerikil). \\n\\nSecara pribadi, aku lebih memilih mencari kerikil di tempat lain..."
		"{image:atm:textures/questpics/undergarden/undergarden_barren.png width:200 height:100 align:center}"
	]
	quest.36389696767EFB4E.title: "Barren Abyss"
	quest.36541A2179A7E76B.quest_subtitle: "Berikan bijih Benitoite ke BlazBee"
	quest.36541A2179A7E76B.title: "Benitoite Bee"
	quest.365D4B1DC953D406.quest_desc: ["&7Cart&r Dispenser bekerja sesuai namanya. Alat ini bisa mengeluarkan &7Cart&r apa pun ke &6Rel&r di depannya. Membutuhkan sinyal Redstone untuk bekerja."]
	quest.365D4B1DC953D406.title: "Dispenser &7Cart&r"
	quest.366431661CC43A6E.quest_desc: [
		"Quest ini dibuat oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods."
		"Karena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak diperbolehkan untuk digunakan dalam pack publik yang tidak dirilis oleh &6Tim AllTheMods&r, tanpa izin eksplisit."
		""
		""
		""
		"Quest ini sengaja disembunyikan, jika kamu melihat ini, kamu sedang dalam mode editing."
	]
	quest.367E891A50991436.quest_desc: ["Menggunakan &cSevira's Permanent Confinement&r, kita bisa menggabungkan beberapa material Wither dan sedikit Netherite untuk menciptakan tiga Witherite Dust. Dengan ini, kita bisa membuat kasta tertinggi dari Kapur Fondasi, yaitu Black Chalk."]
	quest.367E891A50991436.title: "Black Chalk (Kapur Hitam)"
	quest.36836AD948F96B9F.quest_desc: [
		"Pipa yang paling simpel dari yang tersimpel, yaitu &eItem Pipe&r. \\n\\nIa akan memindahkan Item dari satu Inventaris ke yang lainnya. Bisa dari satu Peti ke yang lain, dari Kebun ke Sistem, atau bahkan dari Quarry ke Smelter. \\n\\nSangat mudah, cukup hubungkan &ePipez&r ke tempat yang ingin dipindahkan, dan gunakan Wrench untuk mengatur sisi mana yang Menarik (Pull). "
		"{image:atm:textures/questpics/logistics/pipez_item.png width:200 height:50 align:center}"
	]
	quest.36836AD948F96B9F.title: "&eItem Pipez"
	quest.3685B52446DEC809.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_gold.png width:100 height:150 align:center}"]
	quest.3685B52446DEC809.title: "&eGold&r"
	quest.36926B5EBFF6E55A.quest_desc: [
		"&cMercury&r adalah salah satu material terpenting dalam &l&6Theurgy&r! \\n\\nUntuk mendapatkannya, kita harus melakukan distilasi di &cMercury&r Distiller. Masukkan item ke dalam Distiller dan beri panas (Heat)! \\n\\nBeberapa item menghasilkan lebih banyak &cMercury&r, contohnya Diamond yang memberikan 10 Mercury untuk 1 Diamond, dibanding Batu yang butuh 10 blok untuk menghasilkan hanya 1 &cMercury&r."
		"{image:atm:textures/questpics/theurgy/theurgy_distiller.png width:100 height:150 align:center}"
	]
	quest.36926B5EBFF6E55A.title: "Membuat &cMercury"
	quest.3697AAF8F281B247.quest_desc: ["Ini sedikit rumit! Dengarkan baik-baik! \\n1. Bangun &bMesin Uap&r-nya. &bTangki Cairan&r menentukan berapa banyak &9Air&r yang bisa ditampung dan menentukan Level &bMesin Uap&r. \\n\\nKemudian, pasang &bMesin Uap&r ke samping &bTangki Cairan&r dan ia akan menjadi &bBoiler Uap&r. Setelah itu, pasang &8Poros&r ke &bMesin Uap&r untuk mendapatkan Lengan Mekanik yang akan memberi kita &dTenaga Rotasi&r. \\n\\n2. &cSumber Panas&r. Kita butuh &cSumber Panas&r di bawah &bTangki Cairan&r untuk memanaskan &9Air&r. Ada beberapa &cSumber Panas&r: Api, Api Unggun, Lava, Blok Magma — tapi &cPembakar Blaze&r adalah yang terbaik! \\n\\nSemakin baik &cSumber Panas&r, semakin banyak Satuan Stres! Jadi beri &cPembakar Blaze&r-mu &cKue Blaze&r dan kamu akan ngebut! \\n\\n3. &9Air&r. Ini adalah bahan bakar &bMesin Uap&r kita, nggak akan ada Uap tanpa &9Air&r. \\n\\nBagaimana cara mengalirkan &9Air&r terserah kamu, tapi untuk &6&lATM10&r aku sarankan Wastafel dan &9&lID&r!"]
	quest.3697AAF8F281B247.title: "&bMesin Uap"
	quest.369D3AF332181DA8.quest_desc: ["Stone Nest bisa diletakkan di biome Overworld mana pun untuk memancing Mason Bee atau Digger Bee."]
	quest.369D3AF332181DA8.quest_subtitle: "Memancing lebah di biome Overworld mana pun"
	quest.369DADE3B3D8416F.quest_desc: ["&aTritium&r sayangnya gak segampang &cDeuterium&r... \\n\\nKita butuh &6&lThermal Evaporation Plant&r. Ya... sebenernya 2. 1 buat ubah &9Air&r jadi &eBrine&r, yang lain buat ubah &eBrine&r jadi &6Lithium&r. \\n\\nYa... sebenernya &6Liquid Lithium&r, kita butuh &cChemical &6Lithium&r. Pake &c&lRotary &bCondensator&r buat ubah dari &bLiquid&r ke &cChemical&r! \\n\\nTerus, kita bisa pake &e&lSolar Neutron Activator&r buat ubah &6Lithium&r jadi &aTritium&r.\\n\\nLebih susah dari &cDeuterium&r, tapi lebih gampang dari &2Fissile Fuel&r."]
	quest.369DADE3B3D8416F.quest_subtitle: "T"
	quest.369DADE3B3D8416F.title: "&aTritium"
	quest.36A3ECD4F6CA2732.quest_subtitle: "&f8 &cAttack Damage"
	quest.36ABE142039E712B.quest_desc: ["Cara kerjanya kayak penyimpanan energi tak terbatas biasa, tapi yang ini bisa nyambung ke sistemmu! Nggak perlu khawatir lagi sistemmu kehabisan daya! Termasuk buat &5Quantum Armor&r. \\n\\nKamu butuh 4 &dSuperdense Cell&r dan sebuah &6&lATM Star&r. Tiap &dSuperdense Cell&r butuh 8 &dDense Cell&r, dan tiap &dDense Cell&r butuh 8 &dEnergy Cell&r. \\n\\nTotal 256 &dEnergy Cell&r... plus energi yang banyaaak banget!"]
	quest.36ABE142039E712B.title: "&5&lCreative &dEnergy Cell"
	quest.36B283532D70776A.quest_desc: ["&aBoots of Speed&r adalah Boots terbaik yang bisa kamu dapatkan di sini. \\n\\nPertama, kita butuh &aArchevokers Boots&r. Jika kamu tidak suka barang bekas, aku sarankan Craft sendiri. \\n\\nLalu, kita butuh &bMithril Weave&r. Ini kombinasi &bMithril Ingot&r dan Rantai. Ini hanya digunakan untuk Craft Armor jadi kamu hanya butuh beberapa. \\n\\nTerakhir adalah &dDivine Soulshard&r. \\n\\n&aBoots&r ini akan memberikan lebih banyak Mana dari Boots mana pun, lebih banyak &3Spell Power&r, plus membuat kamu lebih cepat? Bagaimana bisa membuat kamu lebih cepat? Dengan meningkatkan Movement dan &3Spell Casting&r Speed!"]
	quest.36B283532D70776A.title: "&aBoots of Speed"
	quest.36B9D5A99E1AA85C.quest_subtitle: "&f8 &cAttack Damage"
	quest.36BCCF7395658A5C.quest_desc: ["Boss di Starlight tinggal di struktur mereka. Ini gak umum (untungnya) jadi kamu mungkin butuh bantuan alias Seeking Eye. \\n\\nSeaking Eye kerja kayak Ender Eye, Right Click buat lempar dan ikuti mereka buat sampai ke struktur. \\n\\nBuat set struktur kamu butuh Item tertentu di Offhand kamu, item kayak..."]
	quest.36BCCF7395658A5C.title: "Nemuin Boss"
	quest.36BCE35215B2B6E9.quest_desc: ["Memasak makanan secara otomatis di dalam Tas."]
	quest.36BCE35215B2B6E9.quest_subtitle: "Otomatis"
	quest.36BCE35215B2B6E9.title: "&eAuto-Smoking Upgrade"
	quest.36CDA39C23D3AA2B.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, kamu sedang dalam mode pengeditan."]
	quest.36CF8D1DD1EF6307.quest_subtitle: "2 Blok Hijau Muda Basah"
	quest.36D35C35BBC0A555.quest_subtitle: "Yang paling efisien"
	quest.36D72D759C4E8823.quest_desc: ["Mungkin malah terlalu cepat."]
	quest.36D72D759C4E8823.quest_subtitle: "Maks: 1"
	quest.36DAFC3FECC67406.quest_desc: ["Energy Battery terbaik yang akan DE berikan."]
	quest.36DAFC3FECC67406.title: "Chaotic Capacitor"
	quest.36DEA17CBB696CC7.quest_desc: ["Jika kamu klik kanan pada Plug, kamu akan melihat antarmuka Flux Network. Di pojok kanan atas, klik tombol + untuk membuat jaringan pertamamu. Kamu harus mengatur kata sandi untuk membuat jaringan, tapi kamu juga bisa memilih warnanya!\\n\\nDari sini, kamu bisa pergi ke tab Network Selection untuk mengaktifkan jaringanmu pada Plug tersebut. Jika Plug terhubung ke sumber daya, kamu sekarang bisa menggunakan daya tersebut di mana saja menggunakan Flux Point!\\n\\nTips Pro: Kamu bisa membuat banyak jaringan jika ingin memiliki sumber daya berbeda yang menyuplai bagian sistem yang berbeda pula!"]
	quest.36DEA17CBB696CC7.quest_subtitle: "Menjadi Admin Jaringan!"
	quest.36DED7099E80ED51.quest_desc: ["Yang satu ini melakukan persis seperti namanya: meletakkan blok. \\n\\nAtur arah peletakkan blok, sebaiknya pasang Filter, lalu masukkan Module dan bloknya ke dalam Router! Begitu Redstone aktif, blok akan terpasang!"]
	quest.36DF0D83EBC2B6A9.quest_desc: [""]
	quest.36DF0D83EBC2B6A9.quest_subtitle: "&oKurangnya kebijaksanaan adalah masa lalu dengan ini."
	quest.36DF0D83EBC2B6A9.title: "&3&lImprobable Probability Device"
	quest.36EB83BB41A9E621.quest_desc: [
		"&b&lTangki&r sama seperti &l&eSilo&r tetapi untuk &bCairan&r! \\n\\nHanya bisa menampung 1 jenis &bCairan&r, tetapi bisa menampung 512 Ember dari &bCairan&r itu. \\n\\nBisa &9Memasukkan &bCairan&r dari Sisi Atas atau Bawah, tetapi hanya bisa &6Mengeluarkan&r dari Bawah."
		"{@pagebreak}"
		"&b&lTangki&r dibangun mirip dengan &e&lSilo&r, mulai dengan Pagar Kayu yang Diolah dan &7Lembar Besi&r tunggal."
		"{image:atm:textures/questpics/immersive/immersive_tank1.png width:125 height:100 align:center}"
		"Sekarang kita membuat kotak penuh &7Lembar Besi&r di atas Pagar kita, sambil meninggalkan ruang di tengah berongga. Lakukan ini 3 Blok tinggi."
		"{image:atm:textures/questpics/immersive/immersive_tank2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_tank3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_tank4.png width:100 height:100 align:center}"
		"Kemudian, tutup dengan kotak penuh &7Lembar Besi&r!"
		"{image:atm:textures/questpics/immersive/immersive_tank5.png width:100 height:100 align:center}"
		"Klik Kanan Blok yang sama seperti di &e&lSilo&r untuk membuat &b&lTangki&r kita."
		"{image:atm:textures/questpics/immersive/immersive_tank.png width:100 height:120 align:center}"
	]
	quest.36EB83BB41A9E621.title: "&b&lTangki"
	quest.36F123B2A6B52A01.quest_desc: ["Ini bisa memindahkan lebih banyak Energy dan punya lebih banyak link. Level tertinggi Energy Crystals."]
	quest.36F123B2A6B52A01.title: "Draconic Energy Relay Crystal"
	quest.36F87173D8CD1D68.quest_desc: ["Naik &5Petir&r! &5&lLightning&r adalah tentang menggunakan Listrik untuk membunuh dan mendukung dirimu sendiri. Beberapa serangan bahkan bekerja sebagai &5Petir&r asli! \\n\\n&5&lLightning&r menggunakan &5Bottle 'O Lightning&r sebagai Material Fokusnya yang kamu dapatkan dari menggunakan Empty Bottle pada Charged Creeper. Kamu butuh &5Petir&r untuk membuat lebih banyak &5Petir&r! \\n\\n&5Scroll&r-nya berwarna &7Abu-abu&r dengan teks &bBiru Muda&r."]
	quest.36F87173D8CD1D68.title: "&5&lLightning"
	quest.36FB694262102CFD.quest_desc: [
		"ExtendedAE nawarin tipe cell baru, Infinity Cell."
		""
		"Cell ini kasih unlimited supply resource tertentu, seperti Air, Cobblestone, Lava, dll."
	]
	quest.36FB694262102CFD.quest_subtitle: "Sink tapi bentuk cell"
	quest.36FB694262102CFD.title: "Resource Lebih dari Cukup: Infinity Cell"
	quest.37045B986619A03D.quest_subtitle: "Yellow + Green Carpenter Bee"
	quest.3705D303CF423804.quest_desc: ["Versi lain dari &aFeral Claws&r, sarung tangan ini meningkatkan Damage yang kamu hasilkan saat memakainya."]
	quest.3705D303CF423804.quest_subtitle: "Tangan"
	quest.3705D303CF423804.title: "&ePower Glove&r"
	quest.3707C3EDA1C5A0B2.quest_subtitle: "Firecracker + Flickering Sun"
	quest.3708A4780ACEB34E.quest_desc: ["Dalam modpack ini, quest bersifat opsional. Mod tidak dikunci di balik penyelesaian quest apa pun!\\n\\nBanyak rangkaian quest individual di luar quest utama dimaksudkan sebagai panduan mod. Jika kamu ingin mengikuti progresi yang ada, pastikan untuk memeriksa Main Questline!"]
	quest.371A34B297C8A8EF.quest_desc: ["PneumaticCraft adalah tentang Tekanan Udara! Quest ini tidak akan membahas semua yang ada di mod ini, tapi tetap mencakup banyak hal! Harap ingat untuk cek JEI, baca tooltip, dan baca PCB:R, semuanya sangat berguna.\\n\\nUntuk memulai, kamu butuh men-craft &3Compressed Iron Ingot&r! Cara termudah adalah membuat lubang di tanah, lempar beberapa iron ingot (atau blok) ke dalamnya, lalu ledakkan dengan TNT!\\n\\nBeberapa mungkin akan hilang akibat ledakan, tapi itu risiko yang harus kita ambil!"]
	quest.371A34B297C8A8EF.quest_subtitle: "Kekuatan Udara"
	quest.371A34B297C8A8EF.title: "PneumaticCraft: Repressurized"
	quest.371A382CF1DDF2B2.quest_desc: ["&bCapacity Card&f memungkinkan bus yang ditingkatkan untuk menampung filter yang lebih besar. Import dan Export bus yang ditingkatkan dengan kartu ini bisa mendukung hingga sembilan slot filter, sementara Storage bus akan meningkat dari 18 slot menjadi maksimal 63."]
	quest.371A382CF1DDF2B2.title: "Capacity Card"
	quest.371E09ED2A3F6BDC.quest_subtitle: "Muncul di Advanced Beehive yang kosong di tempat gelap"
	quest.371E09ED2A3F6BDC.title: "ZomBee"
	quest.3722B43822F80470.quest_desc: ["Damage lebih besar dari Pedang, tapi lebih lambat."]
	quest.3722B43822F80470.quest_subtitle: "Keluarkan jiwa Samurai-mu"
	quest.372B5BF416CA83A4.quest_desc: ["&5&lMekanism&r adalah salah satu Mod Mesin dan Teknologi paling populer. Sejujurnya gue susah meringkas karena ada banyak banget di dalamnya! \\n\\nBanyak banget sampe kita harus bikin 2 Quest Page buat ini! \\n\\nStuff yang kita butuhin buat &6&lATM Star&r ada di page Reactor tapi kamu harus lewatin page Mekanism dulu."]
	quest.372B5BF416CA83A4.title: "&5&lMekanism"
	quest.37355F60E45777FE.quest_desc: ["Orb of Prophecy bisa di-craft atau didapet dari ngalahin Gatekeeper! \\n\\nKegunaan utamanya adalah ngaktifin Portal, tapi bakal ada kegunaan lain!"]
	quest.373668AE257A7A94.quest_desc: ["Kartrid Bahan Peledak Tinggi akan menembakkan bahan peledak ke Musuh, meledakkan semua yang ada di dekatnya seperti TNT! \\n\\nCangkang Napas Naga bekerja seperti Buckshot, tetapi sekarang Proyektilnya terbakar!!!!! \\n\\nKartrid Botol memberikan Efek Ramuan berdasarkan Ramuan yang digunakan dalam pembuatannya. \\n\\nCangkang Suar bekerja seperti Kembang Api di Busur Silang. \\n\\nKartrid Homing akan membidik Mob mana pun yang paling dekat... semoga itu Mob berbahaya. \\n\\nCangkang Wolfpack seperti Cangkang Buckshot tetapi sekarang Proyektilnya adalah Kartrid Homing!"]
	quest.373668AE257A7A94.title: "Proyektil Khusus"
	quest.37367101B3DAA70F.quest_desc: ["Ashy Mining Bee muncul dari Dirt, Gravel, atau Sand Nest."]
	quest.37367101B3DAA70F.quest_subtitle: "Muncul dari Dirt Nest"
	quest.373EBEB2E96D9361.quest_desc: ["Saat menjelajahi Biome Bersalju kamu mungkin menemukan apa yang terlihat seperti Gereja bobrok. \\n\\nTapi apa yang ada di dalamnya, tidaklah &6Suci&r! \\n\\nTurun ke Basement ke Catacombs. Di sini akan ada banyak Stray Spawner, jebakan Powder Snow, dan Loot! \\n\\nSerta &bIce Spider Egg&r... coba Pecahkan dan kamu akan memperingatkan..."]
	quest.373EBEB2E96D9361.title: "&bIce Spider Den"
	quest.374C06B3999BB0D3.quest_desc: ["Mencampur &#C2C78BBesi&r, &#EDB2EAChromium&r, &#BEC9A3Nikel&r, dan &7Manganese&r akan memberimu &#ADF0EEStainless Steel Dust&r."]
	quest.3751015CD5C84134.title: "&bKomponen Penyimpanan Cairan 4096B"
	quest.375F0A098589CF29.quest_desc: [
		"Pakai Seeking Eye kamu mungkin bingung kenapa tiba-tiba masuk underground. Itu mungkin karena Golem Forge ada di underground, kayak di level Y negatif. \\n\\nAda banyak ruangan berliku penuh Loot, Lava, dan Freeze! Ruangan yang kita cari itu yang ada Starlight Golem-nya!"
		"{image:atm:textures/questpics/eternal/starlight_golemforge.png width:200 height:100 align:center}"
	]
	quest.375F0A098589CF29.title: "Golem Forge"
	quest.376532CD98D39781.quest_desc: ["&c&lChemical Infuser&r bakal ambil 2 &cChemical&r beda terus... digabungin. \\n\\nIni nggak terlalu bantu di awal game, tapi nanti bakal penting banget! \\n\\n&cChemical&r pertama masuk ke &4Bar Merah&r di kiri dan &cChemical&r kedua masuk ke &6Bar Oranye&r di kanan. \\n\\nYa, urutan posisinya itu ngaruh. Itu aku pelajarin lewat cara yang susah di &6&l9TTS&r!"]
	quest.376532CD98D39781.title: "&c&lChemical Infuser"
	quest.3765485408041FC6.quest_desc: ["Lihat Modules untuk belajar lebih tentang cara menggunakan dan upgrade item DE! Pickaxe bekerja sebagai Pickaxe Tier 6 normal. Bisa menambang setiap level block, dari Stone sampai Unobtainium. Item yang ditambang akan otomatis masuk ke Inventory-mu."]
	quest.3765485408041FC6.title: "Wyvern Pickaxe"
	quest.376D154F27A00BCD.quest_desc: ["Apa masalahnya dengan Fisika dan DE dan mengkhianati mereka? Gravitasi menarik Arrow ke bawah seiring waktu ditembakkan. Gravity Compensation membuat kita tidak terlalu khawatir tentang itu."]
	quest.376D154F27A00BCD.title: "Wyvern Projectile Gravity Compensation Module"
	quest.377A41499D8218C9.quest_desc: [
		"&lWorld Tier&r pertama adalah &l&9Haven&r! Karena ini yang pertama, Haven menjadi yang paling mudah dijelajahi dan didapatkan. \\n\\nUntuk membukanya, kamu cukup memegang satu &eAffixed Item&r di tangan! World Tier akan otomatis terset saat terbuka. \\n\\n&lWorld Tier: &9Haven&r memiliki peluang tertinggi untuk &8Common&r &aGear&r &fdan &aGem&r. Bisa juga muncul &aUncommon&r dan (sangat jarang) &9Rare&r."
		""
		"Ini juga satu-satunya &lWorld Tier&r di mana &4Invader&r tidak bisa spawn secara alami."
	]
	quest.377A41499D8218C9.title: "&lWorld Tier: &9Haven"
	quest.377D6CF86BC1C64F.quest_desc: ["&8Tome of Scrapping&r hanya mengambil setengah dari &5Enchantment&r yang ada, sedangkan &8Tome of Superior Scrapping&r akan mengambil SETIAP &5Enchantment&r dari item tersebut! \\n\\nKedua &8Tome&r ini tetap akan menghancurkan item aslinya saat digunakan. \\n\\nUntuk melakukan &d&lInfuse&r pada &8Tome of Scrapping&r menjadi &8Tome of Superior Scrapping&r, kita bisa menggunakan 3 &9Echoing Sculkshelves&r dan 15 Bookshelf, atau 4 Draconium Block."]
	quest.377D6CF86BC1C64F.quest_subtitle: "Semua Enchantment, menghancurkan item"
	quest.377D6CF86BC1C64F.title: "&8Tome of Superior Scrapping"
	quest.378105383747DD48.quest_desc: ["Nah yang ini rumit. \\n\\nUntuk mendapat &8&lReplica&r pertama siapkan 5 Soul, Damage Exchange, dan Immunity Exchange. \\n\\nKemudian, pegang Strengthened Shield untuk memblokir serangan, lalu akan dapat &8&lReplica&r!"]
	quest.378105383747DD48.title: "&8&lReplica"
	quest.378BF828DC931F0C.quest_desc: ["Secara pribadi, benci harus lari ke block cuma buat craft. Di situlah &2Crafting Table on a Stick&r masuk!\\n\\nItem ini bekerja sebagai &aPortable Crafting Table&r!\\n\\nTip: Bisa juga memasukkan ini di slot &aCurios&r dan mengatur &bKeybind&r untuk membukanya!"]
	quest.378BF828DC931F0C.title: "Crafting, tapi di Stick"
	quest.378C95C18798D413.quest_desc: ["Cara cepat untuk berganti-ganti alat.\\n\\nUpgrade dengan kantong sabuk (belt pouch) di Anvil untuk meningkatkan kapasitasnya."]
	quest.378C95C18798D413.title: "Sabuk Perkakas (Tool Belt)"
	quest.379B33D0BCBC47AA.quest_subtitle: "Dibuat di Reprocessor"
	quest.379B33D0BCBC47AA.title: "Magentite Bee"
	quest.37AD651E91FE3E20.quest_subtitle: "Pomelo + Key Lime"
	quest.37B055397B21D936.quest_subtitle: "&f4 &cAttack Damage"
	quest.37B297640F537383.quest_desc: ["Augment Unattuned dipake di Altar Infus buat bikin berbagai augment. Dapetin &eHaste&r, &1Night Vision&r, &bFall Damage Resistance&r, &6Fire Resistance&r, dan banyak lagi dengan augment keren ini!"]
	quest.37B297640F537383.title: "&fAugment Unattuned"
	quest.37B805E875D82A8B.quest_subtitle: "Balsa + Teak"
	quest.37B903620493A354.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pengasap Otomatis"
		"- Membakar Luka"
		"- Teleporter Barang Jatuhan"
		"- Tembus Pandang Monster"
	]
	quest.37CA6F9F0226F10E.quest_desc: ["Blok ini simpan item untuk masak.\\n\\nKamu juga bisa taruh item multi-block kitchen lain di atasnya, seperti toaster dan Cow in a Jar."]
	quest.37CA6F9F0226F10E.quest_subtitle: "Kita butuh lebih banyak ruang masak"
	quest.37CA6F9F0226F10E.title: "Butuh lebih banyak ruang masak?"
	quest.37CC51B689CB8A40.quest_desc: ["Chestplate bekerja mirip dengan Meka-Suit. Damage apapun yang akan diberikan padamu diniadakan dan malah diambil dari Shield-mu. Shield capacity adalah berapa banyak Shield yang bisa kamu tahan, recharge rate adalah seberapa cepat mengisi, dan OP akan digunakan saat recharging."]
	quest.37CC51B689CB8A40.title: "Wyvern Shield Capacity Module"
	quest.37CD9BF281903F56.quest_subtitle: "Berikan Shroombee sebuah Red Mushroom"
	quest.37CD9BF281903F56.title: "Red Shroombee"
	quest.37D4E5ACB35D8BF1.quest_desc: ["&cJetpack&r milik &5&lMekanism&r ini cara kerjanya mirip &l&7Iron Jetpacks&r cuma modenya beda dan butuh Hydrogen sebagai bahan bakar, bukannya &aEnergi&r! \\n\\nTinggal isi Hydrogen ke &cJetpack&r dengan naruh dia di &5Mesin&r yang punya Hydrogen. Lucunya, &9&lElectrolytic Separator&r juga punya Hydrogen pas dia lagi proses &bOxygen&r! \\n\\nPas sudah dipasang di punggung, kamu bisa tekan (G) buat ganti-ganti mode. \\n\\n&4Regular&r: tahan loncat buat naik, kamu bakal gerak ke arah mana pun yang kamu tekan di WASD dan kalau nggak ditekan cuma bakal naik lurus. Pas dilepas tombol loncatnya, kamu bakal jatuh. \\n\\n&bHover&r: kontrolnya sama kayak standar tapi gerakannya lebih pelan dan kamu nggak bakal jatuh pas lepas tombol loncat. Kamu bisa turun pakai (Shift). \\n\\n&6Vector&r: nggak bakal ngerespon WASD tapi bakal gerak ke arah mana pemain melihat pas tahan tombol loncat buat naik. \\n\\n&4Disabled&r: nggak nyala! \\n\\nNgomong-ngomong, kamu bisa upgrade &cJetpack&r-nya pakai beberapa blok dan item biar punya proteksi armor!"]
	quest.37D4E5ACB35D8BF1.quest_subtitle: "Butuh Hydrogen biar Jalan!"
	quest.37D4E5ACB35D8BF1.title: "&cJetpack"
	quest.37DB7871590921CF.quest_desc: ["&bHippocampus&r bisa di-Tame! Dengan Kasih makan Kelp. \\n\\nPas udah Jinak, kita bisa Klik Kanan mereka pake Sadel, buat bisa Naik mereka kayak Kuda. \\n\\nMereka bisa Merangkak pelan di darat atau Berenang cepat di &9Air&r. Pas di &9Air&r di Punggung mereka, kamu bakal dapet &9Water Breathing&r! \\n\\nMereka bahkan bisa Lompat! Cuma gak terlalu tinggi..."]
	quest.37DB7871590921CF.title: "Jinakkin &mManatee&r &bHippocampus"
	quest.37E4DECFB6526969.quest_desc: ["&3Soul Render&r dibuat dari &3Cursium&r dan Black Steel. \\n\\nSebagai senjata yang masif (seperti kebanyakan di mod &4&lCataclysm&r), ia punya Jarak yang jauh dan Damage besar... tapi efek spesialnya jauh lebih hebat! \\n\\nKamu bisa Klik Kanan untuk menerjang maju. Saat kamu melakukannya, &3Phantom Halberd&r akan jatuh dari langit di tempat yang kamu lalui! Kamu juga bisa Shift+Klik Kanan untuk memanggil &3Phantom Halberd&r di sekelilingmu."]
	quest.37E4DECFB6526969.title: "&3Soul Render"
	quest.37EBB8E0D6E5F821.quest_desc: [
		"&6Hostile Neural Networks&r (disingkat HNN) adalah mod yang berbasis simulasi kill mob untuk mendapat loot!\\n\\nCaranya dengan mengumpulkan \"data\" dari mob, lalu menjalankan simulasi dari data tersebut untuk membuat drop mereka!\\n"
		"{image:atm:textures/questpics/hnn.png width:150 height:150 align:center}"
	]
	quest.37EBB8E0D6E5F821.title: "Selamat Datang di &9Hostile Neural Networks&r!"
	quest.37F2BE3C2BAF7C2D.quest_desc: ["Tag adalah bagian esensial dari Minecraft. \\n\\nBagi yang belum tahu, Tag berfungsi sebagai alat organisasi untuk memilih item yang serupa untuk tugas yang sama. Contohnya, Meja Crafting bisa dibuat dengan Papan (Planks) apa saja. \\n\\nUntuk memfilter berdasarkan Tag, masukkan sebuah item, lalu pilih tag dari grupnya. Contohnya Iron Ore untuk kategori bijih."]
	quest.3804364077F4BAD4.quest_desc: ["Sangat jarang &dPixie&r mungkin kehilangan &dSayap&r mereka pas Mati. Mereka gak bakal butuh lagi, mereka Mati... tapi kamu tetep harus merasa bersalah buat Bunuh mereka! \\n\\nAtau daripada berkabung kehilangan nyawa yang tak bersalah kamu bisa Craft Senjata dari sisa-sisa mereka! \\n\\nWah, kamu monster banget. \\n\\n&dTongkat Pixie&r bakal pake &dDebu Pixie&r buat Tembak &dSinar Pixie&r! Ini bakal Damage dan kasih Levitation dan Glowing ke apapun yang kena."]
	quest.3804364077F4BAD4.title: "&dTongkat Pixie"
	quest.380D3212D1CBA593.quest_desc: [
		"&cRot Mob&r berukuran sedang, yaitu &cRotwalker&r. \\n\\nMereka punya 20 HP. \\n\\nSeperti semua &cRot Mobs&r, mereka akan menyerang &2Stoneborn&r serta &7Forgotten&r dan menjatuhkan &cUtheric Shard&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotwalker.png width:100 height:200 align:center}"
	]
	quest.380D3212D1CBA593.title: "&cRotwalker&r"
	quest.3813F5C1760C3A79.quest_desc: ["Memasukkan Piglin Brute ke sini mungkin menimbulkan kontroversi, tapi aku menganggap mereka sebagai Minibos. \\n\\nMereka muncul di Bastion bersama Piglin biasa, tapi mereka Agresif, bukan Netral. Secara pribadi aku benci itu, terutama karena jika kamu memukul mereka, semua Piglin akan berubah menjadi Agresif terhadapmu. \\n\\nMereka punya 50 HP dan Kapak Emas untuk memukulmu. Biasanya Kapak Emas hampir tidak memberikan damage, tapi entah kenapa saat mereka yang pakai, damagenya luar biasa! \\n\\nMereka tidak menjatuhkan apa pun dan lebih berperan sebagai penghalang di Bastion!"]
	quest.3813F5C1760C3A79.title: "Kalahkan Piglin Brute"
	quest.38451B61E3FC075B.quest_desc: [
		"Tunggu, kita punya Baja lagi, apakah itu berarti kita mendapatkan (Coal) Coke kembali? Ya! \\nUntuk mendapatkan Coal Coke, kamu butuh Coke Oven. Buatlah strukturnya dengan 26 Coke Oven Brick berukuran 3x3x3 dengan 1 blok kosong di tengah. Kamu tahu mesin ini jadi saat GUI bisa diakses. \\n\\nMasukkan Batu Bara (Coal) untuk mendapatkan Coal Coke dan Cairan Creosote! Kamu juga bisa memasukkan kayu apa saja untuk mendapatkan Charcoal dan Creosote."
		"{image:atm:textures/questpics/railcraft/rail_coke.png width:100 height:100 align:center}"
	]
	quest.38451B61E3FC075B.title: "Coke Oven"
	quest.38622692756F1F27.quest_subtitle: "Crystalline + Ender"
	quest.38622692756F1F27.title: "Spatial Bee"
	quest.386ABEB4249D157D.quest_desc: ["Satu buah &#919191Monocrystalline Silicon&r dapat dipotong menjadi 32 &#8FA4B5Silicon Wafer&r."]
	quest.3889D0255074CE85.quest_desc: ["&bMacaw&r memutuskan bahwa perabotan saja tidak cukup, dia butuh rumah Macaw-nya memiliki lebih dari sekadar pencahayaan alami dari &b&lMacaw Windows&r-nya. \\n\\nJadi sekarang kita punya &b&lMacaw's Lights and Lamps&r yang menambahkan segala macam sumber cahaya. \\n\\nMulai dari lampu meja, lentera, hingga lampu gantung!"]
	quest.3889D0255074CE85.title: "&l&bMacaw's Lights and Lamps&r"
	quest.3891F8D4201E6BFD.quest_desc: [
		"&#EBA844Kanthal Ingot&r dapat diproses menjadi Fine Wire, yang kemudian dibentuk menjadi Kabel untuk akhirnya membuat &#EBA844Kanthal Coil&r. "
		""
		"&#EBA844Kanthal Coil&r memungkinkan &#816DF7Electric Blast Furnace&r kita berjalan pada &#F76D6Dsuhu&r yang jauh lebih tinggi, sehingga lebih banyak resep yang bisa dikerjakan."
		""
		"Kamu harus mengganti coil tersebut di dalam GUI &#816DF7Electric Blast Furnace&r."
		""
		"{image:atm:textures/questpics/modernindustrialization/switch_to_kanthal.png width:150 height:75 align:center}"
	]
	quest.38954551309F42A7.quest_desc: ["Sender Module MK2 bekerja mirip dengan MK1 tetapi dengan batasan yang lebih sedikit. \\n\\nMK2 tidak butuh pandangan mata langsung atau berada di koordinat yang sejajar. \\n\\nTetap harus berada di dimensi yang sama, kecuali kamu punya..."]
	quest.38956DC28E317DEF.quest_desc: ["&dSigil of Rebirth&r adalah bahan bakar untuk semua &l&9Reforging Table&r. \\n\\nMeja tersebut tetap butuh material lain dan item yang ingin diubah agar bisa bekerja... \\n\\nSetidaknya Sigil ini relatif mudah untuk di-craft!"]
	quest.38956DC28E317DEF.title: "&dSigil of Rebirth"
	quest.389655CD41C7A691.quest_desc: [
		"Tier 1 hanya butuh Core dan 4 Stabilizers untuk dibuat."
		"{image:atm:textures/questpics/draconic/draconic_core_1off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_1on.png width:100 height:100 align:1}"
	]
	quest.389655CD41C7A691.quest_subtitle: "Menyimpan: 45,500,000 RF"
	quest.389655CD41C7A691.title: "Tier 1"
	quest.38A1295878B68F83.quest_desc: [
		"Bukan, bukan jenis yang itu."
		""
		"&cAfrit Demon&r adalah Setan &cApi&r. Mereka adalah setan tingkat lanjut; ada yang teman dan ada yang... bukan. Semua tergantung seberapa kuat ritual tersebut bisa mengendalikan sang &cAfrit&r. "
		""
		"Karena kita belum punya akses ke Red Chalk, yang bisa kita panggil hanyalah setan &9Unbound&r (Liar), yang berarti ia tidak bisa dikendalikan dan akan menyerang."
	]
	quest.38A1295878B68F83.quest_subtitle: "Setan Panas!"
	quest.38A1295878B68F83.title: "&6Abras' Open Conjure"
	quest.38A77DBAD24C4B53.quest_subtitle: "Tingkat: &63"
	quest.38AD547C36BDF4C4.title: "Draconic Projectile Accuracy Module"
	quest.38ADDF7FF4E4892D.quest_desc: ["&7Glass Sword&r menghasilkan damage sebesar 40 heart, tapi hanya memiliki 1 durabilitas.\\n\\nKamu bisa membuatnya menjadi tidak bisa hancur (indestructible) jika ingin memakainya.\\n\\nPedang ini jarang ditemukan di dalam peti loot di &bAurora Palace&r."]
	quest.38ADDF7FF4E4892D.title: "Pedang Kaca (&7Glass Sword&r)"
	quest.38BFF6F845EA479E.quest_subtitle: "4/5"
	quest.38BFF6F845EA479E.title: "Bagian Kiri Bawah &6&lATM Star&r"
	quest.38C236042AB5DDB9.quest_subtitle: "Bull Pine + Silver Fir"
	quest.38C98FCB6A2D4226.quest_desc: ["Kumparan Tesla Miniatur akan bertindak seperti Enchantment Thorns. \\n\\nSiapa pun yang mengenaimu, saat mengenakan &c&lRansel&r, akan Terkejut. Memberikan Kerusakan dan memberikan Efek!"]
	quest.38CAB3EF0D89B8F4.quest_desc: [
		"kamu pernah denger orang bilang Burung itu kerabat terdekat Dinosaurus? Nah, &0Cockatrice&r adalah kenapa mereka bilang gitu! \\n\\n&0Cockatrice&r punya bentuk dan kekuatan membunuh Raptor dari Jurassic Park, sambil keliatan persis kayak Ayam! \\n\\nSecara teknis mereka Netral dan punya 140 &4Hearts&r dengan 2 &7Armor Points&r. \\n\\nMereka Netral kayak &5Enderman&r, jangan Pukul mereka, coba Pukul mereka, atau liat ke Mata mereka. \\n\\nIya, &0Mata Cockatrice&r mematikan, kalo kamu liat ke mata mereka kamu bakal dapet &0Wither&r, Nausea, Slowness, dan Weakness. kamu bisa pake Penutup Mata buat blok &0Serangan Mata&r mereka tapi nanti, mereka bakal anggap itu ancaman dan pake Serangan lain mereka. Yang adalah Tendang kamu. \\n\\nGue bahkan gak nyalahin mereka, satu-satunya alasan kamu pake Penutup Mata adalah buat bunuh &2&lGorgon&r atau &0Cockatrice&r, dan gue gak liat Gorgon di sini!"
		"{image:atm:textures/questpics/iceandfire/iaf_cockatrice.png width:200 height:100 align:center}"
	]
	quest.38CAB3EF0D89B8F4.title: "&8Cockatrice"
	quest.38CB5044AB3F859B.quest_desc: ["&aLem Super&r digunakan untuk menempelkan Blok bersama-sama! Agar bisa digerakkan dengan &aKontraption&r. \\n\\nUntuk &aLem&r Blok bersama, Klik Kanan dua Blok berbeda dan semua Blok di antaranya akan &aditempel&r. Kalau ingin &aMelepas Lem&r, cukup Klik Kiri dengan &aLem Super&r. \\n\\nAda beberapa syarat: setiap Blok harus terhubung ke Blok lainnya dan tidak boleh secara diagonal. \\n\\nKamu juga bisa menggabungkan Blok yang sudah &aditempel&r dengan grup &aditempel&r yang berbeda. Semua dapat &aLem&r! \\n\\nPlus ini juga mempengaruhi Blok lain di dekat Blok yang sudah &aditempel&r. Blok yang bersebelahan dengan Blok &aditempel&r akan ikut bergerak. Begitu pula Blok yang menempel pada Blok &aditempel&r, seperti Obor atau Papan Nama."]
	quest.38CB5044AB3F859B.title: "&aLem Super"
	quest.38D0BBD5F699EF41.quest_desc: ["Memungkinkan Quantum Armor charge dari energi ME system kalau dilink ke Wireless Access Point. Kalau dipasang di Quantum Chestplate, juga recharge item di inventory. Ada interaksi khusus dengan AppliedFlux, dimana kalau ada FE Cell di network, akan extract energi dari sana."]
	quest.38F01BAEC74D5D68.quest_desc: ["Sama dengan Preheater lainnya, hanya ingin simetris :D."]
	quest.38F9E9A830D3EA0C.quest_desc: ["Jika kamu mengira mod ini hanya untuk item padat, kamu salah. Ada juga Fluid Drawer!\\n\\nCara kerjanya sama dengan Drawer biasa, namun digunakan untuk menyimpan cairan."]
	quest.3907E68572324333.quest_desc: ["Untuk mendapat &4&lMorgan&r butuh &e&lCaliburn&r. \\n\\nUntuk mendapat &e&lCaliburn&r butuh &3Mahou Lake&r. \\n\\nUntuk mendapat &3Mahou Lake&r butuh Power Consolidation Ritual. \\n\\nYang bisa dilakukan seperti ritual lainnya dengan 2 powdered diamond dan 1 powdered emerald. \\n\\nFYI jangan lakukan dekat base, Ritual akan menjadi tengah &3Lake&r!"]
	quest.3907E68572324333.title: "Power Consolidation Ritual"
	quest.3908F7C80154D9CA.quest_desc: ["&2Zombie Scepter&r ada karena siapa sih yang nggak mau memanggil pasukannya &2Zombie&r sendiri?\\n\\nUntuk mengisinya kembali, gabungkan dengan &cDaging Busuk (Rotten Flesh)&r di meja crafting."]
	quest.3908F7C80154D9CA.quest_subtitle: "Memanggil Zombie"
	quest.3908F7C80154D9CA.title: "&2Zombie Scepter"
	quest.39100B3867E9C01E.quest_desc: ["&cGloomy Geysers&r adalah Block yang bisa kamu temukan di &cOvercast Columns&r. \\n\\nSaat kamu Berjalan di atasnya mereka akan melemparmu tinggi ke Udara! Hati-hati ya, kamu masih kena Fall Damage. \\n\\nKamu bisa ambil dengan Silk Touch."]
	quest.39100B3867E9C01E.title: "&cGloomy Geyser"
	quest.39107884D6C80D41.quest_desc: ["&aIngot Phantasmal&r (dan &aEktoplasma&r) adalah Drop cuma dari &aHantu&r yang spawn dari &aTanah Kuburan&r. \\n\\nKita bisa gabungin &aIngot Phantasmal&r dengan &7Pedang Tulang Naga&r buat Craft &aPedang Phantasmal&r! \\n\\nSaat ini, Nyerangnya kayak Pedang normal, tapi pas diperbaiki bakal nembak ke Mob Nge-Hit mereka bahkan lewat Blok!"]
	quest.39107884D6C80D41.title: "&aPedang Phantasmal"
	quest.3916B48D7F294932.quest_desc: ["ME Wireless Hub adalah upgrade dari ME Wireless Connector. Sekarang bisa konek ke 8 Wireless Connector atau Hub berbeda. Catatan Hub cuma bisa transfer 32 channel total."]
	quest.3916B48D7F294932.title: "Cabang Koneksi: Wireless Hub"
	quest.3917DECAEF56A06A.quest_desc: ["&fTier 2&r setara dengan peralatan Stone (batu). Hampir hanya digunakan untuk menambang item-item berbahan Besi (Iron)."]
	quest.3917DECAEF56A06A.title: "&fHarvest Tier 2"
	quest.392EAE8BE71510C1.quest_desc: ["Gurun tandus dimensi &5End&r sekarang punya 1 penghuni baru. \\n\\nSatunya lagi tentu saja sang &dEnder Dragon&r!"]
	quest.392EAE8BE71510C1.title: "&5End&r: Tanah dengan 1 Bos yang Kesepian"
	quest.392F34FD4FCC794A.quest_desc: ["Meskipun harganya bisa mahal, mereka juga sangat bergaya!"]
	quest.392F34FD4FCC794A.title: "Blok &2&lMystical Agriculture&r"
	quest.3930404D5C8B44EB.quest_desc: ["Digunakan untuk membuat alloy (logam paduan) kustom.\\n\\nIni juga satu-satunya cara untuk mendapatkan Tyrian Steel!"]
	quest.3930404D5C8B44EB.quest_subtitle: "Menggabungkan Material"
	quest.393DA9C9D808A851.quest_desc: ["Kunci Inggris-nya mod &l&6Theurgy&r adalah Mercurial Wand. Kamu bisa menekan Shift dan Scroll untuk mengganti modenya. \\n\\nKamu bisa mengaktifkan/mematikan kabel (Enable/Disable) untuk menghentikan transfer item. \\n\\nKamu bisa mengubah sisi mana item akan ditarik (Extract) atau dimasukkan (Insert). \\n\\nDan kamu bisa mengubah Saluran Frekuensi!"]
	quest.393DA9C9D808A851.quest_subtitle: "Kira-kira ini mod sihir apa teknik ya..."
	quest.393DA9C9D808A851.title: "Tentu Saja Ada Wrench"
	quest.3942B5F5FD8ADF89.quest_subtitle: "Sycamore + Breadfruit"
	quest.395417A7ABC3658F.quest_desc: ["&2Kepala Gorgon&r adalah Drop yang dikonfirmasi dan satu-satunya dari &2&lGorgon&r. \\n\\nCuma punya 1 kegunaan, pas kamu pake, dia bakal hilang. \\n\\nPas kamu Tahan Klik Kanan sambil liat ke Mob, terus lepas, Mob-nya bakal diubah jadi &7Patung Batu&r. \\n\\nMob-nya bakal Mati tapi gak bakal kasih Drop apapun..."]
	quest.395417A7ABC3658F.title: "&2Kepala Gorgon"
	quest.395668FBCB6537AF.quest_desc: ["Gadis-gadis suka &ePerhiasan&r! &eBastion Ring&r sangat sempurna bagi pria yang hobi barter. Selama memakainya, Piglin akan bersikap netral padamu seperti saat kamu memakai &eEmas&r. Tapi ini bukan berarti kamu bisa bebas menjarah peti mereka ya. &eCincin&r ini juga memberimu peluang mendapatkan loot lebih banyak dari Barter. \\n \\n(Saat memakai &eCincin&r ini, Piglin mungkin akan menunjukkan arah ke Bastion terdekat)."]
	quest.395668FBCB6537AF.quest_subtitle: "Ditemukan di Ruined Portal, Nether Fortress, dan Bastion"
	quest.395668FBCB6537AF.title: "&eBastion Ring"
	quest.395A33977B18B9AD.quest_desc: [
		"Setelah mencoba memanen &5Tumpukan Armor&r mereka tampak kembali hidup seolah ada tubuh yang menggunakannya. Mereka juga bisa datang dari Spawner. \\n\\nMereka punya 60 &4Heart&r dan berbeda dari boss lain karena mereka tidak menggunakan sihir, melainkan aku percaya mereka adalah sesuatu yang dibuat dari sihir. Mereka akan menyerang menggunakan Pedang mereka baik dengan mengayunkannya atau menyerangmu dengannya. \\n\\nDari yang aku lihat mereka akan menyerang semua yang mereka lihat selain &5&lKnight&r lain! \\n\\nSetelah dibunuh mereka menjatuhkan Netherite Scrap dan &cCinder Essence&r. Jarang mereka akan Menjatuhkan &5Senjata&r mereka dan yang di &cCitadel&r akan Menjatuhkan Decrepit Key."
		"{image:atm:textures/questpics/iron_spells/spells_knight.png width:100 height:150 align:center}"
	]
	quest.395A33977B18B9AD.title: "&5&lAncient Knight"
	quest.39605F1FEB1A5A1C.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Community contributor&r untuk dipakai di AllTheMods Modpack. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan dengan &eAll Rights Reserved&r, Quest ini ga boleh dipakai di pack publik manapun yang ga dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan, kalau kamu lihat ini, berarti kamu lagi di editing mode."]
	quest.39605F1FEB1A5A1C.title: "AllRightsReserved"
	quest.39647A2473F6F7D7.quest_desc: [
		"Langkah kita selanjutnya adalah mencoba &6Ritual Infusi&r. Ritual ini digunakan untuk menyuntikkan sihir setan ke dalam sebuah item."
		""
		"Tingkat pertama &6Ritual Infusi&r adalah &eEziveus' Spectral Compulsion&r. Kita akan menggunakan ritual ini untuk membuat beberapa item yang akan kamu butuhkan di sepanjang mod ini."
		""
		"Disarankan untuk membuat ritual ini di area terpisah dari yang pertama, karena tiga jenis utama ritual dibangun berdasarkan tingkat sebelumnya."
	]
	quest.39647A2473F6F7D7.quest_subtitle: "Taburkan sedikit Debu Setan™ di atasnya!"
	quest.39647A2473F6F7D7.title: "&eEziveus' Spectral Compulsion"
	quest.396CEB9D05700927.quest_desc: ["Untuk masuk ke &l&6Bumblezone&r pertama-tama kamu butuh sebuah &eBeehive&r (Sarang Lebah). Bisa pakai sarang normal atau yang Advanced! \\n\\nLalu kamu perlu melemparkan Enderpearl ke dalamnya atau minta didorong Piston ke arah sarang tersebut! \\n\\nDan kamu akan masuk ke dalam sarang dan tiba di &l&6Bumblezone&r!"]
	quest.396CEB9D05700927.quest_subtitle: "Sungguh Menakjubkan"
	quest.396CEB9D05700927.title: "Masuk ke dalam &eHive"
	quest.396E7A2078F2CBC5.quest_subtitle: "Ash + Whitebeam"
	quest.3971FF7D044D1FE5.quest_desc: ["Kemampuan armor bisa dikonfigurasi dan diaktifkan/nonaktifkan di menu konfigurasi. Gunakan alat atau tongkat JDT untuk membuka menu dan klik armor kamu untuk konfigurasi kemampuan armor tersebut."]
	quest.3972EE0ECB215843.quest_desc: ["Extended dan Advanced AE adalah addon untuk Applied Energistics 2. Keduanya fokus meningkatkan pengalaman kamu, menambah versi improved dari berbagai device, dan lainnya."]
	quest.3972EE0ECB215843.title: "Extended \\& Advanced AE"
	quest.39796D8EE440F318.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_dune.png width:100 height:150 align:center}"]
	quest.39796D8EE440F318.quest_subtitle: "Desert Pyramids"
	quest.39796D8EE440F318.title: "Dune Armor Trim"
	quest.397E2D14BDE7DED0.quest_desc: ["Semua lebah akan menghasilkan blok sarang (Comb Block) alih-alih sarang satuan, melipatgandakan hasil produksi hingga 4 kali lipat!"]
	quest.397E2D14BDE7DED0.quest_subtitle: "4x Hasil Sarang"
	quest.39865681B03CABAA.quest_desc: ["Air agak kental, atau setidaknya lebih padat dari udara. Karena itu Mining di Bawah Air lebih lambat. Kamu bisa pakai Enchantment Aqua Affinity, atau pakai Module ini. Pilihanmu!"]
	quest.39865681B03CABAA.title: "Aqua Adapt Module"
	quest.3991EEEFDD263A91.quest_desc: [
		"Nightfall Spider, kayak Lonestar Skeleton, Hostile dan spawn dimana aja. \\n\\nMereka punya 5 Heart dan nyerang dengan mukul kamu. Setelah mukul kamu mereka bakal kasih kamu efek Glowing beberapa detik. \\n\\nKalau mati mereka bakal drop String dan mata mereka!"
		"{image:atm:textures/questpics/eternal/starlight_spider.png width:100 height:100 align:center}"
	]
	quest.3991EEEFDD263A91.title: "Nightfall Spider"
	quest.399858D28294D633.quest_subtitle: "Mandarin + Citron"
	quest.399882F3C51DD282.quest_subtitle: "Berikan Skeletal Bee sebuah bunga Wither Rose"
	quest.399882F3C51DD282.title: "Withered Bee"
	quest.3999AE0921641E60.quest_desc: [
		"&8Dark Matter&r dibuat dengan Smelting Edelwood. \\n\\n&5Corrupti Dust&r dibuat dengan &5Obsidiansteel&r dan beberapa Mob Drop. \\n\\nLempar keduanya di tanah bareng dan &8Black Hole&r akan spawn! \\n\\n&8Black Hole&r akan void setiap Item atau Projectile yang mendekat, tapi yang kita mau kasih makan adalah &aExperience&r! \\n\\nSaat kamu kasih makan cukup &aEXP&r akan kasih kembali &aXpetrified Orb&r."
		"{image:atm:textures/questpics/forbidden/forbidden_blackhole.png width:150 height:100 align:center}"
	]
	quest.3999AE0921641E60.title: "&8Black Hole"
	quest.39A0BA6E2A72A681.quest_desc: ["Mencampur &#99F0F0Stainless Steel&r, &#ADDBDBAluminium&r, dan &#E9A8F7Chromium Dust&r akan menghasilkan &#EBA844Kanthal Dust&r."]
	quest.39A19138C501B16F.quest_desc: ["Kamu bisa memancing lebah ini menggunakan Slimy Nest di biome rawa (swamp)."]
	quest.39A19138C501B16F.quest_subtitle: "&9Membutuhkan Slimy Nest"
	quest.39A19138C501B16F.title: "Slimy Bee"
	quest.39A7619B4C5592BE.quest_desc: ["&bDrain Item&r adalah cara kita untuk mengekstrak &bCairan&r dari &eItem&r secara massal! \\n\\nKalau Botol atau Ember dilempar di atas &bDrain&r — baik melalui Sabuk, Selokan, atau Tangan — &bCairan&r akan dikosongkan ke dalam &bDrain&r. \\n\\n&eItem&r yang sudah kosong kemudian akan didorong keluar dari &bDrain&r ke arah berlawanan, dan &bCairan&r akan menunggu di dalam &bDrain&r untuk di-&bPipa&r-kan keluar."]
	quest.39A7619B4C5592BE.title: "&bDrain Item"
	quest.39AF9B1A996DA949.quest_desc: ["Seperti Netherite Sword tapi jauh lebih baik dan jauh lebih keren!"]
	quest.39AF9B1A996DA949.title: "Chaotic Sword"
	quest.39B4F361EF611927.quest_desc: [""]
	quest.39B4F361EF611927.quest_subtitle: "&oKekuatan atas Kematian itu sendiri."
	quest.39B4F361EF611927.title: "&l&8Wither's Compass"
	quest.39B6D9FD21419776.quest_desc: ["{image:atm:textures/questpics/allthemodium/all_armor_vibmage.png width:100 height:175 align:center}"]
	quest.39B6D9FD21419776.title: "&3Vibranium Mage Armor"
	quest.39B85DB54B1037FE.quest_desc: ["Sedikit lebih cepat dari Pedang, tapi damage lebih rendah."]
	quest.39B85DB54B1037FE.quest_subtitle: "Pedang Tebal"
	quest.39BED5DD9D24F98E.quest_desc: ["&3Sculk Grime&r adalah versi Clay dari &3&lDeeper and Darker&r! \\n\\nKamu bisa menemukannya di beberapa Biome dan saat kamu menambangnya kamu akan dapat &3Grime Balls&r. \\n\\nIni bisa dibuat kembali jadi &3Sculk Grime&r atau dibuat jadi &3Grime Bricks&r."]
	quest.39BED5DD9D24F98E.title: "&3Sculk Grime"
	quest.39C8E1705EF1CD31.title: "&eKomponen Penyimpanan Cairan 256B"
	quest.39DAC0592300992A.quest_desc: ["&9Cetak Biru Cetakan Pers Logam&r bisa dibuat. \\n\\n&7&lMultiblok Pers Logam&r akan mengotomatiskan pembuatan &7Pelat Logam&r dan &eBarang&r. \\n\\nUntuk menekan &7Logam&r, kita memerlukan Cetakan. \\n\\nUntuk membuat Cetakan, diperlukan &9Cetak Biru&r ini!"]
	quest.39DAC0592300992A.title: "&9Cetak Biru Cetakan Pers Logam"
	quest.39E4FC9BA89E44BC.quest_desc: ["Balloon on a Stick adalah sumber awal untuk mendapatkan mode terbang (Creative Flight) namun dengan batasan.\\n\\nLetakkan stick tersebut dan kamu akan terikat pada balon! Tekan spasi dua kali untuk mulai terbang, tapi jangan terlalu jauh. Jika terlalu jauh, talinya akan terlepas dan kamu akan jatuh."]
	quest.39E4FC9BA89E44BC.quest_subtitle: "Meluncur ke Atas!"
	quest.39F142224D5210A9.quest_desc: ["&3Biodiesel&r dapat digunakan untuk membuat &3Lubricant&r (Pelumas) dan &3Molten Plastic&r (Plastik Cair)."]
	quest.39F142224D5210A9.quest_subtitle: "Bio/Diesel"
	quest.39F142224D5210A9.title: "Biodiesel"
	quest.39F9C825B03DA317.quest_desc: ["&8Aerial Interface&r bekerja sebagai link antara storage internal sendiri dan Inventory kamu. Pada dasarnya apapun yang masuk ke sana, masuk ke kamu. \\n\\nKamu butuh seluruh assembly line buat craft ini, Quest harusnya bantu kamu!"]
	quest.39F9C825B03DA317.title: "&8Aerial Interface"
	quest.3A03852E282DAA4D.quest_desc: ["&#ED8055Electrolyzer&r mampu memberikan ledakan energi yang cukup pada material sehingga mereka terurai menjadi sumber daya yang lebih fundamental."]
	quest.3A0C8BCE197A448B.quest_desc: ["&#827AFFStyrene-Butadiene&r dapat dicampur dengan &#9683F7Lead Tiny Dust&r atau &#FEA8FFChromium Tiny Dust&r untuk mendapatkan &#A1A1A1Styrene-Butadiene Rubber&r."]
	quest.3A1D07AED2A841E4.quest_desc: ["Membakar item secara otomatis di dalam Tas."]
	quest.3A1D07AED2A841E4.quest_subtitle: "Otomatis"
	quest.3A1D07AED2A841E4.title: "&eAuto-Smelting Upgrade"
	quest.3A2047CC0F59C6CC.quest_desc: ["Armor fase akhir (Late game) untuk mod &a&lRoots Classic&r."]
	quest.3A2047CC0F59C6CC.quest_subtitle: "17"
	quest.3A2047CC0F59C6CC.title: "&aWildwood Gear"
	quest.3A2249D94C019F0E.quest_subtitle: "Silver Lime + Cherry"
	quest.3A3ED88027331A6C.quest_desc: ["&eCharm of Keeping III&r bekerja sama seperti Charm of Keeping lainnya, namun mencegahmu kehilangan seluruh barang di inventaris."]
	quest.3A3ED88027331A6C.title: "&eCharm of Keeping III"
	quest.3A471716A29F5172.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memberikan Elytra kepada pemain, perlu dicatat Elytra yang diberikan oleh upgrade ini dipengaruhi oleh upgrade Kecepatan Jalan dan Kecepatan Lari."
	]
	quest.3A4A8EAA3022C7BA.quest_desc: ["Kincir Air adalah salah satu Mesin yang bisa kita gunakan untuk Dinamo Kinetik. \\n\\nIni jauh lebih kompak tetapi juga mahal, dibandingkan dengan Kincir Angin. \\n\\nUntuk menggunakannya, diperlukan &9Air&r mengalir di atas Kincir Air. Semakin banyak &9Air&r di sekitarnya, semakin cepat! Pastikan &9Air&r tidak mengalir di 2 arah berbeda! \\n\\nLebih kompak berarti kita bisa menempatkan 3 Kincir Air pada 1 Dinamo Kinetik untuk mendapatkan lebih banyak Energi."]
	quest.3A4C17878FC8315B.quest_desc: ["&6Allthemodium Furnace&r hampir sama kayak Netherite Furnace. Kamu butuh ini buat craft &3Vibranium Furnace&r."]
	quest.3A4C17878FC8315B.title: "&6Allthemodium Furnace"
	quest.3A4C62865C7CC862.quest_desc: ["&bTangki Cairan&r bisa menampung &bCairan&r. Seperti Peti, tapi untuk &9Air&r dan sejenisnya! \\n\\nKamu hanya bisa memasukkan &bCairan&r dengan Ember, tapi dengan &bPipa&r kamu bisa memasukkan dan mengeluarkan &bCairan&r dari mereka. \\n\\nSetiap &bTangki Cairan&r bisa menampung 8 Ember atau 8000mB &bCairan&r. Tapi angka itu akan bertambah saat digabungkan! \\n\\nYa, kamu dengar benar! Kita bisa menaruh beberapa &bTangki Cairan&r bersebelahan untuk menggabungkan Inventaris. Bisa ditumpuk vertikal hingga 32, atau dibuat 2x2 maupun 3x3."]
	quest.3A4C62865C7CC862.title: "&bTangki Cairan"
	quest.3A79E24283523E58.quest_subtitle: "Spruce + Birch"
	quest.3A85110725E81CDF.quest_desc: ["Jika kamu pernah bermain &2&lMinecraft&r sebelumnya, kamu harus tahu apa itu Armor dan apa fungsinya! \\n\\n&lIron's Spells&r menambahkan jenis Armor mereka sendiri juga. \\n\\nIni bekerja seperti Armor normal tapi masing-masing akan memberikan boost berbeda untuk kekuatan magismu. Seperti &3Spell Power&r yang lebih tinggi, lebih banyak Mana, dan bahkan boost Elemental."]
	quest.3A85110725E81CDF.title: "&lArmor"
	quest.3A9AC6AB4407DC32.quest_desc: ["Meskipun tidak semua resep butuh komponen yang sama, kamu bisa menyusun &3Assembly Line&r milikmu dengan semua alat terpasang. Contoh setup &3Assembly Line&r sederhana yang bisa dipakai untuk apa saja ditunjukkan pada gambar di bawah. Baca quest untuk tiap komponen untuk info penting tentangnya.\\n\\nSpeed Upgrade membuat proses ini jauh lebih cepat!"]
	quest.3A9AC6AB4407DC32.quest_subtitle: "Beberapa Perakitan Dibutuhkan"
	quest.3A9AC6AB4407DC32.title: "Menggunakan Assembly Line"
	quest.3AA4D1B60E4E71A5.quest_desc: ["Semua struktur &cmultiblock&r ditentukan oleh &ehatches&r yang dipasang di dalamnya. Meng-upgrade &ehatches&r ini pada &cmultiblock&r akan meningkatkan performa mesin secara keseluruhan."]
	quest.3AA836E8EDB52097.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_lapis.png width:100 height:150 align:center}"]
	quest.3AA836E8EDB52097.title: "&9Lapis Lazuli&r"
	quest.3AAB71E9BDFD4C1E.quest_desc: ["Gak ada tekanan! Ya sebenernya kamu butuh banyak banget Tekanan pake &4&lPneumaticCraft&r. \\n\\nItu kira-kira tentang apa mod ini..."]
	quest.3AAB71E9BDFD4C1E.title: "&4&lPneumaticCraft"
	quest.3AB0822F02350DA3.quest_subtitle: "Damage Tak Terbatas"
	quest.3ABE7074E500494D.quest_desc: ["&7Steel&r (Baja) digunakan untuk sebagian besar mesin di mod &5&lMekanism&r... plus bisa jadi Armor juga, keren kan!"]
	quest.3ABE7074E500494D.quest_subtitle: "20"
	quest.3ABE7074E500494D.title: "&7Steel Armor"
	quest.3AC03D1FA5C341A7.quest_desc: ["Recrystallizer memungkinkanmu menggabungkan berbagai kristal untuk membuat kristal baru yang digunakan untuk membuat senjata, alat, dan armor."]
	quest.3AC03D1FA5C341A7.title: "Recrystallizer"
	quest.3ACC27B786CDCF22.quest_desc: ["Sebuah &#3ABEC7Electric Compressor memungkinkanmu mengubah &#CE5ADBTungsten Tiny Dust&r menjadi &#AF22BFTungsten Nugget&r."]
	quest.3AD4367855B3E595.quest_subtitle: "Tingkat: &b4"
	quest.3ADC0CBB059FF927.quest_desc: ["Untuk menggunakan ini: 1. Taruh di tangan kiri 2. Harus waktu siang hari 3. Harus terpapar langit langsung. \\n\\nLalu kamu akan mendapatkan efek Regeneration, Saturation, Speed, Haste, dan Resistance. Ia juga akan memperbaiki durabilitas Armormu. \\n\\nSetelah habis digunakan, ia akan masuk masa tunggu selama 10 menit."]
	quest.3ADC0CBB059FF927.title: "&eEssence of Radiance"
	quest.3ADCAD65EA6900BA.quest_desc: ["&2Archaeology&r memungkinkan pemain menemukan item di dalam block &aSuspicious&r seperti Sand dan Gravel.\\n\\nBlock ini bisa ditemukan di berbagai struktur seperti Warm Ocean Ruins, Desert Pyramids, Desert Wells, dan &eTrail Ruins&r.\\n\\nUntuk mengungkap item dari block Suspicious, perlu membuat &aBrush&r untuk menyingkirkan block dan mengungkap item."]
	quest.3ADCAD65EA6900BA.title: "&2Archaeology&r!"
	quest.3AE0198177A8E91B.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_coast.png width:100 height:150 align:center}"]
	quest.3AE0198177A8E91B.quest_subtitle: "Shipwrecks dan Buried Treasure"
	quest.3AE0198177A8E91B.title: "Coast Armor Trim"
	quest.3AE1811C32B94A66.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memadamkan pemain jika mereka terbakar, memiliki cooldown."
	]
	quest.3AF1DC02E9A0010C.quest_desc: ["&cPressurized Tubes&r bakal pindahin hampir semua hal yang nggak bisa dipindahin pipa lain! &cChemical&f, &cPigment&f, dan &cInfuse Type&r semua dipindahin pakai &cPressurized Tubes&r. \\n\\nBiar bisa masukin &cChemical&r ke &5Mesin&r, kita harus ganti setelan Config di dalam &5Mesin&r-nya. Ada di pojok kiri atas GUI mesin, Side Configs. Harus diset ke Auto-Eject biar bisa keluarin hasil! \\n\\nKamu bisa bikin ini pakai 2 &8Steel Ingot&r dan satu kaca, kaca apa aja! Terus upgrade pakai 8 &cTubes&r dan satu Control Circuit. \\n\\n&a&lBasic&r: nampung 4 Bucket kimia dan pindahin 750mB tiap Tick. \\n&c&lAdvanced&r: nampung 16 Bucket kimia dan pindahin 2 Bucket tiap Tick. \\n\\n&b&lElite&r: nampung 256 Bucket kimia dan pindahin 64 Bucket tiap Tick. \\n\\n&d&lUltimate&r: nampung 1,024 Bucket dan pindahin 256 Bucket tiap Tick."]
	quest.3AF1DC02E9A0010C.quest_subtitle: "Kimia, Pigmen, Tipe Infuse"
	quest.3AF1DC02E9A0010C.title: "&cPressurized Tubes"
	quest.3AF2BC9A0E298882.quest_desc: ["Dengan &8Paduan Andesit&r kita sekarang bisa membuat &8Casing Andesit&r. \\n\\nAmbil kayu, Kupas dengan Kapak, lalu Klik Kanan Kayu Terkupas tersebut dengan &8Paduan Andesit&r. \\n\\nItu akan menghasilkan &8Casing Andesit&r! \\n\\n&8Casing Andesit&r akan dibutuhkan untuk sangat, sangat, sangat banyak &6Mesin&r! Dan terlihat bagus untuk dekorasi."]
	quest.3AF2BC9A0E298882.title: "&6&lMesin"
	quest.3AF30E1EC163E2E3.quest_subtitle: "Berikan Diamond Bee sebuah Sapphire"
	quest.3AF30E1EC163E2E3.title: "Sapphire Bee"
	quest.3AF7446592D19FA6.quest_desc: ["&eRegalium&r adalah padanan Emerald di dimensi &2&lUndergarden&r. \\n\\nIa tidak bisa dibuat menjadi armor atau peralatan, tapi bisa digunakan untuk barter dengan para &2Stoneborn&r untuk mendapatkan item lainnya."]
	quest.3AF7446592D19FA6.title: "&eRegalium&r"
	quest.3B062B9EC2CEF592.quest_desc: ["&4Mega Exporter&r memiliki 54 slot filter, bekerja 8x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.3B062B9EC2CEF592.title: "&4Mega Exporter"
	quest.3B1CDC2DD05CAE80.quest_desc: ["&#F36EF5PolyVinyl Chloride&r digabung dengan &#6EBAF5Platinum Plate, &#C4C362Cadmium Battery&r, &#F7BB57Annealed Copper Cable&r, dan &#57BFF7Digital Circuit Board&r akan menghasilkan &#EBE56EProcessing Unit Board&r."]
	quest.3B3B38B17CF5D81C.quest_desc: ["&ePort Kodok Paket&r adalah &6Mesin&r yang lucu dan berguna untuk memadukan &ePaket&f dan &8Konveyor Rantai&r! \\n\\nPertama, Klik Kanan bagian &8Rantai&f pada &8Konveyor Rantai&r dengan &ePort Kodok&r di tangan, ini akan mengaturnya sebagai tujuan &ePort Kodok&r. \\n\\nSetelah dipasang, kita bisa mengatur GUI-nya. Di sini kita bisa mengubah nama Alamat, menentukan apakah ia hanya menerima dan mengirim &ePaket&r atau hanya mengirim &ePaket&r. \\n\\nMereka punya 18 Slot untuk menampung &ePaket&r. \\n\\nKalau Alamat &ePaket&r tidak cocok dengan Alamat yang kamu berikan ke &ePort Kodok&f, maka &ePaket&r akan diteruskan ke &8Konveyor Rantai&r. \\n\\nKalau cocok, &ePaket&r akan masuk ke &ePort Kodok&r. Kalau tidak ada Alamat yang cocok, &ePaket&r akan terus berputar! \\n\\n&ePaket&r juga bisa secara otomatis dikirim dan diambil dari &ePort Kodok&r menggunakan &eCorong&f dan &eSabuk&r."]
	quest.3B3B38B17CF5D81C.title: "&ePort Kodok Paket"
	quest.3B3BD39BA02DCA13.quest_desc: ["Dengan &6Pocket Piston&r, seranganmu akan mementalkan musuh jauh lebih jauh! \\n\\nKira-kira mana yang menang ya, &6Pocket Piston&r atau &7Steadfast Boots&r?"]
	quest.3B3BD39BA02DCA13.quest_subtitle: "Tangan"
	quest.3B3BD39BA02DCA13.title: "&6Pocket Piston&r"
	quest.3B3E3D81843BB358.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Meningkatkan kecepatan lari."
	]
	quest.3B3F1DE1AF6EBC1E.quest_subtitle: "+10 Kekuatan"
	quest.3B42CCC19D23EC6D.quest_desc: ["Tingkat kedua dari komponen penyimpanan, menyediakan &e4.096&f byte penyimpanan."]
	quest.3B42CCC19D23EC6D.quest_subtitle: "x4"
	quest.3B42CCC19D23EC6D.title: "Komponen Penyimpanan 4k"
	quest.3B4511E7DC788AB3.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_tenacious.png width:100 height:150 align:center}"]
	quest.3B4511E7DC788AB3.title: "&dTenacious Petal&r"
	quest.3B4BF42C55C8BBBF.quest_desc: ["Sebel nggak sih pas lagi hancurin blok tapi jatuhnya jauh dari jangkauan? \\n\\nTenang saja, sekarang ada &4Magnet&r! Cukup Klik Rikan saat memegang &4Magnet&r untuk menyalakannya. Setelah itu, semua item dan blok yang jatuh dalam radius 5 blok akan tertarik kepadamu. \\n\\nKamu juga bisa memasang &4Magnet&r di slot Curios agar tetap aktif! \\n\\nJika ingin mematikannya (biasanya saat di dekat Mob Farm), cukup Klik Kanan lagi. \\n\\nMagnet ini juga bisa di-upgrade untuk menambah jangkauannya!"]
	quest.3B4BF42C55C8BBBF.title: "&l&9Simple &4Magnets"
	quest.3B4CEE8A8CE0D6CB.quest_desc: [
		"Hampir sampai! Tier 7. 210 Draconium Ingot dan 328 Redstone Blocks!"
		"{image:atm:textures/questpics/draconic/draconic_core_7off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_7on.png width:100 height:100 align:1}"
	]
	quest.3B4CEE8A8CE0D6CB.quest_subtitle: "Menyimpan: 2,140,000,000,000 RF"
	quest.3B4CEE8A8CE0D6CB.title: "Tier 7"
	quest.3B5095CEDD9FB323.quest_subtitle: "Dibuat dengan Energizer"
	quest.3B5095CEDD9FB323.title: "Energized Steel Bee"
	quest.3B542DC05240242C.quest_subtitle: "&f6 &cAttack Damage"
	quest.3B560B2ECE331CAF.quest_desc: ["Ini adalah Pillar Cap Tingkat 3 untuk Starlight Charger."]
	quest.3B560B2ECE331CAF.title: "Pillar Cap Starlight Charger Tingkat 3"
	quest.3B570B3DB5F6D2CB.quest_subtitle: "Upgrade Penyimpanan x16"
	quest.3B570B3DB5F6D2CB.title: "&eGold Upgrade&r"
	quest.3B577572FA7A413E.quest_desc: ["&3Wrath of the &eDesert&r adalah gabungan dari &3Cursed Bow&r dan &eSandstorm in a Bottle&r. \\n\\nBusur ini tidak menembakkan anak panah biasa, melainkan &3Cursed &eSandstorm&r! \\n\\nTepatnya tiga buah badai pasir sekaligus! \\n\\nIa juga tidak butuh anak panah untuk menembak, yang tentu saja sangat praktis."]
	quest.3B577572FA7A413E.title: "&3Wrath of the &eDesert"
	quest.3B5DEB942752B3BF.quest_desc: [
		"Semua resep punya requirement energi &#DE552Cminimum&r. Ini bisa dilihat dengan hover di upgrade di halaman resep. "
		""
		"Requirement energi ini bisa dipenuhi dengan kasih mesin upgrade yang sesuai."
		""
		"{@pagebreak}"
		"1. &n&#A839EDRunic Attuned Crystal&r dari &#39EDA5Forbidden and Arcanus&r. Ini akan tambah &#EDE02F512 EU/t&r kapasitas. Ini skip progres &#EDA439Modern Industrialization&r."
		""
		"2. &n&#2278F2Upgrade Apapun&r dari &#EDA439Modern Industrialization&r. Upgrade berbeda akan nambah kapasitas energi dengan jumlah berbeda. "
		""
		"Basic upgrade tambah &#EDE02F2 EU/t&r, Advanced tambah &#EDE02F16 EU/t&r, Turbo tambah &#EDE02F64 EU/t&r, Highly Advanced tambah &#EDE02F512 EU/t&r dan Quantum tambah &#EDE02F1,000,000,000 EU/t&r.  "
	]
	quest.3B5DEB942752B3BF.quest_subtitle: "Automatic Hephaestus Forge gak kerja tanpa upgrade"
	quest.3B5DEB942752B3BF.title: "Upgrade"
	quest.3B6F1BD64C0C570F.quest_desc: ["Seperti wind generation ini akan memberikan banyak power tanpa memberikan resource apapun. Satu-satunya kekurangan di sini harus siang hari. "]
	quest.3B6F1BD64C0C570F.title: "Solar Power"
	quest.3B6F723B03C4BF55.quest_desc: ["Digestion (pencernaan/pengolahan kasar) adalah cara kita mengubah &3Alchemical Niter&r ke bentuk yang berbeda. \\n\\nPertama kita butuh Purified Gold yang dibuat dengan memasukkan Emas, &bAlchemical Salt&r, dan &9Air&r ke dalam Digestion Vat, lalu Shift+Klik Rikan untuk menutupnya (mirip Fermentation Vat). \\n\\nLalu kita bisa menggabungkan 4 buah &3Alchemical Niter&r dengan Purified Gold dan &dSal Ammoniac&r untuk naik ke Tier lebih tinggi, atau sebaliknya untuk turun ke Tier lebih rendah."]
	quest.3B6F723B03C4BF55.title: "Digestion Vat"
	quest.3B7BB08D6AA2E7FE.quest_desc: [
		"Sekarang &cRed Super Candle&r akhirnya terlihat serasi di sini! Kita tahu ini yang &cMerah&r dari &cBunga Merah&r dan &cRed Luminescent Ancient Wax&r. \\n\\nBerpetualanglah melalui &cruangan merah membara&r untuk sampai ke &cRed Essence&r. \\n\\nLusinan mob pemarah yang berbeda akan muncul: Serigala, Beruang Kutub, dan Hoglin. Kalahkan mereka semua untuk menang!"
		"{image:atm:textures/questpics/bumblezone/bumble_red1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_red2.png width:200 height:100 align:center}"
	]
	quest.3B7BB08D6AA2E7FE.title: "&cRed Sempiternal Sanctum&r"
	quest.3B84215240D9F2CB.quest_desc: ["&3Security Manager&r memungkinkanmu memberikan hak akses dan perizinan kepada pengguna di dalam jaringanmu.\\\\n\\\\nSaat dipasang, kamu akan butuh &3Security Card&r untuk setiap pemain yang ingin kamu atur izinnya. Jika tidak ada kartu, semua orang punya akses penuh.\\\\n\\\\nUntuk membatasi izin bagi pemain yang belum terdaftar, atur sebuah kartu yang tidak terikat ke pemain mana pun dan masukkan ke dalam manager. Orang yang memasang &3Security Manager&r akan selalu memiliki akses penuh."]
	quest.3B84215240D9F2CB.quest_subtitle: "Amankan Grid-mu!"
	quest.3B84215240D9F2CB.title: "&3Security Manager"
	quest.3B884E05AE2EEBFC.quest_subtitle: "Tingkat: &c5"
	quest.3B88D58B11B5DC78.quest_subtitle: "Tingkat: &54"
	quest.3B936CA3F0F7B26B.quest_desc: ["&l&7Digital Miner&r adalah 3x2x3... Blok? &5Mesin&r? \\n\\nKita semua tau Void Miner tapi itu aneh! Ini nambang Blok beneran! \\n\\nKita bisa Klik Kanan buat buka GUI-nya, di sini kita liat banyak banget! Tombol, Layar, bahkan Slot! \\n\\nSlot adalah tempat &eItem&r hasil Nambang. Layar bakal kasih tau kalo udah siap, gak punya &aEnergi&r cukup, atau berapa Blok yang bisa ditambang. Juga punya Tombol di Layar buat Auto-Eject, nyedot Blok yang ditambang, bahkan pake Silk Touch! \\n\\nTombol bakal lakuin yang lain! Kita bisa pake Visual buat liat area yang bakal ditambang. Atau bahkan tambahin Upgrade buat bikin lebih bagus! \\n\\nStart: bakal suruh &l&7Digital Miner&r mulai Nambang! Gak bakal kerja kalo &5Mesin&r belom siap. Stop: bakal suruh &l&7Digital Miner&r berhenti Nambang. Config: set Filter, ini penting. Reset: rusak. \\n\\nConfig sisi kiri set Working Area buat Nambang. Seberapa jauh, tinggi, dan rendah! Sisi kanan buat Filter &eItem&r yang beneran. Filter sama kayak &e&lQIO&r &eImporter &fdan &eExporter&r, cek Quest mereka buat belajar cara set! \\n\\nLo juga bisa pake Inverse Mode buat Blacklist Filter. Plus Replacement yang bakal ngisi Blok yang ditambang. "]
	quest.3B936CA3F0F7B26B.title: "&l&7Digital Miner"
	quest.3B99290BE63F2968.quest_subtitle: "Memadatkan Carbon Dust"
	quest.3B9D9CB589DB2003.quest_desc: [
		"Mesin &#71EBB4&nModern Industrialization&r bekerja secara berbeda dari mod lain. Semua mesin memiliki &#E5EB71pengali efisiensi&r; ini akan naik seiring mesin mengerjakan resep yang sama secara terus-menerus. &#E5EB71Efisiensi&r meningkatkan &#E5EB71kecepatan&r mesin. &#E5EB71Efisiensi&r akan tereset jika resep diganti."
		""
		"Kamu disarankan menggunakan 1 mesin untuk 1 resep guna memproduksi komponen secara pasif. Beginilah cara mod ini seharusnya dimainkan. Upgrade akan membuat sistem jadi lebih baik. Ini akan dibahas di masa depan."
		""
		"{image:atm:textures/questpics/modernindustrialization/prod_line.png width:100 height:100 align:center}"
		""
		"{@pagebreak}"
		"Semua mesin dari mod ini menerima FE sebagai tenaga. &c16 FE&r dikonversi menjadi &#E1EB591 EU&r tenaga."
	]
	quest.3B9D9CB589DB2003.quest_subtitle: "Ini akan membantu"
	quest.3B9E6FBEDABA4F7E.quest_desc: [
		"Jauh di dalam &6&lDinding Sarang&r kamu mungkin menemukan Gua &6Madu&r! \\n\\nDi sini kamu bisa menemukan cairan &6Madu&r, &5Kristal Madu&r, Brood Block, dan bahkan Beehemoth! \\n\\nSegala hal yang berhubungan dengan &6Madu&r. "
		"{image:atm:textures/questpics/bumblezone/bumble_cave.png width:200 height:100 align:center}"
	]
	quest.3B9E6FBEDABA4F7E.title: "Ruang Gua &6Madu&r"
	quest.3BA4504DEFB87264.quest_desc: ["Bekerja mirip dengan &lSimply Lights&r, versi Inverted akan menyala saat tidak ada sinyal Redstone yang diberikan, sementara yang normal hanya akan bekerja dengan Redstone. \\n\\nLampu-lampu ini harus ditempelkan ke dinding untuk bisa diletakkan."]
	quest.3BA4504DEFB87264.title: "Lampu Dinding"
	quest.3BAEF1A3FDB818A4.quest_subtitle: "European Larch + Red Maple"
	quest.3BB0926C4C00BE1D.quest_desc: ["Pernah ngerasa sebel pas lagi asyik terbang pake Jetpack tiba-tiba mati karena abis batre? Nah, kejadian itu nggak bakal keulang lagi! \\n\\nKamu mungkin harus bikin semua tingkatan Jetpack sebelumnya, sebuah &6&lATM Star&r, plus item-item mahal lainnya, tapi ini sangat worth it! \\n\\nTinggal pakai dan terbang sesukamu, nggak perlu dicas-cas lagi."]
	quest.3BB0926C4C00BE1D.title: "&5&lCreative Jetpack"
	quest.3BB3AA6C29285837.quest_desc: ["Buff:\\n\\n - Absorption II (3:00)\\n - Speed II (3:00)"]
	quest.3BB3AA6C29285837.title: "&2Apel Prudentium"
	quest.3BC0A50886A3222B.quest_desc: ["ATM10 adalah pack 'kitchensink' yang membebaskanmu menjelajahi dunia modded Minecraft dengan caramu sendiri!\\n\\nJika kamu memiliki pertanyaan atau kendala, jangan ragu untuk bergabung ke Discord ATM!"]
	quest.3BC0A50886A3222B.title: "&dSelamat Datang di All The Mods 10!"
	quest.3BC94B0B922C0708.quest_desc: ["Ini adalah bahan crafting untuk barang yang melakukan importing, baik itu item, fluid, atau energy."]
	quest.3BD304D851F49EC0.quest_subtitle: "Elderberry + Silver Fir"
	quest.3BD73FEAE853D350.quest_desc: ["Pernah benci betapa lambatnya berjalan di atas &bEs&r kecuali pakai Perahu? Yang sejujurnya masih tidak masuk akal bagiku! &bIce Skates&r mengubah itu; sekarang kamu berakselerasi di atas &bEs&r saat memakainya. Kamu bisa meng-upgrade-nya untuk akselerasi yang lebih kencang! \\n \\nSetelah di-upgrade, kamu bisa mendapatkan kemampuan kedua yang memungkinkanmu melukai mob dengan cara menabrak mereka saat memakai &bIce Skates&r."]
	quest.3BD73FEAE853D350.quest_subtitle: "Ditemukan di Desa di Taiga atau Snowy Taiga"
	quest.3BD73FEAE853D350.title: "&bIce Skates"
	quest.3BDB94F17765EE77.quest_desc: ["Jika kamu ingin menghasilkan daya dalam jumlah masif, kamu bisa mulai dengan meningkatkan skala dari bagian &9Mid Game Power&r. Buat &aReaktor&r yang lebih besar. Upgrade &9Thermo Generator&r kamu ke tingkat Nitro. Lakukan sesukamu.\\n\\nNamun, terkadang kamu butuh daya yang lebih besar lagi."]
	quest.3BDB94F17765EE77.quest_subtitle: "Daya Lebih Dari yang Kamu Butuhkan"
	quest.3BDB94F17765EE77.title: "Opsi Daya End Game"
	quest.3BE3B54B4A681668.quest_desc: ["Di sinilah keputusannya, apakah kamu suka menyakiti musuhmu seperti Truk tapi jauh lebih lambat? Atau kamu lebih suka jadi orang normal yang pakai Sword."]
	quest.3BE3B54B4A681668.title: "Chaotic Axe"
	quest.3BE5CD0C7CC4BCC6.quest_desc: [
		"Soul Lava adalah bagian dari &6&lAllthemodium&r. Bisa ditemuin di &b&lThe Other&r jarang banget underground, atau umum di Piglich Village!\\n\\nKita harus ambil Bucket of &9Soul Lava&r dan tuangin ke Ghostly Bee egg buat bikin &9Soul Lava Bee egg&r.\\n\\nTerus, kamu harus squish mereka atau poke buat DNA-nya buat bikin Spawn Egg!\\n"
		"{image:atm:textures/questpics/soul_lava_process.png width:100 height:100 align:center}"
	]
	quest.3BE5CD0C7CC4BCC6.title: "Spawn Egg &9Soul Lava Bee&r"
	quest.3BF1900346772703.quest_subtitle: "Tingkat: &f2"
	quest.3BF32843DE3CF3C2.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kecepatan Lari"
		"- Kecepatan Jalan"
		"- Kecepatan Berenang"
		"- Umpan"
	]
	quest.3BF5B8DE7A1CC4D7.quest_desc: ["Kalau kamu mau gear yang bagus, kamu butuh &6&lApotheosis Gear&r, dan semuanya dimulai dari sebuah &aGem&r! \\n\\n&aGem&r adalah drop langka dari Mob mana pun, dan dijamin drop dari &4Invader&r. \\n\\nKamu akan belajar lebih banyak soal itu nanti, untuk sekarang, habisi dulu mob-mob itu!"]
	quest.3BF5B8DE7A1CC4D7.title: "&6&lPetualangan Apotheosis"
	quest.3C0671BE5E94730E.quest_desc: [
		"&4&lCyclops&r bisa ditemuin di atau sekitar &4Gua&r mereka. \\n\\nMereka makhluk raksasa mirip Manusia. Sekitar 10 Blok tingginya dan cuma pake rok Wool. Kayak Manusia mereka bisa spawn dengan Jenggot atau engga, kayak beberapa Manusia dan bukan yang lain mereka cuma punya 1 Mata, dan pasti beda dari semua Manusia mereka punya Tanduk di kepala. \\n\\n&4&lCyclops&r punya 650 &4Hearts&r dan 20 &7Armor Points&r. \\n\\nMereka cuma punya satu Serangan dan itu angkat kamu dan Gigit kepala kamu. Ya, Serangan ini kasih Damage gede banget dan ngabaiin Armor. \\n\\nMereka juga mungkin nyerbu kamu kalo kamu jauh. Mereka bisa lari tembus beberapa Blok kayak Daun tapi sisanya mereka bakal nyangkut. \\n\\nSatu-satunya Serangan mereka itu jarak deket banget, jadi paling baik lawan mereka dari jarak jauh pake Busur atau Sihir! Kalo kamu jago nembak pake Busur, kamu bisa Hit mereka di &4Mata&r (kayaknya lebih deket ke Tanduk) buat Buta mereka! \\n\\nIni bakal kasih 10 &4Hearts&r Damage dan bakal bikin mereka susah nemuin kamu."
		"{image:atm:textures/questpics/iceandfire/iaf_cyclops.png width:100 height:200 align:center}"
	]
	quest.3C0671BE5E94730E.title: "&4&lCyclops"
	quest.3C0F8EB779E56F2A.quest_desc: ["Ini dia Crab Claw (Capit Kepiting) dari Mob Vote! \\n\\nHanya saja kepiting yang harus kamu bunuh jauh lebih besar... dan lebih jahat... \\n\\nChitin Claw dijatuhkan oleh Clawdian. \\n\\nSaat dipakai, kamu akan mendapatkan tambahan jarak jangkauan Blok (Block Reach) dan Entitas (Entity Reach). Jadi kamu bisa menaruh blok dan menghajar mob dari jarak yang lebih jauh!"]
	quest.3C0F8EB779E56F2A.title: "&9Chitin Claw"
	quest.3C2F5AB815A6C949.quest_desc: ["Untuk membuat &2Infused Iron Ingot&r, letakkan Iron Ingot di atas &2Natural Altar&r.\\n\\nProses ini akan lebih cepat dibanding dengan &6Tainted Gold&r."]
	quest.3C3FE45CEF5E242B.quest_desc: ["Sementara &aReprocessor Part&r lainnya punya tempat wajib saat build, tiga part ini bisa ditaruh di sisi vertikal manapun selama bukan di frame!\\n\\n&cPower Port&r dipakai buat kasih power ke multiblock machine untuk process waste.\\n\\n&9Fluid Injector Port&r dipakai buat inject liquid yang diperlukan, tergantung tipe waste yang diinject. Untuk Cyanite, artinya air!\\n\\n&aOutput Port&r dipakai buat output material yang sudah direprocess. Kamu bisa klik kanan untuk ambil material langsung, atau pompa keluar untuk automasi."]
	quest.3C413D4A210A3BDE.title: "Lebah Madu"
	quest.3C54C36CE97A48DC.quest_desc: ["Dropper menjatuhkan,\\nDispenser mengeluarkan, \\ndan Flinger melontarkan! \\n\\nAlih-alih menaruh item dengan sopan dari Buffer, Flinger Module akan melemparnya. Seberapa jauh? Kamu yang tentukan!"]
	quest.3C5734448FEC128B.quest_desc: ["Tongkat Divinasi termurah, Glass Divination Rod. \\n\\nAlat ini bisa menemukan semua bijih (ore) yang bisa ditambang dengan Beliung Batu (Stone Pickaxe). Jadi hanya sebatas Tembaga, Batu Bara, dan Besi. Tidak lebih dari itu."]
	quest.3C5A5432E6B1EF9E.quest_desc: [
		"Kita sudah dapat Spawner, kita sudah dapat cara pindahin Mob yang spawn, sekarang gimana dapet &4Blood&r dari mereka? \\n\\nKita bisa pakai Spike atau Mob Masher untuk bunuh mereka normal tapi kalau mau &4Blood&r dari mereka kita harus pakai &4Powered Sanguinary Pedestal&r dengan &7Spiked Plate&r di atasnya! \\n\\nSaat di atas &4Pedestal&r, &7Spiked Plate&r akan kasih damage ke Mob yang kena mereka dan deposit &4Blood&r itu ke &4Pedestal&r. Semakin banyak &4Health&r Mob, semakin banyak &4Blood&r yang bisa didapat! \\n\\n&4Blood&r akan dalam Fluid Form dan bisa dipindah dengan Pipe dari &4Pedestal&r ke &c&lForge&r kita."
		"{image:atm:textures/questpics/forbidden/forbidden_pedestal.png width:100 height:100 align:center}"
	]
	quest.3C5A5432E6B1EF9E.title: "Auto &4Blood&r"
	quest.3C74DAE7EC844A98.quest_desc: ["Lunar Berry adalah Sumber Makanan yang sangat bagus, plus sangat gampang didapet! \\n\\nMereka spawn numbuh ke bawah dari Lunar Tree Leaves, kamu bisa petik Berry dari Vine kayak Glow Berry. \\nCuma yang ini kasih lebih banyak Food Point dan Saturation!"]
	quest.3C7C9EE57AD00A76.quest_desc: ["Ini bisa di-craft?!?!?! Gue selalu loot buat dapetin. \\n\\nKamu bisa ganti apakah mereka ngejar target atau terbang lurus. Waktu homing kamu bisa ganti antara pengaturan &cSpeed&r, &6Damage&r, dan &aTurn Speed&r."]
	quest.3C7C9EE57AD00A76.title: "&cMicromissile"
	quest.3C8724C3A9459507.quest_desc: ["Yeti Armor bisa dibuat menggunakan Alpha Yeti Fur."]
	quest.3C8724C3A9459507.title: "Armor Yeti"
	quest.3C892B33758B7BA6.quest_desc: ["&dRoda Gigi&f dan &dRoda Gigi Besar&r bisa saling berinteraksi untuk mengubah Kecepatan dan Stres! \\n\\nKalau kamu menghubungkan &dRoda Gigi&r secara diagonal dari &dRoda Gigi Besar&r, &dRoda Gigi&r akan berlipat dua kecepatannya! Ini karena &dRoda Gigi Besar&r punya lebih banyak gigi, jadi butuh lebih lama untuk satu &dRotasi&r penuh. \\n\\nIni juga berlaku sebaliknya — kalau kamu menaruh &dRoda Gigi Besar&r diagonal terhadap &dRoda Gigi&r, &dRoda Gigi Besar&r akan berputar setengah Kecepatan. \\n\\nIni juga mempengaruhi Satuan Stres dari &dRoda Gigi&r tersebut. Lebih cepat, lebih banyak Stres. Lebih lambat, lebih sedikit Stres."]
	quest.3C892B33758B7BA6.title: "Kerja Sama &dRoda Gigi&r!"
	quest.3C8C80345D3F5FE8.quest_desc: ["Pengumpul barang mengumpulkan barang dan menyimpannya ke inventori di bawahnya."]
	quest.3C8D9278B81BB37A.quest_desc: ["Kita nggak punya banyak waktu di dunia ini, ayo &eSpeed&r-up (percepat) dikit! \\n\\n&2&lReactor&r-nya nggak bakal nunggu selamanya!"]
	quest.3C8D9278B81BB37A.title: "&eSpeed &8Upgrade"
	quest.3C9539083BCC145C.quest_desc: ["Menril Bees bisa dipakai untuk mengotomasi Crystallized Menril Chunks."]
	quest.3C9539083BCC145C.quest_subtitle: "Mengotomasi Menril"
	quest.3C99017FD32B6DE2.quest_desc: ["&eCasing Kuningan&r dibuat dengan cara yang sama seperti Casing &8Andesit&r dan &cTembaga&r. Cukup terapkan &eItem&r tersebut ke Kayu Terkupas. \\n\\nTapi karena &eCasing Kuningan&r menghasilkan beberapa &6Mesin&r paling kuat, mendapatkannya tidak semudah &8Andesit&r atau &cTembaga&r. \\n\\nUntungnya ini &6&lATM10&r jadi kamu bisa membuat &eKuningan&r dengan banyak cara! \\n\\nTapi cara &6&lCreate&r-nya adalah dengan melempar &cIngot Tembaga&r dan &7Ingot Seng&r ke &8Wadah&r di bawah &6Pengaduk Mekanik&r, saat &8Wadah&r sedang dipanaskan."]
	quest.3C99017FD32B6DE2.title: "&eCasing Kuningan"
	quest.3C9F5EB59D72AC90.quest_desc: ["Blok Batangan Awakened Supremium dibutuhin buat craft &6Bintang ATM&r."]
	quest.3CAD0701EC16C2D8.quest_desc: [
		"Dark Swamp ada dimana-mana di dunia Starlight. \\n\\nDi sini kamu bisa nemuin banyak tanaman, hewan, dan tentu saja Mud."
		"{image:atm:textures/questpics/eternal/starlight_swamp.png width:200 height:100 align:center}"
	]
	quest.3CAD0701EC16C2D8.title: "Dark Swamp"
	quest.3CB05026BC4C5577.quest_desc: ["Untuk saat ini, kamu bisa membuat &#986FC7Blastproof Alloy Plate&r secara tidak efisien di dalam &#6F93C7Electric Compressor&r menggunakan &#3946E3Mixed Blastproof Ingot&r."]
	quest.3CB6DC5B09C62CFE.quest_desc: ["&5Ender Gate&r digunakan untuk mentransfer daya secara nirkabel ke dan dari blok yang menempel ke dalam &7Ender Network&r.\\n\\nBayangkan ini seperti titik akses nirkabel (wireless access point) untuk jaringan listrik nirkabelmu.\\n\\nCatatan: Kamu hanya bisa menambah &akapasitas penyimpanan daya&r menggunakan Ender Cell."]
	quest.3CB7884B7B32CF00.quest_desc: [
		"Mendapatkan &bEther Gas&r pertama mungkin sedikit menakutkan.\\n\\n&bEther Gas&r dibuat dari drilling Wither, menggunakan Fluid Drill dengan &5Purple Lens&r."
		""
		"Tapi jangan khawatir tentang Wither, Industrial Foregoing punya mesin untuk membantu tugas itu. &4Stasis Chamber&r adalah mesin yang membekukan di tempat apapun yang ada di atasnya di area 3x3, termasuk Wither."
		""
		"&cSemoga power tidak habis, karena kalau iya... semoga siap melawan &0Wither&c."
	]
	quest.3CB7884B7B32CF00.quest_subtitle: "Ether Gas? Huh?"
	quest.3CB7AB928D3E1CC6.quest_subtitle: "Dibuat dengan Energizer"
	quest.3CB7AB928D3E1CC6.title: "Blazing Crystal Bee"
	quest.3CB8F5F1D33C8F9F.quest_desc: ["Sama seperti quest sebelumnya, cuma lebih, jauh lebih banyak."]
	quest.3CB8F5F1D33C8F9F.title: "Wyvern Large Shield Capacity Module"
	quest.3CBB78C9B8D3665E.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Mengurangi jarak deteksi monster jahat."
	]
	quest.3CCBE9BBCA8ADA38.quest_desc: ["&d&lSuper-Critical Phase Shifter&r bakal butuh banyak banget &aEnergi&r. Maksud gue banyak banget! Ratusan Juta FE. \\n\\nGimana cara ngirimin &aEnergi&r sebanyak ini? \\n\\nKita butuh minimal 1 (disaranin 2) &dSupercharged Coil&r! \\n\\n&dSupercharged Coil&r ditaro di dalam &d&lS.P.S.&r, di &dSPS Port&r. &dPort&r bakal ngasih &dSupercharged Coil &aEnergi&r. \\n\\nTiap &dSupercharged Coil&r bisa kirim 400MFE per Tick. Dan kita butuh banyak banget buat &dAntimatter&r!"]
	quest.3CCBE9BBCA8ADA38.title: "&dSupercharged Coil"
	quest.3CD307DDD6A5F5A3.quest_subtitle: "&f4 &cAttack Damage"
	quest.3CE3D9245F8EC005.quest_desc: ["Tingkat MEGA keempat dari komponen penyimpanan, menyediakan &e67.108.864&f (65536k) byte penyimpanan."]
	quest.3CE3D9245F8EC005.quest_subtitle: "x4^3"
	quest.3CE3D9245F8EC005.title: "Komponen Penyimpanan 64M"
	quest.3CE72DAF431269CD.quest_desc: ["&#D6AC2FPolarizer&r mampu memberikan daya magnet pada material yang dimasukkan ke dalamnya."]
	quest.3CF2DFB7F0CE065B.quest_desc: [
		"&cOvercast Columns&r jauh lebih Panas dan &6Orange&r dari Biome lain di sini. \\n\\nDi sini &3Sculk&r diganti dengan &cGloomy Sculk&r dan &3Sculk Stone&r diganti dengan &cGloomslate&r. \\n\\nKamu juga akan menemukan Soul Sand/Soil plus &cMagma &fdengan &cLava&r di bawahnya. \\n\\nDengan suhu yang sangat Panas, Mob tidak akan muncul di sini secara normal, tapi ada beberapa kehidupan Tanaman! "
		"{image:atm:textures/questpics/deepndark/dnd_column.png width:200 height:100 align:center}"
	]
	quest.3CF2DFB7F0CE065B.title: "&cOvercast Columns"
	quest.3CF32F2314839B1D.quest_desc: [
		"Bosan sama budding Certus Quartz dan Entroized Fluix yang decay? Kita bisa benerin! Dengan Crystal Fixer ini, kamu bisa benerin Budding Certus Crystal pakai Charged Certus Quartz, dan Entroized Fluix pakai Ender Dust."
		""
		"Bahkan ada kemungkinan kecil bikin Flawless Budding Certus Quartz."
	]
	quest.3CF32F2314839B1D.title: "Perbaiki-Crystal-Kamu: Crystal Fixer"
	quest.3CFD27F273B97FDD.quest_desc: ["Mod &5&lApothic&r punya beberapa core, masing-masing ngerubah bagian berbeda dari &2&lMinecraft&r.\\n\\nMod Attribute dan Enchanting adalah yang kamu butuhin buat dapetin &6&lATM Star&r!"]
	quest.3CFD27F273B97FDD.title: "Mod &5&lApothic&r"
	quest.3CFD798362605880.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Membuat Panah Ramuan yang ditembakkan oleh busur punya efek Percikan, mengenai beberapa target dalam satu area."
	]
	quest.3CFE522A4B7CC2EC.quest_desc: [
		"&3Reinforced Chest&r adalah peti tahan ledakan dengan 36 slot. Tidak bisa dijadikan peti ganda. Juga berfungsi seperti Shulker Box."
		"{image:atm:textures/questpics/pneumaticcraft/reinforced_chest_ui.png width:200 height:100 align:center}"
	]
	quest.3CFE522A4B7CC2EC.quest_subtitle: "Lebih Baik dari Peti Biasamu"
	quest.3D1D5CB45D81A6E4.quest_desc: ["Mirip dengan &b&lMacaw's Doors&r, mod ini menambahkan tipe dan versi yang berbeda untuk Pintu Jebakan (Trapdoor). \\n\\nKamu ingin Trapdoor Hutan (Jungle) dengan pola Spruce? Sekarang kamu bisa membuatnya!"]
	quest.3D1D5CB45D81A6E4.title: "&b&lMacaw's Trapdoors"
	quest.3D26E7BFE0AA964A.quest_desc: [
		"Luminofish adalah ikan bercahaya yang hidup di dalam The Abyss.\\n\\nMereka fungsi kayak Ikan biasa. Kamu bisa mancing mereka, masukin ke Bucket, bahkan masak mereka!"
		"{image:atm:textures/questpics/eternal/starlight_fish1.png width:100 height:100 align:center}"
	]
	quest.3D26E7BFE0AA964A.title: "Luminofish"
	quest.3D29EF7F150F5334.quest_desc: ["&3Ender Bow&r jarang ditemukan di dalam &bAurora Palace&r.\\n\\nSaat musuh terkena anak panah dari busur ini, kamu akan bertukar posisi dengan mereka. Berhati-hatilah saat menembak sesuatu yang ada di langit!"]
	quest.3D29EF7F150F5334.title: "&3Ender Bow"
	quest.3D2A03EB2B91E9C1.quest_desc: ["Ini literally hanya Hopper yang lebih fancy. \\n\\nMenghubungkan dua Inventaris, membawa &eItem&r dari yang Atas ke yang Bawah. \\n\\n&eSelokan&r bisa saling terhubung, bahkan secara diagonal. \\n\\nKamu juga bisa menggunakannya bersama &6Kipas&r untuk melempar &eItem&r ke atas melalui &eSelokan&r!"]
	quest.3D2A03EB2B91E9C1.title: "&eSelokan"
	quest.3D2B4D9FD2086B9B.quest_desc: ["&2Fission Reactor Logic Adapter&r ,yang bakal gue panggil &2FRLA&r, dipake buat monitor sama configure &2&lFission Reactor&r pake &4Redstone&r. \\n\\nPertama, taro &2FRLA&r di salah satu dinding &2&lFission Reactor&r kayak lo taro &2Port&r. \\n\\nTerus, kita bisa Klik Kanan &2FRLA&r buat configure. \\n\\nDisabled: gak bakal interaksi sama &4Redstone&r. \\n\\nActivation: bakal nyalain &2&lReaktor&r pas dikasih &4Redstone Signal&r, dan pas gak ada &4Signal&r lagi bakal mati. \\n\\nHigh Temperature: bakal kirim &4Redstone Signal&r pas &6Temperature&r mencapai Level berbahaya. \\n\\nCritical Waste Level: bakal kasih &4Signal&r pas terlalu banyak &8Nuclear Waste&r. \\n\\nDamage Critical: bakal, kayak yang lain, kasih &4Signal&r pas &2&lReaktor&r hampir meledak! \\n\\nInsufficient Fuel: bakal kasih &4Signal&r pas mulai kehabisan &2Fissile Fuel&r."]
	quest.3D2B4D9FD2086B9B.title: "&2Fission Reactor Logic Adapter"
	quest.3D2C6FF462B17205.quest_desc: ["Damage rendah, kecepatan serangan sangat tinggi. Mengurangi waktu kebal (invincibility) target."]
	quest.3D2C6FF462B17205.quest_subtitle: "Tusuk-tusuk Manja"
	quest.3D31B94CC42BCE43.quest_desc: ["&8Tome of Extraction&r adalah buku yang kita cari-cari! Buku ini akan mengambil semua &5Enchantment&r tanpa menghancurkan item aslinya! \\n\\nUntuk membuatnya, kita harus melakukan &d&lInfuse&r pada &8Tome of Superior Scrapping&r. \\n\\nKita bisa menggunakan setup yang sama seperti sebelumnya untuk proses ini."]
	quest.3D31B94CC42BCE43.quest_subtitle: "Semua Enchantment, tidak merusak item"
	quest.3D4032E7119AF8B7.quest_desc: ["Sonar Bomb dibuat dengan Shivering Gel yang di-drop dari Crystallized Moth. \\n\\nBisa dilempar buat damage Mob (dan Player) apapun di area gede! Dia juga bakal goyangin layar player dan main sound effect keras. \\n\\nBikin pusing jadi cuma pake ke temen kamu aja!"]
	quest.3D41D0092D94636B.quest_desc: [
		"Bagaimana jika aku bilang Buah Setan itu mudah terbakar?"
		""
		"Melemparkan &cDemon's Dream Fruit&r kita ke tanah dan membakarnya akan menciptakan &dSpiritfire&r. Inilah cara kita mengubah item Overworld menjadi material &9Otherworld&r."
		""
		"Selain itu, apinya cantik."
	]
	quest.3D41D0092D94636B.title: "Api dari &9Otherworld"
	quest.3D4D88B8BE881351.quest_desc: ["Jika kamu ingin merapal mantra yang lebih hebat, kamu butuh &6Scribe's Table&r untuk membuka Glyph baru pada spellbook milikmu. \\n\\nAda 3 tingkat Glyph yang bisa dibuka, dan masing-masing membutuhkan sejumlah experience dan item. \\n\\nScribe's Table juga digunakan untuk memasang mantra ke Spell Parchment. Caranya, letakkan Spell Parchment di atas meja, pilih mantra di Spellbook, lalu tekan shift-klik kanan buku tersebut pada meja. \\n\\nUntuk membuat Glyph, klik kanan pada Scribe's Table dengan spellbook milikmu. Cari Glyph yang ingin dibuat, lalu klik Select di bagian bawah. Klik kanan meja dengan item yang dibutuhkan, dan Glyph akan tercipta. Gunakan Glyph tersebut untuk mempelajarinya. \\n\\nCatatan: Meja ini dapat menarik item dari inventaris di sekitarnya."]
	quest.3D4D88B8BE881351.quest_subtitle: "Upgrade Mantra"
	quest.3D579A1F7EFEDD5C.quest_desc: [
		"&9&lWarden&r. Boss paling sulit di &2&lMinecraft&r, tentu saja berada di Struktur paling sulit. \\n\\nDia dipanggil dari &3Sculk Shrieker&r yang diaktifkan 3 kali, atau jumlah berapa pun setelah &9&lWarden&r pertama. \\n\\nDia punya 500 &4Hearts&r dan memberikan banyak Damage baik dari memukulmu dengan tinjunya atau &bSonic Blast&r-nya! \\n\\nDia punya kelemahan, yaitu dia Buta. Dia hanya bisa menemukanmu dengan Suara, atau Bau kalau kamu cukup dekat! Jaga jarakmu, seperti 23 Block ke atas."
		"{image:atm:textures/questpics/gettingstarted/warden_roar.png width:100 height:100 align:center}"
	]
	quest.3D579A1F7EFEDD5C.title: "Kalahkan &9&lWarden&r"
	quest.3D5852E6D0ADF651.title: "Penyimpanan Antar Dimensi"
	quest.3D5F87F8E6B89C1B.quest_desc: ["&7Furnator&r akan membakar item seperti batu bara dan kayu untuk menghasilkan FE."]
	quest.3D63868AC4393EBC.quest_subtitle: "Lapis + Emerald"
	quest.3D63868AC4393EBC.title: "Experience Bee"
	quest.3D72E3E53E7306FA.quest_desc: ["&cFire Armor&r dari mod &e&lIron's Spells&r!"]
	quest.3D72E3E53E7306FA.quest_subtitle: "20"
	quest.3D72E3E53E7306FA.title: "&cPyromancer Outfit"
	quest.3D7480E4F9063E93.quest_subtitle: "Lumber + Sweat"
	quest.3D7480E4F9063E93.title: "Rancher Bee"
	quest.3D755073C56274BE.quest_desc: ["Jatuhkan item Lens di depan Atomic Reconstructor, dan saat aktif, ia bakal berubah jadi Lens of &cC&eo&al&bo&3r&r. \\n\\nJatuhkan Lens of &cC&eo&al&bo&3r&r di depannya lagi, dan saat nyala, ia bakal berubah jadi Lens of &cDetonation&r. \\n\\nTerus lakukan ini sampai kamu dapet Lens of &3Certain Death&r."]
	quest.3D755073C56274BE.title: "Lens of &3Certain Death"
	quest.3D78D9F4E8A60EDB.quest_desc: ["Resepnya saat ini cukup simpel, cuma butuh 4 &dSource Jar&r, 4 &dSource Gem Block&r, dan sebuah &6&lStar&r. Tenang, nanti bakal diubah biar lebih susah kok! \\n\\nJar ini selalu penuh &dSource&r dan bisa disambungin ke apa pun yang butuh &dSource&r. Termasuk ke multiblock &6&lATM Star&r."]
	quest.3D78D9F4E8A60EDB.quest_subtitle: "Dapetin ini duluan!"
	quest.3D78D9F4E8A60EDB.title: "&5&lCreative &dSource &fJar"
	quest.3D819550074CA376.quest_desc: ["Item harus diletakkan di sini sebelum diambil kembali."]
	quest.3D819550074CA376.quest_subtitle: "Selalu Dibutuhkan"
	quest.3D82C6639A6371CB.quest_desc: ["4 &7Quantum Core&r dan &cMundabitur Dust&r dan kamu bisa dapet &7Quantum Injector&r. \\n\\n&7Quantum Injector&r gak banyak dipakai di tahap ini tapi akan diperlukan nanti!"]
	quest.3D82C6639A6371CB.title: "&7Quantum Injector&r"
	quest.3D862A3D3F83CA26.quest_desc: [
		"&9Enchanting Apparatus&r digunakan untuk membuat berbagai item di dalam mod ini. Alat ini membutuhkan Source agar bisa bekerja.\\n\\nIni juga merupakan struktur multiblock yang menggunakan Arcane Pedestal untuk proses pembuatannya.\\n\\nMulailah dengan menaruh Arcane Core di tanah, lalu letakkan Enchanting Apparatus di atasnya. Kelilingi Apparatus tersebut dengan Arcane Pedestal.\\n"
		"{image:atm:textures/questpics/ars/enchanting_app.png width:200 height:175 align:1}"
	]
	quest.3D862A3D3F83CA26.title: "Enchanting Apparatus"
	quest.3D88FEFA4C63CB20.quest_desc: ["Quest ini dibuat oleh &6Staff AllTheMods&r, atau &2Kontributor Komunitas&r buat dipake di Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilindungi &eAll Rights Reserved&r, Quest ini gak boleh dipake di pack publik manapun yang gak dirilis sama &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyiin, kalo kamu liat ini, kamu lagi di mode editing."]
	quest.3D9964CB0440DD5A.quest_desc: ["Menjatuhkan Bara Blaze ke dalam Cairan Polimorfik akan membuat Bahan Bakar Bara Blaze Mentah. Melakukan Penyebaran Lendir dengan lendir Tingkat Dua atau lebih tinggi akan mengubah Bahan Bakar Bara Blaze Mentah menjadi Bahan Bakar Bara Blaze."]
	quest.3DA5F622E3266AE5.quest_subtitle: "Dibuat di Reprocessor"
	quest.3DA5F622E3266AE5.title: "Ridiculite Bee"
	quest.3DB5874FA93FDA50.quest_subtitle: "Elektrolisis 3 Telur Spawn Emerald Bee menjadi 1 Telur Spawn Beryllium Bee"
	quest.3DB5874FA93FDA50.title: "Beryllium Bee"
	quest.3DCD38634176BD92.quest_desc: ["Gabungkan &6Allthemodium&r &eSpell Book&r dengan Vibranium Ingot dan Template di Smithing Table.\\n\\nTemplate ini bisa didapat dari Brushing Suspicious Soul Sand di Bastion."]
	quest.3DCD38634176BD92.title: "&3Vibranium&r Spell Book"
	quest.3DCF26B53AE1EBF6.quest_desc: ["Di dalam &2Dark Forest&r, kamu akan menemukan struktur yang mengarah ke bawah tanah.\\n\\nUntuk masuk, kamu perlu meletakkan salah satu piala (trophy) bos yang sudah kamu dapatkan di atas alas (pedestal) terdekat; jangan khawatir bos mana yang kamu taruh, kamu bisa mengambilnya kembali.\\n\\nDi lapisan ke-3, kamu akan menemukan Knight Phantom. Kalahkan mereka untuk membuka bos berikutnya."]
	quest.3DCF26B53AE1EBF6.quest_subtitle: "Hutan Tergelap"
	quest.3DCF26B53AE1EBF6.title: "Hutan Kegelapan (&2Dark Forest&r)"
	quest.3DD71B6C4B80FB44.quest_desc: ["&3Eye of Curse&r akan menuntunmu ke &3Frosted Prison&r untuk melawan &3&lMaledictus&r."]
	quest.3DD71B6C4B80FB44.title: "&3Eye of Curse"
	quest.3DDB0DDA7571B2C1.quest_desc: ["&bME Level Emitter&f, saat dikonfigurasi dengan item dan jumlah tertentu, akan memancarkan sinyal redstone tergantung pada apakah item di jaringan kurang dari, lebih dari, atau sama dengan jumlah yang ditentukan.\\n\\nIni bisa digunakan, misalnya, untuk menyalakan mesin otomatis saat sumber daya tertentu mulai menipis."]
	quest.3DDB0DDA7571B2C1.title: "ME Level Emitter"
	quest.3DDB7C8E61BA048F.quest_subtitle: "Tingkat: &a2"
	quest.3DDF87A1E5F5D009.quest_desc: [
		"Di awal, kamu bisa bertahan dengan membuat mesin tingkat &7Starter&r dan &bBasic&r menggunakan Besi, tapi lama-kelamaan kamu perlu membuat material yang telah diberi energi menggunakan &9Energizing Orb&r.\\n\\n&9Energizing Orb&r akan memberikan energi pada item menggunakan &aEnergizing Rod&r terdekat dalam radius 9x9 di sekitarnya, menciptakan material yang lebih baik untuk progres ke &eTingkatan (Tier)&r yang lebih tinggi di mod Powah.\\n\\nUntuk menenagai orb, kamu perlu memasang Energizing Rod pada Energy Cable yang dialiri listrik. Jika ingin prosesnya lebih cepat, buatlah lebih banyak rod, upgrade ke tingkat yang lebih tinggi, atau keduanya! Untuk mengecek apakah Rod sudah terhubung, atur &aWrench&r milikmu ke mode 'link' dan kamu bisa menghubungkan Rod mana pun ke Orb."
		""
		"{image:atm:textures/questpics/powah/powah_energizing.png width:200 height:200 align:1}"
	]
	quest.3DDF87A1E5F5D009.title: "&9Energizing Orb"
	quest.3DE14F16F3109229.quest_desc: ["Dengan menggabungkan 8 Papan dari Kayu apa pun, dengan &7Ember Minyak Kreosot&r, kita akan mendapatkan Kayu yang Diolah! \\n\\nKayu yang Diolah digunakan di hampir setiap Barang yang diberikan &8&lIE&r, plus sebagian besar Mesin sederhana. \\n\\nYang paling penting adalah &6Meja Kerja Insinyur&r! Ini akan memberi kita banyak Resep baru."]
	quest.3DE14F16F3109229.title: "Kayu yang Diolah"
	quest.3DF1435A15515DA9.quest_desc: [
		"Untuk dapet Soul otomatis kita butuh beberapa Mesin dari &3&lJust Dire Things&r. \\nKita butuh Block Placer, di-set untuk taruh Soul Sand. \\n\\nKita lalu butuh Advanced Clicker dengan Soul Extractor di-set ke tempat Soul Sand akan ditaruh. Clicker perlu dikonfigurasi ke Hold Click, untuk beberapa Tick. \\n\\nTerakhir, kita butuh Advanced Block Placer di-set untuk break dimana Soul Sand akan ada. Ingat untuk set filter-nya cuma break Soulless Sand, dan kasih Tool! \\n\\nSemua mesin ini butuh Power (selain Block Placer kalau pakai versi normal) dan Advanced Breaker dan Advanced Clicker butuh tool mereka yang punya Durability."
		"{@pagebreak}"
		"{image:atm:textures/questpics/forbidden/forbidden_autosoul.png width:150 height:100 align:center}"
		"Di gambar ini Breaker di Kiri, Placer di Bawah, dan Clicker di Kanan tapi penempatannya gak masalah!"
	]
	quest.3DF1435A15515DA9.title: "Soul Otomatis"
	quest.3DF794EBCAA7AE1A.title: "Draconic Tree Harvester"
	quest.3E0643EA9183CDAE.quest_desc: ["'Itu topinya Tuan Krabs! Dia yang nomor satu!' \\n\\nFungsinya sama persis kayak &6Drinking Hat&r biasa, cuma tampilannya jauh lebih keren!"]
	quest.3E0643EA9183CDAE.quest_subtitle: "Kepala"
	quest.3E0643EA9183CDAE.title: "&9Novelty Drinking Hat"
	quest.3E16CF590C911129.quest_desc: ["&3Air Compressor&r adalah cara mudah membuat tekanan udara, cukup masukkan barang yang bisa dibakar ke dalamnya, dan lihat keajaibannya! (Aku sarankan buat minimal 3 buah untuk awal)."]
	quest.3E16CF590C911129.quest_subtitle: "Merasakan Tekanan"
	quest.3E16CF590C911129.title: "Menghasilkan Tekanan"
	quest.3E1A3BC8642390B3.quest_desc: ["'Aku Mary Poppins, kawan!' \\n\\n&4Umbrella&r (Payung) adalah alat yang sangat berguna dari mod &l&3Artifacts&r! Bisa dipakai di depan sebagai perisai (Shield) dengan tahan klik kanan. Atau bisa dipakai buat memperlambat jatuhmu cuma dengan memegangnya!"]
	quest.3E1A3BC8642390B3.quest_subtitle: "Unik"
	quest.3E1A3BC8642390B3.title: "&4Umbrella&r"
	quest.3E2A411FF5B4B0E7.quest_desc: ["Activation Range adalah seberapa dekat pemain (kamu) harus berada di sekitar spawner agar spawner tersebut bekerja. Jarak terendahnya adalah 1 blok dan tertingginya adalah radius 48 blok."]
	quest.3E2A411FF5B4B0E7.title: "Activation Range"
	quest.3E301F3EEC8C763A.quest_desc: [
		"Bisa digunakan untuk mempercepat pertumbuhan bayi lebah, atau membuat Telur Spawn baru.\\n\\nTaruh bayi lebah di kandang dengan 20 Honey Treat untuk mengubahnya jadi dewasa.\\n\\nUntuk membuat Telur Spawn, gabungkan gen lebah yang diinginkan dengan Honey Treat, lalu gunakan treat itu di mesin ini bersama sebutir telur."
		"{@pagebreak}"
		"Kamu bahkan bisa menerapkan gen ke lebah tanpa mengeluarkannya dari kandang. Masukkan Honey Treat berisi gen pilihan ke dalam inkubator bersama kandang lebah yang ingin dimodifikasi."
	]
	quest.3E301F3EEC8C763A.quest_subtitle: "Tempat Penitipan Bayi Lebah"
	quest.3E32450DBB7529AA.quest_desc: ["&ePembuat Batch Barang&r bekerja seperti antrian untuk Roller Coaster. \\n\\nRoller Coaster tidak akan berangkat sampai semua kursi terisi! Cara yang sama &ePembuat Batch&r tidak akan &6Mengeluarkan &eBarang&r sampai Filter dan Jumlah yang ditetapkan cocok. \\n\\nSempurna untuk hal-hal seperti Pemrosesan Bijih &5&lMekanism&r yang memerlukan jumlah tertentu &eBarang&r &9Dimasukkan&r atau akan macet."]
	quest.3E32450DBB7529AA.title: "&ePembuat Batch Barang"
	quest.3E33730DC2115D26.title: "&eGold Chest"
	quest.3E3CBDCEAB0FF28F.quest_desc: ["&9Deep Learner&r adalah salah satu komponen inti HNN.\\n\\nDengan item ini, bisa klik kanan untuk membuka HUD dan menyimpan &6Data Model&r untuk mengumpulkan data saat membunuh mob.\\n\\nSetiap Learner bisa menampung 4 Data Model, dan selama Learner ada di inventory, akan mengumpulkan data untuk model yang dimasukkan!\\n\\nCatatan: Bisa memiliki beberapa Deep Learner di inventory, dan akan menghitung kill untuk semua Data Model di dalam semua Learner."]
	quest.3E3CBDCEAB0FF28F.quest_subtitle: "HUD Pembelajaran"
	quest.3E3CBDCEAB0FF28F.title: "&aMempelajari Mob"
	quest.3E3DF8E967D95DB0.quest_desc: ["Saat menggunakan komponen penyimpanan 64k atau lebih tinggi, Matter Condenser mampu memadatkan lebih banyak barang untuk menghasilkan &bSingularity&f. Satu singularity membutuhkan 256.000 item untuk dimusnahkan. Itu tepat &o4000 stack&r!\\n\\nLihat apa yang terjadi jika kamu melempar singularity ini ke tanah bersama &eEnder Dust&f. Kamu perlu memberikan sedikit ledakan di sekitarnya, untungnya AE2 menawarkan &bTiny TNT&f untuk meminimalkan kerusakan."]
	quest.3E3DF8E967D95DB0.quest_subtitle: "Materi Sangat Padat"
	quest.3E3DF8E967D95DB0.title: "Hyper-Condensed Matter"
	quest.3E4B27759C973006.quest_desc: ["&l&6Framed Blocks&r adalah mod bangunan tunggal yang paling penting. Faktanya, jika kamu memberiku sebuah Modpack dan &l&6Framed Blocks&r tidak ada di dalamnya, aku tidak akan memainkannya. Sepenting itu! \\n\\n&l&6Framed Blocks&r memberi kita blok tiruan yang bisa diisi dengan blok apa pun yang bukan merupakan Entitas Blok (Entitas Blok adalah blok seperti Crafting Table, Furnace, atau Enrichment Chamber). \\n\\nBingkai-bingkai (Frame) ini bisa berbentuk apa saja! Mulai dari Slab vertikal, lereng, bahkan seperempat blok! \\n\\nKamu ingin Tangga &5Netherite&r? Pakailah Framed Blocks! Kamu ingin Meja Crafting dari Jerami? Kamu bisa mendapatkannya! Kamu ingin sudut yang sempurna di bangunanmu? Mulailah membuat &l&6Framed Blocks&r!"]
	quest.3E4B27759C973006.title: "&l&6Framed Blocks&r"
	quest.3E555B364FD88B43.quest_subtitle: "Jangkauan: &c45&r Blok"
	quest.3E555B364FD88B43.title: "&4Supremium Pemacu Pertumbuhan"
	quest.3E5BE6D6422F682C.quest_desc: ["&9&lTurbine&r kita butuh Steam masuk, &9Air&r keluar, sama &aEnergi&r keluar. \\n\\nTapi gimana? \\n\\nKita bisa pake &9Turbine Port&r buat masukin Steam sama keluarin &aEnergi&r. Kita perlu pake &9Turbine Vent&r buat keluarin &9Air&r! \\n\\nDua-duanya ditaro di dalam Dinding &9&lTurbine&r."]
	quest.3E5BE6D6422F682C.title: "Input dan Output &9&lTurbine&r"
	quest.3E6706BC4C318A40.quest_desc: ["Sewer dipakai untuk membuat Sewage, yang dipakai untuk membuat Fertilizer."]
	quest.3E6706BC4C318A40.title: "Sewer"
	quest.3E75AFE3482834C5.quest_desc: ["&lRailCraft&r adalah mod yang sepenuhnya tentang &5Kereta Api&r! \\n\\nMulai dari &7Minecart&r biasa hingga &eElectric Locomotive&r dan &9Tunnel Bore&r! Mod ini juga memiliki segala aksesori &5Kereta&r: Lampu Lalu Lintas, Steam Boiler untuk menenagai &5Kereta&r, dan otomatisasi untuk semuanya. \\n\\nMod impian bagi para pecinta miniatur &5Kereta&r!"]
	quest.3E75AFE3482834C5.title: "&7&lRailCraft"
	quest.3E76BC1D0FC3E9A8.quest_desc: ["Banyak item di mod &cMr Crayfish&r menggunakan energi! \\n\\nUntuk menenagai mereka, kamu butuh Electricity Generator. Alat ini menggunakan Batu Bara atau bahan bakar tungku lainnya untuk menghasilkan listrik! \\n\\nLalu, kamu butuh Wrench (Kunci Inggris) untuk menghubungkan Generator ke blok-blok yang membutuhkan energi. \\n\\nSaat Generator dinyalakan dengan saklar di bagian atas dan memiliki bahan bakar, ia akan menenagai apa pun yang terhubung."]
	quest.3E76BC1D0FC3E9A8.title: "Set Elektrik"
	quest.3E8077AB45C79E6A.quest_desc: [
		"Pasti lebih baik dari Cauldron Minecraft Normal! \\n\\nAlchemist Cauldron bisa: \\n1. Digunakan untuk mendapatkan &4Darah&r dengan memasak Mob atau Player. \\n2. Membuat dan upgrade Potion. \\n3. Punya setengah peluang mendapat Ink dari Scroll. \\n4. Menggabungkan 4 Ink dari Rarity ke Rarity yang lebih tinggi."
		"{image:atm:textures/questpics/iron_spells/spells_cauldron.png width:100 height:100 align:center}"
	]
	quest.3E89034E0CB8D687.quest_desc: ["Peti Kayu bertindak sebagai Tong... tetapi yang &2&lMinecraft&r, jadi Peti yang bisa dibuka dari sisi mana pun! \\n\\nMereka memiliki 27 Slot tetapi bisa Shift Klik Kanan dengan &6Palu Insinyur&r (beberapa kali) untuk menutupnya! Ini berarti bisa rusak dan mempertahankan &eBarang&r di dalamnya. \\n\\nJuga bisa mengedit Teks Peti untuk mengubah namanya seolah-olah di Anvil. \\n\\nPeti yang Diperkuat bekerja persis sama dengan yang normal, hanya tidak bisa meledak!"]
	quest.3E89034E0CB8D687.title: "Menyimpan &eBarang"
	quest.3E890BABC4C41370.quest_desc: ["Karena batasan jarak Controller, kamu mungkin ingin menghubungkan berbagai sistem ke hub utama tanpa harus menggunakan milyaran kabel.\\n\\nIni dilakukan menggunakan &3Network Transmitter&r dan &3Network Receiver&r.\\n\\n&9Transmitter&r harus terhubung ke sistem utamamu, di mana pun Controller berada.\\n\\n&9Receiver&r dipasang di mana pun kamu ingin jaringan eksternal berada. Contohnya, di bagian markas yang terpisah untuk Lebah, Mob Farm, dll.\\n\\nUntuk menghubungkan Receiver ke jaringan utama, kamu butuh &3Network Card&r. Untuk menyinkronkannya, klik kanan pada Receiver dengan kartu tersebut, lalu letakkan kartunya ke dalam Transmitter yang menempel di sistem utamamu."]
	quest.3E890BABC4C41370.quest_subtitle: "Menghubungkan Jaringan Secara Nirkabel"
	quest.3E890BABC4C41370.title: "&3Jaringan Grid"
	quest.3E89BC6875790952.quest_desc: ["Cuma 2 &bPowdered Diamond&r dan 1 &3Powdered Enderpearl&r (percaya, &3Enderpearl&r penting untuk ini!). \\n\\nGunakan 3 Powder ini pada &7Spell Cloth&r untuk mendapat &7Scroll&r! \\n\\nGunakan &7Scroll&r untuk mendapat &7&lKeys&r, sekarang bisa membuka Pintu apapun! \\n\\nTidak, tunggu keys yang salah..."]
	quest.3E89BC6875790952.title: "&7Scroll of Proximity Projection"
	quest.3E8BA5E075ABD136.quest_desc: ["Kemampuan pertama &7Ice Breaker&r adalah membuat keseimbanganmu sekokoh batu. Knockback berkurang dan kemungkinan terpeleset di atas &bEs&r juga berkurang. \\n \\nKemampuan keduanya adalah Earthquake (Gempa Bumi)! Saat jatuh, pilih Earthquake dengan Alt Kiri dan saat mendarat, itu akan memicu gelombang kejut di bawahmu yang melukai semua mob di sekitar."]
	quest.3E8BA5E075ABD136.quest_subtitle: "Ditemukan di Desa di Taiga atau Snowy Taiga"
	quest.3E8BA5E075ABD136.title: "Ice Breakers"
	quest.3E8C2E7769DFBF35.quest_desc: [
		"Berbeda dengan &3Steam Locomotive&r, kamu tidak perlu memasukkan bahan bakar apa pun ke &eElectric Locomotive&r. \\n\\nIa berjalan menggunakan daya dari &eFrame&r di bawah &6Rel Elektrik&r. \\n\\nYa, ia hanya bisa berjalan di atas &6Rel Elektrik&r."
		"{image:atm:textures/questpics/railcraft/rail_electric.png width:100 height:100 align:center}"
	]
	quest.3E8C2E7769DFBF35.title: "Lokomotif Elektrik"
	quest.3E8C7D92F99496BE.quest_desc: ["&5Eye of Abyss&r akan menuntunmu ke &5Sunken City&r untuk melawan &5&lLeviathan&r."]
	quest.3E8C7D92F99496BE.title: "&5Eye of Abyss&r"
	quest.3E970E76372AB094.quest_desc: ["&2Accelerated Planter&r bekerja mirip dengan Farmland biasa namun dengan beberapa perubahan.\\n\\nTanah ini otomatis terairi dan tumbuh lebih cepat daripada Farmland normal."]
	quest.3E970E76372AB094.title: "&2Accelerated Planter"
	quest.3E99F4CD379DE9D7.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.3EA2578C3A56FAE8.quest_desc: ["Soul Extractor bisa kamu pake buat ngisi Soul Jar dengan cara masukin jar dan pake item mob buat ngisi mereka. Contohnya, nambah Rotten Flesh bakal ngasi sebagian Zombie Soul."]
	quest.3EA3A6414AB8A39C.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_flow.png width:100 height:150 align:center}"]
	quest.3EA3A6414AB8A39C.quest_subtitle: "Trial Chambers"
	quest.3EA3A6414AB8A39C.title: "Flow Armor Trim"
	quest.3EA883C0BB7BD38F.quest_desc: ["Ayo kumpulin Wool!"]
	quest.3EA883C0BB7BD38F.quest_subtitle: "Fleece-nya....Pelangi?"
	quest.3EA883C0BB7BD38F.title: "Mary punya Anak Domba Kecil"
	quest.3EB63AF53E70C931.quest_desc: [
		"Proses Reformasi membutuhkan Mercury Flux agar bisa bekerja! Kamu perlu Shift+Klik Kanan pada ketiga Pedestal menggunakan Sulfuric Flux Emitter untuk menyetelnya. Kemudian letakkan Emitter tersebut dan beri daya listrik.\\n\\nSetelah itu, sistem siap untuk melakukan Reformasi!"
		"{image:atm:textures/questpics/theurgy/theurgy_reform_setup.png width:200 height:50 align:center}"
	]
	quest.3EB63AF53E70C931.title: "Langkah 4: Memberi Daya"
	quest.3EB6CBA0B1374BDD.quest_subtitle: "Dibuat di Dragonsteel Forge"
	quest.3EB6CBA0B1374BDD.title: "Lightning Dragonsteel Bee"
	quest.3EC8A0B89788D079.quest_desc: ["Aku nggak punya tangan, aku punya &9Flippers&r (Kaki Katak). \\n\\n&9Flippers&r ini fungsinya kayak Depth Strider yang jauh lebih oke. Kamu bisa berenang dan jalan di dalam &9Air&r jauh lebih cepat!"]
	quest.3EC8A0B89788D079.quest_subtitle: "Kaki"
	quest.3EC8A0B89788D079.title: "&9Flippers&r"
	quest.3EC90ADA4E322B14.quest_desc: ["Untuk membuat &6Tainted Gold Ingot&r, letakkan &eGold Ingot&r di atas &2Natural Altar&r.\\n\\nProses ini memakan waktu lebih lama dibanding dengan &2Infused Iron&r."]
	quest.3EC90ADA4E322B14.quest_subtitle: "Nodai Emas Itu!"
	quest.3EC90ADA4E322B14.title: "&6Tainted Gold"
	quest.3EC9D0DA61B45328.quest_desc: ["&c&lGenerator&r ini bisa bakar Hydrogen dan &dEthylene&r buat hasilkan &aEnergi&r. \\n\\nCatatan: Bakar Hydrogen nggak bakal hasilkan lebih banyak &aEnergi&r dibanding biaya buat jalanin &b&lElectrolytic Separator&r. \\n\\nPakai buat &dEthylene&r saja!"]
	quest.3EC9D0DA61B45328.quest_subtitle: "Bakar Gas jadi Listrik!"
	quest.3EC9D0DA61B45328.title: "&c&lGas-Burning Generator"
	quest.3ED40CC40458087E.quest_desc: ["&c&lRansel Akumulator&r tidak banyak berguna sendiri, perlu memberinya &cAkumulator&r untuk mendapatkan pekerjaan darinya! &cAkumulator&r apa pun tidak pilih-pilih! \\n\\nSetelah memberinya &cAkumulator&r di &6Meja Kerja Insinyur&r, sekarang bisa mengisinya. Setelah terisi, akan menyediakan &cEnergi&r untuk Barang di Tangan dan Armor yang dikenakan. \\n\\nBisa memakainya di Slot Punggung di Curios, Slot Dada, atau menggabungkannya dengan Dada di Meja Crafting. \\n\\nRansel bisa menampung 1 &cAkumulator&r dan 3 Upgrade."]
	quest.3ED40CC40458087E.title: "&c&lRansel Akumulator"
	quest.3ED8365BAD406CC5.quest_desc: ["Ini adalah mod-mod yang aku temukan sangat sempurna untuk mendekorasi rumah atau markasmu! \\n\\nJangan ragu untuk mengecek lebih banyak lagi dari yang ditampilkan di sini!"]
	quest.3ED8365BAD406CC5.title: "Mod Dekorasi!"
	quest.3EDDF96EA5056D28.quest_desc: ["&6Tembaga&r dan &7Nikel&r akan membuat &6Konstantan&r! \\nAkhirnya yang satu ini cukup banyak digunakan di &8&lIE&r, terutama di Mesin atau Barang yang menggunakan Panas dan Logam, seperti Generator."]
	quest.3EDDF96EA5056D28.title: "&6Batang Konstantan"
	quest.3EE95747CA6DFB1A.quest_desc: [
		"&7&lPres Logam&r adalah Sahabat Terbaik kita untuk semua Resep Crafting dengan &7Logam&r! \\n\\nSangat sederhana, kita menempatkan Cetakan pada Pers, pasang &cEnergi&r ke atas, dan lempar &eBarang&r ke &eSabuk Konveyor&r. \\n\\n&eBarang&r kita akan melewati, mendapatkan &7&lDitekan&r, dan menjadi &eBarang&r baru yang terus bergerak di &eSabuk&r! \\n\\nIni bisa digunakan untuk membuat &cKabel&r, &7Pelat&r, &8Batang&r, dan... &2Irisan Melon&r?"
		"{@pagebreak}"
		"Lapisan pertama sangat sederhana, hanya &8Perancah Baja&r dan kedua sisi &4Blok Teknik Redstone&r."
		"{image:atm:textures/questpics/immersive/immersive_press1.png width:150 height:75 align:center}"
		"Selanjutnya, letakkan Piston, menghadap ke Bawah, di atas &4Blok Teknik Redstone&r dan tambahkan dua Sabuk Konveyor di sebelahnya."
		"{image:atm:textures/questpics/immersive/immersive_press2.png width:125 height:100 align:center}"
		"Kemudian, letakkan satu &7Blok Teknik Berat&r di atas Piston kita!"
		"{image:atm:textures/questpics/immersive/immersive_press3.png width:100 height:100 align:center}"
		"Terakhir, Klik Kanan Piston dengan Palu Insinyur!"
	]
	quest.3EE95747CA6DFB1A.title: "&l&7Pers Logam"
	quest.3EEF17C57375CC39.quest_desc: ["&lSimply Lights&r menambahkan lampu yang sangat simpel dibuat dan mudah digunakan.\\n\\nSaat dalam mode Inverted, mereka akan menyala tanpa Redstone dan akan mati saat sinyal Redstone mengaktifkannya.\\n\\nAda banyak warna dan bentuk yang berbeda!"]
	quest.3EEF17C57375CC39.title: "&lSimply Light&r"
	quest.3F02EF19112D23BE.quest_desc: ["Kamu butuh &6Pengrajin Mekanik&r untuk membuat &6Roda Penghancur&r, ukurannya terlalu besar untuk Meja Kerajinan 3x3. Kamu juga butuh banyak &8Paduan Andesit&r. \\n\\nBTW, kamu butuh 2 untuk bisa menggunakannya. \\nSetelah punya 2, letakkan berdampingan. Kemudian beri keduanya &dTenaga Rotasi&r dan banyak Satuan Stres. \\n\\nPastikan &6Roda Penghancur&r berputar ke arah berlawanan atau tidak akan &6Menghancurkan&r! Yang kiri harus berputar &e&oSearah Jarum Jam&r, dan yang kanan harus berputar &9&oBerlawanan Jarum Jam&r. \\n\\nSetelah berputar (cepat dan ke arah yang benar), kamu bisa menjatuhkan &eItem&r di antara keduanya dan mereka akan &6Dihancurkan&r. \\n\\nItem apa saja? &6Bijih Hancur&r dari Bijih, &eItem&r dari Batu dan Netherrack, Pasir dan Flint dari Kerikil, bahkan Netherwart dari Blok Netherwart!"]
	quest.3F02EF19112D23BE.title: "&6Roda Penghancur"
	quest.3F0CD2C03CD7D730.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_forge.png width:100 height:150 align:center}"]
	quest.3F0CD2C03CD7D730.quest_subtitle: "Dijatuhkan oleh Starlight Golem"
	quest.3F0CD2C03CD7D730.title: "Forge Armor Trim"
	quest.3F185554793CCE54.quest_desc: ["Untuk membangun, kamu akan membutuhkan Alat. Dan kamu akan menginginkan Alat. \\n\\nAlat yang membantumu mendapatkan blok, alat untuk membantumu mendapatkan versi berbeda dari blok tersebut, dan alat untuk membantumu meletakkan blok! \\n\\nKamu harus memulainya dengan sebatang Stick!"]
	quest.3F185554793CCE54.title: "Alat-alat!"
	quest.3F2C1A81C17D2D67.quest_desc: ["&6Lengan Mekanik&r harus dikonfigurasi sebelum dipasang, seperti &ePelontar Berbobot&r. \\n\\nJangkauannya 4 Blok dan bisa mengambil dari &eSabuk&f dan &ePenampang&r. Bisa juga meletakkan ke &eSabuk&f, &ePenampang&f, dan &eCorong&r. \\nSambil memegang &6Lengan Mekanik&r, Klik Kanan Blok untuk mengatur sebagai Input, lalu Klik lagi untuk mengubahnya menjadi Output. Klik Kiri untuk membatalkan pilihan. Kamu bisa memilih sebanyak yang ada dalam jangkauan! \\n\\nSetelah ada &dTenaga Rotasi&r, &eItem&r di Blok Input mana saja, dan ruang di Blok Output mana saja, ia akan mulai memindahkan &eItem&r. Semakin banyak Kecepatan, semakin cepat gerakannya. \\n\\nSeperti &eBrass Tunnel&r, &6Lengan Mekanik&r punya Mode Distribusi. Untungnya jauh lebih sedikit! Round Robin: bergiliran untuk Input dan Output secara berurutan. Forced Round Robin: menunggu sampai setiap Output punya ruang atau setiap Input punya &eItem&r tersedia. Prefer First Target: mengutamakan Blok terdekat."]
	quest.3F2C1A81C17D2D67.quest_subtitle: "Kenapa kerja sendiri kalau Robot bisa melakukannya lebih baik?"
	quest.3F2C1A81C17D2D67.title: "&6Lengan Mekanik"
	quest.3F3559EF5D08B706.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Membuat Anak Panah aktif mengejar target mereka."
	]
	quest.3F39BEB788175CEF.quest_subtitle: "Menggali area 3x3!"
	quest.3F5B5D6B788E0A73.quest_desc: ["Darah, daging, ritual, kalo itu jahat bisa dipastikin itu dari &4&lEvilCraft&r! "]
	quest.3F5B5D6B788E0A73.title: "&4&lEvilCraft"
	quest.3F663416E824720C.quest_desc: ["&cCasing Tembaga&r dibutuhkan untuk sebagian besar Mesin yang terlibat dalam &bLogistik Cairan&r. \\n\\nMau menaruh &9Air&r? Butuh &cCasing Tembaga&r. Mau mengambil &9Air&r? Butuh &cCasing Tembaga&r. \\n\\nDibuat seperti &8Casing Andesit&r — terapkan &cIngot Tembaga&r ke Kayu Terkupas."]
	quest.3F663416E824720C.title: "&cCasing Tembaga"
	quest.3F68BA498E877C8C.quest_subtitle: "Nama tengah Roy Biv"
	quest.3F68BA498E877C8C.title: "&aGreen Xychorium Gems"
	quest.3F8A5CBEAE024748.quest_desc: ["Eye of the Pillager, Eye of the Blaze, dan Eye of the Shulker masing-masing digunakan untuk mencari lokasi struktur tertentu."]
	quest.3F8A5CBEAE024748.quest_subtitle: "Mataku tertuju padamu"
	quest.3F8A5CBEAE024748.title: "Pencari Struktur"
	quest.3F8AEBB994716318.quest_desc: ["&8Wither&r adalah Effect di &l&2Vanilla&r jadi tentu aja kita butuh cara sendiri buat pake dan abuse! \\n\\nKamu bisa Brew Awkward Potion pake &8Wither Skeleton Skull&r buat bikin. Terus kamu bisa craft Arrow dengannya!"]
	quest.3F8D515D7B81B0E3.quest_desc: [
		"Smithing Template lagi?!?!?!\\n\\nYah, setidaknya kamu tidak perlu fitur arkeologi untuk mencarinya!\\n\\nKamu harus mendapatkannya dengan mengalahkan Trial Spawner yang ditemukan di struktur Dungeon di &b&lThe Other&r. Lebih tepatnya di ruang perpustakaan (Library Room)!\\n"
		"{image:atm:textures/questpics/allthemodium/all_library.png width:200 height:100 align:center}"
	]
	quest.3F8D515D7B81B0E3.title: "&5Unobtainium Smithing Template"
	quest.3F8EEE1AD4420702.title: "&bKomponen Penyimpanan 64k"
	quest.3F9CCCFEF4E84166.quest_desc: ["Untuk meningkatkan produksi panasmu, letakkan &3Heat Sink&r di sisi dingin Vortex Tube milikmu."]
	quest.3F9CCCFEF4E84166.quest_subtitle: "Lebih Banyak Panas"
	quest.3F9CCCFEF4E84166.title: "Produksi Panas Lebih Baik"
	quest.3F9D553C9FA64F2A.quest_desc: ["Reactor adalah struktur multi-block, artinya kamu bisa bikin ukuran custom sendiri!\\n\\nKalau pakai &aBasic Reactor Part&r, reactor terbesar yang bisa dibuat adalah 5x5x5.\\n\\n&lReactor Terbesar&r yang bisa dibuat pakai &eReinforced Reactor Part&r adalah 32x32x48. Ada banyak variabel yang berkontribusi ke output reactor secara keseluruhan, jadi pastikan eksperimen!\\n\\nBeberapa tips umum:\\n\\nSemakin tinggi reactor, semakin banyak fuel yang bisa ditampung dan dibakar karena ada lebih banyak fuel rod, artinya lebih banyak power keseluruhan. Ini juga artinya &cburn rate&r lebih tinggi.\\n\\nSemakin lebar reactor, semakin efisien, selama kamu gak nambah fuel rod ke design. Ini artinya konsumsi lebih rendah secara keseluruhan."]
	quest.3F9D553C9FA64F2A.title: "Perluas Reactor Kita"
	quest.3FB0F22BEF7FE622.quest_desc: ["Satu &7Scroll&r yang perlu diterapkan untuk mendapat &8&lReplica&r adalah &7Scroll of Damage Exchange&r. \\n\\nUntuk mendapatkannya lakukan Ritual of Damage Exchange: dengan 1 Powdered Iron dan 2 &aPowdered Emerald&r."]
	quest.3FB0F22BEF7FE622.title: "&7Scroll of Damage Exchange"
	quest.3FBCBBEBB78B83FC.quest_desc: ["Akhirnya buat &5Kereta&r! \\n\\nKita harusnya sudah punya &5Bogie&r dari Quest &5Stasiun Kereta&r, desain &5Bogie&r tidak berpengaruh. \\n\\nKemudian, kita bisa menaruh Blok ke &5Bogie&r dengan &aLem Super&r. Blok apa saja tidak masalah — hampir semua Blok yang bisa digerakkan bisa di-&aGlue&r! \\n\\nInilah saatnya membuat tampilannya cantik! Cek Artwork-Builds Showoff di Discord untuk melihat beberapa contohnya. \\n\\nBlok terpenting untuk &5Kereta&r kita adalah &5Kontrol Kereta&r. Kamu butuh satu untuk bisa menggerakkan &5Kereta&r. \\n\\nKamu juga bisa menambahkan &5Kursi&r untuk &5Kondektur&r (lebih lanjut nanti) atau bahkan dirimu sendiri! \\n\\nSetelah semuanya siap, cukup tekan \"Rakit Kereta\" dan &5Kereta&r-mu akan jadi, atau ia akan memberitahu apa yang kamu lakukan salah!"]
	quest.3FBCBBEBB78B83FC.title: "Merakit &5Kereta"
	quest.3FCEF8FF45E51608.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_quartz.png width:100 height:150 align:center}"]
	quest.3FD19A001899D8C6.quest_desc: ["Oke sekarang yang ini memberikan Gliding dan Flying sebenarnya, Creative Flight lebih tepatnya."]
	quest.3FD19A001899D8C6.title: "Draconic Flight Module"
	quest.3FD702B5AB006402.quest_desc: ["Pernah ingin melayang ke mana pun kamu pergi? \\n\\nSabuk ini memungkinkanmu untuk terbang melayang (levitate). Untuk mengaktifkannya, cukup tekan shift saat berada di udara, baik saat jatuh maupun saat melompat."]
	quest.3FD801D7DE9176FB.title: "&eKomponen Penyimpanan 4k"
	quest.3FD9DC6B7844A79C.quest_desc: ["Aku selalu benci betapa membosankannya Beton (Concrete), terutama di kehidupan nyata. \\n\\nSetidaknya di &2&lMinecraft&r dengan mod &l&bChipped&r, kita bisa mendapatkan berbagai desain berbeda dengannya!"]
	quest.3FD9DC6B7844A79C.title: "Beton &l&bChipped&r"
	quest.3FE2A649F07DF28D.quest_subtitle: "Kamu bisa menghancurkan Blutonium dari Extreme Reactors untuk mendapat Plutonium Dust"
	quest.3FE489E6B1FAC24B.quest_subtitle: "Mendaur ulang Depleted Rod (Batang Bahan Bakar Habis Pakai)"
	quest.3FE489E6B1FAC24B.title: "Mendapatkan Plutonium"
	quest.3FE739EA7E297DF3.quest_desc: [
		"Extended Device adalah varian dari device AE2 yang punya kapasitas lebih tinggi, lebih cepat, atau bahkan keduanya."
		""
		"Contoh: Extended Pattern Provider punya 36 slot pattern, 4x lebih banyak dari Pattern Provider biasa."
		""
		"Atau Extended Export/Import Bus, kerja sekitar 8x lebih cepat dari yang biasa, dan support lebih banyak upgrade."
		""
		"Karena kebanyakan cuma versi upgrade dari yang basic, gak akan bikin quest terpisah buat masing-masing."
	]
	quest.3FE739EA7E297DF3.title: "Lebih Cepat dan Besar: Extended Device"
	quest.3FF61A4D7A250AE1.quest_desc: ["Untuk &5Creative &cEnergy Cell&r yang satu ini (beda lho sama &5Creative &dEnergy Cell&r satunya), kamu butuh 4 &cNitro Cell&r. \\n\\nTiap &cNitro Cell&r butuh 2 &aSpirited Cell&r, dan tiap &aSpirited Cell&r butuh 2 &bNiotic Cell&r. Begitu terus sampe bawah... \\n\\nAku males ngitungnya, cek aja Recipe Tree, masih banyak urusan lain yang lebih penting!"]
	quest.3FF61A4D7A250AE1.quest_subtitle: "Unlimited Powah!"
	quest.3FF61A4D7A250AE1.title: "&l&cEnergy Cell &5(Creative)"
	quest.3FF97A4B5029C0E7.quest_desc: ["Yang ini butuh 2 &bPowdered Diamond&r dan 1 &ePowdered Gold&r, kebalikan dari &c&lExplosive Staff&r! \\n\\nGunakan ini pada &7Spell Cloth&r untuk mendapat &7Scroll&r, lalu bisa gunakan &7Scroll&r untuk mendapat &b&lBow&r!"]
	quest.3FF97A4B5029C0E7.title: "&7Scroll of Weapon Projectiles"
	quest.4007DFA7CC3A5FF2.quest_desc: ["Agar &oseleuruh bagian quest&r ini tidak penuh dengan daftar upgrade, silakan lihat upgrade Sophisticated Backpack.\\n\\nKamu perlu membuat versi Sophisticated Storage-nya, tapi fungsinya hampir sama."]
	quest.4007DFA7CC3A5FF2.quest_subtitle: "Bahan Dasar Upgrade"
	quest.40096ED0B04C3EC5.quest_desc: ["Modifikasi wajib untuk semua Spawner. Saat deskripsinya bilang 'mengabaikan semua syarat', itu artinya hampir semua. Mengabaikan tingkat cahaya, blok yang dibutuhkan untuk spawn, hingga biome. Syarat ruang tetap dibutuhkan, seperti Slime yang butuh area 3x3 untuk muncul, begitu juga pemain yang tetap harus berada di dekatnya (kecuali pakai modifikasi lain)."]
	quest.40096ED0B04C3EC5.title: "Abaikan Semua Syarat"
	quest.401A3FD6A3511870.quest_subtitle: "Simsalabim"
	quest.401A3FD6A3511870.title: "Gerbang (Gates)"
	quest.401B559649C54C5C.quest_desc: ["Mencampur &#92CCF0Hidrogen&r dan &#519BC9Klorin&r akan memberimu &#4FB373Hydrochloric Acid&r (Asam Klorida). Ini akan digunakan untuk mengolah &#F2A0E1Chromium Dust&r."]
	quest.401BB95B740385B7.title: "&6Holy&r Upgrade Orb"
	quest.40258842B0359A2D.quest_desc: ["&6Ironwood Armor&r bisa dibuat menggunakan &6Ironwood&r dan otomatis sudah memiliki mantra."]
	quest.40258842B0359A2D.title: "Armor &6Ironwood"
	quest.403F76908A8A5661.quest_desc: ["Expulsion Pylon mendorong pemain keluar dari area, tapi bagaimana jika kamu ingin agar &lbeberapa&r pemain tetap boleh mendekat! Maka kamu butuh Player Filter. \\n\\nKlik Kanan pada seorang pemain menggunakan item tersebut untuk mendaftarkan mereka, lalu masukkan ke dalam Pylon untuk memasukkan mereka ke Whitelist! \\n\\nJadi saat orang lain terlempar keluar, temanmu tidak akan mengalaminya! \\n\\nSecara default, pemilik Pylon tidak akan terkena efek pengusiran."]
	quest.4040BFCD4BE56621.quest_desc: [
		"Hotel Madu (Honitel) adalah struktur besar yang relatif aman, kecuali risiko damage jatuh. \\n\\nMemiliki puluhan kamar tempat para &6L&8e&6b&8a&6h&r menginap. Di dalam kamar-kamar tersebut juga terdapat banyak loot untuk kamu ambil. \\n\\nAku hanya berharap kamu merasa sedikit bersalah karena mencurinya dari para &6L&8e&6b&8a&6h&r yang tidak bersalah ini.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_honitel.png width:200 height:100 align:center}"
	]
	quest.4040BFCD4BE56621.quest_subtitle: "Kamar Penuh"
	quest.4040BFCD4BE56621.title: "Honitel"
	quest.404AA0F5557D7E35.quest_desc: ["Benih Unobtainium butuh Tanah Ajaib yang ditaro di bawah biar bisa numbuh."]
	quest.404AA0F5557D7E35.quest_subtitle: "Tingkat: &bAjaib"
	quest.405D2571E61694FD.quest_desc: ["Dengan klik kanan pada &dPatrick &aBee&r pakai &6&lATM Star Block&r, kamu bakal dapet &6Starry Bee&r! \\n\\nKamu butuh &6&lATM Star Block&r lain buat mereka menyerbuk... harusnya aku bilang dari tadi ya... \\n\\n&6Starry Bee&r bakal ngasilin &6Starry Comb&r yang bisa diproses di Centrifuge buat dapet &6Star Shard&r (tapi agak jarang)!"]
	quest.405D2571E61694FD.title: "&6Starry Bee&r!"
	quest.405DCD3E36232EEA.quest_desc: ["Damage lebih kecil dari Pedang, tapi jangkauan serangnya lebih panjang."]
	quest.405DCD3E36232EEA.quest_subtitle: "Keluarkan jiwa Spartan-mu"
	quest.406433F7FF3B0E7B.quest_desc: ["&bBaja Naga Es&r dibuat dengan kombinasi &bDarah Naga Es&r dan &7Besi&r di &b&lPemalsuan Naga Es&r. \\n\\nKita bisa bikin Senjata dari ini! Senjata-senjata ini bakal kasih Damage gede, plus &bBekuin&r Mob yang ke-Hit. \\n\\nSelain Senjata juga ada Armor. Armor ini kasih Stats yang banyak, dan keren! Plus ngelindungin kita ekstra dari &bSerangan Elemental Naga&r! \\n\\nKenapa cuma dapetin Armor buat kita doang? Gimana &b&lNaga&r kita juga! Ini lebih mahal banyak, tapi bakal kasih Proteksi yang banyak buat &b&lNaga&r kamu apalagi kalo lawan &b&lNaga&r lain."]
	quest.406433F7FF3B0E7B.title: "&bBaja Naga Es"
	quest.4071BBBE12CACD2D.quest_desc: ["Train Dispenser adalah versi yang lebih canggih dari Cart Dispenser. Ia bisa mengeluarkan seluruh rangkaian &5Kereta&r sekaligus! Atur pola rangkaian yang kamu inginkan lalu beri sinyal redstone."]
	quest.4071BBBE12CACD2D.title: "Dispenser Kereta"
	quest.40786B63E2901D11.quest_desc: [
		"Mari kita lihat gimana cara aku jelasin Cursed Garden... ini labirin gede banget! \\n\\nAda pintu masuk di tiap sisi dan kamu harus cari jalan ke tengah dimana Lunar Monstrosity ada! \\n\\nDi sekitar labirin kamu bisa nemuin chest penuh Loot dan Tangled!"
		"{image:atm:textures/questpics/eternal/starlight_maze.png width:150 height:150 align:center}"
	]
	quest.40786B63E2901D11.title: "Cursed Garden"
	quest.40788326E791845D.quest_desc: ["Extruder akan meletakkan blok yang ada di Buffer Router dalam satu garis lurus di depannya saat diberi sinyal Redstone. Saat sinyal dimatikan, ia akan menghancurkan kembali blok-blok tersebut. \\n\\nSangat berguna untuk membuat Pintu Otomatis!"]
	quest.407C2D00F22BD89D.quest_desc: ["Upgrade ini memberikan ruang untuk 6 Peluru lagi! Membuat total menjadi 14."]
	quest.40888A2C17D8FFF6.quest_desc: ["Pakai Blood Infuser, kamu bisa bikin &cUndead Sapling&r yang tumbuh jadi &dUndead Tree&r.\\n\\nLog dan plank-nya berguna buat bikin beberapa tool dan item di EvilCraft."]
	quest.40888A2C17D8FFF6.title: "Undead Tree"
	quest.408D8B1CFBA22BAF.quest_desc: ["Blok Witherproof, Bata Witherproof dan Kaca Witherproof punya blast resistance yang sangat tinggi dan gak bisa dihancurin sama Wither atau Ender Dragon."]
	quest.408D8B1CFBA22BAF.title: "&0Blok Witherproof"
	quest.408EBED932656006.quest_desc: ["Melakukan doping pada &7Silikon&r akan memberimu hasil yang jauh lebih baik daripada menggunakan &7Silikon&r murni."]
	quest.408EBED932656006.title: "Doped Silicon"
	quest.408F48C4442CE180.quest_desc: ["Banyak pilihan lampu dan tempat penyimpanan untuk tempat istirahatmu."]
	quest.408F48C4442CE180.title: "Set Kamar Tidur"
	quest.40924F0D64253A38.quest_desc: ["Membuat benda-benda bisa mengeluarkan (dispense) item."]
	quest.40924F0D64253A38.quest_subtitle: "Lenyap!"
	quest.4092E914B24C52A7.quest_subtitle: "Membuat berbagai Material Starlight"
	quest.409A92D40F539485.quest_subtitle: "Tingkat: &e1"
	quest.40AB457E37919ABE.quest_desc: ["Kamu suka Terbang? Suka main api? Suka keduanya? Maka Blazing Flask sangat cocok untukmu! Klik Kanan Blazing Flask di dekat sumber api dan lingkaran akan terbentuk di sekitarnya. Di dalam lingkaran tersebut kamu akan mendapatkan mode terbang (Creative Flight). Lingkarannya bisa diperbesar dengan melakukan upgrade di &6Research Window&r dan dengan menambah lebih banyak api!"]
	quest.40AB457E37919ABE.quest_subtitle: "Ditemukan di Ruined Portal, Nether Fortress, dan Bastion"
	quest.40AB457E37919ABE.title: "&5Blazing Flask"
	quest.40B13424FA523E11.quest_subtitle: "Tingkat: &a2"
	quest.40B24676E11D9410.quest_desc: ["Kita butuh banyak Ore buat &5&lMekanism&r jadi kenapa gak upgrade &dMeka-Tool&r buat dapet lebih banyak! \\n\\n&dOre Refinement&r bakal kerja kayak Fortune. Pas Ore ditambang, ada kesempatan buat dapet lebih banyak Drop. \\n\\nKita gak bisa pake &bSilk Touch &7Unit&r sama yang ini. Antara Ore Block atau Ore Drop, pilih 1!"]
	quest.40B24676E11D9410.quest_subtitle: "Meka-Tool"
	quest.40B24676E11D9410.title: "&dOre Refinement &7Unit"
	quest.40B757772D0FBAC9.quest_desc: [
		"&4Blood&r adalah Slot ke-3 yang perlu diisi di &6&lForge&r. \\n\\nKamu bisa bunuh Mob di/dekat &6&lForge&r untuk tambah &4Blood&r. \\n\\nAtau kamu bisa deposit Test Tube yang terisi untuk taruh &4Blood&r itu ke &6&lForge&r. \\n\\nUntuk isi Test Tube, taruh di Offhand saat bunuh Mob."
		"{image:atm:textures/questpics/forbidden/forbidden_blood.png width:135 height:100 align:center}"
	]
	quest.40B757772D0FBAC9.title: "&4Blood"
	quest.40BC67BDEE15D1DE.quest_desc: ["Untuk membuat Source Gem, kita perlu memasukkan Lapis Lazuli atau Amethyst Shard ke dalam Imbuement Chamber. Seiring waktu, item tersebut akan berubah menjadi Source Gem!"]
	quest.40BC67BDEE15D1DE.title: "&5Source Gems"
	quest.40C068B2B8AC0F33.quest_desc: ["Terraforming adalah bagian penting bahkan untuk bangunan yang paling simpel sekalipun. Tapi kita sebagai pemain &2&lMinecraft&r tidak punya waktu atau tenaga untuk melakukannya sendiri. \\n\\nJadi kenapa tidak membiarkan mesin yang melakukannya untuk kita? \\n\\nQuarry adalah cara yang sangat mudah untuk melakukannya, tapi semuanya dimulai dengan Block Breaker. Simple Block Breaker hanya akan menghancurkan apa yang ada di depannya, tidak terlalu membantu... \\n\\nTapi Advanced Block Breaker akan menambang area yang telah ditentukan! Jauh lebih baik untuk Terraforming!"]
	quest.40C068B2B8AC0F33.title: "Quarry dan Tambang"
	quest.40C5C355B6DA1893.quest_desc: ["Generator Saku adalah generator genggam yang menggunakan barang yang bisa dibakar untuk mengisi daya barang dan alat di inventori pemain, Generator Saku kompatibel dengan Tabung Bahan Bakar."]
	quest.40C776497D68367F.quest_desc: ["Vine, Red dan Blue Crystal Moss Carpet, Lunar Berry, Cave Moss, dan Red dan Blue Crystal Root. \\n\\nIni bisa dipake di Offhand kamu dengan Seeking Eye buat nemuin Cursed Garden."]
	quest.40C776497D68367F.title: "Item Monstrosity"
	quest.40DB6E3DE87F16EF.quest_desc: [
		"&dDragon's Breath&r adalah item yang kuat, (bau), dan misterius. Kuat berarti kita bisa bikin Energi dari itu, dan banyak lagi! &5Halitosis Generator&r bikin Energi dari &dDragon's Breath&r!"
		""
		"(BTW kamu bisa farm &dDragon's Breath&r pakai Extractor dari XyCraft dengan Dragon's Head)."
	]
	quest.40DB6E3DE87F16EF.title: "&5Halitosis Generator"
	quest.40E4F1172A164DD1.quest_subtitle: "Peluang muncul saat menghancurkan Cocoa Pod di Hutan Rimba (Jungle)"
	quest.40E4F1172A164DD1.title: "Sugarbag Bee"
	quest.40E8940C92668D4F.quest_desc: ["&cDeuterium&r sebenernya relatif gampang didapet! \\n\\nPertama, kita butuh &9Heavy Water&r. &9Heavy Water&r itu kayak H2O biasa, cuma H-nya agak beda! \\n\\nKita bisa pake &9Filter &8Upgrade&r di &9&lElectric Pump&r (jelas di atas &9Air&r) buat ekstrak &9Heavy Water&r daripada &9Air&r biasa. \\n\\nProses &9Heavy Water&r lewat &9&lElectrolytic Separator&r bakal kasih &bOxygen&r sama &cDeuterium&r daripada &7Hydrogen&r. \\n\\nKan gue bilang gampang!"]
	quest.40E8940C92668D4F.quest_subtitle: "D"
	quest.40E8940C92668D4F.title: "&cDeuterium"
	quest.40F2EDB9384CE782.quest_desc: ["Menyuling &#DBE37FSteam Cracked Light Fuel&r akan menghasilkan &#9C6C35Acetylene&r."]
	quest.40F34EBE09DA7752.quest_desc: ["Auto-Feed akan otomatis memberimu makan makanan apapun di Inventory-mu saat lapar. Punya penyimpanan Food Point maksimal, setiap bar penuh adalah 2 Food Point. Jadi yang Basic hanya bisa menyimpan senilai 8 Steak."]
	quest.40F34EBE09DA7752.title: "Basic Auto Feed Module"
	quest.40F634AC38F42B88.quest_desc: ["Untuk mengalirkan tekanan, kamu butuh &3Pressure Tube&r. Tekanan apa yang kamu maksud? Lanjutkan alur quest untuk melihat kegunaannya."]
	quest.40F634AC38F42B88.quest_subtitle: "Tekanan Apa?"
	quest.40F634AC38F42B88.title: "Mengalirkan Tekanan"
	quest.40F8A44DF4D8DBD6.quest_subtitle: "Magmatic + Nomad"
	quest.40F8A44DF4D8DBD6.title: "BlazBee"
	quest.4101F8275B41C79B.title: "&6Komponen Penyimpanan 1k"
	quest.4104ABDC0E577350.title: "&2Nature&r Upgrade Orb"
	quest.4104C5D003D4705A.quest_desc: [
		"Multiblok lain yang menggunakan &eSabuk&r, aku melihat pola. Pertama, perlu mengatur &9Cetak Biru&r. Klik Kanan &6&lMeja Kerja Otomatis&r untuk membuka GUI-nya dan letakkan &9Cetak Biru&r di slot paling kanan. \\n\\nKemudian, bisa memiliki &eBarang&r melewati &eSabuk&r untuk digunakan dalam Resep jika memungkinkan. \\n\\nSetelah itu, &eBarang&r yang Dibuat (dan &eBarang&r yang tidak sengaja diletakkan di &eSabuk&r) akan keluar &eSabuk&r. \\n\\nIni berguna untuk mengotomatiskan Peluru, &0Grafit HOP&r, dan &7Komponen Mekanik&r."
		"{@pagebreak}"
		"Kita memulai banyak ini dengan bentuk menggunakan &8Perancah Baja&r, kali ini adalah garis diagonal. Di sudut yang lebih kecil, letakkan &7Blok Teknik Berat&r. Di sudut yang lebih besar, letakkan 2 &eBlok Teknik Ringan&r dan &4Blok Teknik Redstone&r."
		"{image:atm:textures/questpics/immersive/immersive_automated1.png width:100 height:100 align:center}"
		"Selanjutnya, letakkan lebih banyak &eBlok Teknik Ringan&r dan &7Blok Teknik Berat&r di atas yang sebelumnya. Di atas &4Blok Teknik Redstone&r dan &8Perancah Baja&r di sebelah kirinya, letakkan Setengah Kayu yang Diolah. Dalam sisa ruang, letakkan &eSabuk Konveyor&r sesuai urutan yang ditunjukkan."
		"{image:atm:textures/questpics/immersive/immersive_automated2.png width:100 height:100 align:center}"
		"Untuk mendapatkan &6&lMeja Kerja Otomatis&r, pukul Setengah Kayu yang Diolah kiri dengan &6Palu Insinyur&r!"
		"{image:atm:textures/questpics/immersive/immersive_automated.png width:100 height:100 align:center}"
	]
	quest.4104C5D003D4705A.title: "&l&6Meja Kerja Otomatis"
	quest.411A463E98C3B102.quest_desc: [
		"Beberapa ingredient yang kamu butuh buat bikin Quantum Computer, Crafter, dan Armor."
		""
		"Shattered Singularity dibuat dengan Singularity, 2 Ender Dust, 2 Sky Stone Dust, dan 100 mB Lava di Reaction Chamber."
		""
		"1 bucket Quantum Infusion dibuat dengan 4 bucket Air dan Quantum Infused Dust, yang didapat dari crushing Shattered Singularity di Inscriber atau Mekanism Crusher."
		""
		"Quantum Infused Alloy dibuat dengan 1 bucket Quantum Infusion, 4 Copper Ingot, 4 Shattered dan 4 Singularity biasa."
	]
	quest.411A463E98C3B102.title: "Ingredient Quantum"
	quest.413F338DB07BA88C.quest_subtitle: "Sama seperti versi uap"
	quest.4141EF8B8C316118.quest_desc: ["&7Cloggrum&r adalah padanan Besi di dimensi &2&lUndergarden&r. \\n\\nIa ditemukan di mana-mana dan digunakan dalam belasan resep berbeda. \\n\\nBahkan beberapa mob menjatuhkannya!"]
	quest.4141EF8B8C316118.title: "&7Cloggrum&r"
	quest.4147D247E4D754D0.quest_desc: [
		"Gleech adalah mob kecil yang spawn di Crystallized Desert. \\n\\nMereka tanpa henti mau darah kamu dan itu artinya bahkan dengan cara kekerasan. Untungnya mereka cuma punya 4 Heart! \\n\\nKalau mati mereka mungkin drop Telur mereka yang bisa dilempar sebagai proyektil."
		"{image:atm:textures/questpics/eternal/starlight_gleech.png width:100 height:100 align:center}"
	]
	quest.4147D247E4D754D0.title: "Gleech"
	quest.414A35A72AFB5FF5.quest_desc: ["Ini mungkin salah satu yang paling nyebelin untuk craft, butuh &bPrismarine&r, &2Turtle Scute&r, &9Lapis&r, dan &3Heart of the Sea&r. \\n\\nSemoga kamu suka &2&lMA&r! \\n\\nDigabungin dengan Helmet... kemungkinan besar kasih Respiration atau Aqua Affinity, tapi gak bisa bikin kerja..."]
	quest.414A35A72AFB5FF5.title: "&9Sea Prism"
	quest.417B88FEB1B8F44E.quest_desc: ["Maksudnya ini payah! Secara harfiah! (Suck = Menghisap). \\n\\nVacuum Module akan menghisap item apa pun di area yang ditentukan dan memindahkannya ke Buffer Router. Mirip dengan Absorption Hopper. \\n\\nJuga bisa digunakan bersama Experience Augment!"]
	quest.41877F44CD3D1EDB.quest_desc: ["&#E3BC19Bronze Furnace&r bertindak persis seperti tungku biasa, satu-satunya perbedaan besar adalah ia berjalan menggunakan uap dan bekerja dua kali lebih cepat."]
	quest.418E57E34FFC19E1.quest_desc: ["Saran: Pakai semacam Wither-Proof Glass."]
	quest.418E57E34FFC19E1.quest_subtitle: "Void Miner"
	quest.418E57E34FFC19E1.title: "Laser Drill"
	quest.4193303999597249.quest_desc: [
		"&9Twilight Forest&r adalah mod yang menambahkan dimensi Hutan Senja ke dalam game. Dimensi ini penuh dengan item, biome, mob, dan bos yang benar-benar baru!\\n\\nUntuk membuat portal menuju &9Twilight Forest&r, buatlah lubang 2x2 di tanah dan isi dengan air. Kelilingi pinggiran lubang dengan bunga, lalu lemparkan Diamond ke dalam air.\\n\\nJika kamu melakukannya dengan benar, Thor akan memberimu tanda dan portal akan aktif.\\n"
		"{image:atm:textures/questpics/gettingstarted/twilight_portal.png width:100 height:100 align:center fit:true}"
	]
	quest.4193303999597249.quest_subtitle: "Masuki Twilight Forest"
	quest.4193303999597249.title: "Selamat Datang di &9Twilight Forest&r!"
	quest.4194397DFD0199C2.quest_desc: ["&6Pengrajin Mekanik&r bisa digunakan untuk &6Pembuatan Otomatis&r dan Resep yang lebih besar dari Grid Kerajinan 3x3 seperti &6Roda Penghancur&r. \\n\\nLetakkan &6Pengrajin Mekanik&r sesuai urutan yang dibutuhkan, lalu atur arah &eItem&r dalam resep bergerak. \\n\\nArahnya ditunjukkan oleh panah di tepi &6Pengrajin&r. Ini bisa diubah dengan Klik Kanan menggunakan &6Kunci Inggris&r! \\n\\nKemudian, masukkan &eItem&r ke dalam &6Pengrajin Mekanik&r baik dengan tangan atau otomatis dengan &eCorong&r. \\n\\nSetelah itu, beri &dTenaga Rotasi&r ke &6Pengrajin Mekanik&r mana saja (mereka berbagi &dRoda Gigi&r) untuk memulai Resep. \\n\\nKalau tidak berjalan, periksa apakah semua &eItem&r sudah masuk, setiap panah sudah menghadap arah yang benar, dan sudah punya cukup &dTenaga Rotasi&r."]
	quest.4194397DFD0199C2.title: "&6Pengrajin Mekanik"
	quest.4195800B4D7631E2.quest_desc: ["Lewat ritual &6Eziveus' Spectral Compulsion&r kita bisa gabungin &7Wormhole Frame&r, 2 Quartz, dan &3Enderpearl&r buat dapetin Wormhole kita!"]
	quest.4195800B4D7631E2.title: "&6Stable Wormhole"
	quest.419C808FE10DB496.quest_subtitle: "Balsa + Wenge"
	quest.419DD6FE84B91749.quest_desc: ["Saat mengumpulkan gen, kamu akan mendapat persentase tertentu. Kamu bisa menggabungkannya di meja crafting untuk menjumlahkan nilainya, atau taruh di Gene Indexer untuk penggabungan otomatis."]
	quest.419DD6FE84B91749.quest_subtitle: "Peti dan Penggabung Gen"
	quest.41A0BE357C8A74E1.quest_desc: ["&9Alchemical Sourcelink&r menghasilkan Source dari toples ramuan (potion jar) di sampingnya. \\n\\nJumlah Source yang dihasilkan bervariasi tergantung jenis ramuan dan kerumitannya."]
	quest.41A0BE357C8A74E1.quest_subtitle: "Energi Lewat Ramuan"
	quest.41ABC09C798CA8BE.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.41B99DBD03EB74FF.quest_desc: [
		"Percaya, Multiblok tidak berbohong ketika mengatakan ditingkatkan! \\n\\nYang satu ini bisa diotomatisasi untuk menerima &9Input&r dari Atas, dan &6Output&r dari Slot Depan dan Belakang. \\n\\nJuga, bisa menambahkan Preheater ke Kiri dan Kanannya! \\n\\nSemua ini membuatnya jauh lebih cepat dan tentu saja, lebih efisien!"
		"{@pagebreak}"
		"Akhirnya yang berbeda! Mulai dengan dasar 3x3x3 &4Bata Blast yang Diperkuat&r."
		"{image:atm:textures/questpics/immersive/immersive_blast1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_blast2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_blast3.png width:100 height:100 align:center}"
		"Kemudian, letakkan Hopper di Atas Blok Tengah."
		"{image:atm:textures/questpics/immersive/immersive_blast4.png width:100 height:125 align:center}"
		"Sekarang Klik Kanan Blok Tengah lapisan ke-2 dengan &6Palu Insinyur&r."
		"{image:atm:textures/questpics/immersive/immersive_blast.png width:100 height:150 align:center}"
	]
	quest.41B99DBD03EB74FF.title: "&l&4Tungku Blast yang Ditingkatkan"
	quest.41BD497108CA109F.quest_desc: ["Awakened Draconium berasal dari Fusion Crafting block-nya. Block-nya bisa di-uncraft jadi 9 Ingot. Ini Ingot terpenting kedua di Draconic Evolution dan sangat diperlukan untuk Tier Wyvern dan Draconic."]
	quest.41BD497108CA109F.title: "Awakened Draconium"
	quest.41C0948CD9D50322.quest_desc: ["Di sini kamu akan menemukan semua hadiah yang bisa kamu dapatkan dengan membantai musuh."]
	quest.41C0948CD9D50322.quest_subtitle: "Membantai Segalanya"
	quest.41C0948CD9D50322.title: "Papan Buronan (Bounty Board)"
	quest.41C661E8630D0146.quest_subtitle: "&f5 &cAttack Damage"
	quest.41C70F0873E14307.quest_desc: ["Ada Pohon di Gurun! \\n\\nGak, tunggu, dulunya ada Pohon..."]
	quest.41C7DEAB41F4B700.quest_desc: [
		"&2&lGorgon&r adalah wanita sombong yang dikutuk karenanya. Sekarang mereka diubah jadi monster setengah Ular setengah Wanita dengan Ular sebagai rambut. \\n\\n&2&lGorgon&r punya 300 &4Hearts&f dan 2 &7Armor Points&r. \\n\\nMereka punya satu Serangan yang sangat kuat yang bakal bunuh Mob apapun yang mereka liat. Ngubah mereka jadi &7Patung Batu&r dengan liat ke Mata mereka. \\n\\nSerangan ini bakal ubah Mob apapun jadi &7Patung&r, ini bakal bunuh Mob tapi gak kasih Drop. Ini juga bakal langsung bunuh Player. \\n\\nKecuali kamu pake Penutup Mata! Ini bakal kasih kamu Blindness dikit tapi bakal cegah Kematian instan. Selain itu mereka juga bisa Pukul kamu."
		"{image:atm:textures/questpics/iceandfire/iaf_gorgon.png width:100 height:150 align:center}"
	]
	quest.41C7DEAB41F4B700.title: "&2&lGorgon"
	quest.41CF7CAEE4F60CCD.quest_desc: ["Saat diletakkan di Nether dan diberikan Glowstone, Glowstone Nest akan memancing Glowing Bee."]
	quest.41CF7CAEE4F60CCD.quest_subtitle: "Memancing Glowing Bee di dimensi Nether"
	quest.41D0CC616B762F4C.quest_desc: ["Kamu bisa melempar sebuah &9Fluix Bee Spawn Egg&r dan &8Entro Dust&r ke dalam air untuk membuat Entro Bee Spawn Egg."]
	quest.41D0CC616B762F4C.title: "Entro Bee"
	quest.41D246E896BD791F.quest_subtitle: "Tingkat: &63"
	quest.41D539DA3B3EC287.quest_desc: [
		"Nama Goliath sebenarnya kurang menggambarkan betapa besarnya Air Mancur &6Madu&r ini. Bayangkan sesuatu yang jauh lebih masif! \\n\\nAir Mancur Goliath &6Madu&r adalah struktur raksasa dengan jumlah &6Madu Cair&r seukuran samudra di dalamnya. \\n\\nKamu bahkan bisa berkeliling di dalamnya untuk menemukan banyak &6Kristal Madu&r dan &5Amethyst&r."
		"{image:atm:textures/questpics/bumblezone/bumble_goliath.png width:200 height:100 align:center}"
	]
	quest.41D539DA3B3EC287.title: "Air Mancur &6Madu&r Goliath"
	quest.41DBE44D7AA0B623.quest_desc: ["Meja Tinkering adalah cara kamu nambah augment ke perlengkapan essence kamu!"]
	quest.41E8550FC36ABCA5.title: "Infinity Tools"
	quest.41E8C93A44559E48.quest_desc: ["&7Mesin Paradoks&r bisa, dengan biaya banyak Tenaga dan &aCairan Waktu&r, mengambil Tangkapan balok dan entitas di area yang ditentukan; lalu menduplikasinya. \\n\\nBanyak Balok dan Entitas yang dilarang oleh konfigurasi jadi gak bisa duplikasi Lebah!"]
	quest.41F9CC26C7D86AE9.quest_desc: ["Dengan &bSirip Hippocampus&r dan Stick, kita bisa Craft Senjata terhebat di semua &2&lMinecraft&r Modded! \\n\\n&bPenampar Hippocampus&r! \\n\\nEngga, ini gak bakal kasih Damage paling banyak... tapi bakal kasih Mob yang kena efek Slowness III dan Nausea III! \\n\\nOke oke ini bukan yang terhebat, lebih kayak Senjata bercanda... tapi tetep!"]
	quest.41F9CC26C7D86AE9.title: "&bPenampar Hippocampus"
	quest.41FD145B911BD625.quest_subtitle: "Telur Spawn Silver Bee ke dalam Spiritfire"
	quest.41FD145B911BD625.title: "Iesnium Bee"
	quest.420158B1736A1354.quest_desc: ["...belum diimplementasikan.\\n\\nSebagai gantinya, pergilah ke kastel raksasa di Final Plateau dan ambil beberapa blok pintu!\\n\\nAda seekor Kobold yang muncul sebagai \"placeholder\", tapi kamu tidak akan mendapatkan apa-apa dengan membunuhnya."]
	quest.420158B1736A1354.title: "&cBos Terakhir"
	quest.420CB9502DF8E1BC.quest_desc: ["&b&lIce Spider&r. \\n\\nIni adalah Musuh dengan 50 &4Heart&r dan 20 Armor Point. \\n\\nJika kamu mendekat mereka akan Menggigitmu atau Memukulmu dengan salah satu dari banyak Lengan mereka! \\nJika kamu menjauh mereka akan Menembak semacam &bkepompong Es&r? Sepertinya? Apa pun itu, ini memberikan Damage padamu dan &bMembekukan&r mu di tempat. Atau mereka mungkin mengirim barisan &bBatu Es&r ke arahmu dari tanah untuk memberikan Damage. \\n\\nSaat Mati mereka akan Menjatuhkan String, &5Arcane Essence&r, dan kadang-kadang &bIcy Fang&r."]
	quest.420CB9502DF8E1BC.title: "&b&lIce Spider"
	quest.420FE84DEE12CCE0.quest_desc: ["&eGold Furnace&r lebih bagus dari yang Iron dengan Cooktime 120 Tick.\\n\\nBisa di-craft dari &7Silver&r atau Iron Furnace dan di-craft jadi yang &bDiamond&r!"]
	quest.420FE84DEE12CCE0.title: "&eGolden Furnace"
	quest.4211F29561F21643.quest_desc: ["Cara kerja &9&lTurbine&r adalah dengan ngambil Steam lewat &9Port&r dan Steam itu bakal gerakin &9Blade&r di &9Rotor&r. \\n\\nOh tunggu gue harusnya jelasin dulu cara bikin bagian dalam &9&lTurbine&r! \\n\\n&9Rotor&r bakal ditaro dari lantai ke atas di tengah persis &9&lTurbine&r. Tiap &9Rotor&r bisa nyimpen 2 &9Blade&r. \\n\\nMakin banyak &9Blade &fdan &9Rotor&r makin lebar. Kita gak bisa pake Base 5x5 dengan bagian dalam yang lebih gede. \\n\\nDi atas &9Rotor&r paling tinggi kita taro &9Rotational Complex&r. Percaya deh ini penting!"]
	quest.4211F29561F21643.title: "Bagian yang bergerak"
	quest.421851D4D39910DB.quest_desc: ["Mempengaruhi kemungkinan lebah kehilangan sengatnya saat menyerang. Ada 4 tingkat: &aWeak&r, &9Normal&r, &dMedium&r, &cStrong&r. Kita mengincar &cStrong&r. Lebah tertentu seperti Draconic dan Obsidian secara alami memiliki daya tahan tinggi, sehingga mereka tidak mati setelah menyengat."]
	quest.421851D4D39910DB.quest_subtitle: "Biar lebahmu nggak 'sekali pakai'"
	quest.421851D4D39910DB.title: "&b&lDaya Tahan (Endurance)"
	quest.421954D7D46FAAD6.quest_desc: ["Energy Core Stabilizers... menstabilkan? Core. Untuk 4 Tier pertama Core kamu hanya butuh 4 Stabilizer di sekitarnya. Kamu bisa mengakses GUI Core melalui Stabilizer juga. Kalau ditempatkan terlalu dekat dengan Core atau di tempat yang salah akan memberitahu bahwa itu salah."]
	quest.421954D7D46FAAD6.title: "Energy Core Stabilizers"
	quest.4221D6CDDF90DACB.quest_subtitle: "Tingkat: &b4"
	quest.423B8DA485C1308C.quest_desc: ["&3Gasoline&r (Bensin) dapat digunakan untuk membuat LPG."]
	quest.423B8DA485C1308C.quest_subtitle: "Gas, gas, gas"
	quest.423B8DA485C1308C.title: "Bensin"
	quest.424B3E3B299D3999.quest_desc: ["Gauge &8Dropper&r itu alat yang berguna buat bersihin isi &cChemical&r. \\n\\nDi GUI &5Mesin&r, ambil Gauge &8Dropper&r-nya terus seret ke atas &cChemical&r yang ada di &5Mesin&r. Terus tinggal Klik Kanan nanti dia bakal ambil &cChemical&r-nya dan masuk ke &8Dropper&r. \\n\\nAku lupa bilang, kita bisa balikin &cChemical&r itu dari Gauge &8Dropper&r dengan klik ke tempat &5Penyimpanan Kimia&r kayak tanki atau kosongin &8Dropper&r-nya dengan shift-klik di udara."]
	quest.424B3E3B299D3999.title: "Gauge &8Dropper"
	quest.425E375A9EC127EB.quest_desc: [
		"&6Reinforced Track&r adalah versi yang lebih kuat dari &6rel&r normal! Jalur ini sedikit lebih cepat dan tidak meledak."
		"{@pagebreak}"
		"1"
		"{image:atm:textures/questpics/railcraft/rail_reinforced1.png width:150 height:100 align:center}"
	]
	quest.425E375A9EC127EB.title: "&6Jalur Rel Diperkuat (Reinforced)"
	quest.42626A0CD814353D.quest_desc: [
		"&5Naga Petir&r bakal ngabisin hari mereka di Sarang mereka di atas tanah. \\n\\nMereka keliatan kayak &cSarang Naga Api&r, cuma daripada &cHangus&r ini &5Retak&r! Dan daripada &eEmas&r ini &6Tembaga&r! \\n\\nYa, &5&lNaga&r paling susah dapat &6Ingot&r terjelek... masuk akal sih. \\n\\nIni bakal jadi tempat &lStage 1&r sampe &lStage 3&r spawn."
		"{image:atm:textures/questpics/iceandfire/iaf_struct_lightningroost.png width:200 height:100 align:center}"
	]
	quest.42626A0CD814353D.title: "&5Sarang Naga Petir"
	quest.427014BDE06DE631.quest_desc: ["Semua yang kupukul langsung terbakar api!!!!!"]
	quest.427014BDE06DE631.quest_subtitle: "Tangan"
	quest.427014BDE06DE631.title: "&cFire Gauntlet&r"
	quest.42746659C66CF17F.quest_desc: ["&6&oLibrary of Alexandria&r adalah versi lebih baik dari &5Enchantment Library&r. \\n\\nPerpustakaan ini bisa menampung level &5Enchanted Book&r yang lebih tinggi, tapi kamu tetap butuh level buku tersebut agar bisa mengambilnya di level yang sama. \\n\\nKapasitas poinnya juga jauh lebih besar. Jika &5Enchantment Library&r biasa menampung 32.768 poin, &6&oLibrary of Alexandria&r bisa menampung hingga 1,1 Miliar poin untuk setiap jenis &5Buku&r! \\n\\nUntuk mendapatkannya, kita harus melakukan &d&lInfuse&r pada &5Enchantment Library&r. \\n\\nGunakan 4 &9Soul-Touched Sculkshelf&f, 4 &9Echoing Sculkshelf&f, 1 &dDraconic Endshelf&f, 5 &6Geode-Encased Bookshelves of Stability&r, dan satu Skeleton Skull."]
	quest.42746659C66CF17F.quest_subtitle: "Bayangkan saja jika Roma tidak pernah terbakar..."
	quest.42746659C66CF17F.title: "&6&oLibrary of Alexandria"
	quest.4274E777FB60BA28.quest_desc: ["&a&lChargepad&r bakal isi daya (Charge) &eItem&r apa pun yang dibawa pemain pas pemain berdiri di atas &a&lPad&r ini! \\n\\nJelas alat ini butuh &aEnergi&r di dalamnya biar jalan. Kita bisa masukin dari belakang atau bawah &a&lChargepad&r. \\n\\nPas sudah ada &aEnergi&r, dia bakal Charge tiap &eItem&r di inventory-mu yang bisa nampung daya! \\n\\nNggak peduli dari mod mana pun! \\nDia bakal prioritasin &eItem&r pertama di inventory dan pas sudah penuh baru lanjut ke yang lain. \\n\\nSeberapa cepat isinya kayaknya sama buat semua &eItem&r."]
	quest.4274E777FB60BA28.title: "&a&lChargepad"
	quest.427516AA3E8C9442.quest_subtitle: "Cangkul Serbaguna"
	quest.427B9C6D95885DE2.quest_subtitle: "Red Delicious Apple + Flowering Azalea"
	quest.427BBEB1F24E9DEE.quest_desc: ["Hampir semua bahan &5Corrupti Dust&r gampang diotomatisasi. \\n\\n&4Nether Wart&r bisa pakai farm otomatis apa aja. &cBlaze Powder&r dan &3Enderpearl Fragment&r bisa didapat dari &b&lHNN&r. &bArcane Crystal&r juga udah dijelasin di quest lain. \\n\\nCuma &5Obsidiansteel&r yang perlu diotomatisasi lewat &b&lRunic Crucible&r."]
	quest.427BBEB1F24E9DEE.title: "&5Corrupti Dust"
	quest.427C3AFC0FF131CD.title: "Fluid"
	quest.4281BCDCE233F65B.quest_desc: ["Bisa ditemukan di dalam peti di Ancient City."]
	quest.4281BCDCE233F65B.quest_subtitle: "Peti Ancient City"
	quest.42822B1E8A53D051.title: "&l&9Overworld Bounty:&r&e Skeletons"
	quest.4285510271B5223D.quest_desc: ["&dGearbox&r berguna untuk mengirimkan &dTenaga Rotasi&r ke berbagai arah sekaligus! \\n\\n&dGearbox&r biasa punya 4 &8Poros&r internal di masing-masing Arah Kardinal: Utara, Timur, Selatan, dan Barat. \\n\\n&8Poros&r lainnya akan cocok Kecepatan dan Satuan Stresnya, tapi mereka juga akan berputar ke arah yang berbeda dari &8Poros&r aslinya."]
	quest.4285510271B5223D.title: "&dGearbox"
	quest.42951D14ADCD9332.quest_desc: ["Boleh pesan yang pakai kacang polong lumat dan kacang di atas roti nggak, Pak?"]
	quest.42951D14ADCD9332.quest_subtitle: "Mau Fish \\& Chips?"
	quest.42951D14ADCD9332.title: "Fish \\& Chips!"
	quest.4295C863C9A81F28.quest_desc: ["Kumparan Tesla adalah pertahanan rumah yang sangat menyenangkan dan &cEnergi&r lapar! \\n\\nPertama, beri daya dengan &cEnergi&r dari Port mana pun. Kemudian, beri &4Sinyal Redstone&r untuk menyalakannya, atau gunakan &6Obeng Insinyur&r untuk membuatnya selalu menyala! \\n\\nSetelah menyala, akan aktif menggunakan &cEnergi&r dan ketika Mob mendekat, akan Membuat mereka terpukau dan melukai mereka! Melukai Mob membuatnya mengambil lebih banyak &cEnergi&r. \\n\\nBisa Shift Klik Kanan dengan &6Obeng Insinyur&r untuk mengaturnya ke mode daya rendah. Akan mengambil lebih sedikit &cEnergi&r tetapi juga memiliki Jangkauan lebih sedikit dan memberikan Kerusakan lebih sedikit!"]
	quest.429785E8F64929CE.quest_desc: ["Buat ke Starlight Dimension kamu harus nemuin Portal Ruin di Overworld. \\n\\nDi sana kamu bakal nemuin Gatekeeper, Right Click buat mulai percakapan dan tantang mereka duel! Hati-hati, mereka sangat tangguh. \\n\\nKalau kamu menang duel kamu bakal dikasih beberapa Item, salah satunya Orb of Prophecy. Right Click Portal dengan Orb buat ngaktifin! Terus, masuk buat ke..."]
	quest.429785E8F64929CE.title: "Gatekeeper dan Gate"
	quest.429B5A81DF6C43FE.quest_desc: [
		"&6Odus' Open Convocation&r digunakan untuk memasukkan setan &cAfrit&r ke dalam seekor Babi. Karena ritual ini dilakukan tanpa menggunakan Red Chalk, kekuatannya hanya cukup untuk memanggil setan &9unbound&r (liar)."
		""
		"Spesifiknya, ritual ini akan menciptakan Zombified Piglin yang dirasuki &cAfrit&r, yang akan menjatuhkan Demonic Meat untuk membuat Pink Chalk."
		""
		"&4PERINGATAN: KAMU MUNGKIN HARUS MELAKUKAN INI BEBERAPA KALI UNTUK MENDAPATKAN CUKUP DEMONIC MEAT."
	]
	quest.429B5A81DF6C43FE.quest_subtitle: "Daging banget..."
	quest.429B5A81DF6C43FE.title: "&6Odus' Open Convocation"
	quest.42AAEC41F2BC2474.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_glacite.png width:100 height:150 align:center}"]
	quest.42AAEC41F2BC2474.title: "&bGlacite&r"
	quest.42AF4EBDA5D6CC36.quest_desc: ["Kamu bisa bikin &2Blastproof Alloy&r dengan gabungin tiga Logam terkuat yang ada. &5Tungsten&r, &dTitanium&r, dan &7Stainless Steel&r. Iya, noda itu penting rupanya. \\n\\nDengan ini kamu bisa gabungin buat bikin &2Casing&r. \\n\\nBuat &3&lImprobable Probability Device&r kita butuh antara 2 &2Blastproof Casing&r, atau 2 256M Portable Item Cell, atau bisa pake campuran keduanya!"]
	quest.42AF4EBDA5D6CC36.title: "&2Blastproof Casing"
	quest.42CB494F72FA1FD1.quest_desc: ["Buatlah 6 &eBeehive&r atau &eBeenest&r. Ini termasuk sarang dari mod &l&6Productive Bees&r juga!"]
	quest.42D173B9FF8D16E4.quest_desc: ["Mencari opsi daya di awal permainan? Ini adalah cara yang baik untuk mulai menghasilkan daya.\\n\\nAlat-alat ini tidak menghasilkan banyak daya, tapi biasanya mudah atau murah untuk didapatkan di awal permainan!"]
	quest.42D173B9FF8D16E4.quest_subtitle: "Daya Awal"
	quest.42D173B9FF8D16E4.title: "&8&lOpsi Daya Early Game"
	quest.42D7C8CD8E6F5CD7.quest_desc: ["Dengan menggunakan Chorus Fruit pada Spawner, kamu menyedot jiwa dari mob yang akan muncul, meninggalkan mereka hanya sebagai cangkang kosong. Mob tersebut akan kehilangan semua AI (kecerdasan buatan), jadi mereka cuma akan diam seperti armor stand. Mereka nggak bisa memukulmu, nggak bisa teleportasi, dan nggak bisa bergerak sendiri. Mereka cuma duduk manis menunggu buat dibunuh, seru kan!"]
	quest.42D7C8CD8E6F5CD7.title: "Tanpa AI"
	quest.42F50CE7FE715583.quest_desc: [
		"Untuk meningkatkan jumlah stack yang bisa ditampung penyimpanan sihirmu, kamu perlu membuat &dStorage Stabilizer&r."
		""
		"Setelah dibuat, alat ini harus diarahkan langsung ke bagian Dimensional Matrix pada Storage Actuator-mu, bukan ke dasarnya. Jaraknya bisa sampai 5 blok, tapi harus memiliki pandangan tanpa penghalang ke arah Matrix."
		""
		"Kapan pun kamu ingin meningkatkan Stabilizer ke tingkat yang lebih tinggi, menghancurkannya tidak akan menghilangkan item di dalamnya. Namun, kamu tidak akan bisa menambah item lagi sampai alatnya diganti atau ditingkatkan."
		""
		"Di bawah adalah contoh setup sederhana!"
		""
		"{image:atm:textures/questpics/occultism/storageupgradeexample.png width:200 height:150 align:1}"
	]
	quest.42F50CE7FE715583.title: "&aMeningkatkan Penyimpanan Sihir Kita"
	quest.43008E93B34F4F06.quest_desc: ["Dengan &9Sisik Ular Laut &fdan &9Taring&r plus Stick kita bisa bikin &9Anak Panah Pasang&r. \\n\\nIni kerja kayak Anak Panah normal tapi gak bakal dilambatin sama &9Air&r."]
	quest.43008E93B34F4F06.title: "&9Anak Panah Pasang"
	quest.43021923E220CF68.quest_desc: ["Untuk bajak Dirt jadi Farmland kamu butuh Hoe."]
	quest.43021923E220CF68.quest_subtitle: "Tunggu sampai kamu dapat Mesin untuk ini..."
	quest.43021923E220CF68.title: "Petani"
	quest.43167C59036E79A7.quest_desc: ["&8Tome of Miner&r akan membantumu dalam segala urusan menambang. Buku ini memberikan &5Efficiency&f, &5Fortune&f, dan &5Silk Touch&r. \\n\\nEfek ini berlaku untuk Pickaxe, Axe, Shovel, bahkan Hoe! \\n\\n&8Tome of the Fisher&r hanya memberikan &5Enchantment&r khusus alat pancing, dan ya, pilihannya ada banyak."]
	quest.43167C59036E79A7.title: "&8Tool Tomes"
	quest.431A8FDF15701BA4.quest_desc: ["&2Hunter's Belt&r bekerja seperti sabuk kulit pada umumnya yaitu menyimpan Talisman. Itu adalah kemampuan pertamanya yang bisa di-upgrade untuk menampung lebih banyak! \\n \\nKemampuan keduanya meningkatkan damage yang dihasilkan peliharaanmu. Peliharaan adalah mob jinak yang bisa menyerang mob lain, seperti serigala!"]
	quest.431A8FDF15701BA4.quest_subtitle: "Ditemukan di Rumah Jagal (Butcher) di Desa mana pun"
	quest.431A8FDF15701BA4.title: "&2Hunter's Belt"
	quest.431C62A6F8ECB4EC.quest_desc: ["&7Batang Aluminium&r - 10 \\n&7Batang Besi&r - 16 \\n&8Batang Baja&r - 24 \\n&8Bilah Gergaji&r - 12 \\n&0Elektroda Grafit&r - 30"]
	quest.431C62A6F8ECB4EC.title: "Ammo &5&lRailgun&r dari &8&lIE&r"
	quest.43265FEF45846357.quest_subtitle: "Pomelo + Citron"
	quest.433117EEA55B6A54.quest_desc: ["Peletakan cairan sederhana."]
	quest.435890CE1A1B3C04.quest_desc: [
		"&4Gua Cyclops&r untungnya gak di bawah Tanah! Mereka spawn di atas Tanah di &eGurun The Other&r. \\n\\nLo bisa kenali dari penampilannya, yang cuma kubah gede yang sepenuhnya terbuat dari &7Batu&r! \\n\\nDi dalam &4Gua Cyclops&r kamu bakal nemuin &4&lCyclops&r dan Domba-dombanya! Domba-dombanya ada di kandang mereka dan entah Putih atau &eKuning&r. \\n\\nLoot di &4Gua&r-nya kebanyakan berhubungan sama Domba, dari Wool sampai Gunting, sampai Daging Domba... Lebih bagusnya juga ada &eTumpukan Emas&r!"
		"{image:atm:textures/questpics/iceandfire/iaf_struct_cyclops.png width:200 height:100 align:center}"
	]
	quest.435890CE1A1B3C04.title: "&4Gua Cyclops"
	quest.43630EF0B85AE7E1.quest_desc: [
		"Jauh di dalam tanah kita bisa nemuin &cGua Hangus&r yang gede banget. \\n\\nPuluhan Blok panjang, lebar, dan tinggi. Penuh dengan &eEmas&r dan Chest. \\n\\nKarena Gelap lebih banyak Mob mungkin spawn di dalam. Tapi di dalam Gua bakal ada &c&lNaga Api&r yang gede banget. \\n\\nYang sama persis yang ngancurin Desa di Zaman Kegelapan. Satu yang lebih kuat dari yang manapun di atas permukaan. \\n\\nIni &lStage 4&r dan &l5 &cNaga Api&r. \\n\\nMereka adalah mimpi buruk yang jadi kenyataan."
		"{image:atm:textures/questpics/iceandfire/iaf_struct_firecave.png width:200 height:100 align:center}"
	]
	quest.43630EF0B85AE7E1.title: "&cGua Naga Api"
	quest.436E4E3515BCCDE9.quest_desc: ["Dengan &bCloud in a Bottle&r, kamu bisa menekan spasi dua kali untuk melakukan Double Jump! Sangat membantu buat parkour! \\n\\nJuga meningkatkan batas ketinggian aman saat jatuh, kayak &dBunny Hoppers&r!"]
	quest.436E4E3515BCCDE9.quest_subtitle: "Sabuk"
	quest.436E4E3515BCCDE9.title: "&bCloud in a Bottle&r"
	quest.437DB2CE10D33A08.quest_desc: ["Kamu butuh sebuah &6Glowstone Nest&r dan pergi ke dimensi Nether untuk menangkap lebah ini!"]
	quest.437DB2CE10D33A08.title: "Glowing Bee"
	quest.437F4945AFBE0825.quest_desc: ["Saat klik kanan pada Importer atau Exporter, akan muncul menu. Menu ini terutama untuk filtering, misalnya punya Variable Card yang diatur ke Cobblestone, Exporter hanya akan mengirim Cobblestone.\\n\\nAda tanda \"+\" kecil di sebelah kiri variable saat dimasukkan, klik untuk membuka GUI lain. Di sini bisa mengubah transfer rate untuk bisa mengirim item/fluid/energy &dTANPA BATAS&r, dan bisa melakukan hal lain juga.\\n\\nDi kiri atas ada settings, ini sebagian besar sama dengan interface settings."]
	quest.438F734D16DA9638.quest_desc: ["Kita udah dapet &aPolonium&r dan sisanya yang harusnya kita udah punya! \\n\\nYaitu &2&lP.R.C.&r, &9Air&r, sama &dFluorite Dust&r! \\n\\nGabungin 1,000mB &9Air&r, dengan 1,000mB &aPolonium&r, sama 1 &dFluorite Dust&r buat bikin 1 &aPolonium Pellet&r dan 1,000mB &8Spent Nuclear Waste&r. \\n\\n&dFluorite Dust&r bisa dibuat kayak Metal Dust pada umumnya: &4&lCrusher&r, &d&lEnrichment Chamber&r, atau bahkan Ore Hammer!"]
	quest.438F734D16DA9638.title: "&aPolonium Pellet"
	quest.43922DB543DC05C0.quest_desc: [
		"&lStage 1&r sampe &l3 &bNaga Es&r bakal Spawn di &bSarang Naga Es&r. \\n\\n&b&lNaga Es&r dateng dalam Warna &bBiru&f, Putih, &9Safir&r, dan &7Perak&r. Mereka juga punya 6 Tanduk di Kepala dan satu lagi di Hidung. Plus ekor kayak kipas. \\n\\n&b&lNaga Es&r bisa ditemuin Terbang atau bahkan Berenang di sekitar &bSarang Naga Es&r mereka di Bioma Bersalju. Pas mereka nemuin penyusup mereka bakal pake banyak Serangan mengerikan buat ngurusin kamu. Kayak... \\n\\n&bNapas Es&r mereka yang bakal &bBekuin&r Player dan Blok di jalan mereka. Cuma &lStage 2&r ke atas &b&lNaga Es&r yang bisa pake &bNapas Es&r. Kalo itu belum cukup, mereka juga bisa Tembak &bBola Es&r ke kamu. Ini bakal meledak dan &bBekuin&r setiap Mob deket! Untungnya cuma &lStage 3&r ke atas yang bisa pake Serangan ini. \\n\\nMereka gak cuma pake &bSerangan Elemental&r, mereka juga bisa Cambuk Ekor kamu, Gigit kamu, atau acak-acak Badan kamu pake Mulut mereka! Plus Kipasin Sayap mereka buat lempar kamu mundur dari mereka. \\n\\n&bSerangan Es&r mereka bisa &bBekuin&r dan Damage kamu jadi paling baik hindari itu sebisa mungkin. Jaga jarak kamu sebisa kamu dan jangan takut buat cari perlindungan. Pet yang Terbang gak bakal terlalu membantu kalo mereka &bBeku&r di Langit!"
		"{@pagebreak}"
		"Setelah kamu bertahan lawan &b&lNaga Es&r dan menang, &b&lNaga Es&r bakal jadi Mayat. Coba jangan sampai ilang di antara Salju dan Es. \\n\\nTerus, Klik Kanan Mayat dengan Tangan Kosong dan bakal lepas &bSisik&f, &bDaging&f, dan &bJantung&r dari &b&lNaga Es&r. \\n\\nDaripada Klik Kanan pake Tangan Kosong, kenapa gak pake Botol Kosong! Ini bakal kasih kita &bDarah Naga Es&r daripada &bSisik &fatau &bDaging&r. \\n\\nPas semua bagian enaknya dilepas, dia bakal jadi &7Kerangka Naga&r. Terus, kamu bisa lepas &7Tulang&f dan &7Tengkorak&r-nya, sama kayak kamu dapet &bSisik &fatau &bDarah&r!"
	]
	quest.43922DB543DC05C0.title: "&lStage 1-3 &bNaga Es"
	quest.439B5FDAC84271A2.quest_subtitle: "Diamond + Iron"
	quest.439B5FDAC84271A2.title: "Titanium Bee"
	quest.43A1BC20BB054A14.quest_desc: ["Glitterkelp tumbuh di Ancient Sea dan Icy Sea. \\n\\nMereka tidak punya banyak fungsi selain bersinar dan bisa di-craft menjadi Pie!"]
	quest.43A5B83862D9E94C.quest_desc: ["&bEye of Flame&r akan menuntunmu ke &bBurning Arena&r untuk melawan &b&lIgnis&r."]
	quest.43A5B83862D9E94C.title: "&bEye of Flame&r"
	quest.43C2B07AB25C708E.quest_desc: ["Versi upgrade dari Wyvern Bow."]
	quest.43C2B07AB25C708E.title: "Draconic Bow"
	quest.43CDC28DC56BB3E2.quest_subtitle: "128,000mb"
	quest.43D83CFA824B0A70.quest_desc: ["&9Mekanism&r memiliki opsi daya akhir permainan yang sulit dikalahkan. &dFusion Reactor&r dapat menghasilkan hingga 80MRF/t, dan jika kamu ingin belajar cara membangunnya, pastikan cek bab quest &aMekanism: &dReactors&r!"]
	quest.43D83CFA824B0A70.quest_subtitle: "Aktivasi Fusi!"
	quest.43D83CFA824B0A70.title: "&9Mekanism: &dFusion Reactor"
	quest.43DB0CFC5F5B0967.quest_desc: ["&aDosimeter&r bakal nunjukin berapa banyak Unit SVP &aRadiasi&r yang ada di dalam lo. \\nIya, di dalam lo. \\n\\nInget lo bisa enable sama disable buat bebasin ruang di HUD!"]
	quest.43DB0CFC5F5B0967.quest_subtitle: "Bodyarmor"
	quest.43DB0CFC5F5B0967.title: "&aDosimeter &7Unit"
	quest.43E8912CB307E421.quest_desc: ["Bagus! Kita bisa menyimpan barang secara virtual, tapi bagaimana cara melihat apa saja yang ada di jaringan?\\n\\nUntuk mengakses sistem, kamu perlu membuat &3Grid&r. Ini adalah bentuk paling dasar dari 'Layar Display' untuk item di jaringanmu.\\n\\n&3Grid&r ini bisa menampilkan Item, Cairan, Energi, Source, Soul, dan Kimia."]
	quest.43E8912CB307E421.quest_subtitle: "Akses Jaringanmu"
	quest.43E8912CB307E421.title: "&3The Grid"
	quest.43EF5513A1C52A37.quest_desc: ["&3Thermopneumatic Processing Plant&r akan digunakan untuk membuat Plastik Cair, cukup alirkan LPG, Batu Bara, dan sedikit panas."]
	quest.43EF5513A1C52A37.quest_subtitle: "Semakin panjang namanya, semakin bagus"
	quest.43EF5513A1C52A37.title: "Pemrosesan Termopneumatik"
	quest.43F08B510FC1C06F.quest_desc: ["Item IO memberikan kemampuan untuk mentransfer item masuk dan keluar dari Tank. Bisa diatur untuk mode Output maupun Input."]
	quest.43F08B510FC1C06F.quest_subtitle: "Tempat Item Datang dan Pergi"
	quest.43F08B510FC1C06F.title: "Item IO"
	quest.43FD4AEBB9548E57.quest_desc: [
		"Smogstem Forest adalah biome tetangga dari Indigo Mushroom Bog. \\n\\nTentu saja tempat ini juga berwarna biru dan ada Jamur Indigo di dalamnya! Bedanya hanya ia memiliki Pohon Smogstem yang lebih besar!"
		"{image:atm:textures/questpics/undergarden/undergarden_smogstem.png width:200 height:100 align:center}"
	]
	quest.43FD4AEBB9548E57.title: "Smogstem Forest"
	quest.4407BD7B5F033765.quest_desc: ["&eSpell Book&r yang bisa di-Craft lainnya dan mengikuti pola yang satu ini bahkan lebih mahal. Membutuhkan Arcane Cloth, Gold, dan Enchanted Book. Tidak pilih-pilih Book mana saja yang penting Enchanted! \\n\\nIni punya 10 &3Spell&r Slot dan memberikan boost Mana yang besar!"]
	quest.4407BD7B5F033765.title: "Enchanted Spell Book"
	quest.440B1E1D4951F808.quest_desc: [
		"&3Smart Chest&r adalah peti tahan ledakan dengan 72 slot, menyertakan Omnidirectional Hopper bawaan yang bisa dikonfigurasi penuh, dan memiliki slot upgrade. Tidak bisa dijadikan peti ganda. Juga berfungsi seperti Shulker Box."
		"{image:atm:textures/questpics/pneumaticcraft/smart_chest_ui.png width:200 height:100 align:center}"
	]
	quest.440B1E1D4951F808.quest_subtitle: "Peti Pintar"
	quest.4415C9F8DA2D7E68.quest_desc: ["Dengan Cyanite, kita bisa bikin jantung Turbine, &9Turbine Controller&r.\\n\\nTurbine adalah struktur multi-block, sama kayak Reactor! Mereka input vapor kayak &7Steam&r yang dibuat oleh Reactor &dActively Cooled&r untuk bikin BANYAK power! Kita butuh beberapa part lain buat bisa bangun yang pertama.\\n\\nCatatan: Basic Turbine part cuma bisa dipakai buat bangun Turbine ukuran max 5x5x10. Untuk bangun Turbine lebih besar, harus pakai &aReinforced Turbine Part&r."]
	quest.4415C9F8DA2D7E68.title: "Bikin Turbine"
	quest.441C0659ED28D935.quest_desc: ["Glyph Tingkat 1 membutuhkan 3 level experience untuk dibuat."]
	quest.441F37A95AB66E6B.quest_desc: ["Quest ini dibuat oleh &6Staf AllTheMods&r, atau &2kontributor Komunitas&r untuk digunakan di Modpack AllTheMods. \\n\\nKarena semua paket &6AllTheMods&r dilisensikan di bawah &eHak Cipta Dilindungi&r, Quest ini tidak boleh digunakan di paket publik manapun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan, kalau kamu melihat ini, kamu sedang dalam mode sunting."]
	quest.442B1A1900BADAFC.quest_desc: ["Beberapa Mesin di &8&lIE&r bukan Multiblok, melainkan satu blok! \\n\\nJangan berpikir bahwa, hanya karena mereka dibuat dengan 1 Blok, mereka tidak penting!"]
	quest.442B1A1900BADAFC.title: "Mesin Kecil"
	quest.4447EEEB8D762721.quest_desc: ["&4Laser Dissipation &7Unit&r bakal upgrade &a&lMekaSuit&r. Ya tiap bagiannya. \\n\\nDaripada langsung bunuh lo pas jalan ke &4Laser&r, mereka gak bakal kasih Damage sama sekali! \\n\\nSedikit &4Laser&r sebenernya bakal lewat langsung! Gak semuanya."]
	quest.4447EEEB8D762721.quest_subtitle: "Semua Armor"
	quest.4447EEEB8D762721.title: "&4Laser Dissipation &7Unit"
	quest.4458F8829800A950.quest_desc: ["Cairan Polimorfik adalah dasar dari semua Cairan / Bahan Bakar di JDT. Cairan Polimorfik dibuat dengan menjatuhkan Katalis Polimorfik ke dalam air."]
	quest.445C21949ADA1FE3.quest_desc: ["Gabungkan Ancient Codex dengan &6Allthemodium Ingot&r dan Template di Smithing Table.\\n\\nKamu bisa mendapat Template dari Brushing Suspicious Clay di &9Ancient City&r."]
	quest.445C21949ADA1FE3.title: "&6Allthemodium&r Spell Book"
	quest.445C9117198936B6.quest_desc: ["&4Wither Assault Shoulder Weapon (W.A.S.W.)&r adalah senjata terakhir yang bisa kamu buat dari &4Witherite&r. \\n\\nIa punya 2 jenis proyektil yang bisa ditembakkan: &4Wither Missile&r dan &4Wither Howitzer&r. \\n\\n&4Wither Missile&r ditembakkan hanya dengan Menahan Klik Kanan, dan akan melukai apa pun yang terkena dengan cooldown rendah. \\n\\n&4Wither Howitzer&r ditembakkan saat Shift+Menahan Klik Kanan, melukai area yang lebih luas dan meninggalkan jejak efek Wither yang melukai siapa pun di atasnya. Namun cooldown-nya jauh lebih lama."]
	quest.445C9117198936B6.title: "&4W.A.S.W. (Wither Assault Shoulder Weapon)"
	quest.445CC9AAA6F8AAB6.quest_desc: [
		"Buat Tier &lOre Processing&r selanjutnya kita butuh &l&bPurifier&r dan mereka butuh &bOxygen&r. Jadi, ayo bikin &bOxygen&r! \\n\\nPakai &9&lElectric Pump&r atau apa pun yang otomatis kasih &9Air&r buat masukin &9Air&r ke &9&lElectrolytic Separator&r. \\n\\nPas sudah dikasih &aEnergi &fdan &9Air&r, &9&lElectrolytic Separator&r bakal ngerubah H2O itu jadi H (Hydrogen) dan O (&bOxygen&r)! \\n\\nKita bisa buang &bHydrogen&r-nya, terus alirkan Oxygen-nya ke &b&lPurifier&r. \\n\\nSekarang pas &b&lPurifier&r sudah punya &bOxygen&r, kita bisa taruh &7Ore&r ke dalamnya buat dapat 3 &7Ore Clump&f dari &7Ore Block&f atau 2 &7Ore Clump &fdari &7Raw Ore&r."
		"{image:atm:textures/questpics/mek/mek_tier2_1.png width:100 height:100 align:center}"
	]
	quest.445CC9AAA6F8AAB6.quest_subtitle: "Pengolahan Bijih Tier 2"
	quest.445CC9AAA6F8AAB6.title: "Bikin &bOxygen &fbuat &b&lPurifier"
	quest.445DB66B81146E91.quest_desc: ["Macuahuitl adalah Senjata yang dipake banyak Suku Mesoamerika. Biasanya Gada dengan &5Pecahan Obsidian&r dimasukkan ke dalamnya. \\n\\n&5Obsidian&r di dunia nyata jauh lebih rapuh, dan tajam daripada di &2&lMinecraft&r. Pas orang dipukul sama Macuahuitl mereka bakal robek sama &5Obsidian&r dan kepingannya bakal pecah di dalam mereka dan kasih Damage yang gak bisa diperbaiki! \\n\\n&3Macuahuitl Amphithere&r dipake dan dibuat mirip kayak dunia nyata, tapi &3Bulu Amphithere&r bikin lebih kuat lagi! \\n\\nSekarang, bakal lempar Musuh kamu mundur dan stun mereka sampe mereka gak bisa defend diri sendiri pake Shield!"]
	quest.445DB66B81146E91.title: "&3Macuahuitl Amphithere"
	quest.44688FC2E34FF09F.quest_desc: ["Minecraft sudah menambahkan ratusan blok, dan mod menambahkan ratusan lagi! Tapi terkadang itu masih belum cukup. \\n\\nDengan beberapa mod, kita bisa mengubah blok yang sudah kita miliki menjadi bentuk, desain, dan bahkan menjadi blok yang benar-benar baru!"]
	quest.44688FC2E34FF09F.title: "Mengubah Blok"
	quest.446A37C7FCDACF84.quest_desc: ["Batu Bara Apikegelapan adalah material baru yang ditambahkan oleh JDT. Apikegelapan didapatkan dengan melakukan Penyebaran Lendir pada Balok Bara Blaze menggunakan lendir tingkat tiga atau lebih tinggi. Bijih Batu Bara Apikegelapan dipengaruhi oleh keberuntungan."]
	quest.447CAC472A99835B.quest_subtitle: "Muncul dari Snow Nest"
	quest.4485C4ABD57874EB.quest_desc: ["&b&lApplied Energistics&r bukan Storage Mod, ini &lMOD&r Storage. \\n\\nGue pribadi gak tau banyak tentang Mod ini tapi Quest page harusnya bantu kamu belajar!"]
	quest.4485C4ABD57874EB.title: "&b&lApplied Energistics"
	quest.44881E39AB1D62AA.quest_desc: ["&3Autocrafter&r adalah tempat kita menyimpan Pattern agar jaringan tahu cara men-craft item. Begitu resep dimasukkan, kamu bisa 'Meminta' item untuk dibuat langsung dari &3Grid&r. Caranya dengan menekan Control + Shift sambil mengklik item yang punya resep tersebut.\\n\\nBlok ini juga bisa diletakkan menghadap sebuah mesin untuk menggunakan &6Processing Pattern&r. Contoh: jika kamu mengarahkan &3Autocrafter&r ke Furnace, kamu bisa menaruh resep untuk membakar Raw Processor. Selama &3Autocrafter&r terhubung ke sistem dan Furnace punya Importer, kamu bisa meminta versi Processor yang sudah dibakar!"]
	quest.44881E39AB1D62AA.quest_subtitle: "Crafting otomatis!"
	quest.44881E39AB1D62AA.title: "&3Autocrafter"
	quest.44B22160850ACAB2.quest_desc: ["Benih Nether Star butuh Nether Star Crux yang ditaro di bawah biar bisa numbuh."]
	quest.44B22160850ACAB2.quest_subtitle: "Tingkat: &56"
	quest.44BD0B40EB5451AF.quest_desc: ["Supply Camp/Ship adalah item yang ditambahkan oleh &lMinecolonies&r. Mereka dibuat untuk secara instan membuatkanmu markas untuk tinggal dan memulai Koloni! \\n\\nKamu bisa Klik Kanan item tersebut untuk membuka menu, di sana kamu harus memilih tipe Camp/Ship yang kamu inginkan! \\n\\nLalu, kamu perlu mencari tempat untuk meletakkannya. Tanahnya harus datar, blok bergaris merah memberitahumu apa yang harus disingkirkan! \\n\\nSetelah diatur, Camp/Ship barumu akan dibangun sepenuhnya secara gratis! \\n\\nIa akan memiliki Townhall, tempat tidur, perbekalan, dan banyak lagi!"]
	quest.44BD0B40EB5451AF.title: "Cara Curang"
	quest.44D5EDB8711EC7A0.quest_desc: ["&2&lVanilla&r tidak boleh bersenang-senang sendiri dengan Mace! Jadi, tentu saja ada upgrade &6Allthemodium&r untuk senjata ini! \\n\\nTingkatkan Mace dengan sebuah &6Allthemodium Block&r untuk mendapatkan &6Allthemodium Mace&r. \\n\\nSenjata ini menghasilkan base damage dan damage jatuh yang lebih besar, dengan Enchantment yang sama!"]
	quest.44D5EDB8711EC7A0.title: "&6Allthemodium Mace"
	quest.44DA091B53473723.quest_desc: ["Mechanical Squeezer menggunakan energy untuk squeeze."]
	quest.44E8D5DAD7E22724.quest_desc: ["Lucunya, ini tidak banyak upgrade. \\n\\n&3Spell Power&r tetap sama, Mana tetap sama, bahkan Armor Point tetap sama. Satu-satunya perubahan adalah penambahan Armor Toughness. \\n\\nItu masuk akal, ini hanya &5Netherite Upgrade&r untuk &bWizard Gear&r!"]
	quest.44E8D5DAD7E22724.title: "&cNetherite Battlemage Armor"
	quest.44F9B8F285546B2C.quest_desc: ["&bBlooming Moss&r berasal dari... kamu tebak! &bBlooming Caverns&r! \\n\\nIni akan muncul di tanah menunggumu untuk mengambilnya. \\n\\nMereka tidak menyebar seperti &2Moss&r normal dan tidak punya Recipe apapun."]
	quest.44F9B8F285546B2C.title: "&bBlooming Moss"
	quest.44FEE957BD333241.quest_subtitle: "Silver Lime + Sour Cherry"
	quest.45068FB6758D3BA1.quest_desc: [
		"&b&lPemalsuan Naga Es&r adalah Multiblock 3x3x3 yang dibuat dari Drop &b&lNaga Es&r dan &bBata&r! \\n\\nLayer pertama mulai dengan Salib dari &bBata Pemalsuan Naga Es&r. Buat isi kotak kita butuh &7Blok Tulang Naga&r. "
		"{image:atm:textures/questpics/iceandfire/chap3_ice1.png width:100 height:100 align:center}"
		"Layer kedua lebih tricky. Taro &bInti Pemalsuan Naga Es&r tepat di tengah, dengan &bAperature Pemalsuan Naga Es&r di sampingnya. Sisa layer ini cuma terbuat dari &bBata Pemalsuan Naga Es&r. "
		"{image:atm:textures/questpics/iceandfire/chap3_ice2.png width:100 height:100 align:center}"
		"Inget layer pertama? Ayo ulangi itu, cuma di atas sekarang!"
		"{image:atm:textures/questpics/iceandfire/chap3_ice4.png width:100 height:100 align:center}"
		"{@pagebreak}"
		"&b&lPemalsuan Naga Es&r pake insulasi internal dari &b&lNaga Es&r buat &bBekuin&r Item sampe sedingin itu mereka nyatu! \\n\\nEntah &7Besi &fdan &bDarah Naga Es&r buat bikin &bBaja Naga Es&r atau Item Alloy lain! \\n\\nKita harus lempar Item-item itu ke &b&lPemalsuan Naga&r, terus Dinginkan. \\n\\nTunggu, &3Es Biru&r gak cukup? Apa yang lebih &bDingin&r dari &3Es Biru&r? \\n\\n&bNapas Naga Es&r! Kita bisa pake &b&lNaga Es&r apapun yang deket, entah Jinak sendiri atau Liar dan di-Rantai."
	]
	quest.45068FB6758D3BA1.title: "&b&lPemalsuan Naga Es"
	quest.45084D3A3E5DB63B.quest_desc: ["Troll bisa Drop banyak Item berbeda! Ini kebanyakan ditentukan sama Bioma mereka. \\n\\nTapi semua Troll bakal Drop Gading, Kulit mereka, dan Senjata yang mereka pegang. \\n\\nGading dan Kulit keduanya dipake buat Armor Kulit Troll."]
	quest.45084D3A3E5DB63B.title: "&8Kulit &fdan &8Gading Troll"
	quest.450EDE68EC992A5A.quest_desc: ["Interface &cmembaca&r apapun yang dilihatnya. Bisa dianggap seperti &bAE2&r Storage Bus.\\n\\nBelum tahu itu apa? Ini contohnya: Chest dengan 100 Cobblestone di dalamnya punya interface, berarti network ID punya 100 Cobblestone di sistemnya, cukup simpel kan?"]
	quest.450EDE68EC992A5A.quest_subtitle: "Interface Punya GUI!"
	quest.4510FD92BACF00FF.quest_subtitle: "Plum + Sweet Chestnut"
	quest.45161821C221EF0B.quest_desc: ["Begitu kita meletakkan 15 &4Hellshelf&r di sekitar &5Enchantment Table&r, kita akan memiliki &a45 Eterna&r dan &c30% Quanta&r pada &5Meja&r kita. \\n\\nIni adalah jumlah yang pas untuk melakukan &d&lInfuse&r pada &4Hellshelf&r kita! \\n\\n&4Infused Hellshelf&r memberikan &a5 Eterna&r dengan batas maksimal &a60 Eterna&r, serta &c5% Quanta&r. \\n\\nIni bisa di-craft dengan item lain untuk membuat &7Rak Buku&r yang berbeda; untuk yang kita inginkan, kita butuh 12 &4Infused Hellshelf&r! \\n\\nTentu saja, karena aku baik hati, kamu cuma perlu mengumpulkan 8 buah saja!"]
	quest.45161821C221EF0B.title: "&4Infused Hellshelves"
	quest.45268A619787288F.title: "&eGold Backpack"
	quest.4526E151BAE88310.quest_subtitle: "Tingkat: &e1"
	quest.452DC5EB02D592B8.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_amethyst.png width:100 height:150 align:center}"]
	quest.452DC5EB02D592B8.title: "&5Amethyst&r"
	quest.452EF09F6CB4AD99.quest_desc: ["&cRelay&r tidak menghubungkan &cKabel&r ke Mesin, melainkan menghubungkan &cKabel&r ke lebih banyak &cKabel&r! \\n\\n&cRelay&r bekerja dengan menggabungkan banyak &cKabel&r ke satu tempat, jadi akan mengambil semua &9Input &cEnergi&r dan mengirimkannya ke &cKonektor&r ke semua &6Output&r yang terhubung. \\n\\nIni membantu ketika memiliki satu Generator Daya yang ingin mengisi beberapa Mesin!"]
	quest.452EF09F6CB4AD99.title: "&cRelay"
	quest.4530C14828C3D153.quest_subtitle: "Tingkat: &b4"
	quest.454662617304E299.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memungkinkan pemain berjalan menembus balok saat dipasang di celana. Ada tag balok untuk melarang balok yang tidak bisa ditembus."
		"Saat dipasang di busur, memungkinkan anak panah menembus tembok."
	]
	quest.454AC491FDFC3FDB.quest_desc: [
		"Berbeda dengan kebanyakan mob berbentuk kubus, &6Honey Slime&r itu ramah! \\n\\nMereka bisa dikawinkan dengan Gula dan mereka bisa... diperah? Gunakan botol untuk mendapatkan &6Botol Madu&r. Tapi mereka akan marah jika kamu memerahnya, kecuali kamu menggunakan efek Essence of Bees. \\n\\nSaat mati mereka menjatuhkan Gula. \\n\\nKamu bisa menemukan mereka di beberapa struktur, &bDanau Gula&r, atau terkadang muncul dari lebah yang tumbuh di Brood Block."
		"{image:atm:textures/questpics/bumblezone/bumble_slime.png width:100 height:100 align:center}"
	]
	quest.454AC491FDFC3FDB.quest_subtitle: "Tidak ada Royal Jelly Slime?"
	quest.454AC491FDFC3FDB.title: "&6Honey Slime"
	quest.454CA1F8CC198D9D.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Bantuan Tangga"
		"- Dorongan Lompat"
	]
	quest.45549E52B3CE2D23.quest_desc: ["Sabit adalah alat yang bisa nge-farm area tanaman yang luas sekaligus. Mereka juga bisa dipake sebagai senjata yang lumayan bagus."]
	quest.45647395169978ED.quest_desc: ["Untuk mendapatkan &9Gem Dust&r, kamu butuh sebuah &6&lApotheosis&r &aGem&r dan sebuah &7&lAnvil&r. \\n\\nBisa pakai &aGem&r &6&lApotheosis&r apa saja (disarankan cuma pakai yang &8Common &fatau &aUncommon&r)! \\n\\nBegitu dapat &aGem&r-nya, hancurkan dengan menjatuhkan &7&lAnvil&r di atasnya! \\n\\nLalu, kamu bisa menggunakan &9Gem Dust&r tersebut untuk men-craft &c&lSalvaging Table&r."]
	quest.45647395169978ED.title: "&9Gem Dust"
	quest.4564B577CB4EC046.quest_desc: ["Saat membantai ratusan Sapi, kamu mungkin bakal nemu daging sapi langka. Bukan sapi gila ya, tapi &cEverlasting Beef&r!\\n\\n&cEverlasting Beef&r bisa dimakan kayak daging sapi mentah biasa, tapi nggak bakal habis pas dimakan! Sebagai gantinya, bakal ada cooldown sebelum kamu bisa makan lagi.\\n\\n(Juga berfungsi dengan backpack yang punya fitur autofeed!)"]
	quest.4564B577CB4EC046.quest_subtitle: "Unik"
	quest.4564B577CB4EC046.title: "&cEverlasting Beef&r"
	quest.4567A27C53A01903.quest_desc: [
		"&c&lEcho of Tyrus&r adalah Boss nyata pertama yang kita dapatkan dari &lIron's&r! \\n\\nDia punya 1000 &4Heart&r dengan 16 Armor Point. Serta Kemampuan untuk memanggil &5Ancient Knight&r untuk Bertarung dengannya! \\n\\nSeperti yang bisa kamu tebak dari gelarnya &c&lFirst Flamebearer&r, kamu akan tahu dia menggunakan &cFire Magic&r untuk Menyerang. \\n\\nDia bisa mengayunkan &cScythe&r-nya untuk Memukulmu atau memukul Tanah untuk melepaskan Gelombang &cApi&r ke semua arah. \\n\\nBeberapa Serangan lagi melibatkan &cPedang Api&r, dia bisa melempar banyak padamu berturut-turut atau memanggil puluhan untuk naik dari Tanah untuk memberikan Damage. \\n\\nSerangan terakhir yang dia miliki adalah menggunakan &cFireball&r, yang akan dia Lempar padamu baik berdiri diam atau melompat tinggi ke udara! \\n\\nSaat kamu melakukan seperempat dari &4Health&r-nya dia akan berlutut. Ini saat kamu bisa Memukulnya paling keras! Tapi begitu dia sampai 300 &4Heart&r dia akan upgrade Senjata dan Armornya. Bahkan meng-upgrade &5Ancient Knight&r-nya juga! \\n\\nJika kamu entah bagaimana bisa Membunuhnya, dia akan Menjatuhkan &cScythe&r-nya dan &dDivine Soulshard&r. Plus Essence tapi siapa peduli tentang itu kita punya &cScythe&r!"
		"{image:atm:textures/questpics/iron_spells/spells_echo.png width:125 height:100 align:center}"
	]
	quest.4567A27C53A01903.title: "&c&lEcho of Tyrus, First Flamebearer"
	quest.4568C2F465EDB960.quest_desc: ["Droopfruit bisa muncul di biome mana pun, coba lihat ke atas! \\n\\nMereka tumbuh di atap sebagian besar biome dan tumbuh mirip dengan Glowberry."]
	quest.456B9DD108CF340F.quest_desc: ["Membuat segalanya lebih cepat."]
	quest.456B9DD108CF340F.quest_subtitle: "Ngebut!"
	quest.457CAE66B0FA4CCF.quest_desc: ["Semua bijih &2Vanilla&r bisa ditemukan menggunakan Diamond Divination Rod. Bisa mencari semuanya sampai ke Netherite!"]
	quest.457DE8C154641437.quest_desc: ["&9Ritual Brazier&r digunakan untuk menjalankan ritual. Alat ini juga bisa digunakan sebagai dekorasi. Jika kamu ingin menyalakannya, gunakan mantra cahaya (Light) pada alat ini. \\n\\nUntuk melakukan ritual, kamu juga butuh Arcane Pedestal. Karena ada banyak jenis ritual, pastikan kamu mengecek semuanya menggunakan &6Worn Notebook&r! \\n\\nCaranya dengan menahan Ctrl pada Ritual Table saat buku tersebut ada di inventarismu."]
	quest.458265FCD6B3068E.quest_desc: ["Semua orang menyukai Stasiun Crafting dari &lTinker's Construct&r dan rupanya juga Dev &8&lIE&r! \\n\\n&6Meja Crafting Insinyur&r akan bertindak seperti Meja Crafting normal, dengan tambahan 18 Slot Penyimpanan di dalamnya, plus menyimpan &eBarang&r di Kisi saat berhenti melihatnya! \\n\\nApa lagi yang bisa diminta!"]
	quest.458265FCD6B3068E.title: "&6Meja Crafting Insinyur"
	quest.45899579D9B92D91.quest_desc: ["&aController&r adalah jantung dari &c&lFoundry&r. \\n\\nSetiap &c&lFoundry&r membutuhkan setidaknya 1 blok ini agar bisa terbentuk. \\n\\nKita bisa menggunakan blok ini untuk melihat GUI &c&lFoundry&r. Di sini kita bisa melihat jumlah cairan di dalamnya. \\n\\nKita juga bisa menggunakannya untuk memasukkan dan mengambil item dari &c&lFoundry&r."]
	quest.45899579D9B92D91.title: "&aController&r &c&lFoundry&r"
	quest.458BFDB636F8B495.quest_desc: ["Menggabungkan Coke dust dengan Besi akan menghasilkan Uncooked Steel Dust. Membakarnya di Steam Blast Furnace akan menghasilkan Ingot Baja (Steel) yang dibutuhkan untuk progres selanjutnya."]
	quest.4597D3B3BDC2BED5.quest_desc: ["&bMolecular Assembler&f adalah meja crafting otomatis versi AE2, yang dibutuhkan untuk menjalankan tugas pola &ecrafting&f apa pun.\\n\\nMolecular Assembler mampu mentransfer daya dan channel ke perangkat ME lain yang terhubung, tetapi ia sendiri tidak memakan channel. Hingga 6 MA dapat dihubungkan ke satu Pattern Provider (jika digunakan) untuk memungkinkan lebih banyak proses pembuatan dilakukan secara paralel.\\n\\nMA juga masing-masing memiliki slot khusus untuk satu pola crafting, memungkinkannya berfungsi sendiri jika diberi daya. Jika dioperasikan dengan cara ini, item apa pun yang cocok yang dimasukkan ke dalam MA akan secara otomatis dibuat menjadi hasil dari pola tersebut."]
	quest.4597D3B3BDC2BED5.title: "Molecular Assembler"
	quest.45996B848792379E.quest_desc: ["Kamu bisa menambang &dSal Ammoniac Crystal&r di &2Overworld&r tapi tidak semudah itu. Kita tetap butuh &9Air&r dan mesin pembuat &dSal Ammoniac&r untuk memproduksi &eAlchemical Sulfur&r. \\n\\n&dKristal&r ini opsional tapi sangat membantu; dengan hanya Air, 1000mb akan menjadi 100mb &dSal Ammoniac&r. Tapi dengan 1000mb &9Air&r ditambah sebuah &dSal Ammoniac Crystal&r, kita akan mendapatkan 1000mb &dSal Ammoniac&r. \\n\\nProduksi meningkat 10 kali lipat hanya dengan satu item tambahan!"]
	quest.45996B848792379E.quest_subtitle: "Kenapa butuh mesin kalau bisa ditambang?"
	quest.45996B848792379E.title: "Kenapa Harus Mesin?"
	quest.459AEC4C2A611824.quest_desc: ["Buat semua Player yang gak curang pake Resource Pack &aNight Vision&r, ini mungkin berguna! \\n\\n&7Module Unit&r ini bakal kasih &aNight Vision&r pas lo pake &a&lMekaSuit Helmet&r. \\n\\nMeski iya, banyak &eItem&r yang bikin ini gak guna, gue tetep bakal kasih tau!"]
	quest.459AEC4C2A611824.quest_subtitle: "Helmet"
	quest.459AEC4C2A611824.title: "&aVision Enhancement &7Unit"
	quest.459BA85E48B343AE.quest_desc: ["&aRangka Radial&r bekerja mirip dengan &aRangka Linear&r dalam hal menghubungkan satu sama lain, tapi selebihnya berbeda. \\n\\nKamu bisa menghubungkan &aRangka Radial&r lain di atas atau bawah &aRangka Radial&r lainnya dan mereka akan otomatis terhubung. \\n\\nKemudian, &aGlue&r sisi-sisi &aRangka Radial&r untuk &aGlue&r setiap Blok dalam Radius tertentu dari &aRangka&r. BTW Radius berarti lingkaran! \\n\\nKamu bisa mengubah seberapa jauh lingkarannya dengan &6Kunci Inggris&r ke &aRangka Radial&r."]
	quest.459BA85E48B343AE.title: "&aRangka Radial"
	quest.459BB5B4CDB21773.quest_desc: ["&9Swamp Silver&r ditemukan di rawa-rawa berlumpur dimensi &5&lEternal Starlight&r."]
	quest.459BB5B4CDB21773.quest_subtitle: "15"
	quest.459BB5B4CDB21773.title: "&9Swamp Silver Armor"
	quest.45A25221F54A1DEC.quest_desc: ["Kunci Pas Ferricore memungkinkan pemain memutar mesin, tapi juga digunakan untuk menghubungkan penukar."]
	quest.45C9D975E3731DFE.quest_desc: ["&9Reinforced Echo Shard&r adalah Item Crafted yang butuh beberapa Item. \\n\\nPertama, dan paling mudah didapat adalah &7Phantom Membrane&r! &7Phantoms&r akan muncul setelah Player tidak tidur beberapa hari. Semakin banyak malam tanpa tidur, semakin banyak &7Phantoms&r! \\n\\nKedua, adalah &9Echo Shard&r. Ini bisa ditemukan dengan beberapa cara tapi paling mudah adalah Looting di &6Ancient Cities&r. \\n\\nTerakhir adalah &9Warden Carapaces&r. Ini Drop dari &9&lWarden&r saat mati. Jangan khawatir dia biasanya drop lebih dari satu!"]
	quest.45C9D975E3731DFE.title: "&9Reinforced Echo Shard"
	quest.45D10F53CA18B8EE.quest_desc: ["Sayangnya kamu gak bisa dapetin Rune &5Lightning&r dari drop Mob, sebaliknya kita harus craft pake &5Bottle O' Lightning&r. \\n\\nKita dapetin &5Bottle O' Lightning&r dari pake Empty Bottle di Charged Creeper. \\n\\nBerbahaya gue tau..."]
	quest.45D10F53CA18B8EE.title: "Upgrade Orb &5Lightning&r"
	quest.45D1FFB263CD722D.quest_subtitle: "Teak + Clove"
	quest.45D683D7F1A32B04.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memungkinkan alat untuk langsung menambang balok."
	]
	quest.45EC31812FB9934D.quest_desc: ["&aPiston Mekanik&r bertindak seperti Piston biasa dalam hal menggerakkan Blok, tapi setelah itu kesamaannya berakhir! \\n\\nMereka tidak menggunakan &4Redstone&r, melainkan &dTenaga Rotasi&r. &dTenaga Rotasi&r menentukan seberapa cepat dan arah Piston bergerak. \\n\\nMereka juga bisa ditambahkan &aSlime Ball&r untuk &aLengket&r ke Blok. Dan Blok tersebut bisa di-&aGlue&r agar semuanya bergerak bersama Piston. \\n\\nYang paling keren adalah kita bisa menambahkan &aTiang Ekstensi Piston&r di bagian belakang &aPiston&r untuk mengubah seberapa jauh &aPiston&r bisa bergerak! \\n\\nSetiap &aTiang&r baru menambah satu Blok jarak. Aku nggak tahu berapa maksimalnya, mungkin itu yang bisa kamu cari tahu sendiri!"]
	quest.45EC31812FB9934D.title: "&aPiston Mekanik"
	quest.45EE60207C466D6C.quest_desc: ["Untuk masuk ke Draconic Evolution kamu butuh Chaos Shards. Chaos Shards ada di Chaos Island dijaga oleh Chaos Guardian di End. Pergi ke End di koordinat X/Z yang merupakan kelipatan 10k. 10k, 10k / 10k, 20k / 20k, 20k dll."]
	quest.45EE60207C466D6C.quest_subtitle: "Menemukan Chaos Island"
	quest.45EE60207C466D6C.title: "Di mana dia?"
	quest.45F83C2750F70F9B.quest_desc: ["Ayo, taruh Book di Furnace dan smelt."]
	quest.45F83C2750F70F9B.quest_subtitle: "Gak akan kebakar kok..."
	quest.45F83C2750F70F9B.title: "Bikin Kitchen, dengan Book"
	quest.45FBEABEBA7CC09E.quest_desc: [
		"Entah apa yang terjadi sampai &5Kota&r ini tenggelam ke bawah &9Air&r, tapi yang jelas ia ada di sana! Kamu bisa menemukannya dengan mudah dari Stone Brick yang menyembul di permukaan &9Air&r. \\n\\nRuangan pertama dan terbesar adalah Pusat Kota, kubah raksasa! Di sinilah &5Altar of the Abyss&r berada. \\n\\nDari ruangan itu, kamu akan menemukan lorong-lorong menuju bangunan lain di &5Kota&r tersebut. Penjara yang menahan &5Coralussus&r dan bahkan Ruang Harta yang berisi banyak loot berharga! \\n\\nDi seluruh penjuru &5Kota&r kamu akan bertemu penduduknya, para &5Deepling&r. "
		"{image:atm:textures/questpics/cataclysm/cataclysm_city.png width:200 height:100 align:center}"
	]
	quest.45FBEABEBA7CC09E.title: "&5Sunken City&r: Rumah sang &5&lLeviathan&r"
	quest.45FF08E4DB6F7F0E.quest_desc: ["Elite Autocrafter memiliki 18 slot Pattern dan bekerja 2x lebih cepat."]
	quest.45FF08E4DB6F7F0E.title: "Elite Autocrafter"
	quest.460A8F17F3ED6CAF.quest_desc: ["Ada titik di mana tingkat penyimpanan standar tidak lagi cukup untuk menampung sumber daya yang kamu kumpulkan.\\n\\nDi sinilah add-on &dMEGA Cells&f berperan, memperluas tingkat penyimpanan ke wilayah megabyte. Tingkat pertama dari komponen ini adalah &bKomponen Penyimpanan MEGA 1M&f, menyediakan 1024 &okilo&rbyte, atau &e1.048.576&f byte penyimpanan."]
	quest.460A8F17F3ED6CAF.quest_subtitle: "Megabyte Pertama"
	quest.460A8F17F3ED6CAF.title: "Komponen Penyimpanan 1M"
	quest.461C8F1E88AA58D9.quest_desc: [
		"Ini dapat digunakan dalam resep yang memakai versi ember dari cairan PneumaticCraft.\\n\\nSaat sebuah &3Fluid Tank&r diletakkan di atas &3Fluid Tank&r lainnya dan disambung dengan wrench, mereka akan menjadi satu tangki besar.\\n"
		"{image:pneumaticcraft:textures/patchouli/small_tanks.png width:250 height:250 align:center fit:true}"
	]
	quest.461C8F1E88AA58D9.quest_subtitle: "32,000mb"
	quest.462C1F75A2FB9F02.quest_subtitle: "Di mana si Willy?"
	quest.462D173D576A8D91.quest_desc: ["&eAncient Metal&r dijatuhkan oleh hampir semua hal di dalam &eCursed Pyramid&r! \\n\\nSama seperti ingot lainnya, ia bisa dibuat dari Nugget atau Blok dan sebaliknya. \\n\\nKamu bisa menggunakannya untuk membuat &eBone Reptile Armor&r atau &eAncient Spear&r."]
	quest.462D173D576A8D91.title: "&eAncient Metal"
	quest.4638F21544D6D337.title: "Chaos-Entangled Quantum Energy Tunnel"
	quest.4646DCF463FD913F.quest_desc: ["Kalahkan Wither menggunakan Stinger Spear. \\n\\nCobalah gunakan portal keluar The End untuk membantu memudahkan ini."]
	quest.464DDEAF167BD0D5.quest_subtitle: "&f9 &cAttack Damage"
	quest.46567ED894E9883C.quest_desc: [
		"Di sini jadi seru! \\n\\nPakai 4 &6Deorum&r Ingot, 4 &bArcane Crystal&r, dan &9Chiseled Polished Darkstone&r untuk upgrade dari &3&lTier 2&r ke &e&lTier 3&r. \\n\\nSekarang kita bisa tahan lebih banyak Essence, lebih banyak Relic, dan lebih banyak Resep!"
		"{image:atm:textures/questpics/forbidden/forbidden_tier2.png width:100 height:100 align:center}"
	]
	quest.46567ED894E9883C.title: "&e&lTier 3 &6Forge"
	quest.465B08461B460DAC.quest_desc: ["&dEndermaptera&r tinggal di sekitar &dRuined Citadel&r. \\n\\nMereka punya 8 &4HP&r dan hanya serangan dasar berupa gigitan. \\n\\nJika mereka terlalu banyak menggigit, rahang mereka bisa patah, sehingga tidak akan menjatuhkannya lagi saat mati. \\n\\nJadi pastikan membunuh mereka dengan cepat jika menginginkan &dVoid Jaw&r tersebut!"]
	quest.465B08461B460DAC.quest_subtitle: "Kecoak End"
	quest.465B08461B460DAC.title: "&dEndermaptera"
	quest.4664AFCFB5618CEB.quest_desc: ["&bGlacite&r ditemukan di biome dingin dalam dimensi &5&lEternal Starlight&r!"]
	quest.4664AFCFB5618CEB.quest_subtitle: "17"
	quest.4664AFCFB5618CEB.title: "&bGlacite Armor"
	quest.4665E6FD0AAED164.quest_desc: ["&fCharm of Keeping II&r bekerja sama seperti &6Charm of Keeping I&r namun juga mencegahmu kehilangan barang yang ada di hotbar saat kamu mati."]
	quest.4665E6FD0AAED164.title: "&fCharm of Keeping II"
	quest.4676E9CD0F312C1A.quest_subtitle: "Mandarin + Kumquat"
	quest.46932D87871BE12F.quest_desc: ["&5&lChemical Crystallizer Multiblock&r bakal bisa Mass &5Crystallize &eItem&r. \\n\\n&5Multiblock&r ini butuh &aEnergi&r Input Hatch, &cChemical&r Input Hatch, sama &eItem&r Output Hatch. \\n\\nLo bisa masukin 6,400mB &7Clean Ore Slurry&r buat dapet 32 &7Ore Crystal&r dan pake 32,000mB &dAntimatter&r buat bikin 32 &dAntimatter Pellet&r."]
	quest.46932D87871BE12F.title: "&5&lChemical Crystallizer Multiblock"
	quest.46AADB01BBD156D2.quest_desc: ["Kita bisa Tame &0Cockatrice&r dengan 2 cara berbeda. 1. &0Telur Busuk&r 2. Kerja keras. \\n\\nLempar &0Telur Busuk&r buat dapet &0Bayi Cockatrice&r yang jinak. Atau bertahan natap &0Cockatrice&r cukup lama. \\n\\n&0Cockatrice Jinak&r gak bakal Sakitin kamu pas kamu liat ke &0Mata&r mereka, malah mereka bakal lindungin kamu! \\n\\nKayak Anjing mereka bakal Nyerang Monster, Bunuh apapun yang Nyerang kamu, dan bahkan pake &0Sinar Mata&r mereka ke mereka!"]
	quest.46AADB01BBD156D2.title: "Menang kontes menatap"
	quest.46BE62C20C720D10.quest_desc: ["Membuat Enderman tidak marah kepadamu, sama seperti memakai Labu Ukir (Carved Pumpkin)."]
	quest.46BE62C20C720D10.quest_subtitle: "Maks: 1"
	quest.46C816844C513D5D.quest_desc: ["Versi upgrade dari Wyvern Shovel."]
	quest.46C816844C513D5D.title: "Draconic Shovel"
	quest.46CC8E7ED59F51D2.quest_desc: ["&5Tidal Claw&r adalah drop yang dijamin dari &5&lThe Leviathan&r. \\n\\nSenjata ini punya dua mode: serang dan tarik (grapple). Serang dengan Klik Kiri, Tarik dengan Klik Kanan. \\n\\nSaat menyerang, ia akan meluncurkan capitnya menembus maksimal 5 mob, memberikan damage dan efek &5Abyssal Curse&r yang akan terus melukai mereka. \\n\\nMode tarik akan menempel pada apa pun di jangkauannya dan menarikmu ke arah tersebut. \\n\\nTanpa durabilitas, jadi nikmatilah selamanya!"]
	quest.46CC8E7ED59F51D2.title: "&5Tidal Claws"
	quest.46D756F4DC6CC894.title: "&dNetherite Backpack"
	quest.46DCB235D3FEDA61.quest_desc: ["Mirip dengan peralatan Besi, hanya saja semua alat ini memberikan efek lambat (slow) kepada siapa pun yang terkena. \\n\\nKecuali cangkulnya (Hoe), tapi siapa sih yang peduli dengan cangkul biasa?"]
	quest.46DCB235D3FEDA61.title: "Peralatan &bFroststeel&r"
	quest.46E6B1600AA8A61E.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemindai Monster"
		"- Pengasap Otomatis"
		"- Membakar Luka"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.46EE2F9818F8D1D9.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Otomatis menghapus balok yang terpengaruh gravitasi langsung di atas balok yang ditambang."
	]
	quest.46FEF3DB6A5B52A0.quest_desc: [
		"Battle Cube adalah penjara bawah tanah (dungeon) di &6&lBumblezone&r! \\n\\nMirip dengan Trial Chamber, tempat ini memiliki banyak ruangan dengan spawner dan tentu saja Loot! \\n\\nDi dalam ruangan terdapat sarang laba-laba dan wol untuk merepresentasikan telur laba-laba, di dalamnya terdapat spawner Spider atau Cave Spider dan terkadang Loot berharga seperti Blok Diamond atau Emerald! \\n\\nAda juga beberapa Honey Cocoon di ruangan terakhir yang bisa berisi loot berharga, seperti &5Throne Pillar Compass&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_cube.png width:200 height:100 align:center}"
	]
	quest.46FEF3DB6A5B52A0.title: "Battle Cube"
	quest.47043AF7D1FABC43.quest_desc: ["&bDis-Enchanting Table&r mungkin adalah tips yang paling membantu di sini. \\n\\nCukup taruh item yang memiliki Enchantment di slot kiri dan sebuah Buku kosong di slot tengah. Maka, Enchantment tersebut akan berpindah ke slot kanan dalam bentuk Buku Sihir! \\n\\nKamu juga bisa menggunakan Buku Sihir alih-alih item untuk memisahkan mantra-mantranya."]
	quest.47043AF7D1FABC43.title: "Meja Pencabut Sihir (&l&bDis-Enchanting Table&r)"
	quest.47045A0E8E3457C2.quest_subtitle: "Tingkat: &63"
	quest.4707FB01F15F6E1F.quest_desc: [
		"&b&lClibano&r adalah Multiblock baru yang kerja kayak Jumbo Furnace! Untuk bikin ikuti langkah ini!"
		"{image:atm:textures/questpics/forbidden/forbidden_clibano1.png width:100 height:100 align:center}"
		"Layer pertama adalah Area 3x3, dengan corner dari &9Polished Darkstone&r dan sisanya diisi &9Polished Darkstone Brick&r."
		"{image:atm:textures/questpics/forbidden/forbidden_clibano2.png width:100 height:100 align:center}"
		"Layer kedua cuma pakai &9Polished Darkstone Brick&r dan &bClibano Core&r. Ingat biarkan Blok tengah kosong!"
		"{image:atm:textures/questpics/forbidden/forbidden_clibano3.png width:100 height:100 align:center}"
		"Layer terakhir sama seperti yang pertama... cuma di atas dua layer lainnya!"
		"{image:atm:textures/questpics/forbidden/forbidden_clibano4.png width:100 height:100 align:center}"
		"Terakhir Klik Kanan Multiblock dengan &cMundabitur Dust&r untuk selesaikan!"
	]
	quest.4707FB01F15F6E1F.title: "&b&lClibano"
	quest.4718C2728C0CA40F.quest_desc: ["Saat berada di tangan kiri, kamu akan mendapatkan begitu banyak pengetahuan! \\n\\nBagian pojok kiri bawah akan memberitahumu struktur apa yang sedang kamu masuki. \\n\\nSemua entitas juga akan disorot saat aktif. Itu termasuk entitas blok seperti Chest atau Armor Stand. \\n\\nSetelah energinya habis, ia butuh 15 menit masa tunggu. Tapi tenang, penggunaannya cukup banyak kok!"]
	quest.4718C2728C0CA40F.title: "&5Essence of Knowledge"
	quest.47358ADC1470C82A.quest_desc: [
		"&cDemon's Dream Fruit&r itu sangat sehat untukmu. Mungkin ada beberapa efek samping yang harus kamu ketahui."
		""
		"Saat memakannya, kamu berpeluang mendapatkan efek &3Third Eye&r (Mata Ketiga), yang memungkinkanmu melihat ke dimensi &9Otherworld&r. Beberapa item di dunia mungkin tidak seperti kelihatannya, dan kamu butuh \"penglihatan\" ini untuk menemukan item tertentu untuk progres."
		""
		"Atau kamu bisa membakarnya dan melewati pencarian manual. Terserah kamu."
	]
	quest.47358ADC1470C82A.quest_subtitle: "Bersiaplah untuk Berhalusinasi"
	quest.47358ADC1470C82A.title: "&cBuah Setan"
	quest.4745152F6FF242B3.quest_desc: ["Saat reactor bakar fuel, bikin &9waste&r atau &dReactant&r yang juga mau kamu keluarin. Itu gunanya Solid Access Port lain! Pastikan set ke output, lalu pompa ke storage."]
	quest.4745152F6FF242B3.quest_subtitle: "Waste Not Want Not atau semacamnya...."
	quest.4745152F6FF242B3.title: "Hadapi Waste"
	quest.4745488579AAF603.quest_subtitle: "&f5.8 &cAttack Damage"
	quest.475E1B94A61B9EB0.quest_desc: ["Seperti MK1, ini menarik item! Bedanya tidak hanya dari inventaris yang menempel, tapi dari inventaris mana pun di sekitar!"]
	quest.475E307844E3AF7F.quest_desc: [
		"Water Boiler adalah salah satu mesin paling berguna dari &l&7RailCraft&r. Mesin ini membutuhkan Fuel Firebox dan semacam boiler di atasnya. Fuel Firebox bisa berukuran 1x1, 2x2, atau 3x3. Ukuran Firebox menentukan seberapa besar Boiler yang bisa dipasang di atasnya. Liquid Fuel menggunakan Creosote untuk memanas, sedangkan Solid Firebox menggunakan bahan bakar tungku apa pun."
		"{image:atm:textures/questpics/railcraft/rail_big_boiler.png width:100 height:100 align:center}"
	]
	quest.475E307844E3AF7F.title: "Boiler"
	quest.47656073894224AF.quest_desc: ["Ya, sama seperti yang ada di Kapal Perang raksasa! \\n\\n&5&lRailgun&r adalah Senjata khusus. Untuk 1. menggunakan Ammo khusus, bukan Kartrid seperti yang digunakan Revolver 2. menggunakan &cEnergi&r dan perlu mengisi sebelum menembak. \\n\\nAmmo yang digunakan adalah &eBarang&r dari Inventaris: &7Aluminium&r, &7Besi&r, dan &8Batang Baja&r, &0Elektroda Grafit&r, Bilah Gergaji, Enderpearls, Trisula, Blaze Rods, dan End Rods. \\n\\nAkan mengambil apa pun yang ada di Inventaris, untuk mengubah apa yang Ditembak, Tahan Shift dan Gulir. \\n\\nSelanjutnya, memerlukan &cEnergi&r di dalamnya untuk Menembak, untuk mengisinya bisa menggunakan &cPengisi Barang&r apa pun, termasuk yang ditambahkan oleh &8&lImmersive Engineering&r! \\n\\nSetelah memiliki semua ini, Tahan Klik Kanan sampai Railgun mencapai Level 99, lalu lepaskan! \\n\\nUpgrade &5&lRailgun&r adalah: Scope Presisi dan Heatsinks. \\n\\nBisa menampung 2 Upgrade, yah itu masuk akal tidak bisa menggunakan lebih dari itu!"]
	quest.47656073894224AF.title: "&5&lRailgun"
	quest.476755275B948A5F.quest_desc: ["Reactor juga bisa dipakai buat panasin &bcoolant&r kayak air untuk bikin &bvapor&r, kayak &bSteam&r.\\n\\nBuat ini, kamu perlu bangun reinforced reactor. Ini dibangun dengan cara yang sama kayak reactor 3x3x3 kamu, tapi semua part perlu jadi &aReinforced Reactor Part&r. Gue juga saranin lebih besar dari 3x3x3.\\n\\nBuat input coolant, kamu butuh &9Forge Fluid Port&r. Ini akan port in fluid kayak Water ke reactor. Ini juga akan dipakai buat export vapor yang dibuat di reactor.\\n\\nKalau mau, kamu bisa bikin &aMekanism Fluid Port&r untuk convert fluid Steam jadi gas Steam Mekanism."]
	quest.476755275B948A5F.quest_subtitle: "Untuk Bikin Steam!!"
	quest.476755275B948A5F.title: "Bangun Actively Cooled Reactor"
	quest.476C7317510198D9.quest_desc: ["Oke yang ini seru! Suka melempar &eItem&r? Maksudnya, benar-benar melempar jauh! \\n\\nKalau iya, &ePelontar Berbobot&r cocok untukmu! \\n\\nPertama, Shift + Klik Kanan Blok dengan &ePelontar Berbobot&r untuk mengaturnya sebagai target. Target harus sejajar dengan arah &ePelontar&r agar bisa kena. \\n\\nSetelah punya target dan sudah dipasang, beri &dTenaga Rotasi&r untuk mengisi dayanya! Kemudian, saat &eItem&r diletakkan di &ePelontar Berbobot&r, ia akan melemparnya! \\nKamu bisa mengatur jumlah tumpukan yang dibutuhkan sebelum &eItem&r dilempar melalui sisi-sisinya."]
	quest.476C7317510198D9.title: "&ePelontar Berbobot"
	quest.4773421DC70009AB.quest_desc: [
		"Kemampuan Intrinsik:"
		"- Tidak Menginjak Tanaman"
		"- Pertumbuhan Tanaman Dipercepat I"
	]
	quest.47750F3CB020104C.quest_desc: ["&lGenerator's Galore&r dan &lIron Furnaces&r adalah dua mod yang beda tapi juga mirip. Keduanya dimulai dengan Furnace legendaris!"]
	quest.47750F3CB020104C.quest_subtitle: "Semuanya dimulai dari sini"
	quest.47750F3CB020104C.title: "The Furnace"
	quest.47764EFC822E462A.quest_desc: ["Blok ini produksi susu seiring waktu, dan aktifkan resep susu untuk multi-block kitchen.\\n\\nUntuk dapetin sapi di jar, taruh jar di lubang. Pancing sapi untuk jatuh di lubang di atas jar, lalu jatuhkan anvil ke atasnya.\\n\\nGak tau kaca ini dibuat dari apa, tapi lebih kuat dari hubungan gue dengan Ayam."]
	quest.47764EFC822E462A.quest_subtitle: "Kekuatan Perah Fenomenal....Ruang hidup super kecil"
	quest.47764EFC822E462A.title: "Sapi di Jar"
	quest.47768B1FFD57D56E.quest_desc: ["Sebel nggak sih kalau kabel &4Redstone&r harus ditarik ke mana-mana? Kalau kita bisa punya FE nirkabel, kenapa nggak bisa punya &4Redstone&r nirkabel? Akhirnya kita bisa melakukannya berkat &c&lLaserIO&r. Kamu bisa memasukkan &4Sinyal Redstone&r dengan &4Card&r ini, lalu gunakan &4Output Card&r untuk mengeluarkan &4Sinyal&r-nya di tempat lain!"]
	quest.47768B1FFD57D56E.title: "&4Redstone Card"
	quest.477B411F84342EEA.quest_desc: ["Mekanism adalah salah satu mod terbaik untuk penyimpanan energi, terutama di awal permainan.\\n\\nBasic Energy Cube mudah dikonfigurasi, mudah dibuat, dan menyimpan banyak daya. Alat ini juga bisa ditingkatkan, dan bisa mengisi daya item di dalam antarmukanya!\\n\\nUntuk mempelajari lebih lanjut tentang meng-upgrade Energy Cube serta mod ini, pergilah ke bab quest &aMekanism&r!"]
	quest.477B411F84342EEA.title: "&9Mekanism: &aEnergy Cubes"
	quest.47897D827C50629D.quest_desc: ["&aTiang Ekstensi Piston&r adalah cara kita membuat dan memperluas &aPiston Mekanik&r. \\n\\nBukan Piston biasa ya, maaf!"]
	quest.47897D827C50629D.quest_subtitle: "Kenapa bergerak sedekat itu?"
	quest.47897D827C50629D.title: "&aEkstensi Piston"
	quest.478C1AF86610A8B7.quest_desc: ["&#EDD653&nCompressor&r digunakan untuk membuat &#53EDAAPlate&r, &#53EDAACurved Plate&r, dan &#53EDAARing&r."]
	quest.47A2BEFB11F4D581.quest_desc: ["Basic Filter ini sangat... mudah digunakan! Cukup masukkan Item ke dalamnya dan mereka sekarang sudah tersaring. \\n\\nKamu bisa mengubahnya agar menjadi Whitelist (hanya mengizinkan item tersebut) atau Blacklist (menolak hanya item tersebut). \\n\\nKamu juga bisa mengaturnya agar mencocokkan data NBT atau tidak. Mencocokkan data NBT artinya harus memiliki Enchantment, Durability, atau bahkan Mob di dalam item yang sama persis. Jika diatur untuk tidak mencocokkan, ia akan menyaring item tersebut tanpa peduli NBT-nya."]
	quest.47A57DF7964D71B9.quest_subtitle: "Cukup di-craft saja"
	quest.47A57DF7964D71B9.title: "Bloody Bee"
	quest.47A6769B6BF1A46D.quest_desc: ["&eCorong&r seperti perpaduan Hopper dan Dispenser. \\n\\nKetika dipasang ke Blok dengan Inventaris, seperti Peti, ia akan otomatis mengambil &eItem&r satu per satu. \\nKalau Shift + Klik Kanan, ia akan otomatis memasukkan &eItem&r ke dalam Inventaris. \\n\\nKeduanya bisa dinonaktifkan dengan &4Sinyal Redstone&r!"]
	quest.47A6769B6BF1A46D.title: "&eCorong Andesit"
	quest.47A7F4972D58A7D5.quest_desc: ["&c&lNaga Jinak&r bakal Tumbuh seiring waktu. Naik &lStage&r, &4Hearts&f, &7Armor&r, dan lebih! \\n\\nButuh Waktu... dan kita gak suka itu. \\n\\nBikin &cMakanan Naga&r dong! \\n\\nPas &c&lNaga Jinak&r Makan &cMakanan Naga&r mereka bakal Umur beberapa Hari cuma dalam satu Gigitan!"]
	quest.47A7F4972D58A7D5.title: "Kasih makan &c&lNaga&r kamu"
	quest.47AED7219704EB3E.quest_subtitle: "&f18 &cAttack Damage"
	quest.47CB136D7764B86D.quest_desc: ["Torreya Vine ditemuin menggantung dari Torreya Tree. \\n\\nMereka menggantung karena gak bisa ditaro dengan cara lain... \\n\\nBola di bawah mereka bakal ngeluarin Cahaya!"]
	quest.47CEFA06392C4211.quest_desc: ["Expansion box diletakkan di atas Advanced Beehive untuk meningkatkan jumlah lebah yang bisa ditampung hingga total 5 slot. Ini juga diperlukan agar sarangmu bisa dipasang upgrade."]
	quest.47CEFA06392C4211.quest_subtitle: "Meningkatkan kapasitas penyimpanan lebah"
	quest.47CEFA06392C4211.title: "Expansion Box"
	quest.47E32A084CAA1512.quest_desc: ["Bisa Diperdagangkan dengan Gunsmith atau Dibuat. \\n\\nSenjata tidak terlalu menyenangkan tanpa Peluru, jadi mari Buat beberapa! Untuk Membuatnya, diperlukan &9Cetak Biru&r ini."]
	quest.47E32A084CAA1512.title: "&9Cetak Biru Proyektil Umum"
	quest.47E4BA6643A4BA85.quest_desc: ["Jinakkin &3Amphithere&r mirip kayak gimana Manusia Jinakkin Serigala jadi Anjing. Melibatkan banyak gigitan... \\n\\nPertama, kamu harus pukul &3Amphithere yang Terbang&r pake Projectile buat jatuhkan dia dari &bLangit&r. \\n\\nTerus, kamu bisa Klik Kanan buat naik ke Punggungnya. Kayak kamu lakukan sama Kuda! Tapi Kuda ini bakal ayunin kepalanya buat Gigit kamu. \\n\\nBuat Tame dia, kamu harus Bertahan dari setiap Gigitan dan tetep di dia. Lama-lama dia bakal nyerah dan sayang kamu. \\n\\nPas mereka sayang kamu, kamu bisa Naik mereka! Kontrolnya agak aneh tapi pas kamu main sama mereka sebentar (dan baca Quest ini) semoga kamu bakal ngerti lebih baik! \\n\\nPas Naik, kamu bisa Pencet dan Tahan Space buat bikin &3Amphithere&r Terbang ke atas. Ini bakal bikin dia Terbang langsung ke atas dari dia berada. Pas kamu lepas, dia bakal mulai Jatuh balik ke Tanah. \\n\\nPas Terbang kamu bisa pake WASD buat gerak ke setiap arah, tapi kamu juga bisa pake Kursor Mouse buat arahin dia Meluncur ke atas atau bawah pas gak pake Space Bar. \\n\\nKayak &eCacing Maut&r, pas Naik kamu bisa pake (G) buat Nyerang sama &3Amphithere&r."]
	quest.47E4BA6643A4BA85.title: "Jinakkin &3Amphithere"
	quest.47E79DFD123BF617.quest_desc: ["&eScuba Set&r itu isinya Helm sama Chestplate yang bakal kasih kamu &9Water Breathing&r (bernapas di air) pas dipakai! \\n\\nBiar bisa &9Bernapas&r, kita harus kasih &eScuba Tank&r kita sedikit &bOxygen&r. Tinggal taruh di dalam &5Mesin&r yang punya Oxygen, kayak &9&lElectrolytic Separator&r nanti dia bakal pelan-pelan terisi! \\n\\nTerus, pakai &eScuba Mask &fdan &eScuba Tank&r terus tekan (G) buat nyalain. Pas &eScuba Gear&r sudah nyala, dia bakal pakai &bOxygen&r-nya biar kamu bisa &9Bernapas di Dalam Air&r!"]
	quest.47E79DFD123BF617.title: "&eScuba Set"
	quest.47F38E606AD3FF53.quest_desc: ["Beberapa resep butuh &7Ore Dust&r! \\n\\nBerkat &6&lAllTheOres&r, kita bisa bikin &7Ore Dust&r lewat sejuta cara beda! \\n\\nCara ala &5&lMekanism&r itu pakai &4&lCrusher&r dan &d&lEnrichment Chamber&r. \\n\\nKita bisa &4Crush&r &7Ingot&f jadi &7Dust&r. Atau &dEnrich&r &7Ore Block&r buat dapat 2 &7Dust&r."]
	quest.47F38E606AD3FF53.title: "&4Crushed &fjadi Dust!"
	quest.47F734CDD5793F26.title: "&5Unobtainium Crossbow"
	quest.480FA9FE57743B66.quest_subtitle: "&f5 &cAttack Damage"
	quest.481205F0C9B08200.quest_subtitle: "Teak + Clove"
	quest.481735FE3164C8D5.quest_desc: ["&bEs Biru&r- 200 K \\n&bEs Padat&r- 240 K \\n&bEs&r- 260 K \\nSalju- 273 K \\n&9Air&r- 300"]
	quest.481735FE3164C8D5.title: "&bBarang Dingin"
	quest.4818C8387C0DBBE7.quest_desc: [
		"ExtendedAE adalah addon untuk Applied Energistics 2, fokus menambah versi improved dari berbagai device, dan bawa kembali beberapa fitur dari versi lama AE2."
		""
		"Buat mulai, ambil Fluix Block."
	]
	quest.4818C8387C0DBBE7.title: "ExtendedAE"
	quest.4821419D44F8083F.quest_desc: [
		"&9Pemacu Pertumbuhan&r sedikit nambah kecepatan tumbuh benih kalau ditaro langsung di bawah lahan pertanian. Setiap tingkat punya jangkauan seberapa banyak blok 'ke atas' yang bisa dipercepat, dengan Inferium paling rendah di 9. "
		""
		"Catatan: Pemacu Pertumbuhan semua tingkat ngasih rate growth tick yang sama. Tingkat lebih tinggi cuma punya jangkauan lebih luas, jadi kamu bisa numpuk lebih banyak di bawah satu tanaman. Gak masalah tingkat mana yang kamu pake selama Pemacu Pertumbuhan ditaro dalam jangkauan maksnya."
	]
	quest.4821419D44F8083F.quest_subtitle: "Jangkauan: &e9&r Blok"
	quest.4821419D44F8083F.title: "&aInferium Pemacu Pertumbuhan"
	quest.482E558BCFEE6B7E.quest_desc: ["&3Construction Brick&r adalah blok bangunan yang keren, tapi hati-hati karena sakit kalau terinjak. Craft ulang untuk menjadikannya halus."]
	quest.482E558BCFEE6B7E.quest_subtitle: "Nggak ada yang lebih sakit daripada menginjak ginian"
	quest.48357A7486125C52.quest_desc: [
		"Bosan sama kecepatan lambat Inscriber?"
		""
		"Kami persembahkan Circuit Slicer! Bisa slice blok seperti Gold Block jadi circuit, bikin sampai 9 circuit sekaligus (atau 4 untuk certus atau entro)."
		""
		"Sisi kaca Circuit Slicer yang gak ada port-nya gak bisa konek ke ME Network."
	]
	quest.48357A7486125C52.title: "Blok jadi Circuit: Circuit Slicer"
	quest.483892F0A0F75B97.quest_desc: ["&bPipa Cairan&r adalah cara kita memindahkan &bCairan&r secara otomatis dari satu Inventaris ke Inventaris lain! \\n\\nKamu bisa memasangnya dan ia akan otomatis terhubung ke Inventaris dan &bPipa&r lainnya. \\n\\nDengan Kunci Inggris kamu bisa menambahkan Jendela ke &bPipa&r. Pipa berjendela tidak akan terhubung ke &bPipa&r sejajar tanpa Jendela. \\n\\n&bPipa&r sendiri tidak akan menggerakkan &bCairan&r — kita butuh &bPompa Mekanik&r untuk itu! \\n\\nTapi kalau &bPipa&r sudah mengalir, kita bisa menggunakannya untuk mengambil &bCairan&r dari Blok Sumber atau sebaliknya menaruh Blok Sumber. \\n\\n&bPipa&r perlu memiliki Ujung Terbuka untuk melakukannya, jadi tidak boleh ada Blok yang menghalangi."]
	quest.483892F0A0F75B97.title: "&bPipa Cairan"
	quest.484ABFF266C8791E.quest_desc: ["Orbflora adalah tanaman yang tumbuh dari dasar Laut. \\n\\nBisa dipanen kapan aja tapi kalau kamu mau Orbflora Light kamu harus nunggu! \\n\\nKalau mereka tumbuh sampai Sea Level mereka bakal berbunga. Setelah berbunga mereka bakal numbuh Light-nya!"]
	quest.485AFAE5BBEF2FC7.title: "Hewan"
	quest.485D5664A17E16DF.quest_subtitle: "Upgrade Penyimpanan x8"
	quest.485D5664A17E16DF.title: "&6Copper Upgrade"
	quest.486060882E507CF1.quest_subtitle: "Muncul dari Dirt Nest"
	quest.4869C413646CC4CC.quest_desc: [
		"Transfer power keluar dari generator mungkin ide bagus, tapi bagaimana caranya? "
		""
		"Untuk memulai, bisa pakai &cEnergy Pipe&r dari mod &aPipez&r, atau bisa pakai &cEnergy Cable&r &9Powah&r kalau sudah mulai menggunakan mod itu. "
		""
		"Atau kalau mau nostalgia, pack ini punya &6EnderIO&r dan bisa pakai &6Energy Conduit&r dari sana."
	]
	quest.4869D9DBDD1A15CD.quest_desc: ["&cC&6o&el&ao&br &cM&6o&ed&au&bl&ca&6t&ei&ao&bn &7Unit&r bakal bikin lo bisa ganti &cC&6o&el&ao&br&r dari &a&lMekaSuit Part&r yang ada di dalemnya. \\n\\nTinggal hold &eItem&r terus pencet (\\\\) buat akses Config-nya. \\n\\nBerapa banyak &cC&6o&el&ao&br&r yang tersedia? Gue gak tau, berapa banyak &cC&6o&el&ao&br&r yang ada dengan Hex Code! \\n\\nIni cuma ngaruh ke &a&lMekaSuit Part&r itu doang, tiap &a&lMekaSuit Part&r butuh &7Unit&r sendiri."]
	quest.4869D9DBDD1A15CD.quest_subtitle: "Semua Armor"
	quest.4869D9DBDD1A15CD.title: "&cC&6o&el&ao&br &cM&6o&ed&au&bl&ca&6t&ei&ao&bn &7Unit"
	quest.486B5A605D79EA10.quest_desc: ["&cManhattan &aModule&r adalah Resep rumit. Butuh &cTNT&r, &dPlutonium Pellet&r, dan &5Heisenberg Compensator&r. Oke mungkin 2/3-nya yang rumit. \\n\\nBuat bikin &dPlutonium Pellet&r, mulai dari Energize &5Amethyst Shard&r. Ini bakal bikin &5Fluxite&r, yang bisa dipake sama &aUranium Dust&r di &l&5Particle Accelerator&r buat bikin &dPlutonium Dust&r. \\n\\n&dPlutonium Dust&r bisa di-Craft sama Plastic Sheet dan Ingot buat bikin &dPellet&r kita. \\n\\n&5Heisenberg Compensator&r punya 2 Resep yang bisa dipake. Masing-masing butuh &c&lAtomic Forge&r buat &cEngrave&r pake &bAdamant Ingot&r. \\n\\n1. Pake &bUnholy Intelligence&r. Yang dibuat dengan isi &2Dubious Container&r sama &5Strange Matter&r. &5Strange Matter&r ditemuin dengan masukin &cLava&r dan &3Enderic Compound&r lewat &d&lFluid Refinery&r dengan 2 Extra Chamber terpasang. \\n\\n2. Pake &eSuper AI Chip&r. AI di &2&lMinecraft&r? Iya, dan ini butuh Pohon Resep &cEngraving&r, dengan &c&lAtomic Forge&r, buat Craft. Banyak &8Silicon&r pasti."]
	quest.486B5A605D79EA10.title: "&cManhattan &aModule"
	quest.487C70679535DDDB.quest_desc: ["Benci limitasi bodoh di Quantum Catcher kamu? Gak bisa taruh Warden di base temen! \\n\\nSekarang gak perlu khawatir karena kita bisa upgrade Quantum Catcher dengan 3 &2Stellarite Piece&r dan Nether Star untuk bikin Boss Catcher. \\n\\nSekarang kita bisa transport Boss kemana kita mau!"]
	quest.488DBE69595F38F8.quest_desc: ["Nggak, nggak, nggak, nggak boleh lagi pakai &0Coal&r buat jalanin tungku kita, kita butuh &0Coal &fbuat bikin &8Steel&r! \\n\\nPakai &6&lEnergized Smelter&r ini aja! Dia pakai &aEnergi&r buat &6Smelt &eItem&r! \\n\\nIni juga bisa di-upgrade biar punya slot lebih banyak buat &6Smelting&r, semacam Jumbo Furnace gitu. \\n\\n&lTier&r yang sudah di-upgrade juga punya tombol Auto-Sort. Ini bolehin &6&lMesin&r-nya otomatis bagi &eItem&r rata ke semua slot biar lebih efisien!"]
	quest.488DBE69595F38F8.quest_subtitle: "Tungku Listrik ala Mekanism"
	quest.488DBE69595F38F8.title: "&6&lEnergized Smelter"
	quest.48971CE964CF037F.quest_desc: ["Meskipun melindungi Reaktor Nuklir kita itu penting dan melihat isinya berhubungan dengan keamanannya. \\n\\nKaca ini juga bisa digunakan untuk membuat markas kita terlihat lebih keren! \\n\\nDan sebenarnya apa yang lebih penting: keamanan dan perlindungan reaktor nuklir kita? Atau membuat markas kita terlihat lebih keren!"]
	quest.4897C7BB3139C6C6.quest_subtitle: "Lumber + Rancher"
	quest.489833A2A6C39151.quest_desc: [
		"Dia jahat kamu bisa mencurinya aku tidak peduli."
		"{image:atm:textures/questpics/iron_spells/spells_outfit_cryomancer.png width:60 height:100 align:center}"
	]
	quest.489833A2A6C39151.title: "&bCryomancer Outfit"
	quest.489A811AB1CFCBA3.quest_subtitle: "Kapok + Dark Oak"
	quest.48B1BD7D86CAC4A0.quest_desc: ["Bukan, bukan kayak di &c&lNether&r. Oke ya emang kayak yang di &c&lNether&r. \\n\\nPenuh dengan &7Soul Sand&r. \\n\\nTinggal singkirin Fosil dan tambahin lebih banyak Lubang dan kamu dapet yang ini! \\n\\nPlus ini di &b&lThe Other&r!"]
	quest.48B1BD7D86CAC4A0.title: "&7Lembah Soul Sand The Other"
	quest.48B97E3C2A93BC46.quest_subtitle: "Aspen + Beech"
	quest.48BA8ACFADE3C8CE.quest_subtitle: "Citron + Wild Cherry"
	quest.48BE7DAC5082044D.quest_desc: ["Stres, seperti &dTenaga Rotasi&r, penting sekaligus membingungkan. \\n\\nSatuan Stres (Su) adalah beban daya untuk &6Mesin&r kita. Beberapa &6Mesin&r punya Stres minimum, artinya kamu butuh sebesar itu dalam Sistem untuk menjalankan &6Mesin&r tersebut. \\n\\n&6Penyebar&f, &6Gergaji Mekanik&f, dan &6Kipas Berselubung&r adalah contohnya! \\n\\nBeberapa &6Mesin&r juga punya Satuan Stres maksimum. Artinya kalau melebihi batas, kemungkinan besar akan berhenti bekerja. Atau meledak, salah satunya! \\n\\nSatuan Stres dihasilkan dari &dRoda Gigi&r dan dari &6Mesin&r kita yang menghasilkan &dTenaga Rotasi&r. &9Kincir Air&r menghasilkan sedikit Stres sedangkan &dMesin Uap&r bisa menghasilkan sangat banyak!"]
	quest.48BE7DAC5082044D.title: "Stres"
	quest.48BF71269DEA1AB1.title: "&4Lahan Pertanian Supremium"
	quest.48C68664319B0294.quest_desc: ["Untuk mendapatkan Spell Book spesial ini kamu harus membunuh &4&lDead King&r! \\n\\nIni punya 10 &3Spell&r Slot tapi 4 sudah terisi. &4Blood Slash&r, &4Blood Step&r, &4Ray of Siphoning&r, dan &4Blaze Storm&r sudah ada dan tidak bisa dilepas."]
	quest.48C68664319B0294.title: "Necronomicon"
	quest.48D358470A019E7A.title: "Katalis Starlight Charger Tingkat 1"
	quest.48DC9E8E9D21A2FA.quest_desc: ["Mekanism menyediakan beberapa cara untuk menghasilkan daya menggunakan sumber daya terbarukan.\\n\\n&9Solar Generator&r memanfaatkan kekuatan Matahari. Alat ini tidak bekerja di malam hari dan harus memiliki akses ke langit. Kaca tidak masalah.\\n\\n&9Wind Generator&r menghasilkan daya melalui angin. Kecepatan putarannya didasarkan pada ketinggian (Y level) tempat ia diletakkan. Alat ini juga butuh akses langsung ke langit tanpa ada blok di atasnya."]
	quest.48DC9E8E9D21A2FA.quest_subtitle: "Kekuatan Matahari..."
	quest.48DC9E8E9D21A2FA.title: "&9Mekanism: &aEnergi Terbarukan"
	quest.48E4D75FD3145AD6.quest_desc: ["Cairan Waktu digunakan oleh Mesin Paradoks dan Tongkat Waktu. Didapatkan dengan menjatuhkan Kristal Waktu ke dalam Cairan Polimorfik.\\n\\nUntung untuk kristal yang susah didapat, mereka kasih cairan yang gampang."]
	quest.48EE6C807C1668D4.quest_desc: ["Jika kamu butuh kabel (wire) untuk menjangkau tempat yang lebih jauh atau menghubungkan lebih banyak lokasi, kamu mungkin butuh Connector Node. \\n\\nSimpel kan!"]
	quest.48EE6C807C1668D4.title: "Kabel ke Sana, Kabel ke Sini"
	quest.48F496BD0FFE5A34.quest_desc: ["&4Magnetic &9Attraction &7Unit&r kerjanya kayak Simple Magnet. Pas dipake/dipakai, bakal narik &eItem&r ke arah lo yang di luar jangkauan. \\n\\nMakin banyak &4Magnetic &9Attraction &7Unit&r makin jauh &eItem&r yang bisa ditarik ke arah lo."]
	quest.48F496BD0FFE5A34.quest_subtitle: "Sepatu"
	quest.48F496BD0FFE5A34.title: "&4Magnetic &9Attraction &7Unit"
	quest.48F77A0BE1F33B29.quest_desc: ["Menggunakan &#65C2A6Wiremill&r yang baru saja dibuat, kita sekarang bisa membuat &#53E67BWire&r dan &#53E67BFine Wire&r yang akan membawa kita ke era kelistrikan."]
	quest.48F77A0BE1F33B29.title: "Kabel yang Rumit"
	quest.4903BDC389C73082.title: "Draconic Projectile Damage Module"
	quest.4926C95DD02F1410.quest_desc: ["Lo pernah liat Tutorial yang pake Beacon sebagai &4Laser Security Gate&r. Terus, pas lo coba ternyata gak bunuh orang? \\n\\nNah &4Laser&r ini beneran bunuh! \\n\\nPercaya deh, mereka kayak Beacon dan mereka beneran bunuh! \\n\\nBeda sama Beacon, lo gak bisa ganti Warnanya pake Glass. Mungkin karena mereka hancurin hampir semua Blok yang menghalangi dan Void drop-nya... \\n\\nMereka juga pake &aEnergi&r daripada Material buat powered. \\n\\nGue gak tau persis berapa banyak Damage yang mereka kasih tapi cukup buat Goreng Ayam pas kena &4Laser&r!"]
	quest.4926C95DD02F1410.title: "&4Laser"
	quest.4933CF4675E77D50.quest_desc: ["Setelah terkena damage api, &5Obsidian Skull&r akan aktif memberimu durasi Fire Resistance. Semoga cukup lama buat kabur dari kobaran api!"]
	quest.4933CF4675E77D50.quest_subtitle: "Sabuk"
	quest.4933CF4675E77D50.title: "&5Obsidian Skull&r"
	quest.4935209D870E25F2.quest_desc: ["90% dari &5&lMekanism&r &5Mesin&r butuh &aEnergi&r biar jalan. &5&lMekanism&r pakai satuan FE buat jalanin &5Mesin&r! \\n\\n1kFE itu 1000 FE, dan 1mFE itu 1,000,000 FE! \\n\\n&aEnergy Tablet&r itu baterai versi &5&lMekanism&r. Kamu juga butuh ini buat crafting kebanyakan &aGenerator&r. \\n\\nYa, &5&lMekanism&r punya &aGenerator&r dan ya, mereka keren banget! "]
	quest.4935209D870E25F2.title: "&a&lListrik!"
	quest.493D04D954E4FBA0.quest_desc: [
		"&5&lMekanism&r adalah mod teknologi... kenapa kamu kaget kalau mesin-mesinnya butuh Energi?"
		"{image:atm:textures/questpics/logistics/meka_cable.png width:200 height:50 align:center}"
	]
	quest.493D04D954E4FBA0.quest_subtitle: "Energi"
	quest.495B0CC178B4CFA9.quest_desc: ["&eCorong Kuningan&r dipasang dan digunakan mirip dengan &eTerowongan Andesit&r. \\n\\nTapi setiap sisi kini hadir dengan konfigurasi baru! \\n\\nSisi Input kini dilengkapi opsi Filter. Cukup taruh &eItem&r di sana, dan ia hanya akan menerima &eItem&r tersebut. \\n\\nSisi Output kini dilengkapi batas. Kamu bisa Scroll untuk mengatur angka dari 1 hingga 64. Bisa juga memilih apakah akan mengeluarkan tepat sejumlah itu, atau hingga sejumlah itu. \\n\\nKalau tepat sejumlah itu, ia akan menunggu sampai jumlah tersebut ada dalam Inventaris untuk dikeluarkan. Kalau hingga sejumlah itu, ia akan terus mengeluarkan &eItem&r sampai angka tersebut tercapai."]
	quest.495B0CC178B4CFA9.title: "&eCorong Kuningan"
	quest.495DCA49B4E80852.quest_desc: ["&3Minigun&r adalah senjata yang butuh tekanan udara dan amunisi agar bisa bekerja. Baca tooltip untuk info lebih lanjut."]
	quest.495DCA49B4E80852.quest_subtitle: "Dor Dor!"
	quest.49636B3C6E6D0C2A.quest_desc: ["Gak ada kegunaannya, tapi kelihatan keren."]
	quest.4966162FBA933453.title: "&4Komponen Penyimpanan 262m"
	quest.49772923B8AF0F1F.title: "&bKomponen Penyimpanan Cairan 1048kB"
	quest.49776AC58E535E6A.quest_subtitle: "Dibuat di Reprocessor"
	quest.49776AC58E535E6A.title: "Inanite Bee"
	quest.4978A9B616362CCE.title: "&aRank 2&r: Lebih Banyak &cDarah"
	quest.497AE687B7E95DE8.quest_desc: [
		"&aRitual of the Forest&r dapat dilakukan dengan membangun struktur multiblock menggunakan 8 Wooden Stand, 16 &eGold Powder&r, dan bibit pohon Oak atau Jungle, tergantung resepnya.\\n\\nUntuk memulai ritual, letakkan item yang dibutuhkan pada Wooden Stand dan tumbuhkan bibit pohon yang diminta di tengahnya. &eGold Powder&r akan terkonsumsi dalam proses ini, jadi kamu akan butuh banyak."
		"{image:atm:textures/questpics/natures_aura/forest_ritual.png width:295 height:150 align:center}"
	]
	quest.497AE687B7E95DE8.title: "&aRitual of the Forest"
	quest.497D222F74A52DF5.quest_desc: ["Nah, ini baru mantap! Besi (Iron) sangat mudah ditemukan dan armornya luar biasa untuk awal permainan. \\n\\nZombie dan Skeleton nggak bakal berkutik!"]
	quest.497D222F74A52DF5.quest_subtitle: "15"
	quest.497FA7CA04117995.title: "Kehidupan"
	quest.498483750C18FCD6.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_regalium.png width:100 height:150 align:center}"]
	quest.498483750C18FCD6.title: "&eRegalium&r"
	quest.4987759CF379C1EB.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Mencegah efek kelambatan dan kecepatan diberikan selama kamu punya Kristal Waktu di inventori."
	]
	quest.499CF9F39CED8899.quest_desc: ["&bIntegrated Dynamics&r (ID) adalah mod logistics yang bisa dipakai untuk storage, transfer item/power/fluid dan lainnya!\\n\\nPohon Menril bisa ditemukan di biome Meneglin.\\n\\nQuest ini akan membahas beberapa konsep dasar mod ini, baca guidebook yang diberikan sebagai reward untuk quest ini kalau ingin lebih dalam."]
	quest.499CF9F39CED8899.quest_subtitle: "Menumbuhkan Menril"
	quest.499CF9F39CED8899.title: "&bIntegrated Dynamics"
	quest.49D0B6D3ED3DCCCD.quest_desc: ["&bArcane Crystal Dust&r cukup simpel, cuma Smelt &bArcane Crystal&r dan boom! \\n\\nKamu juga bisa pakai Clibano Multiblock untuk dapet beberapa bit &bArcane Crystal&r kembali!"]
	quest.49D0B6D3ED3DCCCD.title: "&bArcane Crystal Dust"
	quest.49D1B01E07ABA471.quest_desc: [
		"Kamu bisa mentransfer item menggunakan &cMercury&r. \\nPasang Item Extractor di tempat pengambilan item. Kemudian pasang Item Inserter di tempat tujuan. Hubungkan keduanya dengan &cMercury Wire&r dan item akan mulai berpindah! \\n\\nIni bisa digunakan dengan mesin-mesin &l&6Theurgy&r untuk sistem otomatisasi!"
		"{image:atm:textures/questpics/theurgy/theurgy_item.png width:200 height:75 align:center}"
	]
	quest.49D1B01E07ABA471.title: "Pemindahan Item"
	quest.49D1EA8E812A12F6.quest_desc: ["Ini cuma tanaman yang keren. \\n\\nKamu butuh Swamp Silver Sickle buat ngumpulin! \\n\\nGak tau kenapa aku gak pernah peduli sama tanaman tapi Reed keren buat aku. Mungkin karena deket Air, atau Cattail keliatan kayak Corndog. Gak tau tapi aku suka."]
	quest.49DC0BD7DC1B893C.quest_desc: ["Abyss adalah parit dalam di Starlit Sea. Ini turun sampai sejauh -50! \\n\\nMereka punya beberapa lapisan berwarna Stone dan punya banyak Blok, Moss, dan Ikan berbeda!"]
	quest.49DC0BD7DC1B893C.title: "The Abyss"
	quest.49EB9FB2133E3219.quest_desc: ["Ancient Armor adalah armor yang dikenakan oleh para &7Forgotten&r, dan di sanalah kamu bisa mendapatkannya. \\n\\nTapi tidak ada Ancient Boots, sepertinya para &7Forgotten&r memang tidak punya kaki."]
	quest.49EB9FB2133E3219.title: "Ancient Armor"
	quest.49EDAA2F57D3BF1D.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, kamu sedang dalam mode pengeditan."]
	quest.49EE6D2A3684A510.quest_desc: ["&bIce Bow&r dapat ditemukan secara acak di peti loot, ia akan memberikan efek Slowness III selama 10 detik saat mengenai musuh."]
	quest.49EE6D2A3684A510.title: "Busur Es (&bIce Bow&r)"
	quest.49EF8A4346AEF582.quest_desc: ["Menjatuhkan Bara Gerhana ke dalam Bahan Bakar Apikegelapan akan membuat Bahan Bakar Bara Gerhana Mentah. Melakukan Penyebaran Lendir dengan lendir Tingkat Empat akan mengubah Bahan Bakar Bara Gerhana Mentah menjadi Bahan Bakar Bara Gerhana."]
	quest.49F08DE190AAD0D8.quest_desc: ["&3Augment&r: Factory bikin Furnace-mu lebih mirip Smelting Factory dari Mekanism. Daripada pakai Fuel sekarang bakal pakai Energi! Pipe-in Energi dan bakal mulai Smelting."]
	quest.49F08DE190AAD0D8.title: "&3Augment&r: Factory"
	quest.49FDD8666356A3E7.quest_desc: ["Kita bisa pake antara atau keduanya &2Blastproof Casing&r atau 256M Portable Item Cell buat Craft &3&lImprobable Probability Device&r. \\n\\nTunggu gue bilang antara atau keduanya? \\n\\nIya gue bilang! Kita bisa pake 2 &2Blastproof Casing&r atau 2 256M Portable Item Cell atau satu dari masing-masing."]
	quest.49FDD8666356A3E7.title: "Antara atau &2Blastproof Casing&f dan 256M Portable Item Cell"
	quest.4A01C5F5DCF32C19.quest_desc: ["&3Soul Elytra&r bekerja seperti &8Elytra&r normal, cuma sekarang dengan lebih banyak Durability dan Armor Points! \\n\\nMereka tidak bisa diperbaiki dengan &7Phantom Membranes&r seperti &8Elytras&r normal... tapi Enchantment masih bisa memperbaikinya! \\n\\nUntuk Craft-nya kamu butuh &8Elytra&r, 4 &3Sculk Bones&r yang drop dari &3Shattered&r, 2 &3Soul Dust&r yang drop dari &3Sculk Snappers &fatau &3Sculk Leeches&r, dan &3Soul Crystal&r yang drop dari &3&lStalker&r."]
	quest.4A01C5F5DCF32C19.title: "&3Soul Elytra"
	quest.4A03A671757B2EBF.quest_desc: ["Durabilitas, Tingkat Cairan, Tingkat Energi, Tingkat Mantra, dan Nilai Makanan adalah kategori yang bisa kita gunakan dengan Inspection Filter.\\n\\nLalu kita pilih apakah ingin Lebih Besar dari, Lebih Kecil dari, Sama Dengan, atau campuran dengan Jumlah Angka tertentu.\\n\\nBisa digunakan untuk hanya menyimpan alat dengan durabilitas tinggi atau makanan bergizi tinggi."]
	quest.4A05C037C0EE40BD.quest_desc: ["Logic Cables berbeda dari cable lain. Cable lain bertindak seperti Hopper, item bergerak dari 1 Inventory, ke cable, lalu ke inventory ke-2. Logic Cables langsung skip perantara yang juga skip banyak lag.\\n\\nIni hanya untuk menghubungkan Importer dan Interface."]
	quest.4A05C037C0EE40BD.quest_subtitle: "Membuat Network"
	quest.4A05C037C0EE40BD.title: "Logic Cables"
	quest.4A06CCE1FE0F333C.quest_desc: ["&#74C3DBAir Intake&r saat dimasukkan ke dalam &#46CAF2Vacuum Freezer&r akan menghasilkan &#B5E7F7Liquid Air&r."]
	quest.4A076530297F4A97.quest_desc: [
		"Dengan 3 komponen ini, kamu bisa membuat &3Elevator&r (Lift) yang luar biasa.\\n"
		"{image:pneumaticcraft:textures/patchouli/elevator.png width:1 height:1 align:left fit:true}"
	]
	quest.4A076530297F4A97.title: "Elevator"
	quest.4A079D40C0AF6BC3.quest_desc: [
		"Tidak, ini tidak ditemukan di &5&lThe Beyond&r. \\n\\nKamu bisa menemukan &5Unobtainium Ore&r dengan sangat langka di biome End Highlands. Di biome itu jugalah biasanya End City muncul! \\n\\nKamu butuh &3Vibranium Pickaxe&r (atau tingkat yang sama) untuk menambang bijihnya. \\n\\nApa aku perlu ingatkan lagi untuk memproses bijihnya?"
		"{image:atm:textures/questpics/allthemodium/all_3.png width:100 height:100 align:center}"
	]
	quest.4A079D40C0AF6BC3.title: "&5Unobtainium Ingot&r"
	quest.4A198E875A6B0A64.quest_desc: ["&bUltra Autocrafter&r memiliki 36 slot Pattern, bekerja 5x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.4A198E875A6B0A64.title: "&bUltra Autocrafter"
	quest.4A1C8125896F7F1A.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau kontributor &2Komunitas&r buat dipakai di Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r punya lisensi &eAll Rights Reserved&r, Quest ini nggak boleh dipakai di pack publik mana pun yang nggak dirilis sama &6AllTheMods Team&r tanpa izin jelas.\\n\\nQuest ini sengaja disembunyiin, kalau kamu lihat ini, berarti kamu lagi di mode editing."]
	quest.4A3A5684302C8627.title: "Chaotic Shield Capacity Module"
	quest.4A44623D8A307473.quest_desc: [
		"&6High Speed Electric Track&r seperti &6Rel Elektrik&r tapi jauh lebih cepat! Jalur ini membutuhkan syarat dari High Speed Track biasa dan Rel Elektrik: &cSpeed Boost&r dan &eFrame&r sebagai tenaga. Sekarang kamu harus hati-hati di tikungan dan jangan sampai menyentuhnya!"
		"{image:atm:textures/questpics/railcraft/rail_electric_speed.png width:150 height:100 align:center}"
	]
	quest.4A44623D8A307473.title: "&6Jalur Elektrik Kecepatan Tinggi"
	quest.4A4C14AF947D93EF.quest_subtitle: "Tingkat: &b4"
	quest.4A4C71C43519D5FE.quest_desc: [
		"Untuk memanggil boss Nether, perlu mengumpulkan beberapa item dulu. "
		""
		"Perlu mendapat setidaknya 3 &5Wither Skeleton Skull&r. Ini adalah rare drop dari membunuh &7Wither Skeleton&r, atau bisa di-craft dengan drop yang lebih umum, &3Wither Skull Fragment&r. "
		""
		"Juga butuh setidaknya 4 Soul Sand, dan mungkin armor yang cukup bagus."
	]
	quest.4A4C71C43519D5FE.title: "&6Memanggil &5Wither"
	quest.4A54288FD22C903D.quest_desc: ["Velvetumoss spawn di dalam The Abyss. \\n\\nKamu bisa tambang yang hijau buat dapet Velvetumoss Ball yang bisa dimakan atau dibuat jadi Slimeball! \\n\\nYang merah bakal spawn tanaman cantik!"]
	quest.4A564E8FE587C7E4.quest_desc: ["Cara terbaik dapet Soul adalah via Soul Extractor! \\n\\nUntuk beberapa Nether Item dan Block dan Utrem Jar (yang butuh Edelwood untuk craft) kamu bisa dapet tool untuk Soul-Finding! \\n\\nTahan Klik Kanan dengannya di Soul Sand dan akan extract Soul dari sana. \\n\\nNinggalin sebagai Sand... gak tunggu itu Soulless Sand... apa sih Soulless Sand?!?!?!"]
	quest.4A5937F6E5D06BE1.quest_desc: ["Generator bahan bakar cair sederhana yang berjalan dengan bahan bakar cair yang ditambahkan oleh JDT."]
	quest.4A5A143A79809BB6.quest_desc: [
		"Ah ya, akhirnya kamu sampai di sini. Selamat datang di Zaman Listrik, inilah awal petualanganmu yang sesungguhnya."
		""
		"Pertama-tama, kita butuh Battery Alloy... untuk membuat baterai, mengejutkan, bukan?"
	]
	quest.4A5A143A79809BB6.quest_subtitle: "Paduan Logam Baterai"
	quest.4A5A143A79809BB6.title: "Zaman Listrik"
	quest.4A5EA948F5DCEB73.quest_desc: ["Swamp Silver bisa jarang ditemuin di dalam Nightfall Mud. \\n\\nBisa dipake buat craft Armor dan Tool!"]
	quest.4A5F84912C755688.quest_desc: [
		"Sebuah lantai dansa untuk para lebah. Ayo gerakkan tubuhmu seirama musik!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_dance.png width:200 height:100 align:center}"
	]
	quest.4A5F84912C755688.title: "Lantai Dansa"
	quest.4A618CA66AD6223D.quest_subtitle: "Input tenaga yang lebih besar lagi"
	quest.4A6B585C2394A89A.quest_desc: ["Dua item yang kita butuhin lewat &5&lRunic Enchanter&r adalah &dInfused Dragon's Breath&r dan &5Mending Book&r. \\n\\n&dInfused Dragon's Breath&r cukup simpel, cuma &aFluid XP&r, &dSource&r, dan &dDragon's Breath&r! \\n\\n&dDragon's Breath&r bisa di-farm pakai &b&lHNN&r atau yang lebih bagus lagi, Extractor dari &l&9X&cy&aC&8r&aa&cf&9t&r. \\n\\n&5Mending Book&r bisa diotomatisasi pakai &aFluid XP&r, &dSource&r, &9Lapis Lazuli&r, &4Supremium Enchanting Base&r, dan bagian tersulitnya: &aExperience Rod&r. \\n\\n&9Lapis&r bisa dapet dari &2&lMA&r, &6&lBees&r, atau nambang pakai Quarry. \\n\\n&aExperience Rod&r butuh dua alloy dari &a&lEnderIO&r: Soularium dan Energetic Alloy. Keduanya bisa dibuat di Alloy Smelter. \\n\\n&4Supremium Enchanting Base&r adalah item baru khusus buat &5&lRunic Enchanter&r. Kamu harus pakai banyak banget &aEXP Essence&r dan Tiered Essence untuk memproses Book and Quill (bisa di-farm via &b&lHNN&r) jadi &4Supremium Enchanting Base&r!"]
	quest.4A7AEBEB87CEC274.quest_desc: ["Kayaknya aku nggak punya izin buat nyebut merk &cSepatu Lari&r tertentu, jadi bayangin aja sendiri merknya apa. \\n\\n&cRunning Shoes&r memberimu Speed Boost saat lari (Sprinting) jadi kamu bakal lebih kencang lagi! Juga dapet fitur auto-jump pas lari..."]
	quest.4A7AEBEB87CEC274.quest_subtitle: "Kaki"
	quest.4A7AEBEB87CEC274.title: "&cRunning Shoes&r"
	quest.4A84C8578C2F7F71.quest_desc: ["Dengan beberapa &eKitin Cacing Maut &fdan &eLidah Cacing Maut&r (plus Rantai) kita bisa bikin &eSarung Tangan Cacing Maut&r! \\n\\nIni pada dasarnya bertindak sebagai bagian bahaya dari &eCacing Maut&r. \\n\\nKita bisa Klik Kanan buat kirim &eLidah Cacing Maut&r ke Mob. Kalo kena mereka, bakal kasih Damage dan tarik mereka ke kamu. \\n\\nSayangnya ada Cooldown... &eLidah&r harus masuk balik."]
	quest.4A84C8578C2F7F71.title: "&eSarung Tangan Cacing Maut"
	quest.4A854CD5EC70733E.quest_desc: ["Menambahkan fungsi Meja Crafting ke dalam Tas."]
	quest.4A88472F1581EE7E.quest_desc: ["Selamat datang di &4&lMahou Tsukai&r. \\n\\nTidak, tidak bisa langsung dapat &4&lMorgan Sword&r harus benar-benar bermain mod ini sedikit. \\n\\nUntuk memulai, terima damage. Akan ada efek bleeding. Sebelum hilang, tahan shift dan tekan M pada solid block untuk menempatkan &cMahou Circle&r pertama. \\n\\nAlias &cMahoujin&r!"]
	quest.4A88472F1581EE7E.title: "&4&lMahou Tsukai"
	quest.4A92237E17ED5F1C.quest_desc: ["Void Container mengubah inventaris apa pun menjadi tempat sampah (Trash Can). Letakkan di atas inventaris dan item akan lenyap!"]
	quest.4A99CAB529BB9F75.quest_desc: ["&4Mega Constructor&r memiliki 54 slot filter, bekerja 8x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.4A99CAB529BB9F75.title: "&4Mega Constructor"
	quest.4A9CB8778D37049F.quest_desc: ["Kamu butuh Awakening Ritual untuk mendapatkan item yang diperlukan untuk melakukan Awakening Ritual lainnya pada &4Supremium Armor&r. \\n\\nMenurutku ini sangat sepadan; ini armor terbaik yang bisa kamu dapatkan dari mod &2&lMystical Agriculture&r!"]
	quest.4A9CB8778D37049F.quest_subtitle: "36"
	quest.4A9CB8778D37049F.title: "&6Awakened Supremium Armor"
	quest.4AAADEC52D16461A.quest_desc: ["Pada dasarnya mengaktifkan auto-jump. Pribadi aku suka tapi terserah kamu untuk pakainya!"]
	quest.4AAADEC52D16461A.title: "Hill Step Module"
	quest.4AAB3899F530CC19.quest_desc: ["Chute bisa mengambil &eBarang&r (dan beberapa Entitas) dan menjatuhkannya tanpa khawatir hilang! \\n\\nMereka juga menjatuhkan &eBarang&r cukup cepat. \\n\\nBisa menggunakan &6Palu Insinyur&r untuk membuat Chute melengkung untuk melempar &eBarang&r ke &eSabuk&r!"]
	quest.4AAB3899F530CC19.quest_subtitle: "Tidak Ada Tangga?"
	quest.4AB0DD227471FDBF.quest_desc: ["Bab ini didedikasikan untuk segala hal yang berhubungan dengan daya!\\n\\nDi sini kamu akan menemukan cara dasar untuk menghasilkan, menyimpan, dan mentransfer daya."]
	quest.4AB0DD227471FDBF.quest_subtitle: "Segala Macam Daya!"
	quest.4AB0DD227471FDBF.title: "&cBasic Power"
	quest.4AB564420C48579B.quest_desc: ["Draconic Evolution tidak melihat perlunya menutupi seluruh tubuh dengan armor payah saat kamu bisa pakai satu Chestplate dengan shield built-in. Tunggu, mereka tidak built-in kamu butuh Module untuk itu... maaf."]
	quest.4AB564420C48579B.title: "Wyvern Chestplate"
	quest.4ABEF61DADBD0640.quest_desc: ["Kebanyakan Bow adalah Semi-Otomatis. Kamu harus tarik tali, lepas, dan masukkan Arrow lain ke bow, dan ulangi. Alih-alih lewati semua itu biarkan Bow otomatis menembak setiap kali tertarik penuh. Tinggal tahan Klik Kanan dan lihat!"]
	quest.4ABEF61DADBD0640.title: "Auto Fire Module"
	quest.4AC3EA41234BC5F0.quest_subtitle: "+20 HP Maksimal"
	quest.4ACB72F3A23A5A19.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Meningkatkan kecepatan berenang."
	]
	quest.4AD4FDF70B9BFCC9.quest_desc: ["Menggunakan Token milikmu pada Offering Table akan meningkatkannya. Token yang sudah ditingkatkan ini akan dibutuhkan untuk resep crafting yang lebih lanjut."]
	quest.4AD4FDF70B9BFCC9.title: "Token yang Ditingkatkan"
	quest.4AD8363D7359A072.quest_desc: [
		"Kita akan bangun passive reactor terkecil yang mungkin, &93x3x3&r. Requirement untuk quest adalah jumlah pasti yang kamu butuh buat bangun satu.\\n\\nBuat bangun ini, mulai dengan bangun frame 3x3x3 dari Casing. Di tengah sisi bawah, kamu bisa pakai Reactor Casing lain. Kamu mau setiap dinding luar punya &9reactor component&r, kayak Active Power Tap atau Solid Access Port."
		"{@pagebreak}"
		"Setiap reactor yang kamu bangun memerlukan tepat 1 &6Reactor Controller&r, yang biasanya ditaruh di tengah dinding depan. Selanjutnya, kita taruh 1 &aFuel Rod&r di tengah multiblock, dan 1 &eControl Rod&r di atasnya di sisi atas.\\n\\nKamu butuh cara buat input dan output waste, yang dilakukan pakai &9Reactor Solid Access Port&r. Untuk build ini, taruh satu di sisi kiri dan satu di kanan.\\n\\nUntuk ngeluarin power, kita taruh &cActive Power Tap&r di tengah dinding belakang. Setelah ditaruh, reactor harusnya lengkap! Kamu sekarang bisa klik kanan Controller untuk buka interface dan nyalain!\\n\\nCatatan: Reactor terbesar yang bisa kamu buat pakai &aBasic Reactor Part&r adalah 5x5x5. Untuk bangun reactor lebih besar, kamu butuh &eReinforced Reactor Part&r."
		"{@pagebreak}"
		"Ini bentuk reactor 3x3x3:\\n"
		"{image:atm:textures/questpics/extremereactors/3x3sample.png width:150 height:150 align:1}"
	]
	quest.4AD8363D7359A072.quest_subtitle: "Belajar Dasar"
	quest.4AD8363D7359A072.title: "&dReactor Pertama Kita"
	quest.4AE8D8826F894EC7.quest_desc: ["&l&5Domun Ornamentum&r itu semacam gabungan &l&6Framed Blocks&r dan &l&bChipped&r! \\n\\nMenggunakan Architects Cutter, kita bisa membuat banyak bentuk dan variasi blok yang berbeda. \\n\\nSaat membuat sebuah blok, pertama pilih grupnya: Pintu, Lampu, DLL. \\nLalu pilih variannya. \\nSetelah itu, kita perlu menambahkan blok dasar pembuatnya! Beberapa blok membutuhkan dua blok pilihan yang berbeda sementara yang lain hanya butuh satu."]
	quest.4AE8D8826F894EC7.title: "&l&5Domun Ornamentum&r"
	quest.4AEB4BF7624ABA0F.quest_subtitle: "Firecracker + Soul Tree"
	quest.4AFA3CB55F6C10C2.quest_subtitle: "Pandanus + Coconut"
	quest.4AFDC9ACAC926654.quest_desc: ["Kadang Telur Ayam bisa spesial. Kayak punya 2 Kuning atau Menetas 4 Ayam! Atau Menetas Dinosaurus! \\n\\nTunggu... apa? \\n\\nKadang Ayam bakal bertelur &0Telur Busuk&r. &0Telur Busuk&r bisa dilempar buat Menetas &0Bayi Cockatrice&r! \\n\\n&0Bayi Cockatrice&r ini bakal otomatis Jinak dan harus tumbuh gede."]
	quest.4AFDC9ACAC926654.title: "&0Telur Busuk"
	quest.4B12425E74C5E511.quest_desc: ["&cExplosive Mycelial Generator&r jago banget nyerap Ledakan. \\n\\nKita bisa pake itu buat &d&lPulsating &8Black Hole&r!"]
	quest.4B12425E74C5E511.title: "&cExplosive Mycelial Generator"
	quest.4B1E4FC4599DB916.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kekebalan"
		"- Padamkan Api"
		"- Elytra"
	]
	quest.4B2146C9527C54E7.quest_desc: ["Jelas karena kamu sudah berada di Chapter 2, kamu telah menamatkan &2&lVanilla Minecraft&r! \\n\\nSekarang kamu seharusnya sudah punya &cNetherite&r dan membunuh semua bos yang ada di &2&lMinecraft&r. Apa selanjutnya? \\n\\n&6&lAllthemodium&r adalah langkah selanjutnya! Namun, untuk mulai mendapatkan &6Allthemodium&r, kamu akan butuh &cNetherite&r. Mari kita mulai dari sana!"]
	quest.4B2146C9527C54E7.title: "&6&lAllthemodium"
	quest.4B2835706B593E9A.quest_desc: ["&d&lAntiprotonic &5Nucleosynthesizer&r adalah &5Mesin&r yang dibuat dari &dAntimatter Pellet&r. \\n\\nTentu aja juga pake &dAntimatter&r sebagai Fuel, karena belom cukup mahal! \\n\\nJadi apa fungsinya? \\n\\nPake &dAntimatter&r, &aEnergi&r, sama &eItem&r tertentu buat bikin &eItem&r baru (dan biasanya langka). Beberapa bahkan gak bisa di-Craft! \\n\\nKayak &5Amethyst&f jadi &9Echo Shard&f, &eGolden Apple&f jadi &eEnchanted Golden Apple&r, bahkan Egg jadi &dDragon Egg&r!"]
	quest.4B2835706B593E9A.title: "&d&lAntiprotonic &5Nucleosynthesizer"
	quest.4B35C01F5D0AAC58.quest_desc: ["Sekarang pas kita sudah punya &9&lMetallurgic Infusion&r dan semoga sudah ada &cEnergi&r, kita bisa mulai bikin &8Steel&r! \\n\\nKita butuh &0Carbon&r di &eChemical Bar&r kita. Kita bisa pakai &0Coal&f, &0Charcoal&r, atau varian lain di &eChemical Slot&f buat nambahin &0Carbon&r. \\n\\nTerus, kalau kita taruh &7Iron Ingot&f/&7Dust&r ke &4Item Slot&r, dia bakal Infuse pakai 10mB Carbon buat bikin Enriched Iron. \\n\\nKita perlu ulangi langkah itu tapi kali ini nambahin 10mB &0Carbon&r buat ngerubah &7Enriched Iron&r tadi jadi &8Steel Dust&r! Bakar &8Dust&r-nya buat dapat &8Steel Ingot&r. \\n\\n&8Steel&r dipakai buat hampir semua hal! Mesin, alat, upgrade, reaktor, sel energi! Kamu bakal butuh banyak banget."]
	quest.4B35C01F5D0AAC58.title: "&8Steel "
	quest.4B3F20E5C7E3BCFB.quest_desc: ["Batu Bara Purba adalah material baru yang ditambahkan oleh JDT. Batu Bara Purba didapatkan dengan melakukan Penyebaran Lendir pada Balok Batu Bara menggunakan lendir tingkat satu atau lebih tinggi. Bijih Batu Bara Purba dipengaruhi oleh keberuntungan."]
	quest.4B42D962FE910CB3.quest_desc: ["Dengan ini ditambahkan ke &d&lRevolver&r, Peluru akan memberikan Mob yang ditembak Efek Terpukau."]
	quest.4B4F5341D6DBDD19.quest_desc: ["Menjaga agar kamu tetap bisa bernapas di bawah air; saat gelembungmu tersisa 5, mereka akan terisi kembali! Ini juga membuatmu bisa melihat jauh lebih mudah di bawah air!"]
	quest.4B4F5341D6DBDD19.quest_subtitle: "Maks: 1"
	quest.4B552E9D05FF5415.quest_desc: ["&l&9X&cy&aC&8r&aa&cf&9t&r adalah tentang 5 warna yang berbeda, ini termasuk menggunakannya untuk blok! \\n\\n&aHijau&r, &cMerah&r, &9Biru&r, &8Gelap&r, dan berbagai macam blok bercahaya!"]
	quest.4B552E9D05FF5415.title: "Dunia &l&9X&cy&aC&8r&aa&cf&9t&r"
	quest.4B62AF0405F68041.quest_desc: ["Menambahkan filter yang memungkinkanmu memberi tahu Tas item mana saja yang harus selalu tersedia. Shift+Klik Kanan pada inventaris akan mengisinya kembali."]
	quest.4B62AF0405F68041.quest_subtitle: "Selalu Siap Stok"
	quest.4B62AF0405F68041.title: "Restock Upgrade"
	quest.4B65100885AE762D.quest_desc: ["&6Holy Armor&r dari mod &e&lIron's Spells&r!"]
	quest.4B65100885AE762D.quest_subtitle: "20"
	quest.4B65100885AE762D.title: "&6Priest Outfit"
	quest.4B65720872B062F8.quest_desc: [
		"&lStage 1&r sampe &l3 &5Naga Petir&r bakal Spawn di &5Sarang Naga Petir&r. \\n\\nMereka dateng dalam &9Biru Listrik&r, &dAmethyst&f, &6Tembaga&f, dan &0Hitam&r. &5Naga Petir&r punya 6 Tanduk yang cuma di Kepala, juga punya Ekor Berduri! \\n\\nTunggu, &5&lNaga&r ini gak bangun pas &9Siang&r! Oh mereka Nokturnal! Mereka bakal Tidur selama &eSiang&r dan berburu pas &9Malam&r. Mereka cuma Tidur berdiri yang bisa bikin bingung. \\n\\n&5&lNaga Petir&r dianggap &5&lNaga&r terkuat karena Damage yang bisa mereka kasih ke Player. &5Serangan Elemental&r mereka gak bakal kasih Efek kayak &bBeku &fatau &cBakar&r, tapi kompensasi dengan lebih banyak Damage! \\n\\n&5Napas Petir&r mereka bakal ikutin kamu kemanapun kamu pas &5Bola Petir&r mereka bakal kasih Ledakan gede! \\n\\nTenang itu bukan semua yang mereka bisa lakukan! Mereka juga bisa Pukul kamu pake Ekor Berduri, Gigit kamu, robek kamu jadi serpihan, dan lempar kamu mundur sama kekuatan Sayap mereka. \\n\\nPaling baik lawan &5&lNaga Petir&r pas &eSiang&r jadi Mob lebih dikit dan mereka bakal tidur. kamu juga butuh banyak Armor dan Resistance buat tahan Damage mereka!"
		"{@pagebreak}"
		"kamu Bunuh satu? &5&lNaga Petir&r? Gimana caranya? \\n\\nYa, kalo kamu gak bohong dan mereka gak cuma tidur mereka harusnya jadi Mayat sekarang. \\nKlik Kanan Mayat &5&lNaga Petir&r pake Tangan Kosong buat lepas &5Sisik&f, &5Daging&f, dan &5Jantung&r-nya. \\n\\nKalo kamu Klik Kanan Mayat pake Botol Kosong kamu gak bakal dapet &5Sisik&f, &5Daging&f, atau &5Jantung&r tapi kamu bakal dapet &5Darah Naga Petir&r. \\n\\nSetelah kamu kupas &5Sisik &fatau &5Darah&r-nya dia bakal jadi &7Kerangka Naga&r. \\n\\nTinggal Klik Kanan &7Kerangka&r pake Tangan Kosong buat dapet &7Tulang &fdan &7Tengkorak&r dari hasil bunuh kamu!"
	]
	quest.4B65720872B062F8.title: "&lStage 1-3 &5Naga Petir"
	quest.4B76FE0348DB0E45.quest_desc: ["Quantum Bridge Card adalah metode alternatif untuk mendapatkan akses nirkabel lintas dimensi ke sistem AE2 kamu. Kamu butuh Quantum Bridge di markasmu dan kartu ini di terminalmu. Keduanya diikat menggunakan Quantum Entangled Singularity agar bisa diakses di mana pun."]
	quest.4B76FE0348DB0E45.title: "Quantum Bridge Card"
	quest.4B7840F1A8CF1378.quest_desc: ["Fusion Crafting adalah cara kebanyakan (setidaknya item seru) akan dibuat. Untuk memulai kamu butuh Fusion Crafting Core, tempatkan sekitar satu block di atas tanah. Core adalah tempat resep bisa auto-place dari JEI, di mana item tengah masuk, dan di mana item akhir akan diletakkan. Butuh Injector diletakkan beberapa block jauh darinya menghadap Core di dua sisi. Lihat Quest berikutnya untuk info lebih tentang itu. Injector juga butuh Energy yang akan dijelaskan lebih di Quest Crystal Binding."]
	quest.4B7840F1A8CF1378.title: "Fusion Crafting"
	quest.4B7D387CEFF9667E.quest_desc: ["Akhirnya! &6&lCreate&r udah di-update dan pasti worth the wait! \\n\\n&6&lCreate&r itu semua tentang rotate dan pake Rotational Power... ya buat hampir semuanya! Crafting, crushing, mixing, brewing, DLL. \\n\\nKalo udah lama banget sampe kamu gak ingat cara pake &6&lCreate&r, kamu bisa pake &7&lModern Industrialization&r buat Craft &6&lATM Star&r."]
	quest.4B7D387CEFF9667E.title: "&6&lCreate"
	quest.4B81E84CAE814BA9.title: "&6Komponen Penyimpanan Cairan 64B"
	quest.4B95D48D7525FFAD.quest_desc: ["Saatnya pergi ke &2Rawa (Swamp)&r! Di sana, kamu akan menemukan bukit aneh dengan pintu masuk di atasnya. Ini adalah &cMinoshroom Labyrinth&r!\\n\\nDi dalam, kamu akan melawan beberapa musuh baru yang bisa menjatuhkan &eMaze Map Focus&r. Ini dibutuhkan untuk membuat &eMaze Map&r.\\n\\nIni adalah peta spesial yang akan memetakan jalanmu di dalam &cMinoshroom Labyrinth&r. Minimap biasa tidak berguna di sini.\\n\\nKamu juga bisa menemukan beberapa ruang harta karun dengan loot spesial untuk Labirin!"]
	quest.4B95D48D7525FFAD.quest_subtitle: "Di mana Shrek?"
	quest.4B95D48D7525FFAD.title: "Ke Rawa! (&2Swamps&r)"
	quest.4B9C54DA5CB6D5C9.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_host.png width:100 height:150 align:center}"]
	quest.4B9C54DA5CB6D5C9.quest_subtitle: "Trail Ruins"
	quest.4B9C54DA5CB6D5C9.title: "Host Armor Trim"
	quest.4B9E9497E44D0096.quest_desc: ["Untuk bangun reactor, kamu perlu mulai dengan bikin &6Reactor Casing&r.\\n\\nIni bikin frame dan dinding reactor kamu, meskipun dindingnya bisa diganti dengan &9Reactor Glass&r kalau mau lihat ke dalam reactor.\\n\\nBuat referensi nanti, saat part bilang \"Basic\", artinya cuma bisa dipakai dengan part basic lain. Part Basic juga cuma bisa dipakai buat bangun reactor lebih kecil, karena ada batas ukuran tertentu. Ingat ini!"]
	quest.4B9E9497E44D0096.title: "Komponen Bangun Reactor"
	quest.4B9FF9E972B0E530.quest_desc: ["Semakin baik Energy Link atau Tunnel jelas semakin banyak OP yang bisa transfer, tapi juga kamu mungkin menyadari sesuatu yang hilang dengan Energy Link. Tidak bekerja antar Dimension! Untungnya yang lebih baik bisa, pastikan sisi lainnya di-chunkload."]
	quest.4B9FF9E972B0E530.title: "Quantum Energy Tunnel"
	quest.4BA2F4AC2A08C294.quest_desc: [
		"Apa itu? Hanya Multiblok tersulit dan termahal di &8&lImmersive Engineering&r. &c&lEkskavator&r! \\n\\nRaksasa besar ini akan secara otomatis mengumpulkan Bijih dan Blok dari Tanah. \\n\\nBarang yang diambil akan &6Dikeluarkan&r dari Port di Belakangnya. Jika tidak ada Inventaris di sebelahnya, akan mengeluarkan Barang. \\n\\nIni juga Mesin yang sangat &cEnergi&r lapar, perlu menggunakan Port Energi di Sisi Kirinya untuk memberinya makan!"
		"{@pagebreak}"
		"Letakkan &8Blok Baja&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator1.png width:100 height:100 align:center}"
		"Tambahkan 3 &8Perancah Baja&r di atas &8Blok Baja&r dan letakkan 2 &8Blok Baja&r di ujungnya."
		"{image:atm:textures/questpics/immersive/immersive_excavator2.png width:175 height:100 align:center}"
		"Setelah itu letakkan 3x3 &8Perancah Baja&r di atas &8Perancah&r sebelumnya, dan satu tambahan pada masing-masing &8Blok Baja&r. Kemudian, menggunakan &8Lembar Baja&r buat lingkaran dari &8Perancah&r, termasuk &eBlok Teknik Ringan&r dan &8Blok Radiator&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator3.png width:150 height:100 align:center}"
		"Di atas &8Perancah Baja&r tambahkan lebih banyak, dengan &8Blok Baja&r di tengah. Kemudian, pasang lebih banyak &8Blok Baja&r ke ujung itu. Di satu sisi akan menjadi 3 &eBlok Teknik Ringan&r dan yang lain akan menjadi 3 &7Blok Teknik Berat&r. Di atas &eBlok Teknik Ringan&r di lapisan terakhir, akan menjadi yang lain. Dan di atas &8Blok Radiator&r akan menjadi &4Blok Teknik Redstone&r. Di sebelahnya akan menjadi &7Blok Teknik Berat&r lain dan sisanya akan menjadi &8Lembar Baja&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator4.png width:150 height:100 align:center}"
		"Sekarang untuk bagian tengah kita akan mengulangi apa yang kita lakukan di bawah setengah, jadi sekarang hanya &8Perancah Baja&r. Di sisi di sebelahnya dengan &eBlok Teknik Ringan&r akan menjadi 3 lagi, sama dengan &eBlok Teknik Ringan&r acak di sisi lain. Di sebelah 3 &eBlok Teknik Ringan&r akan menjadi 2 &8Blok Radiator&r, dan yang lainnya adalah &8Lembar&r."
		"{image:atm:textures/questpics/immersive/immersive_excavator5.png width:150 height:100 align:center}"
		"Di atas &8Perancah Baja&r akan menjadi 1 &8Blok Baja&r diikuti oleh 3 &8Perancah&r dan &8Blok&r lainnya."
		"{image:atm:textures/questpics/immersive/immersive_excavator6.png width:150 height:100 align:center}"
		"Ceri terakhir di atas, &8Blok Baja&r!"
		"{image:atm:textures/questpics/immersive/immersive_excavator7.png width:150 height:100 align:center}"
		"Kemudian, Klik Kanan &7Blok Teknik Berat&r di belakang dengan &6Palu&r kita dan akan menjadi &c&lEkskavator&r yang perkasa!"
		"{image:atm:textures/questpics/immersive/immersive_excavator.png width:125 height:100 align:center}"
	]
	quest.4BA2F4AC2A08C294.title: "&l&cEkskavator"
	quest.4BAF44FCA0894DE8.quest_desc: ["Kayak &5&lIsotopic Centrifuge&r, &e&lSolar Neutron Activator&r cuma dipake buat 2 Recipe dan salah satunya pake &8Nuclear Waste&r! \\n\\n&5Mesin&r ini bakal ngambil Sinar &eMatahari&r lewat &eSolar Cell&r di atas. Terus bakal fokuskan Sinar itu jadi satu Beam dan makenya di &8Nuclear Waste&r. \\n\\nIni juga bikin dia gak kerja pas &9Malam&r... \\n\\nTiap 5mB &8Nuclear Waste&r bakal jadi 1mB &aPolonium&r. \\n\\nJadi lo butuh 5,000mB &2Fissile Fuel&r buat bikin 5,000mB &8Nuclear Waste&r."]
	quest.4BAF44FCA0894DE8.title: "Pake &eMatahari&r buat bikin &aPolonium"
	quest.4BBF987FEF639801.quest_desc: [
		"Paduan adalah kombinasi 2 Logam berbeda. \\n\\nLogam biasanya tidak cair pada suhu kamar jadi perlu melelehkannya sedikit (terima kasih Merkurius)! \\n\\nTambahkan 2 Logam ke slot atas, dan Bahan Bakar Tungku seperti &0Arang&r ke slot bawah. \\n\\nTunggu... &8Baja&r adalah Paduan!"
		"{@pagebreak}"
		"&6&lKiln Paduan&r adalah 2x2x2 &6Bata Kiln&r."
		"{image:atm:textures/questpics/immersive/immersive_alloy1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_alloy2.png width:100 height:100 align:center}"
		"Kemudian Klik Kanan Blok Kanan Atas dengan &6Palu Insinyur&r untuk membuatnya!"
		"{image:atm:textures/questpics/immersive/immersive_alloy.png width:100 height:100 align:center}"
	]
	quest.4BBF987FEF639801.title: "&l&6Kiln Paduan"
	quest.4BC27F16229BBF46.quest_desc: ["&l&6Storage Delight&r adalah tentang penyimpanan item tetapi membuatnya terlihat cantik. \\n\\nAda lusinan laci dengan desain dan warna yang berbeda. \\n\\nMemiliki kegunaan dan ruang yang sama dengan Barrel (Tong)."]
	quest.4BC27F16229BBF46.title: "&l&6Storage Delight&r"
	quest.4BC2D7FCDD792DBA.quest_desc: [
		"Karena item, blok, dan cairan &2&lMinecraft&r biasa saja tidak cukup. Begitu juga dengan tambahan Panas dan Energi. \\n\\nSisa hal lainnya di &5&lMekanism&r dipindahkan dengan Pressurized Tube. Gas adalah yang utama karena jika kamu menggunakan &5&lMekanism&r kamu akan menggunakan gas seperti Hidrogen dan Oksigen. \\nInfuse Type juga mirip, seperti Coal Infuse dan Redstone Infuse. Slurry digunakan dalam Pemrosesan Bijih. \\nDan Pigmen Pewarna adalah esensi dari Warna, item apa pun yang diwarnai bisa diubah dengan bagian &5&lMekanism&r ini."
		"{image:atm:textures/questpics/logistics/meka_tube.png width:200 height:50 align:center}"
	]
	quest.4BC2D7FCDD792DBA.quest_subtitle: "Gas+Lainnya"
	quest.4BD203AD481DDE8F.quest_desc: ["&4Meat Shredder&r dibuat dari &4Witherite&r, yang merupakan Drop dari &4&lThe Harbinger&r. \\n\\nKamu harus cari &4Ancient Factory&r yang ada jauh underground di &2&lOverworld&r. \\n\\nTerus kamu bakal nemuin &4&lHarbinger&r yang mati, buat nyalain kita harus kasih makan Nether Star! \\n\\nTerus, setelah boss fight yang susah dan lama, kamu bisa Craft &4Meat Shredder&r!"]
	quest.4BD203AD481DDE8F.title: "&4Meat Shredder"
	quest.4BE209D5DAF1F321.quest_desc: [
		"&bAureal&r adalah Slot pertama dan paling penting di &6&lForge&r. \\n\\nKamu bisa automasi dengan &bArcane Crystal Obelisk&r atau deposit &bAureal Bottle&f/&bPotion&r! \\n\\nKamu bisa temuin &bAureal Bottle&r di Chest di kebanyakan Structure, atau bisa craft dengan &bArcane Crystal Dust&r dan Potion of Regeneration II."
		"{image:atm:textures/questpics/forbidden/forbidden_aureal.png width:135 height:100 align:center}"
	]
	quest.4BE209D5DAF1F321.title: "&bAureal"
	quest.4BF0BB763BFFACF0.quest_desc: [
		"Sumber daya paling penting yang kamu butuhkan selanjutnya adalah &eFluix&f, yang digunakan di hampir semua perangkat AE2 dan menjadi dasar pembuatan kabel ME. "
		""
		"Kamu bisa memproduksinya secara masal dengan membuat &bFluix Crystal&r; lemparkan &eNether Quartz&f, &e&oCharged&r&e Certus Quartz&r, dan &eRedstone&f secara bersamaan ke dalam air. Ini akan memberimu &eFluix Crystal&r yang bisa diubah menjadi dust di Inscriber."
	]
	quest.4BF0BB763BFFACF0.title: "Fluix"
	quest.4BF5EB050EC14C80.quest_desc: ["&4The Watcher&r... yah, mereka mengawasi &4Ancient Factory&r. Mereka menyerang apa pun yang mereka lihat (pemain) dengan sinar laser dan bilah tajam jika sudah dekat. \\n\\nMereka punya 12 setengah &4HP&r, bisa terbang, dan lemah terhadap serangan EMP juga. \\n\\nSeperti &4The Prowler&r, mereka menjatuhkan Redstone dan Besi saat mati."]
	quest.4BF5EB050EC14C80.title: "&4The Watcher&r"
	quest.4C0302FF4F63B52E.quest_desc: [
		"Jika kamu ingin lebah ATM, butuh banyak usaha menangkap, mengawinkan, dan memberi makan."
		""
		"Bagian questline berikut akan menjelaskan lebah mana saja yang kamu butuhkan."
		""
		"Pastikan cek JEI dan buku &9Big Book of Bees&r untuk info lebih lengkap!"
	]
	quest.4C0BDD483CCB40C4.title: "&bDiamond Chest"
	quest.4C0D00B5305117A1.quest_desc: [
		"&3Sentry Turret&r dapat diletakkan di suatu tempat dan diatur untuk menyerang mob atau pemain saat berada dalam jangkauan. Ia hanya butuh Minigun Ammo."
		""
		"{image:pneumaticcraft:textures/patchouli/sentry_turret.png width:100 height:100 align:left fit:true}"
	]
	quest.4C0D00B5305117A1.quest_subtitle: "Dor Dor (Tanpa kamu)"
	quest.4C0EAB9F795686D0.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.4C0EAB9F795686D0.title: "&eAdvanced Deposit Upgrade"
	quest.4C1F13F5A0E273EF.title: "&6Komponen Penyimpanan 256k"
	quest.4C23D7E3DC8327C2.quest_desc: ["Buat bunuh Lunar Monstrosity kamu harus bakarin dia! \\n\\nKamu bisa pake Flint and Steel atau Saltpeter Matchbox. \\n\\nMenurut aku Matchbox lebih cocok!"]
	quest.4C23D7E3DC8327C2.title: "Bakarin!"
	quest.4C2A60FC1F1E0328.quest_desc: ["Menambahkan baterai energi ke dalam Tas."]
	quest.4C31649D721F76B5.quest_desc: ["&6Pemanen Mekanik&r akan otomatis memanen Tanaman yang sudah Matang, lalu Menanamnya kembali. \\n\\nTentu saja ia harus digerakkan oleh &aKontraption&r agar berfungsi. \\n\\nIa juga otomatis menaruh Tanaman yang dipanen ke Inventaris yang terhubung ke &aKontraption&r. Kalau tidak ada, Tanaman akan dijatuhkan ke tanah."]
	quest.4C31649D721F76B5.title: "&6Pemanen Mekanik"
	quest.4C366515E3CCB0B2.quest_desc: ["Meat melalui tube, enak."]
	quest.4C3B7BAEA653587B.quest_desc: ["Bisa ditemukan di dalam peti di Piramida Gurun (Desert Pyramid)."]
	quest.4C3B7BAEA653587B.quest_subtitle: "Peti Piramida Gurun"
	quest.4C41FD926F31180B.quest_desc: ["Untuk memindahkan &2Item&r dengan &c&lLaserIO&r, kamu butuh beberapa &2Item Card&r. \\n\\nAtur satu kartu ke mode Extract dan pasang pada sisi &cLaser Node&r tempat kamu ingin mengambil item. Lalu atur kartu lainnya ke mode Insert dan pasang pada sisi tujuan item ingin dikeluarkan. \\n\\nAda berbagai pengaturan yang bisa kamu ubah pada mode Extract jika ada banyak tempat untuk mengambil item. Round Robin akan membuatnya mengambil item secara berurutan, alih-alih dari inventaris terdekat dulu."]
	quest.4C41FD926F31180B.title: "&2Item Card"
	quest.4C47EB9D2CE26BC6.quest_subtitle: "Muncul dari Quartz Nest di dimensi Nether"
	quest.4C47EB9D2CE26BC6.title: "Crystalline Bee"
	quest.4C4C9ADAC6107F89.quest_desc: ["&eBlok Teknik Ringan&r adalah resep yang cukup mudah. \\n\\nPerlu 1 &6Batang Tembaga&r, yang tidak perlu dijelaskan, itu benar-benar fitur &2&lVanilla&r. \\n\\n4 &7Lembar Besi&r, yang hanya 4 &7Pelat Besi&r digabungkan satu sama lain! \\n\\nJuga perlu 4 &7Komponen Mekanik Besi&r, yang merupakan 4 &7Pelat Besi&r dan &6Batang Tembaga&r di Meja Crafting, atau 2 &7Pelat Besi&r dan &6Batang Tembaga&r di &6Meja Kerja Insinyur&r."]
	quest.4C4C9ADAC6107F89.title: "&eBlok Teknik Ringan"
	quest.4C54BD57CAB8A54B.quest_desc: [
		"Lendir Blazebloom adalah tingkat kedua dari lendir yang ditambahkan oleh JDT dan membutuhkan material Nether untuk kerajinan."
		""
		"Kerajinan yang Terbuka:"
		"- Blazegold"
		"- Bara Blaze"
	]
	quest.4C5CFA45D9B4F6D3.quest_desc: ["Jamur Indigo sepertinya sahabat karib dari Smogstem dan akan muncul terutama bersama mereka! "]
	quest.4C647369D976E67E.quest_desc: ["&c&lStaff&r ini punya 3 Mode: Beam, AOE, atau Big Explosion, masing-masing diganti lewat Shift Right Click! (Tenang semua menyebabkan Ledakan!) \\n\\nBeam bekerja seperti yang diceritakan, akan menembakkan Beam raksasa ke arah yang ditunjuk, memusnahkan setiap Block dan Mob di jalannya! \\n\\nAOE memanggil belasan circle di depan, masing-masing menembakkan Explosive blast ke arah yang dibidik. \\n\\nBig Explosion adalah Mode paling seru, cukup Tahan Right Click pada target... terus tahan. Butuh sedikit waktu, setelah semua garis selesai tumbuh. Lalu, lepaskan! \\n\\nBOOM! ledakan nuklir masif akan terjadi! Menghancurkan area raksasa, jadi jangan gunakan dekat base. Sebenarnya jangan gunakan Mode apapun dekat base..."]
	quest.4C647369D976E67E.title: "&c&lExplosive Mana Condensation"
	quest.4C77ABCD41383F32.quest_desc: ["&cKue Blaze&r bisa digunakan untuk membuat &cPembakar Blaze&r menjadi &bSuper Panas&r! Suhu yang belum pernah ada sebelumnya! \\n\\nTapi bagaimana cara memasaknya? \\n\\nPertama, kita perlu membuat &4Alas Kue Blaze&r. Untuk mendapatkannya, proses Telur, Gula, dan &4Tepung Bara&r dalam Pres Mekanik dan Wadah. \\n\\n&4Tepung Bara&r dibuat dengan Menghancurkan &4Netherrack&r melalui dua Roda Penghancur. \\n\\nKemudian, setelah punya &4Alas Kue Blaze&r, isi dengan &cLava&r dari &bCerat&r untuk membuat &cKue Blaze&r!"]
	quest.4C77ABCD41383F32.title: "&cKue Blaze"
	quest.4C7E006502E30C20.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.4C873491F6F0FFAF.quest_desc: [
		"Menggunakan &dSpiritfire&r, kita bisa mengubah beberapa material Overworld menjadi varian Otherworld. Kamu juga bisa menemukan beberapa material Otherworld dengan menggunakan efek &bThird Eye&r dan berpetualang. Kamu mungkin akan terkejut dengan apa yang kamu temukan. Untuk mempermudah, ada resep crafting material dasar dengan melemparkannya ke &dSpiritfire&r."
		""
		"&bAndesite&r berubah menjadi &3Otherstone&r, yang bisa digunakan untuk menyalakan &dSpiritfire&r permanen."
		""
		"&aOak Sapling&r berubah menjadi &9Oak Sapling&r tapi tidak sama. Saat tumbuh, pohon ini terlihat persis seperti pohon Oak biasa. Namun, di bawah efek &bThird Eye&r, kamu bisa memanen varian Otherworld-nya."
		""
		"Jika kamu kesulitan mengambil batang kayunya (jika berubah jadi Oak Log biasa meski pakai &bThird Eye&r), cobalah memanennya dari bagian atas."
		""
		"&eDiamond&r akan berubah menjadi &dSpirit Attuned Gem&r yang digunakan dalam beberapa resep yang kita butuhkan nanti."
	]
	quest.4C873491F6F0FFAF.title: "Konversi &dSpiritfire&r"
	quest.4C8C56F960D92E9D.quest_subtitle: "&f51 &cAttack Damage"
	quest.4CA17B0A80020B2F.quest_desc: ["&3Manometer&r digunakan untuk menampilkan informasi tambahan tentang sebuah mesin."]
	quest.4CA17B0A80020B2F.quest_subtitle: "Aku butuh info lebih!"
	quest.4CB488E5CF10F3A4.quest_desc: ["Cuma Generator paling kuat dan mahal dari &c&lGenerator Galore&r. \\n\\nKamu butuh &9Echo Shard&r, &bConduit&r, dan banyak banget Netherstar Generator!"]
	quest.4CC963F5AECF285A.quest_desc: ["Normalnya Router memindahkan 1 item setiap kali beraksi. Ini bisa digandakan dan ditumpuk dengan Stack Upgrade! \\n\\n1 Stack Upgrade memindahkan 2 item, 2 Stack jadi 4 item, dan 6 Stack bisa memindahkan 64 item sekaligus."]
	quest.4CCA1E2AAA9AB9D9.quest_desc: [
		"Kapan ini akan datang ke Mod?"
		"{image:atm:textures/questpics/iron_spells/spells_outfit_electromancer.png width:50 height:100 align:center}"
	]
	quest.4CCA1E2AAA9AB9D9.title: "&5Electromancer Outfit"
	quest.4CCEC13CC5A5772D.quest_desc: ["Ada 3 peliharaan dari mod &4&lCataclysm&r: &eModern Remnant&r, &5Baby Leviathan&r, dan &4Netherite Ministrosity&r! \\n\\n&eModern Remnant&r dan &4Netherite Ministrosity&r bisa dimasukkan ke dalam Ember (Bucket). \\n\\n&5Baby Leviathan&r akan membutuhkan Water Bucket."]
	quest.4CCEC13CC5A5772D.title: "Sini, pegang ini!"
	quest.4CD2ADD3601B8191.quest_desc: ["Mau Shield-mu kembali dan tidak hanya saat hampir mati? Lalu, kamu butuh Recovery Modules. Semakin banyak Module semakin cepat recovery."]
	quest.4CD2ADD3601B8191.title: "Wyvern Shield Recovery Module"
	quest.4CD83943865018EA.quest_desc: ["&9Exporter&r digunakan untuk mendorong item dari sistemmu ke dalam sebuah blok di luar jaringan.\\n\\nIni bisa digunakan untuk mengisi Furnace dengan bijih atau bahan bakar, memasukkan material ke peti tertentu, dll.\\n\\nKamu juga bisa memfilter item apa saja yang boleh dikeluarkan."]
	quest.4CD83943865018EA.quest_subtitle: "Mengekspor Item!"
	quest.4CD83943865018EA.title: "Exporter"
	quest.4CE571F942461909.quest_desc: [
		"Ritual Satchel memang bagus, tapi memakan waktu lama untuk menaruh semua bloknya. Sekarang karena kamu sudah bisa melakukan ritual &cSevira's Permenant Confinement&r, kamu bisa membuat Artisanal Ritual Satchel!"
		""
		"Artisanal Ritual Satchel berfungsi hampir identik dengan versi biasa, kecuali ia menaruh semua item ritual secara instan, dan punya kemampuan tambahan Klik Kanan pada Golden Bowl untuk menghapus semua Rune Kapur serta mengambil kembali semua item lain (Tengkorak, Lilin, dan Kristal) ke dalam tas."
		""
		"Tidak, tas ini tidak memulihkan durabilitas Kapur."
	]
	quest.4CE571F942461909.title: "Peralatan Profesi: Artisanal Ritual Satchel"
	quest.4CE6EB54B12EF6C5.quest_subtitle: "&f10 &cAttack Damage"
	quest.4CFE097D0A8683C8.quest_desc: ["&5Obsidian Skull&r adalah Helmet yang saat dipakai bisa lindungi kamu dari Fire/Lava damage! \\n\\nSeiring waktu akan wear down dimana kamu perlu repair dengan &5Obsidiansteel&r. \\n\\nItu juga cara craft-nya, Skeleton Skull dengan 8 &5Obsidiansteel&r."]
	quest.4CFE097D0A8683C8.title: "&5Obsidian Skull"
	quest.4D07B0A4A2E77CDA.quest_desc: ["Max Entities adalah jumlah maksimal mob yang bisa dimunculkan dan dibiarkan ada oleh satu spawner. Jika batasnya cuma 6 entitas dan sudah ada 6 mob, tidak akan ada lagi yang muncul sampai mereka mati atau dipindahkan. Setiap Ghast Tear akan menambah atau mengurangi batas ini sebanyak 2 entitas. Maksimal 16 entitas dan minimal 1."]
	quest.4D07B0A4A2E77CDA.title: "Max Entities"
	quest.4D0B50731FED3CEE.quest_desc: ["Buat dapet Cresant Spear kamu harus craft dari Item yang di-drop Lunar Monstrosity dan Tangled Hatred, atau di-drop dari Lunar Monstrosity. (Kamu harus bunuh dia pokoknya). \\n\\nKamu bisa pake Spear kayak Trident dan tinggal pukul Mob atau kamu bisa hold Right Click buat diterbangkan ke depan dengan dia. Kalau kamu kena Mob dengan serangan kedua, Mob di sekitar juga bakal kena damage."]
	quest.4D193D60A3CAF435.quest_desc: [
		"Ini adalah Generator yang kemungkinan besar akan digunakan, &2&lGenerator Diesel&r! \\n\\nAkan &9Memasukkan&r Bahan Bakar di sudut kiri bawah dan kanan &2&lGenerator Diesel&r. Bahan Bakarnya bisa: Minyak Creosote, Biodiesel, dan Biodiesel Cetana Tinggi. Itu berurutan dari terburuk ke terbaik! \\n\\n&2&lGenerator Diesel&r akan membakar Bahan Bakar dan menghasilkan &cEnergi&r yang bisa &6Dikeluarkan&r dari 3 konektor di depan."
		"{@pagebreak}"
		"Di belakang &2&lGenerator Diesel&r perlu 3 &8Blok Radiator&r. Tengahnya akan menjadi &bPipa Cairan&r dikelilingi oleh &8Perancah Baja&r. Dengan bagian depan memiliki &6Blok Generator&r dan 2 &bPipa Cairan&r di sebelahnya."
		"{image:atm:textures/questpics/immersive/immersive_diesel1.png width:100 height:150 align:center}"
		"Di atas 3 &8Blok Radiator&r akan menjadi 3 &8Blok Radiator&r lagi! Dan &6Blok Generator&r dan &bPipa Cairan&r di sebelahnya, akan memiliki 3 &6Blok Generator&r di atasnya. Sisanya akan diisi dengan &7Blok Teknik Berat&r dan satu &4Blok Teknik Redstone&r."
		"{image:atm:textures/questpics/immersive/immersive_diesel2.png width:100 height:100 align:center}"
		"Untuk menyelesaikan perlu 3 &8Blok Radiator&r lagi di atas yang lain, dan di sebelahnya akan membuat salib &7Blok Teknik Berat&r."
		"{image:atm:textures/questpics/immersive/immersive_diesel3.png width:100 height:100 align:center}"
		"Langkah terakhir adalah Klik Kanan &6Blok Generator&r tengah dan atas dengan &6Palu Insinyur&r!"
		"{image:atm:textures/questpics/immersive/immersive_diesel.png width:100 height:100 align:center}"
	]
	quest.4D193D60A3CAF435.title: "&2&lGenerator Diesel"
	quest.4D3379D38237F830.quest_desc: ["Selama memakai &bsepatu&r ini, kamu bisa melakukan mukjizat! Berjalan di atas &9Air&r! \\n\\nSebenarnya lari sih, kamu harus Sprinting biar bisa lari di atas &9Air&r. Kalau kamu berhenti lari, kamu bakal tenggelam."]
	quest.4D3379D38237F830.quest_subtitle: "Kaki"
	quest.4D3379D38237F830.title: "&bAqua-Dashers&r"
	quest.4D4152032F0410D2.quest_desc: ["Logic Programmer memungkinkan mengatur nilai variable. Bisa diatur ke item dan fluid untuk filtering, atau bahkan nilai. \\n\\nContoh sederhana: Pilih &bItem&r dari sisi kiri, masukkan item pilihan ke slot tengah GUI yang muncul, dan masukkan &bVariable Card&r di slot kanan bawah. Kalau kemudian memasukkan variable card itu di importer/exporter, hanya akan import/export block itu!"]
	quest.4D4152032F0410D2.quest_subtitle: "Jadi Advanced"
	quest.4D4AB60B3B1CD437.quest_desc: ["Dari sisik &2Naga&r, kamu bisa membuat beberapa armor.\\n\\nArmornya tidak terlalu kuat, tapi tampilannya cukup bagus."]
	quest.4D4AB60B3B1CD437.title: "Armor Sisik &2Naga"
	quest.4D4DE266A2A325B0.quest_desc: ["Redstone, Golem Steel, dan Oxidized Golem Steel adalah Item yang dipake buat nemuin Golem Forge. \\n\\nPegang salah satu (kemungkinan Redstone yang spawn di Starlight underground) di Offhand kamu dan pake Seeking Eye buat nemuin Golem Forge yang btw ada di underground!"]
	quest.4D4DE266A2A325B0.title: "Item Golem"
	quest.4D53D9BBD8279282.quest_desc: ["Lunar Tree bisa dari Pohon besar menjulang, sampai yang kecil banget. Mereka beradaptasi buat ngambil tempat sebanyak mungkin! (Itu yang jelasin Dense Forest). \\n\\nMereka ditanam kayak Sapling biasa dan bisa punya Lunar Berry spawn dari daun mereka!"]
	quest.4D562F5D72038083.quest_subtitle: "Alder + European Larch"
	quest.4D57A07592AED307.quest_desc: [
		"&3&lStalker&r adalah Boss yang bisa dipanggil dengan memecahkan Ancient Vases. \\n\\nDia punya 200 &4Hearts&r dan Boss Bar untuk melacak. Kita perlu membunuhnya untuk dapat &3Soul Crystals&r. \\n\\nDia sangat cepat dan memberikan banyak Damage kalau Mengenaimu. Untungnya dia Buta, seperti &9&lWarden&r. Tapi dia juga punya pendengaran luar biasa yang membuatnya mendengar segalanya di dekatnya. \\n\\nDia punya beberapa serangan, biasanya dia akan Memukulmu. Kadang dia mungkin melakukan serangan AOE dan bisa memanggil &3Sculk Leeches&r untuk menyerangmu! \\n\\nDia juga akan menyerang setiap Mob non-&3Sculk&r."
		"{image:atm:textures/questpics/deepndark/dnd_stalker.png width:100 height:200 align:center}"
	]
	quest.4D57A07592AED307.title: "&3&lStalker"
	quest.4D62C62B523C69EC.quest_desc: ["Generator menghasilkan FE menggunakan fuel yang bisa dibakar seperti Coal."]
	quest.4D62C62B523C69EC.quest_subtitle: "Menyediakan Energy!"
	quest.4D644A9829C240CB.quest_desc: ["Kamu suka perisai &b&lIgnis&r? Nah, kamu bisa membuat satu untuk dirimu sendiri dengan &bIgnitium&r. \\n\\n&bBulwark of the Flame&r bisa digunakan seperti Perisai biasa tapi punya efek spesial. \\n\\nSaat Menahan Klik Kanan dan Shift, melepasnya akan membuatmu menyeruduk apa pun di depanmu, seperti kambing gunung. \\n\\nApa pun yang tertabrak akan menerima Damage dan jika terbentur ke dinding akan terkena efek stun. \\n\\nSangat berguna untuk dimiliki!"]
	quest.4D644A9829C240CB.title: "&bBulwark of the Flame"
	quest.4D7B6842B9F53459.quest_desc: ["Effortless Ring kasih kamu speed boost dan step height!"]
	quest.4D7D4C718837BCA5.quest_desc: ["Bagian utama resep Miniature Nether Portal adalah &3Hellshelf of Masterful Sight&r. Biasanya dipake buat liat Enchantment apa yang bakal kamu dapetin tapi kita di sini buat &6&lATM Star&r bukan buat Enchantment. \\n\\nKamu cuma butuh enchant sampe &4Infused Hellshelf&r yang bisa kamu dapetin dari beberapa Shelf aja. Terus kamu harus craft dengannya buat upgrade lebih lagi! \\n\\nSetelah itu kamu bisa craft Miniature Nether Portal, yang enggak kamu gak bisa jalan lewat kamu terlalu besar!"]
	quest.4D8190E94851C546.quest_desc: ["&cKabel&r Aktif (&cKabel&r yang mentransportasi &cEnergi&r adalah &cKabel&r Aktif) akan melukai saat menggunakan &6&lSkyhook&r pada mereka. \\n\\nKecuali jika Mengisolasi Pegangan!"]
	quest.4D822D92492E1F53.quest_desc: ["&3Aptrgangr&r adalah mini-bos di dalam &3Frosted Prison&r. \\n\\nMereka punya 800 &4HP&r dan menyerangmu dengan Kapak raksasanya. \\n\\nMereka bisa mengayunkan kapak, atau menghantamkannya ke tanah di dekatmu. Saat melakukan itu, laser akan muncul melukai semua di jalurnya. Mereka juga punya serangan serudukan mirip dengan &eKobolediator&r! \\n\\nSaat mati mereka menjatuhkan Ingot dan Nugget Black Steel, serta Rotten Flesh dan Bone."]
	quest.4D822D92492E1F53.title: "&3Aptrgangr"
	quest.4D836B9D9E3B898F.quest_desc: [
		"&2Stoneborn&r adalah perpaduan sempurna antara Villager dan Iron Golem. \\n\\nKamu bisa barter dengan mereka dengan cara Klik Rikan. \\n\\nDan mereka akan melawan Mob Agresif (atau pemain yang memukul mereka)."
		"{image:atm:textures/questpics/undergarden/undergarden_stoneborn.png width:100 height:150 align:center}"
	]
	quest.4D836B9D9E3B898F.title: "&2Stoneborn&r"
	quest.4D8B82FBA0FFD49E.quest_subtitle: "Tingkat: &63"
	quest.4D8C9960BB675221.quest_desc: ["Namanya lucu!"]
	quest.4D98D2123BD5BFB3.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Menambang batang kayu yang berdekatan sekaligus, perlu dicatat akan meningkatkan waktu yang dibutuhkan untuk hancur saat menambang beberapa batang kayu."
	]
	quest.4DA0725E089D7C91.quest_desc: ["Temukan &cQ&6u&ee&2s&3t&9i&5n&cg &6R&ea&2m&r, karena ia memberikan kekayaan bagi mereka yang memberinya &cW&6o&el &2P&3e&9l&5a&cn&6g&ei&r (16 warna).\\n\\nPetunjuk: Ada Dispenser di atas kepalamu di reruntuhan tempat sang Ram berada. Mungkin itu berguna."]
	quest.4DA0725E089D7C91.quest_subtitle: "Misi?"
	quest.4DA0725E089D7C91.title: "&cR&6a&em&2i&3f&9i&5c&ca&6t&ei&2o&3n"
	quest.4DB5DD6E20619B4D.quest_desc: ["Dipakai untuk membuat mesin lebih baik."]
	quest.4DBC3B4D38CC6152.quest_desc: [
		"Crystallized Moth spawn jauh di bawah Crystallized Desert. \\n\\nMereka netral dan aku saranin jangan mukul mereka karena mereka ngasih damage banyak banget! \\n\\nMereka juga punya 10 Heart dan bisa drop Starlight Crystal atau Shivering Gel kalau mati."
		"{image:atm:textures/questpics/eternal/starlight_moth.png width:125 height:100 align:center}"
	]
	quest.4DBC3B4D38CC6152.title: "Crystallized Moth"
	quest.4DCEC4B97E24B6F1.quest_subtitle: "&f17 &cAttack Damage"
	quest.4DD66E31859EA593.quest_desc: ["&3Vibranium Armor&r tapi dengan buff untuk mantra &e&lIron's Spells&r!"]
	quest.4DD66E31859EA593.quest_subtitle: "32"
	quest.4DD66E31859EA593.title: "&3Vibranium Mage Outfit"
	quest.4DE1158931F84F22.quest_desc: [
		"Setelah punya Pickaxe tier Iron atau lebih baik, bisa menambang &cRedstone&r. "
		""
		"Redstone memulai perjalanan ke banyak mod teknis, seperti membuat power atau gadget keren. "
		""
		"Ini adalah resource yang akan sangat dibutuhkan!"
	]
	quest.4DE1158931F84F22.title: "&cRedstone&r"
	quest.4DF0D7B85065ADC9.quest_subtitle: "Tebas dan hancurkan!"
	quest.4DF0D7B85065ADC9.title: "Peralatan Profesi: Butcher's Knife"
	quest.4DF23FC932F5EB7D.quest_subtitle: "Tingkat: &b4"
	quest.4DF683461225690F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_iron.png width:100 height:150 align:center}"]
	quest.4DF683461225690F.title: "&7Besi&r"
	quest.4DF7E2149F4BD8CC.quest_desc: ["Buat masukin potion yang diinginkan, tinggal klik kanan dengan &2Primed Pendant&r di tangan buat buka inventory-nya."]
	quest.4DF7E2149F4BD8CC.quest_subtitle: "Memberikan Efek Potion"
	quest.4E014B495668A601.quest_desc: ["Sekarang kita punya &aExperience Holder&r collecting &aXP&r, kita bisa pipe &aXP Fluid&r ke &c&lAuto Forge&r!"]
	quest.4E014B495668A601.title: "&aXP Fluid&r"
	quest.4E03AE15BEF86178.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemindai Monster"
		"- Pengasap Otomatis"
		"- Membakar Luka"
		"- Teleporter Barang Jatuhan"
	]
	quest.4E09BBC0BAED3440.quest_subtitle: "Tingkat: &c5"
	quest.4E18E28BDF6B7983.quest_desc: ["&cFusion Reactor Port&r bakal ganti Reactor Glass di dalam &c&lFusion Reactor&r buat dipake. \\n\\nKita butuh beberapa &cPort&r. 2 (atau 1) buat &cDeuterium&r sama &aTritium&r (atau cuma &5D-T Fuel&r) buat Fuel. Kita juga butuh 1 buat Output &aEnergi&r. \\n\\nKalo lo mau pake &9Air&r buat dinginkan &c&lFusion Reactor&r, lo butuh 2 &cPort&r lagi. 1 buat Input &9Air&r dan 1 buat Output Steam. \\n\\nKayak Port lain, kita bisa pake &3Configurator&r buat set apakah &cPort&r Input atau Output!"]
	quest.4E18E28BDF6B7983.title: "&cFusion Reactor Port"
	quest.4E1E31EDD544EE10.quest_subtitle: "64,000mb"
	quest.4E27182763DA83DC.quest_desc: ["Versi upgrade dari Wyvern Chestplate."]
	quest.4E27182763DA83DC.title: "Draconic Chestplate"
	quest.4E28B67554CBDAB7.quest_desc: ["Pedang dengan damage tertinggi kedua di antara semua pedang. Yang pertama menghasilkan damage Infinite (tak terbatas), dan tidak ada yang bisa menandingi Infinite."]
	quest.4E28B67554CBDAB7.title: "&6Allthemodium &5Alloy &3Sword"
	quest.4E297778DCEEC963.quest_desc: ["Heatsink Lanjutan adalah satu-satunya Upgrade eksklusif &5&lRailgun&r. \\n\\nAkan membuat &5&lRailgun&r mengisi jauh lebih cepat!"]
	quest.4E2C589C7638390F.quest_desc: ["&3Cursed Bow&r bekerja mirip dengan Busur dengan mantra Multishot! \\n\\nDengan anak panah normal, ia akan menembakkan 3 sekaligus! Dengan anak panah spesial, ia hanya menembakkan 2. \\n\\nKira-kira apa bisa diberi mantra Multishot juga ya?"]
	quest.4E2C589C7638390F.title: "&3Cursed Bow"
	quest.4E3355FDCB65BB63.quest_desc: ["&aEvoker&r dikenal sebagai Miniboss Minecraft yang kuat dan mematikan. Jadi tentu saja &lIron&r menambahkan versi yang lebih kuat dan mematikan! Dan ya &eBook&r ini adalah drop langka dari keduanya! \\n\\nIni punya 10 Spell Slot tapi 3 terisi. &aFang Strike&r, &aFang Ward&r, dan &aVex Swarm&r semua datang dengan &eBook&r dan tidak bisa dipindahkan. \\n\\nJuga memberikan boost untuk &a&lEvocation&r!"]
	quest.4E3355FDCB65BB63.title: "&aGrimoire of Evokation"
	quest.4E3D548E5D8D7D26.quest_desc: [
		"Forgotten Fields adalah 'Plains' versi &2&lUndergarden&r. \\n\\nMereka tidak punya pohon, tapi punya banyak batu, bunga, dan mob! \\n\\nTapi mereka tidak memunculkan &7Forgotten&r, ya, maaf kalau mengecewakan."
		"{image:atm:textures/questpics/undergarden/undergarden_field.png width:200 height:100 align:center}"
	]
	quest.4E3D548E5D8D7D26.title: "Forgotten Fields"
	quest.4E4C8BCD45766F03.quest_desc: ["Drawer ini akan otomatis mengubah item di dalamnya ke bentuk yang dipadatkan (contoh: Ingot ke Blok)."]
	quest.4E4C8BCD45766F03.quest_subtitle: "Otomatis Memadatkan/Menguraikan"
	quest.4E5238F00CEED8B2.quest_desc: ["Smelt raw ore di awal memang perlu, tapi kehilangan extra resource!\\n\\nAda beberapa cara untuk menggandakan output per raw ore, tapi salah satu cara termudah adalah dengan membuat dan menggunakan &eOre Hammer&r.\\n\\nIni akan memecah 1 raw ore menjadi 2 ore dust, yang bisa di-smelt jadi ingot, efektif menggandakan output ingot!\\n\\nMau lebih banyak per raw ore? Lihat mod &5Occultism&r!"]
	quest.4E5238F00CEED8B2.title: "&eOre Doubling Dasar"
	quest.4E69C6ABFE467C25.quest_desc: ["&#65C2A6Alloy Smelter&r berasal dari mod &#3187C4Extended Industrialization&r. Alat ini menggabungkan tugas &#4C4BDEMixer&r dan &#954BDEFurnace&r menjadi satu, sehingga membuat pekerjaan jadi tidak terlalu membosankan."]
	quest.4E737C490DCC5D6C.quest_desc: [
		"&5Unobtainium Armor&r adalah set terbaik yang bisa kita dapat dari mod &6&lAllTheModium&r! Kita akan membutuhkannya untuk membuat armor yang jauh lebih hebat! \\n\\n&5Unobtainium Armor&r memberikan 40 Armor Point, 60 Armor Toughness, plus 100% Knockback Resistance. Kamu tidak akan terlempar ke mana-mana! \\n\\nSekarang, selain efek lain yang diberikan oleh armor sebelumnya, kita mendapatkan 90% &dMagic Damage Resistance&r (resistansi serangan sihir)."
		"{image:atm:textures/questpics/allthemodium/all_armor_uno.png width:100 height:175 align:center}"
	]
	quest.4E737C490DCC5D6C.title: "&5Unobtainium Armor"
	quest.4E7823C2FCEBE4DC.quest_desc: ["Cuma Bow biasa tapi pakai &aEnergi&r bukannya Durability."]
	quest.4E7823C2FCEBE4DC.title: "&3Electric Bow"
	quest.4E7990AEBCCC3C95.quest_subtitle: "Tingkat: &b4"
	quest.4E7B1B16C7CDA84C.quest_subtitle: "Sama seperti versi uap"
	quest.4E802144C6E40D43.quest_subtitle: "Ceylon Ebony + Cherry"
	quest.4E802144C6E40D43.title: "Purple Crepe Myrtle Sapling"
	quest.4E82E843737045D9.quest_desc: [""]
	quest.4E82E843737045D9.quest_subtitle: "&oEsensi makhluk terkuat."
	quest.4E82E843737045D9.title: "&d&lDragon Soul"
	quest.4E8860056D068610.quest_desc: ["Ini tidak bisa Dibuat, melainkan adalah Perdagangan terakhir dari Villager Machinist. \\n\\n&0Elektroda Grafit&r digunakan sebagai Bahan Bakar untuk &8&lArc Furnace&r (juga untuk Lampu Fluorescent). \\n\\nUntuk mendapatkannya perlu &9Cetak Biru&r khusus ini."]
	quest.4E8860056D068610.title: "&9Cetak Biru Elektroda Arc Furnace"
	quest.4E895C54651A3CB3.quest_desc: ["&8Tome&r adalah &7Buku&r... cuma versi yang lebih berguna! \\n\\nSetiap &8Tome&r dibuat dengan &7Buku&r biasa, Stick, &cBlaze Rod&f, dan &cPowder&r. \\n\\n&8Tome&r bisa diberi &5Enchant&r, seperti item lainnya, untuk mendapatkan &5Enchantment&r tertentu. \\n\\nAda juga &8Tome of Scrapping&r yang bisa digunakan di Anvil untuk mencopot &5Enchantment&r dari item."]
	quest.4E895C54651A3CB3.title: "&8&lTomes"
	quest.4E8A05C3BFA80540.quest_desc: ["Aspek terpenting dari AE2 adalah sistem penyimpanannya yang menggunakan &eStorage Cell&f digital. Cell ini dapat diakses melalui &eME Chest&r (untuk cell tunggal) atau &eME Drive&r (untuk banyak cell).\\n\\n&bME Chest&f menampung satu Cell, yang bisa dibaca dan ditulis dari terminal lain di jaringan yang sama. ME Chest itu sendiri juga menyediakan layar terminal di bagian atasnya.\\n\\n&bME Drive&f dapat menampung hingga 10 Storage Cell dalam satu blok dan hanya memakan satu channel ME. Namun, ia tidak menyediakan layar terminal sendiri, sehingga memerlukan terminal eksternal di tempat lain."]
	quest.4E8A05C3BFA80540.quest_subtitle: "Item Sebagai Sistem File"
	quest.4E8A05C3BFA80540.title: "Penyimpanan ME"
	quest.4E8C32CD6057A1AB.quest_desc: ["Buat bikin &c&lPhilosopher's Fuel&r kita dikasih pilihan mau pake &cBlaze Burner&r atau &aUranium Quad Fuel Rod&r. \\n\\nMana yang lebih gampang buat kamu Craft! \\n\\n(AKA &cBlaze Burner&r!)"]
	quest.4E8C32CD6057A1AB.title: "&cBlaze Burner&f atau &aUranium Quad Fuel Rod"
	quest.4E8ECD407C8EA2DC.quest_subtitle: "Mandarin + Pomelo"
	quest.4E9B35DCA018FD42.title: "Upgrade Alat"
	quest.4E9DDDBD8263D0E3.quest_desc: ["&7Sigil of Unnaming&r bekerja sesuai namanya. Saat kamu punya &eAffixed Item&r dengan nama yang sangat panjang dan aneh, kamu bisa menggabungkannya dengan &7Sigil&r ini di &8&lSmithing Table&r untuk menghapus sebagian besar namanya. \\n\\n(Hanya Material, Tipe Item, dan warna Rarity yang akan tersisa)."]
	quest.4E9DDDBD8263D0E3.title: "&7Sigil of Unnaming"
	quest.4EA2DB12E8F0068F.quest_desc: ["&l&aOh The Biomes We've Gone&r adalah kelanjutan dari &l&aOh The Biomes You'll Go&r.\\n\\nIa menambahkan banyak biome baru yang indah! Dengan tanaman baru, bebatuan, dan tentu saja pepohonan!"]
	quest.4EA2DB12E8F0068F.title: "Kayu &l&aOh The Biomes We've Gone&r"
	quest.4EAFE7B240AF0A4D.quest_desc: ["Tidak bisa menjangkau apa yang kamu butuhkan? Coba Ranging Up! \\n\\nDengan ini, semua aksi akan menjangkau lebih jauh. Vacuum punya radius ambil lebih luas. Energi menjangkau lebih jauh. Flinger melontar dengan lebih kuat!"]
	quest.4EB7245727EE1EF9.quest_subtitle: "Tingkat: &63"
	quest.4EBED8ABC8C863A4.title: "&aRank 3&r: Lebih Banyak Lagi &cDarah"
	quest.4ED01E04D55999D9.quest_subtitle: "Tuangkan Molten Uru ke atas Telur Spawn BeeBee"
	quest.4ED01E04D55999D9.title: "Uru Metal Bee"
	quest.4ED36AA3766E842B.quest_desc: ["Daripada bangun Turbine terkecil di titik ini, lebih baik bangun Turbine berdasarkan design &9Reactor&r kamu.\\n\\nBuat awal, kamu mau bangun Turbine yang bisa handle &9Vapor Production Rate&r reactor kamu. Untuk dapet power maksimal dari sana, perlu maintain 900RPM atau 1800RPM juga. Ini butuh banyak eksperimen dengan coil berbeda, # blade, dan ukuran keseluruhan Turbine!\\n\\nCatatan: Untuk lengkapin quest ini, kamu perlu bikin &dTask Screen&r ukuran apapun. Setelah ditaruh, kamu bisa klik kanan screen dan pilih quest ini sebagai requirement, lalu output power ke blok task screen untuk ngisi dan lengkapin quest."]
	quest.4ED36AA3766E842B.title: "&dTurbine"
	quest.4ED6B18DF7D51E13.quest_desc: [
		"&eCacing Maut&r adalah Monster kayak lintah yang menggali lewat Pasir di &eGurun&r. \\n\\nMereka punya 3 Warna: Putih, Cokelat, dan Merah. Semuanya punya penampilan yang sama. Mulut gede bergigi, dan Badan dengan Duri gelap di atasnya. Itu aja! Gak ada mata, hidung, telinga, atau apapun lainnya. \\n\\nMereka dateng dalam banyak ukuran berbeda, dari hampir seperempat Blok lebar, sampai 3x3 Blok lebar. Ukuran mereka bakal nentuin Health mereka juga, dari 50 &4Hearts &fsampe lebih dari 300 &4Hearts&r. Semuanya punya 4 &7Armor Points&r! \\n\\nSemua &eCacing Maut&r bakal gali di bawah &ePasir&r dan nyerbu kamu lewat situ pas kamu ketahuan. Mereka bakal keluar buat Gigit kamu! Kalo mereka lebih gede beberapa mungkin bahkan lompat keluar dari &ePasir&r dan jatuh ke kamu. Ini bakal lempar &ePasir&r kemana-mana kalo mereka cukup gede! \\n\\nLo harus tunggu mereka keluar dari &ePasir&r buat Nyerang mereka... atau Nyalain beberapa &4T&0N&4T&r deket mereka dan mereka bakal telen!"
		"{image:atm:textures/questpics/iceandfire/iaf_worm.png width:100 height:100 align:center}"
	]
	quest.4ED6B18DF7D51E13.title: "&eCacing Maut"
	quest.4EDD96EB60EF5814.quest_desc: ["Kalau kamu ragu apa upgrade ini sepadan, jawabannya iya.\\n\\n&e&l&oAdvanced Solar Generator&r bakal makan tempat lebih banyak dan mahal buat dibikin tapi bakal hasilkan &aEnergi&r jauh lebih banyak. \\n\\nCara kerjanya sama kayak &e&lSolar Generator&r biasa, pas &eSiang Hari&f dan butuh terpapar &bLangit&r langsung. \\n\\nIni bisa nampung 100kFE! \\n\\nKamu juga bisa pasang ini di atas &6&lThermal Evaporation Plant&r buat hasilkan &6Panas&r lebih."]
	quest.4EDD96EB60EF5814.quest_subtitle: "Hasilkan sekitar 480FE/t"
	quest.4EDD96EB60EF5814.title: "&l&e&oAdvanced Solar Generator"
	quest.4EE10B8E194F5CA9.quest_desc: ["&6&lCreate&r 1.21 kini hadir dengan Kereta yang sudah termasuk dalam Mod dasarnya. \\n\\nPertama, kamu butuh &5Logam Kokoh&r! \\n\\nHancurkan &5Obsidian&r untuk mendapatkan &5Debu Obsidian&r. Kemudian, gunakan &bCerat&r untuk menaruh &cLava&r ke &5Obsidian Hancur&r. \\n\\nSetelah itu, Pres dua kali dengan &6Pres Mekanik&r dan kamu akan mendapatkan &5Logam Kokoh&r. \\n\\n&5Logam Kokoh&r kemudian bisa diterapkan ke &eCasing Kuningan&r untuk membuat &5Casing Kereta&r."]
	quest.4EE10B8E194F5CA9.title: "&5&lKereta"
	quest.4EE482B9D61B5933.quest_desc: ["Tentu saja bijih &2Vanilla&r bukan batas akhir kita, ada jauh lebih banyak dan jauh lebih langka di versi Modded! "]
	quest.4EE482B9D61B5933.title: "Material Modded"
	quest.4EEAB467C722ECE7.quest_desc: ["Ini adalah pipa sederhana yang dapat ditingkatkan dengan Pipe Upgrade.\\n\\nUntuk 'menarik (extract)' daya dari sebuah blok, letakkan pipa di samping blok tersebut, dan pada sisi yang terhubung, shift+klik kanan dengan pipe wrench untuk mengatur pipa ke mode extract.\\n\\nMod &e&lPipez&r juga menawarkan cara untuk mentransfer item, gas, dan cairan juga! Atau kamu bisa membuat pipa All-In-One yang disebut &aUniversal Pipe&r.\\n\\nWrench dari mod lain juga bisa digunakan untuk &e&lPipez&r!"]
	quest.4EEAB467C722ECE7.title: "&9Pipez: &aEnergy Pipes"
	quest.4EF5DE3FBA2A7AE3.quest_desc: ["Mulai dari Inferium Essence, kamu bisa bikin batangan buat bikin &9Peralatan&r dan &9Armor&r Essence.\\n\\nPeralatan Essence bisa di-upgrade ke tingkat lebih tinggi, dan kayak Armor, mereka bisa di-&5Augment&r di &3Meja Tinkering&r."]
	quest.4EF5DE3FBA2A7AE3.title: "&aPeralatan Inferium"
	quest.4EFFE300EC781C3E.quest_desc: ["Module sangat penting untuk item DE kita. Sangat penting sampai tidak bekerja tanpa mereka! Kebanyakan Module dibuat dari Module Core atau Module sebelumnya. Pegang item dan tekan Shift dan C untuk membuka Menu Module. Di sana kamu akan melihat beberapa slot dan tombol! Slot adalah tempat Module akan masuk dan Grid adalah yang menentukan berapa banyak Module yang bisa masuk. Saat Module mengatakan 1x1 hanya akan mengambil 1 Slot, sementara yang mengatakan 2x2 akan mengambil 4 slot. Tombol paling bawah di kanan akan menunjukkan Module apa yang bisa diterapkan ke Item yang kamu pegang. Sisanya hanya mengubah tampilan GUI."]
	quest.4EFFE300EC781C3E.title: "Modules!"
	quest.4F03B152479C4AC0.quest_desc: ["&bStaff of Riches&r menggunakan aura untuk menyoroti semua wadah penyimpanan dalam radius 64 blok selama sekitar 1 menit.\\n\\nIni sangat berguna jika kamu mencari peti loot atau jika kamu lupa menaruh peti di suatu tempat di dalam tambang."]
	quest.4F03B152479C4AC0.title: "&bStaff of Riches"
	quest.4F0DD86CF6E5F1B5.quest_subtitle: "Tingkat: &b4"
	quest.4F137DB561F45306.title: "&2Armor Prudentium&r"
	quest.4F144E5F70932C7D.quest_desc: [
		"Struktur melayang lainnya! (Aku mulai melihat pola di sini). \\n\\nDi sini kamu akan menemukan banyak Loot di dalam Cocoon dan di bawah Glistering Honey Crystal. \\n\\nKamu juga akan menemukan banyak Phantom di sini, sesuai namanya! Mungkin kamu butuh sesuatu untuk mencegah damage jatuh..."
		"{image:atm:textures/questpics/bumblezone/bumble_phantasm.png width:200 height:100 align:center}"
	]
	quest.4F144E5F70932C7D.title: "Phantasm Aviary"
	quest.4F1FFC02F4EAA2E6.title: "Tingkat: &4Nitro"
	quest.4F35D04721DFC9FF.quest_desc: [
		"Jenis ritual pertama yang akan kita lakukan adalah &9Ritual Pemanggilan (Summoning)&r. Ritual ini digunakan untuk memanggil berbagai jenis Setan yang berguna untuk membantumu menghancurkan barang, membakar, dan banyak lagi seiring kamu naik ke tingkat ritual yang lebih tinggi."
		""
		"Untuk ritual pertama, kita ingin memanggil setan &aFoliot Crusher&r. Setan ini akan menghancurkan item untuk kita, sesuatu yang kita butuhkan untuk membuat beberapa Kapur tingkat tinggi!"
		""
		"Untuk memulai, gabungkan Unbound Book milikmu dengan &aDictionary of Spirits&r di meja crafting. Ini akan mengikat setan ke dalam Buku, yang kita butuhkan untuk ritual."
		""
		"Bicara soal Dictionary of Spirits, saatnya membukanya! Di sebelah kiri, klik tab &dPentacles&r dan klik &bAviar's Circle&r. Kamu mungkin harus membacanya sedikit demi sedikit untuk lanjut. Ada juga cara dengan mengklik \"Mark All As Read\" agar semuanya langsung terbuka."
		""
		"Inilah yang akan kita gunakan untuk memanggil teman baru kita. Di sisi kanan, kamu bisa klik ikon mata di pojok kiri bawah gambar untuk memunculkan garis luar (outline) ritual di duniamu. Ini sangat membantu!"
		""
		"Setelah kamu menyelesaikan struktur ritual multiblock tersebut, letakkan 4 (atau lebih untuk ritual masa depan) Sacrificial Bowl di mana saja dalam radius horizontal 8 blok dari pusat Golden Sacrificial Bowl dan taruh item yang diminta. Begitu kamu menaruh Bound Book di dalam Golden Sacrificial Bowl, ritual akan dimulai!"
		""
		"Inilah tampilan ritualnya nanti."
		""
		"{image:atm:textures/questpics/occultism/aviarcirclenew.png width:200 height:200 align:1}"
	]
	quest.4F35D04721DFC9FF.quest_subtitle: "Aviar's Circle"
	quest.4F35D04721DFC9FF.title: "&bRitual Pertama &dKita"
	quest.4F3B4990BE6C2A4A.quest_desc: [
		"&7Scintling&r adalah siput kecil tak berdosa yang ditemukan di mana-mana di &2&lUndergarden&r. \\n\\nMereka bertindak seperti Snow Golem karena meninggalkan jejak di mana pun mereka berjalan. Hanya saja jejak yang satu ini lebih lengket... \\n\\nSaat mati mereka menjatuhkan Scintling Goo, tapi kamu bisa mengambilnya dari jejak mereka, jadi kenapa harus membunuhnya!"
		"{image:atm:textures/questpics/undergarden/undergarden_scintling.png width:150 height:100 align:center}"
	]
	quest.4F3B4990BE6C2A4A.title: "&7Scintling&r"
	quest.4F4C1A349F953013.quest_subtitle: "Ditemukan di dimensi Undergarden"
	quest.4F4C1A349F953013.title: "Forgotten Bee"
	quest.4F5348D0C83C3B0D.quest_desc: ["&3Solar Cell&r digunakan untuk membuat Solar Compressor."]
	quest.4F5348D0C83C3B0D.quest_subtitle: "Sel milik Matahari"
	quest.4F5348D0C83C3B0D.title: "Solar Cell"
	quest.4F56BFE6E4716F6D.quest_desc: [
		"&8&lArc Furnace&r adalah Mesin besar dan membantu. Membuat sebagian besar Mesin lain tidak berguna! \\n\\nUntuk memulai, diperlukan &cEnergi&r Input dari outlet di Belakang &8&lArc Furnace&r. Kemudian memerlukan Bahan Bakar yang merupakan &0Elektroda Grafit&r. Ini hanya bisa ditempatkan ke GUI-nya, tidak bisa diotomatisasi. \\n\\nKemudian perlu &6Memasukkan&r &eBarang&r ke Port Atas, di dekat tempat &0Elektroda Grafit&r berada. Ketika diberi bahan bakar dan daya, akan meleleh, hampir semuanya. Dari &7Batang Besi&r ke &7Batang Besi&r, ke &bHelm Froststeel&r ke &bFroststeel&r, ke &eBeliung Emas&r ke &eEmas&r! \\n\\n&eBarang&r yang meleleh akan &6Dikeluarkan&r ke Belakang di bawah Outlet Daya. \\n\\nJuga bisa membuat Paduan dari Logam!"
		"{@pagebreak}"
		"Lapisan 1 dimulai dengan U yang terbuat dari &8Lembar Baja&r dengan tengahnya menjadi &7Blok Teknik Berat&r dan ujungnya menjadi &8Blok Baja&r. Sisanya akan menjadi &8Lembar Baja Setengah&r dengan &8Perancah Baja&r dan Kuali yang menyimpang."
		"{image:atm:textures/questpics/immersive/immersive_arc1.png width:100 height:100 align:center}"
		"Lapisan ke-2 dimulai dengan, di atas &7Blok Teknik Berat&r dan 2 Blok di sebelahnya akan menjadi &eBlok Teknik Ringan&r. Kemudian, sisi U akan menjadi &7Blok Teknik Berat&r. Dengan lebih banyak &8Blok Baja&r di atas yang sebelumnya. Juga perlu 2x3 &4Bata Blast yang Diperkuat&r di atas &8Setengah&r. Jangan lupa &4Blok Teknik Redstone&r di atas &8Perancah&r!"
		"{image:atm:textures/questpics/immersive/immersive_arc2.png width:100 height:100 align:center}"
		"Ke-3 memiliki lebih banyak &8Blok Baja&r, lebih banyak &eBlok Teknik Ringan&r, dan perpanjangan &4Bata Blast yang Diperkuat&r. Juga perlu 1 &8Lembar Baja&r di setiap sisi."
		"{image:atm:textures/questpics/immersive/immersive_arc3.png width:100 height:100 align:center}"
		"Ke-4 memerlukan &eBlok Teknik Ringan&r ditempatkan di tengah di atas yang lain. Di sebelahnya akan menjadi 2 &8Perancah Baja&r. Dan perlu menambahkan lebih banyak &4Bata Blast yang Diperkuat&r tetapi kali ini panjang Blok pendek!"
		"{image:atm:textures/questpics/immersive/immersive_arc4.png width:100 height:100 align:center}"
		"Lapisan ke-5 dan terakhir hanya 2 &8Perancah Baja&r lagi di atas yang lain. Kemudian, &eBlok Teknik Ringan&r di atas yang sebelumnya dan dalam garis di depannya."
		"{image:atm:textures/questpics/immersive/immersive_arc5.png width:100 height:100 align:center}"
		"Akhirnya Klik Kanan Kuali dengan &6Palu&r untuk menyelesaikannya!"
		"{image:atm:textures/questpics/immersive/immersive_arc.png width:100 height:100 align:center}"
	]
	quest.4F56BFE6E4716F6D.title: "&8&lArc Furnace"
	quest.4F5A2E2A5C7F4837.quest_desc: ["&aForgotten Ingot&r harus didapatkan melalui Catacomb; baik dengan menjarah peti atau membunuh &aForgotten Guardian&r. \\n\\nKamu juga butuh Smithing Template yang ditemukan di dalam peti-peti di Catacomb."]
	quest.4F5A2E2A5C7F4837.title: "&aForgotten&r"
	quest.4F66DF6B494BEFF3.quest_desc: ["Menggabungkan &8Raven Feather&r dengan &eTorchberries&r dan &6Glowstone&r akan memberimu &eMagic Map Focus&r."]
	quest.4F66DF6B494BEFF3.title: "&eMagic Map Focus"
	quest.4F6A9F1AEFD535F5.title: "Draconic Large Shield Capacity Module"
	quest.4F780343E3FFA43E.quest_subtitle: "Inilah Akhirnya"
	quest.4F7F0A5162D70082.quest_desc: ["Jangan bingung, ada &5Creative &aEnergy Cube&r yang versi penuh dan kosong. \\n\\n&aEmpty Cube&r (Kosong) fungsinya kayak tempat sampah energi, bakal menghapus semua energi yang masuk. \\n\\n&aFull Cube&r (Penuh) fungsinya buat penyimpanan energi tak terbatas. Tapi kamu butuh &aEmpty Energy Cube&r buat bikinnya... dan harganya mahal! \\n\\nDengan memberi daya (energizing) pada 4 &aEmpty Energy Cube&r bareng sebuah &6&lATM Star&r, kamu baru bisa dapet yang versi penuh."]
	quest.4F7F0A5162D70082.title: "&5&lCreative &aEnergy Cube"
	quest.4F7F8F4ED1CA0550.quest_desc: ["Campfire yang digunakan pada spawner akan membuat mob muncul dalam keadaan terbakar. Cocok banget buat dapet Steak matang."]
	quest.4F7F8F4ED1CA0550.title: "Membakar"
	quest.4F870252E9FB1A41.quest_desc: ["Reaktor dapat ditenagai oleh Fuel Rod (Batang Bahan Bakar). Ini adalah jenis yang paling dasar yang bisa kamu buat."]
	quest.4F9932477EDDCB8E.quest_desc: ["Pistol Portal Tingkat Lanjut adalah versi tingkat lanjut dari Pistol Portal yang membutuhkan tenaga dan cairan portal untuk beroperasi. Tidak seperti Pistol Portal, Pistol Portal Tingkat Lanjut memungkinkan pemain teleportasi antar lokasi yang sudah di-encode. Menggunakan \"V\" (tombol pintas default) menu yang digunakan untuk encode dan memilih tujuan teleportasi."]
	quest.4F9C8D90ACF563F5.quest_desc: ["Makasih &2&lMinecraft&r buat Update Aquatic, tapi Berenang masih bisa lambat banget. \\n\\nJadi kenapa gak dipercepat! Kayak Depth Strider! \\n\\nPake &9Hydrostatic Repulsor &7Unit&r lo bisa Jalan sama Berenang lebih cepet di &9Air&r."]
	quest.4F9C8D90ACF563F5.quest_subtitle: "Celana"
	quest.4F9C8D90ACF563F5.title: "&9Hydrostatic Repulsor &7Unit"
	quest.4F9D6109EEA5D26A.quest_desc: ["Menghancurkan &eGolden Leaves&r memiliki peluang tinggi untuk menjatuhkan &eGold Leaf&r, yang dibutuhkan untuk membuat &eGold Powder&r. "]
	quest.4F9D6109EEA5D26A.quest_subtitle: "Aura dengan Kunang-kunang"
	quest.4F9D6109EEA5D26A.title: "&eGolden Leaves"
	quest.4FA156C383C9C438.quest_desc: ["&eKoboleton&r adalah kerangka dino kecil yang melayani &e&lAncient Remnant&r. \\n\\nMereka hanya punya 12 setengah &4HP&r dan menyerangmu dengan Khopesh. \\n\\nMereka bisa menjatuhkan senjatanya, tulang, serta Ancient Metal Nugget."]
	quest.4FA156C383C9C438.quest_subtitle: "Dino Mini!"
	quest.4FA156C383C9C438.title: "&eKoboleton"
	quest.4FA5192164E4A427.quest_desc: ["Cairan tidak menumpuk (stack) seperti item, jadi upgrade-nya sedikit berbeda. Tetap memindahkan lebih banyak, tapi dengan hitungan yang berbeda."]
	quest.4FA6BEA4E646B742.quest_desc: ["Sebelum kita bisa mulai bangun reactor, kita perlu smelt Coal atau Charcoal untuk bikin &9Graphite Ingot&r.\\n\\nGraphite, ditambah Iron, adalah salah satu material utama saat bikin Reactor."]
	quest.4FA6BEA4E646B742.quest_subtitle: "Hardened Carbon"
	quest.4FA6BEA4E646B742.title: "Graphite untuk Casing"
	quest.4FA7774D89171BB3.quest_desc: ["Ingin peliharaan lain dari &4&lCataclysm&r? Remnant Skull adalah yang kamu butuhkan! \\n\\nIni adalah drop yang dijamin dari &eAncient Remnant&r dan saat digunakan akan memunculkan Modern Revenant. \\n\\nYang satu ini jauh lebih kecil dan ramah dibanding versi &eAncient&r. Kamu bisa menjinakkannya dengan memberi makan Sniffer Egg, lalu ia akan bertindak seperti anjing; menyerang apa pun yang menyerangmu. Ia punya 3 mode: ikuti, berkeliaran, dan diam. \\n\\nMereka punya 2700 &4HP&r dan kamu bisa memberi mereka &eKoboleton Bone&r untuk menyembuhkannya! \\n\\nSelamat menikmati dino barumu!"]
	quest.4FA7774D89171BB3.title: "Monster yang Tak Boleh Disebut Namanya Demi Kelancaran Game"
	quest.4FBAB3A0FBF8CE2F.quest_desc: [
		"Kenapa harus bingung mikirin apa yang dipindahkan kalau kamu bisa memindahkan semuanya sekaligus! &5Universal Pipez&r bahkan lebih tidak pandu bulu dibanding &cEnergy Pipez&r. Pipa ini bisa memindahkan &eItem&r, &bCairan&r, atau &cEnergi&r. "
		"{image:atm:textures/questpics/logistics/pipez_universal.png width:200 height:50 align:center}"
	]
	quest.4FBAB3A0FBF8CE2F.title: "&5Universal Pipez"
	quest.4FCC20D9F8F87B2F.quest_desc: ["&3Pneumatic Wrench&r digunakan untuk memindahkan atau menghancurkan mesin dan pipa milikmu."]
	quest.4FCC20D9F8F87B2F.quest_subtitle: "Lagi ngomongin alat!"
	quest.4FE7F45C72EF5DC1.quest_subtitle: "Iron + Sweat"
	quest.4FE7F45C72EF5DC1.title: "Nickel Bee"
	quest.50013DD7370F8EDB.title: "Chaotic Jump Module"
	quest.500BEAD94C97DF96.quest_desc: ["Bisa diletakkan di sarang atau centrifuge.\\n\\nSaat di sarang, mengurangi waktu lebah berada di dalam sebanyak 20%.\\n\\nSaat di Centrifuge, meningkatkan kecepatan pemrosesan sarang.\\n\\nEfeknya bisa ditumpuk (stack)."]
	quest.500BEAD94C97DF96.quest_subtitle: "Lebah secepat kilat"
	quest.50150380043F97F9.title: "Penerbangan Lebah"
	quest.501A0AEEC73C0790.quest_desc: ["&6Piglich&r adalah Boss yang ditambahin &6&lAllthemodium&r yang tinggal di Ancient Pyramid di &l&bThe Other&r. \\n\\nWaktu mati dia bakal drop 1 Heart-nya! Kamu butuh 9 dari mereka mati buat bikin Block... \\n\\nUntungnya ada cara buat farm mereka!"]
	quest.501A0AEEC73C0790.title: "&6Piglich Heart Block"
	quest.501C6B7580453410.quest_desc: ["&aFluidizer&r adalah multiblock yang bisa dikustomisasi dengan ukuran minimum 3x3x3. Sama kayak multiblock lain, frame perlu dibuat dari Casing, sementara sisi bisa dibuat dari Glass."]
	quest.501C6B7580453410.title: "Konstruksi Fluidizer"
	quest.5021D159A5EC2315.title: "Draconic Energy Module"
	quest.5030F1D96457202E.quest_subtitle: "European Larch + Spruce"
	quest.50326B1D6EE8FA0B.quest_desc: ["&cAkumulator&r adalah versi baterai &8&lIE&r. \\n\\nMenampung &cEnergi&r dengan &6LV&r menampung 100kFE, &eMV&r menampung 1MFE, dan &5HV&r menampung 4MFE! \\n\\nSecara default memiliki slot atas yang hanya memungkinkan &9Input&r, tetapi sisi mana pun bisa diubah dengan &6Palu Insinyur&r ke &9Input&r, &6Output&r, atau Tidak Ada."]
	quest.50326B1D6EE8FA0B.title: "&cAkumulator"
	quest.5034A9137E0F3D3D.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit."]
	quest.5040B3D29F238BC0.quest_desc: ["Lompat kelinci, lompat!\\n\\nDengan &dBunny Hoppers&r, kamu bisa lompat dua kali lebih tinggi dan dapet pengurangan damage jatuh jadi setengahnya! Nggak bikin kamu kebal damage jatuh sih, tapi seenggaknya lebih susah buat mati."]
	quest.5040B3D29F238BC0.quest_subtitle: "Kaki"
	quest.5040B3D29F238BC0.title: "&dBunny Hoppers&r"
	quest.50429F57480F44DA.quest_desc: ["&cThermal Springstone&r muncul di kolam air panas yang jarang ditemukan di dimensi &5&lEternal Starlight&r!"]
	quest.50429F57480F44DA.quest_subtitle: "16"
	quest.50429F57480F44DA.title: "&cThermal Springstone Armor"
	quest.504752A1C9EFED76.quest_subtitle: "Citron + Wild Cherry"
	quest.5054977BD5354561.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penebang Pohon"
		"- Penghancur Daun"
	]
	quest.505799C894C771B2.quest_desc: [
		"Beberapa &5Mesin&r dari &5&lMekanism&r bisa di-Upgrade kayak &9&lMetallurgic Infuser&r sama &d&lEnrichment Chamber&r. Beberapa gak bisa, mereka cuma bisa nerima &8Upgrade&r Card. \\nDev &6&lATM&r liat ini dan pengen Player daripada bikin 50 &9&lElectrolytic Separator&r mereka bisa bikin 1 Multiblock! \\n\\nBuat Craft Multiblock ini, kita butuh Multiblock sebelumnya. &c&lAutomatic Hepheastus Forge&r. \\n\\nPunya Quest sendiri di &aChapter 4&r: &dCreative&r. Cek di sana! \\n\\nSemua Multiblock pake Struktur yang sama cuma dengan Controller yang beda. Cek Halaman Selanjutnya buat liat Instruksi Bangunnya!"
		"{@pagebreak}"
		"Layer pertama paling rumit karena nampung semua &cMachine Casing&r. Berbagai &cMachine Casing&r bakal ada di tengah sedangkan &9Darkstone Stairs &fdan &9Block&r sama &6Gilded Chiseled Polished Darkstone&r ngelilingi mereka."
		"{image:atm:textures/questpics/mek/mek_multi_runic1.png width:150 height:100 align:center}"
		"Layer kedua nutup layer pertama dengan lebih banyak &9Darkstone Brick&r sama &9Stairs&r. Sekarang termasuk &9Darkstone Slab&r sama &7Rune Block&r juga!"
		"{image:atm:textures/questpics/mek/mek_multi_runic2.png width:150 height:100 align:center}"
		"Gak ada yang lebih gampang dari ini! Tinggal taro &9Darkstone Pillar&r di atas 4 &7Rune Block&r luar dan itu semua yang harus dilakuin!"
		"{image:atm:textures/questpics/mek/mek_multi_runic3.png width:150 height:100 align:center}"
		"Gue bener kan, gak jadi lebih gampang. Tetep sama gampangnya! Ulang step sebelumnya."
		"{image:atm:textures/questpics/mek/mek_multi_runic4.png width:150 height:100 align:center}"
		"Buat selesaiin, taro &bArcane Crystal Block&r di atas &9Darkstone Pillar&r dan &8Quantum Injector&r di atas &7Rune Block&r yang belom ditutup."
		"{image:atm:textures/questpics/mek/mek_multi_runic5.png width:150 height:100 align:center}"
		"&5&lMultiblock Machine&r kita butuh Hatch buat kerja! Buat tambahin mereka, ganti &9Darkstone Brick&r di layer pertama dengan Hatch."
	]
	quest.505799C894C771B2.title: "Upgraded, Un-Upgradable &5Machine"
	quest.5064D5F99E2C69C8.quest_desc: ["Versi peningkatan dari &9Imperium&r."]
	quest.5064D5F99E2C69C8.quest_subtitle: "29"
	quest.5064D5F99E2C69C8.title: "&4Supremium Armor"
	quest.50674FE3C6BE9990.quest_desc: [
		"Kayak Starlight Forest biasa cuma dengan jarak antar Pohon yang lebih sedikit!"
		"{image:atm:textures/questpics/eternal/starlight_dense.png width:200 height:100 align:center}"
	]
	quest.50674FE3C6BE9990.title: "Dense Starlight Forest"
	quest.506F20AF8E857559.quest_desc: ["Dinamo Kinetik adalah Generator yang menggunakan momentum untuk membuat Energi! \\n\\nUntuk mulai membuat Energi, diperlukan Kincir Air atau Kincir Angin terpasang di sisi dengan lubang besar yang menganga! \\n\\nDinamo Kinetik tidak memiliki penyimpanan Energi internal, melainkan menyediakan Energi ke Blok yang terhubung seperti Konektor atau Akumulator."]
	quest.506F20AF8E857559.title: "Energi dari benda bergerak!"
	quest.508A8366219175FE.quest_desc: ["Configuration Tool digunakan untuk mengunci Drawer agar ia mengingat item yang ada di dalamnya.\\n\\nIni sangat berguna jika kamu memasang sistem otomatisasi. Drawer yang dikunci tidak akan membiarkan item lain masuk menggantikan item yang sudah disetel!"]
	quest.50A286C268F38E09.quest_desc: ["Di halaman Quest ini, aku meluangkan banyak waktu memberi warna pada teks untuk membantu kamu memahami apa yang sedang dibahas. Tapi mungkin ini malah bikin bingung, jadi ini Legendanya! \\n\\n&5Ungu&r adalah Kereta atau Lokomotif (Elektrik, Uap, dan Cart yang tersambung). \\n&6Emas&r adalah Jalur dan Rel, termasuk rel khusus tapi bukan Track Kit. \\n&cMerah Muda&r adalah Track Kit. \\n&4Merah Tua&r adalah Crowbar. \\n&3Sian&r khusus untuk Steam Locomotive. \\n&eKuning&r khusus untuk Electric Locomotive. \\n&9Biru&r untuk Tunnel Bore. \\n&7Abu-abu&r untuk Minecart dan Cart khusus."]
	quest.50A286C268F38E09.title: "Legenda Warna"
	quest.50A32AC6EDBC5854.quest_desc: ["Makan cuma nasi doang mah bosen, bakal lebih enak kalau ada sampingannya! Contohnya (sebuah) &6Onion Ring&r!\\n\\nSaat memakai &6Onion Ring&r, apa pun yang kamu makan akan memberimu sedikit efek Haste."]
	quest.50A32AC6EDBC5854.quest_subtitle: "Tangan"
	quest.50A32AC6EDBC5854.title: "&6Onion Ring&r"
	quest.50B127137AA9E660.quest_desc: ["Akhirnya &6Copper&r (Tembaga) punya kegunaan nyata!"]
	quest.50B127137AA9E660.quest_subtitle: "13"
	quest.50B127137AA9E660.title: "&6Copper Armor"
	quest.50B62CF314648881.quest_desc: ["&c&lChemical Infuser Multiblock&r lakuin hal yang persis sama, cuma lebih banyak! Bakal gabungin 2 &cChemical&r yang beda jadi 1 yang baru! \\n\\nLo cuma butuh &bEnergi&r Input Hatch sama &cChemical&r Input dan Output Hatch, tapi lo pengen banyak Storage buat semua &cChemical&r. \\n\\n"]
	quest.50B62CF314648881.title: "&c&lChemical Infuser Multiblock"
	quest.50C9CB8FB16E453D.quest_desc: [
		"&bBurning Arena&r adalah Arena raksasa mirip Koloseum di dimensi Nether. \\nKamu akan tiba di lantai 1 yang damai tapi panas, di lantai 2 kamu akan menemukan &bIgnited Revenant&r yang harus kamu bunuh untuk &bBurning Ashes&r. \\n\\nYang kemudian bisa digunakan di lantai 3, pada Altar untuk memanggil &b&lIgnis&r! \\n\\nOh ya, jika kamu mencari loot, coba cek di atas lantai 3!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_arena.png width:200 height:100 align:center}"
	]
	quest.50C9CB8FB16E453D.title: "&bBurning Arena&r: Rumah sang &b&lIgnis&r"
	quest.50DBB87E53017E60.quest_desc: ["&bKatup Cairan&r bisa digunakan untuk menghentikan &bPipa&r dari mengalirkan &bCairan&r. \\n\\nBeri putaran, paling mudah dari &cGagang Katup&r, untuk menghentikan aliran &bCairan&r. \\n\\nPutar lagi untuk mengalirkan &bCairan&r kembali!"]
	quest.50DBB87E53017E60.title: "&bKatup Cairan"
	quest.50ED69AEEE808B24.quest_subtitle: "Berikan satu ember Liquid Lithium ke Water Bee"
	quest.50ED69AEEE808B24.title: "Lithium Bee"
	quest.50F1C4521D282C60.quest_desc: ["Bulwark adalah unit berat militan ini. \\n\\nMereka memiliki 12 Hati dengan 18 Poin Armor! \\n\\nSenjata mereka adalah &b&lChemthrower&r dengan &8&lPerisai Berlapis Berat&r di Tangan Kedua. \\n\\nJika entah bagaimana membunuh satu, akan mendapatkan &aEmerald&r dan Tas Shader Masterwork!"]
	quest.50F1C4521D282C60.title: "Bulwark"
	quest.50F23B2688D7E699.quest_desc: ["Dengan 1,000mB &dAntimatter&r diproses lewat &5&lChemical Crystallizer&r kita bisa bikin 1 &dAntimatter Pellet&r. \\n\\nItu artinya butuh 1,000,000mB &aPolonium&r atau 1MmB &aPolonium&r. \\n\\nBuat semua &aPolonium&r itu lo butuh 5,000,000mB &8Nuclear Waste&r dan &2Fissile Fuel&r buat bikin &8Nuclear Waste&r. Cuma 5MmB &2Fissile Fuel&r... cuma! \\n\\nTapi akhirnya, kita dapet! &eItem&r paling berharga di &5&lMekanism&r! &dAntimatter Pellet&r. \\n\\nSekarang kita bisa bikin MekaSuit, lebih banyak storage buat &e&lQIO&r, bahkan &6&lATM Star&r!"]
	quest.50F23B2688D7E699.title: "&dAntimatter Pellet"
	quest.50F97171D25CD2EE.quest_desc: ["&#6EDDFFTurbo Upgrade&r menambah kapasitas sebesar &#FFEB6E512 EU/t&r per upgrade."]
	quest.5103C817381181DE.quest_desc: ["Memungkinkanmu memakai Elytra meski sedang mengenakan Pneumatic Chestplate."]
	quest.5103C817381181DE.quest_subtitle: "Maks: 1"
	quest.511144EF336BFAF5.quest_desc: [
		"Smog Spire adalah... ya, kamu menebaknya! Dari sinilah semua kabut asap (smog) berasal! Yah tidak semua, kita tidak bisa melupakan peran &2Mog&r dan &3S'mog&r. \\n\\nDi sini kamu akan menemukan Blisterberry, Coarse Deepsoil, dan Smog Vent. Aku tidak menyarankan untuk mendekati mereka..."
		"{image:atm:textures/questpics/undergarden/undergarden_smogspires.png width:200 height:100 align:center}"
	]
	quest.511144EF336BFAF5.title: "Smog Spires"
	quest.511562EA5811306B.title: "Pancing Diamond"
	quest.51162B9185A45BB1.quest_desc: ["Busur ini bisa dipasangi mantra menggunakan Scribe's Table. \\n\\nDengan biaya mana, anak panah akan menjadi Spell Arrow dan akan memberikan efek mantra pada targetnya. \\n\\nJika kamu tidak punya anak panah, Spell Arrow yang dihasilkan akan memberikan 0 damage. Jika mana tidak cukup, anak panah biasa akan ditembakkan. \\n\\n&9Enchanter's Bow&r juga bisa menggunakan Augment Arrow khusus yang memperkuat mantra yang terpasang."]
	quest.51236544BFEF487B.quest_desc: ["Saatnya mencari &eMeteorit&f yang mengandung &bSky Stone&f. Meteorit ini bisa berada di permukaan atau di bawah tanah, dan memiliki &bMysterious Cube&f di tengahnya.\\n\\nKubus ini berisi berbagai &ePress&r yang digunakan di Inscriber untuk membuat komponen crafting spesial AE2.\\n\\nCara termudah menemukannya adalah dengan membuat &eMeteorite Compass&r dengan menaruh kompas di dalam Charger."]
	quest.51236544BFEF487B.quest_subtitle: "Berburu Meteorit"
	quest.51236544BFEF487B.title: "Meteorite Hunting"
	quest.512396B331108BAF.quest_subtitle: "Tingkat: &e5"
	quest.5128B119DFFF0C4C.quest_desc: [
		"&3Steam Locomotive&r adalah &5Lokomotif&r yang paling dasar. Ia ditenagai dengan air dan bahan bakar tungku. Ia butuh air terus-menerus agar tetap berjalan. \\n\\nJangan khawatir, asap yang keluar dari atasnya hanyalah uap air yang aman bagi lingkungan. Yah, bagian batubaranya sih kurang bagus buat lingkungan... tapi ini kan &2Minecraft&r, siapa peduli! "
		"{image:atm:textures/questpics/railcraft/rail_steam_locomotive.png width:100 height:100 align:center}"
	]
	quest.5128B119DFFF0C4C.title: "Lokomotif Uap (Steam)"
	quest.513060836057E5B7.quest_desc: [
		"&e&lPollinated Fields&r adalah... HATSYI... seperti biome Plains tapi penuh dengan &eSerbuk Sari (Pollen)&r! HATSYI... serbuk sari ini menumpuk seperti lapisan salju, ia... HATSYI... menumpuk di atas serbuk sari lain dan jatuh karena gravitasi... HATSYI. Ia akan memperlambatmu saat berjalan melewatinya, mirip seperti... HATSYI... salju bubuk (Powdered Snow).\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_pollenfields.png width:200 height:100 align:center}"
	]
	quest.513060836057E5B7.title: "&e&lLadang Serbuk Sari"
	quest.5134C81D96C55375.quest_desc: ["&5Observer Kereta&r bekerja seperti Rel Deteksi yang lebih canggih. \\n\\nKetika &5Kereta&r melintas di atasnya pada &7Rel&r yang sudah diatur (dipilih seperti &5Stasiun Kereta&r), ia akan memberikan &4Sinyal Redstone&r. \\n\\nKamu juga bisa memasukkan Filter ke dalam &5Observer&r agar hanya memberikan &4Sinyal Redstone&r ketika &5Kereta&r membawa &eItem&f atau &bCairan&r tertentu di dalamnya."]
	quest.5134C81D96C55375.title: "&5Observer Kereta"
	quest.5149BDF6BC4B3857.quest_desc: ["Atau, buat Durability Exchange dan lempar Item kuat (tapi tidak terlalu kuat) ke dalamnya. \\n\\nDisarankan Item seperti &5Netherite Shovel&r!"]
	quest.5149BDF6BC4B3857.title: "Durability Exchange"
	quest.5151CDD8FCDE7A07.quest_desc: ["Selamat datang di Peralatan Dasar!\\n\\nPernah mendapatkan alat yang belum pernah kamu lihat atau dengar dan ingin tahu di mana posisinya dibandingkan alat lain? Maka quest ini sangat cocok untukmu!\\n\\n(Pedang diurutkan berdasarkan base damage, pedang yang dapat di-upgrade atau digunakan untuk mendapatkan damage lebih tinggi tidak termasuk).\\n\\nQuest untuk semua beliung (pickaxe) dan pedang ini bersifat OPSIONAL!"]
	quest.5151CDD8FCDE7A07.quest_subtitle: "Semua Peralatan"
	quest.5151CDD8FCDE7A07.title: "Peralatan Dasar!"
	quest.51538F4DCE24E3E7.quest_desc: ["&5Multi&f-&2Piston&r adalah mesin kecil yang membingungkan tapi sangat membantu untuk memindahkan blok! \\n\\nKlik Kanan pada &2Piston&r untuk membuka GUI-nya. Di sana kita bisa mengatur Sisi (Side), Jarak (Spacing), dan Kecepatan (Speed). \\n\\nSisi ditentukan oleh warna piston: &eKuning&r adalah &eAtas&r, &6Oranye&r adalah &6Bawah&r, &9Biru&r adalah &9Utara&r, &2Hijau&r adalah &2Timur&r, &4Merah&r adalah &4Selatan&r, dan &5Ungu&r adalah &5Barat&r. \\n\\nKamu perlu mengatur warna Input (asal) dan Output (tujuan) blok yang ingin dipindahkan! \\n\\nSpacing adalah seberapa banyak blok yang ingin dipindahkan dari sisi tersebut. Jika diatur ke 3, ia akan memindahkan 3 blok. Jika 30, maka 30 blok akan berpindah. \\n\\nAlat ini membutuhkan &cSinyal Redstone&r untuk bekerja, dan beberapa blok seperti Peti (Chest) tidak bisa dipindahkan."]
	quest.51538F4DCE24E3E7.title: "&l&5Multi&f-&2Piston"
	quest.51592B271E56C6B2.quest_subtitle: "Tingkat: &a2"
	quest.515A60B89ED5440D.quest_desc: ["&7Stone Generator&r cuma buat &7&lDigital Miner&r. \\n\\nPas dipakai di sana, dia bakal otomatis bikin &7Stone&r, jadi nggak perlu dikasih manual. \\n\\nDia bakal pakai &7Stone&r ini buat gantiin Ore yang dia ambil!"]
	quest.515A60B89ED5440D.title: "&7Stone Generator &8Upgrade"
	quest.515C0527226BA50C.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memberikan terbang kreatif kepada pemain."
	]
	quest.5160D62F07A642A7.quest_subtitle: "Rowan + Beech"
	quest.516289A040EE9FDC.quest_subtitle: "Crystalline + Neon Cuckoo"
	quest.516289A040EE9FDC.title: "Menril Bee"
	quest.516AC1F0E0BCAE55.quest_desc: ["Frozen Tube di-drop dari Freeze di Golem Forge. \\n\\nBisa dilempar kayak Potion buat nyakitin siapa aja yang kena."]
	quest.516E66BE01EE5B31.quest_desc: ["&8Tome of Weaponry&r memberikan &5Enchantment&r untuk Sword dan Axe. \\n\\nTerutama enchant yang membantu untuk membunuh sesuatu! Seperti &5Sharpness &fdan &5Fire Aspect&r. \\n&8Tome of Archery&r memberikan &5Enchantment&r untuk senjata jarak jauh seperti Bow dan Crossbow. \\n\\n&5Piercing&f, &5Power&f, dan &5Knockback&r!"]
	quest.516E66BE01EE5B31.title: "&8Weapon Tomes"
	quest.516ECA0396621C32.quest_desc: [
		"Bagaimana kita tahu ini &aHijau&r? Rumputnya memang &ahijau&r tapi itu ada di setiap Sanctum. &aAzalea Bush&r dan &aGreen Luminescent Ancient Wax&r menunjukkan bahwa ini adalah yang &aHijau&r. \\n\\nIkuti hembusan angin dan saluran air basah ke ruangan utama untuk menemukan &aGreen Essence&r. \\n\\nMasuklah ke dalamnya dan pertarungan Bos melawan Rootmin akan dimulai. Berdirilah di platform seberang dan pukul balik butiran tanah yang ia lempar untuk mengurangi bar HP bos di bagian atas."
		"{image:atm:textures/questpics/bumblezone/bumble_green1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_green2.png width:200 height:100 align:center}"
	]
	quest.516ECA0396621C32.title: "&aGreen Sempiternal Sanctum"
	quest.517F0135926B15EE.quest_desc: ["Semua mesin sederhana dilengkapi dengan kontrol redstone, dan beberapa dilengkapi dengan penyaring."]
	quest.5180CDD196518F64.quest_desc: [
		"&6Strap Iron Track&r, seperti &6Abandoned Track&r, sangat cocok buat yang mau hemat. Jalur ini jauh lebih lambat dari &6rel&r lainnya tapi tidak ada risiko anjlok!"
		"{image:atm:textures/questpics/railcraft/rail_strap.png width:150 height:100 align:center}"
	]
	quest.5180CDD196518F64.title: "&6Rel Lempeng Besi (Strap Iron)"
	quest.5194A067BEA98E79.quest_desc: ["Hei, gue inget lo! \\n\\nTernyata, &5&lIsotopic Centrifuge&r dipake buat 2 Recipe. &2Fissile Fuel&r sama &3Plutonium&r! \\n\\nBuat tiap 5mB &8Nuclear Waste&r kita bisa bikin 1mB &3Plutonium&r. \\n\\nKalo tiap &3Plutonium Pellet&r senilai 1,000mB &3Plutonium&r, berarti kita butuh 5,000mB &8Nuclear Waste&r dan sama buat &2Fissile Fuel&r."]
	quest.5194A067BEA98E79.title: "Spinning buat &3Plutonium"
	quest.51A57E142C686C8F.quest_desc: ["Tingkat MEGA kelima dan terakhir dari komponen penyimpanan, menyediakan &e268.435.456&f (262144k) byte penyimpanan."]
	quest.51A57E142C686C8F.quest_subtitle: "x4^4"
	quest.51A57E142C686C8F.title: "Komponen Penyimpanan 256M"
	quest.51B24CC5E9332C1E.quest_desc: ["Kadang kalau kamu bunuh mob, &dVengeance Spirit&r bakal spawn.\\n\\n&dEssence&r mereka kayaknya berguna buat craft item lebih advance di EvilCraft.\\n\\nGak banyak nemuin Spirit? Bikin &9Vengeance Ring&r dan nyalain buat narik lebih banyak Spirit selama pertempuran kamu."]
	quest.51B24CC5E9332C1E.title: "Balas Dendam &dSpirit"
	quest.51BC981AB4CFAD95.quest_desc: ["Mazebreaker adalah beliung spesial yang jarang ditemukan di dalam Labirin.\\n\\nBeliung ini hanya akan menerima 1 damage saat menghancurkan Tembok Labirin (Maze Wall), bukannya 16 damage seperti beliung lainnya!"]
	quest.51BC981AB4CFAD95.quest_subtitle: "Ruang Terjebak, jangan masuk?"
	quest.51C59FDF0BD11FDF.quest_desc: ["Aku cukup yakin satu-satunya definisi dari Pohon Wigglewood adalah ia punya batang dan daun Wigglewood. Mereka tumbuh ke arah, ukuran, dan bentuk apa pun. \\n\\nKamu bisa menemukannya di Wigglewood Forest dan Dense Forest. \\n\\nPohon ini punya daun pink yang cantik dan batang cokelat mirip Spruce!"]
	quest.51CF09EC333DB1A3.quest_desc: ["Untuk Tier up di Fusion Crafting Draconic Evolution, Injector yang diperlukan untuk resep harus setidaknya Tier atau lebih tinggi. Seperti kalau kamu mau buat Wyvern Axe kamu butuh setidaknya 6 Wyvern Injector, dengan 3 di setiap sisi. Jangan khawatir Crafting Core tetap sama!"]
	quest.51CF09EC333DB1A3.title: "Tier Wyvern"
	quest.51DBE688ED630DB1.quest_subtitle: "Tingkat: &54"
	quest.51DE3157DE3E57B8.quest_desc: [
		"Penyimpanan memang bagus, tapi apa gunanya jika sistem penuh dengan bahan mentah yang masih harus diproses secara manual?"
		""
		"Otomatisasi crafting AE2 dimulai dengan &bME Pattern Provider&f. Alat ini menampung item yang disebut &bPattern&r yang diprogram untuk menyimpan resep. Hingga 9 pattern dapat dimasukkan ke dalam satu provider."
		""
		"Kamu akan sering menggunakan banyak Pattern Provider di markasmu, itulah sebabnya &bPattern Access Terminal&f sangat berguna untuk mengakses semua konten provider di jaringan ME kamu dari jarak jauh."
	]
	quest.51DE3157DE3E57B8.quest_subtitle: "Sesuai Pesanan"
	quest.51DE3157DE3E57B8.title: "Otomatisasi Crafting"
	quest.51E2728C5E35A152.quest_desc: ["Froststeel muncul di biome beku: Frostfields, Frosty Smogstem Forest, dan kemungkinan di Icy Sea. \\n\\nIa muncul di dalam Shiverstone yang menggantikan Depthrock di biome-biome ini. Shiverstone bersifat seperti es, licin dan membuatmu sedikit lambat. \\n\\nKamu mungkin juga menemukan beberapa Nugget di perut para Muncher!"]
	quest.51E2728C5E35A152.title: "&bFroststeel&r"
	quest.51E554305FFEBA1D.quest_desc: ["&4Blazing Hellshelf&r memberikan sedikit &cQuanta&r dan &aEterna&r, tapi ini bukan pilihan murah yang kita cari untuk &d&lInfusion&r kita!"]
	quest.51E554305FFEBA1D.title: "&4Blazing Hellshelf"
	quest.51E77B9CD3FB6DEA.quest_desc: ["Ini tidak wajib tetapi aku merasa ini sangat membantu. \\n\\nDigging Claws meningkatkan tingkatan (Tier) beliung pada tanganmu. Jadi kamu bisa menambang sampai Bijih Besi hanya dengan tinjumu! \\n\\nItu juga termasuk menambang hal-hal seperti Batu, Terracotta, dan Beton. Dan kamu bahkan bisa menambang itu dengan blok di tanganmu. \\n\\nSejujurnya, ini hampir seperti kebutuhan."]
	quest.51EA6B1452883AB2.quest_desc: ["Rangka Linear bekerja seperti Dempul di dunia nyata, hanya menempel sesama jenisnya. \\n\\nRangka Linear yang menghadap arah yang sama akan otomatis terhubung seolah sudah di-Glue. Rangka Linear lain atau yang menghadap arah berbeda tidak akan melekat. \\n\\nKamu kemudian bisa menggunakan Glue di bagian Atas dan Bawah Rangka Linear untuk menghubungkan sederetan Blok darinya. Jadi semua Blok di atasnya akan di-Glue ke Rangka Linear. Sangat menghemat Glue! \\n\\nDengan Kunci Inggris kamu bisa mengatur berapa banyak Blok yang di-Glue di Atas atau Bawah Rangka Linear."]
	quest.51EA6B1452883AB2.title: "&aRangka Linear"
	quest.520904C106D7D93D.quest_desc: ["Ini membuat &6&lSkyhook&r bertindak mirip dengan Gada, akan memberikan Kerusakan ekstra melukai Mob jika jatuh saat memukul mereka. \\n\\nDi Bioshock Infinite disebut Skystrike!"]
	quest.520904C106D7D93D.quest_subtitle: "Tekan LMB untuk Skystrike"
	quest.520EFA7F446AFBF2.quest_desc: ["&3Lubricant&r (Pelumas) dapat digunakan untuk membuat Drill Bit."]
	quest.520EFA7F446AFBF2.quest_subtitle: "Produksi Pelumas!"
	quest.520EFA7F446AFBF2.title: "Pelumas"
	quest.5210DC0095996B62.quest_subtitle: "Tingkat: &b4"
	quest.5212A4D67B1851EF.quest_desc: ["&7&lKeys&r seru ini, bertindak mirip Wolverine Claws, yang memang terlihat sangat mirip! \\n\\nSaat memegangnya Circle akan muncul di sekitar Target, gunakan Left Click untuk TP ke Target dan Pukul mereka! \\n\\nBisa digunakan untuk jarak yang sangat jauh! (Lebih dari seratus Block). \\n\\nDamage-nya sekitar sama dengan Iron Sword."]
	quest.5212A4D67B1851EF.title: "&7&lKeys of Proximity Projection"
	quest.521656D425E2FDBA.quest_desc: ["Jauh lebih cepat daripada Tingkat II."]
	quest.521656D425E2FDBA.quest_subtitle: "Maks: 1"
	quest.5218DAE147AC9F44.quest_desc: ["Tabung Bilah memungkinkan menampung lebih banyak &8Bilah&r atau &8Barang seperti Bilah&r di &2&lGergaji&r. \\n\\nUntuk beralih antara &8Bilah&r (atau &8Barang seperti Bilah&r) Tahan Shift dan Gulir. \\n\\nIni berguna untuk mengganti &8Bilah&r yang rusak atau bahkan beralih ke &8Disk Penggilingan&r!"]
	quest.5219D2F2B13F57F3.quest_desc: [
		"Salah satu, kalau bukan yang paling penting, item di &6&lBumblezone&r! Buzzing Briefcase adalah item sempurna untuk merawat &6L&8e&6b&8a&6h&r. \\n\\nKamu bisa Klik Kanan lebah dengan tas ini untuk menangkap mereka. Lalu, kamu bisa Shift+Klik Kanan tas ini untuk melihat isi &6L&8e&6b&8a&6h&r di dalamnya. \\n\\nDapat menampung 14 &6L&8e&6b&8a&6h&r, dan lebah apa pun termasuk dari mod &lProductive Bees&r. \\n\\nDi sini kamu bisa melihat HP, Nama, jenis lebah, apakah ia punya sengat, apakah ia membawa &ePollen&r, dan banyak lagi! \\n\\nKamu juga bisa menggunakannya untuk melepaskan para lebah tersebut."
		"{image:atm:textures/questpics/bumblezone/bumble_briefcase.png width:200 height:150 align:center}"
	]
	quest.521C9B00B1D87DEB.quest_subtitle: "Tingkat: &b4"
	quest.5233A447BAA4593C.quest_desc: ["&bME Smart Cable&f dan &bDense Smart Cable&f berfungsi sama dengan kabel covered dalam hal distribusi channel, tetapi juga menampilkan jumlah channel yang sedang digunakan berupa garis-garis berwarna pada kabel tersebut."]
	quest.5233A447BAA4593C.quest_subtitle: "Kabel Pintar"
	quest.5233A447BAA4593C.title: "Kabel Canggih"
	quest.523853C1C4E688BA.quest_desc: ["Tingkat keempat dari komponen penyimpanan, menyediakan &e65.536&f byte penyimpanan."]
	quest.523853C1C4E688BA.quest_subtitle: "x4^3"
	quest.523853C1C4E688BA.title: "Komponen Penyimpanan 64k"
	quest.523DC411241B470A.quest_desc: [
		"Semua &5Enchantment&r dari &5Enchantment Table&r ditentukan oleh level &aEterna&r, &cQuanta&r, dan &5Arcana&r. \\n\\nKita bisa melihat daftar &5Enchantment&r yang tersedia dengan mengklik tanda '?' di pojok kanan atas GUI &5Enchantment Table&r saat sebuah item diletakkan untuk di-&5Enchant&r. \\n\\nSemakin tinggi &cQuanta&r, semakin besar peluang mendapatkan &5Enchantment&r yang lebih lemah. \\n\\nDengan &6Geode-Encased Bookshelf of Stability&r, ia akan menghilangkan peningkatan peluang mendapatkan &5Enchantment&r buruk tersebut."
		"{@pagebreak}"
		"Untuk membuatnya, kita butuh satu &7Rak Buku&r, 7 Calcite, dan 1 &5Budding Amethyst&r. \\n\\n&5Budding Amethyst&r tidak bisa didapat dari menambang, bahkan dengan &5Silk Touch&r. Kamu butuh Ritual atau Infusion untuk mendapatkannya!"
	]
	quest.523DC411241B470A.title: "Penghilang Enchantment Negatif"
	quest.5244B2D6B5FA0487.quest_desc: [
		"Crystallized Desert keliatan kayak Gurun biasa tapi warna Ungu. \\n\\nJuga dengan tambahan kristal raksasa, aku gak pikir Gurun biasa punya itu..."
		"{image:atm:textures/questpics/eternal/starlight_desert.png width:200 height:100 align:center}"
	]
	quest.5244B2D6B5FA0487.title: "Crystallized Desert"
	quest.52472667678E10D1.quest_desc: ["&2Stellarite&r spawn antara Y Level 42 dan -44. \\n\\nKamu pikir, dengan radius segede itu akan gampang dicari! Ternyata gak, ini sangat langka! \\n\\nHati-hati saat Mining, saat dipecah akan MELEDAK!"]
	quest.52472667678E10D1.title: "&2Stellarite Piece"
	quest.525517F1625A9BCB.quest_desc: ["Apa mob jatuh terlalu keras dan &cDarah&r-nya kemana-mana? Oh tidak!\\n\\nKamu bisa pake &cSanguinary Pedestal&r buat nyerap &cDarah&r berharga itu buat dipake nanti!\\n\\nMau otomatis ngumpulin darah? Taro &9Spiked Plate&r di atas Pedestal, terus biarkan mob berdiri di atasnya."]
	quest.525517F1625A9BCB.title: "&aMengumpulkan &cNoda Darah"
	quest.525F25F4ADE45B50.quest_desc: [
		"&bME Formation Plane&f bertindak mirip dengan Storage Bus, tetapi memperlakukan dunia luar sebagai media penyimpanannya. Dengan kata lain, ia akan meletakkan blok apa pun yang ada di filternya tepat di depannya. "
		""
		"Ini berguna untuk situasi di mana blok bisa diproses hanya dengan meletakkannya dan menghancurkannya dengan alat tertentu."
	]
	quest.525F25F4ADE45B50.quest_subtitle: "Keluarkan ke Dunia"
	quest.525F25F4ADE45B50.title: "ME Formation Plane"
	quest.52672B7FFFD51D16.quest_desc: ["Menambahkan fungsi Stonecutter ke dalam Tas."]
	quest.526A9655A62C93F4.quest_subtitle: "European Larch + Bull Pine"
	quest.526CED9509FAA79B.quest_subtitle: "Blue Yonder + Firecracker"
	quest.529123A789D790E3.title: "Wyvern Jump Module"
	quest.52A29269A23F85B3.quest_desc: ["&9Yeti Outfit&r butuh Alpha Yeti Fur, yang seperti kamu tebak, cuma dijatuhkan oleh Alpha Yeti. \\n\\nSetidaknya outfit ini akan memperlambat musuhmu dengan efek mendinginkan (chilling)!"]
	quest.52A29269A23F85B3.quest_subtitle: "20"
	quest.52A29269A23F85B3.title: "&9Yeti Outfit"
	quest.52ACADDFCB0E22AB.title: "&aKomponen Penyimpanan 4096k"
	quest.52AFABA08674B6A8.quest_desc: ["&3Vibranium Armor&r tapi dengan buff untuk mantra &d&lArs Nouveau&r!"]
	quest.52AFABA08674B6A8.quest_subtitle: "32"
	quest.52AFABA08674B6A8.title: "&3Vibranium Arcanist Gear"
	quest.52B22C07818981D0.quest_subtitle: "Tuangkan Molten Constantan ke atas telur lebah Nickel/Copper"
	quest.52B22C07818981D0.title: "Constantan Bee"
	quest.52B2ADE472707372.quest_subtitle: "Golden Delicious Apple + Granny Smith Apple"
	quest.52B3955A80DB0B4A.quest_desc: ["&6Blasting&r gak mirip Enchantment &2&lVanilla&r, tapi lebih ke Modded! \\n\\nBegitu di-Install, kita bisa ngubah Config-nya buat ganti seberapa besar kotak Blok yang bisa ditambang. \\n\\nDefault adalah 1x1 alias 1 Blok. Kita bisa ganti jadi 3x3, 5x5, 7x7, sama 9x9. \\n\\nIya, Nambang kotak 9x9 bakal butuh lebih banyak &aEnergi&r daripada Nambang 1 Blok."]
	quest.52B3955A80DB0B4A.quest_subtitle: "Meka-Tool"
	quest.52B3955A80DB0B4A.title: "&6Blasting &7Unit"
	quest.52B61FB01D7C12A4.quest_desc: ["Versi peningkatan dari &aInferium&r."]
	quest.52B61FB01D7C12A4.quest_subtitle: "23"
	quest.52B61FB01D7C12A4.title: "&2Prudentium Armor"
	quest.52BB58D470560219.quest_subtitle: "Jangkauan: &c54&r Blok"
	quest.52BB58D470560219.title: "&6Awakened Supremium Pemacu Pertumbuhan"
	quest.52C301DF1776E0D8.title: "Chaotic Projectile Damage Module"
	quest.52C3F61D678B00F5.quest_desc: ["Chaotic Hoe, aku pernah pacaran sama salah satu beberapa waktu lalu."]
	quest.52C3F61D678B00F5.title: "Chaotic Hoe"
	quest.52C7FAA044E07628.quest_desc: ["Bayangkan Totem of Undying, tapi versi yang sangat kuat. Itulah &fEssence of Continuity&r. \\n\\nSaat kamu akan menerima serangan mematikan, kamu akan menteleportasikan dirimu ke titik Respawn dengan HP penuh, tingkat lapar penuh, dan efek buruk dihilangkan. Jelas menyelamatkan nyawamu. \\n\\nIa juga akan memberimu jurnal yang menjelaskan bagaimana dan di mana seharusnya kamu mati. \\n\\nSetelah menyelamatkan nyawamu, ia akan masuk masa tunggu selama 40 menit dan memberikan cooldown ke semua Essence lain yang kamu miliki. "]
	quest.52C7FAA044E07628.title: "&fEssence of Continuity"
	quest.52CD31F48715B17C.quest_desc: [
		"ME Wireless Connector bisa dipakai buat konek dua titik ME Network secara wireless, mirip Quantum Bridge. Beda sama Quantum Bridge, cuma bisa konek ke Wireless Connector sampai sekitar 1000 blok, dan gak bisa cross dimension."
		""
		"&lBuat setup koneksi, pakai Wireless Setup Kit di dua Wireless Connector yang mau dilink.&r"
		""
		"Kamu juga bisa ganti warna Wireless Connector dengan Color Applicator. Ini bikin dia gak konek ke kabel atau Wireless Connector warna lain."
	]
	quest.52CD31F48715B17C.title: "Koneksi Jarak Jauh: Wireless Connector"
	quest.52CDB46F6CBF007B.quest_subtitle: "Gali-gali terus"
	quest.52D3697F1F5625C7.quest_desc: ["&3Etching Acid&r dibuat di dalam Pressure Chamber menggunakan Molten Plastic... dan beberapa barang lain. Digunakan di Etching Tank."]
	quest.52D3697F1F5625C7.quest_subtitle: "Jangan tanya..."
	quest.52D4FCE72B15BC46.quest_desc: ["Pernah mau \"Bucket lebih bagus\"? Bisa dengan Edelwood Bucket! \\n\\nCuma butuh beberapa Edelwood Plank kamu bisa dapet Bucket lebih bagus, yang bisa tahan 4 Bucket Air atau Susu. \\n\\nKamu juga bisa tahan 3 Bucket Lava! Lebih berat jadi cuma bisa tahan 3 daripada 4."]
	quest.52E59FCB39D66BCF.quest_desc: ["Salah satu pilihan terbaik untuk \"Energi Pasif\", &9Thermal Generator&r akan menghasilkan FE saat diletakkan di atas &cSumber Panas&r dan diberikan suplai air yang stabil.\\n\\Saat ini ada 3 blok yang bisa digunakan sebagai alas: blok Magma (paling rendah), blok sumber Lava (sedikit lebih baik), atau &cBlock of Blazing Crystal&r yang memberikan panas paling tinggi. "]
	quest.52EA9793A7100E75.title: "Chaotic Undying Module"
	quest.52EC86E03EB50525.quest_desc: [
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
		"- Tidak Menginjak Tanaman"
		"- Panen Otomatis"
		"- Pertumbuhan Tanaman Dipercepat II"
	]
	quest.52F85CED20C8B1E9.quest_desc: ["&eEnergi&r harus dialirkan ke suatu tempat, lebih baik ke tempat yang kita mau. Alirkan energi sama seperti kamu mengalirkan &2Item&r, &9Cairan&r, dan &5Kimia (Chemical)&r!"]
	quest.52F85CED20C8B1E9.title: "&eEnergy Card"
	quest.5303509A1C2B1CCD.quest_desc: ["&3Pneumatic Jackhammer&r menggunakan tekanan udara untuk menambang, ia bisa di-upgrade agar menjadi luar biasa!"]
	quest.5303509A1C2B1CCD.quest_subtitle: "Maaf ya, Jack!"
	quest.5311404799117060.quest_subtitle: "Tingkat: &b4"
	quest.53154550397E9704.quest_desc: [
		"&c&lNetherite Monstrosity&r sangat sesuai dengan namanya, ia adalah monster dari &cNetherite&f dan &cLava&r. \\n\\nIa bisa memiliki hingga 48.000 &4HP&r namun biasanya saat pertama bertemu ia hanya di sekitar 9.500 &4HP&r. Ia akan meregenerasi HP saat tidak ada pemain di dekatnya.\\n\\nIa punya beberapa serangan jarak dekat seperti menghajarmu dengan lengannya yang masif dan hantaman tanah. Ia juga bisa melempar blok ke udara memicu Shockwave. \\n\\nJika kamu menjauh, ia mungkin menyeruduk atau melompat ke arahmu. Sejujurnya ia terlihat seperti berbobot 100 Ton, aku tidak mau tertimpa olehnya! \\n\\nSerangan terburuknya adalah serangan jarak jauh... ia bisa menembakkan &cMagma Ball&r padamu dan di tempat jatuhnya akan muncul &cLava&r. Ia juga bisa menembakkan &cFireball&r dari tangannya yang memicu semburan api dari tanah."
		"{image:atm:textures/questpics/cataclysm/cataclysm_monstrosity.png width:100 height:100 align:center}"
	]
	quest.53154550397E9704.title: "&c&lNetherite Monstrosity&r"
	quest.5316DF321B45D2CA.quest_desc: ["Selamat datang di &dOccultism&r!\\n\\nMod ini bertujuan untuk membantu pemain dalam banyak hal dengan meminta bantuan dari &bRoh&r &c&mSetan&r! Jangan khawatir, kebanyakan dari mereka ramah. &oKebanyakan&r.\\n\\nUntuk memulai, kamu butuh &aDemon's Fruit Seed&r (Biji Buah Setan)."]
	quest.5316DF321B45D2CA.title: "&dMemimpikan &cSetan"
	quest.532229D285CA4858.quest_desc: ["&9Importer&r adalah interface yang digunakan untuk menarik item dari blok yang terhubung.\\n\\nContohnya, kamu bisa memasang ini pada Furnace untuk menarik hasil pembakaran masuk ke sistem penyimpananmu.\\n\\nKamu juga bisa memfilter item apa saja yang ditarik."]
	quest.532229D285CA4858.quest_subtitle: "Mengimpor Item!"
	quest.532229D285CA4858.title: "Importer"
	quest.53292D808E8F5218.quest_subtitle: "Blackthorn + Luck"
	quest.532BCAB3FBF91B1D.quest_desc: [
		"&#44DB9CUpgrade&r menambahkan kemampuan bagi mesin untuk masuk ke status &#4467DBoverclocked&r, yang semakin meningkatkan kecepatan maksimal mesin."
		""
		"Sebuah mesin bisa menampung hingga satu stack upgrade tingkat mana pun. &#CEDB44Basic Upgrade&r menambah kapasitas &#F7F448+2EU/t&r per upgrade."
	]
	quest.532F3E6868A29037.quest_desc: ["Mirip upgrade Speed sebelumnya, tapi yang ini jauh lebih cepat! \\n\\nUpgrade ini bisa digunakan di mesin agar bekerja 40% lebih cepat! \\nEfeknya bisa ditumpuk, tapi TIDAK bisa digunakan di sarang lebah."]
	quest.532F3E6868A29037.quest_subtitle: "Lebih cepat dari Sonic"
	quest.532F3E6868A29037.title: "Ultra Speed Upgrade"
	quest.534D827A628907F4.quest_desc: [
		"Extended Pattern Access Terminal kerja sama kayak Pattern Access Terminal biasa, tapi dengan 3 fitur tambahan."
		""
		"&l&nPencarian Pattern Lebih Baik&r"
		""
		"Kamu bisa cari pattern berdasarkan nama ingredient input/output."
		""
		"&l&nHighlight Pattern&r"
		""
		"Kadang, karena cara pattern ditampilkan di grup, masih susah cari pattern yang dicari. Dengan terminal ini, pattern yang dicari akan di-highlight di GUI."
		""
		"&l&nHighlight Pattern Provider In-World&r"
		""
		"Nyebelin cari tahu Pattern Provider mana yang stuck waktu jalanin job crafting besar. Extended Pattern Access Terminal bisa highlight Pattern Provider di dunia, bikin lebih gampang nemuin."
	]
	quest.534D827A628907F4.title: "Akses Pattern Lebih Baik: Extended Pattern Access Terminal"
	quest.53518D4ED99A242F.quest_desc: ["&3Camouflage Applicator&r dapat digunakan untuk menyembunyikan mesin-mesin PneumaticCraft di dalam blok lain."]
	quest.53518D4ED99A242F.quest_subtitle: "Mau buat setup-mu terlihat keren?"
	quest.535525EA4DF4AB59.quest_desc: ["&cPlayer Transmitter&r bakal supply energy ke siapapun dengan Binded Card. Itu termasuk energy ke semua armor, tool, dan item di inventory mereka. \\n\\n&cNitro Tier&r dibutuhin buat &6&lStar&r, yang tentu aja yang terakhir dan paling susah didapetin."]
	quest.535525EA4DF4AB59.title: "&cNitro Player Transmitter"
	quest.53594EBA9F7BA840.quest_desc: ["Advanced Item Unloader sama seperti versi normalnya tetapi bisa digunakan dari arah mana pun."]
	quest.53594EBA9F7BA840.title: "Advanced Item Unloader"
	quest.5372264ED2D55143.quest_subtitle: "Tekan telur lebah Coal secara industrial"
	quest.5372264ED2D55143.title: "HOP Graphite Bee"
	quest.537B39B42C7D21ED.quest_desc: ["Di biome baru yang ditambahkan oleh &l&aOh The Biomes We've Gone&r, kamu bisa menemukan 4 tipe batu baru: Dacite, Red Rock, Mossy Stone, dan Rocky Stone. \\n\\nSekarang aku ingin tahu apa yang membedakan Rocky Stone dari batu lainnya sehingga ia layak menyandang gelar Berbatu (Rocky)."]
	quest.537B39B42C7D21ED.title: "Batu &l&aOh The Biomes We've Gone&r"
	quest.53829B3E51936ACD.quest_desc: ["Pegang &bDiamond Sword&r di off hand dan &7Scroll of Strengthening&r di main hand lalu tahan Right Click."]
	quest.53829B3E51936ACD.title: "Strong Sword"
	quest.538821E23E39BE97.quest_desc: ["&2Augment&r: Fuel Efficiency buat kalian semua yang cinta Bumi, peluk Pohon, fans Captain Planet, Hippies. Furnace consume setengah jumlah Fuel dengan cost setengah waktu. Coal ga akan Smelt 8 item tapi 16!"]
	quest.538821E23E39BE97.title: "&2Augment&r: Fuel Efficiency"
	quest.5391385A75535EC8.quest_desc: ["&2Nature Armor&r dari mod &e&lIron's Spells&r!"]
	quest.5391385A75535EC8.quest_subtitle: "20"
	quest.5391385A75535EC8.title: "&2Plagued Outfit"
	quest.539266A1C03C2EBA.quest_desc: [
		"Soul adalah Slot ke-2 yang diperlukan untuk &6&lForge&r, juga yang terkecil: cuma butuh 10 untuk isi! \\n\\nTiap Soul dan Corrupt Soul akan dihitung sebagai 1 Soul. Sementara Enchanted Soul dihitung sebagai 10 penuh!"
		"{image:atm:textures/questpics/forbidden/forbidden_souls.png width:135 height:100 align:center}"
	]
	quest.539266A1C03C2EBA.title: "Soul"
	quest.53A5F5E49EA8D5AF.quest_desc: [
		"Ini adalah contoh bagus menggunakan Modular Router untuk membuat Mob Farm yang rapi. (Tidak termasuk cara membunuh mobnya). \\n\\nContohnya kebun Wither Skeleton. \\n\\nPertama, ambil item ke Buffer dengan Vacuum Module. Kedua, buang pedang batu (Stone Sword) dengan Void Module. Agar tidak menghapus semuanya, gunakan Whitelist Filter berisi pedang batu. Setelah itu, kamu butuh tempat menaruh loot (aku sarankan sistem Drawer). Terakhir, gunakan Sender Module untuk mengirim loot ke penyimpanan. \\n\\nCuma itu yang kamu butuh!"
		"{image:atm:textures/questpics/router/router_mob.png width:200 height:65 align:center}"
	]
	quest.53A5F5E49EA8D5AF.title: "Router untuk Mob Farm"
	quest.53A79338994088FD.quest_desc: ["&dTri-Bow&r dijatuhkan oleh &3Snow Queen&r, ia bisa menembakkan 3 anak panah secara bersamaan meski hanya menggunakan 1 stok anak panah."]
	quest.53A79338994088FD.quest_subtitle: "Dari seekor Lynel?"
	quest.53A79338994088FD.title: "&dTri-Bow"
	quest.53B58FC3958750E7.quest_desc: ["Terlalu banyak main pakai Placer sampai perlu menghancurkan blok-blok itu? \\n\\nTingkatan dan mantranya ditentukan oleh Beliung yang dipakai saat crafting. \\n\\nAtur areanya, pasang Filter, dan jalankan! \\n\\nBisa digunakan bareng Placer untuk mengubah bijih menjadi item."]
	quest.53BA0C64804ADD24.quest_subtitle: "Pomelo + Wild Cherry"
	quest.53BDD0459F7B1D60.quest_subtitle: "Coffea + Teak"
	quest.53C167AF34694F8F.quest_desc: ["Mencampur &#40B36AYttrium&r, &#DBA146Annealed Copper&r, &#33CC3ANeodymium&r, dan &#D6D290Iridium&r Dust akan menghasilkan &#5EDEE0SuperConductor Dust&r. Ini dapat dibakar di dalam &#E3CE54Kanthal EBF&r lalu didinginkan di dalam &#4CBBD9Vacuum Freezer&r."]
	quest.53C167AF34694F8F.quest_subtitle: "Konduktivitas super"
	quest.53CA0D6B4D5A17D5.title: "&6Komponen Penyimpanan Cairan 16384B"
	quest.53CE66D760CEFD7E.quest_desc: ["Wastafel, toilet, dan bak mandi! \\n\\nSegala yang kamu butuhkan untuk tetap segar dan higienis! \\n\\nSemuanya bisa menampung air dan ya, kamu bisa duduk di toiletnya."]
	quest.53CE66D760CEFD7E.title: "Set Kamar Mandi"
	quest.53DEA3DFEDC4809E.quest_desc: [
		"Tenang, ini adalah yang terakhir dari seri ritual Abras. Ini digunakan untuk memanggil setan &9Marid&r, tapi meskipun menggunakan Red Chalk, kekuatannya tidak cukup untuk &9mengikat&r sang Setan. Artinya, sayangnya, kamu harus melawannya."
		""
		"Ritual ini menggunakan Trident sebagai tumbal, yang agak aneh karena biasanya tumbal adalah makhluk hidup. Jadi alih-alih membunuh mob di atas lingkaran ritual yang sudah jadi, kamu cukup melemparkan Trident ke arah bowl tengah untuk memulai ritual."
	]
	quest.53DEA3DFEDC4809E.quest_subtitle: "Apakah itu Burung? Pesawat? Bukan, itu adalah &9Marid&r liar!"
	quest.53DEA3DFEDC4809E.title: "&4Abras' Fortified Conjure"
	quest.53E2BEA626B35BFC.quest_desc: ["Resep cukup mahal tapi pasti worth it! \\n\\nPakai &6Spectral &4Eye&r akan kasih &4Spectral Vision Effect&r. Effect ini kasih &eGlowing&r ke setiap Mob dalam radius 100 Blok ke semua arah! \\n\\nSempurna untuk cari struktur underground, atau Bastion di &c&lNether&r, atau bahkan cari Axolotl farm tersembunyi temen kamu!"]
	quest.53E2BEA626B35BFC.quest_subtitle: "Sangat populer di ATM6!"
	quest.53E2BEA626B35BFC.title: "&6Spectral &4Eye &7Amulet"
	quest.53E5A8F2B05C2989.quest_subtitle: "Tingkat: &63"
	quest.53E929BF89209CFC.quest_desc: ["&eImporter &fdan &eExporter&r bisa dipake buat otomatis Import dan Export &eItem&r dari dan ke &e&lQIO System&r. \\n\\n&eImporter &fdan &eExporter&r ditaro di Blok dengan Inventory buat ambil atau kasih &eItem&r. Mereka juga harus diset ke Network yang sama dengan &e&lQIO Drive Array&r. \\n\\nKalo mereka diset buat Import atau Export tanpa Filter, mereka bakal otomatis ambil (atau keluar) semua &eItem&r di Inventory atau System yang berkaitan. \\n\\nKalo lo mau Filter, pake Itemstack, Tag, sama Mod. Masing-masing diset dengan taro &eItem&r ke Slot. Itemstack bakal pake cuma &eItem&r itu. Tag butuh Item Tag diketik di Text Box. Mod bakal pake Mod dari &eItem&r. Kayak &2&lMinecraft&r buat semua Blok &2&lVanilla&r."]
	quest.53E929BF89209CFC.title: "Import dan Export"
	quest.53EC96FA0E7C4ED4.quest_desc: [
		"Setiap mod teknologi butuh &cEnergi&r, entah itu FE, RF, atau yang lainnya! &cEnergy Pipez&r tidak pilih-pilih, energi akan mengalir saja! \\n\\nBeberapa mesin memiliki port IO yang ketat untuk &cEnergi&r, jadi pastikan untuk mengecek hal tersebut!"
		"{image:atm:textures/questpics/logistics/pipez_energy.png width:200 height:50 align:center}"
	]
	quest.53EC96FA0E7C4ED4.title: "&cEnergy Pipez"
	quest.53F861876B991C36.quest_desc: ["Menambahkan fungsi Jukebox ke dalam Tas."]
	quest.53F861876B991C36.quest_subtitle: "Ayo Berjoget"
	quest.53F9E5CE7EE6F852.quest_desc: ["Penangkap Makhluk memungkinkan transport monster. Monster bisa dilarang melalui tag entitas."]
	quest.53FDC6C536E50A1A.quest_desc: ["&bGwibling&r adalah ikan ramah yang ada di lautan. \\n\\nMereka lebih kecil dari &bGwib&r dan bertindak seperti ikan Vanilla!"]
	quest.53FDC6C536E50A1A.title: "&bGwibling&r"
	quest.540895E6C9E724AD.quest_desc: [
		"&6&lPilar&r itu seperti &6&lDinding Hive&r tapi versi lebih kecil. Sesimpel itu."
		"{image:atm:textures/questpics/bumblezone/bumble_hivepillar.png width:200 height:100 align:center}"
	]
	quest.540895E6C9E724AD.title: "&6&lPilar Hive"
	quest.540B857F043C24D5.quest_desc: ["Bioreactor menggunakan Biofuel yang dibuat dari Biofuel Generator untuk menghasilkan FE."]
	quest.540B857F043C24D5.title: "Bio Power"
	quest.541446863A72B96C.title: "&7Common&r Ink"
	quest.54169B69725C49DF.quest_desc: ["Teteskan Plastik Cair ke tanah atau simpan di dalam peti yang dipasang Heat Frame, maka jadilah &3Plastic Sheet&r (Lembaran Plastik)!"]
	quest.54169B69725C49DF.quest_subtitle: "Akhirnya!"
	quest.54169B69725C49DF.title: "&fPlastik"
	quest.541D270451DA4320.quest_desc: ["Switch Track dibutuhkan untuk berpindah jalur antar berbagai &6Rel&r khusus. Anak panah di atasnya menunjukkan arah perpindahannya."]
	quest.5424A0E1292B13EE.quest_desc: ["Di sekitar Starlight kamu mungkin nemuin Hot Pond. \\n\\n(Ini bukan biome atau struktur jadi kamu harus cari aja buat nemuin!) \\n\\nDi dalamnya kamu bisa nemuin Thermal Springstone."]
	quest.54255B7820A0F0B1.quest_desc: ["Bikin &2Fissile Fuel&r sama &bPolonium&r... itu doang. \\n\\nLo butuh &aEnergi&r Input, &cChemical&r Input, sama &cChemical&r Output. \\n\\nDari 10,240 &8Nuclear Waste&r jadi 2,048 &bPolonium&r. Plus 2,048 &aUranium Hexafluoride&r jadi 2,048 &2Fissile Fuel&r."]
	quest.54255B7820A0F0B1.title: "&l&5Isotopic Centrifuge Multiblock"
	quest.542AD6FD1927C3E6.title: "Draconic Undying Module"
	quest.542C6D76B579886C.quest_desc: ["Menggunakan struktur Enchanting Apparatus, kita akan membuat benih pertama kita, &5Magebloom Seed&r. \\n\\nBenih ini akan digunakan untuk membuat pakaian ajaib!"]
	quest.5436157FDFC9633E.quest_desc: ["Dengan Infused &dPatrick &aStar&r, 5 &6Star Fragment&r, &5Corrupti Dust&r, &cMundabitur Dust&r, dan Lens of the &4Killer&r, kita bisa membuat ulang &6&lATM Star&r secara otomatis 100%! \\n\\nSekarang, bikin item-item &5Creative&r lainnya bakal kerasa jauh lebih enteng!"]
	quest.5436157FDFC9633E.title: "Otomatisasi Penuh &6&lATM Star"
	quest.54378277B8D28B1D.quest_desc: [
		"Sebuah \"upgrade\" untuk Rainbow Chalk, bagi mereka yang tidak suka rune yang gonta-ganti warna secara cepat karena merusak estetika yang sudah dibangun dengan susah payah. "
		""
		"Fungsinya sama dengan Rainbow Chalk, bedanya semua rune akan muncul sebagai warna putih. Selain itu, ini juga berfungsi sebagai kapur fondasi."
	]
	quest.543F00603790AD3E.quest_desc: ["Log Stripper menguliti Batang Kayu (Log) secara otomatis menggunakan Kapak yang dimasukkan ke dalam mesin."]
	quest.543F00603790AD3E.quest_subtitle: "Tolong jangan lakukan itu"
	quest.543F00603790AD3E.title: "Pengulitan Kayu"
	quest.5443AA65C0D0C599.quest_desc: ["Item ini bisa kamu curi dari &5Ratu Lebah&r atau didapat dengan membantunya. Aku sarankan bersikaplah sopan kepada sang &5Ratu&r, dia adalah bangsawan! \\n\\nSaat kamu meminumnya, kamu akan mendapatkan banyak efek luar biasa serta menghilangkan beberapa efek buruk. \\n\\nIni juga bisa digunakan pada lebah dan Beehemoth untuk memberi mereka efek!"]
	quest.5443E15E226DFC86.quest_desc: ["Pylon adalah cara kamu memasukkan dan mengeluarkan OP dari Energy Core. Tempatkan setidaknya dekat Core, 2 di antaranya 1 untuk input dan 1 untuk output (kamu bisa pakai lebih). Lalu, tempatkan Glass di atasnya dan akan dirakit otomatis menargetkan Energy Core terdekat. Klik Kanan bola yang baru terbentuk di atas Pylon untuk mengubah apakah Input atau Output (kamu tahu dari panah dan desainnya). Lalu, kamu bisa pasang Crystal ke mereka untuk memindahkan OP masuk dan keluar!"]
	quest.5443E15E226DFC86.title: "Power masuk dan keluar melalui ini"
	quest.544791880F315D5A.quest_desc: ["Boat with Chest adalah perahu dengan peti di atasnya. Kamu bisa membuka peti saat berada di dalam perahu atau dengan klik kanan. Hanya satu orang yang bisa menaiki perahu ini dalam satu waktu."]
	quest.5466CB622A637DCD.quest_desc: ["Abyssal Fruit secara teknis bisa spawn di air manapun tapi satu-satunya yang hidup di Shimmer River. \\n\\nDia tumbuh kayak Kelp dari dasar ke atas, tapi juga kerja kayak Glowberry karena Buah tumbuh dan bisa diambil darinya."]
	quest.54735C5FCD2077B3.quest_desc: ["&aMystical Agriculture&r adalah mod generasi resource yang bikin kamu bisa nanem berbagai macam resource vanilla dan modded pakai &aBenih&r."]
	quest.54735C5FCD2077B3.title: "&aMystical Agriculture!"
	quest.54822638CC243004.quest_desc: ["Ikan buntal itu keren, begitu juga Guardian dan efek Thorns! Setiap damage yang diterima saat memakai &9Reflecting Necklace&r akan mengumpulkan poin. Setelah 5 detik dari damage terakhir atau saat poin penuh, &9Kalung&r ini akan menembakkan &5Obsidian Spike&r ke segala arah melukai semua yang ada di dekatnya."]
	quest.54822638CC243004.quest_subtitle: "Ditemukan di Ruined Portal, Nether Fortress, dan Bastion"
	quest.54822638CC243004.title: "&9Reflecting Necklace"
	quest.548274CC00E67EC4.quest_desc: ["Mentransfer listrik itu mudah, kamu tinggal memasang kabel di antara &#F5B027Generator&r dan &#3CC1FAMesin&r milikmu. Kabel LV dapat mentransfer maksimal &#EEFA3C256 EU/t&r."]
	quest.548274CC00E67EC4.quest_subtitle: "Batasan Kabel"
	quest.548274CC00E67EC4.title: "Kabel LV"
	quest.548F85EE6B6F1811.quest_desc: [
		"Sama seperti Piglin yang menyerupai &2&lApotheocarist&r, dia juga Netral. Dia tidak peduli tentang &eGold&r seperti sesama Piglin-nya, hanya orang yang menyerangnya. \\n\\nKamu bisa berdagang dengannya: memberinya Emerald atau Bahan Potion untuk Potion, Bahan Potion, dan &2Nature Scroll&r. \\n\\nJika kamu ingin membunuhnya dia punya 60 Heart. Dia akan menyerangmu dengan Potion dan &2Nature Spell&r. Saat terluka dia akan mencoba menyembuhkan dengan Potion, (Aku pikir dia sangat suka Potion). \\n\\nSaat dibunuh dia akan menjatuhkan Arcane Essence, Ink, &2Nature Rune&r, dan &2Nature Scroll&r!"
		"{image:atm:textures/questpics/iron_spells/spells_apotheocarist.png width:100 height:200 align:center}"
	]
	quest.548F85EE6B6F1811.title: "&2&lApothecarist"
	quest.54B1A876E9F6707A.quest_desc: [""]
	quest.54B1A876E9F6707A.quest_subtitle: "&oKekuatan dan kehancuran yang gak ada tandingannya!"
	quest.54B1A876E9F6707A.title: "&5&lOblivion Shard"
	quest.54BAF833344F0AAE.quest_desc: ["Yang ini 2 bagian! Pertama, kamu butuh &8Dark Tank&r. Resep simpel cuma butuh &8Dark Gem&r, Iron, dan Glass. \\n\\nSelanjutnya, kamu butuh &7Eclipse Ember Fuel&r. Itu gak gitu simpel... \\n\\nBuat dapetin kamu bisa mulai, drop &7Eclipse Ember&r ke &3Liquid Voidflame Fuel&r buat bikin &7Unrefined Eclipse Ember&r. Terus, kamu butuh &9Shadowpulse Goo&r buat spread ke itu buat bikin &7Eclipse Ember Fuel&r. \\n\\nBy the way kamu butuh 16 Bucket!"]
	quest.54BAF833344F0AAE.title: "&8Dark Tank&r penuh &7Eclipse Ember Fuel"
	quest.54C852CA6E056589.quest_subtitle: "Baterai Nuklir"
	quest.54CBCD9D2F1AD907.quest_subtitle: "Berikan sebuah blok Arcane Crystal ke Diamond Bee"
	quest.54CBCD9D2F1AD907.title: "Arcanus Bee"
	quest.54CE9493B63620C4.quest_desc: ["&#AC59EBDiesel Generator&r mengubah berbagai bahan bakar cair menjadi listrik. Yang paling mudah diakses untukmu di awal adalah &7Creosote Oil&r dan &8Synthetic Oil&r."]
	quest.54CE9493B63620C4.quest_subtitle: "Bahan Bakar Cair -> Listrik"
	quest.54D3D6806C1F33F3.quest_subtitle: "&f5 &cAttack Damage"
	quest.54D72C234EA76054.quest_subtitle: "Tingkat: &e1"
	quest.54D80939887B3F7D.quest_desc: ["Berdaganglah dengan &5Bee Queen&r sebanyak 128 kali! \\n\\nSemoga beruntung!"]
	quest.54DE8AAAE2181F18.quest_desc: ["Moonring Greatsword harus di-craft dari drop kedua Boss! Jelas bikin ini yang paling susah didapet dan paling kuat! \\n\\nKerjanya kayak Sword biasa, cuma sebelum 1.9. Bisa block serangan kayak shield, tapi gak bisa di-spam buat full damage."]
	quest.54E0B946BAC13654.quest_desc: [
		"Secara teknis &a&lEnergized Induction Matrix&r paling kecil (yang berfungsi) yang bisa kita bikin cuma punya 1 &aInduction Cell &fdan &aInduction Provider&r tapi semua dibuat dengan cara yang sama. \\n\\nKita perlu bikin frame dari &aInduction Casing&r minimal 3x4x3 sampe 18x18x18. \\n\\nDinding, Langit-langit, sama Lantai bisa diisi dengan &aInduction Casing&r, Structural/Reactor Glass, atau &aInduction Port&r. \\n\\nBagian dalam &a&lInduction Matrix&r bakal dibuat dari &aInduction Cell &fdan &aProvider&r. \\n\\nKalo kita pake ukuran 18x18x18, kita punya 4,096 Ruang buat taro &aCell &fdan &aProvider&r. Jadi kalo dibagi setengah antara keduanya kita bisa dapet... Storage 3.28QFE dan Input/Output 107GFE per Tick."
		"{@pagebreak}"
		"Multiblock ini bisa dibuat dengan ukuran apapun yang tersedia, gak cuma yang ditampilin di Gambar. Gambar cuma nunjukin ukuran paling kecil yang bisa dibuat."
		"{image:atm:textures/questpics/mek/mek_matrix1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_matrix2.png width:100 height:90 align:center}"
		"{image:atm:textures/questpics/mek/mek_matrix3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_matrix4.png width:100 height:110 align:center}"
	]
	quest.54E0B946BAC13654.title: "&a&lEnergized Induction Matrix"
	quest.54E4F00AD20D7096.quest_subtitle: "Tingkat: &b4"
	quest.54E6C0D1BB442184.quest_desc: ["Untuk mendapat &eSpell&r butuh Powdered Item. \\n\\nUntuk mendapat Powdered Item butuh &9Mortar and Pestle&r."]
	quest.54E6C0D1BB442184.title: "&9Mortar and Pestle"
	quest.54E7967B45B20F36.quest_subtitle: "Holly + Purple Crepe Myrtle"
	quest.54EC1C7FC1DA9107.quest_desc: ["&dChain Drive yang Dapat Disesuaikan&r bekerja seperti &dChain Drive Berselubung&r, tapi dengan konfigurasi lebih banyak. \\n\\nKalau kita kirim &4Sinyal Redstone&r ke &dChain Drive yang Dapat Disesuaikan&r tempat &8Poros&r asli terhubung, &8Poros Chain Drive&r lainnya akan berlipat dua kecepatannya! \\n\\nTapi kalau kita kirim sinyal ke &dChain Drive&r yang berbeda, Kecepatan &dChain Drive&r tersebut akan berkurang setengahnya!"]
	quest.54EC1C7FC1DA9107.title: "&dChain Drive yang Dapat Disesuaikan"
	quest.54F0C5C48CFC94D0.quest_desc: ["Dalam sistem Logistik, kita butuh penyaringan (Filtering). Ada dua jenis filter: List (Daftar) dan Attribute (Sifat). \\nList Filter digunakan dengan memasukkan item ke dalamnya dan mengatur apakah itu whitelist atau blacklist, serta apakah memperhitungkan data NBT atau tidak. \\n\\nAttribute Filter mengambil item contoh lalu menyaring berdasarkan Sifat yang dipilih. Ini termasuk tag dan hal lain seperti apakah item itu bisa digunakan sebagai bahan bakar tungku!"]
	quest.54F0C5C48CFC94D0.title: "Penyaringan"
	quest.54F2CB52D3A7BA87.quest_desc: ["Item Unloader adalah kebalikan dari Item Loader. Alat ini mengambil item dari &7Cart&r. Alat ini juga harus berada di atas &6Rel&r."]
	quest.54F2CB52D3A7BA87.title: "Item Unloader"
	quest.54F78C9A945CF0E7.title: "Chaotic Energy Module"
	quest.54F7AD64A403C9BF.quest_desc: ["Catalyst ini dapat ditambahkan di atas pilar &2Natural Altar&r milikmu. Alat ini memungkinkanmu mengubah lebih banyak item menjadi item lain atau mengurainya.\\n\\nCrumbling Catalyst memungkinkanmu mengubah setiap Gold Leaf menjadi 4 Gold Powder, bukannya 2! "]
	quest.54F7AD64A403C9BF.title: "Katalis (Catalysts)"
	quest.55160BAFFD9E2988.quest_desc: ["Mod &9Macaw&r yang sangat esensial, &9&lMacaw's Furniture&r! \\n\\nIa menambahkan segala yang kamu butuhkan! Kursi, meja, rak buku, bahkan laci!"]
	quest.55160BAFFD9E2988.title: "&l&9Macaw's Furniture&r"
	quest.55186B8602689B66.quest_desc: [
		"&bMemory Card&f memiliki dua fungsi. Pertama, menyimpan konfigurasi perangkat (seperti filter whitelist) untuk disalin ke perangkat lain yang sejenis. "
		""
		"Fungsi kedua adalah untuk menghubungkan &eP2P tunnel&f bersama-sama. Saat dilakukan, P2P tunnel yang dihubungkan akan diberikan ID unik yang disimpan di dalam memory card untuk sinkronisasi lebih lanjut."
	]
	quest.55186B8602689B66.title: "Memory Card"
	quest.551A4916F032ACCF.quest_desc: [
		"Arcane Anvil punya penggunaan paling banyak dari block mana pun di &lIron Spells&r. \\n\\nKamu bisa menggabungkan &3Spell&r dengan Ink yang sama untuk level up. \\nIni bisa menggabungkan &3Scroll&r ke Senjata untuk digunakan dengannya, seperti Pedang. \\n\\nKamu juga bisa set Affinity ke Ring menggunakan Upgrade Orb, atau menambah Upgrade Orb ke Senjata dan Gear."
		"{image:atm:textures/questpics/iron_spells/spells_anvil_gui.png width:100 height:100 align:center}"
	]
	quest.552335ED867D6EFA.quest_desc: [
		"Mantap buat smelting banyak item sekaligus!"
		""
		"Blok Batu Bara Insanium dibutuhin buat craft &6Bintang ATM&r."
	]
	quest.55278DDC31951DA5.quest_desc: ["Kurasa para &3Draugr&r benar-benar ingin menjaga &3Cursed Tombstone&r tetap aman karena mereka menguncinya! \\n\\n&3Door of Seal&r menghalangi kita untuk mencapainya. Kita butuh &3Strange Key&r untuk membukanya. \\n\\nSekali lagi, mereka benar-benar menjaganya karena kunci itu diberikan kepada &3Aptrgangr&r. Sosok paling tangguh di &3Frosted Prison&r yang masih hidup!"]
	quest.55278DDC31951DA5.quest_subtitle: "Membuka akses ke Maledictus"
	quest.55278DDC31951DA5.title: "&3Strange Key"
	quest.552BA5E6FA987256.quest_desc: ["&cSigil of Malice&r adalah sigil yang misterius. Tidak ada yang tahu cara men-craft-nya. Rumor beredar bahwa sigil ini dijatuhkan oleh &4Invader&r.\\n\\nFungsinya juga misteri, meski beberapa pemain menemukan bahwa mereka kehilangan satu affix dari gear yang dipasangi sigil ini, namun affix lainnya menjadi jauh lebih kuat. Affix mana yang dipilih untuk proses ini, sama seperti sigilnya sendiri, masih menjadi misteri."]
	quest.552CA2ABE659A507.quest_desc: ["&cLava&r masuk. Energi keluar."]
	quest.552CA2ABE659A507.title: "&cMagmatic Generator"
	quest.552F0B9B00F4F914.quest_desc: ["Quest ini ditulis oleh staf &6AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, kamu sedang dalam mode pengeditan."]
	quest.553220A2CD7CAFE4.quest_desc: ["Pas Natal semua Chest kelihatan kayak Hadiah... tapi Furnace aja yang menonjol! Sekarang bisa diubah pakai Wrapping Paper! Kamu bisa Right Click ke &lIron Furnace&r manapun dan bakal siap buat musim liburan! Dan setelah musimnya lewat kamu bisa Shift Right Click buat unwrap!"]
	quest.553220A2CD7CAFE4.quest_subtitle: "Dibungkus rapi"
	quest.553ADA7040B652CD.quest_desc: ["&4&lBor Pertambangan&r, &2&lGergaji&r, dan &b&lPelempar Kimia&r biasanya menampung 1.000mB atau 1 Ember &bCairan&r. \\n\\nBiasanya tidak berarti selalu! Dengan Tangki Besar sekarang bisa menampung 2.000mB atau 2 Ember. \\n\\nKedengarannya tidak banyak tetapi percaya itu banyak."]
	quest.553C44F85E508DE3.quest_desc: ["Yang satu ini unik karena tidak digunakan untuk 1 Router saja, tapi untuk banyak Router sekaligus. \\n\\nJika ingin banyak Router bekerja di waktu yang bersamaan (sinkron), masing-masing butuh Sync Upgrade. \\n\\nHarus diselaraskan di GUI-nya sendiri."]
	quest.554F47A0AF7506EC.quest_subtitle: "59,049 End Stone"
	quest.555ED1E39131D91B.quest_desc: [
		"Seharusnya tidak masuk ke &bMenara&r, &b&lCryomancer&r tidak suka Player, mereka Hostile padamu. \\n\\n&b&lCryomancer&r akan langsung mulai menyerangmu dengan &bIce Spell&r. Mungkin bahkan menggunakan hewan melawanmu! Mengorbankan hewan untuk memenangkan pertarungan, dia benar-benar berhati dingin! \\n\\nSetelah dibunuh dia akan menjatuhkan Arcane Essence, Ink, &bIce Rune&r, dan &bIce Scroll&r."
		"{image:atm:textures/questpics/iron_spells/spells_cryomancer.png width:100 height:200 align:center}"
	]
	quest.555ED1E39131D91B.title: "&b&lCryomancer"
	quest.5560F303C452E110.quest_desc: ["Extruder mendorong blok dan entitas, tapi kenapa tidak didorong lebih jauh lagi! \\n\\nEntitasnya ya, bukan bloknya."]
	quest.5563BD4934297522.quest_desc: ["Setelah punya Diamond Bee, kawinkan dengan Slimy Bee untuk membuat Emerald Bee!"]
	quest.5563BD4934297522.quest_subtitle: "Diamond Bee + Slimy Bee"
	quest.5563BD4934297522.title: "Emerald Bee"
	quest.55702BE0151D33FE.quest_desc: ["&aInduction Port&r adalah cara kita masukin dan keluarin &aEnergi&r dari &a&lEnergized Induction Matrix&r. \\n\\nKayak di hampir semua Multiblock, lo perlu taro &aPort&r di dalam Dinding &a&lInduction Matrix&r. \\n\\nGue gak yakin &aPort&r punya limit selain yang dimiliki &a&lInduction Matrix&r, jadi lo gak butuh lebih dari 2 kecuali lo ambil dari sumber yang beda!"]
	quest.55702BE0151D33FE.title: "&aInduction Port"
	quest.5577F49A93ADB19C.quest_desc: ["&lProductive Trees&r adalah mod saudara dari &lProductive Bees&r.\\n\\nUntuk mendapatkan berbagai jenis pohon, kamu membutuhkan Daun yang Terpolinasi (Pollinated Leaves). Untuk mendapatkannya, kamu butuh Serbuk Sari (Pollen). Untuk serbuk sari, kamu butuh Lebah.\\n\\nLebah yang mengambil sari bunga di dekat pohon akan otomatis melakukan polinasi pada daun, atau kamu bisa menggunakan Pollen Sieve Upgrade di dalam sarang (Hive) untuk mendapatkan dan menggunakan serbuk sari sendiri! Ini, satu buat kamu gratis!"]
	quest.5577F49A93ADB19C.title: "Productive Trees"
	quest.55820773BDD5319D.quest_desc: ["&bIndustrial Foregoing&r (IF singkatannya) adalah mod tech yang menambahkan banyak mesin dengan berbagai kegunaan berbeda.\\n\\nUntuk memulai, craft &aPity Machine Frame&r."]
	quest.55820773BDD5319D.quest_subtitle: "Tier: &a1"
	quest.55820773BDD5319D.title: "Industrial Foregoing"
	quest.5585130028BB8298.quest_desc: ["Senjata paling dasar yang bisa ditemukan di &6&lATM10&r, &d&lRevolver&r! \\n\\nShift Klik Kanan untuk membuka &d&lRevolver&r, lalu pindahkan beberapa Ammo ke Slot. Setelah itu, Klik Kanan untuk menembak! \\n\\nBisa menerapkan 2 Upgrade padanya. Upgradenya adalah: Bayonet, Speedloader, Majalah Diperpanjang, Tabung Elektron Amplifier, dan Scope Presisi. \\n\\n&d&lRevolver&r hanya bisa menampung 2 Upgrade tetapi Speedloader secara teknis berbeda."]
	quest.5585130028BB8298.quest_subtitle: "Apakah merasa beruntung, Punk?"
	quest.5585130028BB8298.title: "&d&lRevolver"
	quest.55882C10292B6A3D.quest_subtitle: "Berikan sebuah blok Prosperity ke Crystalline Bee"
	quest.55882C10292B6A3D.title: "ProsperiBee"
	quest.558FF21A6BCFE6E8.quest_desc: ["{image:atm:textures/questpics/allthemodium/all_armor_unomage.png width:100 height:175 align:center}"]
	quest.558FF21A6BCFE6E8.title: "&5Unobtainium Mage Armor"
	quest.55A9EB63F4964FCF.quest_subtitle: "&f7 &cAttack Damage"
	quest.55B9B9C3AA01D323.quest_desc: [
		"Di antara &5Kristal Berkilau&r masif di &5&lCrystal Canyon&r terdapat sebuah &5Kristal&r berbentuk &dBunga&r. \\n\\nSangat indah, hampir menghipnotis. Itu membuatku ingin menanam taman penuh &dBunga&r yang cantik, tapi aku tahu tidak ada bunga yang bisa menandingi keindahan &5Bunga Kristal&r ini... \\n\\nTerlepas dari itu, kamu akan menemukan banyak &5Kristal Madu&r, &6Madu&r, dan yang terpenting &5Crystalline Flower&r!"
		"{image:atm:textures/questpics/bumblezone/bumble_overgrown.png width:200 height:100 align:center}"
	]
	quest.55B9B9C3AA01D323.title: "&5Bunga Raksasa (Overgrown Flower)"
	quest.55BB4005BB4CA316.title: "Pengolahan Monazite"
	quest.55BF254B1831359B.quest_desc: ["&5Galadorian Drill&r adalah Drill terhebat yang bisa kita pasang ke Cart kita. \\n\\nKarena kehebatannya, itu juga artinya craft-nya bakal lebih susah... \\nCukup bilang kamu butuh banyak banget &3Stabilized Metal&r! Ikutin resep-resepnya!"]
	quest.55BF254B1831359B.title: "&5Galadorian Drill"
	quest.55C4824DAD905512.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Kontributor Komunitas&r untuk dipakai di AllTheMods Modpack.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan, kalau kamu lihat ini, kamu lagi di mode editing."]
	quest.55C6BBC996B51838.quest_desc: [
		"&#ED9553Bronze Boiler&r mengubah &9air&r menjadi uap (steam). Uap akan bertindak sebagai bahan bakar untuk mesin-mesinmu di era &7&nZaman Uap (Steam Age)&r."
		""
		"Untuk menggunakan mesin ini, cukup beri &9air&r dan &#ED5353bahan bakar tungku&r apa pun. Ini akan menaikkan suhu mesin; pada suhu maksimal, ia akan mampu menangani 4 mesin secara bersamaan."
	]
	quest.55C6BBC996B51838.quest_subtitle: "Merebus air"
	quest.55D7CD0FA8F1AE48.quest_desc: ["Alasan kita semua di sini: &5Kereta Api&r. Mod ini namanya &l&7RailCraft&r, jadi jangan kaget. \\n\\nAda 2 jenis rangkaian &5Kereta&r utama dan 1 &5Kereta&r khusus tambang. \\n\\nKereta-kereta ini kalau sendirian agak membosankan, jadi sambungkan &7Cart&r ke mereka! Menghubungkan &7Cart&r satu sama lain disebut Coupling, dan melepaskannya disebut Decouple. Gunakan &4Crowbar&r atau rel dengan Coupling &cTrack Kit&r untuk melakukannya."]
	quest.55D7CD0FA8F1AE48.title: "&7&lCart&r dan &5&lKereta&r!"
	quest.55DCA040C84DCEF3.quest_desc: ["Kalau mau ambil produk yang dibuat &aFluidizer&r, kamu butuh &aOutput Port&r di salah satu sisi.\\n\\n&aFluidizer&r butuh power untuk beroperasi, jadi &cPower Port&r diperlukan untuk ngelengkapin struktur."]
	quest.55DCA040C84DCEF3.title: "Port yang Diperlukan"
	quest.55DFC96B4CDBFA7D.quest_desc: ["Quantum Computer Core adalah jantung Quantum Computer. Punya 256M crafting storage dan 12 thread co-processing sendiri. Juga satu-satunya blok yang bisa jadi Quantum Computer sendiri, kalau dipowered lewat sisi Atas atau Bawah, dimana connector-nya ada. Tapi kalau dipakai bikin multiblock, computer jauh lebih kuat bisa dibuat."]
	quest.55DFC96B4CDBFA7D.title: "Jantung Craft: Quantum Computer Core"
	quest.55E321EFBE8956DE.quest_desc: ["Jika kamu ingin resep Fermentasi yang lebih murah, Fermentation Starter sangat cocok untukmu. \\n\\nPengganti yang sangat murah untuk item lain dalam proses Fermentasi."]
	quest.55E321EFBE8956DE.title: "Fermentasi Lebih Mudah"
	quest.5608C74936CA9E81.quest_desc: ["&6Mechanical Arm&r adalah Mesin yang membingungkan tapi juga sangat membantu dari &6&lCreate&r. Syukurin, gue gak perlu jelasin cara pakainya, cuma cara Craft-nya! \\n\\nPertama, dan paling simpel adalah &8Andesite Alloy&r. Itu cuma 2 &8Andesite Block&r dan 2 &7Zinc/Iron Nugget&r. \\n\\nSelanjutnya, adalah &eBrass Plate &fdan &eCasing&r. Keduanya jelas butuh &eBrass&r yang merupakan Alloy dari &6Copper&r dan &7Zinc&r! \\n\\nTerakhir, pasti yang paling susah dari ini, &ePrecision Mechanism&r. Kamu butuh seluruh setup &6Deployer &fdan &eBelt&r buat terus gerakin &eGold Plate&r kita buat nambah Item lagi ke itu. \\n\\nStep 1: pake &6Deployer&r buat nambah &dCogwheel&r ke &eGold Plate&r kita. 2: pake serupa buat nambah &dLarge Cogwheel&r. Step 3: nambah &7Iron Nugget&r pake &6Deployer&r. \\n\\nKita harus ulangi ini 5 kali buat semoga dapetin &ePrecision Mechanism&r kita! Yep, ada 20% kamu gak bakal dapetin Item di akhir! \\n\\nHey, kalo kamu gak suka semua kerjaan ini, kamu selalu bisa Craft &6Large Advanced Motor&r."]
	quest.5608C74936CA9E81.title: "&6Mechanical Arm"
	quest.561B5FB009744D2B.quest_desc: ["Buat dapetin &aInsanite Block&r kamu butuh 8 &aInsanite Ingot&r dan 1 &cBlock of Inanite&r. Iya, gue tau membingungkan dengan cuma beda satu huruf. \\n\\nBuat dapetin &aInsanite Ingot&r kamu harus reprocess &bBenitoite&r sama &4Rossinite&r di Reprocessor. \\n\\n&bBenitoite&r harus di-Mine di &c&lThe Nether&r. \\n\\n&cInanite Block&r dibuat dengan gabungin 8 &cInanite Ingot&r sama &cBlock of Netherite&r! &cInanite&r bukan &aInsanite&r. \\n\\nBuat dapetin Inanite Ingot kamu harus reprocess &dRidiculite&r sama &4Rossinite&r di Reprocessor. \\n\\n&dRidiculite&r adalah rantai resep lain yang sejujurnya gue capek liatin!"]
	quest.561B5FB009744D2B.title: "&aInsanite Block"
	quest.562BD37539EE318E.title: "Tingkat: &cBlazing"
	quest.565376084F05ED6E.quest_desc: ["Dimensi yang dikenal sebagai rumah Piglin dan Blaze ini, sekarang memiliki 2 bos baru untuk dilawan!"]
	quest.565376084F05ED6E.title: "&4Nether&r: Tanah dengan 2 Bos"
	quest.56550CD12C681B0F.quest_desc: ["&2Flax Seeds&r bisa ditemukan tumbuh di ladang rumput. Flax bagus kalau butuh banyak String di early game."]
	quest.56550CD12C681B0F.quest_subtitle: "Flax on, Flax off"
	quest.565703CBB06CEABF.quest_desc: ["Sudah tahu kenapa kalian di sini, kalian di sini untuk &4&lMorgan Sword&r. \\n\\nSalah satu Sword terkuat di semua &6&lATM Modpack&r. \\n\\nIkuti Quest ini dan akan menjadi kekuatan yang tak terhentikan!"]
	quest.565703CBB06CEABF.title: "Mendapatkan &4&lMorgan"
	quest.565EBD340595EAC4.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.5660E81BBEED6DC3.quest_desc: ["&dSoul Binding Crystal&r adalah yang paling susah dibuat. \\n&3Ender Pearl Fragment&r bisa dibuat dari &3Ender Pearl&r hasil farm &5Endermen&r. Kamu bisa pakai Extractor buat dapet &5Amethyst&r tanpa batas. Quartz bisa di-farm lewat &2&lMA&r. \\n\\nSekarang fokus ke Soul (jiwa). Mulanya kita butuh Soul normal! Biasanya kita pakai Soul Extractor ke Soul Sand buat ngambil jiwanya. \\n\\nTapi itu kan pakai item, dan bakal ngubah Soul Sand-nya... Pertama, kita bisa gantiin peran kita pakai Clicker dari &3&lJust Dire Things&r! \\n\\nSekarang tinggal ganti Soulless Sand yang abis diambil jiwanya jadi Soul Sand lagi pakai Block Breaker dan Placer, juga dari &3&lJust Dire Things&r. \\n\\nLalu, kita bisa gabungin Soul dengan &5Corrupti Dust&r dan Trapped Soul (drop item dari &5Lunar Guardian&r) buat dapet Corrupt Soul. \\n\\nTerakhir, gabungin Soul dengan Liquid Aureal dan Holy Hand Grenade buat bikin Enchanted Soul. Holy Hand Grenade itu bagian dari rangkaian resep dari &c&lReliquary&r."]
	quest.5660E81BBEED6DC3.title: "&dSoul Binding Crystal"
	quest.566C1DBA9829E328.quest_desc: ["&e&lCombiner&r bisa otomatisasi resep 2 &eItem&r yang simpel! \\n\\nKayak 2 Dye yang beda, atau Mud sama Wheat buat jadi Packed Mud. \\n\\nDia bahkan bisa lakuin resep unik baru kayak &7Cobble&f sama &0Flint&r buat bikin &7Gravel&r, atau 4 &5Obsidian Dust &fsama &8Deepslate&f buat bikin &5Obsidian&r!"]
	quest.566C1DBA9829E328.title: "&e&lCombiner"
	quest.567005978482235F.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Panah Ramuan"
		"- Percikan"
		""
		"Kemampuan Intrinsik:"
		"- Perbaikan Lava"
	]
	quest.56970D44D4C9015A.quest_subtitle: "&f7 &cAttack Damage"
	quest.56A4F5D301BC1E93.quest_desc: ["&#6EDDFFTurbo Upgrade&r menambah kapasitas sebesar &#FFEB6E64 EU/t&r per upgrade."]
	quest.56B58CAFCB707565.quest_subtitle: "Tingkat: &63"
	quest.56B6ABF3D6EA0D84.quest_desc: ["Dengan Plug yang sudah terpasang, kita sekarang bisa menarik daya dari jaringan kita. &9Flux Point&r melakukan hal tersebut. Ia mengarahkan daya dari jaringanmu ke blok apa pun yang terhubung, termasuk Pipa atau Kabel, atau langsung ke mesin!\\n\\nSetelah kamu memasang Point pada mesin atau blok yang ingin ditenagai, klik kanan dan pilih jaringanmu di tab \"Network Selection\". Sama seperti Plug, kamu bisa menyesuaikan berapa banyak daya yang ditarik, level prioritas, dll."]
	quest.56B6ABF3D6EA0D84.title: "Mengakses Daya Jaringan"
	quest.56B80A7EBFE21428.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.56B80A7EBFE21428.title: "&eAdvanced Pump Upgrade"
	quest.56BF647EA84FFF7E.quest_desc: ["Menunjukkan resep crafting mana yang sedang terjadi kapan saja."]
	quest.56BF647EA84FFF7E.quest_subtitle: "Menampilkan Resep"
	quest.56CE6CF9C99FB522.quest_desc: ["Untuk &8Radiator&r perlu &8Lembar Baja&r yang biasa, &9Ember Air&r yang baru! Dan &6Pelat Konstantan&r. \\n\\n&6Konstantan&r adalah Paduan yang dibuat dengan menggabungkan &6Tembaga&r dan &7Nikel&r di &l&6Kiln Paduan&r."]
	quest.56CE6CF9C99FB522.title: "&8Blok Radiator"
	quest.56D41A4605C42EB5.quest_desc: ["&6Crystallized Amber&r tumbuh di &cOvercast Columns&r. \\n\\nKamu butuh Silk Touch untuk mengambilnya. \\n\\nMereka tidak melakukan banyak, tapi terlihat cantik!"]
	quest.56D41A4605C42EB5.title: "&6Crystallized Amber"
	quest.56DA46DC82F6665D.quest_desc: ["Wilden Chimera adalah Bos yang ditambahkan oleh Ars Nouveau dan dibutuhkan untuk progres di mod tersebut. \\n\\nIa harus dipanggil melalui ritual kemudian dilawan!"]
	quest.56DA46DC82F6665D.title: "Kalahkan Wilden Chimera"
	quest.56DB53F255100136.quest_desc: ["Lo butuh Celana yang lebih keren? Gimana kalo kita upgrade &5Unobtainium legging&r jadi &a&lMekaSuit Pants&r! \\n\\nIni juga bakal butuh &dAntimatter Pellet&r, &dUltimate Induction Cell&r, sama beberapa &aPolonium Pellet&r. \\n\\nApakah upgrade-nya worth it? Cuma punya stat Armor sama kayak &cNetherite Legging&r?!? Dan ini harusnya 4 upgrade setelah &cNetherite&r! \\n\\nIya... itu... worth! Kita bisa Charge &a&lMekaSuit Pants&r dan daripada lo kena Damage, &a&lMekaSuit Pants&r bakal pake &aEnergi&r! Ya semua Damage kecuali Magic Damage... \\n\\nTerus, pake di &7&lModification Station&r buat tambahin &7Module Unit&r yang kebanyakan upgrade Movement lo. Iya, itu bisa penting banget!"]
	quest.56DB53F255100136.title: "&a&lMekaSuit Pants"
	quest.56DE217FEAE3F036.quest_desc: [
		"ME Advanced Pattern Provider adalah tipe baru ME Pattern Provider yang upgrade standard atau Extended Pattern Provider dengan kemampuan konfigurasi sisi mana tiap item di pattern dikirim. Ini memungkinkan automasi mesin yang butuh sisi spesifik buat input spesifik dilakukan dengan satu blok tanpa pipe atau subnet, seperti Metallurgic Infuser dari Mekanism."
		""
		"Buat pakai fitur ini, kamu butuh Advanced Pattern Encoder, buat tentukan sisi mesin mana yang dikirim tiap ingredient."
	]
	quest.56DE217FEAE3F036.quest_subtitle: "Lihat kamu, Mekanism"
	quest.56DE217FEAE3F036.title: "Pattern Sisi Spesifik: Advanced Pattern Provider"
	quest.56E30438AE512475.quest_desc: ["Mari bakar api ini! \\n\\nPreheater adalah tambahan yang sangat sederhana untuk &l&4Tungku Blast yang Ditingkatkan&r. \\n\\nCukup tempatkan di Kiri dan Kanan &l&4Tungku Blast yang Ditingkatkan&r. Kemudian, hubungkan daya ke atasnya dan akan mulai mempercepat &l&4Tungku Blast yang Ditingkatkan&r."]
	quest.56EC79AF11B0869E.quest_desc: ["&9Xeovrenth Adjure&r adalah tingkat tertinggi dari &5Ritual Perasukan&r. Ia hanya punya dua fungsi: menciptakan Cruelty Essence, bahan utama Brown Chalk, dan menciptakan Iesnium Golem, yang pada dasarnya hanyalah Iron Golem yang abadi dan menghasilkan damage lebih besar."]
	quest.56EC79AF11B0869E.quest_subtitle: "Perasukan Maksimal"
	quest.56EC79AF11B0869E.title: "&9Xeovrenth Adjure"
	quest.56FB82DEB944F758.quest_desc: ["Kerjanya kayak &aMace&r, tapi bikin ledakan AoE."]
	quest.570223A03231DF8C.quest_desc: ["Overhauled Endermen adalah mod yang mirip dengan Overhauled Creepers! Tentu saja hanya fokus pada Enderman! \\n\\nKamu akan menemukan para Enderman ini di semua biome yang berbeda dan masing-masing unik dengan caranya sendiri! Ada yang punya serangan berbeda, ada yang menjatuhkan Pearl yang berbeda, dan tampilan mereka pun berbeda-beda!"]
	quest.570223A03231DF8C.title: "Perombakan Enderman"
	quest.5703EDAFCF9E7719.quest_subtitle: "Tingkat: &63"
	quest.57167FE67CFAC255.quest_subtitle: "Digunakan untuk mendaftarkan lebah ke dalam Filter"
	quest.5716E84828EC0C23.quest_desc: ["Plastic Construction Brick adalah blok yang dibuat melalui &l&7PneumaticCraft: Repressurized&r. \\n\\nSama seperti versi dunia nyatanya, ini sangat sakit jika terinjak! \\n\\nJadi antara pakai sepatu atau haluskan dulu bata-batanya."]
	quest.5716E84828EC0C23.title: "Bata Konstruksi Plastik"
	quest.571CC5558B87377D.quest_desc: [
		"Crystal Cannon adalah senjata yang sangat seru dan berbahaya dari &6&lBumblezone&r! \\n\\nTapi seperti semua meriam, lebih baik latihan dulu. Cannon Range dibuat untuk itu! \\n\\nDi sana kamu akan menemukan banyak meriam, &5kristal&r, dan target untuk ditembak! Lalu kamu bisa mengambil hadiah karena mengenai blok target tersebut."
		"{image:atm:textures/questpics/bumblezone/bumble_range.png width:200 height:100 align:center}"
	]
	quest.571CC5558B87377D.title: "Tempat Latihan Meriam"
	quest.57282D7E31EE61EE.quest_desc: [
		"Setelah mengumpulkan beberapa &aRaw Iesnium Ore&r, kamu mungkin ingin menggunakan ingot pertama untuk membuat &dIesnium Pickaxe&r. Ini tidak hanya bisa menambang Iesnium seperti Infused Pickaxe, tapi juga jauh lebih awet."
		""
		"Bantulah dirimu sendiri dan buatlah alat ini!"
	]
	quest.57282D7E31EE61EE.title: "&aBeliung Otherworld"
	quest.5728D87E3240AF0D.quest_desc: [
		"Struktur yang sangat sederhana, &ePollinated Stream&r. Mereka adalah akuaduk &bAir Gula&r!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_streams.png width:200 height:100 align:center}"
	]
	quest.5728D87E3240AF0D.title: "&eAliran Serbuk Sari"
	quest.573885D6EF32B7BC.quest_subtitle: "Tingkat: &a2"
	quest.573BC5360C5CA675.quest_subtitle: "Ghostly + Skeletal"
	quest.573BC5360C5CA675.title: "Grave's Bee"
	quest.573C2242EAB85B49.quest_desc: [
		"&0&lCoke Oven&r adalah cara membuat &0Coal Coke&r, tebak terbuat dari apa! \\n\\nBisa menggunakan &0&lOven&r untuk melelehkan Log menjadi &0Arang&r, atau melelehkan &0Batu Bara&r dan &0Blok Batu Bara&r menjadi &0Kokas&r! \\n\\nSalah satu dari ini akan menghasilkan Minyak Kreosot serta resep normal."
		"{@pagebreak}"
		"&0&lCoke Oven&r adalah Multiblok yang sangat sederhana, 3x3x3 &0Bata Kokas&r."
		"{image:atm:textures/questpics/immersive/immersive_coke1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_coke2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_coke3.png width:100 height:100 align:center}"
		"Cukup Klik Kanan Blok Tengah Sisi Depan dengan &6Palu Insinyur&r untuk membuatnya."
		"{image:atm:textures/questpics/immersive/immersive_coke.png width:100 height:100 align:center}"
	]
	quest.573C2242EAB85B49.title: "&l&8Coke Oven"
	quest.573DD5834B321D0A.quest_desc: [
		"&9Acropolis&r adalah kota raksasa di atas Awan di atas &9Samudra&r yang luas. \\n\\nTerbuat dari &9Azure Seastone&r, &3Prismarine&r, dan &9Air&r! Ya, banyak sekali &9Air&r! \\n\\nArsitekturnya berbasis gaya Yunani, dengan banyak lantai, taman, dan bahkan arena. \\n\\nDi sekelilingnya akan muncul &9Octohost&r, &9Urchinkin&r, &9Cindaria&r, &9Hippocamtus&r, dan &9Clawdian&r! Serta beberapa mob &9Samudra&r yang malang. \\n\\nHampir di setiap sudut tersembunyi kamu bisa menemukan Peti dan blok langka seperti Blok Diamond dan Sponge!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_acropolis.png width:200 height:100 align:center}"
	]
	quest.573DD5834B321D0A.title: "&9Acropolis&f: Rumah &9&lScylla"
	quest.574E5806D1A98FE5.quest_desc: ["Energy Modules adalah Module paling penting dan diperlukan untuk menggunakan item DE. Jumlah di dalamnya menentukan berapa banyak OP yang bisa item tahan dan ambil, lihat Energy Infuser untuk belajar lebih tentang charging. Semakin lanjut Tier Energy Module semakin banyak OP yang bisa item tahan dan gunakan. Ini penting karena saat item di-upgrade mereka menggunakan lebih banyak OP per penggunaan."]
	quest.574E5806D1A98FE5.title: "Basic Energy Module"
	quest.5753E0138A072A3F.quest_subtitle: "Cherry + Oak/Dark Oak"
	quest.5758645223B4B5BA.quest_desc: ["Dengan &3Aqua Walker&r, kamu bisa menggunakan kemampuannya untuk berjalan di atas &9Air&r! Kamu bisa menahan Shift untuk menyelam ke dalam &9Air&r dan berenang. Sepertinya aku pernah baca cerita seperti itu dulu?"]
	quest.5758645223B4B5BA.quest_subtitle: "Ditemukan di Bangkai Kapal dan Reruntuhan Laut"
	quest.5758645223B4B5BA.title: "&3Aqua Walkers"
	quest.575E405B270BBCBC.quest_desc: ["Di &9Twilight Forest&r, ada banyak makhluk baru untuk ditemukan.\\n\\nSalah satu yang paling menyebalkan adalah Cicada (Tonggeret). Aku sarankan membunuhnya untuk misi ini, tapi membunuh mob Twilight Forest mana pun juga bisa."]
	quest.575E405B270BBCBC.title: "Keheningan Hutan"
	quest.5766C8B9E850C186.quest_desc: [
		"Untuk membuat salah satu item crafting utama di Ars, yaitu &9Source Gem&r, kita perlu membuat &6Imbuement Chamber&r. \\n\\nImbuement Chamber membutuhkan Source untuk memproses item. Alat ini menghasilkan sedikit Source dengan sendirinya, tetapi juga bisa menggunakan Source Jar sebagai sumber tenaga. \\n\\nBeberapa resep juga membutuhkan Arcane Pedestal yang diletakkan di sekelilingnya.\\n"
		"{image:atm:textures/questpics/ars/imbuement.png width:200 height:150 align:1}"
	]
	quest.5766C8B9E850C186.quest_subtitle: "Membuat Source Gem"
	quest.576ABF43FCF886B7.title: "&2Lahan Pertanian Prudentium"
	quest.577A5FC500E14C05.quest_subtitle: "Lawson Cypress + Oak"
	quest.5791F3000D18E2C9.quest_desc: ["&8Wither&r punya kecenderungan buat ngebreak dan meledakin Block. \\n\\nKebanyakan player gak suka ini, jadi &8Witherproof Brick&r adalah yang kamu cari! \\n\\nMereka sama kayak &8Witherproof Block&r, cuma dengan desain lebih bagus!"]
	quest.5791F3000D18E2C9.title: "&8Witherproof Brick"
	quest.5792CC9E3AFAB229.quest_desc: ["Ada juga mod bernama &aGenerators Galore&r! Mod ini menambahkan generator unik yang menggunakan coal atau item lain."]
	quest.57940981E8DE55D4.quest_desc: ["Mudah sekali tersesat di &9Twilight Forest&r. Dalam perjalananmu, kamu akan menemukan pilar-pilar &5Obsidian&r.\\n\\nPilar-pilar ini dikelilingi oleh &8Raven&r (Gagak). Bunuh mereka dan mereka akan menjatuhkan bulunya, yang bisa kamu gunakan untuk membuat peta &9Twilight Forest&r!"]
	quest.57940981E8DE55D4.title: "Bulu Gagak (&8Raven Feather&r)"
	quest.579DA82672BF632C.quest_subtitle: "&f6 &cAttack Damage"
	quest.57A18F2E51952EB8.quest_desc: ["&5Kotak Pos&r akan menggunakan Alamat dan &5Kereta&r untuk mengirimkan &ePaket&r! \\n\\nPertama, &ePaket&r bisa ditaruh di &5Kereta&r menggunakan &ePenampang&r! Tentu saja &ePenampang&r harus terhubung ke &5Kereta&f melalui &aGlue&r. \\n\\nBerikutnya, kita bisa menghubungkan &5Kotak Pos&r ke &5Stasiun Kereta&r dengan Klik Kanan &5Stasiun Kereta&r sambil memegang &5Kotak Pos&r. \\n\\nKita kemudian bisa menaruh &5Kotak Pos&r di dekatnya dan ketika &5Kereta&f tiba di &5Stasiun&r, mereka akan berinteraksi dengan &5Kotak Pos&r. \\n\\nDi GUI &5Kotak Pos&r kita bisa mengubah Alamatnya, yang mempengaruhi apakah &ePaket&r dikirimkan atau dikirim darinya. Kalau Alamat &ePaket&r cocok dengan Alamat &5Kotak Pos&r, &ePaket&r akan dikirim ke &5Kotak Pos&r. Kalau tidak cocok, &ePaket&r akan pergi dari &5Kotak Pos&r ke &5Kereta&r!"]
	quest.57A18F2E51952EB8.title: "&5Kotak Pos"
	quest.57A7A5C79389A96A.quest_desc: ["Sebagian besar Pemain sudah mengenal &6&lCreate&r apalagi dengan berjuta Addon-nya! Tidak banyak Mod yang punya Modpack tersendiri berdasarkan mereka! \\n\\nKalau kamu belum terbiasa dengan &6&lCreate&r, Quest-quest ini seharusnya membantumu mempelajarinya. Dan untuk banyak &eItem&f dan &6Mesin&r ada opsi Ponder! Tahan W sambil melihat &eItem&r untuk menonton skematik yang akan mengajarkanmu memahami &eItem&f atau &6Mesin&r tersebut. \\n\\nPercayalah, kamu akan mau belajar &6&lCreate&r, sangat berguna! \\n\\nUntuk memulai kamu butuh &8Andesit&r dan banyak darinya."]
	quest.57A7A5C79389A96A.title: "&6&lCreate&r"
	quest.57ACD83205988834.quest_subtitle: "Gold + Ender"
	quest.57ACD83205988834.title: "Platinum Bee"
	quest.57BB2CC6D9D2AE87.quest_desc: ["Inilah yang benar-benar kamu butuhkan untuk mendapatkan &eAffix&r yang sempurna. \\n\\nPertama kamu butuh &6&lTable&r ini, sebuah peralatan, dan &6Sigil of Enhancement&r. \\n\\nBegitu punya semuanya, dunia ada di genggamanmu! Kamu bisa me-reroll &eAffix&r, memilih &eAffix&r spesifik, atau meng-upgrade &eAffix&r yang sudah ada!"]
	quest.57BB2CC6D9D2AE87.title: "&6&lAugmenting Table"
	quest.57C4A0BAE739E903.quest_desc: ["Dissolution Chamber dipakai untuk craft mesin yang lebih advanced.\\n\\nPerlu memasukkan fluid tertentu di dalamnya bersama dengan item yang diperlukan untuk apa yang di-craft. Cek JEI."]
	quest.57C4A0BAE739E903.quest_subtitle: "Crafting Table-nya?"
	quest.57CF8C6C867B9BDA.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.57CF8C6C867B9BDA.title: "&eAdvanced Filter Upgrade"
	quest.57F107892FFA1F52.quest_desc: ["Buat grow Nether Star Seed kamu butuh Crux di bawah Farmland. Iya growing Nether Star harus dibuat lebih mahal! \\n\\nBuat bikin Nether Star Crux kamu butuh &7Withering Soul&r yang punya drop 1/3 dari &8Wither&r."]
	quest.57F47BA495B27F83.quest_desc: ["&9Tier 1&r Harvest Level adalah tingkat beliung terendah yang membutuhkan alat. Beliung apa pun dapat menambang tingkat ini. Item yang termasuk Tier 1 adalah seperti Batu (Stone), Furnace, dan Bijih Batu Bara (Coal Ore)."]
	quest.57F47BA495B27F83.title: "&9Harvest Tier 1"
	quest.580148D1141446A6.quest_desc: [
		"&c&lNether&r terlalu seram buat kamu? Kalau gitu, bisa cari Soul di &2&lOverworld&r!\\n\\nDi World kamu (Gue suruh kamu ke Dark Forest karena &l&6Forbidden \\& Arcanus&r lama dulu punya Blok di sana) kamu mungkin nemuin Lost Soul berkeliaran.\\n\\nKamu bisa bunuh mereka untuk Soul yang mereka drop! Tapi jauh kurang efisien...\\n"
		"Kalau kamu kesusahan cari Soul, mungkin mau cek Soul Looting enchantment di pedang kamu. Bunuh mob dengan enchantment ini kadang akan spawn Soul."
	]
	quest.580148D1141446A6.title: "Lost Soul"
	quest.5820EDEF71340A1A.quest_desc: [
		"&6Abandoned Track&r bagus untuk penghematan dan estetika. Rel ini bisa digunakan untuk menyeberangi beberapa blok tanpa penyangga. Namun, ada risiko anjlok (derailment), di mana &7Cart&r kamu akan terlempar keluar dari &6rel&r."
		"{image:atm:textures/questpics/railcraft/rail_abandoned.png width:150 height:100 align:center}"
	]
	quest.5820EDEF71340A1A.title: "&6Rel Terbengkalai (Abandoned)"
	quest.5831B3192C0E8C56.quest_desc: [
		"Ingin mengakses penyimpananmu dari jauh? Ini bisa dilakukan dengan &eStable Wormhole&r atau &aStorage Accessor&r."
		""
		"Untuk menggunakan &eStable Wormhole&r, shift-klik pada &dStorage Actuator&r untuk menghubungkannya. Kamu bisa meletakkan Wormhole ini sebagai titik akses penyimpanan di lokasi lain."
		""
		"&aStorage Accessor&r dihubungkan dengan cara yang sama, tapi berfungsi sebagai remote nirkabel yang bahkan bisa bekerja lintas dimensi!"
	]
	quest.5831B3192C0E8C56.title: "&aAkses Jarak Jauh"
	quest.5844DD2BEE5EC3DC.quest_desc: ["Jangan dimakan! \\n\\n&cMercury&r (Raksa) bisa digunakan untuk 3 hal berbeda: Inkubasi, Menghasilkan Energi, dan Logistik!"]
	quest.5844DD2BEE5EC3DC.quest_subtitle: "Planet... eh, unsur &cMercury&r!"
	quest.5844DD2BEE5EC3DC.title: "Mercury"
	quest.58495CFBF4F20CE9.quest_desc: ["Ini kerja sama kayak kitchen counter, tapi di udara.\\n\\nDan kamu gak bisa taruh sesuatu di atasnya."]
	quest.58495CFBF4F20CE9.quest_subtitle: "Banyak ruang untuk aktivitas!"
	quest.58495CFBF4F20CE9.title: "Storage Lebih Banyak Lagi"
	quest.58514FDE153FD971.quest_subtitle: "Iron Chest?"
	quest.58514FDE153FD971.title: "&fIron Chest"
	quest.5865951E4F81C91F.quest_desc: ["&7Osmium&r + &6Glowstone&r = &eRefined Glowstone&r!"]
	quest.5865951E4F81C91F.quest_subtitle: "20"
	quest.5865951E4F81C91F.title: "&eRefined Glowstone Armor"
	quest.5866438E5D19AB69.quest_desc: [
		"&3Sculk Leeches&r kadang bisa muncul dari Ancient Vases yang pecah. \\n\\nIni bertindak sebagai kejutan kecil untukmu saat 2 muncul keluar! \\n\\nMereka hanya punya 2 &4Hearts&r dan akan menyerangmu meskipun begitu. \\n\\nSaat mati mereka akan drop &3Soul Dust&r."
		"{image:atm:textures/questpics/deepndark/dnd_leech.png width:100 height:100 align:center}"
	]
	quest.5866438E5D19AB69.title: "&3Sculk Leech"
	quest.5867713D016143A6.quest_subtitle: "Dibuat dengan Enchanting Apparatus"
	quest.5867713D016143A6.title: "Arcane Bee"
	quest.5869E198DA416346.quest_desc: ["Late Game &5&lMekanism&r itu gila. Buat 1 &5Antimatter Pellet&r kamu harus crystallize 1,000mb &5Antimatter&r. \\n\\nBuat 1mb &5Antimatter&r kamu harus power 1,000mb &3Polonium&r lewat SPS. \\n\\nBuat dapetin 1mb &3Polonium&r kamu harus activate Neutron dari 5mb &2Nuclear Waste&r. \\n\\nDan &2Nuclear Waste&r kamu dapetin dari process &9Fissile Fuel&r lewat Fission Reactor!"]
	quest.5869E198DA416346.title: "2 &5Antimatter Pellet"
	quest.586D5DE28EEC8014.quest_desc: ["&cQuanta&r membantu mengacak daftar &5Enchantment&r, mempermudahmu mendapatkan banyak jenis &5Enchantment&r yang berbeda. \\n\\nTapi &cQuanta&r juga bisa merugikanmu; semakin banyak nilainya, semakin sering &5Enchantment&r Buruk muncul. Contohnya seperti &5Curse of Binding&r! \\n\\nDulu kita memakai mekanisme &eRectification&r, tapi sekarang kita menggunakan &6Geode-Encased Bookshelves of Stability&r! \\n\\nNilai standar &cQuanta&r adalah &c15%&r dan maksimalnya &c100%&r."]
	quest.586D5DE28EEC8014.title: "&cQuanta"
	quest.586F6FD38CF85DCA.quest_desc: ["&4&lBor Pertambangan&r melakukan seperti namanya, Menambang! \\n\\nBekerja seperti Beliung, hanya perlu &8Kepala Bor&r dan &2Bio-Diesel&r. &8Kepala Bor&r menentukan Level Pertambangannya dan memiliki Daya Tahan yang berarti perlu diganti. Bisa memasang &8Kepala Bor&r di &6Meja Kerja Insinyur&r, di Slot Atas. \\n\\n&2Bio-Diesel&r adalah &bBahan Bakar Cair&r yang memiliki resep sangat sulit untuk dibuat... itu untuk Quest berbeda, kita hanya melihat cara Mengisi Bahan Bakar! Bisa menggunakan &4&lBor&r pada &bTangki&r atau Mesin apa pun yang menahan &2Bio-Diesel&r untuk mengisinya. \\n\\n&4&lBor Pertambangan&r akan menambang di area 3x3 atau 2x2, kecuali Bergeser saat menghancurkan! \\n\\nJuga bisa Memukul Mob dengannya untuk memberikan Kerusakan yang sama dengan Pedang Netherite, ini juga menggunakan Bahan Bakar serta Daya Tahan. \\n\\n&4&lBor Pertambangan&r bisa menampung 1 Kepala Bor dan 3 Upgrade."]
	quest.586F6FD38CF85DCA.quest_subtitle: "Maukah kamu?"
	quest.586F6FD38CF85DCA.title: "&4&lBor Pertambangan"
	quest.5894A9DB9C379E91.quest_subtitle: "Infusion Crafting"
	quest.5894A9DB9C379E91.title: "Prudentium Bee"
	quest.5895B7FA5497BD68.quest_desc: ["Versi upgrade dari Wyvern Axe."]
	quest.5895B7FA5497BD68.title: "Draconic Axe"
	quest.589DFDB8FB7211AA.quest_desc: ["Produksi &7Karet (Rubber)&r untuk persiapan transisimu ke &#C1DB46&nZaman Listrik&r sangatlah penting. Mengotomatisasinya sedini mungkin akan membantumu melangkah lebih jauh dari yang kamu bayangkan."]
	quest.589DFDB8FB7211AA.title: "Karet dan Papan Sirkuit"
	quest.589EB4602E3F9EEE.quest_desc: ["Tin Bee dibuat dengan mengawinkan Crystalline Bee dengan Ashy Mining Bee."]
	quest.589EB4602E3F9EEE.quest_subtitle: "Ashy Mining + Crystalline"
	quest.589EB4602E3F9EEE.title: "Tin Bee"
	quest.589F1D502F680075.quest_desc: ["Cocok buat pesta kolam renang! \\n\\nSelain kelihatan lucu, &dHelium Flamingo&r membolehkanmu berenang di Udara. Iya, beneran! Berenang... di... udara... \\n\\nPas lagi di udara, kayak habis lompat gitu, kamu bisa tekan CTRL buat mulai berenang di udara. Kamu bisa gerak bebas kayak di air: berenang ke atas, ke bawah, muter-muter sesukamu!"]
	quest.589F1D502F680075.quest_subtitle: "Sabuk"
	quest.589F1D502F680075.title: "&dHelium Flamingo&r"
	quest.58B125BD4876054C.quest_desc: ["&5&lMekanism&r itu mod teknologi yang bakal ngerubah cara kamu main &2&lMinecraft&r. \\n\\nMod ini fokus ke pemecahan bahan jadi struktur kimianya, dan dapetin hasil terbaik dari tiap bahan yang kamu temuin.\\n\\nMod ini punya &cJetpack&r bertenaga Hydrogen, teman robot kecil, &2&lReactor&r, &7&lDigital Miner&r buat otomatisasi tambang, dan banyak lagi. \\n\\nPercaya deh, kamu bakal tahu kenapa mod ini dipakai di hampir setiap &6&lATM Modpack&r!"]
	quest.58B125BD4876054C.quest_subtitle: "Awal dari Pabrikmu Sendiri"
	quest.58B125BD4876054C.title: "&5&lMekanism&r"
	quest.58B5EF8EB72934C2.quest_desc: ["&cJetpack &7Unit&r bakal kerja kayak lo pake &5&lMekanism&r &cJetpack&r sama &a&lMekaSuit Bodyarmor&r. \\n\\n&cJetpack&r pake Control yang sama, dan butuh &7Hydrogen&r sebagai fuel. \\n\\nLo bisa ngisi dengan &7Hydrogen&r dengan 2 cara. Lo bisa taro di &5Mesin&r yang punya &7Hydrogen&r di dalamnya. Atau ada di bawah &9Air&r sambil &a&lMekaSuit Helmet&r lo punya &9&lElectrolytic Breathing&r. \\n\\nLo gak bisa pake &7Unit&r ini pas lo punya &dGravitational Modulating &7Unit&r."]
	quest.58B5EF8EB72934C2.quest_subtitle: "Bodyarmor"
	quest.58B5EF8EB72934C2.title: "&cJetpack &7Unit"
	quest.58BD1063A19777DC.quest_desc: ["Setelah kamu membuka biome &2Highland&r, pergilah dan temukan beberapa Troll untuk dibunuh.\\n\\nMereka bisa menjatuhkan &9Magic Bean&r. Kamu juga akan menemukan peti yang berisi Uberus Soil, yang dibutuhkan untuk menanam Magic Bean tersebut."]
	quest.58BD1063A19777DC.quest_subtitle: "Di mana Jack?"
	quest.58BD1063A19777DC.title: "Mengunjungi Raksasa"
	quest.58C2ABED43B2EA61.quest_desc: ["&9Model Framework&r adalah titik awal untuk membuat Data Model.\\n\\nUntuk mulai mengumpulkan data mob tertentu, buat salah satu lalu &9klik kanan&r mob yang ingin dikumpulkan datanya. Kalau benar, Model Framework akan berubah jadi Data Model dari mob yang diklik.\\n\\nUntuk mengumpulkan data mob tersebut, masukkan Data Model yang baru dibuat ke &aDeep Learner&r, lalu mulai bunuh mob spesifik itu dengan Deep Learner di inventory."]
	quest.58C2ABED43B2EA61.quest_subtitle: "\"Mengumpulkan Data\""
	quest.58C2ABED43B2EA61.title: "&9Memodelkan Mob"
	quest.58CC2E563F92B4C5.quest_desc: ["&cEssence of Raging&r saat berada di tangan kiri akan bertindak seperti sistem buronan. \\n\\nIa akan menyoroti 4 mob dan saat mereka mati kamu akan mendapatkan Strength, dan semakin banyak yang kamu bunuh semakin kuat efeknya! \\n\\nMaksimal hingga 16. \\n\\nSetelah digunakan, ia akan memiliki waktu tunggu selama 30 menit."]
	quest.58CC2E563F92B4C5.title: "&cEssence of Raging"
	quest.58D5BD3106BFD94A.quest_desc: ["Craft versi berikutnya dari book. Gue jamin, ini worth it.\\n\\nGue bahkan kasih kamu Diamond balik."]
	quest.58D5BD3106BFD94A.quest_subtitle: "Ini beneran worth it"
	quest.58D5BD3106BFD94A.title: "Masak dengan kekuatan Diamond"
	quest.58DDD32F849940A0.quest_subtitle: "Tingkat: &d6"
	quest.58EC47584C773B82.quest_desc: ["Menggunakan struktur Enchanting Apparatus, kita akan membuat benih pertama kita, &5Magebloom Seed&r. \\n\\nBenih ini akan digunakan untuk membuat pakaian ajaib!"]
	quest.58EC47584C773B82.quest_subtitle: "Menanam Sihir"
	quest.58EC47584C773B82.title: "Magebloom Seed"
	quest.58F7C11C241DD7A4.quest_desc: [
		"&#6AADD9Distillation Tower&r adalah bentuk peningkatan dari &#A3D2F0Distillery&r. Keuntungan utamanya adalah ia memberimu banyak output dari satu input yang sama."
		""
		"Untuk membangunnya, kamu harus membuka GUI blok &#6AADD9Distillation Tower&r dan memilih ketinggiannya. Tinggi menara tergantung pada berapa banyak output yang kamu butuhkan. Untuk mengolah &#76759ECrude Oil&r, kamu butuh tinggi 3 blok."
	]
	quest.58F7C11C241DD7A4.quest_subtitle: "Efisiensi itu penting"
	quest.59036A2741E7A8AA.quest_desc: ["Mau bikin Spawn Egg dari spirit yang kamu punya di kotak itu?\\n\\n&9Spirit Reanimator&r ngasih persis itu. Kasih banyak &cBlood&r dan Telur, dan tentu saja &9Box of Eternal Closure&r dengan Spirit yang mau kamu bikin Spawn Egg-nya, dan dia bakal coba bikin Spawn Egg!\\n\\nCatatan: Beberapa mob gak bisa dipake buat bikin Spawn Egg."]
	quest.59036A2741E7A8AA.title: "&aBikin &9Spawn Egg"
	quest.59135B04FC7C3E61.quest_subtitle: "Berikan sebuah blok Cloggrum ke Iron Bee"
	quest.59135B04FC7C3E61.title: "Cloggrum Bee"
	quest.5914D015D8543875.quest_desc: ["&aFluidizer&r bisa beroperasi di salah satu dari 3 mode: Solid ke Fluid, Menggabungkan 2 Solid jadi Fluid, atau menggabungkan 2 Fluid jadi Fluid baru. Ini semua tergantung tipe &aInjector&r yang kamu pakai buat multiblock.\\n\\nContoh, kalau mau convert &dBlutonium&r jadi fluid, kamu bisa pakai 1 &aSolid Injector&r.\\n\\nKalau mau gabungin dua solid jadi sesuatu yang baru, kamu bangun multiblock dengan 2 &aSolid Injector&r.\\n\\nKalau mau gabungin dua fluid, kamu pakai 2 &9Fluid Injector&r.\\n\\nIni mungkin membingungkan, tapi penting untuk progres. Contoh, kamu mau convert Magentite jadi fluid di Fluidizer dulu, lalu kirim ke &aReprocessor&r dengan Ludicrite untuk bikin Ridiculite."]
	quest.5914D015D8543875.title: "Mode Operasional"
	quest.591E6964ABCC638C.quest_desc: ["&eSabuk Konveyor&r adalah cara memindahkan &eBarang&r (dan beberapa Entitas). \\n\\nKetika &eBarang&r dijatuhkan ke &eSabuk&r, akan menahan dan memindahkannya. Ini kemudian bisa dipindahkan ke Inventaris berbeda, jika ingin mengekstrak dari Inventaris perlu jenis khusus &eSabuk&r! \\n\\nCara menempatkan &eSabuk&r akan menentukan ke mana bergerak, ini juga bisa diubah dengan &6Palu Insinyur&r! \\nMereka perlu ditempatkan di Blok tetapi cukup lucu tidak memerlukan Blok di bawah untuk tetap berdiri dan bekerja!"]
	quest.591E6964ABCC638C.quest_subtitle: "dan beberapa Entitas!"
	quest.591E6964ABCC638C.title: "Memindahkan &eBarang&r"
	quest.593A32072E7FD91D.quest_subtitle: "Tingkat: &c5"
	quest.593CB120B657126C.quest_desc: ["Sekarang kita akhirnya bisa khawatir soal &aRadioaktivitas&r! \\n\\n&8Nuclear Waste&r (sama produknya) adalah &aRadioaktif&r. Itu artinya harus disimpen di &eRadioactive Waste Barrel&r. \\n\\n&8Nuclear Waste&r (sama produknya) harus di-Tubing masuk dan keluar dari &eRadioactive Waste Barrel&r. \\n\\nLo gak boleh hancurin &eBarrel&r atau &cTube&r yang nyimpen material &aRadioaktif&r, atau &aRadiasi&r bakal nyebar di Dunia. \\n\\n&aRadioaktivitas&r juga bisa datang dari &2&lReaktor&r yang bocor atau meleleh. \\n\\nGimana cara ngatasi &aRadioaktivitas&r? &6Hazmat Suit&r dan waktu. Cek Quest-nya buat belajar lebih banyak!"]
	quest.593CB120B657126C.title: "&aRadioaktivitas"
	quest.594BBD31461F212D.title: "Draconic Shield Recovery Module"
	quest.594F6ED00D1619EE.quest_subtitle: "Tingkat: &a2"
	quest.5961C1ED32522BEF.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r "
		""
		"Memunculkan umpan dari pemain yang menarik perhatian dari pemain, memiliki cooldown."
	]
	quest.5962DC39E5874FB9.quest_subtitle: "Lapis + Skeletal"
	quest.5979DE0E2BA3DAE5.quest_desc: ["&7Rel Kereta&r adalah... ya, yang akan kamu gunakan untuk menggerakkan &5Kereta&r! \\n\\nKamu perlu &6Mendeploy&r 2 &7Nugget Besi&r ke &8Lempengan Batu&r, lalu &6Menekan&r dengan &6Pres Logam&r untuk mendapatkan 1. \\n\\nIni adalah Blok pertama yang kamu pasang untuk mendapatkan &5Kereta&r karena dibutuhkan untuk memasang &5Stasiun Kereta&r. \\n\\nNamun ada beberapa batasan — tidak bisa dibuat di sudut curam untuk berbelok atau naik. Kamu butuh 4 Blok ruang untuk naik satu Blok dengan &7Rel Kereta&r. Untuk berbelok bahkan lebih rumit! Anggap saja, kalau kamu ingin lingkaran sempurna dengan &7Rel Kereta&r, butuh diameter 18 Blok."]
	quest.5979DE0E2BA3DAE5.title: "&7Rel Kereta"
	quest.598DE7CEDA864B50.quest_desc: ["Mengapa hanya memiliki 1 Tangki, ketika bisa menggunakan 3! \\n\\nSekarang bisa menampung 3 &bCairan&r berbeda di &b&lPelempar Kimia&r. Tahan Shift dan Gulir untuk beralih di antara mereka. \\n\\nIni tidak bisa digunakan dengan Tangki Besar..."]
	quest.59AF80E8EE17C769.quest_desc: [
		"&5Echoing Forest&r agak polos tapi juga menampung &5Echoing Trees&r! \\n\\n&5Echoing Trees&r bertindak seperti Pohon normal, kamu bisa Menambang &aLogs&r-nya untuk Crafting dan &5Leaves&r-nya akan drop Saplings. Kamu juga bisa menemukan Sculk Gleam di dalam Leaves. \\n\\nDi sekitarnya kamu akan menemukan &5Echoing Soil&r di seluruh permukaan. Ini sayangnya tidak bisa dibuat jadi Farmland atau Dirt, mereka hanya Block."
		"{image:atm:textures/questpics/deepndark/dnd_forest.png width:200 height:100 align:center}"
	]
	quest.59AF80E8EE17C769.title: "&5Echoing Forest"
	quest.59B6C6BF0550D13D.quest_desc: ["Tipe kaca baru yang bisa digunakan untuk Kereta Apimu! Atau markasmu, \\n\\nAku tidak bisa memaksamu menggunakannya untuk hal tertentu."]
	quest.59B6C6BF0550D13D.title: "Kaca &7&lRailcraft&r"
	quest.59D91C5E11F67FC3.quest_desc: ["Rival dari &bHutan Warped Kuno&r. \\n\\n&cHutan&r ini punya tanah &cNylium Crimson&r juga dengan &cNetherrack&r di bawah. \\n\\nDaripada &bPohon Soul&r, &cHutan&r ini punya &cPohon Iblis&r. Ouuu serem!"]
	quest.59D91C5E11F67FC3.title: "&cHutan Crimson Kuno"
	quest.59E68086A8B99EA7.quest_desc: [
		"&c&lPyromancer&r (berbeda dari Pie Romancer) adalah Mob Netral lain yang ditambahkan oleh &lIron's Spells&r. Dia mungkin akan menyalakan Mob yang dekat dengannya &capi&r... \\n\\nKamu bisa berdagang dengannya semua hal tentang &cApi&r, Ink, dan bahkan &cFire Scroll&r. \\n\\nJika kamu ingin mengambil risiko semua rambut di tubuhmu dengan melawannya bersiaplah, dia punya 60 Heart. Dia akan menyalakanmu dengan &cApi&r dengan &cFire Spell&r, tidak perlu dipertanyakan lagi. \\n\\nSaat mati dia akan menjatuhkan Arcane Essence, Ink, &cFire Rune&r, dan &cFire Spell&r!"
		"{image:atm:textures/questpics/iron_spells/spells_pyromancer.png width:100 height:200 align:center}"
	]
	quest.59E68086A8B99EA7.title: "&c&lPyromancer"
	quest.59EC02C1FBCF14EA.quest_desc: ["Kamu bisa upgrade &5Obsidian Generator&r-mu jadi &3Ender Generator&r. \\n\\nTerus, ini bisa pake &3Ender Pearl&r atau &3Eyes of Ender&r buat bikin Energy! \\n\\nAtau bikin &6&lStar&r, pilihan kamu."]
	quest.59EC02C1FBCF14EA.title: "&3Ender Generator"
	quest.59F5ED931FD70C55.quest_desc: ["&9Pattern&r adalah inti dari autocrafting. Benda ini menyimpan resep agar jaringan RS tahu cara membuat suatu item."]
	quest.59F5ED931FD70C55.quest_subtitle: "Ikuti Polanya"
	quest.59F5ED931FD70C55.title: "Autocrafting"
	quest.59FD3C4E415EEDDD.quest_desc: ["Setelah Ritual dimulai akan melihat &3Lake&r dibuat. \\n\\nAkan tumbuh sekitar area 20x20 block penuh &3Murky Water&r. \\n\\n&3Murky Water&r tidak akan membunuh; kecuali lupa naik untuk ambil udara."]
	quest.59FD3C4E415EEDDD.title: "&3Mahou Lake"
	quest.5A011CE8EEA3F9D8.quest_desc: ["Aura dapat dimasukkan ke dalam botol dengan cara Klik Kanan di udara menggunakan Bottle and Cork. Aura akan mengambil bentuk berbeda tergantung di mana ia dikumpulkan.\\n\\nDi Overworld ia akan menjadi &aSunlight&r, di Nether menjadi &4Ghosts&r, dan di End menjadi &0Darkness&r.\\n\\nJika area tempat kamu menggunakan botol sangat kekurangan aura, kamu akan mendapatkan &0Bottled Vacuum&r."]
	quest.5A011CE8EEA3F9D8.quest_subtitle: "Memasukkan Aura ke Botol"
	quest.5A011CE8EEA3F9D8.title: "Botol Aura"
	quest.5A0860631323B5E3.quest_desc: ["Terbuat dari &3Wheat Flour&r (Tepung Gandum). Bisa digunakan untuk membuat Salmon Tempura dan Roti Sourdough."]
	quest.5A0860631323B5E3.quest_subtitle: "Kamu butuh ini"
	quest.5A088F8402230BA5.quest_desc: ["&2Fission Reactor Port&r sangat penting. &2&lFission Reactor&r butuh Port buat &2Fuel&f, &bCoolant&f, sama &8Waste&r... jadi gak bakal kerja tanpa &2Port&r. \\n\\n&2Port&r bisa ditaro di bagian manapun dari Dinding &2&lFission Reactor&r, cuma gak di pinggiran. \\n\\nKita perlu punya 4 dan kita perlu pake &3Configurator&r di &2Port&r buat Configure mereka. \\n\\nMereka bakal mulai sebagai &aInput Only&r tapi dengan Shift Klik Kanan &2Port&r pake &3Configurator&r bakal ganti ke &eOutput Waste&r terus ke &bOutput Coolant&r. \\n\\n&aInput Only&r bakal terima &2Fissile Fuel&r sama &bCoolant&r entah itu &9Air&r atau Sodium. \\n\\n&eOutput Waste&r bakal kirim &8Nuclear Waste&r keluar dari &2&lFission Reactor&r. \\n\\n&bOutput Coolant&r bakal entah keluarin Steam kalo &9Air&r dipake sebagai &bCoolant&r atau kalo Sodium dipake bakal keluarin &6Superheated Sodium&r."]
	quest.5A088F8402230BA5.title: "&2Fission Reactor Port"
	quest.5A0EB2ADEBC7EE2B.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.5A17C762CDB680B5.quest_subtitle: "Tingkat: &63"
	quest.5A1AB1AD7DEFDD9A.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kekebalan"
		"- Padamkan Api"
		"- Elytra"
		"- Perlindungan Kematian"
		"- Terbang"
		"- Kekebalan Lava"
		"- Perlindungan Waktu"
	]
	quest.5A1DCD6C7F712A78.title: "Pancing Neptunium"
	quest.5A23107C363A209E.quest_subtitle: "Membuat berbagai Material End"
	quest.5A26738AC904DC39.quest_desc: ["13 Slot Mantra!"]
	quest.5A26738AC904DC39.title: "&6Allthemodium Spell Book"
	quest.5A2908437EC43AC6.quest_subtitle: "Tingkat: &54"
	quest.5A2A718C569F3C19.quest_desc: ["Dengan Melelehkan &0Batu Bara&r di &lCoke Oven&r bisa mendapatkan &0Coal Coke&r! Atau seperti yang akan disebut, hanya &0Kokas&r! \\n\\nPada dasarnya hanya &0Batu Bara&r tetapi memiliki lebih banyak kegunaan di &8&lIE&r. \\n\\nBisa menggabungkannya dengan Besi untuk mendapatkan &7Baja&r, Menghancurkannya untuk mendapatkan &0Debu Kokas&r yang akan diperlukan untuk &0Grafit&r, atau gunakan sebagai Bahan Bakar untuk Tungku Blast."]
	quest.5A2A718C569F3C19.title: "&8Kokas&r"
	quest.5A38E9F68570F7F3.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kecepatan Lari"
		"- Kecepatan Jalan"
		"- Kecepatan Berenang"
		""
		"Kemampuan Intrinsik:"
		"- Kemampuan Lava"
	]
	quest.5A4406F89DB802F0.quest_desc: ["Reaksi antara &#BB95CFStyrene&r dan &#D46C85Butadiene&r menghasilkan &#827AFFStyrene-Butadiene&r."]
	quest.5A4C9F7F81D6B9DB.quest_desc: ["&5Gravitational Modulating Additional &7Unit&r, kayak lo bisa liat dari namanya adalah upgrade ke &dGravitational Modulating &7Unit&r. \\n\\nKeduanya harus di-Install buat pake mereka! \\n\\nJadi apa Upgrade-nya? Ya lo bakal langsung berhenti pas lo berhenti pencet tombol Movement saat Terbang. Lo bisa naik lebih cepet! Bahkan bisa Terbang terus!"]
	quest.5A4C9F7F81D6B9DB.quest_subtitle: "Bodyarmor"
	quest.5A4C9F7F81D6B9DB.title: "&5Gravitational Modulating Additional &7Unit"
	quest.5A615BB74A5CD332.quest_desc: ["Pakai &aReprocessor&r, kita bisa gabungin semua yang sudah kita buat sejauh ini untuk bikin beberapa ingot baru.\\n\\nCatatan: Kamu mungkin butuh &9Fluidizer&r untuk ngelengkapin langkah ini!"]
	quest.5A615BB74A5CD332.title: "Ludicrite \\& Ridiculite"
	quest.5A62260FB3850092.quest_desc: ["Mencampur &eSulfur&r, &#6ACDE6Oksigen&r, dan &9Air&r akan memberimu &#D3D955Sulfuric Acid&r (Asam Sulfat). Ini akan digunakan untuk mengolah &7Manganese Dust&r."]
	quest.5A6670364ADE0858.quest_subtitle: "&f29 &cAttack Damage"
	quest.5A6831E0BD2F6AB5.quest_desc: ["Kamu butuh banyak banget &8Dark Gem&r!"]
	quest.5A6831E0BD2F6AB5.title: "2 &4Piercing Vengeance Focus"
	quest.5A6FF0D4BA894306.quest_desc: ["Poster child dari &6&lForbidden \\& Arcanus&r, &aEternal Stella&r. \\n\\nUntuk 1 &6Allthemodium&r Ingot, 3 &aXpetrified Orb&r, dan &2Stellarite Piece&r kita bisa bikin salah satu Item paling overpowered di Modpack ini! \\n\\nKamu bisa pakai &aEternal Stella&r dengan Item dan Apply Item Modifier untuk bikin Item kehilangan Durability mereka. Gak, tunggu maksudnya kehilangan kebutuhan Durability! Pada dasarnya Item yang Indestructible. \\n\\nIni bisa dipakai di hampir setiap Item dengan Durability dari &bDiamond Axe&r, ke Fishing Rod, bahkan &eRefined Glowstone Armor&r! \\n\\nAda beberapa limitasi, cuma kerja dengan Item dengan Durability bukan uses: seperti Infusion Crystal atau Energy: seperti Meka-Tool!"]
	quest.5A6FF0D4BA894306.title: "&aEternal Stella"
	quest.5A84A64CB3D3E6F5.quest_subtitle: "White Willow + Oak/Birch/Silver Lime"
	quest.5A8F4CA0F09F4842.quest_desc: ["Butuh hapus &dEnchantment&r dari item yang kamu temuin? Mungkin kamu mau hapus Curse? Ini bisa dilakuin pakai &cPurifier&r.\\n\\nBuat ini, pertama taro minimal 3 bucket darah ke Purifier, terus lempar item yang mau kamu hapus enchantment-nya.\\n\\nSelanjutnya, tambahin &cBlook&r. Blook bakal nyerap satu enchant dari item, dan ubah jadi buku enchant."]
	quest.5A8F4CA0F09F4842.title: "Menghapus &dEnchantment&r dan &dCurse"
	quest.5A9436B100FC1E67.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Panah Ramuan"
	]
	quest.5A94A2664BFDD7B9.quest_desc: ["Selamat datang di bab Penyimpanan Dasar!\\n\\nKamu akan menemukan berbagai cara dasar untuk menyimpan item tanpa butuh energi, serta item-item berguna untuk kebutuhan logistikmu!"]
	quest.5A94A2664BFDD7B9.title: "Penyimpanan Dasar"
	quest.5A955C0F53AED3ED.quest_desc: ["&bChain of Souls&r kerja mirip Grappling Hook. \\n\\nKamu bisa Klik Kanan buat kirim &bChain&r yang bakal narik kamu ke Block yang kamu tembak. Kamu bisa Klik Kanan lagi buat lepas. Plus ini punya Range 90 Block kurang lebih. \\n\\nBuat bikin kamu butuh &bTrapped Soul&r, 2 &5Tenacious Vine&r, dan &9Tenacious Petal&r. \\n\\nKamu bisa dapetin mob ini dari bunuh &9Lunar Monstrosity&r. "]
	quest.5A955C0F53AED3ED.title: "&bChain of Souls"
	quest.5A9B2246E33065A5.quest_desc: ["Mempengaruhi jumlah sarang (combs) yang dihasilkan lebah. Ada 4 tingkat: &aNormal&r, &9Medium&r, &dHigh&r, &cVery High&r. Kita mengincar &cVery High&r.\\n\\nSifat ini ditemukan pada KamikazBee dan BeeBee. BeeBee bisa ditemukan di dimensi The Other dan SANGAT mematikan. Jika tidak mau ambil risiko, gunakan KamikazBee.\\n\\nUntuk dapat KamikazBee, kamu butuh Bee Nest Helmet. Biarkan dirimu diserang mob saat pakai helm itu; ada peluang 30% KamikazBee akan muncul. Tangkap secepat mungkin sebelum ia menyengat musuhmu!"]
	quest.5A9B2246E33065A5.quest_subtitle: "Sifat terpenting"
	quest.5A9B2246E33065A5.title: "&a&lProduktivitas"
	quest.5A9C646718EE92C2.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_vibranium.png width:100 height:150 align:center}"]
	quest.5A9C646718EE92C2.title: "&3Vibranium&r"
	quest.5A9D6672385D3D82.quest_desc: ["Hanya butuh 1 Lapis untuk satu Upgrade, bukannya 4."]
	quest.5A9D6672385D3D82.quest_subtitle: "Hemat Lapis"
	quest.5AA3E5DFECB4AC4D.quest_desc: ["AE2 menyediakan cara untuk mempercepat pertumbuhan kristal secara drastis.\\n\\nLetakkan perangkat ini di sekitar Budding Crystal-mu, beri daya, dan lihatlah kristalmu tumbuh dengan cepat!"]
	quest.5AA3E5DFECB4AC4D.title: "Crystal Growth Accelerator"
	quest.5AA8D2A1F3618615.quest_subtitle: "Mengalirkan listrik"
	quest.5AAF6CA41209B365.title: "Peralatan &3Vibranium"
	quest.5AC1BE754210429E.quest_desc: ["Jika kamu ingin membuat tim untukmu dan teman-temanmu, gunakan perintah &a/ftbteams party create (nama tim)&r untuk membuat tim tersebut!"]
	quest.5AC497F76A086A5C.title: "&l&9Overworld Bounty:&r&e Witches"
	quest.5AC68C8A4024F4C9.quest_desc: ["&aEnergy &7Unit&r bisa dipake di semua &a&lMekaSuit Part&r bahkan &dMeka-Tool&r. \\n\\nKita bisa tambahin 8 ke tiap &eItem&r. Masing-masing nambahin lebih banyak &aEnergy Storage&r ke &eItem&r. \\n\\nGak, ini gak nambah &aEnergi&r yang udah ada di dalamnya. Gak ada yang namanya &aEnergi&r Gratis!"]
	quest.5AC68C8A4024F4C9.quest_subtitle: "Semua"
	quest.5AC68C8A4024F4C9.title: "&aEnergy &7Unit"
	quest.5ACE97EE75813006.quest_desc: [
		"Inilah sumber informasi utama mengenai &dRitual&r. Berikut dasarnya:"
		""
		"&lTingkatan Ritual&r:"
		""
		"Ritual (pada dasarnya) memiliki empat tingkat berdasarkan seberapa kuat Setan yang kamu panggil. Tingkat pertama adalah &eFoliot&r, lalu &aDijini&r, &cAfrit&r, dan &9Marid&r. Beberapa ritual berada di tingkat antara, seperti tingkat &6Unbound Afrit&r."
		""
		"&lJenis Ritual&r:"
		""
		"Ada lima jenis utama ritual, tapi kita hanya butuh empat untuk progres. Tiga yang utama adalah &9Ritual Pemanggilan&r, &5Ritual Perasukan&r, dan &6Ritual Infusi&r. Masing-masing akan dijelaskan saat pertama kali muncul di quest ini. Jenis keempat adalah semacam &dRitual Tanpa-Setan&r, artinya ia menggunakan bagian-bagian dari ketiga jenis tersebut untuk melakukan aksi spesial tanpa penggunaan Setan secara langsung."
		""
		"Jenis kelima, &eRitual Familiar&r, tidak diperlukan untuk progres. Tapi mereka tetap bisa memanggil teman-teman berguna untuk membantumu!"
		""
		"&lKapur (Chalks)&r:"
		""
		"Ada dua jenis Kapur: Foundation Chalk (Kapur Fondasi), dan Colored Chalk (Kapur Warna)."
		""
		"Kapur fondasi digunakan di setiap ritual, dan setiap tingkat yang lebih tinggi warnanya akan lebih gelap, dimulai dari White Chalk dan berakhir di Black Chalk. "
		""
		"Kapur warna adalah yang paling sering digunakan, tapi warnanya tidak secara langsung melambangkan kekuatannya seperti pada Kapur Fondasi."
	]
	quest.5ACE97EE75813006.title: "Dasar-Dasar Ritual"
	quest.5AD09CCEEDC0B50F.quest_desc: ["Nah, alat-alat ini sangat membantu, kamu harus benar-benar mencobanya! \\n\\nSumber cahaya aslinya adalah Feral Flare Lantern. Ia akan meletakkan sumber cahaya tak terlihat di sekitar radius 20 blok atau lebih di sekelilingnya. \\n\\nMega Torch berbeda: ia tidak memancarkan cahaya tetapi ia MENCEGAH semua pemunculan (spawn) Mob Agresif dalam radius 64 blok! Berguna bagi mereka yang menggunakan Night Vision. \\n\\nDread Lamp melakukan sebaliknya, ia mencegah pemunculan Mob Pasif di area yang sama."]
	quest.5AD09CCEEDC0B50F.title: "&l&eTorchmaster&r"
	quest.5AD80D3242DD3F60.quest_desc: ["Salah satu material paling susah didapat di mod ini!\\n\\nIni juga dipakai buat bikin &6ATM Star&r!"]
	quest.5AD80D3242DD3F60.title: "&dInsanite Block"
	quest.5ADFC45B03BAB852.quest_desc: ["Inilah gunanya Draconic Cores."]
	quest.5ADFC45B03BAB852.title: "Tier Draconic"
	quest.5AE80FF518B1BBA6.quest_desc: [
		"Lelah membawa-bawa Kapur, Lilin, Tengkorak, dan Kristal? Buat saja Ritual Satchel!"
		""
		"Dengan sneak + klik kanan saat memegang Ritual Satchel, kamu bisa mengisinya dengan semua material yang dibutuhkan untuk menggambar lingkaran ritual."
		""
		"Setelah tas terisi, cukup klik kanan pada blok preview mana saja untuk mulai (secara perlahan) menaruh semua rune untuk ritual yang dipilih secara otomatis. "
		""
		"Jika durabilitas kapur di dalam tas turun di bawah 40%, kilauan sihir pada item ini akan menghilang sebagai pertanda sudah waktunya memperbaiki atau mengganti kapurmu."
	]
	quest.5AE80FF518B1BBA6.quest_subtitle: "Ritual Saku!"
	quest.5AE80FF518B1BBA6.title: "Peralatan Profesi: Ritual Satchel"
	quest.5AE851B8074BC7E6.quest_subtitle: "Glowing + Chocolate Mining"
	quest.5AE851B8074BC7E6.title: "Redstone Crystal Bee"
	quest.5AEA705D6A64A982.quest_desc: ["Kalo lo punya &2&lFission Reactor&r kecil terutama buat &aPolonium&r maka kita harus pake ini sebagai fail safe sederhana! \\n\\n&aPolonium&r dibuat dengan &e&lSolar Neutron Activator&r. Lo mungkin bisa tau butuh &eSiang hari&r buat kerja! \\n\\nJadi, buat stop bottle-necking (yang bisa mematikan pas kita ngomongin &2&lReaktor&r) kita bisa matiin &2&lReaktor&r pas Malam! \\n\\nPertama, set &2FRLA&r ke Activation. Ini bakal nyalain &2&lReaktor&r pas ada &4Redstone Signal&r dan matiin pas gak ada. \\n\\nSekarang kita bisa taro &eDaylight Sensor&r dan sambungin ke &2FRLA&r dengan &4Redstone&r. \\n\\nTerus, boom, udah siap!"]
	quest.5AEA705D6A64A982.title: "Clock Switch"
	quest.5AEE86EB39FD4087.quest_desc: ["&3Vortex Tube&r memisahkan tekanan udara menjadi udara panas dan dingin. Udara dingin keluar ke sisi biru dan udara panas ke sisi merah."]
	quest.5AEE86EB39FD4087.quest_subtitle: "Tetap bukan RF..."
	quest.5AEE86EB39FD4087.title: "Produksi Panas"
	quest.5B013A3A37D6902B.quest_desc: ["Kamu bisa menemukan fragmen Ancient Knowledge tersebar di Chest &9Ancient City&r. \\n\\nKamu juga butuh &9Echo Shard&r untuk 1. Menggabungkan Fragment untuk belajar tentang &9Spell&r dan 2. Benar-benar membuat &9Spell&r."]
	quest.5B013A3A37D6902B.title: "Ke Ancient City"
	quest.5B02719C13B1FFE2.quest_desc: [
		"Kemampuan:"
		"- Ledakan Udara: Jarak luncur lebih ditingkatkan."
		"- Perpindahan Kegelapan: Jarak teleportasi ditingkatkan."
		"- Gerbang Gerhana: Membuat lubang portabel di area 3x3, arah tergantung pada sisi balok yang ditarget. Jarak lubang yang dibuat bisa dikonfigurasi. Perlu dicatat Gerbang Gerhana tidak bekerja pada entitas ubin."
	]
	quest.5B0FF8E0B58A4150.quest_subtitle: "Walnut + Wild Cherry"
	quest.5B114CE7192A0549.quest_subtitle: "Beech + Birch"
	quest.5B18676A77CD6069.quest_desc: ["Minggir &b&lAE2&r sama &3&lRS2&r! Kita punya &5&lMekanism&r! \\n\\n&e&lQuantum Item Orchestration&r (&e&lQIO&r) adalah storage &eItem&r Virtual. Kita butuh beberapa &eItem&r buat buka dan simpen &eItem&r di dalamnya sebelum bisa dipake! \\n\\nPertama, adalah jantungnya system, &e&lQIO Drive Array&r. Ini &5Mesin&r tempat semua lewat dan tersambung. \\n\\nGak butuh &aEnergi&r tapi kayak &a&lTeleporter&r sama &5&lQuantum Entangloporter&r harus diset ke Network! &eItem&r lain yang tersambung ke &e&lQIO Drive Array&r juga harus diset ke Network yang sama. \\n\\nBuat &eQIO Drive&r tinggal taro di dalam &e&lQIO Drive Array&r! "]
	quest.5B18676A77CD6069.quest_subtitle: "(QIO)"
	quest.5B18676A77CD6069.title: "&e&lQuantum Item Orchestration"
	quest.5B1E0E3E876339E7.title: "&4Armor Supremium"
	quest.5B2FD54E425D5C9D.quest_desc: ["Nah yang ini susah didapetin... kita harus bunuh 2 Boss dan Miniboss buat dapetin semua buat &dVoid &cForge&r. \\n\\nPertama, kita butuh &4Mechanical Fusion Anvil&r. Buat dapetin, kunjungi &4Ancient Factory&r yang ada di bawah &2&lOverworld&r. \\n\\nTerus, kasih makan &4&lThe Harbinger&r Nether Star buat nyalain dan bunuh! &4&lThe Harbinger&r bakal drop &4Witherite&r yang bisa Craft &4Mechanical Fusion Anvil&r. \\n\\nSelanjutnya, kita butuh &cInfernal Forge&r. Itu Drop dari &c&lNetherite Monstrosity&r. \\n\\nPergi ke &c&lThe Nether&r buat cari struktur &cSoul Blacksmith&r. Terus, fight dan bunuh &c&lNetherite Monstrosity&r buat dapetin &cInfernal Forge&r! \\n\\nTerakhir dan mungkin paling gampang adalah &dVoid Core&r. Untungnya gak di-drop Boss, tapi Miniboss! \\n\\nKunjungi &5&lThe End&r buat cari &dRuined Citadel&r, di dalam kamu bakal nemuin &dEnder Golem&r. Yang ini bakal drop &dVoid Core&r kita. \\n\\nSetelah kamu punya semuanya, pake &4Mechanical Fusion Anvil&r buat gabungin &cInfernal Forge&r dan &dVoid Core&r buat bikin &dVoid &cForge&r."]
	quest.5B2FD54E425D5C9D.title: "&dVoid &cForge"
	quest.5B36DE3826F26963.quest_desc: ["&dTenaga Rotasi&r adalah bagian terpenting sekaligus paling membingungkan dari &6&lCreate&r. \\n\\nSemua Mesin butuh &dTenaga Rotasi&r untuk bekerja, tapi apa itu dan bagaimana cara menggunakannya? \\n\\n&dTenaga Rotasi&r sederhananya adalah Mesin kita yang bergerak. Blok seperti Poros dan Roda Gigi akan menyalurkan &dTenaga Rotasi&r tersebut ke Mesin kita. \\n\\nBicara soal Poros, itulah awal dari &dTenaga Rotasi&r. Mereka bisa dipasang dalam garis lurus, berdampingan. \\n\\nKetika satu &8Poros&r bergerak, semua &8Poros&r yang terhubung dengannya (pada sumbu yang sama) akan ikut bergerak. \\n\\nBuat 2 &8Paduan Andesit&r untuk membuat 8 &8Poros&r."]
	quest.5B36DE3826F26963.title: "&d&lTenaga Rotasi"
	quest.5B4397D4EC23E702.quest_desc: [
		"Tempat sempurna bagi semua Prajurit Lebah! \\n\\nDi sini kamu bisa mengambil Stinger Spear dan buku sihir untuknya!"
		"{image:atm:textures/questpics/bumblezone/bumble_stingy.png width:200 height:100 align:center}"
	]
	quest.5B4397D4EC23E702.title: "Kuil Stinger Spear"
	quest.5B45AB96953FA61C.title: "Zaman Digital"
	quest.5B46B5BF4ADB2BE9.quest_desc: ["Tenang, alat ini juga bisa membuat jalan setapak (pathways)!"]
	quest.5B46B5BF4ADB2BE9.title: "&6Allthemodium &5Alloy &3Shovel"
	quest.5B4B5C148D63ACA1.quest_desc: [
		"&aForgotten Minion&r tidak muncul secara alami, mereka harus dibuat. Caranya dengan menaruh Carved Gloomgourd di atas sebuah &aBlock of Forgotten Ingot&r. \\n\\nMereka bertindak mirip Snow Golem, tidak akan pernah menyerangmu dan justru menembaki mob agresif. \\n\\nMereka punya 10 HP dan tidak menjatuhkan apa pun saat mati... tapi masa tega membunuhnya?"
		"{image:atm:textures/questpics/undergarden/undergarden_minion.png width:125 height:100 align:center}"
	]
	quest.5B4B5C148D63ACA1.title: "&aForgotten Minion&r"
	quest.5B50AC47957F0CD7.quest_desc: ["&7Oil Rig&r (Anjungan Minyak) akan mengebor &#7A7A7AShale Oil&r dan &#918686Crude Oil&r untukmu."]
	quest.5B50AC47957F0CD7.quest_subtitle: "Suara elang berkumandang"
	quest.5B52389583A70E66.quest_subtitle: "Tingkat: &c5"
	quest.5B556192F060F3F1.quest_desc: ["&5Refined Obsidian&r bakal penting buat banyak &eItem &fdan &5Mesin&r di &5&lMekanism&r terutama di &d&lUltimate Tier&r. \\nPertama, kita perlu &3Crush &5Obsidian&f buat dapat &5Obsidian Dust&r. Jelas kamu butuh &4&lCrusher&r buat itu. \\n\\nTerus, kita bisa pakai &9&lMetallurgic Infuser&r buat &9Infuse&f &5Obsidian Dust&r tadi pakai &bChemical Diamond&r. Aku saranin pakai &bEnriched Diamond&r biar hasilnya maksimal! \\n\\nSekarang kita punya pilihan mau diapain, antara di-&dEnrich&r biar dapat lebih banyak &5Chemical Refined Obsidian&r atau..."]
	quest.5B556192F060F3F1.title: "&5Refined Obsidian Dust"
	quest.5B5FC539BD1F4A73.quest_desc: [
		"Pylon ini berfungsi khusus untuk mencegah pemunculan (spawn) mob."
		""
		"Kamu bisa menggunakan Mob Filter untuk mencegah kemunculan mob tertentu saja, atau gunakan Lifeless Filter untuk menghentikan semua jenis mob!"
		""
		"Kamu bisa menumpuk beberapa Mob Filter untuk memblokir lebih banyak jenis mob. Selain itu, kamu bisa mengubah radius area kerja seberapa jauh ia memblokir pemunculan mob tersebut."
		""
		"Jika kamu menggunakan Lifeless Filter, ia akan mengabaikan semua pengaturan filter individu tersebut."
	]
	quest.5B5FC539BD1F4A73.title: "Pylon Pencegah Mob"
	quest.5B910F1389C0B915.quest_desc: [
		"Kemampuan:"
		"- Ledakan Udara: Jarak peluncuran ditingkatkan dan mengonsumsi FE."
		"- Perpindahan Kegelapan: Teleportasi pemain ke arah yang mereka lihat sambil mengonsumsi FE."
	]
	quest.5B969BF6F00A84D8.quest_subtitle: "Olahlah 6 Telur RuBee di Centrifuge untuk dapat 1 Telur Chromium Bee"
	quest.5B969BF6F00A84D8.title: "Chromium Bee"
	quest.5B9F3F32AB28A83A.quest_desc: ["Bagian dalam, dan yang penting, dari &6&lThermoelectric Boiler&r dibuat dari Blok keren! \\n\\n&6Superheating Element&r yang kerja transfer &6Panas&r ke &9Air&r dan &9Pressure Disperser&r yang bakal bantu bikin Steam! \\n\\nKalo kita pake Build yang lebih gede, kita bisa kasih ruang antara Blok yang beda di dalam &6&lBoiler&r buat kasih lebih banyak storage ke Steam sama &9Air&r. \\n\\nUdara antara Atas sama &9Pressure Disperser&r bakal nambah Steam Storage. Udara antara &9Pressure Disperser&r sama &6Superheating Element&r bakal kasih lebih banyak ruang buat &9Air&r."]
	quest.5B9F3F32AB28A83A.title: "Bagian Thermo dari &6&lThermoelectric Boiler"
	quest.5B9F933ECD6B24FD.quest_desc: ["Memungkinkanmu melompat lebih tinggi daripada Tingkat II."]
	quest.5B9F933ECD6B24FD.quest_subtitle: "Maks: 1"
	quest.5BA84F6282D9CAF1.quest_desc: ["&6Allthemodium Armor&r tapi dengan buff untuk mantra &e&lIron's Spells&r!"]
	quest.5BA84F6282D9CAF1.quest_subtitle: "24"
	quest.5BA84F6282D9CAF1.title: "&6Allthemodium Mage Outfit"
	quest.5BA986D7928BF09F.quest_desc: ["Piglich adalah bos yang ditambahkan oleh &6&lAllthemodium&r. \\n\\nIa punya 1000 Heart dan saat ini belum punya serangan khusus, tapi percayalah saat ia punya nanti, serangannya akan sangat mematikan! \\n\\nSaat terbunuh, ia akan menjatuhkan jantungnya (Heart) yang dibutuhkan untuk pembuatan Alloy dan ATM Star! \\n\\n(Cari cara untuk melakukan farming bos ini, misalnya dengan HNN atau EnderIO!)"]
	quest.5BA986D7928BF09F.title: "Bos Piglich"
	quest.5BB7648DC10E1E08.quest_desc: ["&bUltra Exporter&r memiliki 36 slot filter, bekerja 5x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.5BB7648DC10E1E08.title: "&bUltra Exporter"
	quest.5BB887411B8B38FA.quest_desc: ["Mengenai perluasan jaringan ME secara nirkabel, langkah pertamanya mungkin agak tidak biasa.\\n\\n&bMatter Condenser&f adalah tempat pembuangan barang versi AE2 yang menghancurkan item apa pun. Saat dipasangi &eStorage Component&f, ia bisa menghasilkan dua item crafting spesial dari energi item yang dimusnahkan.\\n\\nItem pertama adalah &bMatter Ball&f, membutuhkan setidaknya komponen penyimpanan 1k dan 256 item yang dimusnahkan."]
	quest.5BB887411B8B38FA.title: "Condensed Matter"
	quest.5BBE8B30ED7518B8.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penambang Bijih"
		"- Pemindai Bijih &4&lDINONAKTIFKAN&r&f"
	]
	quest.5BC4250E4C9F803C.title: "&9Lahan Pertanian Imperium"
	quest.5BC6CC3C09F512A7.quest_desc: [
		"Reactor Core adalah bagian terpenting dari Reactor, IE Core! Tempatkan 5 block atau lebih dari Injector dan Stabilizer, dan kamu bisa klik kanan untuk melihat GUI-nya di sini kamu akan menemukan beberapa bar, bola, tombol, dan slot. Bar dari kiri ke kanan: Heat, Containment Field, Energy Saturation, dan Fuel Conversion. Kamu sudah belajar tentang Field dan Energy dan akan belajar tentang Fuel di quest berikutnya. Jadi Heat cukup penting karena saat warming up akan naik ke 2000C sebelum siap untuk activate. Pastikan tidak terlalu tinggi atau... meltdown! Bola adalah gambar Core-mu, sekarang aku punya bug di mana Core tidak punya texture jadi tidak bisa jelasin banyak. Tombol mengubah tampilan GUI, untuk activate atau shutdown Reactor, dan charge-nya."
		"{image:atm:textures/questpics/draconic/draconic_reactor_off_down.png width:200 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_reactor_off_up.png width:150 height:150 align:1}"
	]
	quest.5BC6CC3C09F512A7.quest_subtitle: "KEKUATAN TAK TERBATAS"
	quest.5BC6CC3C09F512A7.title: "Membangun Reactor"
	quest.5BCA3F716348ECCD.quest_desc: ["&9Energy Hopper&r akan mengisi daya item apa pun yang bisa diisi dayanya di dalam inventaris blok yang dituju, seperti sebuah peti."]
	quest.5BD22081ED81BCC6.quest_desc: ["&9Urchinkin&r adalah hama kecil yang entah kenapa tinggal di &9Acropolis&r. \\n\\nMereka punya 6 &4HP&r tanpa armor. Untungnya cukup lemah. \\n\\nMereka punya beberapa serangan; jika dekat mereka akan memukulmu. Jika jauh mereka akan menggelinding ke arahmu. Saat menggelinding, banyak &9Spike (Duri)&r akan ditembakkan, melukai siapa pun yang terkena! \\n\\nSaat mati mereka tidak menjatuhkan sesuatu yang unik. Selain duri tambahan untuk melukaimu, itu saja."]
	quest.5BD22081ED81BCC6.title: "&9Urchinkin"
	quest.5BD5737703F3F077.quest_desc: ["Ferricore adalah material baru yang ditambahkan oleh JDT. Ferricore didapatkan dengan melakukan Penyebaran Lendir pada Balok Besi menggunakan lendir tingkat satu atau lebih tinggi. Bijih Ferricore dipengaruhi oleh keberuntungan."]
	quest.5BD5737703F3F077.title: "Ferricore"
	quest.5C040191740A53C8.quest_desc: [
		"Yang Mulia, sang &5Bee Queen&r (Ratu Lebah).\\n\\nSeekor lebah berukuran raksasa, saking besarnya ia bahkan tidak bisa bergerak sendiri.\\n\\nSaat bertemu dengannya, ia akan meminta item tertentu padamu. Jika kamu memberikannya, kamu akan diberi hadiah spesial.\\n\\nJuga sekarang setelah bertemu dengannya, kamu bisa berdagang dengannya (cek JEI untuk semua daftar dagangan) dan kamu bisa melakukan misi keinginannya.\\n\\nUntuk maju lebih jauh di Bumblezone kamu akan butuh Bee Essence yang didapat dari menyelesaikan semua 16 misinya.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_queen.png width:200 height:100 align:center}"
	]
	quest.5C040191740A53C8.title: "&5Yang Mulia Ratu"
	quest.5C0F6B1C93A52113.quest_desc: ["Nah, inilah jantung asli dari &c&lLaserIO&r! &cLaser Node&r adalah tempat di mana Kartu-kartu akan dimasukkan agar bisa bekerja. \\n\\nMereka akan memindahkan item dari inventaris mana pun yang menempel di 4 arah mata angin serta Atas dan Bawah. Untuk memindahkan ke inventaris yang lebih Jauh, kamu butuh &cNode&r kedua dan hubungkan keduanya dengan Wrench dengan cara Shift + Klik Rikan pada Node pertama dan Klik Kanan pada Node kedua. \\n\\nKamu masukkan Kartu ke dalam slot arah yang benar, dan kamu juga bisa memasukkan Node Overclocker di sana agar bekerja lebih cepat. "]
	quest.5C0F6B1C93A52113.title: "&cLaser Node"
	quest.5C22E3103544B120.quest_desc: ["&eME Glass Cable&f adalah jenis kabel yang paling dasar. Glass cable dan &ecovered&f cable dapat menampung hingga 8 channel. Varian &edense&f covered cable dapat menampung hingga 32 channel, tetapi perangkat seperti bus tidak bisa langsung dipasang padanya.\\n\\nSemua kabel dapat di-craft dengan pewarna. Kabel tanpa warna ('Fluix') bisa terhubung ke warna apa pun, namun kabel dengan warna berbeda tidak akan pernah saling terhubung."]
	quest.5C22E3103544B120.title: "Kabel Dasar"
	quest.5C26EBA2F58F28F1.quest_subtitle: "Red Delicious Apple + Cherry"
	quest.5C2B30655A44227F.quest_desc: ["Oh, apa kamu pikir &5&lEternal Starlight&r akan membiarkanmu mendapatkan semua logam ini dengan cara mudah? \\n\\nHA! jangan konyol. Kamu harus melawan Bos, menggali lumpur, dan mencari Hujan Meteor!"]
	quest.5C2B30655A44227F.title: "Logam &5&lEternal Starlight&r"
	quest.5C2C29ECA67F9B49.quest_desc: [
		"Dengan Lifeless Filter, kamu tidak perlu khawatir lagi akan adanya mob yang muncul dalam area 25x25 Chunk."
		""
		"Namun, ini tidak termasuk pemunculan paksa (Forced Spawns), yaitu mob yang muncul dari Spawner atau dari Telur Spawn (Spawn Egg)!"
		""
		"Radius 25x25 ini mencakup seluruh jarak kemunculan mob di sekitar pemain, baik yang agresif maupun pasif."
		""
		"Ini juga mencakup setiap tingkat ketinggian (Y Level), baik di atas maupun di bawah Pylon, jadi tidak perlu pusing lagi menerangi goa-goa gelap! "
		""
		"Tidak ada sistem Whitelist untuk filter ini; ia akan mencegah pemunculan mob apa pun tanpa kecuali."
	]
	quest.5C2C29ECA67F9B49.quest_subtitle: "Akhirnya tenang dan damai. "
	quest.5C2C29ECA67F9B49.title: "Lifeless Filter"
	quest.5C2CF51D28F84CBE.quest_desc: [
		"Sekarang pertarungan sebenarnya dimulai, dia punya dua health bar keduanya perlu turun ke 0 untuk dapat Chaos Shards. Jangan terlalu dekat atau dia akan memukulmu dengan serangan Fireball! {BTW di versi lama Chaos Guardian bahkan bisa membunuh seseorang di mode Creative! Untungnya sekarang tidak bisa lagi}"
		"{image:atm:textures/questpics/draconic/draconic_guardian.png width:150 height:100 align:1}"
	]
	quest.5C2CF51D28F84CBE.title: "Kalahkan Chaos Guardian"
	quest.5C3FF43CF16BCF30.quest_desc: ["Dengan Source Gem, kamu bisa mulai membuat berbagai mesin dengan menciptakan &5Sourcestone&r."]
	quest.5C3FF43CF16BCF30.quest_subtitle: "Dulu bernama \"Arcane Stone\""
	quest.5C3FF43CF16BCF30.title: "Sourcestone"
	quest.5C47935A3B2877FF.quest_desc: ["Mekanism menawarkan Kabel yang tampilannya bagus untuk mentransfer daya.\\n\\nJika mesin yang kamu hubungkan sudah otomatis menarik atau mendorong daya, kamu tidak perlu mengonfigurasi kabelnya. Jika tidak, kamu butuh &9Configurator&r. Shift+klik kanan akan mengubah kabel ke mode pull (tarik) atau push (dorong)."]
	quest.5C47935A3B2877FF.quest_subtitle: "Pipa Transfer Energi Mekanism"
	quest.5C47935A3B2877FF.title: "&9Mekanism: &aUniversal Cables"
	quest.5C5546A5103BCF55.quest_desc: ["Yang satu ini seharusnya menembakkan Kimia seperti &bCairan&r atau Gas... tapi tidak akan melakukannya untukku. \\n\\nBisa menampung 2 Upgrade setidaknya! Itu berfungsi!"]
	quest.5C5546A5103BCF55.title: "&b&lPelempar Kimia"
	quest.5C590DB2F3D935E5.quest_desc: ["Seed Reprocessor bisa ngubah benih essence balik jadi essence."]
	quest.5C590DB2F3D935E5.quest_subtitle: "Daur Ulang!"
	quest.5C6709350BEF4050.quest_desc: [
		"Lendir Voidshimmer adalah tingkat ketiga dari lendir yang ditambahkan oleh JDT dan membutuhkan material Akhir untuk kerajinan."
		""
		"Kerajinan yang Terbuka:"
		"- Celestigem"
		"- Api Kegelapan"
	]
	quest.5C6C4AD0F60BECCA.quest_desc: ["&eKhopesh&r adalah senjata sekaligus drop dari &eKoboleton&r. \\n\\nDamagenya sama dengan Pedang Besi (Iron Sword) tapi tidak bisa diberi mantra atau diperbaiki. \\n\\nSepertinya mereka memang tidak ingin kamu memakainya lama-lama..."]
	quest.5C6C4AD0F60BECCA.title: "&eKhopesh"
	quest.5C73247A48E72FB3.quest_desc: ["Jika kamu ingin menghapus &5Enchant&r tertentu dari daftar &5Enchantment Pool&r, kamu bisa menggunakan &bRak Buku&r ini di setup &5Enchanting&r-mu! \\n\\nLetakkan &5Enchantment Book&r yang ingin kamu 'blacklist' ke dalam slot kosong di &bSeashelf&r ini. \\n\\nNantinya, saat kamu melakukan &5Enchant&r, &5Enchantment&r tersebut tidak akan muncul pada item atau buku."]
	quest.5C73247A48E72FB3.title: "Hapus Enchantment dari Daftar"
	quest.5C7D9BCDF19B86BD.quest_desc: ["Mencegah segala sesuatu meledak."]
	quest.5C7D9BCDF19B86BD.quest_subtitle: "Aman!"
	quest.5C83D5CDD980FD9A.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_snout.png width:100 height:150 align:center}"]
	quest.5C83D5CDD980FD9A.quest_subtitle: "Bastion Remnants"
	quest.5C83D5CDD980FD9A.title: "Snout Armor Trim"
	quest.5C983A41886A2B75.quest_desc: ["Untuk kembali ke &2&lOverworld&r, kita bisa keluar dengan cara yang sama saat datang! \\n\\nGunakan &9Heart of the Deep&r pada Frame dari &8Reinforced Deepslate&r. \\n\\nUntungnya kita dapat salah satunya di bagian bawah &6Ancient Temple&r."]
	quest.5C983A41886A2B75.title: "Rumah, Rumah Manis!"
	quest.5C990F7E5D345A6F.quest_desc: [
		"Offering to the Gods adalah struktur multiblock yang terbuat dari 1 Offering Table dan 36 Bunga. Untuk memberikan persembahan, kamu butuh Spirits of Calling.\\n"
		"{image:atm:textures/questpics/natures_aura/offering.png width:295 height:150 align:center}"
	]
	quest.5C990F7E5D345A6F.quest_subtitle: "Mempersembahkan Birdbath kepada para dewa di tengah hutan bunga"
	quest.5C990F7E5D345A6F.title: "Persembahan untuk Dewa"
	quest.5CAC395680027354.quest_desc: ["&bInterdimensional Wireless Transmitter&r adalah versi upgrade dari transmitter biasa yang memiliki jangkauan tak terbatas, bahkan lintas dimensi."]
	quest.5CAC395680027354.quest_subtitle: "Intinya: Wifi Spek Dewa"
	quest.5CAC395680027354.title: "&dInterdimensional Wireless Transmitter"
	quest.5CBA8C89FE717B9C.quest_desc: ["Dengan &8Giant's Pickaxe&r (Beliung Raksasa), pergilah kembali ke Troll Cave untuk menemukan &5Giant Obsidian&r.\\n\\nGunakan &8Giant's Pickaxe&r untuk menghancurkannya, dan kamu akan menemukan beberapa loot. Dapatkan &6Lamp of Cinders&r untuk melanjutkan."]
	quest.5CBA8C89FE717B9C.title: "&6Lamp of Cinders"
	quest.5CC9CB0911954215.quest_desc: ["Reed Nest bisa diletakkan di biome Overworld mana pun, dan akan menarik Mason Bee atau Reed Bee."]
	quest.5CC9CB0911954215.quest_subtitle: "Memancing lebah di biome Overworld mana pun"
	quest.5CCF573B67317591.quest_desc: ["&bGlowing Roots&r tumbuh di &bBlooming Caverns&r. \\n\\nMereka tidak bisa Dipanjat dan tidak drop Makanan... Kurasa mereka hanya untuk dekor."]
	quest.5CCF573B67317591.title: "&bGlowing Roots"
	quest.5CCF92238B23EDC9.quest_desc: [
		"&#A0DE45&nModern Industrialization&r adalah mod yang mirip dengan &#D93D3DIC2&r dan &#D93D3DGregTech&r secara konsep, tetapi kamu harus berprogres dengan cara yang berbeda dari kedua mod tersebut."
		""
		"Melalui rangkaian quest ini, aku akan memandumu membuat komponen yang dibutuhkan untuk &#E8C843AllTheMods Star&r dan nantinya &#43E898Infinity Armor&r."
	]
	quest.5CCF92238B23EDC9.quest_subtitle: "Membaca panduan akan sangat membantu"
	quest.5CCF92238B23EDC9.title: "&#A0DE45Selamat Datang di Modern Industrialization"
	quest.5CD0E6F349F2F32D.quest_desc: ["Jangan takut, ini bukan hantu, ini Edelwood yang sudah tumbuh penuh! \\n\\nTree akan punya Carved Edelwood Log di atas dan Edelwood Branch keluar darinya, ini bisa dipecah untuk Edelwood Stick. \\n\\nLog-nya hollow di dalam, space mirip Cauldron. Lucunya juga bisa tahan Air seperti Cauldron!"]
	quest.5CD65553EF60029B.quest_desc: ["Skyseeker's Pickaxe menteleportasikan blok yang ditambang langsung ke dalam inventaris pemain."]
	quest.5CD65553EF60029B.quest_subtitle: "Tingkat: &54"
	quest.5CD8D169181C7339.quest_desc: ["Tiga item terakhir ini lebih ke arah mainan tambahan dari AE2.\\n\\n&bCharged Staff&f adalah tongkat bertenaga untuk menyerang (3 heart damage) yang mengonsumsi 300AE tiap pukulan. Alat ini menggunakan mekanik combat lama (pre-1.9), jadi kamu bisa melakukan spam-klik.\\n\\n&bEntropy Manipulator&f dapat digunakan untuk melelehkan blok di tempat, seperti pasir menjadi kaca atau bijih menjadi ingot. Jika tidak bisa dilelehkan, ia akan membakarnya.\\n\\n&bMatter Cannon&f berfungsi untuk menembakkan 'amunisi' seperti Matter Ball atau nugget emas/besi untuk menyerang mob atau menghancurkan blok. Kamu juga bisa menggunakan &bPaint Ball&f atau &bLumen Paint Ball&f untuk efek percikan cat (dan cahaya)."]
	quest.5CD8D169181C7339.quest_subtitle: "Peralatan Unik"
	quest.5CD8D169181C7339.title: "Senjata...?"
	quest.5CE44C58A470E48E.quest_desc: ["&l&3Artifacts&r adalah mod luar biasa yang menambahkan &l&3Artifact&r untuk membuat pengalaman Minecraft kamu jauh lebih mudah dan seru!\\n\\nSemua &l&3Artifact&r bisa ditemukan lewat eksplorasi, arkeologi, atau dengan membunuh Mimic!\\n\\nMimic ditemukan di perkemahan (Campsite) bawah tanah, bentuknya mirip Chest biasa! Tapi kalau kamu terlalu dekat, mereka bakal menyerang!"]
	quest.5CE44C58A470E48E.title: "&l&3Artifacts"
	quest.5CE7756D80E051CC.quest_desc: ["Biasanya &8Soul Sand&r bakal bikin lo lambat. Biasanya... \\n\\nPake &8Soul Surfer &7Unit&r lo bakal jalan normal di &8Soul Sand &fdan &8Soil&r. \\n\\nPake beberapa lagi lo bakal jalan lebih cepet di &8Soul Sand &fdan &8Soil&r daripada di Blok lain! \\n\\nHei, mungkin jalan dari &8Soul Sand&r bukan ide buruk lagi..."]
	quest.5CE7756D80E051CC.quest_subtitle: "Sepatu"
	quest.5CE7756D80E051CC.title: "&8Soul Surfer &7Unit"
	quest.5CF2A069A3CC4EF6.quest_subtitle: "Resin + Reed"
	quest.5CF2A069A3CC4EF6.title: "Silky Bee"
	quest.5CF320E9C4C1B1E1.quest_desc: ["ATM10 adalah pack &aKitchensink&r, artinya bebas untuk explore dan bermain modpack dengan cara apapun!\\n\\nNamun, ada tujuan endgame: Membuat &6ATM Star&r!\\n\\nQuestline ini berfungsi sebagai panduan untuk semua pemain, baik yang baru di Minecraft atau sudah bermain pack ATM sebelumnya.\\n\\nSeperti hampir setiap modpack, kumpulkan wood untuk memulai!"]
	quest.5CF320E9C4C1B1E1.title: "&eSelamat Datang di Getting Started&r!"
	quest.5CFBA24B3E0CDEDD.quest_desc: [
		"Sambil memegang Spellbook, kamu bisa menekan tombol C untuk membuka halaman pembuatan mantra. \\n\\nSetiap mantra harus memiliki 'form'. Kamu memulai dengan 3 form dasar: Projectile, Self-cast, dan Touch. \\n\\nUntuk bagian 'Effect', ini menentukan apa yang terjadi saat mantra dirapal. Kamu bisa memasang hingga 9 efek per mantra. \\n\\nSebagai permulaan, kamu punya efek Harm dan Break. \\n\\nPilih satu Form dan satu Effect, beri nama mantramu, lalu klik create!"
		""
		"{image:atm:textures/questpics/ars/spellbook.png width:200 height:150 align:1}"
	]
	quest.5D229FA3A5F92954.quest_desc: [
		"&4Muncher&r mirip dengan mob agresif lainnya di &2&lUndergarden&r, tapi hasil drop item-nya membuat mereka jauh lebih berguna! \\n\\nMuncher bisa menjatuhkan nugget &7Cloggrum&r dan &bFroststeel&r saat mati."
		"{image:atm:textures/questpics/undergarden/undergarden_muncher.png width:100 height:100 align:center}"
	]
	quest.5D229FA3A5F92954.title: "&4Muncher&r"
	quest.5D404ED40C6C2690.quest_subtitle: "Masukkan lebih banyak tenaga"
	quest.5D46EEC88D662443.quest_subtitle: "&f9 &cAttack Damage"
	quest.5D4E51471F3939E0.quest_desc: [
		"Kemampuan:"
		"- Ledakan Udara: Meluncurkan pemain ke arah yang mereka hadapi sambil mengonsumsi ketahanan, tongkat tingkat lebih tinggi meluncurkan pemain lebih jauh. Perlu dicatat pemain tidak akan terkena kerusakan jatuh selama mereka memegang tongkat."
	]
	quest.5D5563142917495A.quest_desc: ["&l&eFarmer's Delight&r adalah tentang bertani dan memasak item makanan! Kita juga bisa menggunakan item yang sama untuk dekorasi dan kegunaan! \\n\\nKompor, panci, dan penggorengan sangat sempurna untuk Dapur. \\n\\nTong makanan sangat bagus untuk gudang makanan (pantry). \\n\\nBarang pertanian sangat bagus untuk dekorasi luar ruangan dan lemari kabinetnya cocok untuk di mana saja!"]
	quest.5D5563142917495A.title: "&l&eFarmer's Delight&r"
	quest.5D64250B940BC8FD.quest_desc: ["Compressed Iron dapat digunakan untuk men-craft &3Compressed Iron Armor&r, fungsinya sama dengan Iron Armor tapi dengan Armor Toughness dan Knockback Resistance yang lebih baik.\\n\\nArmor ini bisa dibuat atau sering ditemukan di dalam peti loot."]
	quest.5D64250B940BC8FD.quest_subtitle: "Ketahanan Knockback Hebat"
	quest.5D64250B940BC8FD.title: "Armor Compressed Iron"
	quest.5D6A4E574823446F.quest_desc: [
		"Semua &8Troll&r bakal punya 500 &4Hearts &fdan 10 &7Armor Points&r. \\n\\nMereka bakal ayunin &8Senjata&r mereka ke kamu buat kasih Damage dikit, tapi kalo mereka gak bisa sampe kamu mereka bakal pukul Tanah pake &8Senjata&r mereka buat kasih lebih banyak Damage dan Knockback! \\n\\nUntungnya &8Troll&r punya kelemahan! Kayak Troll di dunia nyata, mereka benci &eMatahari&r dan bakal jadi &7Batu&r pas kena. Kalo aja gak selalu &9Malam&r di &b&lThe Other&r. \\n\\nSemua &8Troll&r sekitar 4 Blok Tinggi dan punya Gading dengan Mata Bercahaya. Mereka juga semua bisa pegang &8Kapak Troll &fdan &8Palu&r. \\n\\n&8Troll Hutan&r punya Kulit Abu-abu tanpa rambut tapi Mata Kuning. Mereka bakal pegang, selain &8Kapak &fdan &8Palu&r, &8Kolom Batu Berlumut&r dan &8Batang Pohon&r. Ini spawn di &cHutan Crimson Kuno&r. \\n&8Troll Es&r punya Kulit Biru Muda/Abu-abu, dengan rambut Putih. Mereka juga bakal pegang &8Batang Pohon Beku&f dan &8Kolom Beku&r sebagai Senjata. Spawn di &bHutan Warped Kuno&r. \\n\\n&8Troll Gunung&r keliatan kayak versi lebih cerah dari &8Troll Hutan&r, tapi yang ini bakal pegang &8Kolom Batu&r biasa dan gak bakal pegang &8Batang Pohon&r. Ini spawn di Bioma &3The Other&r."
		"{image:atm:textures/questpics/iceandfire/iaf_troll.png width:100 height:200 align:center}"
	]
	quest.5D6A4E574823446F.title: "&8Troll"
	quest.5D71589555637DB0.quest_subtitle: "Berikan bijih Anglesite ke Draconic Bee"
	quest.5D71589555637DB0.title: "Anglesite Bee"
	quest.5D71ED16FD4E725A.quest_desc: ["Membuat Piglin menjadi pasif (sama seperti memakai Gold Armor), kamu hanya perlu memasang upgrade ini di satu bagian armor saja."]
	quest.5D71ED16FD4E725A.quest_subtitle: "Maks: 1"
	quest.5D74D73092ACD2F2.quest_desc: ["&5Coral Golem&r muncul di dalam &5Sunken City&r. \\n\\nMereka mirip dengan versi besarnya, &5Coralssus&r, tapi HP-nya lebih sedikit yaitu 110 dan tidak bisa ditunggangi &5Deepling&r. \\n\\nTapi mereka punya lebih banyak serangan! Seperti melompat dan menghantam tanah di dekatmu, atau sekadar memukul. \\n\\nSaat mati mereka menjatuhkan Crystallized Coral Fragment, yang bisa dibuat menjadi Crystallized Coral untuk bahan &5Abyssal Sacrifice&r."]
	quest.5D74D73092ACD2F2.title: "&5Coral Golem"
	quest.5D7B34761E8FD212.quest_desc: [
		"&3Electrostatic Compressor&r menghasilkan banyak tekanan udara dari Sambaran Petir.\\n\\nUntuk info lebih lanjut cek tab \"Information\" di JEI.\\n"
		"{image:pneumaticcraft:textures/patchouli/electrostatic_compressor.png width:100 height:100 align:left fit:true}"
	]
	quest.5D7B34761E8FD212.title: "Tekanan dari Petir"
	quest.5D82340E9BED9C79.quest_desc: ["Relic ini dapat ditemukan di dimensi &dThe End&r!"]
	quest.5D82340E9BED9C79.title: "&dThe End"
	quest.5D87088E8D71DB9B.quest_desc: ["IO Crystals bekerja sebagai block yang bisa terhubung satu sama lain dan memindahkan power dari satu ke yang lain. Untuk menghubungkan mereka Shift Klik Kanan dengan Crystal Binder untuk mengatur satu lalu klik kanan Crystal mana pun yang ingin kamu hubungkan. Saat kamu melihat Crystal akan mengatakan Input from block atau Output to block. Input adalah yang kamu ingin ambil OP darinya dan Output ke tempat kamu ingin pergi."]
	quest.5D87088E8D71DB9B.title: "Memindahkan OP"
	quest.5DC892BA79EB52EC.quest_desc: ["&6Pengaduk&r bisa melakukan beberapa Resep berbeda tapi semuanya butuh &8Wadah&r di bawahnya! \\n\\nKita bisa &6Mencampur&r, menggabungkan &bCairan&f dan &eItem&f menjadi &eItem&r baru. Seperti memasak kue! \\n\\n&6Penyulingan&r bisa menggabungkan &bCairan&f dan &eItem&r yang tepat untuk membuat Ramuan Cair. Kemudian bisa diciduk ke dalam Botol Kosong untuk mendapatkan Ramuan. Kamu butuh panas dari &cPembakar Blaze&r untuk &6Menyuling&r. \\n\\nTerakhir adalah &6Pembuatan Tanpa Pola Otomatis&r. Bagi pemain biasa ini mungkin terdengar membingungkan tapi percayalah nggak sesulit itu. Pembuatan Tanpa Pola adalah Resep yang bisa dibuat dengan bahan dalam urutan apapun. \\n\\nSeperti Mewarnai Wol — Pewarna dan Wol bisa berada di mana saja di Meja Kerajinan. Atau bahkan bagian dan pola Silent Gear!"]
	quest.5DC892BA79EB52EC.title: "&6Pengaduk Mekanik"
	quest.5DCDDC346359DF28.quest_subtitle: "Balsa + Dark Oak"
	quest.5DD6631F5996BA71.quest_desc: ["&9Kincir Air&r adalah generator &dTenaga Rotasi&r otomatis yang sederhana. \\n\\nCukup pasang, lalu biarkan &9Air&r mengalir melewatinya ke arah tertentu. Kalau mengalir dari kedua sisi, tidak akan bergerak — arah aliran &9Air&r menentukan arah &dRotasi&r &9Kincir Air&r. \\n\\n&9Kincir Air&r biasa hanya berukuran 1 Blok dan memberikan sedikit Kecepatan dengan Satuan Stres minimal. \\n\\n&9Kincir Air Besar&r membutuhkan area 3x3 dan memberikan lebih banyak Satuan Stres, tapi dengan Kecepatan lebih rendah. \\n\\nKamu bisa menggunakan keduanya bersama untuk mendapatkan Satuan Stres dan Kecepatan yang setara!"]
	quest.5DD6631F5996BA71.title: "&9Kincir Air"
	quest.5DDC15AAFD2CAF47.quest_desc: ["&bDiamond Armor&r adalah langkah selanjutnya dalam rantai &l&2Vanilla&r, di fase inilah biasanya kita mulai memberikan Enchantment! \\n\\nAku sarankan Protection dan berbagai variannya; kita nggak perlu pilih-pilih kalau pakai mod!"]
	quest.5DDC15AAFD2CAF47.quest_subtitle: "20"
	quest.5DDC15AAFD2CAF47.title: "&bDiamond Armor"
	quest.5DE3F2A96715BA2E.quest_desc: [
		"&e&lSilo&r adalah Multiblok yang dibuat untuk menyimpan banyak hanya satu jenis &eBarang&r, seperti Laci. \\n\\nBisa &9menyimpan&r &eBarang&r dan duplikatnya di Sisi Atas atau Sisi Bawah, tetapi untuk &6mengekstrak&r perlu menggunakan Sisi Bawah! \\n\\nBisa menampung 41.472 &eBarang&r, hanya dari jenis yang sama."
		"{@pagebreak}"
		"Pertama letakkan kotak Pagar Kayu yang Diolah dengan &7Lembar Besi&r di tengah."
		"{image:atm:textures/questpics/immersive/immersive_silo1.png width:125 height:100 align:center}"
		"Selanjutnya, buat kotak penuh &7Lembar Besi&r di atas Pagar, sambil meninggalkan ruang di tengah berongga. Lakukan ini 5 kali!"
		"{image:atm:textures/questpics/immersive/immersive_silo2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo4.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo5.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/immersive/immersive_silo6.png width:100 height:100 align:center}"
		"Kemudian, lapisan terakhir yang merupakan seluruh kotak &7Lembar Besi&r, termasuk mengisi Blok tengah."
		"{image:atm:textures/questpics/immersive/immersive_silo7.png width:100 height:100 align:center}"
		"Setelah itu, Klik Kanan &7Lembar Besi&r Tengah pada lapisan kedua dengan &6Palu&r untuk membuat &e&lSilo&r!"
		"{image:atm:textures/questpics/immersive/immersive_silo.png width:100 height:125 align:center}"
	]
	quest.5DE3F2A96715BA2E.title: "&l&eSilo"
	quest.5DE45BC0258D1B0B.quest_desc: ["&dPearlescent Endshelf&r adalah &7Rak Buku&r yang lumayan oke, terutama mengingat harganya. \\n\\nRak ini dibuat dengan menggabungkan sebuah &dEndshelf&r dengan 4 &7End Rod&r dan 2 &3Ender Pearl&r. \\n\\nRak ini memberikan batas maksimal &aEterna 90&r, tapi ini bukan yang kita cari untuk setup &5Enchanting&r maksimal."]
	quest.5DE45BC0258D1B0B.title: "&dPearlescent Endshelf"
	quest.5DE7C4FD5FA29236.quest_desc: ["Sebel nggak sih pas mau bunuh Enderman eh dia malah teleportasi? Nah, sekarang jangan sebel lagi, jadilah seperti mereka! \\n\\nDengan &5Chorus Belt&r, kamu bisa melakukannya! Kamu akan berteleportasi jika terkena serangan yang seharusnya membunuhmu."]
	quest.5DE7C4FD5FA29236.quest_subtitle: "Sabuk"
	quest.5DE7C4FD5FA29236.title: "&5Chorus Belt&r"
	quest.5DE863C3FB6492BE.quest_desc: ["{image:atm:textures/questpics/iron_spells/spells_outfit_cultist.png width:60 height:100 align:center}"]
	quest.5DE863C3FB6492BE.title: "&4Cultist Outfit"
	quest.5DF26D712B643655.quest_subtitle: "Tuangkan Molten Brass ke atas telur lebah Zinc/Copper"
	quest.5DF26D712B643655.title: "Brass Bee"
	quest.5DFE3CB5B0130A7A.quest_desc: ["Ada banyak tanaman di atas Shimmer River, beberapa bisa kamu pijakin!"]
	quest.5E02AE661945306C.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.5E090C9BB4DAA5D4.title: "Tingkat: &aEnergized"
	quest.5E0D78B7B2CF1729.quest_desc: ["Aku tahu ini Tier Wyvern jadi kenapa item Draconic ada di sini? Untuk sampai ke Tier Draconic kamu butuh Draconic Injector. Untuk dapat Draconic Injector kamu butuh Draconic Cores. Paham kenapa mereka di sini sekarang?"]
	quest.5E0D78B7B2CF1729.title: "Draconic Core"
	quest.5E116409DC7D30BB.quest_desc: ["Kamu harusnya sudah tahu soal Logistik sekarang! Quest ini sekarang khusus buat jelasin &3Configurator&r! \\n\\nDengan tahan Shift dan Scroll kamu bisa ganti Mode dari &3Configurator&r. \\n\\n&dWrench&r: bakal lepasin &5&lMekanism&r &5Mesin&r dan blok pas dipakai ke mereka. \\n&eRotate&r: cuma buat putar arah bloknya. \\n&4Empty&r: bakal kerja kayak Gauge Dropper. \\nSisanya bakal bikin &3Configurator&r berinteraksi sama&5 Mesin&r buat ganti Config mereka! \\n\\nKalau dipakai ke Pipa nanti dia bakal ganti apa pipanya dorong (Push), tarik (Pull), atau keduanya. Bisa dipakai ke Port buat atur Input dan Output. Bahkan ke Bin buat atur biar dia Auto-Export ke bawah."]
	quest.5E116409DC7D30BB.quest_subtitle: "Sang Konfigurator"
	quest.5E116409DC7D30BB.title: "&5&lMekanism&r Logistics"
	quest.5E180764FBEE666B.quest_desc: [
		"Blok yang sangat unik dan membantu dari &6&lBumblezone&r yang jarang ditemukan di beberapa struktur, yang termudah ada di &5Bunga Raksasa (Overgrown Flower)&r! \\n\\nIni blok yang rumit jadi dengarkan baik-baik. &5Bunga&r ini digunakan untuk menyihir buku (enchanting), ia memiliki tingkatan (Tier) yang dibutuhkan untuk membuka dan menggunakan sihir. \\n\\nUntuk mendapatkan Tier lebih tinggi, kamu perlu memberi makan &5Bunga&r ini item atau XP. Lalu kamu bisa menaruh Buku atau Buku Sihir dan memilih sihir untuk dipasangkan ke buku tersebut."
		"{image:atm:textures/questpics/bumblezone/bumble_flower.png width:175 height:200 align:center}"
	]
	quest.5E180764FBEE666B.title: "&5Bunga Crystalline"
	quest.5E191081662C2F1A.quest_desc: ["&#6E6D6DForge Hammer&r berfungsi sebagai blok tempat kerja untuk villager dari &#A0DE45Modern Industrialization&r. Villager ini akan memberimu berbagai macam transaksi yang berguna."]
	quest.5E1D4169C083ACEF.quest_desc: ["&cIgnition Plate&r akan memunculkan api di depannya saat menerima sinyal Redstone.\\n\\nApi akan padam saat sinyal dimatikan."]
	quest.5E1D4169C083ACEF.title: "&cIgnition Plate"
	quest.5E228ACA1B13AD04.quest_desc: ["Sekarang menembak dan memukul!"]
	quest.5E24012A3D9B72A1.quest_desc: [
		"Bukan hanya item yang bisa disimpan. &bME Fluid Storage Cell&f dapat menyimpan cairan seperti air, lava, atau bahan bakar modded. "
		""
		"Perlu dicatat bahwa seluruh cell penyimpanan hanya berbeda pada bagian luarnya (housing); baik cell item maupun cairan menggunakan komponen penyimpanan yang sama. "
		""
		"Untuk cairan, 1 byte setara dengan 8 bucket (8000mb)."
	]
	quest.5E24012A3D9B72A1.title: "Penyimpanan Cairan"
	quest.5E287410EE969244.quest_desc: [
		"&9Shattered&r muncul di beberapa Biome di &3&lOtherside&r. \\n\\nMereka bertindak seperti mini &9&lWardens&r, Buta mengandalkan &3Sculk&r untuk menemukan Musuh. Mereka juga menyerang semua Mob non-&3Sculk&r. \\n\\n&9Shattereds&r punya 50 &4Hearts&r dan pukulannya cukup sakit! Jadi hati-hati untuk tidak menarik terlalu banyak. \\n\\nKalau kamu bisa membunuh mereka, mereka akan drop &9Sculk Bones&r. Ini akan diperlukan untuk beberapa Recipe."
		"{image:atm:textures/questpics/deepndark/dnd_shattered.png width:100 height:150 align:center}"
	]
	quest.5E287410EE969244.title: "&9Shattered"
	quest.5E3263ACE170A8E3.quest_desc: ["&dGauntlet of &eMaelstrom&r dibuat dengan &dGauntlet of Guard&r dan &eSandstorm in a Bottle&r di dalam &4Mechanical Fusion Anvil&r. \\n\\nSenjata ini unik dibanding senjata mod &4&lCataclysm&r lainnya. \\n\\nSaat kamu Menahan Klik Kanan, sebuah &dVoid &eVortex&r (Pusaran) akan muncul di tempat kamu membidik. \\n\\nPusaran tersebut akan menyedot semua entitas di dekatnya, lalu setelah beberapa detik, ia akan menutup dan meledak! Melukai semua yang ada di sekitarnya."]
	quest.5E3263ACE170A8E3.title: "&dGauntlet of &eMaelstrom"
	quest.5E41363F9AE243F3.quest_desc: ["Kamu tidak bisa selamanya mengandalkan Batu Bara untuk markasmu! Jika kamu sudah punya cukup sumber daya, saatnya meng-upgrade setup dayamu!\\n\\nOpsi-opsi ini biasanya butuh sedikit persiapan, tapi menghasilkan daya yang cukup untuk menemanimu hingga jauh di dalam permainan."]
	quest.5E41363F9AE243F3.title: "&b&lOpsi Daya Mid Game"
	quest.5E45C9C2D72EDBCC.quest_desc: [
		"Pas lagi jalan-jalan lewat &cHutan Crimson&r kamu mungkin denger tawa kecil. \\n\\nWalaupun mungkin lucu didenger di taman atau di rumah, di &cHutan&r agak lebih serem! \\n\\nTapi jangan khawatir, tawa itu sangat ramah. Itu dari &dPixie&r di dalam &dDesa Pixie&r! \\n\\n&dDesa Pixie&r adalah Log kecil dan Jamur yang udah diubah jadi rumah buat &dPixie&r!"
		"{image:atm:textures/questpics/iceandfire/iaf_struct_pixie.png width:200 height:100 align:center}"
	]
	quest.5E45C9C2D72EDBCC.title: "&dDesa Pixie"
	quest.5E4BC0F59C90433A.quest_desc: ["Sophisticated Storage memungkinkanmu meng-upgrade Peti dan Barrel menggunakan logam untuk meningkatkan kapasitasnya! Kamu juga bisa menambah upgrade untuk fungsi tambahan.\\n\\nPeti ini mirip seperti versi Vanilla, tapi memiliki slot khusus untuk Upgrade Penyimpanan!"]
	quest.5E4BC0F59C90433A.quest_subtitle: "\"Peti Vanilla Plus\""
	quest.5E4BC0F59C90433A.title: "Sophisticated Storage"
	quest.5E4FE420B6D2C97F.quest_desc: ["Memadatkan item di dalam Tas ke resep 3x3 (contoh: Blok Besi)."]
	quest.5E4FE420B6D2C97F.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.5E4FE420B6D2C97F.title: "&eAdvanced Compacting Upgrade"
	quest.5E5D5D28D82F6891.quest_desc: ["&l&9X&cy&aC&8r&aa&cf&9t&r menambahkan banyak jenis Kaca dengan &lWorld Core&r-nya! \\n\\nMulai dari yang bisa kamu tembus, yang bercahaya, hingga yang lebih kuat!"]
	quest.5E5D5D28D82F6891.title: "Kaca &l&9X&cy&aC&8r&aa&cf&9t&r"
	quest.5E610C059737628B.quest_subtitle: "Sampai +3 Tinggi Step"
	quest.5E63C78CDC44FF95.quest_desc: ["Rotten Blisterberry tidak bisa dilempar, tapi kalau dibuat menjadi Blisterbomb baru bisa! \\n\\nKamu bahkan bisa melangkah lebih jauh dan membuat Boomgourd yang bertindak seperti TNT dan menyebarkan Blisterberry ke mana-mana."]
	quest.5E63C78CDC44FF95.title: "Bahan Peledak!!!"
	quest.5E6585F7627247E3.quest_desc: ["&bCrafting Card&f memungkinkan perangkat seperti Interface atau Export Bus untuk secara otomatis mengirim permintaan crafting-nya sendiri untuk item yang difilter. Crafting CPU dapat diatur untuk hanya merespons permintaan otomatis ini.\\n\\nSaat &eLevel Emitter&f ditingkatkan dengan kartu ini, ia bisa diatur untuk memancarkan redstone guna memfasilitasi pembuatan item secara langsung saat terdeteksi pekerjaan crafting sedang berjalan."]
	quest.5E6585F7627247E3.quest_subtitle: "Otomatisasi Dalam Bentuk Upgrade"
	quest.5E6585F7627247E3.title: "Crafting Card"
	quest.5E671F1F370DDE43.title: "Draconic Auto Feed Module"
	quest.5E6D7C1D7957DD4D.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_forgotten.png width:100 height:150 align:center}"]
	quest.5E6D7C1D7957DD4D.title: "&aForgotten&r"
	quest.5E71F8A046C60346.quest_desc: ["Siapa bilang PneumaticCraft bukan tentang menghasilkan listrik?\\n\\n&3Pneumatic Dynamo&r memungkinkanmu mengubah tekanan udara menjadi FE. Baca tooltip atau baca Manual PNC:R untuk belajar cara kerjanya."]
	quest.5E71F8A046C60346.quest_subtitle: "Tekanan = Energi"
	quest.5E71F8A046C60346.title: "Menghasilkan Energi"
	quest.5E750DB2244A67A1.quest_desc: [
		"&6Turnout Track&r adalah hasil pertama dari memukul &6rel&r dengan Spike Maul. Ia membantu kereta memilih dua arah: lurus atau belok ke samping. Bisa diatur menggunakan Switch di samping &6rel&r."
		"{image:atm:textures/questpics/railcraft/rail_turnout.png width:100 height:100 align:center}"
	]
	quest.5E750DB2244A67A1.title: "&6Jalur Belokan (Turnout)"
	quest.5E766840DAB839A2.quest_subtitle: "Ash + Sugar Maple"
	quest.5E799B92358A8732.quest_desc: ["Di &cNether&r, akan bertemu &6Ancient Debris&r. Ini bisa di-smelt jadi Scrap yang bisa digabungkan dengan Gold untuk membuat &6Netherite Ingot&r, yang merupakan metal endgame dipakai untuk craft beberapa tool dan armor terkuat di game."]
	quest.5E799B92358A8732.title: "&dMetal Kuno"
	quest.5E7CCDE9229A646A.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_allthemodium.png width:100 height:150 align:center}"]
	quest.5E7CCDE9229A646A.title: "&6Allthemodium&r"
	quest.5E7E35CCAF1C88EE.quest_desc: ["&bME Import Bus&f secara berkala menyedot item dari penyimpanan eksternal yang dihadapinya ke dalam jaringan ME. Opsionalnya, bus ini bisa difilter agar hanya mengambil item tertentu saja."]
	quest.5E7E35CCAF1C88EE.quest_subtitle: "Input (Masuk)"
	quest.5E8D527DE9D7DD46.quest_desc: ["Dengan ini di Chestplate-mu kamu bisa Glide! Seolah kamu pakai Elytra (Tapi tanpa cost Armor). Aku tidak suka menyebutnya flying, lebih 'jatuh dengan gaya'."]
	quest.5E8D527DE9D7DD46.title: "Wyvern Flight Module"
	quest.5EAD916C4F15335F.quest_desc: ["&4Mega Importer&r memiliki 54 slot filter, bekerja 8x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.5EAD916C4F15335F.title: "&4Mega Importer"
	quest.5EB488C393B084C4.quest_desc: ["Kelanjutan dari &lChiseled&r, yaitu &4&lRechiseled&r! \\n\\nSeluruh fungsi mod ini bekerja di dalam alat Chisel, Klik Kanan dengannya untuk membuka GUI. \\nDi sebelah kiri adalah tempat memilih desain dan di bawah kanan adalah tempat menaruh blok. \\n\\nDi atasnya kamu bisa melihat desain dalam pola tertentu: hanya 1 blok, pola 3x1, atau dinding 3x3 dari blok tersebut. Kamu juga bisa mengatur agar gambar berputar atau tidak dengan mengklik tombolnya! \\n\\nDi sebelah tempat blok diletakkan, kamu bisa mengklik ikon Chisel, melakukan ini akan menerapkan desain yang dipilih ke setiap blok di inventarismu yang bisa diubah. \\n\\nJuga tidak memiliki durabilitas!"]
	quest.5EB488C393B084C4.title: "&4&lRechiseled&r"
	quest.5EB7CE3A1DCD3E9B.quest_desc: ["Ini sebuah &cMagnet&r."]
	quest.5EB7CE3A1DCD3E9B.quest_subtitle: "Sabuk"
	quest.5EB7CE3A1DCD3E9B.title: "&cUniversal Attractor&r"
	quest.5EB87CE5F6DEFAAA.quest_desc: ["&6Magma Walker&r memungkinkanmu melakukan 2 hal: berjalan di atas &cMagma Block&r tanpa terkena damage, dan berjalan di atas &4Lava&r untuk sesaat. &cMagma Block&r tidak memiliki waktu tunggu, tapi berjalan di &4Lava&r memilikinya. Setelah durasinya habis, &6Sepatu&r ini akan mengalami panas berlebih (overheat) dan melukaimu. "]
	quest.5EB87CE5F6DEFAAA.quest_subtitle: "Ditemukan di Ruined Portal, Nether Fortress, dan Bastion"
	quest.5EB87CE5F6DEFAAA.title: "&6Magma Walkers"
	quest.5EC1B868720BF521.quest_desc: ["&8&lImmersive Engineering&r itu semua tentang Multiblock Machine, Tool seru, dan tentu aja engineering. \\n\\nJangan khawatir kamu gak butuh 4 tahun kuliah buat ini! Tapi Manual mungkin bantu kamu mulai."]
	quest.5EC1B868720BF521.title: "&8&lImmersive Engineering"
	quest.5ED0DA95BAE43D88.quest_desc: ["Yang terakhir dari Prism, well yang ini &dCrystal&r tapi kamu ngerti maksudnya! \\n\\nPertama, kamu butuh &eDivine Pact&r Relic, yang ditemukan di &b&lThe Other&r. \\n\\nLalu, kamu butuh &3Enderpearl Fragment&r, &5Amethyst&r, dan Nether Quartz. Jangan khawatir jadi lebih susah! \\n\\nSekarang kita butuh setiap tipe Soul. Gue ajarkan cara dapet Soul dan &9Corrupt Soul&r di Quest lain sekarang gue ajarkan tentang &dEnchanted Soul&r. \\n\\nCari Lost Soul terbang di world kamu, lalu lempar &bSplash Potion of Aureal&r ke mereka! Lalu, mereka akan jadi &dLost Enchanted Soul&r, bunuh mereka! \\n\\nDengan itu kamu sekarang bisa bikin &dCrystal&r, yang bisa dipasang ke Tool dan Armor untuk kasih Soulbound. Ini artinya saat kamu mati, kamu respawn dengan Item ini masih di Inventory."]
	quest.5ED0DA95BAE43D88.title: "&dSoul Binding Crystal"
	quest.5ED368C926E5F32C.quest_desc: ["Ada kelas &3Spell&r terakhir yang aku lupa sebutkan. Ya semua pengetahuan tentang &9Spell&r ini telah dilupakan jadi bukan hanya aku. \\n\\nUntuk mendapatkan kembali ingatan kita perlu berjalan, dengan tenang, menyusuri jalan kenangan. Yang kebetulan adalah &9Ancient City&r."]
	quest.5ED368C926E5F32C.title: "Kelas Terakhir..."
	quest.5EDB5A2D744CE415.quest_desc: ["&4Laser Gatling&r adalah senjata yang bisa kamu buat dari &4Witherite&r. \\n\\nDengan menggunakan Redstone di inventarismu, kamu bisa menembakkan Laser yang memicu api dan memberikan damage 3 setengah &4HP&r. \\n\\nIa menembakkan 50 Laser untuk setiap 1 redstone, penawaran yang cukup bagus kurasa."]
	quest.5EDB5A2D744CE415.quest_subtitle: "Mirip dari Fallout"
	quest.5EDB5A2D744CE415.title: "&4Laser Gatling"
	quest.5EE1DF1C8F0C1FF9.quest_desc: [
		"Setelah membangun &l&5Kumparan Petir&r bisa memiliki Petir Menyambar &8Pagar Baja&r, yang kemudian akan menjadi &cEnergi&r di reservoir &cEnergi&r sendiri. \\n\\nSemakin banyak &8Pagar Baja&r, semakin tinggi peluang Petir! \\n\\nBertanya-tanya apakah bisa menggunakan Mod lain untuk memanggil Petir?"
		"{@pagebreak}"
		"Untuk memanfaatkan kekuatan Ibu Alam yang paling menghancurkan, perlu memulai dengan &5Blok Kumparan Tegangan Tinggi&r. Kemudian, letakkan &5Akumulator HV&r berdekatan dengan &5Blok Kumparan Tegangan Tinggi&r. Di sudut letakkan &8Perancah Baja&r."
		"{image:atm:textures/questpics/immersive/immersive_lightning1.png width:100 height:100 align:center}"
		"Untuk lapisan berikutnya, letakkan &5Blok Kumparan Tegangan Tinggi&r lain di atas yang sebelumnya. Berdekatan dengan itu, akan menjadi &eBlok Teknik Ringan&r. Di sudut akan hanya Pagar Kayu yang Diolah sederhana!"
		"{image:atm:textures/questpics/immersive/immersive_lightning2.png width:100 height:100 align:center}"
		"Sekarang, perlu &5Blok Kumparan Tegangan Tinggi&r ketiga di atas yang lain, dan mengelilinginya akan menjadi 8 &6Blok Kumparan Tembaga&r."
		"{image:atm:textures/questpics/immersive/immersive_lightning3.png width:100 height:100 align:center}"
		"Kemudian, Klik Kanan &eBlok Teknik Ringan&r di Sisi Depan dengan &6Palu&r untuk mengubahnya menjadi &5&lKumparan Petir&r!"
		"{image:atm:textures/questpics/immersive/immersive_lightning.png width:100 height:100 align:center}"
		"Tidak membuat gambar untuk langkah ini tetapi perlu &8Pagar Baja&r di atas &5&lKumparan Petir&r agar Petir mengenainya!"
	]
	quest.5EE1DF1C8F0C1FF9.title: "&5&lKumparan Petir"
	quest.5EE485880EA9FACF.quest_subtitle: "Tingkat: &63"
	quest.5EE7D5DE07A83C7D.quest_desc: ["&lTipe Kemampuan:&r Aktif\\n\\n&lFungsi Kemampuan:&r\\n\\nMenyorot bijih di sekitar dengan partikel hijau saat diaktifkan.\\n\\n&4&lCATATAN KEMAMPUAN INI TELAH DINONAKTIFKAN.&r&f"]
	quest.5EE945A1185E8336.quest_desc: ["&l&7Functional Storage&r menambahkan &7Drawer&r (laci) yang bisa menampung banyak stack dari satu jenis item. Ini bisa ditingkatkan untuk menampung lebih banyak lagi!\\n\\nSangat cocok untuk item yang kamu punya banyak, seperti Cobblestone atau Benih!"]
	quest.5EE945A1185E8336.quest_subtitle: "Laci Penyimpanan?"
	quest.5EE945A1185E8336.title: "&l&7Functional Storage"
	quest.5EF54E0EB14024D1.quest_desc: ["2 &ePowdered Gold&r dan 1 &3Powdered Enderpearl&r (jangan tertukar atau akan dapat Ascension!). \\n\\nGunakan ini pada &7Spell Cloth&r untuk mendapat &7Scroll&r! \\n\\nLalu, menggunakan &7Scroll&r itu akan mendapat &a&lStaff&r yang kurang Explosive tapi tetap seru!"]
	quest.5EF54E0EB14024D1.title: "&7Scroll of Spatial Disorientation"
	quest.5F00A66CC1FE1F9F.quest_desc: ["Jujur bagian paling susah dari resep ini adalah Bat Wing, seberapa sering kamu bunuh Bat apalagi Farm mereka? \\n\\nIni cukup baru dan gak gabung dengan Armor, cuma dipakai untuk end game!"]
	quest.5F078A574A783B02.quest_desc: ["Item pertama yang kamu butuhkan untuk memulai Flux Network adalah &9Flux Plug&r.\\n\\nPlug digunakan untuk \"menarik\" daya dari blok tempat ia menempel. Selain buffer kecil, Plug tidak menyimpan daya sendiri, jadi jangan khawatir ia akan menyedot habis dayamu.\\n\\nDisarankan untuk memasang Plug pada blok penyimpanan daya seperti Energy Cube. Ia bisa terhubung ke Kabel, Pipa, atau output dari mesin penghasil daya apa pun.\\n\\nUntuk belajar cara menyiapkan jaringan pertamamu, cek quest berikutnya!"]
	quest.5F078A574A783B02.quest_subtitle: "Tinggal colok!"
	quest.5F078A574A783B02.title: "Memulai Jaringanmu"
	quest.5F080CFA1DC7F435.quest_subtitle: "Muncul menggunakan Soul Sand Nest di dimensi Nether."
	quest.5F080CFA1DC7F435.title: "Ghostly Bee"
	quest.5F1218CF8EFC607B.quest_desc: [
		"&c&lLaserIO&r adalah kelanjutan dari sistem &lLogistik&r mod &a&lEnderIO&r yang dibuat oleh DireWolf."
		""
		"Ini semua tentang memindahkan item melalui &cLaser&r! Siapa sih yang nggak suka &cLaser&r?!"
		""
		"Dan semuanya dimulai dengan Logic Chip."
	]
	quest.5F1218CF8EFC607B.title: "&c&lLaser IO"
	quest.5F1784E562C29B66.quest_desc: ["Buatlah sebuah &5End Stone Nest&r dan pergilah ke dimensi End untuk menangkap lebah ini!"]
	quest.5F1784E562C29B66.quest_subtitle: "&9Membutuhkan End Stone Nest"
	quest.5F1784E562C29B66.title: "Ender Bee"
	quest.5F458D79D43D8842.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.5F4AA7E7D050C327.quest_subtitle: "White Poplar + Ceylon Ebony"
	quest.5F4F7637044BD4F1.quest_desc: [
		"&2&lFermenter&r akan menahan &eBarang&r Makanan dan setelah beberapa saat akan membentuknya menjadi Etanol. \\n\\nAda daftar Barang, bisa ditemukan di &6Manual Insinyur&r, dari &eBarang&r yang bisa dimasukkan ke &2&lFermenter&r oleh Port di Belakang dan sisi Kiri. \\n\\nJika menggunakan &6Botol Madu&r, bisa &6Mengekstrak&r Botol dari Port di Sisi Kanan. \\n\\n&2&lFermenter&r akan memerlukan &cEnergi&r yang akan datang dari Port di Atas &2&lFermenter&r!"
		"{@pagebreak}"
		"Awal yang cukup sederhana, buat n terbalik dari &8Perancah Baja&r dan di dalamnya letakkan &bPipa Cairan&r dan di sudut letakkan &eBlok Teknik Ringan&r."
		"{image:atm:textures/questpics/immersive/immersive_fermenter1.png width:100 height:100 align:center}"
		"Di atas &eBlok Teknik Ringan&r letakkan yang lain. Di sebelah kanannya, lewati Blok, lalu letakkan &4Blok Teknik Redstone&r. Di sebelah kiri &eBlok Teknik Ringan&r letakkan 2x2 Kuali."
		"{image:atm:textures/questpics/immersive/immersive_fermenter2.png width:100 height:100 align:center}"
		"Langkah sederhana lainnya, letakkan &7Lembar Besi&r di atas semua Kuali!"
		"{image:atm:textures/questpics/immersive/immersive_fermenter3.png width:100 height:100 align:center}"
		"Klik Kanan Kuali antara &eBlok Teknik Ringan&r dan &4Blok Teknik Redstone&r dengan &6Palu&r."
		"{image:atm:textures/questpics/immersive/immersive_fermenter.png width:100 height:100 align:center}"
	]
	quest.5F4F7637044BD4F1.title: "&l&2Fermenter"
	quest.5F5120451BA5B2FE.quest_desc: ["Mesin tingkat lanjut punya kemampuan yang sama dengan varian sederhana mereka dengan tambahan area kerja yang bisa dikonfigurasi, lebih banyak slot penyaring, dan membutuhkan tenaga."]
	quest.5F56892CD904C40F.quest_desc: ["Tingkat kelima dan terakhir dari komponen penyimpanan standar AE2, menyediakan &e262.144&f byte penyimpanan."]
	quest.5F56892CD904C40F.quest_subtitle: "x4^4"
	quest.5F56892CD904C40F.title: "Komponen Penyimpanan 256k"
	quest.5F5E43B3F51CAE9E.quest_desc: ["'Sangat lezat dan ajaib!' \\n\\n&aSuperstitious Hat&r memberimu tambahan tingkat Looting pada mob yang kamu bunuh! \\n\\nEfek ini bisa ditumpuk (stack) dengan Enchantment!"]
	quest.5F5E43B3F51CAE9E.quest_subtitle: "Kepala"
	quest.5F5E43B3F51CAE9E.title: "&aSuperstitious Hat"
	quest.5F6152CF085D75D6.title: "Reaktor (Basic)"
	quest.5F6ACDE014A61F46.quest_desc: ["Buff:\\n\\n - Absorption II (3:00)\\n - Speed II (3:00)\\n - Resistance II (3:00)"]
	quest.5F6ACDE014A61F46.title: "&cApel Tertium"
	quest.5F72C0C82F3C0310.quest_subtitle: "Tingkat: &c5"
	quest.5F7F753FD72BFBBF.quest_desc: ["Lebih banyak blok yang ditambahkan oleh &l&7Railcraft&r? Aku mulai ragu apakah mod ini memang tentang Kereta Api!"]
	quest.5F7F753FD72BFBBF.title: "Blok Berwarna &l&7Railcraft&r"
	quest.5F834F8C607A8B77.quest_desc: ["Kamu harus menemukannya di struktur di &6&lBumblezone&r atau bisa menukarkannya dengan &5Ratu Lebah&r! \\n\\nSambil memakainya kamu bisa menahan tombol Spasi untuk terbang sebentar. \\n\\nTapi seperti lebah asli, sayapnya terlalu kecil untuk menopang tubuh gemukmu dari tanah."]
	quest.5F9B8ACCE0C8389E.quest_desc: ["Untuk mendapat lebih banyak senjata &4&lMahou Tsukai&r yang seru, butuh &7Scroll of Strengthening&r. \\n\\nUntuk mendapatkannya, letakkan &7Spell Cloth&r, lalu lakukan Ritual of Strengthening di atasnya dan ambil &7Cloth&r."]
	quest.5F9B8ACCE0C8389E.title: "&7Scroll of Strengthening"
	quest.5FA68047A3C05E80.quest_desc: ["15 Slot Mantra!"]
	quest.5FA68047A3C05E80.title: "&5Unobtainium Spell Book"
	quest.5FA9BC0D8476D322.quest_desc: ["Memberimu makan secara otomatis menggunakan makanan yang ada di dalam Tas."]
	quest.5FB29F3F4DF17765.quest_desc: ["Terkadang kamu tidak ingin setiap Module memindahkan banyak stack sekaligus. Jika ingin hanya 1 Module yang melakukan itu, gunakan Augment! Ini tidak menumpuk dengan Upgrade, malah akan menimpanya (override)."]
	quest.5FBA199E0B7F1585.quest_desc: ["&9Octohost&r sebenarnya adalah 2 mob yang bekerja sama untuk menghabisimu! \\n\\nTerdiri dari &9Symbiocto&r yang mengendalikan &9Drowned Host&r. \\n\\n&9Symbiocto&r punya 8 &4HP&r dan tanpa armor. Saat sendirian, ia hanya akan menembakkan tinta padamu. Saat mati menjatuhkan Ink Sac. \\n\\n&9Drowned Host&r bertindak seperti Drowned normal. Punya 10 &4HP&r serta 2 Poin Armor. Bisa muncul dengan armor dan senjata. \\n\\nSaat bersama, mereka akan menyerangmu sekaligus. &9Symbiocto&r menembak tinta sementara &9Drowned Host&r memukulmu."]
	quest.5FBA199E0B7F1585.title: "&9Octohost"
	quest.5FC92F3794004A98.quest_subtitle: "Rippling Willow + Soul Tree"
	quest.5FCA6F5FE97780B7.quest_desc: [
		"&eGronglet&r secara teknis adalah Blok, bukan Mob. Tapi aku sangat menyukai mereka jadi harus kumasukkan! \\n\\nMereka muncul di Pohon Grongle dan mengeluarkan suara serta cahaya! Sangat sempurna untuk dekorasi."
		"{image:atm:textures/questpics/undergarden/undergarden_gronglet.png width:100 height:100 align:center}"
	]
	quest.5FCA6F5FE97780B7.title: "&eGronglet&r"
	quest.5FD4FB9D24586B9B.quest_desc: ["Penasaran harus bagaimana untuk mendapat &9Lightning Staff&r? \\n\\nMungkinkah harus tersambar &9Lightning&r sambil memegang Strengthened Stick?\\n\\nSeperti itu! \\n\\nSetelah punya &9&lEmrys&r pegang di off hand dan tahan Right Click, hasilnya akan MENGEJUTKAN!"]
	quest.5FD4FB9D24586B9B.title: "&9&lEmrys"
	quest.5FD6A738754F6013.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, kamu sedang dalam mode pengeditan."]
	quest.5FD88ED4937971D7.quest_subtitle: "Tuscarora Crepe Myrtle + Luck"
	quest.5FD88ED4937971D7.title: "Moonlight Magic Crepe Myrtle Sapling"
	quest.5FE4DAE8F41B1437.quest_desc: ["&cOre Magnet&r dapat menarik apa pun yang memiliki nama 'Ore' (bijih), kecuali Batu Bara.\\n\\nIni bisa ditemukan di dalam peti-peti &2Hollow Hill&r."]
	quest.5FE4DAE8F41B1437.title: "&cOre Magnet"
	quest.5FE507DAEE770507.quest_desc: ["Malas memanggil &9Marid Crusher&r untuk mendapatkan &bLight Blue Chalk&r? Kamu bisa menggunakan &aDjinni Crusher&r sebagai gantinya. &aOphyx' Calling&r digunakan untuk memanggil para &aDjinni&r. Ini termasuk Istri/Suami Setan. Para &aDjinni&r mampu menghancurkan bijih lebih efisien daripada Foliot, tapi tidak seefisien &cAfrit&r atau &9Marid&r. Mereka juga mampu menghancurkan es tanpa mencairkannya."]
	quest.5FE507DAEE770507.quest_subtitle: "Jalur alternatif untuk biru muda"
	quest.5FE507DAEE770507.title: "&aOphyx' Calling"
	quest.5FE631066CAB7397.quest_desc: ["Dipakai untuk menjebak dan mentransport mob dengan mudah."]
	quest.6009E239E2E15236.quest_desc: [
		"Hippogryth adalah campuran Kuda dan Elang. Setengah belakang mereka seperti Kuda dan setengah depan kayak Elang. \\n\\nMereka Terbang sangat cepat karena Sayap mereka, mereka juga punya 20 &4Hearts&r. \\n\\nHippogryth gak bakal langsung nyerbu buat Berantem tapi kalo kamu terlalu deket mereka bakal bela diri. Mereka bakal pake Cakar mereka buat kasih Damage dikit atau Tendang kamu tinggi ke udara buat kena Fall Damage. \\n\\nMungkin lebih baik coba Tame mereka... kecuali kamu bener-bener mau Pedang Cakar Hippogryth."
		"{image:atm:textures/questpics/iceandfire/iaf_hippogryth.png width:130 height:100 align:center}"
	]
	quest.6009E239E2E15236.title: "Hippogryth"
	quest.600F66B13B29708B.quest_desc: ["Entah dengan daging &aPlayer&r atau &dWerewolf&r, kamu bisa bikin &aSumber Makanan Infinite&r pakai kekuatan Garmonbozia!"]
	quest.6012D6C3253895F0.quest_desc: ["&cMr Crayfish&r adalah nama yang identik dengan &2&lMinecraft&r Modded. \\n\\nMod-nya yang paling banyak diunduh tentu saja Furniture Mod! \\n\\nUntuk memulai kamu butuh Workbench, yang memerlukan Energi untuk bekerja."]
	quest.6012D6C3253895F0.title: "Mod &cMr Crayfish&c"
	quest.6013C6B2E0B81D73.quest_desc: [
		"Di bagian luar &6&lDinding Hive&r dan &6&lPilar&r kamu akan menemukan apa yang kusebut &6Penitipan Anak Lebah&r.\\n\\nDi sini akan ada &6Blok Madu&r dan Honeycomb Brood Block! Blok ini berisi bayi lebah di salah satu tahap pertumbuhannya.\\n\\nKamu bisa memberinya makan: Botol &bAir Gula&r, &6Botol Madu&r, atau Bee Bread. Memiliki 4 tahap dan setelah tahap ke-4 diberi makan, seekor bayi lebah akan muncul. Terkadang &6Honey Slime&r juga ikut muncul!\\n\\nKamu bisa membawa Brood Block yang kosong ke &5Ratu Lebah&r untuk mengisinya kembali!\\n\\nSaat kamu memberi mereka makan yang cukup, kamu akan mendapatkan efek Protection of the Hive. Jika kamu membunuh mereka, kamu akan mendapatkan Wrath of the Hive.\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_daycare.png width:200 height:100 align:center}"
	]
	quest.6013C6B2E0B81D73.title: "&6Penitipan Anak"
	quest.601C719C8FD513F0.quest_desc: ["3 &cNetherite Ingot&r, 3 Wireless Booster, dan banyak &2fancy &eGear&r kita bisa dapetin Infinity Range Booster! \\n\\nBagian paling membingungkan adalah Gear. Kita gak bisa bikin Ingot langsung kita harus campur Dust terus Smelt hasilnya buat dapetin Ingot.\\n\\nIni gak jalan lintas Dimensi maaf!"]
	quest.60244F26B9ABED49.title: "&aKomponen Penyimpanan Cairan 1024B"
	quest.602A6CF9D5B66AD3.quest_desc: ["&5&lChemical Crystallizer&r itu sebenernya mesin yang cukup simpel! Kita cuma butuh &cChemical &fsama &aEnergi&r! \\n\\nDan ya, yang satu ini nggak cuma dipakai buat &lOre Processing&r! Yah sebagian sih... tapi nggak semua. \\n\\nTinggal masukin &7Clean Ore Slurry&r ke &5&lCrystallizer&r nanti dia bakal ngerubah itu jadi &7Ore Crystal&r. \\n\\nKamu juga bisa kasih &dAntimatter&r buat bikin &dAntimatter Pellet&r, atau &6Lithium&r buat bikin &6Lithium Dust&r!"]
	quest.602A6CF9D5B66AD3.title: "&5&lChemical Crystallizer"
	quest.602C3E88D96F8843.quest_desc: ["Masukkan Charged Empty PCB ke dalam Etching Tank dengan Etching Acid dan sedikit panas, maka kamu akan mendapatkan &3Unassembled PCB&r (PCB Belum Dirakit)."]
	quest.602C3E88D96F8843.quest_subtitle: "Hampir sampai!"
	quest.6033ABA2088BA70C.quest_subtitle: "Tanpa Flight Drift"
	quest.603BEDD49070ECAD.quest_desc: ["&bCondensating&r itu proses dari &bCairan &fke &cGas&r. &cDecondensating&r itu ngerubah &cGas &fke &bCairan&r. \\n\\n&c&lRotary &bCondenstrator&r bisa lakuin keduanya! \\n\\n&cGas&r masuk ke Bar di sebelah kiri. Bisa ditambahin lewat &cTubes &fatau &cChemical Tank&r yang kamu taruh di Slot Kiri. \\n\\n&bCairan&r masuk ke Bar Kanan. Bisa juga ditambahin pakai &bPipes &fatau &bFluid Tank&r yang ditaruh di Slot Kanan. \\n\\nPas ada tenaga, &cGas&r bakal jadi &bCairan&r, dan &bCairan&r jadi &cGas&r. Mereka bakal tukar posisi Bar dan bisa diambil pakai &cTubes&f/&bPipes&r atau &cChemical&f/&bFluid Tank&r."]
	quest.603BEDD49070ECAD.title: "&c&lRotary &bCondensentrator"
	quest.6046CA1F6AFE2AEA.quest_desc: ["&4The Blood Staff&r adalah Drop dari &4&lThe Dead King&r. Mungkin karena ini benar-benar Staff-nya! \\n\\nStaff ini memberikan 8 &4Damage&r, lebih dari yang sebelumnya. \\n\\nIni memberikan 5% &3Spell Power&r untuk semua &3Spell&r dan 15% hanya untuk &4Blood Spell&r serta 10% Summon Power."]
	quest.6046CA1F6AFE2AEA.title: "&4The Blood Staff"
	quest.604C003EE6B1CC6B.quest_subtitle: "Sama seperti versi uap"
	quest.604F2B68B27885BF.quest_desc: ["Ada banyak sekali jenis makanan yang bisa kamu buat dari hasil &9Twilight Forest&r!\\n\\nCoba semuanya!"]
	quest.604F2B68B27885BF.title: "Makanan Mewah"
	quest.6063F4B7BE4D394C.quest_desc: ["Sender Module akan memindahkan item dari slot Buffer Router ke inventaris lain. \\n\\nMK1 hanya akan mengirim ke inventaris yang berada di koordinat yang sejajar dan punya pandangan langsung. Jika ada blok yang menghalangi, MK1 tidak akan mengirim."]
	quest.606775701551F3EE.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_carminite.png width:100 height:150 align:center}"]
	quest.606775701551F3EE.title: "&4Carminite"
	quest.60721C9B94B36C24.quest_desc: [
		"&3Sculk Centipedes&r adalah Mob netral panjang yang muncul di &3&lOtherside&r. \\n\\nMereka punya 10 &4Hearts&r dan akan menyerang dalam kelompok kalau Dipukul, seperti Wolves. \\n\\nMereka hanya drop &aXP&r dan mungkin String, jadi lebih baik tinggalkan mereka!"
		"{image:atm:textures/questpics/deepndark/dnd_centipede.png width:100 height:100 align:center}"
	]
	quest.60721C9B94B36C24.title: "&3Sculk Centipede"
	quest.607337D8AA20FA18.quest_desc: ["Semua Pohon yang terhubung dengan yang ditebang, ikut bersamanya."]
	quest.607337D8AA20FA18.title: "Wyvern Tree Harvester"
	quest.6076D1DB438EB997.quest_desc: ["Resepnya gampang banget, cuma butuh &7Coal&r, &cBlaze Powder&r, dan sebuah &bArcane Crystal Block&r. \\n\\n&7Coal&r dan &bArcane Crystal&r bisa didapat lewat Quarry, &6&lBees&r, atau &2&lMA&r. \\n\\n&cBlaze Powder&r bisa didapat dari dua mod terakhir yang disebut tadi, atau farm biasa dan &b&lHNN&r. Ada banyak banget cara buat dapet &cBlaze Powder&r."]
	quest.6076D1DB438EB997.title: "&cSmelter Prism"
	quest.607D592CE102C82E.title: "Peralatan Knightmetal"
	quest.607D9B53C632DEDE.quest_desc: ["&bKatup Pipa&r bekerja membantu menyortir dan menghentikan aliran &bCairan&r! \\n\\nKetika digunakan dengan &bPipa Cairan&r, akan membuat &bCairan&r hanya pergi ke arah dengan panah pada &bKatup Pipa&r. \\n\\nJuga bisa mengirimkan &4Sinyal Redstone&r yang akan benar-benar menghentikan aliran &bCairan&r!"]
	quest.607D9B53C632DEDE.title: "&bKatup Pipa"
	quest.60850E717C747A78.quest_desc: ["Pernah nggak sih kamu menghabiskan waktu 3 bulan belajar &oKode Galaksi&r cuma buat paham bahasa di &5Enchantment Table&r tapi ternyata isinya cuma omong kosong? \\n\\nNggak pernah? \\n\\nAku juga sih, tapi &9Enchanting Clue&r adalah penerjemah aslimu untuk itu! \\n\\nSetiap &9Enchanting Clue&r akan memberitahumu 1 &5Enchantment&r yang akan didapat sebelum kamu benar-benar menggunakannya."]
	quest.60850E717C747A78.title: "Petunjuk Enchanting"
	quest.6092490EC9008A05.quest_desc: ["&4Destructor&r adalah interface yang akan secara otomatis menghancurkan blok yang ada di depannya.\\n\\nKamu juga bisa mengaturnya ke mode whitelist, yang sangat berguna untuk mengotomatisasi proses tertentu, seperti membuat Casing di mod &6Create.&r"]
	quest.6092490EC9008A05.quest_subtitle: "Menghancurkan Blok!"
	quest.6092490EC9008A05.title: "Destructor"
	quest.609CA1ACFA981BD5.quest_desc: ["&cRouting Kit&r digunakan bersama dengan tiket perjalanan."]
	quest.609CA1ACFA981BD5.title: "&cTrack Kit&r Perutean (Routing)"
	quest.609D03E335CF32E2.quest_subtitle: "Tingkat: &d6"
	quest.60A1AEEDB0C44663.quest_desc: ["&3&lC.D.C.&r sekarang punya Multiblock juga buat &lOre Processing&r yang lebih baik! \\n\\nLo butuh &eItem&r Input Hatch, &aEnergi&r Input, sama &cChemical&r Input Hatch khusus buat &eSulfuric Acid&r. Terus &cChemical&r Output Hatch. \\n\\nCuma 3 Ore Block sekaligus? Ayo kita bisa lebih dari itu! Kenapa gak lakuin 16 sekaligus pake &3&lC.D.C. Multiblock&r!"]
	quest.60A1AEEDB0C44663.title: "&3&lChemical Dissolution Chamber Multiblock"
	quest.60A4994078500F63.quest_desc: ["Celestigem adalah material baru yang ditambahkan oleh JDT. Celestigem didapatkan dengan melakukan Penyebaran Lendir pada Balok Berlian menggunakan lendir tingkat tiga atau lebih tinggi. Bijih Celestigem dipengaruhi oleh keberuntungan."]
	quest.60B52705049D1BA5.quest_desc: ["&a&lChemical Washer&r cuma buat &7Ore Processing&r. \\n\\nKayak &9&lElectrolytic Separator&r, yang satu ini cuma jalan pakai &cChemical&f/&bCairan&r! \\n\\n&9Air&r (atau pengganti &9Air&r) masuk ke Bar Kiri! Terus Ore Slurry masuk ke Bar sebelahnya. \\n\\nPas dikasih &aEnergi&r, &a&lChemical Washer&r bakal bikin Dirty Slurry jadi bersih (Clean)! \\n\\nKayak mesin cuci gitu!"]
	quest.60B52705049D1BA5.title: "&a&lChemical Washer"
	quest.60B985069E0E643E.quest_subtitle: "Water + Lava"
	quest.60B985069E0E643E.title: "Obsidian Bee"
	quest.60C27206F1414DD6.quest_desc: ["Berkat Newton kita tahu untuk setiap aksi ada reaksi yang sama dan berlawanan. Pada dasarnya saat Arrow mengenai mob gaya dari Mob berlaku untuk Arrow yang akan memperlambatnya. Kecuali kamu punya Module ini. Tidak bertindak seolah setiap mob adalah kertas, bertindak seolah setiap mob tidak menghalangi. Arrow tidak akan melambat setelah Menembus target."]
	quest.60C27206F1414DD6.title: "Projectile Immunity Cancellation Module"
	quest.60CECAAE2D43EC6E.quest_desc: ["&2Ender Hand&r memiliki dua fungsi: Kemampuan Pasif dan Kemampuan Aktif. Pasif membuat &5Enderman&r tidak marah saat kamu menatap mereka. Aktif memungkinkanmu bertukar posisi dengan mob yang sedang kamu lihat dengan menekan Alt Kiri."]
	quest.60CECAAE2D43EC6E.quest_subtitle: "Ditemukan di End City dan End Ship"
	quest.60CECAAE2D43EC6E.title: "&2Ender Hand"
	quest.60D9F04E91171D16.quest_desc: ["Ini bisa bertindak sebagai Chest untuk Variable, atau bisa benar-benar dipakai di network advanced.\\n\\nKalau ingin network advanced, pastikan membaca tentang mereka di &eDynamics of Integration&r."]
	quest.60ECCCAB66AAC05D.quest_desc: ["&eLogistical Transporter&r bakal mindahin &eItem&f dan &eBlok&r dari satu inventory ke yang lain! \\n\\nBiar bisa mindahin &eItem&r ke &5Mesin&r, kita harus ganti Config di dalam &5Mesin&r-nya. Ada di pojok kiri atas GUI &5Mesin&r, Side Configs. Harus diset ke Auto-Eject biar bisa keluarin &eItem&r. \\n\\n&eLogistical Transporter&r dibuat pakai 2 &8Steel Ingot&r dan 1 &aBasic Control Circuit&r. Kamu bisa gabungin 8 &eLogistical Transporter&r sama Control Circuit tier berikutnya buat upgrade. \\n\\n&a&lBasic&r: pindahin 2 Blok/Item sejauh 1 blok tiap detik. \\n\\n&c&lAdvanced&r: pindahin 32 Blok/Item sejauh 2 blok tiap detik. \\n\\n&b&lElite&r: pindahin satu tumpukan (stack) Item/Blok sejauh 4 blok tiap detik. \\n\\n&d&lUltimate&r: pindahin 2 tumpukan (stack) Item/Blok sejauh 10 blok tiap detik."]
	quest.60ECCCAB66AAC05D.quest_subtitle: "Item"
	quest.60ECCCAB66AAC05D.title: "&eLogistical Transporters"
	quest.60FAD8BF235E381B.title: "&bRare&r Ink"
	quest.60FC2DAEA954A849.quest_desc: ["&6Moonworm Queen&r itu seperti pelontar obor. Ia meluncurkan &eMoonworm&r ke blok target, yang akan menerangi blok tersebut mirip seperti obor.\\n\\nItem ini bisa ditemukan di beberapa peti loot &2Hollow Hill&r dan &eLich Tower&r."]
	quest.60FC2DAEA954A849.title: "&6Moonworm Queen"
	quest.60FDCA2FDFE74056.quest_desc: [
		"PINK! \\n\\nDi sini kamu bakal nemuin Scarlet Tree dengan daun mereka yang jatuh menumpuk di bawah mereka. Kamu juga bisa nemuin Glowing Mushroom di sini!"
		"{image:atm:textures/questpics/eternal/starlight_scarlet.png width:200 height:100 align:center}"
	]
	quest.60FDCA2FDFE74056.title: "Scarlet Forest"
	quest.610F9E9D0B5131C7.quest_desc: ["&6Charm of Keeping I&r akan mencegahmu kehilangan barang di tangan utama, tangan kiri, serta armor yang kamu pakai saat kamu mati."]
	quest.610F9E9D0B5131C7.title: "&6Charm of Keeping I"
	quest.6112956E19017D2D.quest_desc: ["Logic Cable berbeda dari &e&lPipez&r atau &5&lPipa Meka&r lainnya. Pipa lainnya bekerja seperti Hopper, item berpindah dari inventaris 1, ke dalam pipa, baru ke inventaris 2. Logic Cable langsung melewati perantara tersebut yang juga menghilangkan banyak lag. \\n\\nKabel ini hanya digunakan untuk menghubungkan Importer dan Interface."]
	quest.6112956E19017D2D.title: "Logic Cable"
	quest.61213012615619C5.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Otomatis mengasap barang yang dijatuhkan dari pembunuhan."
	]
	quest.612157986673F815.quest_desc: ["Beri makan para lebah apa pun kecuali Bunga sebanyak 48 kali!"]
	quest.61217D80BFF8A858.quest_desc: ["Tingkat ketiga dan terakhir dari &5Ender Lead&r sudah hadir! Yang ini tidak bisa hancur dan bahkan bisa mengikat mob ke Spawner. Ini membutuhkan setup &d&lInfusion&r yang jauh lebih rumit. Kita butuh setidaknya &a75 Eterna&r, &c85% Quanta&r, dan antara &560-85% Arcana&r.\\n\\nKamu bisa mendapatkan ini dengan 4 &9Soul-Touched Sculkshelves&r, 4 &9Echoing Sculkshelves&r, 2 &7Stoneshelves&r, dan satu Bookshelf vanilla. Oh, dan kamu juga butuh seorang Witch yang terikat di Ender Lead yang digunakan untuk &d&lInfusion&r ini."]
	quest.61217D80BFF8A858.quest_subtitle: "Nggak ada hubungannya sama Occultism, sumpah"
	quest.61217D80BFF8A858.title: "&5Occult Ender Lead"
	quest.6124C0E9E419694B.quest_desc: ["Tingkatkan peralatan &7Cloggrum&r dengan &aForgotten Ingot&r dan sebuah Smithing Template. \\n\\nInilah peralatan terbaik yang bisa kamu dapatkan, sudah memiliki efek Efficiency khusus untuk blok-blok &2&lUndergarden&r. \\n\\nPedang dan kapaknya juga memberikan damage lebih besar ke semua mob &2&lUndergarden&r kecuali &cRotbeast&r dan &aForgotten Guardian&r!"]
	quest.6124C0E9E419694B.title: "Peralatan &aForgotten&r"
	quest.613AC4DF39E5621D.quest_desc: [
		"Gazebuzz Cluster adalah kumpulan puluhan ruangan gantung yang tidak terhubung satu sama lain. \\n\\nAku tidak bisa menyebutkan semuanya atau aku akan mengetik seharian! Intinya: ada ruangan berisi &6Madu&r, Daun, Loot, dan bahkan jebakan seru! \\n\\nKamu harus berhati-hati di sini, terutama dengan &6Madu&r dan Lukisan..."
		"{image:atm:textures/questpics/bumblezone/bumble_cluster.png width:200 height:100 align:center}"
	]
	quest.613AC4DF39E5621D.title: "Gazebuzz Cluster"
	quest.6140EAA6E042EF7C.quest_desc: ["&6&lSkyhook&r bekerja baik sebagai Alat maupun Senjata. \\n\\nBisa memukul Mob dengannya seolah-olah Pedang atau menggunakannya untuk bergerak di sekitar base! \\n\\nKetika mendekati &cKabel&r (&6LV&r, &eMV&r, &5HV&r, Terisolasi, Rami, &8Baja&r, &4Redstone&r) bisa Tahan Klik Kanan untuk menempel padanya. Kemudian, bisa bergerak untuk meluncur di &cKabel&r! \\n\\nJika ingin menggunakannya pada &cKabel&r aktif, perlu beberapa Upgrade! Upgrade seperti: Motor Torsi Tinggi, Pegangan Terisolasi, dan Kait Dampak Berat. \\n\\nBisa menampung 2 Upgrade."]
	quest.6140EAA6E042EF7C.quest_subtitle: "Booker tangkap!"
	quest.6140EAA6E042EF7C.title: "&6&lSkyhook Insinyur"
	quest.61419D230687CBB5.quest_desc: ["Velocity adalah kecepatan item pada arah tertentu. Karena Arrow kita bukan dari Guardian of the Galaxy pada dasarnya hanya berarti Kecepatan Arrow. Dengan setiap upgrade waktu yang dibutuhkan Arrow untuk pergi dari Bow-mu ke Target-mu lebih sedikit. Datang dengan biaya sedikit ketidakakuratan."]
	quest.61419D230687CBB5.title: "Wyvern Projectile Velocity Module"
	quest.6141DE779232C8AA.title: "&l&cThe Nether Bounty:&r&e Blazes"
	quest.6144202A97C6CD1C.quest_desc: ["&bQuartz Cutting Knife&f adalah alat bantu crafting yang berguna. Kabel dapat dipisahkan tanpa perlu diwarnai dengan memasang &bCable Anchor&f di antaranya yang dibuat menggunakan pisau ini.\\n\\nCable Anchor juga digunakan untuk membuat &bCable Facade&f guna menyamarkan kabel di dalam dinding dengan blok lain. Klik kanan dengan pisau ini juga akan membuka GUI untuk membuat &bInscriber Name Press&f yang berguna untuk memberi nama pada item lewat Inscriber."]
	quest.6144202A97C6CD1C.quest_subtitle: "Pisau Quartz"
	quest.6144202A97C6CD1C.title: "Cable Anchor"
	quest.614937A2F5823F3E.quest_subtitle: "Muncul menggunakan Nether Brick Nest di dimensi Nether"
	quest.614937A2F5823F3E.title: "Magmatic Bee"
	quest.61500C8F68509E5D.quest_desc: [
		"Pada kunjungan pertamamu ke &d&lFloral Meadows&r kamu mungkin tidak menyadari adanya teman kecil ini yang bersembunyi di rumput. \\n\\nRootmin berpura-pura menjadi Blok Rumput dengan &dBunga&r di atas kepala mereka. \\n\\nJika kamu tidak memakai Bee Armor, mereka mungkin melempar butiran tanah saat kamu lewat. \\n\\nKamu bisa mengganti &dBunga&r di kepala mereka dengan Klik Kanan menggunakan bunga yang berbeda!"
		"{image:atm:textures/questpics/bumblezone/bumble_rootmin2.png width:100 height:150 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_rootmin1.png width:100 height:100 align:center}"
	]
	quest.61500C8F68509E5D.title: "Rootmin"
	quest.615B9062FE8CCD36.quest_desc: ["Otomatis mengganti ke alat yang paling efektif untuk blok yang sedang kamu bidik."]
	quest.615C3E012B2DECD3.quest_desc: ["&eSpellbook&r! Di mana lagi kamu akan menaruh &3Spell&r? \\n\\nKamu bisa menambah &3Scroll&r ke &eSpellbook&r dengan menaruh keduanya ke Inscription Table. Mereka punya jumlah tertentu yang bisa ditampung tapi tidak perlu khawatir lagi tentang Rarity. \\n\\nSaat &3Scroll&r ditambahkan ke &eSpellbook&r mu mereka tidak akan dikonsumsi melainkan Mana yang akan dikonsumsi."]
	quest.615C3E012B2DECD3.title: "&eSpellBook&r!"
	quest.616364E6AE05C341.quest_desc: ["&bMineral Salt&r terbuat dari... yah, mineral. \\n\\nSegala sesuatu yang ditambang dalam bentuk bijih bisa diubah menjadi &bGaram&r. Bijih Mentah, Ingot, Permata, semuanya bisa menjadi &bMineral Salt&r! \\n\\nBahkan Unobtainium bisa dijadikan &bGaram&r! Tapi tolong jangan lakukan itu, masih banyak alternatif lain yang lebih baik."]
	quest.616364E6AE05C341.title: "&bGaram Mineral"
	quest.616B6046EF5DDF21.quest_desc: ["Elite Importer memiliki 18 slot filter dan bekerja 2x lebih cepat."]
	quest.616B6046EF5DDF21.title: "Elite Importer"
	quest.616ED6C49C37EB91.quest_desc: ["&b&lPaths and Pathways&r menambahkan banyak blok mirip karpet (dan versi blok penuh serta slab). \\n\\nIni jelas digunakan sebagai Jalan, tampilannya jauh lebih bagus daripada blok Path milik &2&lMinecraft&r."]
	quest.616ED6C49C37EB91.title: "Jalan dan Trotoar &b&lMacaw's"
	quest.616F9B78B16B42A5.quest_desc: ["Resep buat &6Tesla Coil&r mungkin keliatan rumit, terutama di pohon resep, tapi kita bisa breakdown jadi lebih simpel!\\n\\n&7Aluminum Plate&r sangat simpel, cuma butuh pake Hammer di Ingot atau Metal Press Multiblock.\\n\\n&8Iron Mechanical Component&r simpel juga, cuma beberapa Iron Plate dan &6Copper Ingot&r.\\n\\n&eElectrum Coil Block&r butuh banyak &eElectrum Ingot&r dipotong jadi Wire. &eElectrum&r adalah alloy dari &eGold&r dan Silver.\\n\\n&6Advanced Electronic Component&r adalah seluruh array pake Engineers Workbench dan &9Blueprint&r. Duroplast Sheet-nya butuh banyak refining dan fermenting dengan Multiblock Machine!\\n\\nItem terakhir, &cHV Accumulator&r butuh beberapa Item simpel kayak &8Steel&r, &7Aluminum Plate&r, &cRedstone Acid&r, dan &4Treated Wood&r. Juga butuh Item lebih rumit yang disebut &8HOP Graphite Ingot&r."]
	quest.616F9B78B16B42A5.title: "&6Tesla Coil"
	quest.61768CFEDA041E4D.quest_desc: ["Setelah masuk ke &6&lBumblezone&r kamu mungkin perlu kembali ke &2Overworld&r. Misalnya kalau kamu lupa mematikan kompor! \\n\\nUntuk keluar dari &6&lBumblezone&r kamu bisa menambang ke arah bawah atau atas melewati &eBeehive Beeswax&r untuk masuk ke Void. \\n\\nVoid ini tidak akan membunuhmu, melainkan akan menteleportasikanmu kembali ke tempat asalmu di &2Overworld&r!"]
	quest.61768CFEDA041E4D.quest_subtitle: "Keluarkan aku dari sini!"
	quest.61768CFEDA041E4D.title: "Melarikan Diri"
	quest.617695A9CA45D88F.quest_desc: ["Saat menggunakan &c&lLaserIO&r untuk &lLogistik&r, kamu mungkin akan berakhir dengan BANYAK Kartu. Karena setiap kartu memakan satu slot di inventarismu, itu bisa jadi sangat sempit. Seandainya ada tempat penyimpanan kartu... oh tunggu, ada kok, namanya Card Holder! \\n\\nKamu bisa menyimpan banyak Kartu di dalamnya dan saat kamu membuka Laser Node, Card Holder juga akan terbuka seperti inventaris kedua. Sangat membantu!"]
	quest.617695A9CA45D88F.title: "Card Holder"
	quest.617C6D6C35B4917D.quest_desc: [
		"&dPixie&r adalah wanita kecil Bersayap, Bercahaya yang tinggal di dalam dan sekitar &dDesa Pixie&r mereka! \\n\\nMereka keliatan kayak Player cuma lebih deket ke ukuran Vex. Mereka juga dateng dalam beberapa Warna berbeda: Biru, Hijau, Kuning, Pink, dan Ungu. Ini bakal penting nanti. \\n\\nMereka cuma punya 5 Hearts dan sepenuhnya Pasif! Akhirnya Mob yang baik! \\n\\nDaripada bantai mereka (mereka kayaknya gak suka, mereka suka ngeluh) kita bisa Tame mereka atau perbudak mereka! \\n\\nJangan khawatir kalian monster yang gak bermoral, perbudakan kasih Hadiah lebih banyak daripada pembunuhan!"
		"{image:atm:textures/questpics/iceandfire/iaf_pixie.png width:100 height:125 align:center}"
	]
	quest.617C6D6C35B4917D.title: "&dPixie"
	quest.618411DCC5C1A13C.quest_subtitle: "Berikan debu Plutonium ke Radioactive Bee"
	quest.618411DCC5C1A13C.title: "Uranite Bee"
	quest.61847F47CCA225D9.quest_desc: ["Ikutin pola yang sama, yang ini smelt di 140 Tick atau 7 Detik.\\n\\nBisa di-craft dari &6Copper&r atau Iron Furnace dan bisa dipake buat craft &eGold Furnace&r."]
	quest.61847F47CCA225D9.title: "Silver Furnace"
	quest.6187837A51BA09DC.quest_desc: ["&cCitadel&r adalah Struktur terbesar yang diberikan &lIron's Spells&r kepada kita. Ini hampir seluruhnya terbuat dari &0Blackstone&r. \\n\\nIni punya Tembok dan Menara besar yang mengelilingi dan menghubungkan ke bangunan utama. Ini punya &5Ancient Knight&r Spawner dan Barrel Loot. \\n\\nBangunan utama punya Library/Research Room di lantai pertama. Yang satu ini punya miliaran Buku serta Chest dan lebih banyak &5Ancient Knight&r! \\n\\nLantai di atas akan punya Citadel Vault serta &5Cursed Armor Stand&r. Hati-hati mencoba mengambil Loot mereka, mereka mungkin akan membela properti mereka! \\n\\nLantai paling atas adalah arena..."]
	quest.6187837A51BA09DC.title: "&cCitadel"
	quest.618F1434757C8E69.quest_desc: ["&lGenerator's Galore&r nambahin Generator yang simpel banget. Yang paling basic kerjanya kayak Furnace dengan &3Augment&r: Generator. Bakal ambil Fuel dan bikin jadi Energi! \\n \\nIya kamu harus mulai dari &6Copper Generator&r."]
	quest.618F1434757C8E69.title: "&6Copper Generator&r"
	quest.61999669BDE127F9.quest_desc: [
		"Jika kamu belum menyadarinya, membuat dan mengulang ritual berkali-kali sangat menguras durabilitas Kapurmu. "
		""
		"Jika kamu khawatir kapurmu patah, tapi malas melakukan seluruh ritual untuk membuat kapur baru dari awal, maka ritual ini cocok untukmu!"
		""
		"Menggunakan kekuatan &aDijini&r, kamu bisa memperbaiki warna Kapur apa pun ke kondisi maksimalnya!"
		""
		"Sebagai alternatif, kamu bisa menggunakan sesuatu seperti &aEternal Stella&r dari mod Forbidden Arcanus untuk mengawetkan Kapurmu selamanya!"
	]
	quest.61999669BDE127F9.quest_subtitle: "Kamu merusaknya, &mpara&r Setan memperbaikinya!"
	quest.61999669BDE127F9.title: "Perbaikan Kapur"
	quest.61A22707DBC83818.quest_desc: ["Storage Access Point bertindak sebagai perpanjangan Storage Controller. Bisa digunakan untuk memasukkan atau menarik item. Intinya adalah titik akses untuk jaringan Drawer."]
	quest.61A8FAEC4FF18449.quest_desc: ["Item ini bisa digunakan untuk mengisi daya item di inventarismu, atau digunakan untuk meningkatkan kapasitas daya total dari saluran &7Ender Network&r."]
	quest.61AD2207E770CD7F.quest_desc: ["Memungkinkanmu mengambil item dan experience dari jarak yang lebih jauh."]
	quest.61AD2207E770CD7F.quest_subtitle: "Maks: 6"
	quest.61B479079DC1C69C.quest_desc: ["Memungkinkanmu melompat lebih tinggi daripada Tingkat I."]
	quest.61B479079DC1C69C.quest_subtitle: "Maks: 1"
	quest.61BA2932EC86DA2E.quest_desc: ["Memungkinkanmu melompat SANGAT tinggi."]
	quest.61BA2932EC86DA2E.quest_subtitle: "Maks: 1"
	quest.61BE7882EE0E6FAF.quest_desc: ["Lagu tentang Log (Batang Kayu) dari Ren and Stimpy... \\nItu Batang Kayu! Batang Kayu! Batang Kayu!"]
	quest.61C49BC2B384FB80.quest_desc: ["Setelah mengumpulkan cukup Ender Pearl dan Blaze Powder, bisa menuju End Portal di Overworld.\\n\\nUntuk melakukannya, craft beberapa &dEye of Ender&r dan klik kanan untuk melemparnya ke langit. Ini akan menunjuk ke arah End Portal terdekat.\\n\\nPergi ke Stronghold, temukan End Portal, dan lengkapi frame menggunakan Eye of Ender untuk membuat portal ke &dThe End&r."]
	quest.61C49BC2B384FB80.title: "&aMenemukan &dThe End"
	quest.61C93ABE07742DCD.quest_desc: [
		"Steam Turbine menggunakan Uap (Steam) untuk menghasilkan energi FE dan EU. \\n\\nIni adalah bangunan 3x2x2 yang terdiri dari Steam Turbine Housing, memerlukan Turbine Motor di dalamnya, dan uap yang dialirkan lewat pipa."
		"{image:atm:textures/questpics/railcraft/rail_turbine.png width:100 height:100 align:center}"
	]
	quest.61C93ABE07742DCD.title: "Turbin Uap (Steam Turbine)"
	quest.61DA3D61D7103647.quest_desc: ["&eAlchemical Sulfur&r bisa dibuat dari apa saja dan bisa diubah menjadi apa saja! \\n\\nAda beberapa kelompok item dalam &eAlchemical Sulfur&r yang akan dijelaskan di quest lain. \\n\\nAda 3 jalur utama dalam memproses &eAlchemical Sulfur&r: 1. Fermentasi dan Digestion untuk membuat Niter. 2. Inkubasi untuk menciptakan kembali item aslinya, dan 3. Mengubah item tersebut melalui proses Reformasi (Reformation)."]
	quest.61DA3D61D7103647.title: "&eAlchemical Sulfur"
	quest.61DCECE1FC38E151.title: "Reaktor (Nitro)"
	quest.61F265D9A5713A4D.quest_desc: ["Setiap upgrade nge-upgrade semuanya, dari jumlah yang dibuat sampe berapa banyak yang bisa ditahan sampe apa yang bisa ditransfer ke block lain! \\n \\nKamu butuh &6Copper Generator&r buat bikin Iron Generator, maaf buat yang benci &6Copper&r."]
	quest.61F265D9A5713A4D.title: "&fIron Generator"
	quest.62089E9E6D596DA7.quest_desc: ["&3The &bImmolator&r adalah &3Annihilator&r yang di-upgrade dengan &bIgnitium Ingot&r di dalam &4Mechanical Fusion Anvil&r. \\n\\nSenjata ini memberikan damage lebih besar pada mob yang terkena efek &bBlazing Brand&r, jadi &bBlazing Grip&r sangat cocok dipadukan dengannya! \\n\\nJika kamu memegang &3The &bImmolator&r di masing-masing tangan, kamu bisa Menahan Klik Kanan untuk memanggil serangan &bFlame Strike&r di bawahmu. Ini akan melukai semua mob di dalamnya dan meledak di akhir!"]
	quest.62089E9E6D596DA7.title: "&3The &bImmolator"
	quest.62161BDE9AAAA4BF.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_wayfinder.png width:100 height:150 align:center}"]
	quest.62161BDE9AAAA4BF.quest_subtitle: "Trail Ruins"
	quest.62161BDE9AAAA4BF.title: "Wayfinder Armor Trim"
	quest.6220EDE42C813C1B.quest_desc: ["Bagian terburuk dari &eCharm&r adalah mereka bisa hancur! Kenapa efek ramuan se-OP ini harus punya durabilitas! \\n\\nTenang saja, mod &5&lApotheosis&r punya obatnya... yaitu dengan &d&lInfusion&r! \\n\\nKamu butuh &a100 Eterna&r, di antara &c8,5% &fdan &c13,5% Quanta&r, serta di antara &532,5% &fdan &537,5% Arcana&r. \\n\\nKamu bisa memakai 10 &4Glowing Hellshelves&r, 4 &6Geode-Encased Bookshelves of Stability&r, 2 &dDraconic Endshelves&r, dan satu Skeleton Skull! \\n\\nYa, beberapa Tengkorak dan item lain selain &7Rak Buku&r juga bisa memberikan statistik!"]
	quest.6220EDE42C813C1B.title: "Charm Abadi"
	quest.6235B9923BE0AAEB.quest_desc: ["Enchanter adalah blok yang bikin kamu bisa nambah enchantment ke item yang bisa di-enchant pakai item dan essence."]
	quest.6235B9923BE0AAEB.title: "&bEnchanter"
	quest.623796B1D7981E59.quest_desc: ["'Cobain juga game Terraria!'\\n\\nSaat dipakai, kamu akan mendapatkan tambahan 5 Heart! Alias 10 poin HP tambahan! Menjadikan total darahmu 30 HP pada setelan awal."]
	quest.623796B1D7981E59.quest_subtitle: "Sabuk"
	quest.623796B1D7981E59.title: "&4Crystal Heart&r"
	quest.623E6A855B363C8D.quest_desc: ["&9Water Block&r berfungsi sebagai Air tanpa bagian mengalirnya.\\n\\nBisa digunakan untuk Cobble Gen, mengairi Farmland, hanya saja kamu tidak bisa melakukan MLG clutch dengannya. (Ikan juga akan mencoba masuk ke dalamnya tapi tetap akan mati)."]
	quest.623E6A855B363C8D.quest_subtitle: "Air tapi Padat, Es?"
	quest.623E6A855B363C8D.title: "&9Water Block"
	quest.6255E2FE6DD4084A.quest_subtitle: "Holly + Alder"
	quest.6256612D46C88C0C.quest_desc: [
		"&#723CFATransformer&r mengubah satu rentang daya ke rentang lainnya. "
		""
		"&#723CFATransformer &#EBC471LV&r ke &#DDE548MV&r: Mengubah daya &#EBC471LV&r menjadi daya &#DDE548MV&r, memiliki 5 input dan 1 output."
		""
		"&#723CFATransformer &#DDE548MV&r ke &#EBC471LV&r: Mengubah daya &#DDE548MV&r menjadi daya &#EBC471LV&r, memiliki 1 input dan 5 output."
	]
	quest.6256612D46C88C0C.quest_subtitle: "\"Kebebasan adalah hak semua makhluk hidup\""
	quest.6256612D46C88C0C.title: "Transformer LV-MV"
	quest.6258F26293B9C1C1.quest_desc: ["Apa yang diberikan &9&lCrystalix&r kepada kita? \\nIa memberikan Kaca! Semua tipe kaca yang berbeda! Ada Normal, Clear (Bening), dan Bordered (Berbingkai). \\n\\nBordered adalah pola kaca &2&lMinecraft&r normal. Ia memiliki bingkai dan piksel di dekat sudut untuk memberitahumu bahwa itu adalah kaca. Clear memiliki bingkai tapi tidak ada piksel di sudut, jadi bagian dalamnya bersih. Normal tidak memiliki bingkai atau piksel, sepenuhnya 100% bening dan satu warna. \\n\\nSetiap kaca &9&lCrystalix&r memiliki propertinya sendiri: Shadeless (Tanpa Bayangan), Reinforced (Diperkuat), Light (Cahaya), dan Ghost (Hantu). \\n\\nShadeless akan mempengaruhi reaksinya terhadap Shader dan pencahayaan &2&lMinecraft&r. Reinforced akan mempengaruhi Blast Resistance (Ketahanan Ledakan). Light akan menentukan apakah ia mengeluarkan cahaya, mengabaikan cahaya, atau bertindak seperti kaca normal. Ghost akan memungkinkanmu mengubah siapa yang bisa menembus kaca tersebut, yang ini memiliki paling banyak pengaturan."]
	quest.6258F26293B9C1C1.title: "&9&lCrystalix"
	quest.62622137648A4F56.quest_desc: ["Bosan harus nambang terus ngebakar bijih pakai dua alat berbeda? Nah, sekarang kamu bisa jadi lebih malas dengan &7Pickaxe Heater&r!\\n\\nSambil memakai &7Pickaxe Heater&r, bijih yang kamu tambang akan otomatis terbakar/meleleh (Smelted)!\\n\\nHati-hati ya kalau kamu butuh fitur Ore Processing (pemrosesan bijih)."]
	quest.62622137648A4F56.quest_subtitle: "Tangan"
	quest.62622137648A4F56.title: "&7Pickaxe Heater&r"
	quest.6263A27182B2CE3D.quest_desc: ["Beberapa &5Mesin&r itu sedikit lebih canggih, jadi artinya kita butuh &cItem yang lebih Canggih&r buat bikinnya! \\n\\nNgomongin soal &c&lAdvanced&r, mereka butuh bahan yang sama kayak mesin &c&lAdvanced Tier&r."]
	quest.6263A27182B2CE3D.title: "Mesin yang lebih baik"
	quest.6280748583C62E05.quest_subtitle: "Red Maple + Jungle"
	quest.62827AA1AD29A222.quest_desc: ["&aUniversal Cables&r dipakai buat mindahin &aEnergi&r dari &5Mesin &fke &5Mesin&r! \\n\\nHampir semua &5Mesin&r punya sisi penerima &aEnergi&r standar yang ditandain kotak &aHijau&r. Ini bisa diganti di GUI mesin di bagian Side Configs. \\n\\n&5Mesin&r juga bakal bagi &aEnergi&r yang ada di dalamnya ke &5Mesin&r lain di sebelahnya, kalau Config-nya sudah diset!\\n\\n&aUniversal Cables&r dibuat pakai 2 &8Steel Ingot&r dan satu &4Redstone Dust&r. Bisa di-upgrade dengan gabungin 8 kabel tier yang sama sama &aControl Circuit&r! \\n\\n&a&lBasic&r: nampung dan pindahin 3.2kFE tiap Tick. \\n\\n&c&lAdvanced&r: nampung dan pindahin 51.2kFE tiap Tick. \\n\\n&b&lElite&r: nampung dan pindahin 409.6kFE tiap Tick. \\n\\n&d&lUltimate&r: nampung dan pindahin 3.27mFE tiap Tick."]
	quest.62827AA1AD29A222.title: "&aUniversal Cables"
	quest.62991D7431A48F6D.quest_subtitle: "Banana + Kapok"
	quest.62A262A706CFCAF0.quest_desc: ["Kita gak bakal bikin Dark Power Gem pakai kolam darah lagi.\\n\\nSebaliknya, kita bisa bikin &9Blood Infuser&r buat lakuin semua kerja kotor buat kita. Ini bikin kamu bisa langsung infuse item dengan darah!\\n\\nIni bisa di-upgrade pakai &6Promises&r juga. Ini salah satu mesin utama yang dipake buat progres!"]
	quest.62A262A706CFCAF0.title: "&a&cBlood Infuser"
	quest.62B29AEF8468750E.quest_desc: ["Tunggu, jadi kita dapet lebih sedikit &aEnergi&r dari &6Sumber Panas&r dan bikin &aEnergi&r dari mereka? Gue daftar! \\n\\nPas lo jalan di &6Magma&f, lewat &6Api&f, atau di &6Lava&r lo bakal dapet &aEnergi&r di &a&lMekaSuit Pants&r. \\n\\nKalo punya &aCharge Distribution &7Unit&r di &a&lMekaSuit Bodyarmor&r, juga bakal Charge &a&lMekaSuit Part&r lain."]
	quest.62B29AEF8468750E.quest_subtitle: "Celana"
	quest.62B29AEF8468750E.title: "&6Geothermal Generator &7Unit"
	quest.62B4A37CFDECA679.quest_desc: ["Menril Resin akan pergi ke 2 sisi Squeezer. Menempatkan Drying Basin di sebelah Squeezer akan membuat Drying Basin mengambil Menril Resin.\\n\\nSetelah 7.5 detik Menril Resin akan berubah jadi Block of Crystallized Menril."]
	quest.62B5A84753ADFC35.quest_subtitle: "8 Blok Pink Tua Kering"
	quest.62C32905C33E2D88.quest_desc: ["&dEye of Void&r akan menuntunmu ke &dRuined Citadel&r untuk melawan &d&lEnder Guardian&r."]
	quest.62C32905C33E2D88.title: "&dEye of Void"
	quest.62C60FF24B2F7290.quest_desc: ["&bArcane Crystal&r bisa spawn dari Y Level 14 sampai -40. \\n\\nCukup umum; tapi percaya, kamu butuh banyak, jadi bersyukur! \\n\\nSeperti &bDiamond&r ada Y Level yang paling umum spawn, untuk &bArcane Crystal&r Y Level itu adalah -13."]
	quest.62C60FF24B2F7290.title: "&bArcane Crystal"
	quest.62CE0FFAF6352287.quest_desc: ["Mesin EvilCraft bisa di-upgrade pakai &6Promises&r. Tiap Promise bakal punya efek berbeda, tapi pertama, kita mau upgrade Blood Infuser kita buat unlock resep lebih banyak.\\n\\nBuat ini, kita butuh bikin &6Promise of Tenacity: Tier 1&r. Umumnya, ini cuma nambah storage capacity mesin. Buat Blood Infuser, ini bakal unlock resep lebih banyak!"]
	quest.62CE0FFAF6352287.title: "&aMeng-upgrade Mesin"
	quest.62D39F68DE6E44A4.quest_desc: ["&5Arcana&r adalah nilai yang sangat penting. Ia meningkatkan jumlah &5Enchantment&r yang kamu dapatkan, dan membuat &5Enchantment&r langka jadi lebih sering muncul. \\n\\nContohnya pada Pedang; &5Smite&r adalah &5Enchantment&r yang sangat umum, sedangkan &5Looting&r jauh lebih langka. \\n\\nNilai standar &5Arcana&r adalah &50%&r dan maksimalnya &5100%&r."]
	quest.62D39F68DE6E44A4.title: "&5Arcana"
	quest.62D572BAB055F56F.quest_subtitle: "Tingkat: &e1"
	quest.62DDE5B1287BEB36.quest_desc: ["Bagian lain dari isi &6&lATM Star&r yang juicy adalah &6Awakened &5Unobtainium&f-&3Vibranium&r Alloy Block, yang bakal gue panggil &6Awakened Alloy&r block. \\nBuat dapetin ini kamu butuh multiblock &6&lStar Altar&r, (cek Quest Crafting the Star buat info lebih!) \\n\\nDi sana kamu harus input &5Unobtainium&f-&3Vibranium&r Block, 4 Unbreaking I Book, 4 &6Awakened Supremium Gemstone&r, dan 4 &6Awakened Supremium Essence&r. \\n\\nTerus kamu harus kasih 85 Juta FE... Setelah itu, Alloy-mu seharusnya udah Awakened!"]
	quest.62DDE5B1287BEB36.title: "&6Awakened &5Unobtainium&f-&3Vibranium&r Alloy Block"
	quest.62DF58D36B739EA0.quest_desc: ["&eWadjet&r mirip dengan &eKobolediator&r karena ia berdiam di dalam &eCursed Pyramid&r menunggu pemain mendekat. \\n\\n&eWadjet&r punya 1050 &4HP&r dan untungnya tidak memberimu efek Mining Fatigue! \\nIa punya banyak serangan; saat dekat ia akan mengayunkan senjatanya. Jika jauh ia mungkin melempar Sandstorm atau menjatuhkan blok pasir dari langit-langit tepat ke kepalamu. \\n\\nJujur saja, aku tidak tahu serangan mana yang lebih buruk! \\n\\nSaat mati mereka menjatuhkan Ancient Metal Ingot."]
	quest.62DF58D36B739EA0.title: "&eWadjet"
	quest.62F33BBE7BDFE404.quest_desc: ["Wand of Teleportation adalah drop lain dari Lunar Monstrosity, dan cuma itu! \\n\\nKamu bisa hold Right Click dengan Wand buat mulai, terus kalau kamu lepas dia bakal teleport kamu ke Blok yang kamu lihat terakhir! \\n\\nAda jangkauan tapi lumayan jauh. Dan ada cooldown setelah dipake!"]
	quest.6314B892B569A0A5.quest_desc: ["Starlight! \\n\\nDimensi dimana selalu Senja, dan gak kamu gak bisa ganti. \\n\\nAda puluhan Biome, Mob, Boss, dan bahkan Blok buat ditemuin! Bisa kamu temuin semua?"]
	quest.6314B892B569A0A5.title: "Eternal Starlight"
	quest.631796E7615C04FA.quest_desc: ["&2Amethyst Crab&r tinggal di Lush Cave bersama para Axolotl. \\n\\nIa punya 2800 &4HP&r dan awalnya bersifat netral. Artinya ia tidak akan menyerang duluan, tapi akan membalas jika dipukul. \\n\\nSerangannya berupa pukulan capit, melempar Amethyst, dan menggali masuk ke dalam tanah. \\n\\nSaat mati ia menjatuhkan daging dan cangkangnya. Dagingnya bisa diberkati di Altar of Amethyst agar lebih berkhasiat. Cangkangnya bisa di-craft menjadi Bloom Stone Pauldron yang punya statistik mirip Netherite Chestplate tapi dengan kemampuan mirip sang kepiting."]
	quest.631796E7615C04FA.title: "&2Amethyst Crab"
	quest.632BC46928CC9A8C.quest_desc: ["&9Enchanter's Mirror&r akan memberikan mantra tipe 'self' saat digunakan. \\n\\nMantra yang dirapal dengan cermin ini mendapatkan potongan biaya mana dan tambahan durasi bonus. \\n\\nUntuk memasang mantra, gunakan Scribe's Table. Buatlah mantranya tanpa menggunakan 'form'."]
	quest.63362CC33B39C627.quest_desc: [
		"Starlit Sea adalah badan Air gede yang duduk rapi antara Warm Shore dan daratan. \\n\\nMereka punya banyak keajaiban di dalamnya dan tumbuh di dalamnya! \\n\\nSemoga kamu bawa kacamata renang!"
		"{image:atm:textures/questpics/eternal/starlight_starlitsea.png width:200 height:100 align:center}"
	]
	quest.63362CC33B39C627.title: "Starlit Sea"
	quest.633D6361DA680C75.quest_desc: ["Mencampur &#E6ED98Light Fuel&r dengan Uap (Steam) akan menghasilkan &#DBE37FSteam Cracked Light Fuel&r."]
	quest.6353A39CBEE599A0.quest_desc: ["Suka menggabungkan Inventaris dan membuat cara untuk melihat serta berinteraksi dengan semua Inventaris tersebut melalui beberapa &6Mesin&r sederhana mirip &b&lAE2&r dan &7&lSophisticated Storage&r? \\n\\nKalau iya, kamu butuh &eStock Link&r! \\n\\n&eStock Link&r bisa dipasang di &ePackager&r untuk terhubung ke Inventaris yang tersambung dengan &ePackager&r. Ketika pertama kali dipasang, &eJaringan Stock&r baru akan dibuat. \\n\\nBisa terhubung ke Peti, Tong, bahkan &eVault&r! \\n\\nKamu juga bisa Klik Kanan &eStock Link&r lain dengan &eStock Link&r di tangan untuk menyamakannya ke &eJaringan&r yang sama. Ketika &eStock Link&r baru dipasang ke &ePackager&r lain, Blok Inventaris-nya akan ditambahkan ke &eJaringan&r yang sama. \\n\\nKalau ingin berinteraksi dengan &eJaringan&r ini kamu butuh Blok lain!"]
	quest.6353A39CBEE599A0.title: "&eStock Link"
	quest.635620A03E3505BF.quest_desc: ["Gak mau tau gimana kamu dapetin ini."]
	quest.635620A03E3505BF.quest_subtitle: "Tapi....Sapi gak bisa digunting..."
	quest.635620A03E3505BF.title: "Kulit"
	quest.635BA2C17458E9E6.quest_desc: ["Meski resepnya simpel, kamu bakal dapet mesin yang sangat berguna! \\n\\nTinggal taruh (arah hadapnya pas ditaruh nentuin arah tembaknya, kayak dispenser!), kasih tenaga, dan atur cara kerjanya pakai &4Redstone Torch&r. \\n\\nKalau diatur ke 'deactivate', berarti dia bakal mati kalau kena &4Redstone Signal&r. Kalau 'On Pulse', dia bakal aktif tiap kali dapet &4Redstone Signal&r. \\n\\nKita cuma fokus buat otomatisasi &6&lStar&r doang jadi aku nggak bakal bahas terlalu dalem, kita mulai dari Lens dulu!"]
	quest.636848ED1115A0B3.quest_desc: [
		"Ratlin adalah Mob damai yang bisa spawn di Surface. \\n\\nKalau mati mereka bakal drop Ratlin Meat, Leather, dan Cave Moss. \\n\\nYang terakhir bisa dipake buat Breeding mereka!"
		"{image:atm:textures/questpics/eternal/starlight_rat.png width:100 height:100 align:center}"
	]
	quest.636848ED1115A0B3.title: "Ratlin"
	quest.636854555AD75DC3.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Otomatis teleportasi barang jatuhan ke inventori yang terikat dengan alat. Shift Klik Kanan alat pada inventori untuk mengikatnya. Perlu dicatat saat di cangkul JDT, barang yang dijatuhkan oleh kemampuan panen otomatis dari lahan voidshimmer / shadowpulse diteleportasi ke inventori yang terikat, juga klik kanan lahan voidshimmer / shadowpulse akan mengikat ulang jika inventori terikat alat telah diubah."
	]
	quest.63768C7B988ED22B.quest_desc: ["Bawa &bStrengthened Diamond Sword&r ke kolam &dDragon's Breath&r dan akan mendapat &d&lClarent&r! \\n\\n&d&lClarent&r bekerja sebagai Shield dan Sword. \\n\\nTahan Right Click untuk blok dengan &d&lClarent&r dan serangan apapun yang diblokir akan memberikan damage yang sama dengan yang diblokir."]
	quest.63768C7B988ED22B.title: "&d&lClarent"
	quest.637981B64BBE0D92.quest_desc: ["&aCharging Station&r adalah blok yang sangat membantu di awal permainan. \\n\\nFungsinya jelas untuk mengisi daya item. Kamu bisa menyalurkan energi melalui pipa atau menggunakan bahan bakar tungku (furnace fuel) untuk menghasilkan energi FE. \\n\\nLalu, letakkan item apa pun yang butuh daya ke dalam slot paling kanan."]
	quest.637981B64BBE0D92.title: "&l&aCharging Gadgets"
	quest.637C87D8968CD51A.title: "&aUncommon&r Ink"
	quest.639531AB27DCD267.quest_desc: ["&7Rune&r adalah cara kita membuat Kelas dan bagiannya. Untuk mendapatkan &7Blank Rune&r kamu bisa membunuh &4&lDead King&r atau menghapus Inscribed Rune dengan Shriving Stone. \\n\\nAda 8 kelas berbeda (1 rahasia) masing-masing punya &3Scroll&r, Focus Material, Upgrade, dan Outfit sendiri."]
	quest.639531AB27DCD267.title: "&lKelas"
	quest.63AE4568375DD1BF.quest_desc: ["Dengan &dGarmonbozia&r, sekarang kita bisa bikin &aEnvironmental Accumulator&r sendiri."]
	quest.63AE4568375DD1BF.quest_subtitle: "Environmental Accumulator Sendiri"
	quest.63AE4568375DD1BF.title: "Sanguinary Environmental Accumulator"
	quest.63B0E39CA4B25A7E.quest_desc: ["&dNutritional Paste&r dibuat dari proses &eItem&r apapun yang kasih Food Bar pas dimakan lewat &d&lNutritional Liquifier&r. \\n\\nBayangkan kayak Blender gede! Gue gak bisa jamin &dNutritional Paste&r bakal enak rasanya... \\n\\n&a&lMekaSuit Helmet&r bisa nyimpen &dNutritional Paste&r dan dengan &7Unit&r ini bakal otomatis ngasih makan pas lo kehilangan Hunger Point."]
	quest.63B0E39CA4B25A7E.quest_subtitle: "Helmet"
	quest.63B0E39CA4B25A7E.title: "&dNutritional Injection &7Unit"
	quest.63C95FDAA447CA47.quest_desc: ["Satu-satunya resep yang butuh &3&lTier 2&r, &7Terrastomp Prism&r! \\n\\nKamu butuh &7Dripstone&r, &7Dripstone&r, dan &8Flint&r sama dengan &bDiamond Block&r! \\n\\nSeperti Prism lain ini butuh &3Elementarium&r Relic untuk dibuat. \\nSeperti &cFiery Prism&r, &7Terrastomp Prism&r bisa dipakai dengan Tool. Tool ini bisa mine di Area 3x3, daripada cuma 1 Blok di-mine akan mine 9!"]
	quest.63C95FDAA447CA47.title: "&7Terrastomp Prism"
	quest.63CAD77A4488F2CE.quest_subtitle: "Beliung + Kapak + Sekop"
	quest.63DD7F5A4441ACE7.quest_desc: ["Glyph Tingkat 2 membutuhkan 5 level experience untuk dibuat. \\n\\nKamu juga butuh &9Mage's Spell Book&r untuk menciptakannya."]
	quest.63E4529AF8894018.quest_desc: ["&lModular Routers&r adalah mod logistik. \\n\\nSemua dimulai dari Router! Jadi buatlah satu! \\n\\nBuffer adalah satu-satunya slot item di Router tempat item keluar masuk. Kamu butuh sinyal Redstone agar kebanyakan module bisa bekerja."]
	quest.63E4529AF8894018.title: "&lModular Routers"
	quest.63F41475236F99D2.quest_desc: ["\"Hei nak, aku punya Cheat X-Ray, mau nggak?\" \\n\\n&8Seismic Vibrator &f dan &8Seismic Reader&r kerja bareng buat kasih tahu blok apa yang ada di bawah kita. \\n\\n&8Seismic Vibrator&r itu sebuah &5Mesin&r. Dia butuh &aEnergi&r dan pas sudah ada, dia bakal \"&8Bergetar&r\" di Chunk tempat dia ditaruh. \\n\\n&8Seismic Reader&r itu sebuah &eItem&r dan juga butuh &aEnergi&r! Kalau nggak ada di Chunk yang sama sama &8Vibrator&r, dia nggak bakal jalan. \\n\\nKalau ada, dia bakal kebuka. Layarnya bolehin kita lihat blok yang beda di tiap level Y di bawah blok tempat kamu berdiri. \\n\\nIni emang nggak sempurna, tapi bener-bener ngebantu! Bahkan cuma buat cari Goa doang!"]
	quest.63F41475236F99D2.title: "Cheat Seismic"
	quest.63F5314A1072FA05.quest_desc: [
		"&e&lGergaji&r bekerja mirip dengan &7&lPres Logam&r, menggunakan &eSabuk Konveyor&r dan memerlukan Barang ekstra. \\n\\nBekerja dalam 2 tahap, pertama Mengupas Log. Jika tidak memiliki Bilah Gergaji di dalamnya, hanya akan Mengupas Log. Tahap kedua adalah memotong Log menjadi Papan, ini memerlukan Bilah Gergaji. \\n\\nBilah Gergaji dibuat dengan banyak &8Baja&r. Mereka memiliki Daya Tahan dan untuk memasukkannya, Klik Kanan Slot di dekat Belakang Gergaji. Jika ingin mengeluarkannya, matikan Gergaji dengan &4Redstone&r, lalu Shift Klik Kanan di mana dimasukkan. \\n\\nPerlu memberinya &cEnergi&r di Atas sisi Belakang, dan bisa &9Memasukkan &eBarang&r melalui &eSabuk Konveyor&r. &eBarang&r akan &6Keluar&r dengan &eSabuk&r yang sama, tetapi Serbuk Gergaji keluar dari Port di Depan &e&lMesin&r."
		"{@pagebreak}"
		"Buat bentuk I dengan &8Perancah Baja&r (jangan lupa &7Blok Teknik Berat&r) dan isi satu bagian dengan &eBlok Teknik Ringan&r dan yang lain dengan &7Lembar Besi&r."
		"{image:atm:textures/questpics/immersive/immersive_saw1.png width:150 height:100 align:center}"
		"Letakkan 3 &eBlok Teknik Ringan&r lagi pada kawan bawahnya. Tambahkan 1 &7Lembar Besi&r di &7Lembar Besi&r paling kiri dan di sebelahnya letakkan &4Blok Teknik Redstone&r. Di sebelah &7Lembar Besi&r atas perlu &7Blok Teknik Berat&r lain. Jangan lupa tambahkan Sabuk Konveyor, ini diperlukan untuk Membangunnya!"
		"{image:atm:textures/questpics/immersive/immersive_saw2.png width:100 height:100 align:center}"
		"Klik Kanan &7Lembar Besi&r tengah dengan Palu!"
		"{image:atm:textures/questpics/immersive/immersive_saw.png width:100 height:100 align:center}"
	]
	quest.63F5314A1072FA05.title: "&e&lGergaji"
	quest.63F6F4EBCEB914B0.quest_desc: ["&3Pressure Chamber&r adalah struktur multiblock penting yang terdiri dari &3Pressure Chamber Wall&r (Sisi-sisinya bisa diganti dengan &3Pressure Chamber Glass&r). Ukurannya bisa sekecil 3x3x3 atau sebesar 5x5x5. Blok yang dibutuhkan untuk ukuran 5x5x5 adalah syarat untuk menyelesaikan quest ini.\\n\\nUntuk menggunakan Pressure Chamber, kamu harus mengalirkan tekanan udara ke &3Pressure Chamber Valve&r menggunakan &3Pressure Tube&r, jangan lupa pasang Security Upgrade pada katup tersebut. &lResep yang berbeda membutuhkan jumlah tekanan yang berbeda pula&r.\\n\\nKamu butuh cara untuk memasukkan dan mengeluarkan item; di sinilah &3Pressure Chamber Interface&r berperan. Warna biru di bagian luar berarti untuk mengimpor item, sedangkan warna emas berarti untuk mengekspor item; pasang masing-masing satu di sisi mana pun."]
	quest.63F6F4EBCEB914B0.quest_subtitle: "Pemberian Tekanan!"
	quest.63F6F4EBCEB914B0.title: "Pressure Chamber"
	quest.640D6ADA17709D3A.quest_subtitle: "Yellow Meranti + Kapok"
	quest.64141B720662B652.quest_desc: ["Selamat datang di &6&lRelics&r! \\n \\nMod &6Relics&r mirip dengan Artifacts, kamu akan mendapatkan banyak item unik dan kuat di seluruh penjuru dunia. \\n \\nMereka memiliki banyak kemampuan berbeda yang didapat dan ditingkatkan melalui &6Research Window&r (Tahan Shift pada relic). Di sana kamu bisa menukarkan &aVanilla XP&r untuk mengacak ulang (reroll) statistik kemampuannya, melihat &eRelic XP&r saat ini yang didapat dari penggunaan &6Relic&r, dan menaikkan level kemampuannya! \\n \\nTombol standar untuk menggunakan kemampuan &6Relic&r adalah Alt Kiri."]
	quest.64141B720662B652.title: "&l&6Relics"
	quest.641888DC7BC40AA9.quest_desc: [
		"&aBenteng&r yang dijaga ketat adalah rumah &a&lArchevoker&r dan pengikutnya. \\n\\nKamu akan tahu melihatnya dari Tembok Spruce besar dan &aBenteng&r Batu raksasa di dalamnya. \\n\\nIllager, Vindicator, &aEvoker&r, dan Ravager bisa ditemukan di dalam Tembok dan &aBenteng&r. Setelah melewati mereka kamu bisa naik tangga, parkour ke Atap, dan bertemu &aPemimpin Benteng&r di atas. \\n\\nDengan dijaga ketat tentu saja ada banyak loot di dalam &aBenteng&r."
		"{image:atm:textures/questpics/iron_spells/spells_evokerfort.png width:200 height:100 align:center}"
	]
	quest.641888DC7BC40AA9.title: "&aEvoker Fort"
	quest.6431A384DDFBF439.quest_desc: [
		"&bNetwork Tool&f adalah alat penting untuk menampilkan detail jaringan seperti konsumsi daya dan penyimpanan. "
		""
		"Sebagai bonus, alat ini menyediakan slot inventaris kecil untuk menyimpan &eupgrade card&f, yang bisa diakses saat melihat layar perangkat apa pun untuk penggantian cepat. Alat ini tidak bisa memutar blok, hanya bisa membongkarnya."
	]
	quest.6431A384DDFBF439.title: "Network Tool"
	quest.6434796EAAF2A4EC.quest_desc: ["Setelah menyelesaikan semua misi ini, kamu bisa Klik Kanan sang &5Ratu&r untuk mendapatkan Essence of Bees. \\n\\n&lMakanlah!&r \\n\\nSekarang kamu bisa melakukan apa saja di sini. Kamu bisa mengambil &6Madu&r dengan aman dari semua sarang, sarang madu, dan lebah madu. Kamu bisa jalan melewati Labirin Sel tanpa efek Wrath of the Hive, masuk ke &5Pilar Takhta&r tanpa Mining Fatigue, dan jalan di atas Ancient Wax tanpa efek buruk. Dan saat kamu masuk ke cairan madu atau Royal Jelly kamu akan mendapatkan efek luar biasa. \\n\\nBagian terbaiknya adalah efek ini menetap bahkan setelah kematian! Sekarang kamu bisa masuk ke fase akhir (endgame)!"]
	quest.643FB1A3ED0EA9EC.quest_desc: ["Valve adalah jantung dari Tank milikmu. Di sinilah tempat kamu memompa atau mengalirkan cairan masuk."]
	quest.643FB1A3ED0EA9EC.quest_subtitle: "Tempat Cairan Datang dan Pergi"
	quest.643FB1A3ED0EA9EC.title: "Valves"
	quest.6451D5022BCB5E7E.quest_desc: ["Daging sapi abadi, eh tunggu salah mod. &cInfinity Ham&r berfungsi sebagai sumber makanan tak terbatas. Makanlah semua daging dari tulangnya dan ia akan beregenerasi setelah beberapa waktu. Kamu bisa meng-upgrade-nya agar lebih mengenyangkan. \\n \\nKemampuan kedua dari &cInfinity Ham&r adalah merendamnya dalam ramuan (Potion). Saat kamu melakukannya, setiap kali kamu memakan &cHam&r tersebut, kamu akan mendapatkan efek ramuan itu. Jika kamu menghabiskan seluruh dagingnya, efeknya akan hilang."]
	quest.6451D5022BCB5E7E.quest_subtitle: "Ditemukan di Desa atau Outpost"
	quest.6451D5022BCB5E7E.title: "&cInfinity Ham"
	quest.6474FE12450A4A7D.quest_desc: [
		"&5Pilar Takhta (Throne Pillar)&r terlihat mirip dengan pilar sarang biasa tapi yang ini didekorasi dengan indah menggunakan &5Kristal&r, Jaring, dan sarang madu dalam desain yang elegan. \\n\\nDi tengah pilar ini terdapat Ruang Takhta tempat kamu akan bertemu..."
		"{image:atm:textures/questpics/bumblezone/bumble_throne.png width:200 height:100 align:center}"
	]
	quest.6474FE12450A4A7D.title: "Pilar Takhta"
	quest.647A87E800C703C3.quest_desc: [
		"Biome favoritku sejauh ini! \\n\\nHutan hijau raksasa dengan Pohon Gronglegrowth yang sangat besar. \\n\\nDi pohon-pohon itu kamu bisa menemukan &eGronglet&r!"
		"{image:atm:textures/questpics/undergarden/undergarden_grongle.png width:200 height:100 align:center}"
	]
	quest.647A87E800C703C3.title: "Gronglegrowth"
	quest.64860340A5BEBAB9.quest_desc: ["&eTaplak Meja&r bisa digunakan untuk memamerkan &eItem&r, atau menjualnya! \\n\\nUntuk membuka Toko, lakukan semua langkah dari Quest sebelumnya: pasang &eStock Link&f, &eStock Ticker&r, dan Mob di Kursi atau &cPembakar Blaze&r. \\n\\nSekarang gunakan &eTaplak Meja&r untuk Berinteraksi dengan Mob atau &cPembakar Blaze&r — ini akan menghubungkan &eTaplak Meja&r ke &eStock Ticker&r tersebut. \\n\\nLetakkan &eTaplak Meja&r dan kamu bisa menaruh &eItem&r yang ingin dijual di atasnya, beserta harganya di bawah. \\n\\nKetika seseorang membeli &eItem&r, pesanan akan dikirim ke &eStock Link&r, yang akan &eMengemas&f &eItem&r yang dibeli dan mengambil pembayarannya."]
	quest.64860340A5BEBAB9.quest_subtitle: "Dengan Taplak Meja"
	quest.64860340A5BEBAB9.title: "Toko"
	quest.649167FC31EB916E.quest_desc: ["&3Vegetable Oil&r (Minyak Nabati) dapat dibuat dengan memasukkan hasil panen atau benih ke dalam &3Thermopneumatic Processing Plant&r."]
	quest.649167FC31EB916E.quest_subtitle: "Minyak yang Lebih Baik"
	quest.649167FC31EB916E.title: "Minyak Nabati"
	quest.6497A255E427A5EB.quest_subtitle: "Balsam Fir + Bull Pine"
	quest.64A09E2E3EF16C31.quest_subtitle: "Banana + Teak"
	quest.64B04D1CBC923789.quest_subtitle: "Tingkat: &b4"
	quest.64C105E1E2F97900.quest_desc: ["Spike Maul digunakan pada &6Rel&r normal untuk mengubah modenya. Sangat berguna untuk membuat persimpangan!"]
	quest.64C105E1E2F97900.title: "'Ganti Modenya'"
	quest.64D0D69ADB8820DA.quest_desc: ["&8Fluid Void&r adalah blok yang menghentikan semua air yang terhubung dengannya.\\n\\nBaik blok sumber (source) maupun air mengalir, apa pun dalam radius 1 blok akan lenyap."]
	quest.64D0D69ADB8820DA.title: "&8Fluid Void"
	quest.64D0E66CB4FBEC82.quest_desc: ["Untuk memulai, kamu perlu membuat &6Novice Spellbook&r! \\n\\nDi sinilah kamu membuat dan menyimpan mantra-mantramu. \\n\\nMenekan tombol &9C&r akan membuka halaman 'Create a Spell'. Di sebelah kiri ada beberapa tab, tapi 3 yang utama adalah: Spell Creation, Color Picker, dan Familiars. \\n\\nSpellbook ini hanya memungkinkanmu membuat dan menggunakan Glyph Tingkat 1. Untuk membuat mantra yang lebih hebat, kamu perlu meng-upgrade Spellbook milikmu!"]
	quest.64D0E66CB4FBEC82.quest_subtitle: "Spellbook Pertama Kita"
	quest.64D0E66CB4FBEC82.title: "Buku Mantra"
	quest.64D34A6C3487C5DF.quest_desc: ["&3Aerial Interface&r dapat digunakan untuk mengisi ulang item-itemmu dengan tekanan udara secara nirkabel. Sekarang kamu bisa memakai Pneumatic Armor tanpa perlu repot mengisi ulang!\\n\\nKamu akan butuh alat ini untuk men-craft &6ATM Star&r."]
	quest.64D34A6C3487C5DF.quest_subtitle: "Tekanan Nirkabel!"
	quest.64D6C395B6304F40.title: "&eKomponen Penyimpanan Cairan 65536B"
	quest.64E2E05B228EA53E.quest_desc: ["&3Advanced Pressure Tube&r adalah pipa tekanan udara terbaik yang tersedia, mampu menahan hingga 20 bar tekanan!\\n\\nMeskipun pipa ini sudah keren, mereka juga bisa digunakan dalam beberapa resep yang jauh lebih keren."]
	quest.64E2E05B228EA53E.quest_subtitle: "Tingkatan Baru!"
	quest.64E85274D24FE394.quest_desc: ["Saat terhubung ke sistem, &9Storage Monitor&r akan menampilkan jumlah stok item tertentu yang ada di dalam jaringanmu saat ini."]
	quest.64E85274D24FE394.title: "Storage Monitor"
	quest.64EC182B81BD8B86.quest_desc: ["Buat maju, kita harus bikin &5Dark Power Gem&r pertama.\\n\\nBuat ini, kamu butuh kumpulin minimal 5 bucket darah di &aBlood Extractor&r kamu. Kalau udah dikumpulin, bikin lubang dengan minimal 5 blok ruang, terus isi dengan darah.\\n\\nKalau udah bikin kolam darah, lempar &9Dark Gem&r buat infuse."]
	quest.64EC182B81BD8B86.title: "&dMeng-infuse Gem dengan&r &cDarah"
	quest.64EED65F80A91D9E.quest_subtitle: "Tingkat: &b3"
	quest.64FEF31955CB158D.quest_desc: ["Kenai bunga dengan Pollen Puff untuk menumbuhkan 8 bunga lagi."]
	quest.64FF7118E29931C0.quest_desc: ["Sebelum membahas berbagai &eItem&r yang bisa dihasilkan dari &6Batu Giling&r, mari bahas cara penggunaannya! \\n\\nPertama, butuh &dTenaga Rotasi&r, tenang saja — hanya sedikit yang dibutuhkan. \\n\\nKemudian, jatuhkan &eItem&r yang ingin di-&6Giling&r ke bagian atas &6Batu Giling&r. Setelah selesai, cukup Klik Kanan &6Batu Giling&r untuk mengambil &eItem&r-mu. \\n\\nLalu, &eItem&r apa saja yang bisa kita dapatkan dari &6Batu Giling&r? Kita bisa mendapat Pewarna dari hampir semua Bunga, menghancurkan &7Batu&r menjadi Kerikil atau Blok &7Batu&r lain menjadi Kerikil serupa. Bahkan bisa mendapatkan Tepung Gandum dari Gandum!"]
	quest.64FF7118E29931C0.title: "&6Batu Giling"
	quest.6501A410F1543C70.quest_desc: ["Mystical Fertilizer kerjanya kayak Bonemeal, tapi lebih bagus. Dia langsung ngegedein apapun yang dipake sampe matang penuh."]
	quest.6501A410F1543C70.title: "&dMystical Fertilizer"
	quest.6518480251F0565A.quest_desc: ["Tunggu kalo Paxel bisa bikin Path, bikin Farmland, sama Strip Log kenapa &dMeka-Tool&r gak bisa! \\n\\nOh tunggu, bisa kalo lo pake &2Farming &7Unit&r. \\n\\nLo perlu enable yang diset di Config. Lo gak bisa bikin Soil sama Farmland dari Grass yang sama! \\n\\nKita gak bisa pake ini sama &7Shearing Unit&r atau &5Teleportation &7Unit&r."]
	quest.6518480251F0565A.quest_subtitle: "Meka-Tool"
	quest.6518480251F0565A.title: "&2Farming &7Unit"
	quest.652A14E17DDE97E6.quest_desc: ["Yang lain yang butuh Ruined Book untuk Craft. Kamu bisa menemukan Ruined Book di Chest &9Ancient City&r. \\n\\nKamu juga butuh Dragon Skin yang drop dari &dEnder Dragon&r! \\n\\nIni akan punya 12 &3Spell&r Slot dan memberikan boost untuk &dEnder Spell&r!"]
	quest.652A14E17DDE97E6.title: "&dDragonskin Spell Book"
	quest.654F5C84114A31A1.quest_desc: ["Armor mod &e&lIron's Spells&r yang sangat simpel dan murah, sangat membantu di awal permainan!"]
	quest.654F5C84114A31A1.quest_subtitle: "20"
	quest.654F5C84114A31A1.title: "&4Scarecrow Outfit"
	quest.6552E301C370D203.quest_subtitle: "&f7 &cAttack Damage"
	quest.6559C57A1A476489.quest_subtitle: "+5 Attack Speed"
	quest.655BD0A54AF1E1CA.quest_desc: ["Kita sudah melihat cukup banyak perabotan untuk di dalam ruangan, tapi bagaimana dengan luar ruangan? Kamu tidak bisa pesta BBQ di dalam rumah! \\n\\nSet luar ruangan memberikan kita Panggangan, Kotak Pendingin (Cooler), dan Bel Pintu agar tamu bisa membunyikannya untuk memberitahu bahwa mereka telah sampai!"]
	quest.655BD0A54AF1E1CA.title: "Set Luar Ruangan"
	quest.655BE42CD5BB9D82.title: "Draconic Area-Of-Effect Module"
	quest.655FB110E5F66DF0.quest_subtitle: "Berikan Shadowpulse Goo ke Ancient Bee"
	quest.655FB110E5F66DF0.title: "Eclipse Alloy Bee"
	quest.655FF7295B688354.quest_desc: ["&9Clawdian&r adalah mini-bos di &9Acropolis&r. \\n\\nMereka adalah lobster raksasa yang memegang kapak yang bahkan lebih besar! \\n\\nPunya 225 &4HP&r dan 12 Poin Armor. \\n\\nMereka suka menggunakan Kapak dan Kakinya untuk menyerang; mulai dari ayunan kapak ber-damage sedang, menghantam tanah dengan kapak memicu Shockwave, hingga menghentakkan kaki memicu Shockwave besar dan serangan &9Gelombang&r! \\n\\nJika kamu menjauh, mereka akan menyerudukmu sambil menghancurkan blok di jalurnya! \\n\\nJika kamu bisa membunuhnya, mereka akan menjatuhkan capitnya (&9Claw&r). Agak sadis tapi untungnya ini cuma kekerasan fantasi!"]
	quest.655FF7295B688354.title: "&9Clawdian"
	quest.657B3116A6419420.quest_subtitle: "Gagang milikmu sendiri!"
	quest.657DB994B029F61C.quest_desc: [
		"Saat &3Heat Frame&r dipasang pada kontainer berisi cairan tertentu dan dibuat cukup dingin, ia akan mengubah cairan tersebut menjadi item."
		""
		"Mengubah Molten Plastic menjadi Plastik."
		"Mengubah Air menjadi Es."
		"Mengubah Lava menjadi Obsidian."
	]
	quest.6581D4AF1A6DE230.quest_desc: ["Setan suka Lilin. Sepertinya begitu.\\n\\nUntuk hampir setiap Ritual pemanggilan teman kita, kamu butuh beberapa Lilin. Kamu bisa membuat &aButcher Knife&r dan membunuh babi, sapi, domba, kuda, atau bahkan Llama Pedagang untuk mendapatkan &aTallow&r (Lemak) sebagai bahan pembuatnya. Malah, kamu benar-benar harus mencari Llama Pedagang. Kudengar mereka menghasilkan lilin yang bagus. &mSumpah aku nggak asal ngomong&r.\\n\\nSelain itu, Lilin Vanilla juga bisa digunakan!\\n\\n&9Spirit Attuned Crystal&r juga digunakan dalam beberapa Ritual, jadi lebih baik buat sekarang saja!"]
	quest.6581D4AF1A6DE230.title: "Persiapan Ritual: &aLilin"
	quest.658DEAAD1E68E549.quest_desc: ["Blok ini expand crafting storage Quantum Core. Efektif nambah jumlah task concurrent yang bisa dijalankan Quantum Computer. Juga diperlukan buat bikin Quantum Computer Core."]
	quest.658DEAAD1E68E549.title: "Crafting Storage Gede: Quantum Computer Storage"
	quest.659A903F97F93BE2.quest_subtitle: "Cepat dan Simpel"
	quest.659A903F97F93BE2.title: "Roti Kehidupan"
	quest.65A529C8238E89F1.quest_desc: ["Berkat &5&lMekanism&r kita sekarang bisa membuat Armor dari &9Lapis Lazuli&r! \\n\\nTapi sejujurnya... armor ini agak ampas."]
	quest.65A529C8238E89F1.quest_subtitle: "9"
	quest.65A529C8238E89F1.title: "&9Lapis Lazuli Armor"
	quest.65A7307F9858ECB5.quest_desc: ["Mempengaruhi kegalakan lebah. Ada 4 tingkat: &aPassive&r, &9Normal&r, &cHostile&r, &dAggressive&r. Lebah &dAggressive&r AKAN menyengatmu tanpa alasan. Lebah akan jadi lebih jinak jika kamu sering memberi mereka Honey Treat."]
	quest.65A7307F9858ECB5.quest_subtitle: "Berhenti menyengatku!"
	quest.65A7307F9858ECB5.title: "&4&lSifat Pemarah (Temper)"
	quest.65C8A43FEDBA3835.quest_desc: ["&3Pattern Grid&r memungkinkanmu memasukkan resep ke dalam Pattern untuk jaringanmu.\\n\\nCara termudah untuk membuat resep adalah dengan mencari item di JEI, lalu klik tombol '+' di pojok kanan bawah resep tersebut. Resep akan otomatis terpasang di grid.\\n\\nDi sisi kanan, slot atas digunakan untuk menyimpan Pattern kosong. Dengan Pattern kosong di dalamnya, klik tanda panah di bawahnya untuk mencetak resep ke Pattern tersebut.\\n\\nJangan lupa masukkan Pattern hasilnya ke dalam &3Autocrafter&r!"]
	quest.65C8A43FEDBA3835.title: "&3Pattern Grid"
	quest.65D89991A45BC042.quest_desc: ["Taruh Crafting Interface pada crafting table dan klik kanan, ini akan memberikan beberapa slot untuk &bVariable Card&r. \\n\\nMenggunakan Logic Programmer, cari &eRecipe&r di kiri atas, dan buat satu untuk autocrafting, lalu simpan ke &bVariable Card&r. Kalau resep &c&lmembutuhkan&r item yang perlu di-craft, buat resep untuk masing-masing, lalu masukkan semuanya ke Crafting Interface."]
	quest.65D89991A45BC042.quest_subtitle: "&l&cA&6U&eT&aO &bC&dR&9A&3F&0T"
	quest.65D993EB95726067.title: "Hati-hati dengan Kuil"
	quest.65E2AF881709C896.quest_desc: ["Salah satu material terpenting yang akan kamu butuhkan adalah &3Reinforced Stone&r, buatlah 32 buah menggunakan Compressed Iron dan batu biasa."]
	quest.65E2AF881709C896.quest_subtitle: "Kamu bakal butuh banyak ini"
	quest.65E2AF881709C896.title: "Reinforced Stone"
	quest.65E733AACBE62EDB.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_ward.png width:100 height:150 align:center}"]
	quest.65E733AACBE62EDB.quest_subtitle: "Ancient Cities"
	quest.65E733AACBE62EDB.title: "Ward Armor Trim"
	quest.65E98FCE27B552F4.quest_desc: ["&aGigi Hydra&r adalah Drop umum dari &a&lHydra&r. \\n\\nKita bisa pake mereka daripada Flint buat daripada bikin Anak Panah normal kita bisa bikin &aAnak Panah Hydra&r. \\n\\n&aAnak Panah Hydra&r bakal kasih Mob yang kena, &aRacun&r, dan bakal kasih kamu balik beberapa &4Health&r yang mereka ambil."]
	quest.65E98FCE27B552F4.title: "&aAnak Panah Hydra"
	quest.65FA86357BC60573.quest_desc: ["Saatnya memindahkan barang dari satu tempat ke tempat lain. Ini langkah-langkahnya:\\n\\n&l1.&r Taruh interface pada inventory (seperti Chest atau Tank)\\n\\n&l2.&r Taruh Importer atau Exporter pada inventory lain, tergantung mau pull atau send barang ke sana.\\n\\n&l3.&r Hubungkan keduanya dengan Cable, masukkan Variable Card ke Importer atau Exporter, dan selesai!"]
	quest.65FA86357BC60573.quest_subtitle: "Memindahkan Barang!"
	quest.6601450C63FEEE61.quest_desc: ["&bTier 3&r setara dengan Beliung Besi (Iron Pickaxe), dapat menambang sebagian besar bijih seperti Diamond, Emerald, dan Emas."]
	quest.6601450C63FEEE61.title: "&bHarvest Tier 3"
	quest.6601ACCDDF6CA5FF.quest_desc: ["Reactor hanya bisa menyimpan 1 Miliar OP dan meskipun itu mungkin terlihat seperti angka jauh, tidak akan lama. Saat Energy Saturation mencapai 100%% akan meningkatkan Heat banyak yang bisa menyebabkan Meltdown. Butuh 500,000,000 OP untuk activate dan Flux Gate akan membantu membatasi berapa banyak OP yang masuk dan keluar. (BTW 1 RF = 1 OP) Mereka butuh Redstone untuk activate dan bisa digunakan untuk menambah OP dan mengeluarkan OP. Kamu butuh Energy keluar untuk tidak Meltdown, coba masukkan ke Energy Core!"]
	quest.6601ACCDDF6CA5FF.title: "Jump start"
	quest.66039B738CF0718A.quest_desc: ["&3Vibranium&r yang digabungkan dengan &6Allthemodium&r!"]
	quest.66039B738CF0718A.title: "Alloy Ingot &3Vibranium&r - &6Allthemodium&r"
	quest.6607E5CDB3D17D67.quest_desc: ["Tenang saja, ini tidak akan terbakar!"]
	quest.6607E5CDB3D17D67.title: "Wol &l&bChipped&r"
	quest.660D8AD3EE975340.quest_desc: ["&bWeapon Parts&r akan diperlukan untuk Craft beberapa Senjata. \\n\\nDan ya, kita harus Craft ini juga. \\n\\nMereka cukup sederhana, hanya 3 &bMithril Ingot&r dan 2 &5Arcane Ingot&r. \\n\\n&5Arcane Ingot&r dibuat dari 1 &6Copper Ingot&r dan 8 &5Arcane Essence&r."]
	quest.660D8AD3EE975340.title: "&bWeapon Parts"
	quest.661114AFCBBD5F28.quest_desc: [
		"&aKuburan&r spawn umumnya di seluruh &3The Other&r. Mereka keliatan kayak Kuburan. \\n\\nDi sini kita bisa nemuin &aPeti Terkutuk &fdan &aTanah Kuburan&r yang spawn secara natural. \\n\\nKita juga bisa nemuin &0Mawar Wither&r dan Tengkorak Skeleton, juga Loot di dalam &aPeti Terkutuk&r."
		"{image:atm:textures/questpics/iceandfire/iaf_struct_ghost.png width:200 height:100 align:center}"
	]
	quest.661114AFCBBD5F28.title: "&aKuburan"
	quest.6616A62426ED4D15.quest_desc: ["Injector perlu di sisi berbeda dari semua Stabilizer dan harus berbagi Axis yang sama dengan Core. Di sinilah OP perlu dipompa masuk! Untuk activate dan membuat OP Energy Saturation perlu dinaikkan sedikit. Energy Saturation adalah Energy yang disimpan dan segera dibuat Energy."]
	quest.6616A62426ED4D15.title: "Reactor Energy Injector"
	quest.661C072E48F8D41F.quest_desc: [
		"&6Copper&r salah satu atau bahkan Ore paling umum yang bisa kamu temuin, jadi kenapa ga pakai banyak &6Copper&r sisa buat upgrade furnace kamu!"
		""
		"Furnace biasa butuh 200 Tick buat smelt 1 Item, (20 Tick = 1 Detik) sementara &6Copper Furnace&r butuh 180 Tick."
		""
		"Bisa di-craft jadi &7Silver&r atau &fIron Furnace&r."
	]
	quest.661C072E48F8D41F.title: "&6Copper Furnace"
	quest.662DD269B027B6C8.quest_desc: ["Tidak bisa mengisi &c&lRansel Akumulator&r secara nirkabel... tetapi bisa mengisinya &ckabel&r! \\n\\nCukup pasang Antena Pengisian ke &c&lRansel Akumulator&r dan berjalan ke &cKabel&r apa pun yang mentransportasi &cEnergi&r dan sebagian akan datang ke &c&lRansel&r."]
	quest.66324D7D0C51AEAC.quest_desc: ["Upgrade Base digunakan untuk men-craft berbagai jenis Upgrade di mod Productive Bees."]
	quest.6647A9652EFDDCDF.quest_desc: ["Untuk mendinginkan &#ADF0EEHot Stainless Steel Ingot&r, cukup masukkan ke dalam &#56E3DFVacuum Freezer&r untuk mengubahnya menjadi &#ADF0EEStainless Steel Ingot&r yang siap pakai."]
	quest.6648BC7D14233006.quest_desc: ["Augment mirip dengan Upgrade tetapi untuk masing-masing Module secara individu!"]
	quest.6648BC7D14233006.title: "&lAugment"
	quest.6667638252DB9C74.quest_desc: ["&8Sigil&r adalah item yang digunakan untuk mengubah &eAffixed Item&r &6&lApotheosis&r-mu; entah itu mengosongkan &9Socket&r, menambah &9Socket&r, atau menghapus nama! \\n\\nSemuanya digunakan dengan menggabungkan item-mu di &8&lSmithing Table&r, &9&lReforging Table&r, atau &6&lAugmenting Table&r."]
	quest.6667638252DB9C74.quest_subtitle: "Sekarang cuma Sigil!"
	quest.6667638252DB9C74.title: "&mVial dan&r &8Sigil"
	quest.666EA8B8F13EB292.quest_desc: ["Item ini digunakan untuk menangkap mob untuk transportasi atau penyimpanan. Juga dibutuhkan untuk membuat &6ATM Star&r."]
	quest.666EA8B8F13EB292.title: "&dEmpty Soul Gem"
	quest.666FFDFDB7C869F5.quest_desc: [
		"&8Burung Stymphalian&r ternyata Burung marah yang terbuat dari &8Logam&r. Setidaknya, itu asumsi gue dari deket dan diserang sama mereka. \\n\\nMereka Burung Cokelat dengan &8paruh Abu-abu &fdan &8cakar&r. Mereka juga gerak berkelompok dan semuanya Hostile. \\n\\n&8Burung Stymphalian&r punya 12 &4Hearts &fdan 4 &7Armor Points&r. \\n\\nMereka punya 2 Serangan: 1. adalah Serangan sangat dasar yaitu spam &8Bulu&r mereka ke kamu. Mereka gak kasih Damage banyak tapi punya Knockback jelek dan cepat! 2. cuma Gigitan simple yang bakal kasih Damage lebih banyak dari &8Bulu&r. \\n\\nMereka juga bisa terbang ke kamu atau mundur sangat cepat! \\n\\nSatu &8Burung&r sendiri bukan masalah besar, tapi mereka biasanya gak dateng sendiri! Paling baik lawan mereka satu per satu dan cepet deket ke mereka."
		"{image:atm:textures/questpics/iceandfire/iaf_bird.png width:200 height:100 align:center}"
	]
	quest.666FFDFDB7C869F5.title: "&8Burung Stymphalian"
	quest.6674270897997BF7.quest_desc: ["Memungkinkanmu melompat lebih tinggi dari biasanya dan membuatmu membal, sehingga perjalanan jadi lebih cepat.\\n\\nKamu hanya bisa memasang satu tingkat upgrade ini pada Leggings dalam satu waktu."]
	quest.6674270897997BF7.quest_subtitle: "Maks: 1"
	quest.66762A4743104157.quest_desc: ["&eSpellbook&r yang bisa di-craft lain, yang ini sedikit lebih mahal! Ini butuh Hogskin yang merupakan drop dari Hoglin. \\n\\nYang ini bisa menampung 8 &3Spell&r yang secara teknis masih di sisi rendah tapi lebih baik!"]
	quest.66762A4743104157.title: "Apprentice's Spell Book"
	quest.6678AB58930F4B91.quest_subtitle: "White Willow + Aspen"
	quest.667B95A687703D6D.quest_desc: ["Pernah ingin menembakkan Diamond Sword dari Bow? Atau Netherite Hoe? Atau pada dasarnya \"Weapon\" apapun? \\n\\nKalau begitu, &b&lBow of Weapon Projectiles&r jawabannya! \\n\\nPunya dua Mode yang bisa diganti lewat Shift Right Click: Normal dan Projection. Yang berubah hanya apakah mengambil Weapon apapun dari Inventory (Normal) atau hanya dari Offhand (Projection). \\n\\nWeapon yang ditembakkan dari &b&lBow&r akan bertindak seperti Trident yang dilempar, bisa diambil kembali seperti itu juga. \\n\\nWeapon akan memberikan damage yang sama dengan ayunan normal!"]
	quest.667B95A687703D6D.title: "&b&lBow of Weapon Projectiles"
	quest.667CD7C6E87A05F4.quest_desc: ["&l&9X&cy&aC&8r&aa&cf&9t&r tentu saja berkaitan dengan warna, lampunya juga berbasis warna. \\n\\nLampu RGB akan memiliki warna sesuai pewarna (Dye) yang digunakan untuk membuatnya. \\n\\nSpesifik menggunakan Dye, bukan permata (Gem)."]
	quest.667CD7C6E87A05F4.title: "Lampu &l&9X&cy&aC&8r&aa&cf&9t&r"
	quest.668C313FF46B6005.quest_desc: ["Menambahkan fungsi Furnace (Tungku) ke dalam Tas."]
	quest.6690AEE064DC2A7C.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:"
		""
		"Meningkatkan area yang ditambang sekaligus. Saat dipasang di alat tingkat lebih tinggi, area maksimal yang ditambang meningkat. Area yang ditambang bisa dikonfigurasi di menu."
	]
	quest.66A450CAC07232E1.quest_desc: ["&6Thermodynamic Conductors&r bakal mindahin &6Panas&r. Iya, ada beberapa &5&lMekanism&r &5Mesin&r yang pakai &6Panas&r! Kayak &6&lThermal Evaporation Machine&r. \\n\\nKebanyakan &6Heater&r punya sisi tetap buat Output &6Panas&r! \\n\\nAku nggak yakin angka-angka ini artinya apa tapi polanya: makin mahal, makin bagus!"]
	quest.66A450CAC07232E1.quest_subtitle: "Panas"
	quest.66A450CAC07232E1.title: "&6Thermodynamic Conductors"
	quest.66AADD32A528A56D.quest_subtitle: "Tingkat: &63"
	quest.66B503EB65475B98.quest_subtitle: "Tingkat: &63"
	quest.66B5A8D259E12BF5.quest_desc: ["Tunggu, jadi maksudmu armor ini punya statistik yang sama dengan &cNetherite&r? Ditambah lagi ada bonus Spell? \\n\\nNgapain juga orang masih mau pakai &cNetherite&r biasa!"]
	quest.66B5A8D259E12BF5.quest_subtitle: "20"
	quest.66B5A8D259E12BF5.title: "&4Netherite Battlemage Outfit"
	quest.66BAC2B478F9B119.quest_subtitle: "1/5"
	quest.66BAC2B478F9B119.title: "Bagian Atas &6&lATM Star&r"
	quest.66C21934DAFFAC7F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_tide.png width:100 height:150 align:center}"]
	quest.66C21934DAFFAC7F.quest_subtitle: "Dijatuhkan oleh Elder Guardian"
	quest.66C21934DAFFAC7F.title: "Tide Armor Trim"
	quest.66C52B137A4FF869.quest_desc: ["Ini adalah Essence Tingkat 4, dibuat dengan nggabungin 4 Tertium dengan Kristal Infus."]
	quest.66C52B137A4FF869.quest_subtitle: "Tingkat: &b4"
	quest.66C52B137A4FF869.title: "&9Imperium"
	quest.66D4256F79D5B30B.quest_subtitle: "Sama seperti versi uap"
	quest.66D85424EC74EDCC.quest_desc: ["&9Portable Grid&r adalah sistem penyimpanan portabel yang tidak terhubung ke jaringan utama.\\n\\nIni memungkinkanmu berinteraksi dengan &9Storage Disk&r di mana saja tanpa perlu kabel."]
	quest.66D85424EC74EDCC.title: "Portable Grid"
	quest.66E78F599CD50579.quest_desc: [
		"&#49C472Nuclear Reactor&r memungkinkanmu mengolah sumber daya tingkat tinggi. Kita akan menggunakannya untuk menghasilkan &#8F49C4Deuterium&r dan &#EB5266Tritium&r."
		""
		"Daftar sumber daya ini akan membantumu membangun reaktor ukuran \"Besar\". Ukuran yang lebih kecil tidak disarankan karena masalah kecepatan dan efisiensi."
		"{@pagebreak}"
		"Detail pembuatan reaktor yang efisien terlalu rumit untuk dijelaskan di sini. Namun, aku akan memberimu desain terbaik yang memungkinkan."
		""
		"Ini adalah desain &#49C472Large Reactor&r untuk memproduksi &#8F49C4Deuterium&r."
		"{image:atm:textures/questpics/modernindustrialization/large_reactor.png width:100 height:100 align:center}"
		""
		"Ini adalah desain &#49C472Extreme sized Reactor&r untuk memproduksi &#EB5266Tritium&r."
		""
		"{image:atm:textures/questpics/modernindustrialization/largest_reactor.png width:100 height:100 align:center}"
	]
	quest.66E78F599CD50579.quest_subtitle: "Tenang, nggak meledak kok"
	quest.66E88F916B638B3B.quest_desc: ["Yang ini mungkin agak bikin bingung, soalnya ada banyak &5Creative &eSpellbook&r! Tapi yang kita mau adalah yang dari &d&lAllTheArcanist Gear&r. \\n\\nBuat bikin ini, kita perlu bikin dulu yang versi &l&dArs Nouveau&r. &eSpellbook&r itu butuh &eArchmage Spellbook&r, sebuah &6&lATM Star&r, dan beberapa item tambahan. \\n\\nKonfigurasinya sama kayak &eUnobtainium Spellbook&r, tapi Mana-nya tak terbatas dan semua Glyph sudah terbuka! \\n\\nKekuatan sihir tanpa batas BWAHAHAHAHA!"]
	quest.66E88F916B638B3B.title: "&5&lCreative &eSpellbook"
	quest.66ECC26BC81D0093.title: "Tingkat: &bBasic"
	quest.66FE4552E09B5EFF.quest_desc: ["Prism penting untuk banyak resep &6&lForbidden \\& Arcanus&r dan Mod lain nanti! \\n\\nUntuk craft mereka kita butuh &3Elementarium&r, yang ditemukan di Jungle Temple, Desert Pyramid, dan Underwater Ruin. \\n\\nGue pikir lebih gampang kasih tau dimana kamu gak bisa nemuin!"]
	quest.66FE4552E09B5EFF.title: "&3Elementarium"
	quest.6718043D0F2D1830.quest_desc: ["DireWolf diminta untuk membuat tambahan pada Kartu miliknya agar bisa bekerja dengan &5&lMekanism&r dan... wujud zat lainnya. Apa pun yang bisa dipindahkan oleh Pressurized Tube, kartu ini juga bisa. Gas, Infuse Type, dan Pigmen."]
	quest.6718043D0F2D1830.title: "&5Chemical Card"
	quest.6720F863B907A5F1.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Membuat Panah Ramuan yang ditembakkan oleh busur punya efek Berkelanjutan, memberikan efek ke area dalam jangka waktu."
	]
	quest.672134A1A620EEAB.quest_desc: [
		"Ada banyak cara untuk menyimpan power! "
		""
		"&9Powah&r menawarkan storage hebat menggunakan &aEnergy Cell&r yang bisa di-upgrade, atau selalu bisa pakai gaya multiblock dari &aRFTools&r menggunakan &aPowercell&r! Pilihan ada di tangan. "
		""
		"Catatan: Hanya perlu membuat salah satu item untuk menyelesaikan quest."
	]
	quest.67216EC5274F08B9.quest_subtitle: "Alat cukur domba modern"
	quest.67258590FA14BE44.quest_desc: ["Untuk 250mB &9Air&r dan 2 &bArcane Crystal Dust&r, di &b&lRunic Crucible&r, kita bisa dapet 250mB &bLiquid Aureal&r! \\n\\nKamu butuh 1000 &dSource&r untuk mulai..."]
	quest.67258590FA14BE44.title: "&bLiquid Aureal"
	quest.672AC964851832EB.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_swamp.png width:100 height:150 align:center}"]
	quest.672AC964851832EB.title: "&7Swamp Silver&r"
	quest.672B69448F1D458B.quest_desc: ["&#FAAD28Heat Exchanger&r adalah surga bagi para pecinta Turbin &#4D7DFFExtreme Reactors&r. Mesin ini mampu memproduksi Uap (Steam) dalam jumlah yang sangat fantastis."]
	quest.672B69448F1D458B.quest_subtitle: "Uap melimpah ruah"
	quest.672F9CF5B0E626F1.quest_desc: ["&ePackager&r adalah &6Mesin&r baru yang sangat penting untuk &6&lCreate&r. Untuk menggunakan hampir semua hal dari Update ini kita butuh &ePackager&r. \\nGabungkan &eKardus&r yang baru kita temukan untuk membuat Blok Kardus. Bukan, ini belum jadi &eKotak&r dan tentu saja tidak bisa melakukan apa-apa. \\n\\nYah selain membuat &ePackager&r kita! &ePackager&r kemudian dipasang ke Blok yang memiliki Inventaris, seperti Peti atau Tong. Kamu akan tahu sudah terhubung ketika salah satu sisinya berubah tampak seperti dinding. \\n\\nKemudian, ketika diberi &4Sinyal Redstone&r, ia akan menarik semua &eItem&r dalam Inventaris ke dalam &ePaket&r! Lebih lanjut nanti! \\n\\n&ePaket&r kemudian bisa ditarik keluar dengan Tangan atau &eSabuk&r. Kamu juga bisa mengirim &ePaket&r kembali ke &ePackager&r untuk menaruh &eItem&r kembali ke Inventaris. \\n\\nKalau kamu menaruh dan memberi nama Papan Nama pada &ePackager&r, semua &ePaket&r yang dibuatnya akan diberi Alamat tersebut."]
	quest.672F9CF5B0E626F1.title: "&ePackager"
	quest.67308C5DDF4A10D2.quest_desc: ["&9Wandering Magician Armor&r adalah yang terlemah yang bisa ditawarkan &lIron's Spells&r. \\n\\nIni benar-benar upgrade untuk &7Leather Armor&r! Siapa yang bahkan membuat &7Leather Armor&r?!?!?! \\n\\nTinggal lempar &7Leather Armor&r mu dengan &5Arcane Essence&r di Crafting Table untuk Craft-nya. \\n\\nIni akan membuat setiap bagian memberikan lebih banyak Armor Point serta sedikit boost Mana!"]
	quest.67308C5DDF4A10D2.title: "&9Wandering Magician Outfit"
	quest.6737CB17D562B134.quest_desc: ["Pengklik sederhana yang mengklik dengan barang yang diberikan."]
	quest.67439337E29A308B.quest_desc: ["&eArtificer's Cane&r lebih mahal dari &7Graybeard Staff&r dan karena itu lebih kuat. \\n\\nSekarang akan memberikan 4 &4Damage&r dan memberikan 15% Reduction Cooldown dan Cast Time serta 10% &3Spell Power&r. \\n\\nAku hanya bilang lebih baik, aku tidak bilang jauh lebih baik!"]
	quest.67439337E29A308B.title: "&eArtificer's Cane"
	quest.67482ED4B18F828D.quest_subtitle: "Iron + Neon Cuckoo"
	quest.67482ED4B18F828D.title: "Osmium Bee"
	quest.674A6B0EDA0D348B.quest_subtitle: "Teak + Mangrove"
	quest.674E2690D66ECD6E.quest_desc: ["Kalau lagi badai petir, lempar &aWeather Container&r ke &aEnvironmental Accumulator&r bakal manfaatin kekuatan badai.\\n\\nPakai ini, kita bisa bikin item yang bikin kita bisa kontrol Petir sesuka hati.\\n\\nKamu butuh Lightning Bomb buat craft &6ATM Star&r."]
	quest.674E2690D66ECD6E.title: "&aKamu Kena &9Petir"
	quest.674F28BCA2E4A3C8.quest_desc: ["Saat memindahkan item, Router bisa jadi sangat rakus, mengambil setiap item yang bisa ia jangkau! \\n\\nDengan Regulator Augment, kamu bisa membatasi seberapa banyak item yang boleh dipindahkan."]
	quest.6751F2651063B3A5.quest_desc: ["Blood Mushroom bisa ditemukan di rawanya. \\n\\nBentuknya seperti pohon Dark Oak dan sebagian besar berwarna putih dengan hanya beberapa blok yang punya noda darah!"]
	quest.6754612E9AD4B9C0.title: "Reaktor (Blazing)"
	quest.67704F7341EDCC49.title: "&bDiamond Backpack"
	quest.677365A816994C8B.quest_desc: [
		"&9Player Transmitter&r akan mengisi daya item milik pemain secara nirkabel. Kamu harus menghubungkannya ke pemain terlebih dahulu menggunakan &9Binding Card&r. Kartu dasar hanya mengizinkan transmisi dalam dimensi yang sama. Kamu bisa meningkatkannya dengan menggunakan &dBinding Card (Dimensional)&r sebagai gantinya. "
		""
		"Catatan: Untuk mendapatkan Player Aerial Pearl, gunakan Aerial Pearl pada Zombie atau Husk."
	]
	quest.6774BBE7C7C5D7EB.quest_desc: ["Semua &eCacing Maut&r bakal Drop &eKitin&r sesuai Warna mereka. \\n\\n&eKitin&r bisa dipake buat Craft &eArmor Kitin Cacing Maut &fatau &eSarung Tangan Cacing Maut&r! \\n\\nLo harus pake &eKitin&r Warna yang sama buat keduanya, gak bisa mix-n-match."]
	quest.6774BBE7C7C5D7EB.title: "&eKitin Cacing Maut"
	quest.677A701E06422CF3.quest_desc: ["Memungkinkanmu bergerak jauh lebih cepat di semua blok dengan akselerasi saat berlari! Peringatan: ini jauh lebih licin! Tingkatkan untuk melaju lebih kencang lagi."]
	quest.677A701E06422CF3.quest_subtitle: "Ditemukan di Mineshaft atau Stronghold"
	quest.677A701E06422CF3.title: "&cRoller Skates"
	quest.677C5D35DADA4A42.quest_desc: ["&cCoupler&r digunakan untuk menyambung atau melepas &7Cart&r. Coupling adalah istilah untuk menyambungkan antar &7Cart&r. \\n\\nDapat dikonfigurasi dengan &4Crowbar&r untuk mode menyambung, melepas, atau otomatis. Membutuhkan Redstone."]
	quest.677C5D35DADA4A42.title: "&cTrack Kit&r Coupler"
	quest.677D0C23D53A77CA.quest_desc: [
		"&bDraconic Evolution&r menambahkan multiblock yang disebut &dEnergy Core&r."
		""
		"Walaupun terlihat membingungkan, tingkat (tier) terakhirnya dapat menampung &m9.223.372.036.854.775.808 FE&r—praktis daya tak terbatas."
		""
		"Untuk informasi lebih lanjut, cek bab Draconic Evolution."
		"{image:atm:textures/questpics/draconic/draconic_core_8on.png width:100 height:100 align:1}"
	]
	quest.677D0C23D53A77CA.quest_subtitle: "Penyimpanan Praktis Tak Terbatas"
	quest.677D0C23D53A77CA.title: "&9Draconic Evolution: &dEnergy Core"
	quest.677D0E27CAD7B145.quest_subtitle: "Berikan satu ember Ether Gas ke Pink Slimy Bee"
	quest.677D0E27CAD7B145.title: "Ether Gas Bee"
	quest.6786B08C30D26037.quest_desc: [
		"Untuk mendapatkan lebah ini, kamu butuh Ashy Mining Bee terlebih dahulu."
		""
		"Setelah Ashy Mining Bee merasa nyaman di sarangnya, ada peluang Nomad Bee akan datang dan mengambil alih sarang tersebut."
	]
	quest.6786B08C30D26037.quest_subtitle: "Muncul di sarang yang sudah ditempati Ashy Mining Bee"
	quest.67884BFA27870CCE.quest_desc: [
		"&dOsorin's Unbound Calling&r adalah tingkat kedua dari &dRitual Tanpa-Setan&r. Tingkat pertama tidak berguna untuk progres sama sekali, hanya digunakan untuk menghidupkan kembali Familiar dan mengubah Vex menjadi Allay. "
		""
		"Ritual ini digunakan untuk menciptakan banyak blok, item, dan material yang tergolong langka yang mungkin tidak bisa (atau sulit) didapat dengan cara lain."
	]
	quest.67884BFA27870CCE.quest_subtitle: "Untuk kita yang malas ke Trial Chamber"
	quest.67884BFA27870CCE.title: "&dOsorin's Unbound Calling"
	quest.67940C0774E73217.quest_desc: ["&ePengarah Barang&r akan &9Memasukkan &eBarang&r dan &6Mengeluarkan&r mereka ke lokasi tertentu berdasarkan Filter yang ditetapkan di UI-nya! \\n\\nIni bisa diatur ke &eSabuk&r, Peti, atau Inventaris lain."]
	quest.67940C0774E73217.title: "&ePengarah Barang"
	quest.679E80EBB9A2AE7E.quest_desc: ["&bPengarah Cairan&r menyortir dan memfilter &bCairan&r yang lewat. \\n\\nPerlu mengatur konfigurasi di UI-nya untuk mengatur Filter dan Sisi mana. Setelah melakukannya, akan mengambil semua &bCairan&r yang masuk dan mengirimkannya ke mana mereka diatur untuk pergi!"]
	quest.679E80EBB9A2AE7E.title: "&bPengarah Cairan"
	quest.67A0F6661D658A52.quest_desc: ["Benda ini bisa ditemukan di salah satu dari 3 misi sebelumnya tapi akan selalu muncul di Labirin Sel. \\n\\nIa akan menunjuk ke arah Pilar Takhta terdekat. Ikuti kompas tersebut!"]
	quest.67A2347534269528.quest_desc: [
		"&9Sploogie&r jarang muncul, tapi kalau ada, mereka ditakdirkan untuk mengganggumu. \\n\\nMereka akan meludahimu (dan mengeluarkan suara sedotan yang menjijikkan), tapi kalau kamu pukul mereka akan lari; mirip seperti bayi Piglin. \\n\\nMereka hanya menjatuhkan Depthrock Pebble saat mati."
		"{image:atm:textures/questpics/undergarden/undergarden_sploogie.png width:125 height:100 align:center}"
	]
	quest.67A2347534269528.title: "&9Sploogie&r"
	quest.67A46ED73E488CEE.quest_desc: ["&dGearshift&r bekerja mirip &dKopling&r dengan menghubungkan ke Sistem kita dan ditenagai &4Redstone&r. \\n\\nBeda dari menghentikan &dTenaga Rotasi&r, &dGearshift&r akan mengubah Arahnya! \\n\\nKalau masuk &e&oSearah Jarum Jam&r ke &dGearshift&r yang aktif, keluar menjadi &9&oBerlawanan Jarum Jam&r, dan sebaliknya."]
	quest.67A46ED73E488CEE.title: "&dGearshift"
	quest.67A587F4BAD76C70.quest_desc: ["&eSpellbook&r paling dasar, yang juga membuatnya paling murah! \\n\\nIni hanya bisa menampung total 5 &3Spell&r."]
	quest.67A587F4BAD76C70.title: "Flimsy Journal"
	quest.67A9329C05F98633.quest_desc: ["Jujur, kalo lo gak butuh lebih banyak &aEnergi&r dan lebih mau seaman mungkin dengan &2&lReaktor&r lo maka buang aja! \\n\\nOh iya, lo denger gue! Tinggal buang Steam-nya! \\n\\nGue tau banyak hal penting di &2&lMinecraft&r dan biasanya lebih bagus simpen ini, daripada buang... \\n\\nTapi Steam pada dasarnya cuma buat Turbine bikin &aEnergi&r. \\n\\nGak butuh? Tubing aja ke Ultimate Trash Can!"]
	quest.67A9329C05F98633.title: "Buang aja!"
	quest.67AA59BD340FEC62.quest_subtitle: "Tingkat: &63"
	quest.67AFCBCE7AAC3089.quest_desc: [
		"Untuk bikin Turbine berputar, kita butuh komponen &crequired&r ini:\\n\\n- &9Rotor Bearing&r ditaruh di salah satu ujung shaft turbine. Bisa di sisi manapun, tapi menentukan dimana shaft menonjol. Ini biasanya ditaruh di tengah sisi bawah.\\n\\n- &eRotor Shaft&r memanjang dari satu Rotor Bearing ke sisi berlawanan turbine, sampai ke satu blok Turbine Housing, bikin shaft untuk Turbine.\\n\\n- &9Rotor Blade&r bikin rotor berputar. Ini ditaruh ke Rotor Shaft dan bisa beberapa blok panjangnya. Tiap Blade bisa handle jumlah vapor tertentu, dan menentukan berapa banyak yang diperlukan berdasarkan production rate reactor kamu.\\n\\nIni contoh setup Vertical Shaft untuk Turbine, dengan Turbine Coil Lead di atas.\\n"
		"{image:atm:textures/questpics/extremereactors/maxbasicturbine.png width:100 height:150 align:1}"
	]
	quest.67AFCBCE7AAC3089.title: "Bikin Shaft Turbine"
	quest.67B87570C340C243.title: "Upgrade Armor"
	quest.67C76EDD4BCCFF3F.quest_desc: ["Lewat &bStrigeor's Higher Binding&r kita bisa bikin &bEmpty Soul Gem&r. \\n\\nIni bisa dipake buat transport Mob dengan aman, atau bikin &d&lDragon Soul&r. \\n\\nMenurut gue kita harus lakuin keduanya!"]
	quest.67C76EDD4BCCFF3F.title: "&bEmpty Soul Gem"
	quest.67C7EF299BEC37DE.quest_subtitle: "Creative Flight"
	quest.67CCEFEBA4D79429.quest_desc: ["&eDivine Pact&r paling susah didapat, kamu perlu cari Piglin Village dan Ancient Pyramid di &b&lThe Other&r untuk nemuin mereka! \\n\\nDigunakan untuk craft Soul Binding Crystal dan Multiblock End Game!"]
	quest.67CCEFEBA4D79429.title: "&eDivine Pact"
	quest.67D38E8A57949B34.quest_desc: ["&3Sculk Jaws&r adalah Block yang bisa kita temukan di &9Deeplands&r. \\n\\nSaat kamu tidak sengaja berjalan di atasnya mereka akan menggigitmu, ini menarikmu ke bawah dan memberikan Damage saat kamu tersangkut di dalamnya. \\n\\nKamu bisa mengambilnya dengan Silk Touch."]
	quest.67D38E8A57949B34.title: "&3Sculk Jaw"
	quest.67D40A1A9332C03D.title: "&6Legendary&r Ink"
	quest.67DBE6C59C0D9D1B.quest_desc: ["Ini adalah Essence Tingkat 5, dibuat dengan nggabungin 4 Imperium dengan Kristal Infus."]
	quest.67DBE6C59C0D9D1B.quest_subtitle: "Tingkat: &c5"
	quest.67DBE6C59C0D9D1B.title: "&4Supremium"
	quest.67DDFA6FB1F9EECA.title: "&9Peralatan Imperium"
	quest.67E7A9A65B14C933.quest_desc: [
		"Kita dapat &7Ore Clump&r? Terus diapain si &7Clump&r ini, kita kan maunya &7Ingot&r! \\n\\nBuat mulai, &4Crush &ftiap &7Clump&f buat dapat 2 &7Dirty Ore Dust&r. \\n\\nKita nggak bisa &6Smelt &7Dirty Dust&r, nanti ngerusak Tungku! Jadi kita perlu &dEnrich&r mereka biar jadi &7Dust&r biasa. \\n\\nDan kayak biasanya, &6Smelt &f&7Dust &f-nya buat dapat &7Ingot&r."
		"{image:atm:textures/questpics/mek/mek_tier2_2.png width:250 height:50 align:center}"
	]
	quest.67E7A9A65B14C933.quest_subtitle: "Pengolahan Bijih Tier 2"
	quest.67E7A9A65B14C933.title: "&4Crush &fdan &dEnrich &f&7Clump kita"
	quest.67FB03BE6685AFE1.quest_desc: ["Untuk memulai perang, perlu terlebih dahulu menyatakannya! \\n\\nBercanda, langsung menembak! Tidak ada omong kosong diplomatik di sini! \\n\\nUntuk memulai, tembak Pillager dengan &d&lRevolver&r. \\n\\nIni akan memulai spawning Pillager baru dan lebih keras!"]
	quest.67FB03BE6685AFE1.title: "Serangan dan Pertahanan"
	quest.6800E0113DE9A4DB.quest_desc: [
		"&c&lNaga&r cuma Monster paling bahaya dan penting di seluruh &b&lIce &fdan &cFire&r! \\n\\nElemen &c&lNaga&r nentuin Bioma apa mereka spawn. \\n\\nMereka punya Stage berbeda (1 sampe 5). Ini nentuin &4Health&r, Damage, Drop, dan Spawn mereka. \\n\\nKita harus nemuin, bunuh, dan bahkan Tame beberapa buat dapet beberapa Loot terbaik di &6&lATM10&r! \\n\\nCoba nemuin beberapa &c&lNaga&r yang udah mati dulu buat dapet &7Tulang&r mereka."
		"{@pagebreak}"
		"&lStage 1-3&r bakal spawn di &cSarang&r sementara &lStage 4&r dan &l5&r spawn di &cGua&r. Cuma &l4&r dan &l5&r yang bakal Drop &cTelur&r. Makin tinggi &lStage&r, makin gelap Warna mereka dan makin gede Ukuran mereka! \\n\\n&lStage 1&r: bakal punya dari 50 &4Hearts &fsampe 350 &4Hearts&r juga 2 &7Armor Points&r sampe 6! &lStage 1&r cuma bisa Gigit lawan mereka, mereka gak bisa pake &cNapas Elemental&r. \\n\\n&lStage 2&r: punya 350 &4Hearts &fsampe 600 &4Hearts&r. Mereka juga bisa punya 6 &7Armor Points&f sampe 10 &7Armor Points&r. Sekarang mereka bisa pake &cNapas Elemental&r buat Berantem. \\n\\n&lStage 3&r: bisa punya 600 &4Hearts &fsampe 900 &4Hearts&r dengan 10 sampe 12 &7Armor Points&r. Sekarang &c&lNaga&r ini bakal punya semua Serangan mereka dari &cNapas Elemental&f sampe &cSerangan Elemental&r mereka. \\n\\n&lStage 4&r: bakal tetep punya semua Kemampuan dan Serangan yang sama juga sekarang Drop &cTelur&r. &lStage 4&r bakal punya antara 900 &4Hearts&r sampe 1200! Plus tambahan 12 sampe 16 &7Armor Points&r. \\n\\n&lStage 5&r: cuma &c&lNaga&r terbesar dan terkuat. Ini bisa punya 1200 sampe 1500+ &4Hearts&r! Dengan 16 sampe 20 &7Armor Points&r. Pada dasarnya pake &cArmor Netherite&r, karena mereka sekuat itu!"
	]
	quest.6800E0113DE9A4DB.title: "&c&lNaga&r dan &lStage&r mereka"
	quest.680E960554CEE76B.quest_desc: [
		"Ngarai kristal yang indah ini dikelilingi oleh dinding sarang raksasa dan penuh dengan... ya, benar! &5Kristal&r! \\n\\nLantainya terbuat dari lilin yang bisa dipahat (Carvable Wax) sementara sisanya penuh dengan Kristal Madu kecil dan Kristal Madu Berkilau yang besar."
		"{image:atm:textures/questpics/bumblezone/bumble_canyon.png width:200 height:100 align:center}"
	]
	quest.680E960554CEE76B.title: "&5&lNgarai Kristal"
	quest.680ECE3D8DCDC515.quest_subtitle: "&f13 &cAttack Damage"
	quest.681A3F31FB242555.quest_desc: ["&3Ethanol&r dapat digunakan untuk membuat Biodiesel."]
	quest.681A3F31FB242555.title: "Etanol"
	quest.682034C680FDEDC2.quest_desc: [
		"&aInduction Matrix&r dari &9Mekanism&r adalah salah satu cara terbaik untuk menyimpan dayamu.\\n\\nJika kamu mencari penyimpanan daya terbaik yang ditawarkan Mekanism, cek bab quest &aMekanism:&r &dReactors&r.\\n"
		"{image:atm:textures/questpics/mek/mek_induction_matrix_small.png width:125 height:150 align:center fit:true}"
	]
	quest.682034C680FDEDC2.title: "Penyimpanan Daya Lebih Besar"
	quest.6827836C8E675A94.quest_desc: ["Skeleton punya varian berbeda, seperti Zombie! \\n\\nStray - muncul di Biome Dingin. \\nBogged - muncul di Rawa dan Trial Chamber. \\nMurk - muncul di bawah air di Terumbu Karang. \\nVerdant - muncul di Hutan Rimba (Jungle)."]
	quest.6827836C8E675A94.title: "Varian Skeleton"
	quest.68318811CCC28320.quest_desc: ["Gabungin &cHardened Blood Shard&r dengan &9Dark Power Gem&r bakal bikin Blood Infusion Core.\\n\\n&9Blood Infusion Core&r adalah komponen crafting utama beberapa mesin di EvilCraft."]
	quest.68318811CCC28320.title: "&aInfusion Core"
	quest.683B58B699D4D381.quest_subtitle: "Muncul di sarang yang sudah ditempati Blue Banded Bee"
	quest.683C260C854C5AA3.quest_desc: ["&4Mechanical Fusion Anvil&r dibutuhkan untuk membuat penggabungan item-item &4&lCataclysm&r. \\n\\nKamu bisa meletakkannya seperti Anvil biasa, tapi untungnya yang satu ini tidak punya durabilitas! \\n\\nCek JEI untuk resepnya; letakkan item 1 di slot kiri dan item 2 di slot tengah untuk mendapatkan hasil akhir di slot kanan."]
	quest.683C260C854C5AA3.title: "&4Mechanical Fusion Anvil"
	quest.68446510A1B0D9B8.quest_desc: [
		"&bBlooming Caverns&r lebih seperti Lush Caves daripada Caves normal. Kukatakan itu karena banyaknya TANAMAN! \\n\\nKamu akan menemukan Tanaman tumbuh dari langit-langit ke lantai, Tanaman tumbuh dari lantai ke langit-langit, Tanaman tumbuh dari &9Air&r, dan Tanaman yang bahkan tidak Tumbuh sama sekali! \\n\\nLantainya ditutupi dengan &bBlooming Sculk Stone&r dan bahkan &bBlooming Moss&r. \\n\\nBahkan ada Kolam Air di sini, satu-satunya tempat kamu bisa menemukan &9Air&r di &3&lDimension&r ini."
		"{image:atm:textures/questpics/deepndark/dnd_cave.png width:200 height:100 align:center}"
	]
	quest.68446510A1B0D9B8.title: "&bBlooming Caverns"
	quest.68498ADEF9765F81.quest_desc: ["Untuk membuat Crystallized Menril Chunks pertama taruh beberapa Menril Logs di Squeezer. Lompat di Squeezer untuk mengubahnya jadi Menril Resin.\\n\\nBisa mengosongkan Squeezer dengan memberi sinyal Redstone."]
	quest.684BB9D2F2AC87A6.quest_subtitle: "Wenge + Cocobolo"
	quest.6852BEFDD4DE4E4B.quest_desc: ["&9Soul-Touched Deepshelf&r adalah upgrade dari &9Deepshelf&r. \\n\\nRak ini dibuat dengan sebuah &bSoul Lantern&r dan 3 &3Sculk Block&r. Kamu butuh &5Silk Touch&r untuk mengambil &3Sculk Block&r. \\n\\nLalu, kita bisa men-craft versi &9Soul-Touched&r ini. Rak ini memberikan &cQuanta&r jauh lebih banyak yaitu sebesar &c15%&r! \\n\\nIa juga meningkatkan batas maksimal &aEterna&r menjadi &a75&r."]
	quest.6852BEFDD4DE4E4B.title: "&9Soul-Touched Deepshelf"
	quest.685C4A646E092A82.title: "&6Armor Awakened Supremium"
	quest.686B25F2E9D8CC97.quest_desc: ["Pas nulis ini udah akhir Juli jadi masih sekitar 3 bulan lagi sampe Halloween. Tapi ga pernah terlalu awal buat mulai Spooky! Kayak Spirit Halloween kita bisa Spooky 3 bulan sebelum dimulai. Kali ini dengan Right Click Furnace pakai Spook-alator! Pas udah waktunya bersiap buat Thanksgiving Shift Right Click buat Un-Spook-Alate!"]
	quest.686B25F2E9D8CC97.quest_subtitle: "\"This is Halloween\""
	quest.686EB173C94301C0.quest_desc: ["&bIce Armor&r dari mod &e&lIron's Spells&r!"]
	quest.686EB173C94301C0.quest_subtitle: "20"
	quest.686EB173C94301C0.title: "&bCryomancer Outfit"
	quest.6877F33323910716.quest_desc: ["Tier 4 Pocket Storage punya 64 Slot buat Item dan masing-masing nampung 1,048,575 Item. Itu 67,108,800 Item total. Minggir Backpack kamu udah diganti! \\n\\nIni cuma butuh beberapa Nether Star yang di Modded sejujurnya gak mahal buat apa yang kamu dapetin!"]
	quest.6884E25641A1020C.quest_desc: ["&5Enchantment Library&r adalah tempat penyimpanan &5Enchanted Book&r tunggal paling hebat yang pernah ada! \\n\\nUntuk membuatnya, kamu butuh 4 &3Ender Chest&r, 1 &5Enchanting Table&r, dan 4 dari salah satu jenis rak buku &d&lInfused&r berikut: &4Infused Hellshelf&r, &bInfused Seashelf&r, atau &9Deepshelf&r. \\n\\nUntuk menggunakannya, kamu bisa Shift+Klik Kiri pada &5Enchanted Book&r atau masukkannya ke &9Slot Biru&r. Ini akan memasukkan &5Buku&r tersebut ke dalam &5Library&r. \\n\\n&5Buku-buku&r tersebut diurutkan berdasarkan nama dan disimpan dalam poin. Setiap level buku menentukan poinnya, yang mencerminkan berapa banyak buku yang dibutuhkan untuk mencapai level tersebut. Level 1 = 1 Poin. Level 2 = 2 Poin. Level 3 = 4 Poin. Level 4 = 8 Poin. \\n\\nSetiap &5Buku&r bisa disimpan hingga maksimal 32.768 poin, dan bisa diambil dengan mengklik kiri pada buku yang tersimpan. Setiap klik akan menambah level pada buku di &6Slot Oranye&r. \\n\\nKamu bisa mengklik buku yang berbeda untuk ditambahkan ke buku di &6Slot Oranye&r, mirip seperti menggabungkan buku di Anvil. \\n\\nLevel maksimal buku yang bisa diambil ditentukan oleh level tertinggi buku yang pernah kamu masukkan. Tidak peduli kamu punya 32.000 poin, kalau kamu cuma pernah memasukkan &5Sharpness III&r, kamu cuma bisa mengambil &5Sharpness III&r."]
	quest.6884E25641A1020C.title: "Perpustakaan Enchantment"
	quest.6889EFC6CC291463.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Mendorong monster di sekitar saat diaktifkan, memiliki cooldown."
	]
	quest.688C911ECFB2F134.quest_desc: ["Di dalam &2Dark Forest&r, kamu akan menemukan &8Dark Tower&r (Menara Kegelapan).\\n\\nUntuk masuk, carilah blok yang bisa muncul kembali (reappearing blocks) di dasarnya. Cari jalanmu melalui labirin hingga ke lantai terakhir untuk melawan &cUr-Ghast&r.\\n\\nDisarankan membunuh &cUr-Ghast&r dengan senjata jarak jauh. Ada 4 jebakan Ghast di lantai bos yang bisa digunakan untuk melukainya.\\n\\nJebakan ini diisi muatannya dengan membunuh &cGhastling&r, lalu diaktifkan dengan Redstone. Kamu tidak wajib memakainya, tapi cukup berguna."]
	quest.688C911ECFB2F134.quest_subtitle: "Menara Karbonit Gelap"
	quest.688C911ECFB2F134.title: "&cAir Mata Api"
	quest.6893D537716AA748.quest_desc: ["&dRoda Gigi&r adalah Blok berikutnya yang dibutuhkan untuk menggunakan &dTenaga Rotasi&r! Bisa terhubung ke &8Poros&r atau &dRoda Gigi&r lain untuk menyalurkan &dTenaga Rotasi&r. \\n\\nAda dua versi &dRoda Gigi&r: &dRoda Gigi&r biasa dan &dRoda Gigi Besar&r. Keduanya sama dalam hal &dTenaga Rotasi&r tapi ada beberapa perbedaan! \\n\\n&dRoda Gigi&r biasa bisa terhubung ke &dRoda Gigi&r lain yang bersebelahan. Ini akan menyalurkan &dTenaga Rotasi&r ke arah yang berbeda. Ketika ini terjadi, arah &dRoda Gigi&r kedua akan terbalik. Kalau &dRoda Gigi&r pertama berputar &e&oSearah Jarum Jam&r, yang kedua akan berputar &9&oBerlawanan Jarum Jam&r. \\n\\n&dRoda Gigi Besar&r sedikit lebih sulit digunakan. Tidak bisa terhubung ke &dRoda Gigi Besar&r lain yang bersebelahan — hanya bisa terhubung ke &dRoda Gigi&r yang diagonal darinya! \\n\\nKebanyakan &6Mesin&r akan membutuhkan &dTenaga Rotasi&r dari &dRoda Gigi&r yang terhubung. Kamu akan tahu kalau &6Mesin&r punya &dRoda Gigi&r internal — itulah yang harus digerakkan untuk menggunakan &6Mesin&r tersebut. "]
	quest.6893D537716AA748.quest_subtitle: "Aku cukup sebut mereka Roda Gigi"
	quest.6893D537716AA748.title: "&dRoda Gigi&r!"
	quest.68972BA647FDCF8F.quest_desc: ["Kalau kamu tau &l&6Productive Bees&r kamu harusnya tau LobsterJonn. Dia yang bikin &l&6Productive Bees&r dan &lGenerator's Galore&r (sama banyak lainnya). &6Honey Generator&r adalah cara bagus buat nyambungin kedua mod ini! &6Honey Generator&r pakai &6Liquid Honey&r buat bikin Energi. "]
	quest.68972BA647FDCF8F.title: "&6Honey Generator"
	quest.689F32883C4E9502.quest_desc: ["&4&lCataclysm&r adalah mod yang menambahkan bos baru, dungeon, dan tentu saja loot! \\n\\nTidak ada urutan pasti bos mana yang harus dibunuh duluan, tapi beberapa bos lebih kuat dari yang lain, dan ada loot yang membantu untuk melawan bos lainnya. \\n\\nGunakan item 'Eye' untuk menemukan struktur spesifik yang perlu kamu cari!"]
	quest.689F32883C4E9502.title: "&4&lCataclysm"
	quest.68B0B3DAF1145191.quest_desc: ["Hal pertama yang kamu butuhkan adalah &bCharger&f dan &bInscriber&f.\\n\\n&bCharger&f digunakan untuk mengisi daya Certus Quartz. &eCharged Certus Crystal&r ini kemudian digunakan untuk memproduksi &eFluix&f. Alat ini juga bisa mengisi daya item bertenaga baterai.\\n\\n&bInscriber&r digunakan untuk memproses kristal menjadi dust atau membuat &ePrinted Circuit&f dan &eProcessor&f."]
	quest.68B0B3DAF1145191.quest_subtitle: "Langkah Awal"
	quest.68B0B3DAF1145191.title: "Langkah Awal"
	quest.68B2D3B985FC1378.quest_desc: [
		"Hutan yang terang dan indah, penuh Torreya Tree dan Vine."
		"{image:atm:textures/questpics/eternal/starlight_torreya.png width:200 height:100 align:center}"
	]
	quest.68B2D3B985FC1378.title: "Torreya Forest"
	quest.68B44B9E939F4228.quest_desc: [
		"Di atas &aBenteng&r terdapat &a&lArchevoker&r. Hostile hanya untuk Player dan siapa pun yang menyerangnya. \\n\\nDia punya 60 Heart, dan menyerang seperti &aEvoker&r normal plus lebih! &aFirework&r, &aShield&r, dan &aBlast of Wind&r! \\n\\nSetelah dibunuh dia akan menjatuhkan Arcane Essence, Ink, &aEvokation Rune&r, &aEvokation Scroll&r, dan drop langka &aGrimoire of Evokation&r!"
		"{image:atm:textures/questpics/iron_spells/spells_evoker.png width:100 height:200 align:center}"
	]
	quest.68B44B9E939F4228.title: "&a&lArchevoker"
	quest.68CE30097BADE20E.quest_desc: ["Klik kanan pada Nest yang tipenya sedang kamu cari; ia akan menunjukkan arah ke Nest terdekat lainnya!"]
	quest.68CE30097BADE20E.title: "Mencari Sarang Alami (Nest)"
	quest.68DABFFB6B3E1A57.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_eye.png width:100 height:150 align:center}"]
	quest.68DABFFB6B3E1A57.quest_subtitle: "Stronghold"
	quest.68DABFFB6B3E1A57.title: "Eye Armor Trim"
	quest.68DFFEA05553B67E.quest_subtitle: "Cloggrum + Frosty"
	quest.68DFFEA05553B67E.title: "Froststeel Bee"
	quest.68E6AE1B9EBCEFFF.title: "&3Vibranium Mace"
	quest.68EAB0248989FC97.quest_desc: [
		"&#EDD653&nSteam Blast Furnace&r membuka cakrawala progres baru. Ini akan menjadi struktur multiblock kunci dalam upaya pencapaianmu di masa depan."
		""
		"Struktur ini tidak hanya memungkinkanmu membuat &7Ingot Baja&r, tetapi juga memungkinkan pengolahan &#696E60Raw Synthetic Oil&r menjadi &#494D43Synthetic Oil&r yang akan digunakan nanti untuk membuat &#36472AKaret&r dan hal lainnya."
	]
	quest.68F92455A9483AD6.quest_desc: ["Kamu hanya akan melihat quest ini jika kamu sudah menggunakan Jet Boot.\\n\\nTidak ada cara memakai Jet Boot tanpa menerima damage, jadi jangan coba-coba..."]
	quest.68F92455A9483AD6.quest_subtitle: "Kamu kira pakai Elytra itu susah?"
	quest.68F92455A9483AD6.title: "Jet Boot"
	quest.6904EC449FBEE387.quest_desc: ["&9Kabel&r digunakan untuk menghubungkan blok dan item ke sistemmu.\\\\n\\\\nDi awal, kamu bisa menempelkan blok satu sama lain untuk menghubungkannya, tapi Kabel memungkinkanmu menarik jaringan ke tempat yang jauh! Ini adalah komponen wajib untuk jaringan RS yang besar."]
	quest.6904EC449FBEE387.quest_subtitle: "Menghubungkan Sistem"
	quest.6904EC449FBEE387.title: "Kabel"
	quest.690B89D23134B624.quest_desc: [
		"Ambil kapurmu, gambar ritual &dRonaza's Contact&r, dan bersiaplah menciptakan KAPUR PAMUNGKAS*!"
		""
		"Alih-alih harus membawa satu set lengkap 16 kapur, kamu bisa menggunakan Rainbow Chalk untuk menggambar Rune yang bisa berubah warna dan dihitung sebagai warna apa pun!"
		""
		"&8*Tidak termasuk Kapur Fondasi. Buatlah Void Chalk untuk mencakup itu juga&r"
	]
	quest.690B89D23134B624.title: "Kapur &zPelangi&r (Rainbow)"
	quest.690CFF61CE787D43.quest_desc: ["Plastic adalah resource utama &bIndustrial Foregoing&r, sekarang punya akses ke beberapa mesin yang sangat berguna!"]
	quest.690DB8BEF80617E5.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_utherium.png width:100 height:150 align:center}"]
	quest.690DB8BEF80617E5.title: "&cUtherium&r"
	quest.69201157ECFBB426.quest_desc: ["Gue selalu benci kalau punya Farm &5Enderman&r buat XP atau Apotheosis Gems tapi berakhir dengan semua &3Ender Pearl&r ini (hehe end up, &3ender pearl&r). Sekarang kamu bisa pakai &3Ender Pearl&r itu buat Energi dengan &3Ender Generator&r. Kamu bahkan bisa bikin &aEye of Ender&r buat Energi lebih banyak lagi!"]
	quest.69201157ECFBB426.title: "&3Ender Generator"
	quest.69211D34F8182976.quest_desc: ["Cakar Hippogryth adalah Drop langka dari pas Hippogryth mati. \\n\\nKita bisa pake buat bikin Pedang! \\n\\nPedang ini sangat mirip Pedang Besi, tapi bakal selalu lakuin Sweeping Attack. \\n\\nIni bakal Hit setiap Mob deket di Range, bukan cuma satu! Kebanyakan Pedang cuma lakuin di full charge, tapi Pedang Cakar gak nunggu! \\n\\nIni bakal kasih Damage lebih banyak bikin lebih deket ke Pedang Diamond."]
	quest.69211D34F8182976.title: "Pedang Cakar Hippogryth"
	quest.692183ACBB2AABF7.quest_desc: ["Relic adalah temuan langka di sekitar World &2&lMinecraft&r kamu! \\n\\nMereka bisa dipakai di &6&lForge&r kamu, di kotak sekitar slot tengah, ini terbuka lebih banyak semakin kamu upgrade Tier! \\n\\nAtau bisa pakai di &l&bClibano&r. \\n\\nBeberapa Creative Mode only, jangan khawatir kita tau betapa kamu suka Item OP dan akan cari cara nambahin mereka!"]
	quest.692183ACBB2AABF7.title: "&lRelic"
	quest.692BC8AADCBF76C3.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.692BC8AADCBF76C3.title: "Energetic Alloy Bee"
	quest.69383DA579901E7E.quest_subtitle: "Biar aku Kapak-kan ini"
	quest.69396F87A09FBD85.quest_desc: ["Semua Pickaxe menambang di Mining Tier yang sama jadi satu-satunya kebutuhan untuk upgrade adalah lebih cepat dan dapat Staff."]
	quest.69396F87A09FBD85.title: "Chaotic Pickaxe"
	quest.69439426534EBDC4.quest_desc: ["&bBlazing Grip&r adalah item lain yang bisa kita buat dengan &bIgnitium&r! \\n\\nIni adalah item aksesoris (Curio) yang dipasang di tangan. \\n\\nSaat dipakai, semua serangan berpeluang memberikan efek &bBlazing Brand&r pada target. \\n\\nAku tidak terlalu tahu apa fungsinya, tapi yang jelas sangat menyebalkan jika kita yang terkena dari sang &b&lIgnis&r."]
	quest.69439426534EBDC4.title: "&bBlazing Grip"
	quest.6950FC974624C6AA.quest_subtitle: "Tingkat: &63"
	quest.695889817162EFC7.quest_desc: ["&aEXP&r sangatlah penting untuk sistem &5&lApotheosis Enchanting&r! Setiap &5Enchant&r membutuhkannya! (Kenapa menurutmu aku memberikannya di setiap hadiah quest?) \\n\\nDengan &d&lInfusion&r, kita bisa mengubah &6Honey Bottle&r menjadi &aBottle O' Enchanting&r. Sebenarnya ada 3 tingkat &d&lInfusion&r berbeda untuk ini! Mulai dari hasil 1 botol, 8 botol, sampai 32 botol! \\n\\nPertama, untuk hasil 1 botol, cuma butuh 2 &9Echoing Sculkshelves&r. \\n\\nKedua, untuk hasil 8 botol, butuh 5 &9Echoing Sculkshelves&r dan 1 &9Soul-Touched Sculkshelf&r. \\n\\nTerakhir, untuk hasil 32 &aBottle O' Enchanting&r, butuh 5 &9Echoing Sculkshelf&f, 3 &9Soul-Touched&f, dan 1 &dDraconic Endshelf&r!"]
	quest.695889817162EFC7.title: "Membuat EXP?"
	quest.6963EC8A71D66AE3.quest_desc: [
		"Jauh di Mangrove Swamp berlumpur terdapat tempat berlindung Mob seperti pertapa yang disebut &2&lApotheocarist&r. \\n\\nDengan tidak ada orang di dekat, dan hanya apa yang dia butuhkan untuk Potion-nya ada di sekitar. \\n\\nKamu bisa menemukan &2&lApotheocarist&r di &2Gubuk&r-nya. \\n\\nDi sana kamu juga bisa menemukan Cauldron dan Brewing Stand dengan Potion!"
		"{image:atm:textures/questpics/iron_spells/spells_magrovehut.png width:200 height:100 align:center}"
	]
	quest.6963EC8A71D66AE3.title: "&2Mangrove Hut"
	quest.69642A3618E86DED.quest_desc: [
		"Untuk bangun frame &aReprocessor&r, kamu butuh banyak Casing. Ini juga artinya banyak Cyanite.\\n\\nMulai dengan bangun struktur hollow 3 blok lebar, 3 blok dalam, dan 7 blok tinggi. Ini frame-nya.\\n\\nKalau bener, kamu akan punya tempat kosong di tengah sisi bawah dan atas. Untuk sisi vertikal, kamu bisa pakai &aReprocessor Glass&r atau salah satu &aReprocessor&r part required kayak Power Port, Controller, dll.\\n\\nKalau mau lihat gambar bentuk frame, cek halaman berikutnya!"
		"{@pagebreak}"
		"Frame multiblock Reprocessor.\\n"
		"{image:atm:textures/questpics/extremereactors/reprocessorframe.png width:100 height:175 align:1}"
		"{@pagebreak}"
		"Reprocessor yang sudah dibangun penuh:\\n"
		"{image:atm:textures/questpics/extremereactors/reprocessorfull.png width:100 height:150 align:1}"
	]
	quest.69642A3618E86DED.title: "Bangun Frame"
	quest.696A33E7D91A487E.quest_desc: ["&9Cindaria&r adalah mob ubur-ubur humanoid yang melindungi &9Acropolis&r. Warnanya kehijauan/keunguan dan transparan. \\n\\nMereka punya 60 &4HP&r tanpa armor. \\n\\nMereka memegang benda mirip payung yang sebenarnya adalah senjata mematikan! \\n\\nJika terlalu dekat, mereka akan mengayunkan senjatanya. Jika jauh, mereka menembakkan &9Tombak Petir&r. \\n\\n&9Tombak Petir&r ini memantul di dinding, untungnya &9Acropolis&r sangat terbuka! \\n\\nSaat mati, &9Cindaria&r akan menjatuhkan &9Lacrima&r."]
	quest.696A33E7D91A487E.title: "&9Cindaria"
	quest.696E063016CAD1B9.quest_desc: ["Menambahkan fungsi meja kerja mod Chipped ke dalam Tas."]
	quest.696E063016CAD1B9.title: "Chipped Upgrade"
	quest.6973A5923AF7BF05.quest_desc: ["Elite Exporter memiliki 18 slot filter dan bekerja 2x lebih cepat."]
	quest.6973A5923AF7BF05.title: "Elite Exporter"
	quest.69763C2E2F454A73.quest_desc: ["&c&lFire&r jelas berhubungan dengan &cApi&r. Kebanyakan Scroll adalah dengan menggunakan &cApi&r untuk membakar dan menyakiti. \\n\\n&c&lFire&r menggunakan &cBlaze Rod&r sebagai Material Fokusnya. Kamu bisa craft &cFire Rune&r atau mendapatkannya dari membunuh &c&lPyromancer&r. \\n\\n&cScroll&r-nya berwarna &cMerah Muda&r dengan teks &8Abu-abu&r."]
	quest.69763C2E2F454A73.title: "&c&lFire"
	quest.69838E3F12218D68.quest_desc: [
		"Scroll Forge, kamu bisa tebak apa fungsinya! \\n\\nIni membuat &3Scroll&r! \\n\\nTambahkan Ink untuk set Rarity. Paper untuk &3Scroll&r sebenarnya. Lalu Item dari jenis &3Spell&r apa yang kamu inginkan (&cBlaze Rod&r untuk &c&lFire&r, &2Poisonous Potato&r untuk &2&lNature&r, DST). Terakhir pilih &3Spell&r yang kamu inginkan dan akan dibuat!"
		"{image:atm:textures/questpics/iron_spells/spells_scroll_gui.png width:150 height:100 align:center}"
	]
	quest.698A959C9E449592.quest_desc: ["Langkah progres selanjutnya adalah membuat Iron Pickaxe.\\n\\nPickaxe ini bisa menambang beberapa ore lebih langka di game, termasuk Diamond!"]
	quest.698A959C9E449592.title: "Pickaxe &aIron&r"
	quest.69986817D58AC8BE.quest_desc: ["Stabilizer adalah yang membentuk Containment Field (Force Shield di sekitar Reactor Core). Setelah Containment Shield turun ke 0 saat Reactor menyala akan memulai Meltdown. Semua 4 Stabilizer perlu beberapa block jauh (5 atau lebih) dari Core dan perlu sekitar Axis yang sama dengan Core untuk bekerja. Ini juga tempat kamu akan pipe OP keluar dari Reactor, cuma jangan terlalu banyak!"]
	quest.69986817D58AC8BE.title: "Reactor Stabilizers"
	quest.69A517AB8A801939.quest_desc: ["&5Wither&r adalah salah satu boss paling sulit untuk dibunuh di Minecraft. Terutama karena dia terbang. Dan meledak. Dan cepat. Sudah paham kan.\\n\\nUntuk memanggilnya, letakkan 4 Soul Sand dalam bentuk T. Letakkan 3 Wither Skeleton Skull di atas 'T' dan &5Wither&r akan spawn.\\n\\nTip: Dia meledak. Banyak. Jangan lakukan ini dekat base."]
	quest.69A517AB8A801939.title: "&6Bunuh &5Wither"
	quest.69B5D716568AA9EB.quest_desc: [
		"&d&lCamol&r adalah jawaban untuk menyamarkan &lSEGALANYA.&r Mulai dari Pipez sampai Kabel Mekanism hingga ATM Star, bahkan Bak Cuci Piring sekalipun.\\n\\nCraft &d&lCamo Block&r bersama dengan blok yang ingin kamu gunakan sebagai penyamar, lalu klik kanan pada blok yang ingin kamu samarkan, seperti kabel atau semacamnya.\\n\\nSecara standar &d&lCamo Block&r akan mengikuti bentuk tabrakan (collision) dari blok yang disamarkan. Kamu bisa mengubahnya ke versi Shape Retaining dengan memasukkannya ke grid crafting sendirian. Ini akan membuatnya mengikuti bentuk blok penyamarnya.\\n\\nJika kamu ingin melepas &d&lCamo Block&r, klik kanan blok yang tersamarkan dengan Camo Block lainnya."
		"{@pagebreak}"
		"{image:atm:textures/questpics/building_tips/camol_example.png width:200 height:100 align:center}"
	]
	quest.69B5D716568AA9EB.title: "&d&lCamol"
	quest.69B7DE2283B4EE6C.quest_desc: ["&bCrafting Co-Processing Unit&f membantu mempercepat tugas crafting dengan memungkinkan Pattern Provider mengirim item lebih cepat atau bekerja secara paralel untuk membuat beberapa bahan sekaligus.\\n\\nVarian dari &dMEGA Cells&f menyediakan 4 thread dalam satu blok."]
	quest.69B7DE2283B4EE6C.quest_subtitle: "Tambah Inti CPU"
	quest.69B7DE2283B4EE6C.title: "Crafting Co-Processing Unit"
	quest.69EE22CB4FF1E591.quest_desc: ["&aKontraption&r sangat sulit dipahami, tapi intinya adalah seni menggabungkan Blok dan &6Mesin&r berbeda menjadi satu sistem yang bergerak. \\n\\nKamu butuh &6Mesin&r untuk menggerakkan &aKontraption&r seperti &aRangka Linear&r, butuh &6Mesin&r yang ingin digunakan seperti &6Bor&r, dan butuh &aGlue&r untuk menyatukan semuanya! \\n\\nSetelah semua sudah di-&aGlue&r, semuanya harusnya bergerak ketika &dTenaga Rotasi&r diberikan ke &6Mesin&r penggerak &aKontraption&r."]
	quest.69EE22CB4FF1E591.title: "&a&lKontraption"
	quest.69F11A94D44AB5CF.quest_subtitle: "Silau banget!"
	quest.69F11A94D44AB5CF.title: "&fLight Xychorium Gems"
	quest.69F63F3B48E4344E.quest_subtitle: "Tingkat: &63"
	quest.6A07D09831428CB9.quest_desc: [
		"&4&lThe Nether&r mungkin terasa menakutkan, jika kamu lebih suka berlayar di &bLaut&r, gunakanlah &bSeashelf&r! \\n\\n&bSeashelf&r adalah pengenalanmu terhadap &5Arcana&r. Rak ini memberikan &53% Arcana&r dan &a3 Eterna&r. \\n\\nLebih baik dari rak buku biasa, kan? \\n\\nKamu akan butuh 16 buah untuk &d&lInfusion&r... yah, 15 buah untuk setup, dan 1 buah untuk di-&d&lInfuse&r! \\n\\nMama kayak &4Hellshelf&r, aku akan kasih bonus, kumpulkan saja 11 buah sekarang!"
		"{image:atm:textures/questpics/apothic/enchant_seashelf.png width:100 height:100 align:center}"
	]
	quest.6A07D09831428CB9.title: "&bSeashelves"
	quest.6A1145678E80FB8E.quest_desc: ["Ada banyak banget &5Enchantment&r yang ga berguna, kenapa ga ambil Energi dari mereka! &bEnchantment Generator&r pakai &5Enchanted Book&r buat bikin Energi. Level dan Rarity dari &5Enchanted Book&r ngubah jumlah Energi yang kamu dapat dari mereka."]
	quest.6A1145678E80FB8E.title: "&bEnchantment Generator"
	quest.6A1174845810C7A1.quest_desc: ["&7&lModification Station&r adalah cara kita masukin &7Module Unit&r ke Tool sama Armor. \\n\\nButuh &aEnergi&r buat operasi, karena tentu saja. \\n\\nPas lo Klik Kanan &7&lModification Station&r (yang powered) bakal buka GUI-nya. Di sini kita bisa liat seluruh Inventory termasuk Armor sama Offhand. Kita juga punya Layar sama 2 Slot tambahan. \\n\\n2 Slot tambahan adalah tempat &7Module Unit&r (Slot Kiri) sama Armor atau Tool yang mau ditambahin &7Module Unit&r (Slot Kanan). \\n\\nBegitu keduanya ditambahin ke Slot, otomatis bakal taro &7Module Unit&r ke &eItem&r. Kalo mereka tetep di Slot, kita bisa liat &7Module Unit&r yang di-install di &eItem&r di Layar. \\n\\nKalo lo mau keluarin &7Module Unit&r, klik di Layar, terus pencet tombol Remove. \\n\\nPas kita punya &7Module Unit&r yang di-install kita bisa pencet (\\\\) buat munculin Config mereka. Di sini kita bisa Enable atau Disable, dan lebih! "]
	quest.6A1174845810C7A1.title: "&l&7Modification Station"
	quest.6A12188E50EAEB78.quest_desc: ["&zRainbow Furnace&r bakal smelt satu stack Item sekaligus! \\n\\nBuat craft kamu butuh &zRainbow Core&r yang butuh 2 &cNetherite Furnace&r dan semua warna &zpelangi&r dalam Glass! \\n\\nTerus, kamu butuh &zRainbow Plating&r yang kamu dapetin dari gabungin hampir semua Furnace lain di mod. Kamu butuh 2 dari mereka buat craft &3&lImprobable Probability Device&r."]
	quest.6A12188E50EAEB78.title: "2 &zRainbow Furnace"
	quest.6A18B971C3DB83AE.quest_subtitle: "Tingkat: &63"
	quest.6A1C0B17B22CE50F.quest_desc: ["&9Amulet of Mana Boost&r memberikan peningkatan pada mana maksimal. \\n\\n&6Amulet of Mana Regen&r memberikan peningkatan pada regenerasi mana kamu."]
	quest.6A1C0B17B22CE50F.title: "Amulet"
	quest.6A21228B0511FF85.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_thermal.png width:100 height:150 align:center}"]
	quest.6A21228B0511FF85.title: "&6Thermal Springstone&r"
	quest.6A25ED4059E224D2.quest_desc: [
		"&#ED5585Distillery&r digunakan untuk menyuling cairan tertentu guna mendapatkan hasil yang lebih baik dan sesuai kebutuhan. "
		""
		"Kamu harus mengunci (lock) resep agar mendapatkan hasil yang diinginkan jika satu input menghasilkan banyak jenis output. Pertama, klik ikon gembok di GUI, klik pada tanda panah, lalu ikon &7'+'&r pada resep yang kamu inginkan."
	]
	quest.6A25ED4059E224D2.quest_subtitle: "Kunci resepnya"
	quest.6A2AD67569F91F1F.quest_subtitle: "Tingkat: &c5"
	quest.6A2B2C5E2ADCE366.quest_desc: ["Sophisticated Backpacks menawarkan tas yang bisa di-upgrade dan menggunakan filter untuk berbagai fitur canggih!\\n\\nTas bisa dipasang di slot Curios bagian punggung dan bisa diwarnai."]
	quest.6A2B2C5E2ADCE366.quest_subtitle: "Inventaris Terlalu Kecil"
	quest.6A2B2C5E2ADCE366.title: "Sophisticated Backpacks"
	quest.6A393C7A24899E3E.quest_desc: ["Meletakkan ingot ke dalam Grader bersama Katalis Grader akan memberikan 'grade' (tingkat kualitas) pada material tersebut.\\n\\nSemakin bagus grade-nya, semakin bagus pula statistik pada materialnya.\\n\\nGrade terbaik adalah \"MAX\"."]
	quest.6A393C7A24899E3E.quest_subtitle: "Penguji Material"
	quest.6A452BFC8A967C39.quest_desc: ["Memakai &aClaws&r ini bikin perasaan jadi beda. Adrenalin terpacu, pikiran kosong, kekuatan naik drastis! \\n\\nDengan &aFeral Claws&r, kamu akan menyerang jauh lebih cepat dengan senjata atau tangan kosong."]
	quest.6A452BFC8A967C39.quest_subtitle: "Tangan"
	quest.6A452BFC8A967C39.title: "&aFeral Claws&r"
	quest.6A46A9F04D2A0748.quest_desc: ["Direwolf adalah nama yang identik dengan Modded Minecraft dan &3&lJust Dire Things&r adalah salah satu bayi-nya. \\n\\nIni berkisar tentang Goo, ya gue tau kedengeran menarik!"]
	quest.6A46A9F04D2A0748.title: "&3&lJust Dire Things"
	quest.6A497B063CF32A5C.quest_desc: ["Fermented Spider's Eye bisa digunakan untuk menambah jumlah mob yang DAPAT muncul sekaligus dari satu spawner. Jumlah mob yang muncul tetap acak dengan batas maksimal yang ditentukan oleh angka ini. Nilainya bisa naik atau turun sebanyak 1 untuk setiap mata, hingga maksimal 16."]
	quest.6A497B063CF32A5C.title: "Spawn Count"
	quest.6A4D31194C4CE156.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penambang Bijih"
		"- Pemotong Rumput"
		"- Penyapu Langit"
		"- Penebang Pohon"
		"- Penghancur Daun"
		"- Pelebur Otomatis"
		"- Palu"
		"- Teleporter Barang Jatuhan"
		"- Tembus Pandang"
		"- Hancur Seketika"
	]
	quest.6A8E748B642DD16F.quest_desc: [
		"Di sinilah &bGaram&r akan disimpan. \\n\\nTipe &bGaram&r yang digunakan sangat berpengaruh pada item apa yang akan kamu Inkubasi. Jika ingin membuat Unobtainium kamu butuh &bMineral Salt&r, jika ingin Gandum kamu butuh &bPlant Salt&r, dan seterusnya."
		"{image:atm:textures/questpics/theurgy/theurgy_vessel_2.png width:100 height:125 align:center}"
	]
	quest.6A8E748B642DD16F.title: "Wadah &bGaram&r"
	quest.6A962535CD68713E.quest_desc: ["&e&lPipez&r bisa memindahkan lebih banyak! \\n\\nSemua Upgrade meningkatkan jumlah yang bisa dipindahkan oleh &e&lPipez&r, tapi masing-masing memberikan lebih banyak opsi. \\n\\nBasic Upgrade memungkinkan aktivasi Redstone pada &e&lPipez&r.\\n\\nImproved Upgrade memungkinkanmu mengubah distribusi: Terdekat Dulu, Terjauh Dulu, Round-Robin, atau Acak.\\n\\nAdvanced Upgrade memberimu opsi untuk menambahkan Filter.\\n\\nUltimate tidak memberikan fitur baru, ia hanya memindahkan sangat banyak item sekaligus!"]
	quest.6A962535CD68713E.title: "Pipe Upgrade"
	quest.6A9AE3514B5151C9.quest_desc: ["&#CFB951Kanthal Coil&r akan memungkinkan kita mengolah &#C356C4Raw Titanium&r menjadi &#DF9DE0Titanium Hot Ingot&r. Proses ini membutuhkan &#D49B70Manganese Sulfuric Solution&r."]
	quest.6ABDBE41880CFDA9.quest_desc: ["Quest ini dibuat oleh &6AllTheMods Staff&r, atau &2Community contributor&r untuk dipakai di AllTheMods Modpack.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan dengan &eAll Rights Reserved&r, Quest ini tidak boleh dipakai di pack publik manapun yang tidak dirilis oleh &6AllTheMods Team&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan, kalau terlihat, berarti sedang di editing mode."]
	quest.6AC85C203E7C3482.quest_desc: ["Kamu sudah mendapatkan satu dari segalanya dari &b&lMacaw's Mods&r. Aku rasa kamu layak mendapatkannya. \\n\\nDan yang kumaksud adalah seekor &bMacaw&r (Burung Beo) milikmu sendiri!"]
	quest.6AC85C203E7C3482.title: "Koleksi Macaw Lengkap"
	quest.6AD061C4331BE1F8.quest_desc: ["&4Mahou&r adalah sumber kehidupan segala hal &4&lMahou Tsukai&r. Perlu meningkatkannya dan punya banyak untuk menggunakan &eSpell&r dan membuat Weapon. \\n\\nSaat menggunakan &4Mahou&r batas akan naik. \\nCara mudah menghabiskan &4Mahou&r adalah menggunakan Attuned &aEmerald&r atau &bDiamond&r untuk menyimpan lebih banyak &4Mahou&r. \\n\\nSetelah punya &4Mahou&r yang cukup tinggi bisa coba &eSpell&r ini..."]
	quest.6AD061C4331BE1F8.title: "Cara menumbuhkan &4Mahou&r"
	quest.6ADDFD55AD0DF7D4.quest_desc: ["Gabungin &9Ridiculite Ingot&r dengan &cRossinite&r di &aReprocessor&r akan bikin &dInanite Ingot&r.\\n\\nKita sekarang bisa pakai ini untuk bikin blok &dInanite&r."]
	quest.6ADDFD55AD0DF7D4.title: "Inanite"
	quest.6ADE6F9E004055F7.quest_desc: [
		"Kristal Waktu adalah material baru yang ditambahkan oleh JDT. Ini tumbuh di Balok Kristal Waktu Bertunas, yang dibuat dengan melakukan penyebaran lendir pada Ametis Bertunas atau Balok Kristal Waktu.\\n\\nTAPI, Balok Kristal Waktu Bertunas harus mengumpulkan waktu dari Dunia Atas, Nether, dan Akhir agar bisa menumbuhkan Gugusan Kristal Waktu. Kamu TIDAK BISA hancurkan atau pakai sentuhan sutra pada Balok Kristal Waktu Bertunas. Kamu harus pakai Penukar, Kotak Kardus, atau Alat Potong Tempel untuk memindahkannya.\\n\\nSetelah beberapa waktu, Balok Kristal Waktu Bertunas akan kehabisan energi, dan harus pergi lagi ke Dunia Atas, Nether, dan Akhir."
		"{@pagebreak}"
		"Untuk otomasi proses ini, lihat video yang ditautkan di gambar di atas quest ini."
	]
	quest.6ADE6F9E004055F7.quest_subtitle: "Waktu yang Aneh"
	quest.6AE0A69DB3CDBCAA.quest_subtitle: "Sweet Crabapple + Flowering Azalea"
	quest.6B00D5DBB3552F15.quest_desc: [
		"Tangled adalah musuh yang spawn di Cursed Garden. \\n\\nMereka punya 10 Heart dan bakal nyerang dengan mukul kamu. Kalau kena, kamu bakal dapet sedikit poison. \\n\\nKalau mati mereka bakal drop Vine dan Bone tapi juga bakal spawn Tangled Skull! \\n\\nTangled Skull fungsi mirip kayak Vex, mereka bakal terbang menembus blok dan mukul kamu. Mereka cuma punya 5 Heart dan kalau mati bakal kasih kamu mereka sebagai Item."
		"{image:atm:textures/questpics/eternal/starlight_tangled.png width:150 height:100 align:center}"
	]
	quest.6B00D5DBB3552F15.title: "Tangled"
	quest.6B04FC81351CD1AB.quest_desc: ["Jika kamu ingin mengakses jaringan RS secara nirkabel, kamu perlu membuat &3Wireless Transmitter&r.\\n\\nKamu bisa memasang ini di mana saja di sistemmu. Ini adalah syarat utama untuk bisa menggunakan &9Wireless Grid&r."]
	quest.6B04FC81351CD1AB.quest_subtitle: "Teknologi Abad 21"
	quest.6B04FC81351CD1AB.title: "&5Akses Nirkabel"
	quest.6B0CD6732BE0E819.quest_desc: ["Secara harfiah cuma Jump Boost."]
	quest.6B0CD6732BE0E819.title: "Basic Jump Module"
	quest.6B0D84B730C6C76C.quest_desc: ["16 Warna yang diberikan &2&lMinecraft&r masih kurang? \\n\\nYah, kurasa kamu bisa punya 18 warna lagi! \\n\\n&l&cDy&6en&ea&ami&bcs&r memberikan kita 18 pewarna tambahan yang semuanya bisa digunakan untuk item dan blok yang sama dengan pewarna &2&lMinecraft&r! \\n\\nKamu ingin Lilin warna &6Peach&r? Bisa! Ingin Shulker warna &dBumblegum&r? Kenapa tidak! Ingin tempat tidur warna &eFluorscent&r? Tentu saja!"]
	quest.6B0D84B730C6C76C.title: "&l&cDy&6en&ea&ami&bcs&r"
	quest.6B1C06C753C10E44.quest_desc: ["&3Logistics Configurator&r dapat digunakan untuk mengonfigurasi Logistic Frame dan Transfer Gadget."]
	quest.6B2027DA7AA6FF34.quest_desc: ["&9Powah&r adalah mod teknologi yang berfokus pada penghasilan, penyimpanan, dan transmisi &dEnergi&r. Mulai dari penghasil FE dasar hingga &aReaktor&r yang menghasilkan &b250k FE/t&r, Powah punya semuanya!\\n\\nUntuk memulai, pergilah menambang &aUraninite&r!"]
	quest.6B2027DA7AA6FF34.title: "&aSelamat Datang di &9Powah&r!!!"
	quest.6B2BD6F939136F50.quest_desc: ["Meja Putar cukup sederhana. Wajah Atas dengan kotak &7Abu-abu&r akan menjadi bagian yang bergerak. \\n\\nWajah lainnya adalah &4Port Redstone&r, di mana akan memberi &4Sinyal Redstone&r untuk mengaktifkannya. \\n\\nKetika diaktifkan akan memutar Blok apa pun yang terpasang ke Atas. \\n\\nMungkin perlu menggunakan &6Palu Insinyur&r untuk mengubah cara berputarnya!"]
	quest.6B3BD54A34EB02C2.quest_desc: ["&aInduction Provider&r ditaro di dalam &a&lEnergized Induction Matrix&r dan bakal nambah jumlah &aEnergi&r yang bisa di-Input dan Output. \\n\\nDan iya, total mereka bakal numpuk! \\n\\n&aBasic Induction Provider&r: bakal Input dan Output 102.4kFE tiap Tick. \\n\\n&cAdvanced Induction Provider&r: bakal Input dan Output 819.2kFE tiap Tick. \\n\\n&bElite Induction Provider&r: bakal Input dan Output 6.55MFE tiap Tick. \\n\\n&5Ultimate Induction Provider&r: bakal Input dan Output 52.41MFE tiap Tick."]
	quest.6B3BD54A34EB02C2.quest_subtitle: "Transport"
	quest.6B3BD54A34EB02C2.title: "&aInduction Provider"
	quest.6B40AF49F505A551.quest_desc: ["Pernah ingin jadi seperti Batman? Hidup di dalam bayangan demi menegakkan keadilan? Maka &9Midnight Robe&r sangat cocok untukmu! (Dan juga bergaya!) Saat dipakai di tingkat cahaya rendah, kamu akan menjadi tidak terlihat (Invisible) dan mendapatkan tambahan kecepatan. Ini bisa di-upgrade agar tingkat cahayanya bisa lebih tinggi atau memberikan kecepatan lebih. \\n \\nKemampuan keduanya mirip dengan sistem di game Stealth. Saat memukul mob sambil tidak terlihat, kamu akan memberikan damage yang jauh lebih besar namun akan kehilangan efek stealth dan kecepatan sampai kamu meninggalkan lingkaran yang terbentuk di sekitar mob tersebut."]
	quest.6B40AF49F505A551.quest_subtitle: "Ditemukan di Mineshaft atau Stronghold"
	quest.6B40AF49F505A551.title: "&9Midnight Robe"
	quest.6B511C8B572E8940.quest_desc: ["Di pojok kiri bawah layar, kamu akan melihat sebuah bar. Bar ini adalah kolam mana (mana pool) milikmu! \\n\\nAda beberapa cara untuk meningkatkan kapasitas mana, atau meningkatkan efisiensi mantramu seiring perkembanganmu di mod ini. Meng-upgrade spellbook juga bisa meningkatkan manamu!"]
	quest.6B511C8B572E8940.quest_subtitle: "Kekuatan Penyihir"
	quest.6B511C8B572E8940.title: "Mana"
	quest.6B56F92E28C92A0F.quest_desc: ["&eSolar Neutron Activator&r adalah salah satu &5Mesin&r paling gampang buat bottleneck... mari kita coba cegah dengan Multiblock ini! \\n\\nAnehnya kita gak butuh &aEnergi&r di sini, cuma butuh &cChemical&r Input dan Output. \\n\\nTunggu, kalo yang biasa pake Waktu sama &eSiang hari&r apakah yang ini sama? \\n\\nIya, harus &eSiang hari&r buat jalan. Plus butuh Time Counter Block buat bikin Recipe. Ini bisa ditaro di mana aja di Multiblock tapi gak bisa ganti Blok manapun."]
	quest.6B56F92E28C92A0F.title: "&e&lSolar Neutron Activator Multiblock"
	quest.6B5B01C612951BAF.quest_desc: ["Berbeda dengan Gate Pearl lainnya, yang satu ini didapatkan dengan menyelesaikan &4&lPinnacle&r Gateway.\\n\\nNamun, ini akan membutuhkan pengorbanan Craig the Eternal, makhluk dengan HP yang SANGAT banyak.\\n\\nGateway ini akan memunculkan gelombang musuh yang tak ada habisnya dan semakin kuat, dengan jeda waktu yang semakin singkat. Gateway ini bisa memunculkan &4Invader&r dari dimensi MANA PUN, bukan cuma dari dimensi tempatmu mengaktifkannya. Ini berarti kamu bisa mendapatkan gem yang biasanya eksklusif di dimensi lain, seperti Endersurge Gem di luar The End.\\n\\nJika kamu bisa bertahan hingga 100 gelombang, kamu bisa mendapatkan..."]
	quest.6B5BC33667C782EC.quest_desc: ["&dEnder Golem&r menjaga &dRuined Citadel&r, biasanya ada beberapa di sana. \\n\\nSecara teknis kamu tidak wajib melawannya untuk bisa melawan &dEnder Guardian&r, tapi kamu sangat disarankan melawannya untuk mendapatkan &dVoid Core&r. \\n\\n&dEnder Golem&r punya 5250 &4HP&r dan akan meregenerasinya jika dibiarkan. \\n\\nIa punya serangan pukulan dan hantaman tanah yang memicu &dVoid Rune&r, melukai pemain atau mob yang menyentuhnya."]
	quest.6B5BC33667C782EC.title: "&dEnder Golem"
	quest.6B671CB07D046BEC.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_diamond.png width:100 height:150 align:center}"]
	quest.6B671CB07D046BEC.title: "&bDiamond&r"
	quest.6B747129A85AA768.quest_desc: ["Sekarang bahkan lebih mirip Absorption Hopper! \\n\\nVacuum Module sekarang akan mengambil bola XP selain item. Apa pun yang kamu lakukan dengan XP itu terserah padamu!"]
	quest.6B78378BC8036227.title: "Katalis Grader Tingkat 1"
	quest.6B7E13AB3BF2C5C8.quest_desc: [
		"&6&lThermoelectric Boiler&r dibangun mirip kayak &2&lFission Reactor&r dengan casing luar cuma Casing, Kaca, sama Port, sedangkan dalemnya semua bagian penting! \\n\\nPinggiran &6&lBoiler&r harus pake &6Boiler Casing&r. Atap sama Lantai bisa dibuat sepenuhnya dari &6Casing&r atau tengahnya bisa pake Kaca! \\n\\nDindingnya mirip, sekarang termasuk &6Boiler Port&r. \\n\\nDi dalem ada &9Pressure Disperser&r sama &6Superheating Element&r. \\nAtap bisa dikasih ruang antara Langit-langit sama &9Pressure Disperser&r buat kasih lebih banyak ruang buat Steam. \\n\\nKita juga bisa kasih lebih banyak ruang di bawah &9Pressure Disperser&r dan di atas &6Superheating Element&r buat kasih lebih banyak ruang buat &9Air&r."
		"{@pagebreak}"
		"&6&lThermoelectric Boiler&r gak bakal ngapa-ngapain sendiri, butuh beberapa &6Port&r yang mindahin &cChemical&f sama &bFluid&r masuk buat nyalain! \\n\\nSekarang kita bakal fokus ke pendinginan &6Superheated Sodium&r! Buat itu kita butuh &6Superheated Sodium&r sama &9Air&r di dalam &6&lBoiler&r. \\n\\nBegitu &6Superheated Sodium&r masuk, &6Temperature&r &6&lBoiler&r bakal mulai naik. Dengan &9Air&r, &6Superheated Sodium&r bakal dingin sedangkan &9Air&r bakal mendidih jadi Steam. \\n\\nMakin tinggi &6Temperature&r makin cepet &9Air&r mendidih dan &6Superheated Sodium&r dingin. Kalo kita mau/butuh &6Panas&r ekstra kita bisa &6Conduct&r lewat &6Thermodynamic Conductor&r. \\n\\nKita bisa &6Conduct Heat&r dari &6Resistive Heater&r atau bahkan &2&lFission Reactor&r!"
		"{@pagebreak}"
		"Multiblock ini bisa dibuat dengan ukuran apapun yang tersedia, gak cuma yang ditampilin di Gambar. Gambar cuma nunjukin ukuran paling kecil yang bisa dibuat."
		"{image:atm:textures/questpics/mek/mek_boiler1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_boiler2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_boiler3.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_boiler4.png width:100 height:110 align:center}"
	]
	quest.6B7E13AB3BF2C5C8.title: "&6&lThermoelectric Boiler"
	quest.6B8040401B512E50.quest_desc: ["&3&lC.D.C.&r (&3&lChemical Dissolution Chamber&r bukannya Center for Disease Control) itu &5Mesin&r lain yang cuma dipakai buat &lOre Processing&r. \\n\\n&3&lC.D.C.&r butuh &aSulfuric Acid&r dan &7Ore&r. \\n\\n&7Ore&r masuk ke &4Slot Merah&r sedangkan &aSulfuric Acid&r masuk ke &4Bar Merah&r. \\n\\nHasil &7Dirty Slurry&r bakal muncul di &9Bar Biru&r!"]
	quest.6B8040401B512E50.title: "&3&lChemical Dissolution Chamber"
	quest.6B8F2E05429C185F.quest_desc: [
		"Setelah dikalahkan dia akan drop EXP, Dragon Heart, dan yang terpenting membebaskan Chaos Shard. Lihat ke mana Lightning akan menyambar lalu tambang di bawahnya. Di sana kamu akan menemukan Chaos Shard. Tambang untuk diberikan 5 Chaos Shard yang bisa di-craft jadi bagian lebih kecil darinya!"
		"{image:atm:textures/questpics/draconic/draconic_shard.png width:150 height:100 align:1}"
	]
	quest.6B8F2E05429C185F.title: "Chaos Shard{s}"
	quest.6BA2BC09E23B34A9.quest_desc: [
		"Yang ini butuh &9Chiseled Polished Darkstone&r lain, cuma sekarang dengan 4 &7Rune&r dan 4 &2Stellarite&r Piece. \\n\\n&6&lForge&r ini adalah yang terakhir untuk &6&lForbidden \\& Arcanus&r basic. \\n\\nTentu saja punya sisa Resep plus setiap space untuk Relic sekarang terbuka!"
		"{image:atm:textures/questpics/forbidden/forbidden_tier4.png width:100 height:100 align:center}"
	]
	quest.6BA2BC09E23B34A9.title: "&l&dTier 4 &6Forge"
	quest.6BB948F44B0950E8.quest_desc: ["&3Sculk Stone&r tumbuh hampir di mana-mana kecuali &cOvercast Columns&r. \\n\\nBekerja seperti &7Stone&r normal, seperti dalam segala hal. Kamu bisa smelt versi Cobbled untuk dapat &3Sculk Stone&r yang bisa dibuat jadi banyak Building Block lainnya. \\n\\nSayangnya tidak bisa dipakai untuk membuat Stone Tools... tunggu kenapa kamu peduli, kamu sudah bunuh &9&lWarden&r! Kenapa kamu butuh Stone Tools?!?!?!"]
	quest.6BB948F44B0950E8.title: "&3Sculk Stone"
	quest.6BBC440BD0AD0E93.quest_desc: ["Beberapa orang suka &9&lSilent Gear&r, sementara yang lain suka &7&lTinker's Construct&r. \\n\\nAlih-alih memilih salah satu, kami memutuskan untuk mengambil yang terbaik dari keduanya dengan menggabungkan &9&lSilent Gear&r dan &c&lProductive Metalworks&r! \\n\\n&c&lProductive Metalworks&r akan mengubah cara kita mendapatkan item &9&lSilent&r. Alih-alih memakai &9Blueprint&r, sekarang kita butuh &8Cast&r (Cetakan) dan sebuah &c&lFoundry&r. \\n\\nUntuk mulai membangun &c&lFoundry&r, mulailah dengan membuat &cFire Clay&r."]
	quest.6BBC440BD0AD0E93.title: "&9&lSilent Gear&r dan &c&lProductive Metalworks"
	quest.6BC0904E03683190.quest_desc: ["Kawinkan para lebah untuk mendapatkan 8 bayi lebah baru."]
	quest.6BC3CF8937DEDE89.quest_desc: ["Gabungkan &cInfernal Forge&r dengan &dVoid Core&r untuk membuat &dVoid &cForge&r! \\n\\nBentuknya tetap Beliung, dengan tingkat tambang dan kecepatan yang sama. \\n\\nBedanya sekarang kita bisa Klik Kanan ke tanah untuk memanggil &dVoid Rune&r dalam pola kipas untuk melukai semua mob. \\n\\nMereka sepertinya tidak terlalu peduli dengan fungsi aslinya sebagai beliung, ya?"]
	quest.6BC3CF8937DEDE89.title: "&dVoid &cForge"
	quest.6BC78AF7C9D93F11.quest_desc: ["Bahkan ada versi Glazed-nya!"]
	quest.6BC78AF7C9D93F11.title: "Terracotta &l&bChipped&r"
	quest.6BD348735C27BB44.quest_desc: [
		"&b&lMesin Pembotolan&r akan mengisi &eBarang&r apa pun yang lewat di &eSabuk&r. \\n\\nGunakan Port di Belakang untuk mengisi &b&lMesin&r dengan &bCairan&r, akan tahu berfungsi ketika Tangki penuh dengan &bCairan&r itu! \\n\\nKemudian, ketika &bEmber&r, &bTangki&r, atau &bPenyimpanan Cairan&r apa pun turun di &eSabuk&r, akan diisi dengan &bCairan&r itu. \\n\\n&bEmber&r, &bTangki&r, atau apa pun kemudian akan bergerak di &eSabuk&r penuh dengan &bCairan&r itu! \\n\\nOmong-omong, seperti segala sesuatu dalam hidup, &b&lMesin Pembotolan&r akan memerlukan &cEnergi&r di Port di Atas sisi Belakang!"
		"{@pagebreak}"
		"Untuk memulai, buat segitiga dari &8Perancah Baja&r. Kemudian isi lubang dengan &7Lembar Besi&r, &4Blok Teknik Redstone&r, dan &eBlok Teknik Ringan&r."
		"{image:atm:textures/questpics/immersive/immersive_bottler1.png width:100 height:100 align:center}"
		"Sekarang tambahkan &eSabuk Konveyor&r di sisi depan. Kemudian, tambahkan &7Lembar Besi&r kedua di yang lain, &bPompa Cairan&r di sebelahnya, dan &eBlok Teknik Ringan&r di yang sebelumnya!"
		"{image:atm:textures/questpics/immersive/immersive_bottler2.png width:100 height:100 align:center}"
		"Cukup &6Palu&r &eSabuk Konveyor&r tengah dan BOOM selesai!"
		"{image:atm:textures/questpics/immersive/immersive_bottler.png width:100 height:100 align:center}"
	]
	quest.6BD348735C27BB44.title: "&b&lMesin Pembotolan"
	quest.6BEE3578BD2C713C.quest_subtitle: "Muncul dari Dirt Nest"
	quest.6BF6C7C04F26D8BA.quest_subtitle: "Black Ember + Soul Tree"
	quest.6BFD7854F078BF16.quest_subtitle: "Genggam erat-erat"
	quest.6BFF78D4218DF1F2.quest_subtitle: "Dibuat di Hephaestus Forge"
	quest.6BFF78D4218DF1F2.title: "Stellarite Bee"
	quest.6C001E18093FC037.title: "Tanaman"
	quest.6C14D1B60124C2B2.quest_desc: [
		"&9Tunnel Bore&r sangat cocok untuk memasang &6Rel&r secara otomatis, terutama saat menembus gunung atau bukit. \\n\\nIa butuh 3 hal: &9Kepala Bor&r, bahan bakar seperti Batu Bara, dan &6Rel&r cadangan. Jika sudah lengkap, tinggal jalankan saja! \\n\\nJangan lupa pantau stok item di dalamnya!"
		"{image:atm:textures/questpics/railcraft/rail_tunnel.png width:100 height:100 align:center}"
	]
	quest.6C14D1B60124C2B2.title: "&9Tunnel Bore"
	quest.6C163E005351FF6D.quest_desc: ["&cWhistle Kit&r jika diaktifkan dengan Redstone akan membuat &5Lokomotif&r membunyikan peluitnya."]
	quest.6C163E005351FF6D.title: "&cTrack Kit&r Peluit (Whistle)"
	quest.6C16670D16113DE9.quest_desc: ["Buat otomatisasi crafting &6&lATM Star&r, kita butuh &6Star Shard&r. Dan buat dapetin &6Star Shard&r, kita butuh &6Starry Bee&r. \\n\\nDan tentu aja, buat dapetin &6Starry Bee&r, kita butuh &dPatrick &aBee&r! Kamu bisa dapet &dPatrick &aBee&r (jarang) dengan cara mancing di lautan hangat (Warm Ocean)! \\nKalau kamu nggak mau mengubah mereka, kamu juga bisa pakai mereka buat farm &dPatrick &aStar&r."]
	quest.6C16670D16113DE9.title: "&dPatrick &aStar&r... Bee?"
	quest.6C1BBA559963B3DF.quest_desc: [
		"&aDictionary Of Spirits&r berfungsi sebagai Buku Panduan untuk &dOccultism&r. Kamu sangat wajib membuat buku ini jika ingin lanjut dengan mod ini!"
		""
		"Buku ini memiliki panduan bergaya quest di dalamnya jika kamu lebih suka membacanya daripada mengikuti quest ini!"
		""
		"Kamu juga butuh buku ini untuk men-craft beberapa barang di pack ini, jadi ya memang harus buat. :)"
	]
	quest.6C1BBA559963B3DF.title: "Buku Kecil Panduan &cSetan"
	quest.6C1F7A0B330B3F42.quest_desc: ["&a&lMekaSuit Bodyarmor&r, adalah upgrade dari &5Unobtainium Chestplate&r. \\n\\nButuh beberapa &eItem&r lain buat upgrade, kayak &dAntimatter Pellet&r, &aPolonium Pellet&r, bahkan &dUltimate Induction Cell&r! \\n\\n&a&lMekaSuit Bodyarmor&r tanpa &aEnergi&r bakal kerja kayak &cNetherite Chestplate&r. Gimana kalo pake &aEnergi&r? Bisa blokir semua Damage kecuali Magic Damage dan bakal pake &aEnergi&r daripada Health! \\n\\nKita bisa masukin ke &7&lModification Station&r buat tambahin &7Module Unit&r yang bisa upgrade! &a&lMekaSuit Bodyarmor&r punya &7Module Unit&r paling banyak dari semua Armor, jadi pasti cek!"]
	quest.6C1F7A0B330B3F42.title: "&a&lMekaSuit Bodyarmor"
	quest.6C2C135B9B7B9402.quest_desc: ["&d&lInfusion&r adalah versi spesial dari &5Enchanting&r yang ironisnya digunakan untuk mendapatkan &5Enchantment&r yang lebih baik. \\n\\nSaat level &aEterna&r, &cQuanta&r, dan &5Arcana&r yang tepat tercapai, pilihan &5Enchantment&r akan menawarkan &d&lInfusion&r. \\n\\n(Untuk mengetahui level yang dibutuhkan, kamu bisa cek EMI atau ikuti quest-quest ini)"]
	quest.6C2C135B9B7B9402.title: "Sistem Infusing"
	quest.6C4B93FE64BD418D.quest_desc: ["Pergi ke &2&lUndergarden&r mirip seperti pergi ke &c&lNether&r. Kamu perlu membuat sebuah Portal. \\n\\nBentuk dan ukurannya sama dengan Portal Nether, tapi alih-alih Obsidian, kamu butuh varian dari Stone Brick. Bisa Stone Brick biasa, Mossy Stone Brick, atau Deepslate Brick. \\n\\nSetelah terbentuk, kamu bisa mengaktifkannya menggunakan Catalyst."]
	quest.6C4B93FE64BD418D.quest_subtitle: "Membuat Portal"
	quest.6C4B93FE64BD418D.title: "The Undergarden"
	quest.6C57D64518FF22C0.quest_desc: ["Sisa &5Enchantment&r lainnya berasal dari &8Tome&r ini. \\n\\n&5Unbreaking&r... aku juga nggak tahu apalagi isinya..."]
	quest.6C57D64518FF22C0.title: "Tome Lain-lain"
	quest.6C5D61A704DC125A.quest_desc: [
		"Yang satu ini lucu; kamu bisa menemukannya, membuatnya, atau menukarkannya.\\n\\nLalu kamu bisa mewarnainya sesuka hati dan tentu saja memakainya di kepala!\\n\\nPara lebah akan mengira kamu adalah bunga dan akan mengikutimu.\\n\\nIni juga membuatmu terlihat seperti Daffy Duck dari episode \"Duck Amuck\"."
		"{image:atm:textures/questpics/bumblezone/bumble_duckamuck.png width:100 height:100 align:center}"
	]
	quest.6C5D61A704DC125A.title: "Topi Bunga"
	quest.6C5F9D0D447EFB9C.quest_desc: ["Kamu pikir cuma &l&2Vanilla&r yang kita punya? \\n\\n&6Allthemodium Armor&r memiliki Poin Armor dan Toughness yang lebih tinggi, ditambah perlindungan ekstra terhadap Sihir dan buff lainnya yang bisa kamu baca di halaman quest &6&lAllthemodium&r! \\n\\nNgomong-ngomong, kamu butuh &cNetherite&r untuk men-craft-nya."]
	quest.6C5F9D0D447EFB9C.quest_subtitle: "24"
	quest.6C5F9D0D447EFB9C.title: "&6Allthemodium Armor"
	quest.6C6F4EB5CBE2FBC2.quest_desc: ["Iron Divination Rod setingkat lebih tinggi, mampu menemukan bijih yang bisa ditambang dengan Beliung Besi (Iron Pickaxe)! Seperti Diamond, Redstone, dan Emas."]
	quest.6C9191DA4B1039D6.quest_desc: ["Menril Berries memberikan Night Vision untuk waktu singkat saat dimakan."]
	quest.6CA01DCE1F4A0EC3.quest_desc: ["Tahap mod selanjutnya membutuhkan pengumpulan &3Crude Oil&r (Minyak Mentah). Minyak ini bisa ditemukan secara alami di permukaan dunia Overworld."]
	quest.6CA01DCE1F4A0EC3.quest_subtitle: "Jalan menuju Plastik"
	quest.6CA01DCE1F4A0EC3.title: "Crude Oil (Minyak Mentah)"
	quest.6CA1D90CCE17097D.quest_subtitle: "Lightning Scepter Sekali Pakai"
	quest.6CAD27627A3F8FD7.quest_desc: [
		"Sekarang kita sampai ke inti dari mod ini, &eAlchemical Sulfur&r! \\n\\nUntuk membuatnya, kita butuh Liquefaction Cauldron, sebuah item, &dSal Ammoniac&r, dan sebuah pemanas (Heater). \\n\\nSistem panas dijelaskan di quest lain, tapi kamu butuh Pyromantic Brazier atau Caloric Flux Emitter di bawah Cauldron untuk memanaskannya. \\n\\nLalu masukkan cairan &dSal Ammoniac&r ke dalamnya. \\n\\nDan terakhir, masukkan item yang ingin kamu ubah menjadi &eAlchemical Sulfur&r. \\n\\nKamu tahu prosesnya berjalan saat cairannya bergelembung."
		"{image:atm:textures/questpics/theurgy/theurgy_lique.png width:100 height:100 align:center}"
	]
	quest.6CAD27627A3F8FD7.title: "Membuat &eAlchemical Sulfur"
	quest.6CAD67D21E1EA861.quest_desc: [""]
	quest.6CAD67D21E1EA861.quest_subtitle: "&oAkses remote universal."
	quest.6CAD67D21E1EA861.title: "&7&lNexium Emitter"
	quest.6CB1BFBA10DF24E4.quest_desc: ["Menggunakan &cScepter of Life Draining&r, kamu bisa menyedot nyawa musuhmu!\\n\\nUntuk mengisi kembali tongkat ini, gabungkan dengan &cMata Laba-laba Fermentasi (Fermented Spider Eye)&r di meja crafting."]
	quest.6CB1BFBA10DF24E4.quest_subtitle: "Menyedot Nyawa"
	quest.6CB1BFBA10DF24E4.title: "&cScepter of Life Draining"
	quest.6CB8D3919B16784B.quest_desc: ["&9Ceraunus&r adalah senjata Jangkar yang digunakan oleh &9&lScylla&r sendiri! \\n\\nDengan hanya 2 &9Essence of the Storm&r dan 3 &9Lacrima&r kita bisa men-craft-nya! Hanya urutannya berbeda dengan &9Astrape&r. \\n\\nKamu bisa mengayunkan jangkar ini seperti Gada (Mace) dengan jeda serangan yang lama. Atau gunakan serangan spesial! \\n\\nTahan Klik Kanan untuk melemparkan jangkar ke depan. Jika mengenai mob, ia akan memberikan damage dan knockback. \\n\\nKamu juga bisa Shift+Klik Kanan untuk memunculkan rentetan &9Gelombang&r di depanmu!"]
	quest.6CB8D3919B16784B.title: "&9Ceraunus"
	quest.6CC5FE34778F0DFA.quest_desc: [
		"Kamu pasti akan punya terlalu banyak item saat memainkan modpack ini. Begitulah cara kerjanya, dan jika kamu belum menentukan sistem penyimpananmu, &dDimensional Storage&r mungkin cocok untukmu!"
		""
		"Untuk memulai solusi penyimpanan ajaib ini, kamu perlu men-craft &dDimensional Storage Actuator&r dan meletakkannya di dunia. Alat ini bertindak persis seperti Shulker Box, artinya jika dihancurkan, item di dalamnya tidak akan hilang."
		""
		"Secara default, ini memiliki 128 slot penyimpanan di mana setiap slot menampung hingga 16 stack item, kecuali untuk item dengan data &5NBT&r. Item NBT tidak akan menumpuk dan memakan satu slot utuh, jadi sebaiknya jangan simpan item seperti itu di sini!"
		""
		"Jika kamu tidak yakin item mana yang punya data NBT, kamu bisa cek quest \"NBT dan Kamu\" di alur quest Storage untuk info lebih lanjut!"
	]
	quest.6CC5FE34778F0DFA.title: "Penyimpanan Ajaib &d&c&mSetan&r!"
	quest.6CCDEEDA2C99DA66.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.6CCE920735187234.quest_desc: [
		"&9&lTurbine&r minimal 5x7x5 &5Mesin&r tapi bisa diperbesar buat nampung lebih banyak Steam dan bikin lebih banyak &aEnergi&r! \\n\\nFrame &9&lTurbine&r dibuat dari &9Turbine Casing&r. Lantai sama Langit-langit bisa diisi dengan &9Turbine Casing&r atau Structural Glass. \\n\\nSebelum khawatir soal Dinding, mari fokus ke bagian dalam! Itu yang bener-bener penting! \\n\\nDi tengah persis dari Lantai adalah tempat &9Rotor&r bakal ditaro. Buat yang paling kecil kita butuh 2! Terus, pasang &9Blade&r ke mereka, 4 total. \\n\\nDi atas &9Rotor&r paling tinggi taro &9Rotational Complex&r dan kelilingin dengan &9Pressure Disperser&r. \\n\\nLayer di atas &9Rotational Complex&r bakal jadi &aElectromagnetic Coil&r dan di atasnya bakal ada &9Saturating Condenser&r. \\n\\nSekarang kita bisa taro &9Port&r sama &9Vent&r di Dinding dan isi sisanya dengan &9Turbine Casing&r atau Structural Glass!"
		"{@pagebreak}"
		"Untungnya &9&lTurbine&r jauh lebih gampang dipake daripada Dibangun! \\n\\n&cTubing&r Steam lewat &9Port&r dan harusnya mulai berputar. Jumlah Steam yang bisa ditampung ditentukan sama ukuran seluruh Build &9&lTurbine&r. \\n\\nTerus &9Rotor &fdan &9Blade&r bakal mulai berputar karena Steam naik lewat &9&lTurbine&r. Ini bakal gerakin &9Rotational Complex&r yang gerakin &aElectromagnetic Coil&r bikin &aEnergi&r! \\n\\n&aEnergi&r bisa di-&aKabel&rin keluar dari &9Port&r ke-2 kita. Jumlah &aEnergi&r ditentukan sama seberapa cepet &9Rotor &fdan &9Blade&r bergerak. Yang sendirinya ditentukan sama berapa banyak Steam yang di-Input ke &9&lTurbine&r. \\n\\nKalo kita pake &9Saturating Condenser&r kita bakal dapet sedikit &9Air&r balik dari Steam. Kita bisa keluarin &9Air&r ini dari &9Vent&r dan balik ke &2&lFission Reactor&r! \\n\\nKita punya setting di GUI &9&lTurbine&r yang mirip dengan yang ada di &9&lElectrolytic Separator&r. Kita bisa pilih buat Dump Excess Steam, buat terus kerja di produksi &aEnergi&r paling cepet. Kita bisa Dump Steam, kalo lo mau buang aja kayaknya... atau Idle yang default! Kalo lo pake yang bukan Idle, gak bakal daur ulang &9Air&r dari Steam."
		"{@pagebreak}"
		"Multiblock ini bisa dibuat dengan ukuran apapun yang tersedia, gak cuma yang ditampilin di Gambar. Gambar cuma nunjukin ukuran paling kecil yang bisa dibuat."
		"{image:atm:textures/questpics/mek/mek_turbine1.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine3.png width:110 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine4.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine5.png width:100 height:110 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine6.png width:100 height:120 align:center}"
		"{image:atm:textures/questpics/mek/mek_turbine7.png width:100 height:125 align:center}"
	]
	quest.6CCE920735187234.title: "&9&lTurbine"
	quest.6CD1720B76F47806.quest_desc: ["&2&lBio-Generator&r kerjanya dengan cara ambil &2Bio Fuel&r, dijadiin &2Bioethanol&r, terus dipakai buat &aEnergi&r! \\n\\n&2&lGenerator&r yang ini sudah di-nerf parah, jadi disaranin nggak usah dipakai! \\n\\nItu karena kalian bandel bikin &aKebun Melon&r raksasa yang bikin TPS Server hancur!"]
	quest.6CD1720B76F47806.title: "&2&lBio-Generator"
	quest.6CD60A9D88227005.quest_desc: ["Pernah ingin memasang pipa di celah antar blok? Izinkan aku memperkenalkan &3Transfer Label&r. &3Transfer Label&r bisa digunakan untuk item dan cairan.\\n\\n&lCara penggunaan&r\\n\\nKamu bisa memasang &3Label&r pada blok dengan cara Shift + Klik Kanan pada blok.\\nKamu bisa berinteraksi dengan &3Label&r dengan memegang &3Label&r lain atau &#FFAC3BLabel Accessor&r dan Klik Kanan pada &3Label&r yang sudah terpasang.\\nKamu bisa melepas &3Label&r dengan Klik Kiri sambil memegang &3Label&r lain atau &#FFAC3BLabel Accessor&r.\\nKamu bisa mengakses &3Label&r menembus blok menggunakan &#FFAC3BLabel Accessor&r.\\n\\\\n&lAkselerasi&r\\n\\nKamu bisa mempercepat (accelerate) &3Label&r dengan menambahkan tipe &3Label&r yang sama ke dalam slot jumlah atau kecepatan."]
	quest.6CD60A9D88227005.quest_subtitle: "Saat kamu harus memasang pipa di sela-sela blok"
	quest.6CD60A9D88227005.title: "&3&lTransfer Label"
	quest.6CD7D99AA102A5C3.quest_desc: ["&n&f&lLogistik&r: \\nSebuah sistem untuk memindahkan, mengelola, dan menyimpan item atau sumber daya. \\n\\nDi Minecraft Modded, konsepnya sama: memindahkan item! Di dunia modded kamu akan butuh item dalam jumlah ribuan, bahkan jika kamu ingin &6&lATM Star&r jumlahnya bisa jutaan! Jadi kamu perlu memindahkan item dari pabrik, mesin, kebun, dan terutama peti. Itulah gunanya &l&fLogistik&r."]
	quest.6CD7D99AA102A5C3.title: "&lLogistik"
	quest.6CE7115DA2B23776.quest_desc: ["Tidak jauh lebih baik dari yang Flimsy... \\n\\nIni bisa menampung satu &3Spell&r lebih dari Flimsy Journal! Itu satu &3Spell&r yang sangat kuat lagi yang siap!"]
	quest.6CE7115DA2B23776.title: "Ironbound Journal"
	quest.6D0876A402C22067.quest_desc: ["XyCraft memiliki beberapa fitur penyimpanan dan manipulasi item. Tapi tidak sebanyak fitur manipulasi cairannya!"]
	quest.6D0876A402C22067.title: "&6Penyimpanan dan Manipulasi Item"
	quest.6D09511D64DDC282.quest_desc: ["&dWarden&r bisa dipanggil dengan memicu &5Sculk Sensor&r yang dekat dengan &3Sculk Shrieker&r setidaknya 3 kali.\\n\\nFakta Menarik: Warden buta! Dia hanya bisa menemukan kalau mendengar, jadi terbang atau sneak!\\n\\nTip: Tidak masalah pakai serangan Ranged atau Melee, karena dia akan menemukan. Dan dia akan memukul. Kalau terlalu jauh, dia akan menggali ke tanah dan muncul di sebelah! Semoga beruntung :D"]
	quest.6D09511D64DDC282.title: "&5Bunuh Warden"
	quest.6D0A876D4E4D35AB.quest_desc: ["Creative Essence dibutuhin buat craft &6Bintang ATM&r."]
	quest.6D0A876D4E4D35AB.quest_subtitle: "Tingkat: &5Creative"
	quest.6D0A876D4E4D35AB.title: "&5Creative Essence"
	quest.6D124ACF4AE80490.quest_desc: ["Dengan Micromissile kamu bisa menembakkan ledakan dari jauh! Sekarang nggak ada yang bisa kabur!\\n\\nItem ini dibutuhkan untuk men-craft &6ATM Star&r."]
	quest.6D124ACF4AE80490.quest_subtitle: "Menembakkan Ledakan dari Jauh!"
	quest.6D14ACECD2084456.quest_subtitle: "Wenge + Oak"
	quest.6D1E8399AD39FFC8.quest_desc: ["&7Paradox Machine&r bisa, dengan harga banyak Power dan &aTime Fluid&r, bakal ambil Snapshot dari block dan entity di area yang ditentuin; terus bisa duplikat. \\n\\nBanyak Block dan Entity di-blacklist sama config jadi gak bisa duplikat Bee!"]
	quest.6D1E8399AD39FFC8.title: "&7Paradox Machine"
	quest.6D232F6D8E8DA546.quest_desc: [
		"Sangat populer di sekitar Halloween!"
		"{image:atm:textures/questpics/iron_spells/spells_outfit_plagued.png width:60 height:100 align:center}"
	]
	quest.6D232F6D8E8DA546.title: "&2Plagued Outfit"
	quest.6D42D0102D1CBC19.quest_desc: ["Auger Tambahan adalah Sharpness... hanya untuk &4&lBor&r! \\n\\nOh ya dan bisa memiliki 3 sekaligus, untuk kekuatan bertumpuk."]
	quest.6D484150536536B9.quest_desc: [
		"Nest ini menarik &eCrystalline Bee&r. Kamu butuh blok Nether Quartz sebagai pengganti Honey Treat."
		""
		"Cara termudah dapat blok kuarsa adalah menambangnya pakai beliung Silk Touch."
		""
		"Tips: Material Brass punya sifat Silk Touch otomatis saat dijadikan alat Silent Gear."
	]
	quest.6D484150536536B9.quest_subtitle: "Memancing Crystalline Bee di dimensi Nether"
	quest.6D4FB6291CA8D1A6.quest_desc: ["Pohon Smogstem jauh lebih tebal di bagian bawahnya, mirip pohon Baobab di dunia nyata! \\n\\nPunya daun biru dengan batang abu-abu. \\nKamu bisa menemukannya di banyak biome: Smogstem Forest, Dense Forest, dan bahkan di Indigo Mushroom Bog!"]
	quest.6D54B45CDA70FEAB.quest_desc: ["&bEnergy Card&f dapat dipasang pada perangkat portabel seperti Wireless Terminal untuk meningkatkan kapasitas buffer energinya."]
	quest.6D54B45CDA70FEAB.title: "Energy Card"
	quest.6D6E07564D8FDD8D.quest_desc: ["&aExtreme Reactors&r menawarkan Reaktor multi-blok yang ukurannya, efisiensinya, dan lainnya dapat dikustomisasi sepenuhnya.\\n\\nUntuk belajar cara memulai Extreme Reactors, cek bab quest untuk mod tersebut!"]
	quest.6D6E07564D8FDD8D.quest_subtitle: "Reaktor yang Bisa Dikustomisasi!"
	quest.6D6E07564D8FDD8D.title: "&9Extreme Reactors: &aReactors"
	quest.6D738730B371B152.quest_desc: ["&l&7Mining Dimension&r adalah dunia Superflat dengan absolutly nothing on the surface. \\n\\nDi bawah permukaannya terdapat hampir semua jenis bijih (Ore). \\n\\n&7&lMining Dimension&r tidak memiliki gua, tidak ada mob yang muncul, dan tidak ada yang menghalangi jalanmu. Isinya hanya berbagai jenis Stone dan Ore! \\n\\nKemunculan bijih berbeda-beda tergantung tingkat Y dan lapisannya di &7&lMining Dimension&r.\\n\\nAku sarankan pasanglah sebuah Quarry."]
	quest.6D738730B371B152.title: "&l&7Mining Dimension"
	quest.6D75CF34957ECCD9.quest_desc: ["Energy Battery memungkinkan menyimpan FE. Untuk mentransfernya, butuh &6Energy Interface&r."]
	quest.6D75CF34957ECCD9.quest_subtitle: "Menyimpan Energy"
	quest.6D7D0A5313284B53.quest_desc: ["Hei, Sepatu bagus! &a&lMekaSuit Boots&r adalah upgrade dari &5Unobtainium Boots&r. \\n\\nGak cuma &5Unobtainium Boots&r, lo juga butuh &dAntimatter Pellet&r, &aPolonium Pellet&r, sama &dUltimate Induction Cell&r! \\n\\nApa lo peduli sama stat Sepatu? Siapa yang mukul Kaki lo! Oh iya Fall Damage lupa. \\n\\nKalo gak di-charge bakal melindungi sama kayak &cNetherite Boots&r... tapi kalo di-Charge bakal pake &aEnergi&r buat lindungin lo. \\n\\n&7&lModification Station&r adalah &5Mesin&r yang bisa kita pake buat tambahin &7Module Unit&r buat upgrade &a&lMekaSuit Part&r, termasuk &a&lBoots&r. Upgrade ini mirip banyak Enchantment!"]
	quest.6D7D0A5313284B53.title: "&a&lMekaSuit Boots"
	quest.6D81DF90E9C2C049.quest_desc: ["Elite Destructor memiliki 18 slot filter dan bekerja 2x lebih cepat."]
	quest.6D81DF90E9C2C049.title: "Elite Destructor"
	quest.6D88C19F47D0D469.title: "Tingkat: &7Tiny"
	quest.6D95CB7906C0DC84.quest_subtitle: "Beech + Cacao"
	quest.6D9CFCD81A23BB3B.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Membuat pemain kebal terhadap lava."
	]
	quest.6DAA82B5F94AF9F8.quest_desc: ["&9Jar of Light&r memanggil sumber cahaya melayang yang mengikutimu. \\n\\n&6Jar of Voiding&r menghancurkan item yang kamu ambil dan mengubahnya menjadi mana. Ini bisa difilter. \\n\\nUntuk menambah atau menghapus item yang akan dihancurkan, gunakan toples tersebut sambil memegang item di tangan kiri (off hand), atau gunakan item pada Scribe's Table yang di atasnya sudah diletakkan toples tersebut. \\n\\nToples ini harus ada di hotbar agar berfungsi."]
	quest.6DAA82B5F94AF9F8.title: "Toples Ajaib"
	quest.6DAECA44E28DA9BA.quest_subtitle: "Beech + Birch"
	quest.6DB06E3984D0CF97.quest_desc: ["Elite Constructor memiliki 18 slot filter dan bekerja 2x lebih cepat."]
	quest.6DB06E3984D0CF97.title: "Elite Constructor"
	quest.6DB5732177AABB87.quest_desc: [
		"Struktur terbesar dan tersulit dari &lIron's Spells&r. \\n\\nIni adalah struktur bawah tanah dalam mirip Trial Chamber. Kamu juga bisa menggunakan Wayward Compass untuk membantu menemukannya! \\n\\nDi dalamnya banyak Spawner, Trial Spawner, dan tentu saja Loot. \\n\\nRuangan paling penting adalah Throne Room, begitu kamu tiba di sana, Kerangka &4&lDead King&r akan bangkit kembali! (Jika tidak kamu mungkin perlu mengkliknya)."
		"{image:atm:textures/questpics/iron_spells/spells_catacombs.png width:200 height:100 align:center}"
	]
	quest.6DB5732177AABB87.title: "&4Catacombs"
	quest.6DB65926EE6D6C2E.quest_desc: ["&cTrack Kit&r ini digunakan untuk mengubah momentum &7Cart&r kamu. \\n\\n&cTransition Kit&r mengubah kecepatan &5Lokomotif&r yang lewat, butuh daya redstone. \\n&cBooster Kit&r mempercepat &7Cart&r jika ditenagai dan memperlambat jika tidak. \\n&cControl Kit&r memberikan dorongan kecil, jika ditenagai akan mengubah arah dorongannya. \\n&cThrottle Kit&r akan menyetel kecepatan &5Lokomotif&r yang lewat ke kecepatan yang sudah dikonfigurasi. \\n&cLauncher Kit&r secara harfiah akan melempar &7Cart&r kamu!"]
	quest.6DB65926EE6D6C2E.title: "&cTrack Kit&r untuk Pergerakan Kereta"
	quest.6DBD81BA83B1D0A5.quest_desc: ["Bahkan lebih banyak Operation Potential!"]
	quest.6DBD81BA83B1D0A5.title: "Draconic Capacitor"
	quest.6DBF9CAB37B9BBF3.quest_subtitle: "Meningkatkan produktivitas lebah sebanyak 120%"
	quest.6DC1E08D019FD543.quest_desc: [
		"&7Crystal&r kita butuh &lPengolahan&r yang lebih lagi! \\n\\nUlangi langkah sebelumnya buat bikin &6&lThermal Evaporation Plant&r biar dapat &eBrine&r. \\n\\nPakai &9&lElectrolytic Separator&r buat pisahin &eChlorine &fdari &eBrine&r. \\n\\nTerus dapatkan &bOxygen&r dengan masukin &9Air &fke &9&lElectrolytic Separator&r. \\n\\nGabungin &eChlorine &fdan &bHydrogen &fdi &a&lChemical Infuser&r biar dapat &3Hydrogen Chloride&r! \\n\\nDengan &c&lChemical Injector&r kita, kita bisa &cInject &f&7Crystal&f pakai &3Hydrogen Chloride&r buat dapat 2 &7Ore Shard&r dari tiap &7Ore Crystal&r."
		"{image:atm:textures/questpics/mek/mek_tier4_3.png width:250 height:100 align:center}"
	]
	quest.6DC1E08D019FD543.quest_subtitle: "Pengolahan Bijih Tier 4"
	quest.6DC1E08D019FD543.title: "Bikin &3Hydrogen Chloride lebih banyak"
	quest.6DC826659699E638.quest_subtitle: "Tabrakkan Telur Spawn Redstone Bee dengan Telur Spawn Electrum Bee"
	quest.6DC826659699E638.title: "Fluxite Bee"
	quest.6DCDD55786025911.quest_desc: ["Starlight Golem adalah Bos kedua di Eternal Starlight. \\n\\nIa sedang mengisi energi di Golem Forge menunggu pemain datang untuk melawannya!"]
	quest.6DCDD55786025911.title: "Kalahkan Starlight Golem"
	quest.6DF215923418F56F.quest_subtitle: "Berikan Superenchanting Template ke Experience Bee"
	quest.6DF215923418F56F.title: "Super Experience Bee"
	quest.6E04A314CD796254.quest_desc: ["Apa yang dibutuhkan setiap Magic Mod? Apakah gun! Semoga jawabannya gun! \\n\\nNobu adalah gun, yang tentu saja punya 3 Mode tembakan berbeda."]
	quest.6E04A314CD796254.title: "&5&lNobu"
	quest.6E05B62A40D5A891.quest_desc: [
		"&3&lIntegrated Dynamics&r adalah inti dari &f&lLogistik&r! Ini praktis adalah definisi dari &lLogistik&r itu sendiri."
		""
		"Mod ini tentang memindahkan, mengelola, dan menyimpan item. Bahkan kamu mungkin tidak butuh Wrench untuk menggunakannya karena desainnya sangat bagus! Tapi siapkan satu buat jaga-jaga."
		""
		"(Solusi pipa paling tidak bikin lag, mod ini sangat direkomendasikan)."
	]
	quest.6E05B62A40D5A891.title: "&3&lIntegrated Dynamics"
	quest.6E0624750DF8CD18.quest_desc: ["Peralatan ini tidak bisa dibuat langsung lagi; kamu harus selalu meningkatkan &cNetherite&r ke tingkat ini. \\nYa, upgrade ini mempertahankan Enchantment dan memperbaikinya (repair)!"]
	quest.6E0624750DF8CD18.title: "Peralatan &6Allthemodium"
	quest.6E08D4E6BC3FB99F.quest_desc: ["&5Deepling&r adalah ras kuno monster laut yang tinggal dan menjaga &5Sunken City&r. Mereka punya tingkatan: Angler, Brute, Priest, dan Warlock. \\n\\n&5Deepling&r adalah yang paling dasar, hanya punya 13 &4HP&r dan membawa Coral Spear. \\n\\n&5Deepling Angler&r punya 15 &4HP&r dan memegang alat pancing dengan &5Lionfish&r yang menempel. Ikan itu akan menyerangmu dan memberikan racun (Poison). \\n\\n&5Deepling Brute&r punya 60 &4HP&r dan membawa Coral Bardiche untuk menyerudukmu di dalam air. \\n\\n&5Deepling Warlock&f dan &5Priest&r keduanya punya 45 &4HP&r dan memegang Athame. &5Priest&r punya serangan jarak jauh, sedangkan &5Warlock&r tidak!"]
	quest.6E08D4E6BC3FB99F.title: "&5Deepling"
	quest.6E093D16B12E12B3.quest_subtitle: "Chocolate Mining + Digger"
	quest.6E0DF05DEF48D2EB.quest_subtitle: "Almond + Cashew"
	quest.6E0E13806F388D7E.quest_desc: ["Selamat datang di &aArs Nouveau&f! \\n\\nArs Nouveau adalah mod sihir yang memungkinkanmu menciptakan mantra kustom dengan berbagai Glyph yang tersedia di dalam mod ini!"]
	quest.6E0E13806F388D7E.title: "Selamat Datang di &aArs Nouveau&f!"
	quest.6E15447FC3D678E0.quest_desc: ["&bFuzzy Card&f memungkinkan filter item mengabaikan data NBT (seperti damage atau enchant). &bInverter Card&f mengubah whitelist menjadi blacklist."]
	quest.6E15447FC3D678E0.quest_subtitle: "Kartu Filter Tambahan"
	quest.6E15447FC3D678E0.title: "Manajemen Filter"
	quest.6E17595887A051C2.quest_desc: ["&l&2Modded Minecraft&r memperkenalkan profesi Villager baru! \\n\\nForge Hammer: &5Industrialist&r \\n\\nCharger: &bFluix Researcher&r \\n\\nAdvanced Beehive: &6Beekeeper&r \\n\\nCoffee Maker: &9Engineer&r \\n\\nArcane Core: &dShady Wizard&r \\n\\nForagers Table: &aForager&r \\n\\nPowered Rolling Machine: &eCartman&r \\nManual Rolling Machine: &eTrackman&r \\n\\nEngineer's Workbench: &7Gunsmith&r \\nWhite Banner: &7Outfitter&r \\nEngineer's Circuit Workbench: &7Electrician&r \\nEngineer's Crafting Table: &7Machinist&r \\nTurntable: &7Structural Engineer&r \\n\\nCharging Station: &4Pressure Mechanic&r \\n\\nSaw: &8Carpenter&r"]
	quest.6E17595887A051C2.title: "Lebih Banyak Profesi"
	quest.6E38CF6E7360E9CA.quest_desc: ["&9&lWarden&r akan drop beberapa Item tapi &9Heart of the Deep&r paling penting. \\n\\nKita bisa gunakan &9Heart of the Deep&r pada frame dari &8Reinforced Deepslate&r untuk mendapat Portal kita ke &3&lOtherside&r. Tidak boleh ada Block yang menghalangi Portal Frame atau tidak akan berfungsi. \\n\\nDia juga drop &9Warden Carapace&r dan &9Echo Shards&r, keduanya akan berguna untuk Crafting Item lain!"]
	quest.6E38CF6E7360E9CA.title: "&9Heart of the Deep"
	quest.6E3AD764A67829CB.quest_desc: ["Kayak adik yang lebih inferior, &bInfusion Crystal&r, &cMaster Infusion Crystal&r ngelakuin semua yang bisa dilakuin yang sebelumnya juga. \\n\\nYang ini cuma punya Use Infinite dan bisa upgrade 4 Block Essence ke yang berikutnya dalam bentuk Block! \\n\\nMemang butuh &cSupremium&r buat bikin, tapi percaya deh ini worth it!"]
	quest.6E3AD764A67829CB.title: "&cMaster Infusion Crystal"
	quest.6E3D53D1C4569A89.quest_desc: ["Memungkinkanmu memindahkan experience (XP) antara karaktermu dan Tas."]
	quest.6E3D53D1C4569A89.quest_subtitle: "Menyimpan XP"
	quest.6E3D53D1C4569A89.title: "&aExperience Pump Upgrade"
	quest.6E4C3B87FABE9EFA.quest_subtitle: "Tuangkan Molten Bronze ke atas telur lebah Copper/Tin"
	quest.6E4C3B87FABE9EFA.title: "Bronze Bee"
	quest.6E5954C257726F86.quest_desc: ["Menyaring berdasarkan mod bisa sangat membantu.\\n\\nCaranya, masukkan item dari mod tertentu, ia akan memunculkan nama modnya, lalu klik tombol Plus untuk menambahkannya!"]
	quest.6E7C4228CD2B6BB9.quest_desc: ["&4Crowbar&r ini punya beberapa mode berbeda untuk mengubah desain &5Lokomotif&r. Mulai dari default, mode 'none' yang berwarna &7abu-abu&r, mode &6H&r&5a&r&6l&r&5l&r&6o&r&5w&r&6e&r&5e&r&6n&r yang menyeramkan, hingga mode &cC&r&2h&r&cr&r&2i&r&cs&r&2t&r&cm&r&2a&r&cs&r yang meriah!"]
	quest.6E7DF4AF86A036EC.title: "Pengolahan Shale Oil"
	quest.6E819CCD57B15D54.quest_desc: ["Menggunakan smeltery, tuangkan &#4CE688Molten Vibranium&r ke atas sebuah &#F2EB2EAllthemodium Bee Spawn Egg&r."]
	quest.6E819CCD57B15D54.title: "Vibranium Bee"
	quest.6E901EF1CB411088.quest_desc: ["&9Warden Armor&r adalah upgrade langsung dari &cNetherite&r. Gunakan saja &9Warden Upgrade Template&r, &9Reinforced Echo Shard&r, dan sepotong &cNetherite Armor&r untuk membuatnya. \\n\\nSetiap bagian punya 1 Armor Point lebih dan 1 Armor Protection lebih dibanding &cNetherite&r. \\n\\nTapi tidak ada Knockback Resistance lagi. \\n\\nSetidaknya terlihat jauh lebih keren dari &cNetherite&r! &9Helmet&r-nya punya tanduk besar seperti &9&lWarden&r dan &9Chestplate&r-nya punya spot hati."]
	quest.6E901EF1CB411088.title: "Armor &9Warden&r"
	quest.6E9041744C592573.quest_desc: ["Menambahkan kemampuan untuk memompa cairan dari Upgrade Tangki."]
	quest.6E970CF05B96EB20.quest_desc: ["Buat damage Golem kamu harus matiin sumber dayanya! \\n\\nBuat matiin kamu harus Right Click Energy Block kalau mereka jadi biru. \\n\\nKamu biasanya bisa nemuin 2 di pojok ruang boss dan 2 di atasnya!"]
	quest.6E970CF05B96EB20.title: "Mematikan daya"
	quest.6E9782258731E444.quest_subtitle: "White Ipe + Luck"
	quest.6EB53CDCB80D4B66.quest_desc: [
		"&3Pneumatic Door&r berfungsi sebagai pintu otomatis yang bisa diatur agar hanya terbuka untukmu!"
		""
		"{image:pneumaticcraft:textures/patchouli/pneumatic_door.png width:200 height:200 align:right fit:true}"
	]
	quest.6EC289857CDC4969.quest_desc: [
		"Ent adalah Mob damai lain yang spawn di Surface Starlight. Yang ini spawn di hutan! \\n\\nPohon kecil ini bisa drop Stick, Lunar Berry, dan Lunar Leaves kalau mati. \\n\\nKamu bisa pake Lunar Berry buat Breeding mereka!"
		"{image:atm:textures/questpics/eternal/starlight_ent.png width:100 height:100 align:center}"
	]
	quest.6EC289857CDC4969.title: "Ent"
	quest.6ECB27052FCB874E.quest_desc: ["&bHippocampus&r dan &9Ular Laut&r belum dipindahin ke &b&lThe Other&r! \\nMereka masih ditemuin di &9Samudra&r di &2&lOverworld&r!"]
	quest.6ECB27052FCB874E.title: "Kita belum pindah!"
	quest.6ECDD26CCCBC07C3.quest_desc: [
		"Peningkatan langsung dari &cNetherite Armor&r, karena itulah armor ini akan mempertahankan &5Enchantment&r-nya. \\n\\nSet lengkap &6AllTheModium&r memberikan 24 Armor Point, 20 Armor Toughness, dan 50% Knockback Resistance. \\n\\nApa kamu pikir cuma itu yang diberikan? \\n\\n&6Helmet&r: &9Water Breathing&r, Imunitas terhadap efek &0Darkness&r milik &3&lWarden&r, dan tidak ada kerusakan &7Elytra&r. \\n&6Chestplate&r: 50% &dMagic Damage Resistance&r dan &cFire Resistance&r. \\n&6Leggings&r: &9Depth Strider&r dan Imunitas terhadap &0Wither&r. \\n&6Boots&r: Resisten terhadap Fall Damage, membolehkanmu berjalan di atas &bPowdered Snow&r dan &cLava&r."
		"{image:atm:textures/questpics/allthemodium/all_armor_all.png width:100 height:175 align:center}"
	]
	quest.6ECDD26CCCBC07C3.title: "&6Allthemodium Armor"
	quest.6ED2CDD01659FD10.quest_desc: ["Set armor ini memiliki Poin Armor yang sama dengan Besi, tapi lebih unggul dalam hal Toughness dan Knockback Resistance."]
	quest.6ED2CDD01659FD10.quest_subtitle: "15"
	quest.6ED2CDD01659FD10.title: "&7Compressed Iron Armor"
	quest.6ED61438A8A1EAA4.quest_desc: ["Witherite dijatuhkan oleh &4The Harbinger&r, ia akan selalu menjatuhkan 1 blok yang bisa diubah menjadi 9 ingot. \\n\\nWitherite digunakan untuk men-craft 3 jenis Senjata dan &4Mechanical Fusion Anvil&r yang berguna untuk menggabungkan item-item &4&lCataclysm&r!"]
	quest.6ED61438A8A1EAA4.quest_subtitle: "= Witherite"
	quest.6ED61438A8A1EAA4.title: "Wither plus Netherite = ...?"
	quest.6EDAB29FBD3C60A3.quest_desc: ["Biome ini diperkenalkan di Wild Update!\\n\\nHati-hati! Mungkin tidak sengaja memanggil teman baru.\\n\\nP.S. - Dia tidak ramah."]
	quest.6EDAB29FBD3C60A3.title: "&6Kunjungi &dDeep Dark&r!"
	quest.6EE5BE5693E8ACE4.quest_desc: ["Di &dThe End&r, akan menemukan boss final Vanilla Minecraft: &5Ender Dragon&r.\\n\\nDi atas setiap pilar Obsidian, akan menemukan End Crystal yang menyembuhkan Dragon. Pastikan hancurkan itu dulu! Mereka juga memberikan banyak damage saat meledak, jadi pastikan buat jarak!\\n\\nSetelah dikalahkan, &dDragon Egg&r spawn di atas Exit Portal. Ini tidak bisa ditambang seperti block biasa, tapi terpengaruh gravitasi."]
	quest.6EE5BE5693E8ACE4.title: "&5The End"
	quest.6EE68EEFE388CF8A.quest_subtitle: "&f4 &cAttack Damage"
	quest.6EF206A0BD5BAC0A.quest_desc: ["&5Epic&r akhirnya mulai masuk ke sisi yang sangat kuat (overpowered). \\n\\n&5Epic&r mulai muncul setelah &lWorld Tier: &2Frontier&r dan paling umum ditemukan di &lWorld Tier: &4Pinnacle&r. \\n\\n&5Arcane Sand&r dibuat dengan menghancurkan &eItem&r &5Epic&r di &c&lSalvaging Table&r."]
	quest.6EF206A0BD5BAC0A.quest_subtitle: "&5Epic"
	quest.6EF206A0BD5BAC0A.title: "&5Arcane Sand"
	quest.6EFA73A4D01F0052.quest_subtitle: "&f7 &cAttack Damage"
	quest.6EFFF0DC80C1C8A3.quest_desc: ["Menggunakan smeltery, tuangkan &#F2EB2EMolten Allthemodium&r ke atas sebuah &#944A12Ancient Bee Spawn Egg&r."]
	quest.6EFFF0DC80C1C8A3.title: "Allthemodium Bee"
	quest.6F152402756DA35E.quest_desc: [
		"Agar ini bekerja, pasang Item Importer pada Inventaris tempat Item ingin diambil. Selanjutnya, pasang Interface pada Inventaris kedua dan hubungkan keduanya dengan Logic Cable. Kemudian, masukkan Variable Card ke dalam Importer dan ubah sesuai keinginanmu. \\n\\nBisa diatur untuk Mengimpor Item hingga batas Integer Limit (Lebih dari 2 Miliar)."
		"{image:atm:textures/questpics/logistics/id_item.png width:200 height:50 align:center}"
	]
	quest.6F152402756DA35E.title: "&fItem Importing"
	quest.6F183B06683D1213.quest_desc: ["&#EBA844Kanthal Hot Ingot&r dapat didinginkan menggunakan &#6DC0F7Vacuum Freezer&r."]
	quest.6F335B4F3FD660E7.quest_desc: ["Mendapatkan ini nggak seru sama sekali. \\n\\nKamu butuh &aKnightmetal Ingot&r yang didapat dari membakar (smelting) &aArmor Shard Cluster&r. \\n\\nKamu mendapatkan &aArmor Shard Cluster&r dengan menggabungkan 9 &aArmor Shard&r. \\n\\n&aArmor Shard&r dijatuhkan oleh Goblin di &l&9Twilight Forest&r dan (sangat jarang) dari Helmet Crab."]
	quest.6F335B4F3FD660E7.quest_subtitle: "20"
	quest.6F335B4F3FD660E7.title: "&aKnightmetal Armor"
	quest.6F3602F5600A6221.quest_desc: ["Glyph Tingkat 3 membutuhkan 10 level experience untuk dibuat. \\n\\nKamu juga butuh &6Archmage Spell Book&r."]
	quest.6F3974CAAA555FD0.quest_subtitle: "Mengelola RAM ini"
	quest.6F3C82072672FD17.quest_desc: ["Quest ini telah dibuat oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods. \\n\\nKarena semua paket &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, Quest ini tidak diizinkan untuk digunakan dalam paket publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit. \\n\\nQuest ini sengaja disembunyikan, jika melihat ini, sedang dalam mode pengeditan."]
	quest.6F3D0A248B5A9CA2.quest_desc: [
		"&bSpatial Storage Cell&f digunakan untuk menyimpan volume ruang tertentu, tersedia dalam kapasitas 2x2x2, 16x16x16, dan 128x128x128. "
		""
		"Saat dikodekan, cell ini dialokasikan ke &edimensi&f penyimpanan spasial dengan ID unik. Cell ini kemudian bisa digunakan di Spatial IO Port untuk mengambil atau menukar blok dan entitas antara dunia biasa dan dimensi spasial tersebut."
	]
	quest.6F3D0A248B5A9CA2.title: "Spatial Storage Cell"
	quest.6F416275B6F6D8F0.quest_desc: ["Blisterberry muncul di Smog Spires. \\n\\nKarena mereka tumbuh di area yang menjijikkan, beberapa akan tumbuh busuk (Rotten). \\n\\nAku tidak menyarankan untuk memakannya, mungkin saja bisa berguna untuk hal lain!"]
	quest.6F57BE412A7BE84E.quest_desc: ["&9Corrupt Soul&r dipakai untuk 2 hal! \\n\\n1. Resep Crafting dengan &l&dTier 4 &6Forge&r, yang gak perlu khawatir sekarang. \\n\\n2. Tumbuh Edelwood! \\n\\nMenumbuhkan Edelwood bertindak sebagai Sapling untuk Edelwood, ini satu-satunya cara dapet Edelwood sekarang."]
	quest.6F57BE412A7BE84E.title: "&9Corrupt Soul"
	quest.6F5F1C525CF08F96.quest_desc: ["Staff dan... Item seperti Staff, adalah Senjata yang akan memberikan boost Magic saat Dipegang! \\n\\nPlus mereka bergaya!"]
	quest.6F5F1C525CF08F96.title: "Staff, Rod, dan Cane"
	quest.6F62B5510FA881CD.quest_desc: ["&7Osmium&r itu Ore yang muncul di bawah level Y 56. Bentuk Ore-nya mirip kayak &aEmerald&r tapi warnanya &bAbu-abu Kebiruan&7&r! \\n\\nIni bakal berguna buat banyak &5Mesin&r di &5&lMekanism&r! Jadi kamu butuh banyak banget! \\n\\nKamu juga bisa bikin &7Armor &fdan &7Alat&r dari sini! &7Armor &fdan &7Pedang&r-nya punya poin yang sama kayak &cNetherite&r! Sedangkan &7Pickaxe&r-nya setara sama &7Iron Pickaxe&r."]
	quest.6F62B5510FA881CD.quest_subtitle: "Ingot Bahan Crafting Dasar"
	quest.6F62B5510FA881CD.title: "&7Osmium"
	quest.6F65216B13E9FFA9.quest_desc: ["Ambil sebuah blok. Secara harfiah blok apa pun. \\n\\nSetiap pemain harus tahu bahwa blok adalah fondasi dari membangun. Untuk benar-benar membangun sesuatu, kamu butuh blok."]
	quest.6F65216B13E9FFA9.title: "Blok!"
	quest.6F67079A453DAABE.quest_desc: ["&cCharm of Life I&r adalah item sekali pakai yang akan mencegah kematian. Alih-alih mati, jimat ini akan dikonsumsi dan kamu akan diberi regenerasi HP dalam waktu singkat.\\n\\nJimat ini bisa ditemukan di dalam peti-peti loot."]
	quest.6F67079A453DAABE.title: "&cCharm of Life I"
	quest.6F709652A2B88C78.quest_desc: ["Pemancar energi menyediakan tenaga ke balok dalam jangkauan kerjanya, hanya bisa menerima tenaga dari bawah."]
	quest.6F71FD826C29C31A.quest_desc: ["Fitur ini mungkin baru buat kamu yang baru balik main dari versi lama. Dengan menggunakan Turtle Egg pada spawner, mob yang muncul cuma versi bayinya saja. Ini cuma berlaku untuk mob versi bayi asli dari Vanilla, bukan dari mod."]
	quest.6F71FD826C29C31A.title: "Awet Muda"
	quest.6F76DA3BBAE8337B.quest_desc: ["Armor terhebat yang bisa kita dapatkan dari mod &6&lAllthemodium&r, &5Unobtainium&r! \\n\\nKini dengan 100% Knockback Resistance dan statistik yang lebih tinggi di segala aspek! \\n\\nKamu butuh &3Vibranium Armor&r untuk membuatnya."]
	quest.6F76DA3BBAE8337B.quest_subtitle: "40"
	quest.6F76DA3BBAE8337B.title: "&5Unobtainium Armor"
	quest.6F7AC41B703028CC.quest_subtitle: "Tuangkan Molten Signalum ke atas telur lebah Copper/Silver"
	quest.6F7AC41B703028CC.title: "Signalum Bee"
	quest.6F978C4D561F35EC.quest_desc: [
		"Bottler punya dua fungsi: Memasukkan madu ke botol dan melumatkan lebah untuk gen.\\n\\nUntuk dapat gen, pasang piston di atas Bottler dengan jarak 1 blok.\\n\\nTaruh lebah di atas Bottler, lalu aktifkan piston untuk melumatnya jadi gen. Botol hasilnya bisa diolah di Centrifuge.\\n\\nCatatan: Pastikan Bottler berisi botol kosong."
		"{image:atm:textures/questpics/bees/bottler.png width:100 height:150 align:1}"
	]
	quest.6F978C4D561F35EC.quest_subtitle: "Sayang, Aku Melumatkan Lebahnya"
	quest.6FBAE89EE782DABA.quest_desc: ["Saat diletakkan dan dihubungkan dengan &aLinking Tool&r ke Drawer lain, Controller bertindak sebagai \"Pusat\".\\n\\nJika kamu klik kanan dua kali pada blok ini, semua item di inventarismu yang sudah memiliki slot di jaringan Drawer akan ditarik otomatis.\\n\\nDengan shift+klik kanan pada controller menggunakan tangan kosong, kamu bisa membuka tab upgrade. Masukkan upgrade penyimpanan untuk memperluas jangkauan Controller. Jangkauan maksimal adalah 40 blok ke setiap sisi."]
	quest.6FBAE89EE782DABA.quest_subtitle: "Otak dari Jaringan Drawer"
	quest.6FBE5B5D5027B32C.quest_desc: ["Pake &7Topi&r ini biar hewan ternakmu lari sekencang angin! \\n\\nKelihatan keren juga kok."]
	quest.6FBE5B5D5027B32C.quest_subtitle: "Kepala"
	quest.6FBE5B5D5027B32C.title: "&7Cowboy Hat"
	quest.6FBF112811FB707C.quest_subtitle: "Ash + Birch"
	quest.6FC4146E534C51DA.quest_desc: ["Kamu bisa menggabungkan Netherite Upgrade Template, Helm Netherite, dan &cMonstrous Horn&r untuk membuat &cMonstrous Helm&r. \\n\\nStatistiknya sama, tapi saat HP kamu tersisa setengah, ia akan memantalkan (Knockback) segala hal di dekatmu dan meningkatkan statistik pertahanan."]
	quest.6FC4146E534C51DA.title: "&cMonstrous Helm"
	quest.6FC55CF56BE22866.quest_subtitle: "531,441 Dirt"
	quest.6FC7DC1F856A748D.quest_desc: ["Oke, yang ini agak panjang jadi perhatikan baik-baik. Kemampuan pertama memiliki dua mode: &6Sanctity&r (Kesucian) dan &7Unholiness&r (Kegelapan). &6Sanctity&r mengambil sebagian pemulihan HP-mu dan mengubahnya menjadi damage terhadap musuh. &7Unholiness&r melakukan sebaliknya, mengambil pemulihan HP musuh untuk membantumu memberikan damage lebih besar. Mob seperti &dEnder Dragon&r dan &5Wither&r keduanya meregenerasi darah. \\n \\nKemampuan kedua adalah Repentance (Pertobatan); saat aktif, ia akan membakar mob Undead (Zombie, Skeleton, dan sepupu-sepupunya). \\n \\nKemampuan ketiga memberikan durasi kebal (Invincibility) dalam waktu singkat."]
	quest.6FC7DC1F856A748D.quest_subtitle: "Ditemukan di Semua Desa"
	quest.6FC7DC1F856A748D.title: "&6Holy&r &7Locket&r"
	quest.6FD41DF7704466A4.quest_desc: ["Mengalahkan Alpha Yeti akan membuka biome &9Glacier&r (Gletser). Di sana, kamu akan menemukan Penguin kecil yang lucu dan sang &3Snow Queen&r.\\n\\nDi puncak &bAurora Palace&r, &3Snow Queen&r akan memanggil kristal Es untuk melindungi dirinya.\\n\\nIa juga akan menghantamkan &3Es&r ke bawah yang bisa menghancurkan lantai dan memberikan damage masif.\\n\\nKamu hanya akan bisa menyerang bagian atas tubuhnya, karena ia dilindungi oleh &3Es&r.\\n\\nSetelah mengalahkan &3Snow Queen&r, kamu akan membuka akses ke &2Highlands&r."]
	quest.6FD41DF7704466A4.title: "&bLangit Cerah"
	quest.6FD4C60B547F4131.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penambang Bijih"
		"- Pemindai Bijih &4&lDINONAKTIFKAN&r&f"
		"- Pelebur Otomatis"
		"- Palu"
		"- Teleporter Barang Jatuhan"
	]
	quest.6FD65139CD50A8C0.quest_desc: ["Apa itu mungkin?\\n\\nJika ingin mengotomatisasi proses ini, kamu bisa menggunakan &eProductive Bees&r atau &aMystical Agriculture&r. Atau ya... kamu bisa mengotomatisasinya dengan... ledakan."]
	quest.6FD65139CD50A8C0.quest_subtitle: "Capek ngeledukin barang terus?"
	quest.6FE6F50029D690C0.quest_desc: ["&9Trisula Pasang&r persis kayak Trisula, cuma lebih baik dalam segala hal! \\n\\nIni bisa di-Craft, punya Damage lebih banyak, dan tembus Mob! \\n\\nDan masih bisa pake Enchant Trisula normal. \\n\\nApalagi yang kamu mau!"]
	quest.6FE6F50029D690C0.title: "&9Trisula Pasang"
	quest.6FEED25FFAC4101F.quest_desc: ["Menggunakan &aStrigeor's Higher Binding&r, kamu bisa menciptakan Gray Paste. Oleskan ini pada Impure White Chalk untuk menciptakan Gray Chalk."]
	quest.6FEED25FFAC4101F.title: "&8Gray Chalk (Kapur Abu-abu)"
	quest.6FF04DD735346BED.quest_desc: ["Mengubah Latex jadi Dry Rubber."]
	quest.6FF54B5D953E1797.quest_desc: ["Jika kamu tahu istilah '&4Berserk&r' di dunia game, itu akan membantumu memahami fungsi &cRage Glove&r. Jika tidak, dasarnya adalah saat seseorang memiliki HP rendah atau menerima banyak damage, biasanya mereka akan menghasilkan damage lebih besar dan menjadi lebih cepat. Itulah yang terjadi dengan kemampuan pertama; saat menerima damage kamu mengumpulkan poin yang bisa ditukar dengan damage dan kecepatan lebih tinggi! \\n \\nKemampuan kedua melakukan hal itu secara pasif, dan memberimu regenerasi HP berdasarkan jumlah HP yang hilang. \\n \\nKemampuan ketiga adalah aktif; saat digunakan (Alt+Tab), kamu akan menerjang dan menyerang mob apa pun yang kamu lihat. Saat terkena, itu akan membakar mereka, memberikan efek pendarahan (Bleeding), dan poin &4Berserk&r yang terkumpul akan memberikan damage ekstra!"]
	quest.6FF54B5D953E1797.quest_subtitle: "Ditemukan di Ruined Portal, Nether Fortress, dan Bastion"
	quest.6FF54B5D953E1797.title: "&cRage Glove"
	quest.6FFFAE334DFAAAAB.quest_desc: [
		"Seperti yang mungkin sudah kamu sadari, ritual cenderung... sedikit lambat. Tapi sekarang tidak lagi! Menggunakan &cSevira's Permanent Confinement&r, kamu bisa menciptakan &bIesnium Ritual Bowl&r. "
		""
		"Saat menggunakan ini sebagai pengganti Golden Ritual Bowl, ia akan memangkas waktu pelaksanaan ritual menjadi hanya seperempat dari waktu aslinya!"
	]
	quest.6FFFAE334DFAAAAB.quest_subtitle: "Ritual Kecepatan Super!"
	quest.6FFFAE334DFAAAAB.title: "Iesnium Ritual Bowl"
	quest.70099F9B69F9D055.quest_desc: [
		"Mereka yang sial jatuh di bawah &bEs&r ke sekitar Y Level 0 mungkin nemuin Gua yang mengerikan dan dingin. \\n\\nGua penuh &bEs &flicin dan &bEs Tetes&r yang ngarah ke bawah ke mereka. \\n\\nTentu saja &bGua &rmilik &b&lNaga Es&r terkuat. &lStage 4 &rdan &l5 &bNaga Es&r. \\n\\nSetidaknya juga penuh dengan &7Perak&r dan Chest banyak! \\n\\nJuga Mob termasuk &8Troll Es&r..."
		"{image:atm:textures/questpics/iceandfire/iaf_struct_icecave.png width:200 height:100 align:center}"
	]
	quest.70099F9B69F9D055.title: "&bGua Naga Es"
	quest.700F3FF7C23D0C0F.quest_desc: ["&5Ender Cell&r akan menyimpan daya untuk sebuah saluran dalam &7Ender Network&r milikmu. Untuk meningkatkan kapasitas daya jaringan, klik kanan pada Ender Cell untuk membuka antarmuka, lalu tambahkan &aBaterai&r atau &9Energy Cell&r untuk meningkatkan kapasitas totalnya."]
	quest.7026E46FD8B3A81D.quest_desc: ["&9Hydra&r adalah monster berkepala banyak yang terkenal dari Mitologi Yunani.\\n\\nSerangan jarak jauh tidak terlalu efektif, artinya kamu harus maju dan bertarung dari jarak dekat.\\n\\nSetelah dikalahkan, kamu akan bisa menemukan bos berikutnya di &2Dark Forest&r."]
	quest.7026E46FD8B3A81D.quest_subtitle: "Rawa Api"
	quest.7026E46FD8B3A81D.title: "&9Pembantai Hydra"
	quest.703790CCCE440946.quest_desc: ["&3The Other&r, beda dari &b&lThe Other&r. &3The Other&r adalah Bioma, sementara &b&lThe Other&r adalah Dimensi. \\n\\nLiat betapa membantu Warna dan Bold? \\n\\nBioma terbuat dari &3Pohon Kuno&r dan &3Rumput Kuno&r. Juga punya Gunung gede buat bantu bedain mereka. \\n\\nGue pikir Warna Bioma ini paling cocok sama &3Batu Kuno&r!"]
	quest.703790CCCE440946.quest_subtitle: "Bioma"
	quest.703790CCCE440946.title: "&3The Other"
	quest.703BDCDC88DD813C.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Pemotong Rumput"
		"- Penyapu Langit"
		"- Pelebur Otomatis"
		"- Palu"
		"- Teleporter Barang Jatuhan"
		"- Hancur Seketika"
	]
	quest.7040CA41C0A3C2F2.quest_desc: ["&3PCB Blueprint&r SEDANG DISKON SEKARANG seharga 8 Emerald. (Hanya untuk waktu terbatas)."]
	quest.7040CA41C0A3C2F2.quest_subtitle: "Makasih, Amadron!"
	quest.7040CA41C0A3C2F2.title: "&9PCB Blueprint"
	quest.7044EAB5EDF32BBC.quest_desc: ["Saat terpasang di sistem, &9Crafting Monitor&r memungkinkanmu melihat item apa saja yang sedang dalam antrean pembuatan.\\n\\nKamu butuh ini untuk membatalkan proses crafting yang macet atau error."]
	quest.7044EAB5EDF32BBC.title: "&3Memantau Autocrafting"
	quest.7060290E107D92AB.quest_desc: ["Banyak hal akan memerlukan &cEnergi&r, termasuk beberapa &eBarang&r yang tidak bisa ditempatkan, seperti &5&lRailgun&r! Jadi bagaimana mengisinya? \\n\\nStasiun Pengisian adalah orang yang tepat untuk pekerjaan itu! \\n\\nCukup &6Masukkan &cEnergi&r dari Belakang atau Bawah, dan akan siap mengisi &eBarang&r apa pun yang dimasukkan ke dalamnya! \\n\\nIni termasuk &5&lRailgun&r, &cAkumulator&r, dan barang dari Mod lain! Tidak bisa mengisi Blok di dekatnya..."]
	quest.7080F026A37F1832.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.708129CB530BAC67.quest_subtitle: "Wild Cherry + Cacao"
	quest.7081E9BF44EFBCB0.title: "Chaotic Large Shield Capacity Module"
	quest.70902EF96F060672.quest_desc: ["Upgrade ini membuat Drawer mengeluarkan sinyal Redstone ke semua sisi. Kekuatan sinyal menunjukkan seberapa penuh isi Drawer tersebut.\\n\\nUntuk Drawer dengan banyak slot, upgrade ini bisa diatur untuk memantau slot spesifik.\\n\\n0 - artinya kosong.\\n15 - artinya penuh."]
	quest.70A4E2B0491634FA.quest_subtitle: "Sugar Apple + Banana"
	quest.70A82A5D17D558FB.quest_desc: ["Energy Sword cuma bisa di-drop dari Starlight Golem. \\n\\nKerjanya kayak Sword biasa tapi dengan Right Click kamu bisa dash ke mereka sambil ngayunin dia, kayak Genji dari Overwatch! "]
	quest.70AD088336748892.quest_desc: ["Generator batu bara sederhana."]
	quest.70AD5D79881EE1B5.quest_desc: [
		"&bSarang Naga Es&r spawn di atas tanah sebagai sarang buat &lStage 1&r sampe &lStage 3 &bNaga Es&r. \\n\\nMereka terbuat dari &bBlok Beku&r yang pada dasarnya cuma &bEs&r. \\n\\nMereka penuh Tumpukan &7Perak&r dan punya Chest, kebanyakan dengan &7Perak&r di dalamnya."
		"{image:atm:textures/questpics/iceandfire/iaf_struct_iceroost.png width:200 height:100 align:center}"
	]
	quest.70AD5D79881EE1B5.title: "&bSarang Naga Es"
	quest.70B6C9409AE69284.quest_desc: ["Nature's Compass memberikan daftar biome yang bisa kamu cari.\\n\\nPilih biome, lalu klik 'Search'. Kamu akan melihat info di pojok kiri atas, dan kompas akan menunjuk ke arah biome tersebut.\\n\\nExplorer's Compass bekerja dengan cara yang sama tetapi untuk mencari struktur, bukan biome."]
	quest.70B6C9409AE69284.quest_subtitle: "Membantu Mencari Biome/Struktur"
	quest.70B6C9409AE69284.title: "Kompas Pencari"
	quest.70BF85E2D235BAD5.quest_desc: ["Menjatuhkan Batu Bara Apikegelapan ke dalam Bahan Bakar Bara Blaze akan membuat Bahan Bakar Apikegelapan Mentah. Melakukan Penyebaran Lendir dengan lendir Tingkat Tiga atau lebih tinggi akan mengubah Bahan Bakar Apikegelapan Mentah menjadi Bahan Bakar Apikegelapan."]
	quest.70C404E5685E4E91.quest_desc: ["Peletakan balok sederhana."]
	quest.70C7D92844089DEB.quest_desc: ["Kayak Pendant lainnya, ini berpeluang melukai penyerangmu, tapi pakai petir! \\n\\nJuga bikin kamu nggak bakal sakit kalau (un)lucky kena sambar petir."]
	quest.70C7D92844089DEB.quest_subtitle: "Kalung"
	quest.70C7D92844089DEB.title: "&bShock Pendant&r"
	quest.70C878DB6AE413B2.quest_subtitle: "Magmatic + Coal"
	quest.70C878DB6AE413B2.title: "Sulfur Bee"
	quest.70CCE558E03227AB.quest_desc: [
		"&6&lRunic Star Altar&r adalah Multiblock yang dibuat sama &3Drack.ion&r kita sendiri lewat &7&lModern Industrialization&r! \\n\\nIni Struktur 15x8x15 yang dimulai dari &5Runic Star Altar Block&r. Taruh terus pake &eWrench&r (dari &7&lModern Industrialization&r) di itu. Ngelakuin itu bakal kasih highlight yang bisa kamu ikutin buat bangun Multiblock. \\n\\nSetelah kamu bangun (dengan bantuan Page 2 Quest atau &eWrench&r) di setiap sisi &6&lAltar&r kamu bisa ganti &9Polished Darkstone&r di sebelah &6Arcane Polished Darkstone&r dengan Hatch. Ini dibutuhin buat Crafting &6&lStar&r yang sebenernya. \\n\\nPake Item Input Hatch (semua dari &l&7Modern Industrialization&r), ini adalah tempat Resep bakal dimasukin. Item Output Hatch adalah tempat &6&lThe Star&r bakal keluar. Dan Energy Input dibutuhin buat power &6&lAltar&r! \\nNgomongin Energy, &6&lStar Altar&r butuh boost buat dapetin FE/t yang cukup. Buat dapetin itu kita bisa pake stack Upgrade dari &7&lModern Industrialization&r. Ini ditaruh ke &5Altar Block&r dan waktu kita Hold Shift pas liat Item, kita bisa liat berapa boost ke &6&lAltar&r! \\n\\nKamu bisa cek &5Altar Block&r buat mulai Resep dengan &6&lAltar&r atau kalo gak dibangun dengan benar, bakal ngasih tau. \\n\\n(BTW Loot Bag yang dipake di resepnya dari &5&lLunar Monstrosity&r. Juga arah block kayak &9Stair&r atau &6Pillar&r gak penting buat &6Altar&r)."
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap2/atmstar_layer1.png width:125 height:75 align:center}"
		"Layer 1 cuma &9Polished Darkstone&r, &9Polished Darkstone Stair&r, dan &6Arcane Polished Darkstone&r, sama &5Altar Block&r."
		"{image:atm:textures/questpics/chap2/atmstar_layer2.png width:125 height:75 align:center}"
		"Layer 2 lebih banyak &9Polished Darkstone&r, &9Stair&r, dan sekarang &6Gilded Chiseled Polished Darkstone&r."
		"{image:atm:textures/questpics/chap2/atmstar_layer3.png width:125 height:100 align:center}"
		"Layer 3 nambah &bArcane Crystal Obelisk&r, &7Rune Block&r, &6Arcane Chiseled Polished Darkstone&r, dan &9Polished Darkstone Slab&r!"
		"{image:atm:textures/questpics/chap2/atmstar_layer4.png width:125 height:100 align:center}"
		"Layer 4 adalah tempat kita punya &6Darkstone Pedestal&r, &7Magnetized Darkstone Pedestal&r di tengah, dan &6Arcane Polished Darkstone Pillar&r."
		"{image:atm:textures/questpics/chap2/atmstar_layer5.png width:125 height:100 align:center}"
		"Layer 5 lumayan simpel, cuma beberapa &6Pillar&r lagi."
		"{image:atm:textures/questpics/chap2/atmstar_layer6.png width:125 height:100 align:center}"
		"Layer 6 butuh lebih banyak &6Pillar&r plus &7Quantum Injector&r di atas &7Magnetized Darkstone Pedestal&r."
		"{image:atm:textures/questpics/chap2/atmstar_layer7.png width:100 height:100 align:center}"
		"Layer 7 sangat simpel juga, cuma lebih banyak &6Pillar&r!"
		"{image:atm:textures/questpics/chap2/atmstar_layer8.png width:100 height:100 align:center}"
		"Layer terakhir, butuh lebih banyak &6Pillar&r tentu aja, ditambah lebih banyak &7Rune Block&r dan &bArcane Crystal Block&r."
		"{image:atm:textures/questpics/chap2/atmstar_layer9.png width:125 height:100 align:center}"
		"Sekarang kita bisa tambahin Utrem Jar! &5Altar Block&r kayaknya kesel waktu Jar-nya gak penuh..."
		"{image:atm:textures/questpics/chap2/atmstar_layer10.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/chap2/atmstar_layer11.png width:200 height:100 align:center}"
		"Hal terakhir yang harus kita lakuin buat mulai &6&lAltar&r, adalah tambahin Hatch kita. Taruh di luar &6Arcane Polished Darkstone&r kayak yang ditunjukin, kamu butuh beberapa Item Input, Output, dan Energy Input."
	]
	quest.70CCE558E03227AB.quest_subtitle: "Crafting &l&6ATM Star"
	quest.70CCE558E03227AB.title: "&l&6Runic Star Altar"
	quest.70CDA5F1593DB4B2.quest_desc: [
		"&eThe Cursed Pyramid&r muncul di gurun dan sangat sulit untuk dilewatkan. Sebuah piramida masif dengan pilar-pilar raksasa di pintu masuknya. \\n\\nMasuklah ke dalam dan kamu akan menemukan jebakan di mana-mana, &eKoboleton&r, dan mini-bos! \\n\\nTenang saja ada juga Peti, Pot, dan bahkan Suspicious Sand yang kamu butuhkan untuk..."
		"{image:atm:textures/questpics/cataclysm/cataclysm_pyramid.png width:200 height:100 align:center}"
	]
	quest.70CDA5F1593DB4B2.title: "&eCursed Pyramid&r: Rumah sang &e&lAncient Remnant&r"
	quest.70D2C5FAC661E01A.quest_desc: ["&bHeart-Forged Seashelf&r adalah upgrade lain untuk &bInfused Seashelf&r. \\n\\nMemang agak mahal, tapi memberikan banyak &5Arcana&r! \\n\\nIni akan sangat membantu untuk proses &d&lInfusion&r nanti yang membutuhkan banyak sekali &5Arcana&r."]
	quest.70D2C5FAC661E01A.title: "&bHeart-Forged Seashelf"
	quest.70DB76D3E7704E2C.quest_subtitle: "&f12 &cAttack Damage"
	quest.70E4EBA7C9901007.quest_subtitle: "Tingkat: &b4"
	quest.70ED849A2EB44DEE.quest_subtitle: "Tingkat: &b3"
	quest.70F7B018CD61E946.quest_subtitle: "Dark Oak + Jungle"
	quest.70FB4088084018D3.quest_subtitle: "Dibuat di Reprocessor"
	quest.70FB4088084018D3.title: "Ludicrite Bee"
	quest.70FD8856BFCD9AEE.quest_desc: [
		"&cRot Mob&r yang terbesar dan paling berbahaya. \\n\\nMereka punya 80 HP, yang kurasa sudah layak disebut Minibos. \\n\\nSeperti semua &cRot Mobs&r, mereka akan menyerang &2Stoneborn&r serta &7Forgotten&r dan menjatuhkan &cUtheric Shard&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotbeast.png width:100 height:100 align:center}"
	]
	quest.70FD8856BFCD9AEE.title: "&cRotbeast&r"
	quest.71055E7BBB337C4D.quest_desc: [
		"&3&lMaledictus&r bisa dipanggil kembali dari Valhalla atau apa pun sebutan neraka versi Norse, dengan Klik Kanan pada &3Cursed Tombstone&r. \\n\\nIa punya 50.400 &4HP&r dan sayap yang masif. \\n\\nIa akan menyerangmu dengan 2 &3Annihilator&r-nya dan bisa melakukan hantaman tanah yang memicu Shockwave! \\n\\nSayapnya membuatnya lincah dalam bermanuver dan melakukan banyak serangan. Ia bisa menyerudukmu sambil menghancurkan blok di jalurnya atau bahkan menghindar! \\n\\nIa bisa terbang ke udara dan dari sana menembakmu dengan &3Cursed Bow&r atau menukik turun dengan &3Soul Render&r. &3Cursed Bow&r akan menembakkan 4 anak panah padamu, sementara &3Soul Render&r akan menjatuhkan hujan &3Phantom Halberd&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_maledictus.png width:125 height:100 align:center}"
	]
	quest.71055E7BBB337C4D.title: "&3&lMaledictus"
	quest.710C7FEFAA6C0979.quest_desc: ["Versi upgrade dari Wyvern Sword."]
	quest.710C7FEFAA6C0979.title: "Draconic Sword"
	quest.71128E508D810DDF.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Panah Ramuan"
		"- Percikan"
		"- Berkelanjutan"
		"- Panah Pelacak"
		"- Fase"
		"- Panah Yondu"
	]
	quest.711826BBCA832EE2.quest_desc: ["Semua &8Cast&r (Cetakan) itu setara. Maksudnya, semuanya dibuat dengan cara yang sama. \\n\\nDengan menuangkan &8Baja (Steel)&r ke atas sebuah item di dalam &8Casting Table&r! \\n\\nBagaimana cara membuat &8Baja&r? Cukup lelehkan item atau Ingot &8Baja&r apa pun. Atau kamu bisa membuat alloy dari 9 &7Besi&r dengan 10 &0Batu Bara&r. \\n\\nProses alloying akan terjadi saat &c&lFoundry&r &6panas&r dan jumlah logam cair yang tepat sudah ada di dalamnya. Kedua &7Logam Cair&r tersebut akan menyatu menjadi satu jenis logam cair baru!"]
	quest.711826BBCA832EE2.title: "&8Cetakan (Casts)"
	quest.7119F8C352D057BC.quest_desc: ["Sekarang kita masuk ke bagian yang seru! Item Langka (Rare) bahkan mencakup sampai ke Elytra! Ya, aku juga merasa itu lebih dari sekadar 'Rare', tapi bukan aku yang membuat kategorinya."]
	quest.7119F8C352D057BC.title: "Material Langka"
	quest.711DDD55CEC439E5.quest_desc: ["&aEmerald Furnace&r, kira-kira Villager mau trade buat ini ga ya? \\n \\nKerja di 40 Tick atau cuma 2 Detik buat smelt! Kedip mata bisa kelewat. \\n \\nDi-craft dari &bDiamond Furnace&r dan bisa dibuat jadi &dObsidian Furnace&r."]
	quest.711DDD55CEC439E5.title: "&aEmerald Furnace"
	quest.712EB19B26D405DD.quest_subtitle: "Tingkat: &e1"
	quest.713006AB89E43C6D.quest_desc: [
		"Di puncak tertinggi &9Acropolis&r yang masif adalah tempat &9&lScylla&r muncul. Sama seperti &d&lEnder Guardian&r, kamu hanya perlu berada di dekat sini untuk memunculkannya. \\n\\nIa adalah salah satu bos terkecil di mod &4&lCataclysm&r, tingginya hanya sekitar 3 blok. Saat ini ia punya 390 &4HP&r dan 12 Poin Armor. Tenang, ia akan segera diperkuat (Buff)! \\n\\nJangan biarkan ukuran atau statistik awalnya membuatmu meremehkannya, ia punya variasi serangan terbanyak di antara semua bos di sini. \\n\\nIa bisa menggunakan jangkarnya, &9Ceraunus&r, untuk menarikmu dari jauh, atau sekadar mengayunkannya untuk damage besar! \\n\\nIa bisa melemparkan &9Tombak Petir&r dari punggungnya atau dari awan. Bahkan melompat tinggi ke udara lalu turun menghujamkan &9Sambaran Petir&r di area hantamannya. \\n\\nBahkan belum selesai! Ia punya kendali atas &9Air&r yang memungkinkannya mengirim &9Gelombang&r atau memanggil &9Ular Air&r untuk menggigitmu! \\n\\nSaat dikalahkan, ia akan menjatuhkan perlengkapan Bos biasa, serta &9Lacrima&r dan &9Essence of the Storm&r."
		"{image:atm:textures/questpics/cataclysm/cataclysm_scylla.png width:100 height:100 align:center}"
	]
	quest.713006AB89E43C6D.title: "&9&lScylla"
	quest.713548E540B18E07.quest_desc: ["Moonring Bow cuma bisa drop dari Lunar Monstrosity. \\n\\nDia nembak Arrow kayak Bow biasa tapi Ground Spike bakal muncul searah Arrow pergi!"]
	quest.713D3B3954E58C4A.quest_desc: [
		"Tier 3 butuh 26 Draconium Ingot Blocks di sekitarnya, sepenuhnya menutup Core, untuk dibuat."
		"{image:atm:textures/questpics/draconic/draconic_core_3off.png width:100 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_core_3on.png width:100 height:100 align:1}"
	]
	quest.713D3B3954E58C4A.quest_subtitle: "Menyimpan: 1,640,000,000 RF"
	quest.713D3B3954E58C4A.title: "Tier 3"
	quest.713EF442D59501BA.quest_desc: ["Chain of Souls cuma bisa di-craft dari drop Tangled Hatred dan Lunar Monstrosity. \\n\\nIni grappling hook! Tap Right Click buat kirim dan kalau kena sesuatu dia bakal mulai narik kamu. Terus, kamu harus Right Click lagi buat lepas. \\n\\nJuga dibutuhin buat ATM Star!"]
	quest.7143CE930D08F160.quest_desc: ["Area of Effect adalah frasa yang kebanyakan Gamer tahu. Pada dasarnya meng-upgrade area kerja Tool yang dipakainya. Pickaxe dengan 3x3 AOE akan menambang dalam area 3x3. Sword dengan 3x3 AOE akan membunuh semua mob yang dipukul dalam area itu. Semakin baik upgrade semakin besar areanya. Tidak, tidak stackable!"]
	quest.7143CE930D08F160.title: "Basic Area-Of-Effect Module"
	quest.71441DFA05FD73E5.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kabut Pikiran"
		"- Membingungkan"
		"- Penglihatan Malam"
	]
	quest.7154D73516548149.quest_desc: ["&6&lAllthemodium&r adalah mod yang ditambahin khusus sama &6AllTheMods Team&r buat nambah konten setelah Netherite! \\n\\nKamu harus bertualang lewat ini buat dapetin beberapa Item yang dibutuhin buat &6&lATM Star&r. \\n\\nAda Quest page sekarang yang bisa kamu ikutin!"]
	quest.7154D73516548149.title: "&l&6Allthemodium"
	quest.715588642623A8A1.quest_subtitle: "Crystalline + Iron"
	quest.715588642623A8A1.title: "Quartz Enriched Iron Bee"
	quest.71581992E8E4C43E.quest_desc: ["Lempar beberapa &8Wither Skeleton Skull&r dan &dAbjuration Essence&r buat bikin &8Wither &3Glyph&r! \\n\\nKalo gak jalan kamu mungkin butuh lebih banyak &aEXP&r."]
	quest.71581992E8E4C43E.title: "&3Glyph of &8Wither"
	quest.715B86DC82EA636B.quest_desc: [
		"&3Liquid Compressor&r menghasilkan tekanan udara menggunakan cairan tertentu. Kamu bisa memasukkan bahan bakar dengan klik kanan ember ke mesin, memompanya masuk, atau menaruh ember di slot atas pada GUI."
		""
		"{image:pneumaticcraft:textures/gui/gui_liquid_compressor.png width:200 height:200 align:center fit:true}"
	]
	quest.715B86DC82EA636B.title: "Tekanan dari Cairan"
	quest.715F9F7107374299.quest_desc: ["Wyvern (Energy Relay) Crystal. Melakukan sama persis seperti Basic Crystal cuma lebih banyak Energy dan lebih banyak Link."]
	quest.715F9F7107374299.title: "Wyvern Energy Relay Crystal"
	quest.71667FFC8011525C.quest_subtitle: "Magmatic + Leafcutter"
	quest.71667FFC8011525C.title: "Coal Bee"
	quest.716FF64ACF896D50.quest_desc: ["&cGloomslate&r menggantikan &3Sculk Stone&r di &cOvercast Columns&r. \\n\\nBekerja seperti &3Sculk Stone&r, cuma lebih Coklat."]
	quest.716FF64ACF896D50.title: "&cGloomslate"
	quest.71766BD7321FCB13.quest_desc: ["Mantap, &c&lChemical Infuser&r lagi! \\n\\nGabungin &aUranium Oxide&r sama &7Hydrofluoric Acid&r buat bikin &aUranium Hexafluoride&r. \\n\\nSekarang kita bisa proses &aUranium Hexafluoride&r lewat &5&lIsotopic Centrifuge&r buat akhirnya dapet &2Fissile Fuel&r kita yang indah."]
	quest.71766BD7321FCB13.title: "&2Fissile Fuel"
	quest.7177653B736AB10E.quest_desc: ["Kita bisa gabungin &cDeuterium&r sama &aTritium&r di &c&lChemical Infuser&r buat bikin &5D-T Fuel&r. Kita juga bisa langsung &cPort&r kedua &cChemical&r ke &c&lFusion Reactor&r dan gabungin di dalam &c&lReactor&r. \\n\\nKalo kita cuma &cPort &5D-T Fuel&r bakal Inject sesuai rate yang di-&cPort&rin. Tapi kalo kita &cPort&r &cDeuterium&r sama &aTritium&r dan gabungin di dalam &c&lReactor&r kita bisa pilih Inject Rate apapun yang kita mau! \\n\\nKita juga butuh sedikit &5D-T Fuel&r di dalam &eHohlraum&r dan taro di &c&lFusion Reactor&r buat start up awal. \\n\\nGimana cara bikin &eHohlraum&r? Tinggal &9Infuse &f4 &eGold Dust&r dengan 10mb &0Carbon&r di &9&lMetallurgic Infuser&r buat Craft &eHohlraum&r. \\n\\nOh tunggu keluar kosong, masukin ke &5Mesin&r yang punya &5D-T Fuel&r buat isi. Terus, taro di Slot di GUI &c&lFusion Reactor&r, dan siap!"]
	quest.7177653B736AB10E.title: "&5D-T Fuel&r"
	quest.7177E49BF9ECA5CF.quest_desc: [
		"&3Thermal Compressor&r menghasilkan tekanan udara menggunakan panas! Letakkan sesuatu yang panas di satu sisi dan sesuatu yang dingin di sisi lainnya untuk membuat tekanan."
		""
		"{image:pneumaticcraft:textures/patchouli/thermal_compressor.png width:100 height:100 align:left fit:true}"
	]
	quest.7177E49BF9ECA5CF.title: "Tekanan dari Panas"
	quest.71869B1D81D6A7EF.quest_desc: ["&2&lP.R.C.&r (&2&lPressurized Reaction Chamber&r) gabungin beberapa &bCairan &fdan &cChemical&r sama sebuah &eItem&f buat bikin &eItem &fdan &cChemical&r baru! \\n\\n&bCairan&r (biasanya &9Air&r) masuk ke Bar paling kiri. &cChemical&r masuk ke Bar sebelahnya, dan &eItem&r awal di &4Slot Merah&r. \\n\\nHasil &eItem&r bakal muncul di &9Slot Biru&r dan hasil &cChemical&r bakal ada di &9Bar Biru&r. \\n\\n&2&lP.R.C.&r bisa bikin beberapa hal kayak item HDPE, &7Gunpowder&r dan &aSulfur&r, bahkan item &2Nuklir&r!"]
	quest.71869B1D81D6A7EF.title: "&2&lPressurized Reaction Chamber"
	quest.7188DC06A28AE30E.quest_desc: ["Pake &eGolden Hook&r ini biar dapet experience lebih banyak dari musuh yang kamu kalahkan!"]
	quest.7188DC06A28AE30E.quest_subtitle: "Tangan"
	quest.7188DC06A28AE30E.title: "&eGolden Hook&r"
	quest.718A2040D868E09F.title: "&2Komponen Penyimpanan 1048m"
	quest.718DABA6C9E5982A.quest_desc: ["Memberikan efek Night Vision kepada pemain saat dikenakan."]
	quest.718DABA6C9E5982A.quest_subtitle: "Maks: 1"
	quest.7198ED7E97A256A4.quest_desc: ["Tongkat divinasi khusus pertama yang dibuat adalah Abundant Material Rod! \\n\\nSaat kamu men-craft Rod ini bersama &eAlchemical Sulfur&r dari suatu item, Rod tersebut akan selaras (attuned) dengan item tersebut. \\n\\nKamu bisa melihat daftar Material Melimpah (Abundant) di bagian Tag, jumlahnya terlalu banyak untuk kusebutkan satu per satu di sini."]
	quest.7198ED7E97A256A4.title: "Material Melimpah"
	quest.719D5CEB4217B734.quest_desc: [
		"Ini adalah rumah yang berbentuk seperti lebah! \\n\\nRumah Lebah! \\n\\nMemiliki loot sederhana, &6Madu&r, dan terkadang ada lebah yang tinggal di dalamnya!\\n"
		"{image:atm:textures/questpics/bumblezone/bumble_house.png width:200 height:100 align:center}"
	]
	quest.719D5CEB4217B734.title: "Rumah &8L&6e&8b&6a&6h&r"
	quest.71A1FD0772453B51.quest_desc: ["Sebel nggak sih harus Klik Kanan ke semuanya? Dari domba pakai gunting sampai sapi pakai ember? Ini sudah abad ke-21, harusnya ada robot untuk semuanya! Atau setidaknya Router. \\n\\nDengan Activator Module, ia akan bertindak seolah-olah kamu yang meng-Klik Kanan benda-benda. \\n\\nKamu bisa mengatur apa yang akan di-Klik Kanan, apakah menyerang atau menggunakan mob/blok, apakah menggunakan mode Shift, dan seberapa jauh jaraknya."]
	quest.71AA40CB2948A8D7.quest_subtitle: "Blue Yonder + Soul Tree"
	quest.71B1B53A03A16296.quest_desc: ["&bAntarmuka Cairan Portabel&r digunakan dengan &aKontraption&r yang menggunakan &bTangki Cairan&r. \\n\\nUntuk mengakses &bTangki Cairan&r kamu butuh dua &bAntarmuka Cairan Portabel&r — satu terhubung ke &aKontraption&r dan satu terhubung ke &bPipa Cairan&r. \\n\\n&bAntarmuka Cairan Portabel&r butuh celah 1 atau 2 Blok antara titik pertemuan agar bisa bekerja. \\n\\nKalau semua sudah siap, &bAntarmuka Cairan Portabel&r yang terhubung ke &aKontraption&r akan menghentikan &aKontraption&r sementara untuk mengambil atau memasukkan &bCairan&r dari &bAntarmuka Cairan Portabel&r kedua ke &bTangki Cairan&r dalam &aKontraption&r."]
	quest.71B1B53A03A16296.title: "&bAntarmuka Cairan Portabel"
	quest.71B6F013C8A60EB6.quest_desc: ["&2Canopy Diminisher&r dan &2Herbivorous Absorber&r adalah cara-cara simpel dan mudah untuk menghasilkan aura."]
	quest.71B6F013C8A60EB6.quest_subtitle: "Lebih Banyak Aura!"
	quest.71B6F013C8A60EB6.title: "Penciptaan Aura"
	quest.71B72958B9F80355.quest_desc: ["Tenang, di tahap ini udah nggak ada lagi main lempar-lempar item! \\n\\nSekarang tinggal crafting! Buat Lens of &3Certain Death&r bareng sebuah &bDiamond Sword&r dan &5Enchanted Book of Sharpness V&r. \\n\\nKamu bisa dapet &5Enchanted Book&r tersebut dari &5&lRunic Enchanter&r! Penjelasan lebih lanjut ada di quest lainnya."]
	quest.71B72958B9F80355.title: "Lens of the &4Killer"
	quest.71C552678A0F649F.quest_desc: ["&7Osmium&r muncul di sekitar lapisan Deepslate dan hanya butuh Besi (Iron) untuk menambangnya, tapi ia memberikan statistik yang lebih baik daripada &cNetherite&r!"]
	quest.71C552678A0F649F.quest_subtitle: "21"
	quest.71C552678A0F649F.title: "&7Osmium Armor"
	quest.71C58666D4BC2508.quest_desc: ["Kerjanya kayak Flint and Steel!"]
	quest.71CF9E59F8F0B4A6.quest_desc: ["Mesin-mesin ini lebih baik lagi dibanding &c&lAdvanced&r! \\n\\nPakai &eItem&r dari &b&lElite Tier&r buat bikin mesin-mesin ini!"]
	quest.71CF9E59F8F0B4A6.title: "Mesin yang jauh lebih baik!"
	quest.71D133BA3EC6F4FD.quest_desc: ["Extractor akan \"menumbuhkan\" blok atau item di bawahnya dan memindahkannya ke inventaris di atasnya.\\n\\nIni bisa digunakan untuk generator Cobblestone yang mendukung banyak jenis batu, generator Amethyst, atau bahkan generator Telur Naga (Dragon Egg), dan banyak lagi!"]
	quest.71D133BA3EC6F4FD.quest_subtitle: "Bertani Batu! (dan Lainnya)"
	quest.71E1454990DEC451.quest_desc: [
		"&bGwib&r adalah versi yang lebih besar dan pemarah dari &bGwibling&r. \\n\\nMereka tidak menjatuhkan apa pun dan tidak bisa dimasukkan ke dalam ember. Mereka cuma bawa penderitaan!"
		"{image:atm:textures/questpics/undergarden/undergarden_gwib.png width:100 height:100 align:center}"
	]
	quest.71E1454990DEC451.title: "&bGwib&r"
	quest.71E4FD61787DE299.quest_desc: [
		"Barang lain yang cuma bisa kamu temukan di Ancient City adalah &6Allthemodium Smithing Template&r.\\n\\nUntuk mendapatkannya, kamu harus menyikat (brush) Suspicious Clay.\\n\\nKamu bisa menemukannya di lantai Ancient City.\\n"
		"{image:atm:textures/questpics/allthemodium/all_clay.png width:200 height:100 align:center}"
	]
	quest.71E4FD61787DE299.title: "&6Allthemodium Smithing Template"
	quest.71F0E9C36AA02B46.quest_desc: ["Ya arena ini terlihat cukup kosong... oh tunggu apa ini! \\n\\n&cCinderous Soul Rune&r. Terlihat seperti lubang kunci hampir, hanya Decrepit Key tidak bekerja padanya. \\n\\nPercayalah, tidak. \\n\\nSebaliknya kita butuh &cCinderous Soulcaller&r! Yang dibuat dari &cCinder Essence&r, &5Netherite Scrap&r, dan &9Echo Shard&r. \\n\\n&5Netherite Scrap&r dari &5Ancient Debris&r, &9Echo Shard&r dari &9Ancient City&r, dan &cCinder Essence&r adalah Drop dari &5Ancient Knight&r!"]
	quest.71F0E9C36AA02B46.title: "&cCinderous Soulcaller"
	quest.71FDF8CD953E46FC.quest_desc: ["HAHAHA apa aku mengagetkanmu dengan item Creative di quest tadi?\\n\\nTenang, kamu tidak butuh item itu untuk menyelesaikan bab ini, aku cuma ingin menggodamu.\\n\\nAku boleh kan bersenang-senang sedikit..."]
	quest.7208CB011F6E2ACF.quest_desc: ["Bisa ditemukan di struktur di &l&6Bumblezone&r atau ditukar dengan &5Bee Queen&r! \\n\\nSepatu Carpenter Bee ini benar-benar luar biasa, kamu bisa berlari di dinding atau lompat lebih jauh dari papan kayu, daun, dan blok madu. \\n\\nJuga sambil menahan Shift, sepatu ini akan menambang blok di bawahmu."]
	quest.7208CB011F6E2ACF.title: "Sepatu Lebah Kayu"
	quest.722978AC0C1B2649.quest_desc: ["Item mudah untuk mengotomatisasi &9air&r tak terbatas. \\n\\nButuh lebih banyak &9air&r? Buat lagi yang banyak!"]
	quest.722978AC0C1B2649.quest_subtitle: "Bisa Digunakan Sebagai Pendingin Reaktor"
	quest.722978AC0C1B2649.title: "&9Air&r Tak Terbatas"
	quest.7231F6177EEF5BF0.quest_desc: [
		"Kumpulan tabung berwarna-warni yang sempurna untuk mengangkut lebah atau kamu sendiri! \\n\\nHembusan angin akan membawamu ke mana saja di dalam Subway ini, bahkan ke ruangan penuh loot!"
		"{image:atm:textures/questpics/bumblezone/bumble_subway.png width:200 height:100 align:center}"
	]
	quest.7231F6177EEF5BF0.title: "Subway"
	quest.723E0CD3C8DD36B1.quest_desc: ["Elite Disk Interface memiliki 18 slot filter dan bekerja 2x lebih cepat."]
	quest.723E0CD3C8DD36B1.title: "Elite Disk Interface"
	quest.723F67A9C6993018.quest_desc: ["&bUltra Disk Interface&r memiliki 36 slot filter, bekerja 5x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.723F67A9C6993018.title: "&bUltra Disk Interface"
	quest.7242F591DA474B37.quest_desc: ["&bCairan&r dan &bLiquida&r bukan yang paling penting di setiap aspek &6&lCreate&r, tapi mau tidak mau kamu akan menemukannnya! \\n\\nKamu perlu mempelajari jalur yang agak rumit yaitu &bLogistik Cairan&r untuk menggunakannya dan memindahkannya. \\n\\nDan untuk memulai, kamu butuh &cTembaga&r!"]
	quest.7242F591DA474B37.title: "&b&lLogistik Cairan"
	quest.72489FB9D9A5A24B.quest_desc: ["Bisa ditemukan di struktur di &l&6Bumblezone&r atau ditukar dengan &5Bee Queen&r! \\n\\nSepatu Carpenter Bee ini benar-benar luar biasa, kamu bisa berlari di dinding atau lompat lebih jauh dari papan kayu, daun, dan blok madu. \\n\\nJuga sambil menahan Shift, sepatu ini akan menambang blok di bawahmu."]
	quest.72537968598AB884.quest_desc: ["&6Kacamata Insinyur&r sempurna untuk kamu yang suka tahu segalanya. \\n\\nKetika dipakai, akan menampilkan hampir semua informasi yang dimiliki Blok atau &6Mesin&r! \\n\\nStressometer akan menampilkan berapa Stres yang diberikan dan berapa yang bisa ditampung. Speedometer akan menampilkan berapa Kecepatan dalam sistem kamu. \\n\\n&dBoiler Uap&r akan menampilkan ukurannya, berapa banyak &9Air&r, dan berapa besar Panas yang dimiliki. \\n\\n&6Mesin&r lainnya, seperti &6Penyebar&r atau &6Pres Mekanik&r, akan menampilkan berapa Satuan Stres yang sedang digunakan."]
	quest.72537968598AB884.title: "&6Kacamata Insinyur"
	quest.72569275EDE9FA23.quest_desc: ["Kawinkan 6 Honey Slime menggunakan Gula."]
	quest.726A627BD7654E0C.quest_desc: ["Tidak banyak perubahan dari &cNetherite&r ke &9Warden&r untuk Tools ini. \\n\\nPickaxe-nya Tier sama dan Kecepatan sama. Shovel masih bisa membuat Pathways dan lagi-lagi Kecepatan sama. Hoe masih bisa membuat Farmland dan juga Kecepatan sama. \\n\\nSatu-satunya perubahan nyata adalah Attack Damage lebih tinggi untuk semuanya. \\n\\nLucunya itu berarti &9Warden Hoes&r punya Damage lebih tinggi dari semua Hoe &2&lVanilla&r!"]
	quest.726A627BD7654E0C.title: "Tools &9Warden&r"
	quest.7270A37E31A70C91.quest_desc: ["&6&lHoly&r adalah untuk semua pemain Medic/Support. Ini sebagian besar dimaksudkan untuk menyembuhkan dan membantu. \\n\\n&6&lHoly&r menggunakan &6Divine Pearl&r sebagai Material Fokusnya yang di-craft. Kamu bisa membuat Rune dengan itu atau membunuh &6&lPriest&r untuk mendapatkan &6Holy Rune&r. \\n\\n&6Holy Scroll&r berwarna &fPutih&r dengan teks &6Emas&r."]
	quest.7270A37E31A70C91.title: "&6&lHoly"
	quest.7270FA5C48AF7280.quest_desc: ["&3Cursium Armor&r adalah upgrade untuk Netherite. Gabungkan perlengkapan Netherite dengan &3Cursium Ingot&r dan &3Cursium Upgrade Template&r. Kamu bisa men-craft-nya sendiri! \\n\\n&3Cursium Helmet&r bisa digunakan dengan tombol C untuk melihat mob menembus blok! Mirip dengan Spectral Eye. \\n\\n&3Cursium Chestplate&r berfungsi sebagai Totem of Undying bawaan. Saat kamu mati, kamu akan diselamatkan. Punya Cooldown 6 menit. \\n\\n&3Cursium Leggings&r bekerja dengan peluang (probability)... belum yakin bagaimana cara kerjanya di &2&lMinecraft&r! \\n\\n&3Cursium Boots&r memungkinkanmu melompat mundur dengan tombol V. Mereka juga mengurangi damage jatuh dalam jumlah besar (tapi tidak sepenuhnya!)."]
	quest.7270FA5C48AF7280.title: "&3Cursed Armor"
	quest.72717D1135486D7F.quest_desc: ["Ayo kumpulin seed."]
	quest.72717D1135486D7F.quest_subtitle: "Tangan Blok 1, Rumput Blok 0"
	quest.72717D1135486D7F.title: "Pukul Rumput"
	quest.7276892E129A739B.quest_desc: ["Kamu pikir cuma ini yang dipunya &5&lMekanism&r? Kamu belum tahu apa-apa! \\n\\nSebelum ke sana, ayo siapin beberapa &5Mesin &fdan &aSulfur&r! \\n\\nPerjalanan kita masih panjang ke depannya."]
	quest.7276892E129A739B.title: "&5&lMekanism: Reactor"
	quest.7277D695C4CB7840.quest_subtitle: "Dibuat dengan Energizer"
	quest.7277D695C4CB7840.title: "Niotic Crystal Bee"
	quest.7279700A93E8630B.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_unobtainium.png width:100 height:150 align:center}"]
	quest.7279700A93E8630B.title: "&5Unobtainium&r"
	quest.728189EE56E5CAF7.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.728189EE56E5CAF7.title: "Redstone Alloy Bee"
	quest.7282DCB1547CEB63.quest_desc: ["&#ED9553Perunggu (Bronze)&r akan menjadi bahan bangunan utama di &7&nZaman Uap&r. Membakar debu ini akan memberimu &#ED9553Bronze Ingot&r yang akan kita gunakan lebih lanjut."]
	quest.7282DCB1547CEB63.title: "&#EDD653Bronze"
	quest.728BE1816DA23DC0.quest_desc: ["Ender Dragon adalah Bos yang menjaga The End. \\n\\nSaat kamu memasuki portal End, kamu akan tiba di End Island tempat ia muncul. \\n\\nIa punya 200 HP dan bisa menyerang dengan bola api atau menabrakmu. \\n\\nKamu harus menghancurkan End Crystal di atas pilar karena kristal itu menyembuhkannya, barulah kamu bisa membunuhnya! \\n\\nSetelah kamu berhasil membunuhnya, ia akan menjatuhkan: Arcane Essence, Epic Shaderbag, Dragonskin, Dragon Scale dari dua mod berbeda, dan banyak experience! \\n\\nKemudian Portal akan terbuka sehingga kamu bisa kembali ke Overworld, atau kamu bisa mencari End Gateway untuk menjelajahi pulau-pulau luar. Kamu juga akan menemukan Dragon Egg di atas Portal."]
	quest.728BE1816DA23DC0.title: "Kalahkan Ender Dragon"
	quest.72917C96C322A922.title: "La Bee-da Loca"
	quest.7297391D026EE9A6.quest_desc: ["Mau sesuatu yang seru dan baru buat bikin Energi? Gimana kalau pakai &dPotion&r! Itulah yang dilakukan &dPotion Generator&r, bakal ambil &dPotion&r kamu dan bikin Energi dari itu tergantung kekuatan dan durasinya."]
	quest.7297391D026EE9A6.title: "&dPotion Generator"
	quest.72989212DD45DC10.quest_desc: ["Untuk menemukan telur ini, perlu brush &aSuspicious Sand&r di Warm Ocean Ruins.\\n\\nBisa menempatkan Egg ke dunia dan akan perlahan menetas jadi &dSnifflet&r. Ini butuh sekitar 20 menit untuk menetas normal, tapi bisa diletakkan di block Moss untuk menggandakan kecepatan menetas, hanya butuh 10 menit untuk menetas.\\n\\nSnifflet akhirnya akan tumbuh jadi &dSniffer&r dewasa yang bisa sniff item seperti &2Torchflower Seeds&r atau &2Pitcher Pods&r saat berkeliaran di atas block yang bisa mereka gali.\\n\\nBisa breeding 2 Sniffer dewasa dengan menggunakan Torchflower."]
	quest.72989212DD45DC10.quest_subtitle: "Sepupu Jauh Scruff McGruff"
	quest.72989212DD45DC10.title: "&aSi &5Sniffer"
	quest.729DCB919A92B735.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_bolt.png width:100 height:150 align:center}"]
	quest.729DCB919A92B735.quest_subtitle: "Trial Chambers"
	quest.729DCB919A92B735.title: "Bolt Armor Trim"
	quest.72A287DCAEEFE49F.quest_desc: [
		"Craft 8 Generator 8x yang sama bareng dengan Conduit combine jadi 1 Generator gede! Kerja sama kayak 64 generator biasa tapi cuma butuh space 1 aja."
		""
		"64x Magmatic Generator dibutuhkan buat craft ATM Star."
	]
	quest.72A71E1D6D8996FD.quest_desc: ["Ini kode ya? Aku bukan programmer!? Aku cuma mau buat quest ini! \\n\\nDi sini kamu bisa mengetik Regex ke dalam kotak pencarian dan klik tombol Plus. Kapan pun Regex itu cocok, itemnya akan difilter. (Sangat berguna untuk mencari pola teks tertentu)."]
	quest.72AB70FD8D8FABBF.quest_subtitle: "&cThe Nether&r!"
	quest.72AB70FD8D8FABBF.title: "Di Jalan Raya menuju..."
	quest.72B7C09AFA2245E1.quest_desc: ["&c&lChemical &eOxidizer&r sekarang punya Upgrade! Sangat membantu buat yang otomasi &9&lMetallurgic Infuser&r. \\n\\nLo butuh &aEnergi&r Input sama &eItem&r Input terus &cChemical&r Output. \\n\\nSekarang kita bisa ubah 32 Dust jadi 320mB &cChemical&r atau 32 Enriched &eItem&r jadi 2,560mB &cChemical&r."]
	quest.72B7C09AFA2245E1.title: "&c&lChemical &eOxidizer Multiblock"
	quest.72C09FD89C28B1EC.quest_desc: [
		"&3Oil Refinery&r (Kilang Minyak) yang akan kita buat adalah struktur multiblock 1x1x5 yang terdiri dari 1 &3Refinery Controller&r (paling bawah) dan empat &3Refinery Output&r (di atasnya). Kamu perlu memasukkan Minyak dan panas agar ini bekerja. Alat ini akan menghasilkan Diesel, Kerosene, Bensin, dan LPG. Memasang &3Thermal Lagging&r di sisi-sisinya membantu menjaga suhu tetap panas."
		""
		"{image:atm:textures/questpics/pneumaticcraft/oil_refinery.png width:300 height:150 align:center}"
	]
	quest.72C09FD89C28B1EC.quest_subtitle: "Baru mantap ini"
	quest.72C09FD89C28B1EC.title: "Kilang Minyak (Oil Refinery)"
	quest.72C7698072BF0F1D.quest_desc: ["&dEngkol Tangan&r adalah bentuk paling sederhana sekaligus paling lemah dari pembangkitan &dTenaga Rotasi&r. \\n\\nKetika kamu tahan Klik Kanan, ia akan bergerak &e&oSearah Jarum Jam&r, dan kalau tahan Shift + Klik Kanan, ia akan bergerak &9&oBerlawanan Jarum Jam&r. \\n\\nHanya memberikan sedikit Satuan Stres dan akan berhenti ketika kamu melepasnya."]
	quest.72C7698072BF0F1D.quest_subtitle: "Tenaga Manual!"
	quest.72C7698072BF0F1D.title: "&dEngkol Tangan"
	quest.72CE46D28C9E7452.quest_desc: ["Scope Presisi bisa digunakan pada &5&lRailgun&r dan &d&lRevolver&r. \\n\\nDengan &d&lRevolver&r dan &5&lRailgun&r bisa tekan Klik Tengah untuk menggunakan Scope, lalu bisa Gulir untuk menyesuaikan pembesaran."]
	quest.72D578686C47B154.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_red.png width:100 height:150 align:center}"]
	quest.72D578686C47B154.title: "&5Red Starlight Crystal&r"
	quest.72D6265E35814927.quest_desc: ["Kebanyakan game yang punya sistem darah dan damage pasti punya fitur Invincibility Frames (durasi kebal singkat). Setelah kena damage, kamu bakal punya waktu kebal biar: 1. Nggak langsung mati kena serangan bertubi-tubi, dan 2. Punya waktu buat bales nyerang. \\n\\nDengan &eCross Necklace&r, durasi kebalmu bakal lebih lama. Artinya lebih banyak kesempatan buat bales mukul!"]
	quest.72D6265E35814927.quest_subtitle: "Kalung"
	quest.72D6265E35814927.title: "&eCross Necklace&r"
	quest.72DB967E59EEA729.quest_desc: ["&3&lGlassential&r adalah mod yang sangat penting untuk membangun, bahkan untuk bangunan yang punya fungsi khusus! \\nIni bukan sekadar kaca biasa, mereka punya kemampuan yang bisa dibaca saat kamu mengarahkan kursor ke itemnya! \\n\\nSeperti Ethereal Glass yang bisa kamu lewati tapi Mob tidak bisa. (Aku menggunakan itu untuk Bee Dome milikku di 9sky!)"]
	quest.72DB967E59EEA729.title: "&3&lGlassential&r"
	quest.72DCE154E1714890.quest_desc: [
		"Untuk melihat &6Gergaji Mekanik&r secara mandiri, cek halaman kedua! Yang ini membahas penggunaannya dalam &aKontraption&r. \\n\\nKetika digerakkan dalam &aKontraption&r, &6Gergaji Mekanik&r akan menebang Pohon apapun yang disentuhnya! Ia harus mengenai bagian bawah Pohon dan memutus semua Log di bagian paling bawah Pohon. \\n\\nSetelah memutus Log tersebut, seluruh Pohon akan ditebang menjadi Item. \\n\\nKalau &aKontraption&r punya Inventaris, bagian-bagian Pohon akan dikumpulkan ke dalamnya. Kalau tidak, Pohon akan tetap ada di alam liar... di tanah."
		"{@pagebreak}"
		"&6Gergaji Mekanik&r juga bisa melakukan tugas lain saat tidak digunakan dalam &aKontraption&r. Bisa dipasang dan digunakan dengan &dTenaga Rotasi&r. \\n\\n&6Gergaji&r juga bisa menebang Pohon yang ada di dekatnya. Ya, tetap harus memotong Log paling bawah. \\n\\nTapi juga bisa digunakan sebagai &7Pemotong Batu&r/Pemotong Kayu! Untuk itu harus dipasang menghadap ke atas, seperti biasa. \\n\\nKemudian, kita bisa memberinya Blok dari Tangan (dengan perlindungan yang tepat) atau melalui &eSabuk&r. Log akan Dikupas dan Blok Batu akan Dipotong. \\n\\nKalau Blok memiliki beberapa Resep melalui Pemotong, kamu bisa memfilter mana yang diinginkan dengan menaruh Blok tersebut di Filter &6Gergaji Mekanik&r."
	]
	quest.72DCE154E1714890.title: "&6Gergaji Mekanik"
	quest.72DDA413D73E3235.quest_desc: ["Statistik yang jauh lebih tinggi di segala aspek dengan armor urutan berikutnya dari &6&lAllthemodium&r, yaitu &3Vibranium&r! \\n\\nKamu butuh &6Allthemodium Armor&r untuk membuatnya."]
	quest.72DDA413D73E3235.quest_subtitle: "32"
	quest.72DDA413D73E3235.title: "&3Vibranium Armor"
	quest.72E1C19156633391.quest_desc: ["Bucket dan Tank adalah cara awal yang bagus untuk memindahkan lava."]
	quest.72E1C19156633391.title: "Lava Bucket"
	quest.72EA25D05C46D39A.quest_desc: ["&9Integrated Dynamics&r menyediakan sistem penyimpanan daya yang simpel. Battery dapat digabungkan di meja crafting untuk meningkatkan total kapasitas penyimpanannya!"]
	quest.72EA25D05C46D39A.quest_subtitle: "Baterai Sudah Termasuk"
	quest.72EA25D05C46D39A.title: "&9Integrated Dynamics: &bEnergy Battery"
	quest.72EC845C19645AFC.quest_desc: ["&3Sculk Vines&r adalah versi &3Sculk&r dari &4Weeping Vines&r. \\n\\nMereka bisa tumbuh di &bBlooming Caverns&r dan &9Deeplands&r."]
	quest.72EC845C19645AFC.title: "&3Sculk Vines"
	quest.72F57D77C3FB366D.quest_desc: ["Block of Crystallized Menril bisa di-craft jadi Crystallized Menril Chunks. Chunk ini adalah bahan crafting utama ID."]
	quest.72F57D77C3FB366D.quest_subtitle: "Bahan Crafting Utama"
	quest.72F57D77C3FB366D.title: "Crystallized Menril Chunks"
	quest.72FADEAEE2DA03AF.quest_desc: [
		"Langkah ketiga adalah tempat di mana &eSulfur&r hasil perubahan akan muncul, yaitu Result Pedestal. Hasil reformasi akan keluar di sini."
		"{image:atm:textures/questpics/theurgy/theurgy_reform_3.png width:100 height:100 align:center}"
	]
	quest.72FADEAEE2DA03AF.title: "Langkah 3: Result Pedestal"
	quest.72FB345F3A7E7288.quest_desc: ["&5Baja Naga Petir&r dibuat dengan kombinasi &5Darah Naga Petir&r dan &7Besi&r di &5&lPemalsuan Naga Petir&r. \\n\\nKita bisa bikin Senjata dari ini! Senjata-senjata ini bakal kasih Damage gede, plus bakal Panggil &5Petir&r di setiap Hit. \\n\\nSelain Senjata juga ada Armor. Armor ini kasih Stats yang banyak, dan keren! Plus ngelindungin kita ekstra dari &5Serangan Elemental Naga&r! \\n\\nKenapa cuma dapetin Armor buat kita doang? Gimana &5&lNaga&r kita juga! Ini lebih mahal banyak, tapi bakal kasih Proteksi yang banyak buat &5&lNaga&r kamu apalagi kalo lawan &5&lNaga&r lain."]
	quest.72FB345F3A7E7288.title: "&5Baja Naga Petir"
	quest.72FFD9E471242D68.quest_desc: ["Stainless Steel membutuhkan panas yang lebih tinggi untuk dilelehkan dibanding tungku biasa. Kita harus menggunakan Electric Blast Furnace yang sudah dibuat sebelumnya."]
	quest.730130CCF1CF5119.quest_desc: ["Relic ini dapat ditemukan di dimensi &2Overworld&r!"]
	quest.730130CCF1CF5119.title: "&2Overworld"
	quest.7305EE0F7D73C231.quest_desc: ["Upgrade Kosong adalah dasar dari semua kemampuan. Kemampuan dibagi menjadi dua tipe, pasif dan aktif.\\n\\nKemampuan pasif tidak memerlukan masukan aktif dari pemain untuk bekerja, namun kemampuan aktif hanya bekerja saat dipicu oleh tombol pintas yang pemain atur di menu konfigurasi, juga kemampuan aktif mengonsumsi ketahanan/tenaga saat digunakan. Saat dipasang di armor tingkat lebih tinggi, kemampuan aktif punya cooldown lebih rendah dan kemampuan pasif punya efek lebih besar.\\n\\nMeja pandai besi digunakan untuk memasang upgrade ke alat dan armor JDT. Tahan shift saat mengarahkan kursor ke alat atau armor JDT untuk melihat upgrade yang valid."]
	quest.730AF9210F00018E.quest_desc: ["&bDiamond Minotaur Axe&r dijatuhkan oleh &cMinoshroom&r. Ia menghasilkan damage lebih besar saat penggunanya sedang berlari (sprinting)."]
	quest.730AF9210F00018E.title: "Kapak Minotaur (&bMinotaur Axe&r)"
	quest.730F2D3329C4FF88.quest_desc: ["&nFermentasi&r: \\nProses kimia di mana molekul seperti glukosa dipecah secara anaerob (tanpa oksigen). \\n\\nAlias campuran &9Air&r dan waktu yang mengubah sesuatu! \\n\\nUntuk menggunakan Fermentation Vat, masukkan item dan cairan ke dalamnya lalu Shift+Klik Rikan untuk menutupnya. \\n\\nSetelah beberapa saat, proses fermentasi selesai! Inilah cara kita mengubah &eAlchemical Sulfur&r menjadi &3Alchemical Niter&r yang nantinya bisa diubah lagi menjadi lebih banyak item!"]
	quest.730F2D3329C4FF88.title: "Bak Fermentasi"
	quest.7310BBC4A90EDA9D.quest_desc: ["&ePortable QIO Dashboard&r bikin kita bisa liat &e&lQIO System&r dari mana aja! \\n\\nKlik Kanan dengan &eItem&r buat bikin jadi punya lo! \\n\\nSekarang lo bisa Klik Kanan dan set Network Frequency ke &e&lQIO System&r. \\n\\nBoom semua yang &eQIO Dashboard&r bisa, kita bisa lakuin dengan temen kecil ini!"]
	quest.7310BBC4A90EDA9D.title: "&ePortable QIO Dashboard"
	quest.73110103EF23BFDF.quest_desc: ["Campuran &6Tembaga&r dan &7Seng&r. \\n\\nTidak benar-benar digunakan untuk banyak di &8&lIE&r... Bisa membuat Tanda dengannya..."]
	quest.73110103EF23BFDF.title: "&6Batang Kuningan"
	quest.731A4846BC556AE1.quest_desc: ["Hal terakhir yang dibutuhkan untuk &8&lReplica&r, jelas melibatkan &7Scroll&r lain. \\n\\n&7Scroll of the Mystic Eyes of Death Collection&r. \\n\\nAkan memungkinkan mengumpulkan Soul dari menyaksikan mob mati. \\n\\nSetiap kematian hanya memberikan sedikit Soul jadi butuh melihat banyak kematian. \\n\\nSetelah punya 5 Soul utuh, akan siap mendapat &8&lReplica&r."]
	quest.731A4846BC556AE1.title: "Souls"
	quest.731A70C25C2C7281.quest_desc: ["Item yang didapat dari Tool yang ini akan masuk ke Ender Chest-mu. Yang Minecraft bukan yang modded."]
	quest.731A70C25C2C7281.title: "Ender Collection Module"
	quest.73201E591C2A40CC.quest_desc: ["Karena sekarang udah punya &6Star Shard&r, kamu bisa mulai bikin berbagai bagian untuk menyusun ulang &6&lStar&r kita! \\n\\nKamu butuh total 262 &6Star Shard&r buat bikin 1 &6&lStar&r... semoga sistem peternakan lebahmu lancar ya!"]
	quest.73201E591C2A40CC.title: "&6Star Shards&r"
	quest.732DA855AFF62907.quest_desc: ["Memproses &8Batu Bara (Coal)&r di dalam centrifuge akan menghasilkan &7Carbon Dust&r."]
	quest.73325912C84F64A5.quest_desc: ["Opsi lain adalah menggunakan Chronal Exchange; dapat &4Mahou&r selama 12 jam, lalu habiskan selama 12 jam. \\n\\nKalau membuat Chronal Exchange circle kedua, saat yang pertama mulai menghabiskan, akan menjadi loop."]
	quest.73325912C84F64A5.title: "Chronal Exchange"
	quest.73350AD668200E99.quest_desc: ["Ini adalah Essence Tingkat 2, dibuat dengan nggabungin 4 Inferium dengan Kristal Infus."]
	quest.73350AD668200E99.quest_subtitle: "Tingkat: &a2"
	quest.73350AD668200E99.title: "&2Prudentium"
	quest.7338CA23B27B2AF8.quest_subtitle: "&f12 &cAttack Damage"
	quest.734411D931A8CDBF.quest_desc: ["Ravager adalah Minibos yang hanya muncul di Raid yang lebih sulit. \\n\\nJika kamu tidak tahu apa itu Raid atau tidak mengerti mekanisme terbarunya, jangan khawatir, itulah gunanya Quest! \\n\\nDengan membunuh Kapten Pillager (yang memegang Bendera) kamu bisa mendapatkan Ominous Potion; saat meminumnya kamu akan mendapatkan efek Bad Omen. Kemudian, kamu bisa berjalan di dekat Desa dan memulai Raid. \\n\\nRaid akan memunculkan Pillager, Vindicator, Evoker, Witch, dan Ravager untuk dilawan!"]
	quest.734411D931A8CDBF.title: "Kalahkan Ravager"
	quest.734A72A4C898BDFB.quest_subtitle: "Tuangkan Molten Invar ke atas telur lebah Tin/Iron"
	quest.734A72A4C898BDFB.title: "Invar Bee"
	quest.734F61A03FFA13ED.quest_subtitle: "CreeBee + Iron"
	quest.734F61A03FFA13ED.title: "Radioactive Bee"
	quest.73552A4BA0687962.quest_desc: ["Upgrade ini bisa dipasang di alat atau armor."]
	quest.7361BD20A6B95D14.quest_subtitle: "Tingkat: &63"
	quest.736F4A43EEBDD7B3.quest_desc: [
		"&3Sculk Snappers&r adalah Mob kecil tapi galak! \\n\\nKulihat mereka muncul di &9Deeplands &fdan &cBlooming Caverns&r. \\n\\nMereka punya 6 &4Hearts&r dan akan drop &3Soul Dust&r saat Mati."
		"{image:atm:textures/questpics/deepndark/dnd_snapper.png width:100 height:100 align:center}"
	]
	quest.736F4A43EEBDD7B3.title: "&3Sculk Snapper"
	quest.7377C657CED885AC.quest_desc: ["&2&lMystical Agriculture&r adalah mod tentang pertanian, tapi kamu bertani buat apa?\\n\\nHampir apapun, dari Honey sampe Steel sampe Wither Skeleton.\\n\\nKamu harus farming banyak banget sama mod ini buat bikin &6&lATM Star&r!"]
	quest.7377C657CED885AC.title: "&2&lMystical Agriculture"
	quest.737DC37E4310090C.quest_desc: ["&8Konveyor Rantai&r tidak banyak berguna sendirian. Mereka butuh &8Konveyor Rantai&f lain, &8Rantai&f, dan &dTenaga Rotasi&r! \\n\\n&8Konveyor Rantai&r butuh &8Konveyor Rantai&r lain di dekatnya untuk bisa terhubung dengan &8Rantai&r. \\n\\n&8Rantai&r perlu di-Klik Kanan ke 1 &8Konveyor Rantai&r lalu ke &8Konveyor Rantai&r lain yang ingin dihubungkan. \\n\\nSetelah salah satu diberi &dTenaga Rotasi&r, &8Rantai&r akan bergerak dengan Kecepatan yang sama. Tidak perlu khawatir soal Arah, ada 2 &8Rantai&r! \\n\\nKetika &8Rantai&r sudah bergerak, kamu bisa terhubung ke mereka dengan &6Kunci Inggris&r untuk bergerak bersama &8Rantai&r — tekan Shift atau ganti Item untuk turun dari &8Rantai&r. \\n\\nKamu juga bisa menaruh &ePaket&r di atasnya, tapi tanpa &eItem&r yang dijelaskan di Quest berikutnya, mereka hanya akan terus berputar!"]
	quest.737DC37E4310090C.title: "&8Konveyor Rantai"
	quest.7386A8433698946C.quest_desc: [
		"Pilih sebuah item dan upgrade ini akan mencarinya di sekitar, baik di dalam peti maupun di lantai. Untuk mencarinya di dalam peti, ia butuh Block Tracker Upgrade, dan untuk di lantai butuh Entity Tracker Upgrade.\\n"
		"{image:atm:textures/questpics/pneumaticcraft/item_search_upgrade.png width:200 height:200 align:center}"
	]
	quest.7386A8433698946C.quest_subtitle: "Maks: 1"
	quest.7388D8168AF78B9A.quest_subtitle: "Tingkat: &63"
	quest.7395B41685F4BC1A.quest_desc: ["&3Flux Compressor&r dapat menghasilkan banyak tekanan udara menggunakan listrik. Cukup alirkan FE ke dalamnya dan ia akan mulai beroperasi. Jika kamu punya banyak cadangan FE, ini mungkin cara termudah untuk menghasilkan tekanan udara."]
	quest.7395B41685F4BC1A.quest_subtitle: "Energi = Tekanan"
	quest.7395B41685F4BC1A.title: "Tekanan dari Energi"
	quest.739601B0C43B239B.quest_desc: ["Ya, mereka bisa dijadikan Pewarna Hitam (Black Dye)!"]
	quest.73B73870B29DFAD9.quest_desc: ["Bagian dari kami! Bagian dari kami! \\n\\n&eVillager Hat&r bikin warga desa percaya kalau kamu orang asli sana, jadi mereka nggak bakal narik 'Pajak Orang Luar'. Harga dagangan Villager jadi lebih murah."]
	quest.73B73870B29DFAD9.quest_subtitle: "Kepala"
	quest.73B73870B29DFAD9.title: "&eVillager Hat"
	quest.73B8A70240E6070E.quest_desc: ["Cari Sapi dan Klik Kanan pakai Bucket.\\n\\nSerius, kenapa gak ada Banteng?"]
	quest.73B8A70240E6070E.quest_subtitle: "Kenapa gak ada Banteng di game?"
	quest.73B8A70240E6070E.title: "Perah Sapi - Profit"
	quest.73BE1EB3E69814E9.quest_desc: ["Pertama dan bagian paling gampang dari resep ini adalah &5Evil Stick&r. Cuma butuh &8Dark Gem&r yang kamu Mine, dan &cUndead Plank&r yang kamu dapetin dari &cUndead Tree&r. \\n\\nSelanjutnya, adalah &5Empowered Inverted Potentia&r. Gak gitu susah bikin cukup craft &7Inverted Potentia&r terus simpan di &aEnviromental Accumulator&r dan biarin kena Lightning! \\n\\nBagian terakhir punya garis panjang &aEmpty Promise&r; kamu bakal infuse banyak banget. \\n\\nSemoga kamu punya banyak &4Blood&r! Ngomongin setan kamu juga harus isi &5Mace&r dengan &4Blood&r."]
	quest.73BE1EB3E69814E9.title: "&5Mace of Destruction"
	quest.73C70B15582958A5.quest_desc: [
		"&eDirt Nest&r bisa diletakkan di biome Overworld mana pun untuk memancing lebah."
		""
		"Ia menarik Ashy Mining Bee, Chocolate Mining Bee, dan Leafcutter Bee."
	]
	quest.73C70B15582958A5.quest_subtitle: "Di biome Overworld mana pun"
	quest.73C7F57B90731010.quest_desc: [
		"Struktur air mancur dengan desain indah berisi aliran &6Madu&r dan &bAir Gula&r."
		"{image:atm:textures/questpics/bumblezone/bumble_fountain.png width:200 height:100 align:center}"
	]
	quest.73C7F57B90731010.title: "Air Mancur &6Madu&r"
	quest.73D60868024FF907.quest_desc: ["Fluid MK2! \\n\\nSumber cairan apa pun di sekitar bisa digunakan, tidak harus menempel."]
	quest.73D6B980D35082A0.quest_desc: ["Yang ini butuh waktu lama untuk menjelaskan jadi bersabar. \\n\\nPertama, temukan &aEvoker Fort&r. \\nSelanjutnya, temukan Research Book yang tersembunyi di dalamnya. Lalu, minta Trader yang menjadi sandera di &aBenteng&r untuk menerjemahkannya. (Seperti penerjemah Quest sandera kita!) \\n\\nSetelah diterjemahkan bawa ke &6&lPriest&r di &6Village&r untuk menukarnya dengan &eSpell Book&r! \\n\\nIni memberikan boost untuk &6Holy Spell&r dan jangan khawatir Trader sandera sangat sangat langka, terus cari!"]
	quest.73D6B980D35082A0.title: "&6Villager Bible"
	quest.73E2A53A088AD29A.quest_subtitle: "11 Blok Pink Basah"
	quest.73E6878553BA6908.quest_desc: ["Kamu suka Drawer? &5&lMekanism&r kasih kita juga! Cuma di sini namanya &eBin&r. \\n\\n&eBin&r cuma bisa nampung satu jenis item tapi bisa nampung banyak banget tumpukan (stack) &eItem&r itu! \\n\\nKamu bisa pakai &3Configurator&r ke &eBin&r buat setel supaya dia otomatis kirim (Output) ke inventory di bawahnya. \\n\\nKalau ada &eItem &fdi dalam &eBin&r, kamu bisa Shift Klik Kanan buat ngunci (Lock) item itu. \\n\\n&a&lBasic&r: nampung 64 Stack. \\n\\n&c&lAdvanced&r: nampung 128 Stack. \\n\\n&b&lElite&r: nampung 512 Stack. \\n\\n&d&lUltimate&r: nampung 4,096 Stack."]
	quest.73E6878553BA6908.quest_subtitle: "Drawer"
	quest.73E6878553BA6908.title: "&eBin"
	quest.73EA326304C01C3B.quest_desc: [
		"Taruh Importer pada inventory yang ingin diambil barangnya. Selanjutnya, taruh Interface pada inventory kedua dan hubungkan dengan Logic Cables. Lalu, masukkan Variable Card ke Importer dan ubah sesuai keinginan.\\n\\nBisa diubah untuk import barang pada batas Integer (Lebih dari 2 miliar)."
		"{image:atm:textures/questpics/logistics/id_item.png width:200 height:50 align:center}"
		"{image:atm:textures/questpics/logistics/id_fluid.png width:200 height:50 align:center}"
		"{image:atm:textures/questpics/logistics/id_energy.png width:200 height:50 align:center}"
	]
	quest.73EA326304C01C3B.quest_subtitle: "Importing"
	quest.73FC51144FC2DA52.quest_desc: ["Dengan &7Glove&r ini, kamu bakal nyolong darah/nyawa dari setiap musuh yang kamu pukul!\\n\\nOh iya maaf lupa... bleh bleh blehhh! (suara vampir)."]
	quest.73FC51144FC2DA52.quest_subtitle: "Tangan"
	quest.73FC51144FC2DA52.title: "&7Vampiric Glove&r"
	quest.73FF01D830A669AA.quest_desc: ["&4Augment&r: Blasting ngubah Iron Furnace-mu jadi Iron Blast Furnace! Sekarang cuma bakal smelt Ore tapi dengan kecepatan dua kali lipat! Iya ini nge-stack dengan efek Augment lain dan Tier Furnace yang beda."]
	quest.73FF01D830A669AA.title: "&4Augment&r: Blasting"
	quest.74015945716FD10A.quest_desc: ["&3Omnidirectional Hopper&r dapat mengambil item dari sisi mana pun, plus bisa di-upgrade agar jauh lebih cepat dari Hopper biasa! Bagus digunakan saat Pipa tidak terlalu dibutuhkan."]
	quest.74015945716FD10A.quest_subtitle: "Hopper yang bisa dikonfigurasi"
	quest.7408CCF998D9CD37.quest_desc: ["&eSpell Book&r yang bisa di-Craft... ya tidak mudah di-craft. \\n\\nTersulit untuk didapat adalah Ruined Book, yang bisa kamu temukan di Chest &9Ancient City&r. &4Blood Vial&r bisa didapat dari menaruh Mob (atau bahkan dirimu sendiri) ke Cauldron di atas Campfire atau Alchemical Cauldron. &5Bottle O' Lightning&r datang dari menggunakan Bottle pada Charged Creeper. \\n\\nSetelah kamu melakukan semua itu kamu bisa craft Ancient Codex. 12 &3Spell&r Slot-nya sangat membantu!"]
	quest.7408CCF998D9CD37.title: "Ancient Codex"
	quest.74130EB1E4B8586D.quest_desc: ["Menggunakan &aIhagan's Enthrallment&r, kamu bisa mengorbankan Allay, Kelelawar, Lebah, atau Burung Beo untuk memanggil &6Possessed Bee&r. Setelah mengalahkannya, ia akan menjatuhkan Cursed Honey, bahan utama untuk membuat Orange Chalk!"]
	quest.74130EB1E4B8586D.title: "&6Orange Chalk (Kapur Oranye)"
	quest.7413BB136EF9D6C5.quest_desc: ["Mechanical Drying Basin menggunakan energy untuk dry"]
	quest.74200A48498DD7F8.quest_desc: ["&e&lSolar Generator&r bakal hasilkan &aEnergi&r berdasarkan paparan ke &bLangit&r pas &eSiang Hari&r. \\n\\nIni &e&lGenerator&r otomatis yang simpel banget cara pakainya, cuma bikinnya aja yang agak repot! \\n\\nMereka nggak hasilkan &aEnergi&r sebanyak &b&lWind Generator&r (cuma pas siang) tapi hasilkan lebih banyak pas momen tertentu dan nggak makan banyak tempat! \\n\\nSekarang sudah di-buff dan bisa nampung sekitar 40kFE!"]
	quest.74200A48498DD7F8.quest_subtitle: "Hasilkan sekitar 60FE/t"
	quest.74200A48498DD7F8.title: "&e&lSolar Generator"
	quest.74297A72584F5D7B.quest_subtitle: "Alder + Wild Cherry"
	quest.744842B2AED28344.quest_desc: ["Memungkinkanmu mengakses penyimpanan jaringan secara nirkabel lengkap dengan antarmuka crafting."]
	quest.744842B2AED28344.title: "Wireless Crafting Grid"
	quest.744AC6BD82FC2DEE.quest_subtitle: "&f36 &cAttack Damage"
	quest.744DBE831C120B2F.quest_desc: ["Apakah batu itu bergerak? Tunggu, itu bukan batu, itu adalah seekor &2Mog&r! \\n\\n&2Mog&r bisa dikawinkan menggunakan Depthrock Pebble dan saat mati mungkin menjatuhkan lebih banyak Pebble atau Mogmoss! \\n\\nMogmoss bisa digunakan dalam banyak resep berbeda!"]
	quest.744DBE831C120B2F.title: "&2Mog&r"
	quest.744E620B7DEBB483.quest_desc: ["&#27CFF5Vacuum Freezer&r akan digunakan untuk mendinginkan &#E6AD1EHot Ingot&r atau cairan tertentu demi rasio item yang lebih baik dari yang sudah kamu produksi."]
	quest.744E620B7DEBB483.quest_subtitle: "Adem bener"
	quest.745E616E97838D2E.quest_desc: ["&lTunggu dulu!&r Berhenti membantai hewan-hewan itu, sepertinya PETA udah mau kompromi. Kalau kamu berhenti bunuh hewan yang nggak berdosa, mereka bakal kasih &5Creative &4Blood Drop&r! \\n\\nDengan ini, kamu bisa ngisi wadah apa pun yang butuh &4Blood&r (darah) secara tak terbatas! \\n\\nBuat bikinnya, kamu butuh 4 &bPromise of Tenacity&r, sebuah &6&lATM Star&r, dan 4 item lain yang harus penuh berisi &4Blood&r. "]
	quest.745E616E97838D2E.title: "&5&lCreative &4Blood Drop"
	quest.7464CA1290B3474B.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Kekebalan"
	]
	quest.746DE905D45A396C.quest_desc: [
		"&5&lThe Leviathan&r adalah alasan orang takut pada lautan. \\n\\nIa punya 30.000 &4HP&r, gigi tajam, dan tentakel kuat, serta kebal saat berada di luar &9Air&r. \\n\\nIa punya banyak kekuatan yang akan digunakan melawanmu. Ia bisa memanggil Ranjau bawah air, menembakkan &5Atomic Beam&r mirip Godzilla, bahkan mencaplokmu. \\n\\nYang terburuk adalah pusarannya! Dan yang kumaksud bukan &6&lATM Dev&r-nya! \\n\\nIa bisa menggunakan tentakelnya untuk membuka pusaran air (&5Water Vortex&r) yang akan menyedot entitas di dekatnya sebagai umpan. Ia juga bisa memanggil &5Laser&r dari dasar laut yang menembak ke atas. \\n\\nSetelah HP-nya di bawah setengah, ia akan mengamuk (Enraged)! Saat mengamuk ia akan lebih sering menggunakan laser dan menyerang tanpa henti sampai hanya ada satu makhluk yang tersisa di samudra."
		"{image:atm:textures/questpics/cataclysm/cataclysm_leviathan.png width:100 height:100 align:center}"
	]
	quest.746DE905D45A396C.title: "&5&lThe Leviathan&r"
	quest.747B62A955D0C629.quest_desc: [
		"&4The Ancient Factory&r terletak jauh di bawah tanah &2Overworld&r. \\n\\nKamu akan menemukan banyak item Redstone seperti Tuas, Powered Rail, dan EMP... aku penasaran apakah itu akan berguna nanti? \\n\\nKamu juga akan bertemu mesin Redstone yang mencoba membunuhmu, seperti &4Watcher&f dan &4Prowler&r! \\n\\nMeskipun berbahaya, ada banyak sekali loot dan blok yang bisa kamu ambil dari sini, terutama Redstone."
		"{image:atm:textures/questpics/cataclysm/cataclysm_factory.png width:200 height:100 align:center}"
	]
	quest.747B62A955D0C629.title: "&4Ancient Factory&r: Rumah sang &4&lThe Harbinger&r"
	quest.747BA0DB44A49A4F.quest_subtitle: "Red Delicious Apple + Sand Pear"
	quest.7485BCBE366501DF.quest_desc: [
		"Kalau kita mau &7Ore&r lebih banyak lagi! Kita butuh cara yang lebih baik buat &lProcessing&r Ore kita. Hydrogen nggak bakal cukup, ayo coba &3Hydrogen Chloride&r. \\n\\nJelas buat itu kita butuh &eChlorine&r! \\n\\nLihat &6&lQuest Thermal Evaporation Plant&r buat tahu detail cara bikin Multiblock-nya, tapi intinya kita butuh satu. \\n\\nMasukkan &9Air&f ke &6&lThermal Evaporation Plant&r buat bikin &eBrine&r (agak lama). \\n\\nTerus masukkan &eBrine&r itu ke &9&lElectrolytic Separator&r buat dapat &7Sodium&r dan &eChlorine&r! &7Sodium&r itu berguna buat &2&lFission Reactor&r... tapi nggak buat &lOre Processing&r!"
		"{image:atm:textures/questpics/mek/mek_tier3_1.png width:200 height:100 align:center}"
	]
	quest.7485BCBE366501DF.quest_subtitle: "Pengolahan Bijih Tier 3"
	quest.7485BCBE366501DF.title: "Bikin &eChlorine "
	quest.748A01B5607C475B.quest_desc: ["Digunakan untuk menyimpan Talisman... tidak ada fungsi lain. Mungkin juga bisa buat nahan celana biar nggak melorot tapi aku belum mencobanya."]
	quest.748A01B5607C475B.quest_subtitle: "Ditemukan di Mineshaft atau Stronghold"
	quest.748A01B5607C475B.title: "&6Leather Belt"
	quest.7496B2380A23FDC6.title: "Chaotic Tree Harvester"
	quest.74ACCEB6DC9EF6F7.quest_desc: ["&dVoid &4Assault Shoulder Weapon &d(V.&4A.S.W.)&r sama seperti versi Wither tapi lebih hebat! \\n\\nSekarang ia hanya menembakkan &dVoid &4Howitzer&r yang memberikan damage lebih besar dan memicu &dVoid Rune&r muncul dari tanah di area ledakannya. \\n\\nWalaupun cooldown-nya lama, tapi hasilnya sepadan untuk ditunggu. \\n\\nDibuat dengan menggabungkan &4W.A.S.W.&r dan &dVoid Core&r di dalam &4Mechanical Fusion Anvil&r."]
	quest.74ACCEB6DC9EF6F7.title: "&dV.&4A.S.W. &d(Void &4Assault Shoulder Weapon)"
	quest.74AE214747A3DB1A.quest_desc: ["Meningkatkan kapasitas tekanan udara yang bisa ditampung."]
	quest.74AE214747A3DB1A.quest_subtitle: "Naikkan!"
	quest.74B0308336F5E017.quest_desc: ["&cBlood Chest&r bisa dipake buat perbaiki item pakai &cBlood&r.\\n\\nTapi, item yang diperbaiki mungkin jadi &dTerkutuk&r..."]
	quest.74B0308336F5E017.title: "Memperbaiki Tool dengan &cDarah"
	quest.74B352457BF1541B.quest_desc: ["Kalau kamu kayak aku, atau orang normal lainnya, pasti benci banget sama Powdered Snow. Untungnya &l&3Artifacts&r kasih solusi: Snowshoes! \\n\\nSnowshoes bikin kamu bisa jalan aman di atas Powdered Snow kayak pake Leather Boots. Kamu juga dapet Speed boost tiap jalan di atas Salju apa pun!"]
	quest.74B352457BF1541B.quest_subtitle: "Kaki"
	quest.74B352457BF1541B.title: "&fSnowshoes"
	quest.74B3E4B62FA9565E.quest_subtitle: "Dibuat dengan Offering Table"
	quest.74B3E4B62FA9565E.title: "Bee Of The Sky"
	quest.74C648FC8733310B.quest_desc: [
		"&9Ular Laut&r adalah yang diceritain Pelaut. Monster raksasa di dalam &9Samudra&r lompat keluar dari &9Air&r dan menelan puluhan orang cuma dalam satu gigitan! \\n\\n&9Ular Laut&r ukurannya dari beberapa Blok panjang sampe lebih dari 30! Ukuran mereka juga naikin &4Health&r mereka dari 50 sampe lebih dari 250 &4Hearts&r. \\n\\nPenampilan mereka tetep sama selain Warna dan Ukuran. Semuanya gak punya anggota badan, cuma Kepala ke Badan ke Ekor. \\n\\nMereka punya lumayan banyak Serangan tergantung Jarak kamu dari mereka. Kalo kamu deket ke mereka, mereka bakal Gigit kamu yang bakal kasih Damage lumayan! Kalo kamu jauh mereka bakal tembak &9Aliran Air&r ke kamu yang bakal kasih Damage overtime. Kalo kamu keluar dari &9Air&r tapi dalam Range, mereka mungkin lompat ke udara dan nyelam ke kamu! \\n\\nSerangan itu bakal kasih Damage banyak dan Knockback setiap Mob deket."
		"{image:atm:textures/questpics/iceandfire/iaf_serpent.png width:150 height:100 align:center}"
	]
	quest.74C648FC8733310B.title: "&9Ular Laut"
	quest.74C715F8F24B8BAE.quest_desc: ["Sama tapi dengan opsi filtering."]
	quest.74C715F8F24B8BAE.title: "Filterable Ender Collection Module"
	quest.74CD3FC35F245DF2.quest_subtitle: "Blue Yonder + Flickering Sun"
	quest.74D4E51A6381DB24.title: "Pola Spanduk Mata"
	quest.74FC0DDDB91DB172.quest_desc: ["&bME Interface&f memungkinkan item/cairan yang dimasukkan dari luar disimpan otomatis ke jaringan ME. Sebagai perangkat output, Interface bisa dikonfigurasi untuk selalu menyediakan stok item tertentu dalam inventaris internalnya agar bisa diambil oleh pemain lain atau pipa."]
	quest.74FC0DDDB91DB172.quest_subtitle: "Keluar Masuk Data"
	quest.74FC0DDDB91DB172.title: "Interface"
	quest.7503823ACDDB0491.quest_desc: ["Alat ini bareng &aSuperstitious Hat&r bakal jadi jimat keberuntungan lengkap buatmu!\\n&2Lucky Scarf&r memberikan tambahan satu tingkat Fortune pada Pickaxe-mu."]
	quest.7503823ACDDB0491.quest_subtitle: "Syal (Kalung)"
	quest.7503823ACDDB0491.title: "&2Lucky Scarf&r"
	quest.7509E4093010EA4C.quest_desc: ["&aSeeker Bow&r dijatuhkan oleh &3Snow Queen&r, ia bisa menembakkan anak panah yang akan mengejar targetmu otomatis. Tidak ada lagi tembakan meleset!"]
	quest.7509E4093010EA4C.quest_subtitle: "Tembakan Sering Meleset?"
	quest.7509E4093010EA4C.title: "&aSeeker Bow"
	quest.750B6316267CF574.quest_desc: ["Waktu Hive kamu kosong dan gelap kamu mungkin nemuin pengunjung Lebah kecil, Skeletal Bee. \\n\\nKamu bisa kasih makan pengunjung baru kamu &8Wither Rose&r buat bikin mereka jadi &8Withered Bee&r. "]
	quest.750B6316267CF574.title: "&8Withered Comb Block"
	quest.752DD0BF36B70D88.quest_desc: ["Furnace gak cukup cepat di &2&lMinecraft&r biasa, jadi gimana kamu pikir mereka bakal fair di Modded!?\\n\\nUntungnya &7&lIron Furnaces&r bantu percepat banyak banget! \\n\\nIni juga punya Quest page cuma sekamar sama &c&lGenerator Galore&r."]
	quest.752DD0BF36B70D88.title: "&7&lIron Furnaces"
	quest.753B3EF7CC94A6DD.quest_desc: ["Ini drop unik dari &aPlayer&r, termasuk kalau kamu mati!\\n\\nKamu &obisa&r dapet ini dengan mati berulang kali, atau dengan ikutan PvP."]
	quest.754500BB7FD8C413.quest_subtitle: "Tingkat: &b4"
	quest.754B8F1FBCD983C5.quest_desc: ["&eStock Ticker&r bisa diatur ke &eJaringan&r dengan Klik Kanan &eStock Link&f menggunakan &eStock Ticker&r di tangan. \\n\\nKemudian, letakkan &eStock Ticker&r dan beri &eStock Keeper&r dengan menaruh &cPembakar Blaze&r atau Mob di Kursi di dekatnya. \\n\\nKamu akan tahu mereka adalah &eStock Keeper&r dari Pelindung kepala &aHijau&r khas mereka. Kini kita bisa Klik Kanan &eStock Keeper&r untuk melihat dan memesan &eItem&r dari &eJaringan&r kita. \\n\\nKetika kamu memesan &eItem&r, mereka akan dimasukkan ke &ePaket&f dari &ePackager&f di bawah &eStock Link&r."]
	quest.754B8F1FBCD983C5.title: "&eStock Ticker"
	quest.75560045ED084900.quest_desc: [
		"Kebanyakan benih gampang dibuat, tapi buat bikin &9Benih Mob&r, kamu harus ke Nether buat ngambil &8Soulium&r. "
		""
		"Dengan batu dan ore yang kamu temuin, kamu harus pake ini buat bikin &3Belati Soulium&r dan &3Soul Jar&r. Pakai belati buat bunuh mob, kamu bakal bisa kumpulin &bjiwa&r mereka, yang dipake di Altar Infus buat bikin benih mob yang sesuai. "
		""
		"Alternatifnya, kamu bisa ngisi Soul Jar di dalam &3Soul Extractor&r dengan cara masukin jar dan pake item mob buat ngisi mereka. Contohnya, nambah Rotten Flesh bakal ngasi sebagian Zombie Soul."
	]
	quest.75560045ED084900.title: "Bikin Benih Mob"
	quest.75619C7174C6703C.quest_desc: ["Memproses Uranium Dust di dalam centrifuge akan memberikan beberapa isotop Uranium yang bisa diolah lebih lanjut menjadi batang bahan bakar yang lebih baik."]
	quest.75619C7174C6703C.title: "Centrifuge Uranium Dust"
	quest.756628F4B7F79446.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_aramber.png width:100 height:150 align:center}"]
	quest.756628F4B7F79446.title: "&cAmaramber&r"
	quest.7574A782DCFB87CE.quest_desc: ["Kivi bisa digunakan untuk beberapa hal, terutama dekorasi dan mesin.\\n\\nKamu butuh Kivi untuk Machine Frame dan mesin XyCraft lainnya. Kivi juga bisa digunakan bersama Xychorium Gem di Stonecutter untuk membuat blok dekoratif."]
	quest.7574A782DCFB87CE.title: "&l&7Kivi"
	quest.757B14D08A9A03C4.quest_desc: [" Kayak kebanyakan mesin Modded, Iron Furnace punya Configuration. Config bisa ditemuin dengan klik Kiri Atas. Bakal ada Input, Output, dan aktivasi Redstone. Aktivasi Redstone ngubah kapan Furnace bakal smelt. Tombol atas nentuin apakah auto Input atau Output, yang berarti bakal otomatis pindah ke dan dari Inventory yang terkoneksi. Kotak-kotaknya adalah tiap sisi Furnace dan nentuin apakah Input, Output, keduanya, Input Fuel, atau ga ngapa-ngapain. Ini penting buat Item yang di-Pipe masuk atau keluar. Furnace Settings Linker bakal copy semua setting ini ke Furnace lain!"]
	quest.757B14D08A9A03C4.title: "Configuration"
	quest.7580037DB8ADEB3C.quest_desc: ["Meong meong aku Sapi..."]
	quest.7580037DB8ADEB3C.quest_subtitle: "Tingkat: &a2"
	quest.75ACC8CF5873F92D.quest_desc: [
		"Warna White Luminescent Ancient Wax, bunga putih, dan abu-abu muda menunjukkan ini adalah White Sempiternal Sanctum. \\n\\nSeluruh tempat ini terlihat seperti rasa Vanilla dan Madu, bikin lapar. \\n\\nIkuti ruangan untuk menemukan White Essence. \\n\\nKamu harus melawan 6 entitas Cosmic Crystal. Semuanya punya 60 HP dan hanya menerima 1 damage dari serangan senjata apa pun."
		"{image:atm:textures/questpics/bumblezone/bumble_white1.png width:200 height:100 align:center}"
		"{image:atm:textures/questpics/bumblezone/bumble_white2.png width:200 height:100 align:center}"
	]
	quest.75ACC8CF5873F92D.title: "&fWhite Sempiternal Sanctum&r"
	quest.75AD0CEBC1335915.quest_desc: ["&dReactor Controller&r adalah jantung reactor. Saat reactor terbentuk, kamu bisa klik kanan terminal untuk buka interface reactor.\\n\\nTergantung apakah itu reactor &9Passively Cooled&r atau &eActively Cooled&r, interface-nya akan berubah. Reactor Passively Cooled dipakai untuk produksi power langsung dengan bakar fuel. Reactor Actively Cooled pakai panas yang dibuat untuk vaporize coolant, yang lalu dikirim ke Turbine untuk bikin power.\\n\\nDi interface passive reactor, kamu bisa lihat dan toggle status dan waste ejection. Kamu juga akan lihat temp, berapa banyak FE/t yang diproduksi reactor, dan berapa banyak fuel yang dibakar reactor per tick."]
	quest.75AD0CEBC1335915.quest_subtitle: "Jantung Reactor"
	quest.75B14A09FE39EDDA.quest_desc: ["Sukamu &aKontraption&r bergerak hanya dalam garis lurus? Kalau begitu, &aGerbong Gantry&r cocok untukmu! \\n\\nLetakkan &aPoros Gantry&r di jalur yang kamu inginkan untuk &aKontraption&r bergerak dan beri &dTenaga Rotasi&r. \\n\\nKemudian, letakkan &aGerbong Gantry&r di atas &aGantry&f dan &aPoros&r — ia akan bergerak mengikutinya. \\n\\nKamu bisa men-&aGlue&r Blok dan &6Mesin&r di atas &aGerbong Gantry&r agar ikut bergerak! \\n\\n&aPoros Gantry&r bisa dihentikan dengan memberinya &4Sinyal Redstone&r. Eh, kamu juga perhatikan nggak kalau mereka mirip tiang-tiang yang ada di barbershop?"]
	quest.75B14A09FE39EDDA.quest_subtitle: "Tiang Barbershop"
	quest.75B14A09FE39EDDA.title: "&aGerbong Gantry"
	quest.75CBB5BD8C1DFEA1.quest_desc: ["&8Wadah&r mirip dengan &ePenampang&r, tapi bisa menampung &eItem&r dan &bCairan&r. \\n\\nIni akan sangat berguna untuk menggunakan &6Pengaduk Mekanik&r dalam Pencampuran dan Penyulingan. \\n\\nDan dengan &6Pres Mekanik&r untuk Pembuatan Otomatis!"]
	quest.75CBB5BD8C1DFEA1.title: "&8Wadah"
	quest.75CD4EE6A542D687.quest_subtitle: "Crystalline + Ashy Mining"
	quest.75CD4EE6A542D687.title: "Copper Bee"
	quest.75CE67D3AA75C798.quest_subtitle: "Red Delicious Apple + Granny Smith Apple"
	quest.75CF9EAB75C3907E.quest_desc: ["Pakai kekuatan &9Dark Gem&r, kita bisa bikin &aDark Tank&r.\\n\\nIni bisa nyimpen 16 bucket cairan apapun yang kamu mau, tapi kamu mungkin butuh ini buat semua &cDarah&r yang bakal kamu kumpulin.\\n\\nButuh lebih banyak? Tinggal gabungin di crafting grid dengan Dark Tank lain."]
	quest.75CF9EAB75C3907E.title: "&aMenyimpan &cCairan"
	quest.75D09040185B0E40.quest_subtitle: "Tingkat: &a2"
	quest.75D3F3C1D4A3EAA2.quest_desc: ["Untuk mengalirkan panas yang dihasilkan oleh Vortex Tube, buatlah &3Heat Pipe&r."]
	quest.75D3F3C1D4A3EAA2.quest_subtitle: "Ada panas yang harus dialirkan :)"
	quest.75D3F3C1D4A3EAA2.title: "Mengalirkan Panas"
	quest.75DD345164EE5CD9.quest_desc: [
		"&6High Speed Track&r seperti &6Reinforced Track&r tapi jauh lebih cepat. Kamu butuh &cTrack Kit&r untuk membantu mencapai kecepatan maksimal! Dan hati-hati di tikungan."
		"{image:atm:textures/questpics/railcraft/rail_speed.png width:150 height:100 align:center}"
	]
	quest.75DD345164EE5CD9.title: "&6Jalur Kecepatan Tinggi"
	quest.75E4751F7A802A44.quest_desc: [
		"Asyik banget! Daftar belanjaan isinya &cChemical&r! Kita ini Walter White apa gimana? \\n\\nPertama dan yang paling penting buat bikin &aSulfuric Acid&r itu &eSulfur&r! Tambang sedikit terus &bOxidize&r biar dapat &eSulfur Dioxide&r. \\n\\nKita butuh &bOxygen&r sedikit lagi, jadi ayo ambil lebih banyak pakai &9&lElectrolytic Separator&r yang diisi &9Air&r. \\nTerus, gabungin &bOxygen&r baru tadi sama &eSulfur Dioxide&r di &c&lChemical Infuser&r biar dapat &cSulfur Trioxide&r. \\n\\nTinggalin dulu si &eSulfur&r itu sebentar sampai kita dapat Water Vapor! Buat dapat Water Vapor, masukin &9Air&r lewat &c&lRotary &bCondensator&r. "
		"{image:atm:textures/questpics/mek/mek_tier4_1.png width:200 height:100 align:center}"
	]
	quest.75E4751F7A802A44.quest_subtitle: "Pengolahan Bijih Tier 4"
	quest.75E4751F7A802A44.title: "Bikin &aSulfuric Acid"
	quest.75EE965CBA598FEA.quest_desc: ["Resepnya mungkin keliatan membingungkan tapi percaya ini cukup gampang. Craft &dWireless Terminal&r apapun terus craft bareng buat bikin &dUniversal Wireless Terminal&r. \\n\\nIni juga bakal simpen apapun yang kamu punya di &dTerminal&r kayak Extended Pattern, itu sangat membantu buat pake &b&lAE2&r tapi gak penting buat &6&lATM Star&r!"]
	quest.75EE965CBA598FEA.title: "&dUniversal Wireless Terminal"
	quest.75F0405FFAB9C080.quest_desc: ["Ini akan diperlukan untuk Tier terakhir, Tier Chaotic. Semoga kamu mengikuti cabang quest yang menjelaskan cara dapat Chaos Shard!"]
	quest.75F0405FFAB9C080.title: "Chaotic Core"
	quest.75FE0B514448865B.quest_desc: ["Upgrade dipasang langsung ke Router dan Router bisa menampung 5 buah. Upgrade mempengaruhi semua Module yang ada dan biasanya bisa ditumpuk (stack)!"]
	quest.75FE0B514448865B.title: "&lUpgrade"
	quest.7604D8B3C9FCCFD9.quest_desc: ["Saatnya membuat 'Hard Drive' untuk Refined Storage. Caranya, kita butuh &9Storage Housing&r yang digabungkan dengan &6Storage Part&r untuk menjadi &9Storage Disk&r. Cukup buat ukuran part yang diinginkan, lalu gabungkan.\\n\\n&9Storage Disk&r digunakan untuk menyimpan barangmu secara virtual begitu dimasukkan ke dalam &9Disk Drive&r. Item ini tidak akan hilang (despawn) jika terjatuh di dunia."]
	quest.7604D8B3C9FCCFD9.title: "Storage Disk"
	quest.76062D375E4CC8DD.quest_desc: ["Kita sudah lihat Filter dan kita sudah lihat Round Robin, sekarang kita lihat keduanya! Ini berguna untuk menjaga agar item masuk dalam urutan tertentu, misalnya saat membuat benih Mystical Agriculture!"]
	quest.76064465104B1C28.title: "Draconic Shield Capacity Module"
	quest.76071C22A73A2026.title: "&cLahan Pertanian Tertium"
	quest.760864EE43FB33AC.quest_desc: [
		"&bHippocampus&r pada dasarnya apa yang kita harap Kuda Laut itu kayak. \\n\\nMereka punya Kepala dan Kuku depan kayak Kuda sementara belakang lebih kayak Ikan. Seluruh Badan mereka juga ditutupin &bSisik&r dan Sirip. \\n\\nMereka dateng dalam Merah, Oranye, Kuning, Hijau Muda, Hijau, Biru Muda, dan Biru! \\n\\n&bHippocampus&r punya 20 Hearts dan sepenuhnya Pasif. Mereka gak bakal balas! \\n\\nPas Mati mereka bakal Drop &bSisik Mengkilap&r dan sangat jarang &bSirip Hippocampus&r mereka."
		"{image:atm:textures/questpics/iceandfire/iaf_hippocampus.png width:150 height:100 align:center}"
	]
	quest.760864EE43FB33AC.title: "&bHippocampus"
	quest.7617737FC179EA1A.quest_desc: ["Armor &bFroststeel&r sedikit di bawah Armor Diamond, tapi memberikan Knockback Resistance yang besar. \\n\\nTapi ia juga memberikan debuff kecepatan, sepertinya kita tidak akan bisa bergerak lincah!"]
	quest.7617737FC179EA1A.title: "Armor &bFroststeel&r"
	quest.761D21C6FBD13EE1.quest_subtitle: "Berikan Diamond Bee sebuah Peridot"
	quest.761D21C6FBD13EE1.title: "Peridot Bee"
	quest.762581CAE5F5DDC1.quest_desc: [
		"Mod sihir, gaya sekali! &d&lArs Nouveau&r adalah mod yang akan kita gunakan untuk menggabungkan &5Unobtainium&r dan &6Allthemodium&r! \\n\\nEnchanting Apparatus adalah multiblock yang digunakan untuk banyak resep di sini. Mulailah dengan sebuah Arcane Core, lalu letakkan Enchanting Apparatus di atasnya. Selanjutnya, tempatkan Pedestal di sekitar Enchanting Apparatus pada tingkat Y yang sama. \\n\\nKemudian kamu bisa meletakkan item di atas Pedestal dalam urutan apa pun, pastikan ada Source di dekatnya, lalu letakkan Source Gem di Apparatus untuk memulainya! Setelah itu, kamu akan berhasil membuat Alloy Ingot &5Unobtainium&r-&6Allthemodium&r!\\n"
		"{ \"text\": \"QUESTLINE ARS NOUVEAU\", \"color\": \"#55FF55\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6AEDA2F9BEB57759\" } }"
	]
	quest.762B8309E1A31B99.quest_desc: ["Setiap upgrade menambah +0.5 Armor Defense dan +1 Armor Toughness."]
	quest.762B8309E1A31B99.quest_subtitle: "Maks: 4"
	quest.762C54C261ED5D29.quest_subtitle: "Teak + Mahogany"
	quest.763A19067AEEF6D5.quest_subtitle: "+2 Keberuntungan"
	quest.763AE58CF620695E.quest_desc: ["&9Cetak Biru&r ini, seperti banyak lainnya, bisa Dibuat. \\n\\n&8&lImmersive Engineering&r dilengkapi dengan Pola Banner sendiri! \\n\\nPerlu &9Cetak Biru&r untuk membuatnya."]
	quest.763AE58CF620695E.title: "&9Cetak Biru Pola Banner"
	quest.763EB5C911D7E78C.quest_desc: ["Akhir jalan untuk Crafting Infusion, Tier Chaotic. Semua bisa dibuat setelah kamu di sini. Bukan hanya Tools tapi juga semua yang kamu butuhkan untuk Reactor."]
	quest.763EB5C911D7E78C.title: "Tier Chaotic"
	quest.763FB27929E053BE.quest_desc: ["&9Filter &8Upgrade&r cuma dipakai di &b&lElectric Pump&r. \\n\\n&b&lPump&r-nya bakal kerja kayak biasa, tapi bukannya ambil &9Air&r biasa, dia bakal ambil &9Heavy Water&r. \\n\\n&9Heavy Water&r bakal dibutuhin buat bahan bakar &2&lFission Reactor&r!"]
	quest.763FB27929E053BE.title: "&9Filter &8Upgrade"
	quest.76406EFFF8CBA6B4.quest_desc: ["Diamond adalah salah satu material terbaik untuk crafting tool, tapi juga memungkinkan mengunjungi dimensi baru seperti Twilight Forest!"]
	quest.76406EFFF8CBA6B4.title: "Dapat &bDiamond&r!"
	quest.764609E41957DA69.quest_subtitle: "6,561 Emerald Block"
	quest.7649D648A3688D4A.quest_desc: ["Puller Upgrade memungkinkan Drawer untuk menarik item masuk dari sisi mana pun."]
	quest.76516C997B63905A.quest_subtitle: "Tingkat: &b4"
	quest.76558D23A70AFF78.title: "&bIce&r Upgrade Orb"
	quest.7655E1C6C5E5469F.quest_subtitle: "Jangkauan: &a18&r Blok"
	quest.7655E1C6C5E5469F.title: "&2Prudentium Pemacu Pertumbuhan"
	quest.7658C1C663394E85.quest_desc: ["Ada banyak perintah yang berguna di dalam ATM. Berikut adalah beberapa di antaranya:\\n\\n&e/sethome&r (nama home) | Memungkinkanmu menetapkan titik pulang yang bisa kamu tuju kembali menggunakan /home (nama). Contoh: /sethome kebun - lalu teleportasi dengan /home kebun.\\n\\n&e/spawn&r | Ini akan menteleportasimu ke titik spawn di Overworld.\\n\\n&e/rtp&r | 'Random Teleport' akan menteleportasimu ke lokasi acak di dunia.\\n\\nCatatan: Perintah-perintah ini memiliki waktu tunggu (cooldown) dan batasan. Jika kamu ingin mengubahnya, kamu dapat mengedit file konfigurasi yang dapat ditemukan di sini:\\n\\n - Untuk Singleplayer | &osaves/(nama save)/serverconfig/ftbessentials.snbt&r\\n\\n - Untuk Server | &oworld/serverconfig/ftbessentials.snbt&r"]
	quest.765CD913CC3896B2.quest_desc: ["&lStage 4&r dan &l5 &cNaga Api&r ditemuin tersegel jauh di bawah permukaan aman di dalam &cGua&r mereka. Cuma orang paling bodoh yang mau turun ke sana dan lawan mereka! \\n\\n&cGua Naga Api&r adalah Struktur gede tapi tetep tertutup. Ini berarti &c&lNaga&r-nya gak bisa gampang Terbang kabur... tapi kamu juga gak bisa. \\nKalo kamu mau lawan &c&lNaga&r gede ini kamu butuh Gear, Enchant, dan Potion terbaik. Terutama yang buat cegah &cBakar&r-nya Bunuh kamu! \\nSerangan mereka kasih Damage lebih banyak juga &cSerangan Elemental&r mereka nyebar dan &cBakar&r lebih banyak dari sebelumnya! Jangan lupa mereka punya &4Health&r yang sama kayak &3&lWarden&r dan &7Armor Points&r yang cocok sama &cNetherite&r lengkap! \\n\\nKalo kamu Bunuh &lStage 4&r atau &l5 &cNaga Api Betina&r (dan gak pake Botol ke dia) dia mungkin Drop &cTelur&r. &cTelur Naga&r ini jauh lebih baik dari &2&lVanilla&r &dTelur Naga&r karena..."]
	quest.765CD913CC3896B2.title: "&lStage 4-5 &cNaga Api"
	quest.76660075F254597E.quest_desc: ["&#F5B758Advanced Upgrade&r menambah penggunaan maksimal sebesar &#EDE02F16 EU/t&r per upgrade."]
	quest.766C80E5D7B7A916.quest_subtitle: "Pilih satu!"
	quest.766EEB89C6DF3575.quest_desc: ["Eternal Stella bisa digunakan untuk membuat item tidak bisa hancur (Unbreakable) dengan menggabungkannya di Smithing Table, atau kamu bisa memakainya untuk membuat Alloy Tools! \\n\\nPertama, kamu butuh Tier 3 Forge dengan banyak material di dalamnya. \\n\\nLalu, kamu butuh 3 Xpetrified Orb, yang bisa didapat dengan memberi makan Black Hole berbagai item. \\n\\nDitambah sebuah Stellarite Piece yang harus ditambang! Serta &6Allthemodium Ingot&r yang prosesnya sama."]
	quest.7671AFAA1EFD287F.quest_desc: ["Kamu mau automasi &bAureal&r perlahan untuk &6&lForge&r kamu? Kalau gitu, kamu butuh 2 &bArcane Crystal Block&r, &6Arcane Polished Darkstone&r, dan &cMundabitur Dust&r! \\n\\nTaruh &6Arcane Polished Darkstone&r, lalu di atasnya taruh kedua &bArcane Crystal Block&r. \\n\\nSetelah dapat Struktur 1x3x1 ini, Klik Kanan dengan &cMundabitur Dust&r untuk bikin &bObelisk&r! \\n\\nKamu bisa taruh ini, dimana Pedestal biasanya ada, di &6&lForge Multiblock&r untuk automasi &bAureal&r!"]
	quest.7671AFAA1EFD287F.title: "&bArcane Crystal Obelisk"
	quest.7678B5DD1339833E.quest_desc: ["Solar Panel menghasilkan FE saat mendapatkan akses langsung ke sinar matahari. Namun, kamu bisa menggunakan &7Lens of Ender&r agar ia mengabaikan blok yang menghalangi di atasnya."]
	quest.767E4FC03B6F6534.quest_desc: ["Batang Invar dibuat dengan &7Besi&r dan &7Nikel&r. \\n\\nSeperti banyak Paduan ini, tidak berguna di &8&lIE&r."]
	quest.767E4FC03B6F6534.title: "&7Batang Invar"
	quest.768C07D1B5EB1FEB.quest_desc: ["Bisa ditemukan di dalam Pasir dan Kerikil Mencurigakan (Suspicious Sand/Gravel) di dalam Reruntuhan Laut Dingin (Cold Ocean Ruins)."]
	quest.768C07D1B5EB1FEB.quest_subtitle: "Blok Mencurigakan Reruntuhan Laut Dingin"
	quest.769D5DE66D13B256.quest_desc: ["Quest ini ditulis oleh &6Staf AllTheMods&r, atau &2Kontributor Komunitas&r untuk digunakan dalam Modpack AllTheMods.\\n\\nKarena semua pack &6AllTheMods&r dilisensikan di bawah &eAll Rights Reserved&r, quest ini tidak diperbolehkan untuk digunakan dalam pack publik mana pun yang tidak dirilis oleh &6Tim AllTheMods&r tanpa izin eksplisit.\\n\\nQuest ini sengaja disembunyikan; jika kamu melihat ini, berarti kamu sedang dalam mode pengeditan."]
	quest.76A0592F4C294545.quest_desc: ["Sawmill memotong Batang Kayu (Log) menjadi Serbuk Gergaji (Sawdust) dan menghasilkan lebih banyak Papan (Plank) dibanding crafting biasa. Serbuk gergaji bisa digunakan untuk membuat Kertas.\\n\\n - Fustic Log juga akan memberimu Fustic.\\n - Brazilwood Log dan Logwood Log juga akan memberimu Haematoxylin."]
	quest.76A0592F4C294545.quest_subtitle: "Aku juga kayu"
	quest.76A0592F4C294545.title: "Penggergajian"
	quest.76B1C5AFC5D6B7CF.quest_desc: ["Tongkat Waktu bisa digunakan untuk mempercepat balok, mirip dengan Waktu dalam Botol, hingga x128 kecepatan. Tidak seperti TIAB, ini menggunakan FE dan Cairan Waktu daripada waktu tersimpan sebagai bahan bakar, membuatnya jauh lebih mudah diisi ulang.\\n\\nTapi dilarang untuk pemain palsu. Kita gak mau kamu otomasi INI."]
	quest.76B1C5AFC5D6B7CF.quest_subtitle: "Sepupu Waktu dalam Botol"
	quest.76C63670624C3C56.quest_desc: ["&c&lGenerator Galore&r kasih kita banyak Power Generator yang membantu dan simpel! \\n\\nBeberapa bahkan bisa digabungin satu sama lain buat lebih kuat. \\n\\nAda Quest page buat mereka cuma roommate sama &7&lIron Furnaces&r."]
	quest.76C63670624C3C56.title: "&c&lGenerator Galore"
	quest.76CBFA38D021AC95.quest_desc: ["&dKincir Angin&r sedikit lebih rumit dari &9Kincir Air&r, tapi hadir dengan lebih banyak kustomisasi dan tentunya Kecepatan serta Satuan Stres yang lebih! \\n\\nPertama, kamu butuh inti dari &dKincir Angin&r — &dBantalan Kincir Angin&r. Blok ini akan mengeluarkan &dTenaga Rotasi&r. Ini juga yang kita gunakan untuk menyalakan &dKincir Angin&r! \\n\\nKemudian, kamu butuh Blok untuk membuat bagian &dKincir Angin&r yang sebenarnya. Blok akan otomatis menempel ke &dBantalan&r, tapi ke bagian &dKincir Angin&r lainnya butuh &aGlue&r. Kecuali &dLayar Kincir Angin&r — itu menempel otomatis! \\n\\nKita juga butuh setidaknya 8 Blok mirip &dLayar Kincir Angin&r, yaitu &dLayar Kincir Angin&r itu sendiri atau Wol. Semakin banyak, semakin cepat &dKincir Angin&r berputar! \\n\\nSetelah semuanya siap, cukup Klik Kanan &dBantalan&r dengan Tangan Kosong untuk menyalakannya."]
	quest.76CBFA38D021AC95.title: "&dKincir Angin"
	quest.76CDF08465700AA2.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_silent.png width:100 height:150 align:center}"]
	quest.76CDF08465700AA2.quest_subtitle: "Ancient Cities"
	quest.76CDF08465700AA2.title: "Silence Armor Trim"
	quest.76CECFB244F39F18.quest_desc: [
		"Cukup tempelkan &3Energy Importer&r pada Sumber Energi dan hubungkan ke &3Energy Interface&r dengan Logic Cable! Pasang dan edit Variable Card-nya, maka kamu akan memindahkan Listrik layaknya seorang profesional! \\n\\nAku harus jujur, terkadang ada masalah saat Mengimpor atau Mengekspor ke Flux Plug dan Point, jadi perhatikan hal tersebut."
		"{image:atm:textures/questpics/logistics/id_energy.png width:200 height:50 align:center}"
	]
	quest.76CECFB244F39F18.title: "&3Energy Importing"
	quest.76E94639E90FEB4E.quest_desc: ["Letakkan beberapa &eAdvanced Beehive&r yang kosong di tempat gelap. Lebah akan datang dengan sendirinya seiring waktu."]
	quest.76E94639E90FEB4E.quest_subtitle: "Muncul di sarang kosong di tempat gelap"
	quest.76E94639E90FEB4E.title: "Skeletal Bee"
	quest.76EA017B12E8F01B.quest_desc: ["Bagian ini menunjukkan berbagai cara untuk menyimpan dayamu!"]
	quest.76EA017B12E8F01B.title: "&f&lMenyimpan Daya"
	quest.76F14C2B866B4EAD.quest_desc: ["&3&lOtherside&r adalah tempat kelahiran &3Sculk &fdan &3makhluk Sculk&r, termasuk &9&lWarden&r. \\n\\nDi sini kamu akan menemukan banyak sepupunya yang jauh, tapi jangan khawatir ada juga beberapa sisi positif dari &3&lOtherside&r! \\n\\nAda banyak Building Block dan Item baru yang bisa kita temukan dan &3Sculk&r di mana-mana untuk banyak &aXP&r! \\n\\nJadi siapkan Hoe-mu dan petualangan ke &3&lOtherside&r!"]
	quest.76F14C2B866B4EAD.quest_subtitle: "Halo dari..."
	quest.76F14C2B866B4EAD.title: "&3&lOtherside"
	quest.76F675A898EAB4E8.quest_desc: ["&dSal Ammoniac&r adalah komponen kritis dari &eAlchemical Sulfur&r yang kita gunakan untuk memproduksi dan menggandakan item. \\n\\nUntuk mendapatkan &dSal Ammoniac&r, kita butuh &9Air&r. "]
	quest.76F675A898EAB4E8.title: "&dSal Ammoniac"
	quest.770C0975CA61CE46.quest_desc: ["Glacite bisa ditemuin jauh underground di Permafrost Forest. \\n\\nBisa dipake buat craft Armor dan Tool yang bantu lawan damage Freezing!"]
	quest.77145113CD5B26FB.quest_desc: ["Source Berry menghasilkan lebih banyak Source dibandingkan sumber lainnya. \\n\\nIni juga akan mengubah rumput atau tanah menjadi Mycelium dalam area 3x3 di sekitarnya. Jamur juga akan tumbuh di sekitarnya jika ada ruang kosong."]
	quest.77145113CD5B26FB.quest_subtitle: "Menghasilkan Source dari Makanan di Sekitar"
	quest.7725CB7D0AE55180.quest_desc: [
		"Advanced AE adalah addon untuk Applied Energistics 2, fokus meningkatkan user experience waktu handle ME System dan expand kemungkinan sistem end game."
		""
		"Dari Pattern Provider yang bisa push ke sisi spesifik mesin, sampai multiblock computer yang bisa jalanin job crafting unlimited, sharing co-processor di antara craft tersebut, dan apapun di antaranya."
	]
	quest.7725CB7D0AE55180.title: "Advanced AE"
	quest.772C65FC32AECD6B.title: "Pola Spanduk Damai"
	quest.77382D4114E901CB.quest_desc: ["&bKatrol Selang&r digunakan untuk mengambil dan menaruh Blok Sumber &bCairan&r penuh — ya, bukan hanya &9Air&r. \\n\\nPertama, atur seberapa jauh &bSelang&r turun atau naik dengan &8Poros&r di salah satu sisinya. Bisa menggunakan &6Roda Gigi&f, &8Poros&r, atau &dEngkol Tangan&r yang paling mudah. \\n\\nKemudian, di sisi lain &bKatrol Selang&r kita bisa pasang &bPipa Cairan&r. Dengan &bPompa Mekanik&r kita bisa memilih apakah &bKatrol Selang&r mengambil atau menaruh Sumber &bCairan&r. \\n\\n&bKatrol Selang&r hanya punya Inventaris 1,5 Ember atau 1500mB, tapi &bCairan&r bisa di-&bPipa&r-kan ke Inventaris atau &bTangki&r lain! \\n\\nKalau Sumber &9Air&r tidak terbatas, &bKatrol Selang&r tidak akan mengambil Blok Sumber, tapi akan terus mengambil &bCairan&r. \\n\\nIni juga berlaku untuk Blok Sumber &cLava&r, tapi itu tidak tak terbatas. Jadi mungkin cek &c&lThe Nether&r karena di sana hampir tidak terbatas!"]
	quest.77382D4114E901CB.title: "&bKatrol Selang"
	quest.7741905EA8380B25.quest_desc: ["&aArmor Trim&r adalah item yang dipakai untuk menambahkan trim ke armor! Ini bisa dilakukan di Smithing Table.\\n\\nMeskipun mereka punya resep, kebanyakan trim adalah temuan langka dari loot chest atau archaeology dig. Setelah menemukan satu, bisa menduplikasi Template dengan menggunakan resep untuk membuat lebih banyak!"]
	quest.7741905EA8380B25.title: "&dArmor Trim"
	quest.7744BEC5CD328262.quest_desc: ["Untuk menambang Blok &bdi bawah air&r perlu Upgrade ini. \\n\\nJuga memberi Aqua Affinity! (Itu berarti berada di &bAir&r tidak memperlambat Penambangan.)"]
	quest.7749703A10B78AB1.quest_desc: ["Kemampuan pertama &8Drowned Belt&r sesuai namanya, ia adalah sabuk untuk menyimpan Talisman. \\n \\nYang kedua berkaitan dengan berenang di &9Air&r. Pernah iri bagaimana Drowned bergerak di dalam &9Air&r seolah itu rumah mereka sendiri? Nah, dengan kemampuan ini kamu bisa mendapatkan hal yang serupa! \\n \\nYang ketiga berfungsi seperti Impaling; kamu akan memberikan damage lebih besar saat di dalam &9Air&r. \\n \\nDan kemampuan terakhir berkaitan dengan mantra Trident; kamu sekarang bisa menggunakan Channeling di mana saja tanpa peduli sedang basah atau tidak!"]
	quest.7749703A10B78AB1.quest_subtitle: "Ditemukan di Bangkai Kapal dan Reruntuhan Laut"
	quest.7749703A10B78AB1.title: "&8Drowned Belt"
	quest.774D61FEFABEFD9A.quest_desc: [
		"Shriek Worms muncul dari menginjak &3Infested Sculk&r di &9Deeplands&r. \\n\\nMereka adalah Mini boss dengan 100 &4Hearts&r. \\n\\nKalau kamu terlalu dekat mereka akan menggigitmu, menyebabkan banyak Damage! Tapi kalau kamu terlalu jauh mereka akan mundur kembali ke dalam tanah. \\n\\nMereka tidak drop apapun selain sedikit &aXP&r, yang kurasa tidak sepadan."
		"{image:atm:textures/questpics/deepndark/dnd_worm.png width:100 height:200 align:center}"
	]
	quest.774D61FEFABEFD9A.title: "Shriek Worm"
	quest.775AB10F8196F27B.quest_desc: ["&4Eye of Mech&r akan menuntunmu ke &4Ancient Factory&r untuk melawan &4&lThe Harbinger&r."]
	quest.775AB10F8196F27B.title: "&4Eye of Mech&r"
	quest.775D176081DD75F5.quest_desc: [
		"Klik kanan Turbine Controller saat sudah dibangun penuh akan munculin Turbine Interface.\\n\\nDi sini, kamu bisa lihat semua stat untuk Turbine. Hover di masing-masing akan kasih tau info lebih tentang tiap satu.\\n\\nDi kiri bawah, kamu punya 2 panah untuk kontrol &9Flow Rate&r. Ini kontrol berapa banyak heated vapor yang dipompa ke Turbine. Untuk tau berapa banyak yang harus di-set, cek &dVapor Production Rate&r reactor kamu sebagai titik awal. "
		"{image:atm:textures/questpics/extremereactors/turbineui.png width:200 height:150 align:1}"
	]
	quest.7766E66A14643F4D.quest_desc: ["&6Awakening&r adalah tambahan yang relatif baru ke &2&lMystical Agriculture&r. Lewat &6Awakening Ritual&r kamu bisa bikin &6Awakened Essence&r. \\n\\nTerus kamu bisa gabungin sama Ingot buat dapetin Block ini!"]
	quest.7766E66A14643F4D.title: "&6Awakened Supremium Ingot Block"
	quest.7770F0D62457096D.quest_desc: ["Meskipun quest ini tidak membahas Drone, mereka sangat luar biasa! Silakan pelajari sendiri jika kamu tertarik."]
	quest.7770F0D62457096D.title: "Memprogram Drone"
	quest.7778937DF377C1B4.quest_desc: [
		"Ini pilihan bagus buat otomatis hasilkan &aEnergi&r."
		""
		"Jumlah &aEnergi&r yang dibuat &b&lWind Generator&r itu tergantung level ketinggian Y-nya."
		""
		"Ini hasilkan sekitar 90FE/t di level laut dan paling banyak bisa 360FE/t!"
		""
		"&b&lWind Generator&r juga butuh &bLangit&r terbuka di atasnya biar jalan, kayak Beacon!"
	]
	quest.7778937DF377C1B4.quest_subtitle: "Hasilkan Listrik dari Angin"
	quest.7778937DF377C1B4.title: "&b&lWind Generator"
	quest.77793642678CB886.quest_desc: ["Menetaskan &c&lNaga Api&r gampang banget. \\n\\nBAKAR &cTELUR&r-nya! \\n\\nCara termudah Taro &cTelur &fdi &cNetherrack&r terus bakarin pake Flint and Steel. \\n\\nSetelah 6 Menit &cTelur&r bakal Menetas dan &c&lBayi Naga Api&r kamu bakal Spawn Jinak ke kamu! \\n\\nDan engga, &c&lBayi&r-nya gak bakal kena Damage dari &cApi&r, dia &c&lNaga Api&r!"]
	quest.77793642678CB886.title: "Masakin &cTelur&r kamu"
	quest.777BB82B56038ED3.quest_desc: ["Satu-satunya cara meningkatkan Damage &4&lMorgan&r adalah dengan membunuh Villager. Baby Villager memberikan Damage lebih banyak! \\n\\nMudah-mudahan sudah punya farm. Lalu, setelah banyak, banyak, banyak kematian Villager akan punya &4&lMorgan&r yang maksimal. \\n\\nJuga bisa tahan Right Click dengan &4&lMorgan&r untuk serangan spesial."]
	quest.777BB82B56038ED3.title: "&4&lMorgan Maksimal"
	quest.779CA0C49F93C4F9.quest_subtitle: "59,049 Obsidian"
	quest.77AD61FCA9BC9AFB.quest_desc: ["14 Slot Mantra!"]
	quest.77AD61FCA9BC9AFB.title: "&3Vibranium Spell Book"
	quest.77B5B23A2C01ED7E.quest_desc: ["&9Kineticator&r kerja kayak magnet buat item dan experience.\\n\\n&eReverse Kineticator&r sebaliknya bakal nolak item dan experience."]
	quest.77B5B23A2C01ED7E.quest_subtitle: "Magnet"
	quest.77B5B23A2C01ED7E.title: "Kineticator"
	quest.77B6A7151B3E5980.quest_desc: ["&aVein Mining&r adalah FTB Ultimine yang terbatas. \\n\\nPas kita Nambang Ore atau Log, Blok yang sama yang nyambung bakal ikut hancur. \\n\\nHemat banyak waktu... tapi kita juga punya FTB Ultimine... jadi. "]
	quest.77B6A7151B3E5980.quest_subtitle: "Meka-Tool"
	quest.77B6A7151B3E5980.title: "&aVein Mining &7Unit"
	quest.77BE3D9D274F72F1.quest_desc: ["&5Stasiun Kereta&r adalah Blok terpenting untuk &5Kereta&r! Kita butuhnya untuk membuat &5Kereta&f, membongkar &5Kereta&r, dan menjadwalkannya! \\n\\nUntuk menggunakannya, kamu perlu memilih &7Rel Kereta&r dengannya. Tahan &5Stasiun Kereta&r di tangan dan Klik Kanan &7Rel Kereta&r. \\n\\nAku nggak tahu jarak maksimum &5Stasiun Kereta&r bisa dipasang, setidaknya 10 Blok! (Aku nggak punya ruang cukup untuk menguji). \\n\\nSetelah terpasang, kamu bisa memberinya nama dengan Bilah Teks di bagian atas. \\n\\nKamu juga bisa Klik \"Buat Kereta Baru\" untuk mulai membuat &5Kereta&r pertamamu. Setelah diklik, salah satu &7Rel&r akan berwarna &9Biru&r — itulah &7Rel&r tempat kamu bisa meletakkan &5Bogie&r. \\n\\nKlik Kanan &7Rel&r tersebut dengan &5Casing Kereta&r untuk membuat &5Bogie&r, alias Roda Kereta. Klik Kanan Roda yang sudah ada untuk mengubah desainnya. Lalu kamu bisa..."]
	quest.77BE3D9D274F72F1.title: "&5Stasiun Kereta"
	quest.77C6667B4C37589C.quest_desc: ["Machine Upgrade dipake buat mempercepat mesin &aMystical Agriculture&r."]
	quest.77C9EE701F72586D.quest_desc: [
		"&bPortable Cell&f berfungsi seperti cell biasa yang bisa dimasukkan ke drive penyimpanan. "
		""
		"Namun, isinya bisa diakses langsung melalui item tersebut tanpa perlu terminal, mirip seperti ransel digital bertenaga ME."
	]
	quest.77C9EE701F72586D.title: "Portable Cell"
	quest.77D3546953550E39.quest_subtitle: "Bull Pine + Spruce"
	quest.77F2271C45DB49BA.quest_desc: ["Module ini, waktu dimasukin ke Chestplate &aMekaSuit&r, bakal kasih kamu Creative Flight. \\nKamu cuma butuh beberapa Item termahal di game buat craft!"]
	quest.77F241BEE9902751.quest_desc: ["Peti terbesar dari mod Sophisticated Storage."]
	quest.77F241BEE9902751.quest_subtitle: "Sangat luas untuk segala kebutuhan!"
	quest.77F241BEE9902751.title: "&dNetherite Chest"
	quest.77FB313845779AED.quest_desc: [
		"Sekarang pakai &a&lChemical Infuser&r lain buat &a&lInfuse&r Water Vapor kita sama &cSulfur Trioxide&r. Sekarang kita punya &aSulfuric Acid&r! \\n\\nAlirkan &aSulfuric Acid&r itu ke &3&lC.D.C.&r buat &3Melelehkan&r Ore kita pakai &aAsam&r. Ini bakal kasih kita &7Dirty Ore Slurry&r, bentuk &cChemical&r dari Ore. \\n\\n3 &7Raw Ore&r bakal kasih 2 Bucket &7Ore Slurry&r dan 1 &7Ore Block&r bakal kasih 1 Bucket &7Ore Slurry&r. \\n\\nKita nggak bisa bawa-bawa &7Dirty Ore Slurry&r, malu-maluin! Kita harus bersihin! Nyalain &a&lChemical Washer&r terus masukin &9Air&r (dan sabun cuci) ke dalamnya. \\n\\nTiap 5mb &7Dirty Slurry&r bakal diubah jadi 3mb &7Ore Slurry&r. \\n\\nSekarang pas &7Slurry&r kita sudah bersih, kita bisa masukin ke &5&lChemical Crystallizer&r. Ini bakal kasih kita &7Ore Crystal&r! Iya, beda sama &7Shard &fdan &7Clump&r. Tiap 200mb &7Ore Slurry&r itu setara 1 &7Crystal&r."
		"{image:atm:textures/questpics/mek/mek_tier4_2.png width:300 height:50 align:center}"
	]
	quest.77FB313845779AED.quest_subtitle: "Pengolahan Bijih Tier 4"
	quest.77FB313845779AED.title: "Melelehkan &7Ore&f pakai &aAsam &fdan &5Crystallizing&r mereka"
	quest.77FC692AC94D2EEF.title: "&l&9Overworld Bounty:&r&e Creepers"
	quest.780E0163033CCD9B.quest_subtitle: "Tingkat: &b4"
	quest.78202A1CF5D86B94.quest_desc: ["Berfungsi sebagai &9Power Bank&r-nya mod Powah.\\n\\nIni juga bisa digunakan untuk meningkatkan total kapasitas penyimpanan daya pada jaringan &7Ender Network&r nirkabelmu."]
	quest.78215D704E6095B0.quest_desc: ["Mikir &5&lMekanism&r dan &l&7Modern Industrialization&r doang yang bisa bersenang-senang dengan armor set end game mereka? \\n\\n&5Quantum Armor&r ini punya stat default mirip &cNetherite Armor&r tapi, kayak &aMekaSuit&r bisa pakai Energy sebagai shield. \\nJuga ada upgrade yang bisa dipasang buat bikin kamu lebih kuat! Seperti Flight, Night Vision, bahkan kemampuan recharge. \\n\\nTapi yang paling keren adalah bisa Dilink ke Storage System kamu! Terus, kamu bisa otomatis ambil Energy dari sana dan ambil Item apapun darinya dimanapun kamu berada. \\n\\nLebih lanjut, pakai full set bisa cegah &aRadiation&r membunuhmu."]
	quest.78215D704E6095B0.quest_subtitle: "Gak bikin kamu invincible penuh"
	quest.78215D704E6095B0.title: "ME System Sebagai Armor: Quantum Armor"
	quest.78311531069807DE.quest_desc: ["Setiap jaringan ME memiliki sejumlah &echannels&f yang tersedia, yang menentukan berapa banyak perangkat yang bisa terhubung. Perangkat yang menangani I/O data akan memakan channel, sedangkan komponen daya seperti Energy Cell tidak.\\n\\nJaringan tanpa controller (ad-hoc) hanya mendukung maksimal 8 channel."]
	quest.78311531069807DE.title: "Sistem Channel"
	quest.7834734E79E41A3A.quest_desc: ["Tolong pertimbangkan kembali bermain dengan mod &l&6Bumblezone&r jika kamu menderita fobia berikut: \\n\\nMelissophobia, Apiphobia, Entomophobia, Arachnophobia, Trypophobia, Acrophobia, Claustrophobia, dan Crystallophobia. \\n\\nJika kamu menderita Trypophobia, kamu bisa menggunakan resource pack bawaan mod ini untuk membantu! Jika fobia lainnya, yah... nasibmu."]
	quest.7834734E79E41A3A.quest_subtitle: "Lebah-hati!"
	quest.784466C3813AA506.quest_desc: ["Pernah ingin menangkap mob? Kita... punya Soul Gem, Mob Imprisonment Tool, dan Creature Catcher untuk itu.\\n\\nMari kita abaikan itu semua dan fokus pada pilihan yang ditawarkan &5&lApotheosis&r. &5Flimsy Ender Lead&r adalah varian termurah dari &5Ender Lead&r, tapi juga yang paling lemah dan paling rapuh. Ini hanya bisa menahan hewan, dan akan hancur setelah 8 kali pakai."]
	quest.784466C3813AA506.title: "Tali Ender Rapuh"
	quest.7846B7FFC3DD85C5.quest_desc: ["&d&lSuper-Critical Phase Shifter&r (&d&lS.P.S.&r) bakal ubah &aPolonium&r jadi &dAntimatter&r. \\n\\nBuat lakuin itu, kita butuh &aPolonium&r, &aEnergi&r, tempat buat campur keduanya, sama tempat buat keluarin &dAntimatter&r! \\n\\nJadi kita butuh &dPort&r buat masing-masing! \\n2 &dPort&r buat &aEnergi&r di samping, 1 &dPort&r buat kasih &d&lSPS&r &aPolonium&r, sama yang terakhir buat keluarin &dAntimatter&r."]
	quest.7846B7FFC3DD85C5.title: "&dSPS Port"
	quest.784D6D11C4F41215.quest_subtitle: "&f6.5 &cAttack Damage"
	quest.785951190FFDAA21.quest_desc: ["Meningkatkan ukuran stack di dalam Tas sebanyak 4 kali lipat."]
	quest.785951190FFDAA21.title: "&eStack Upgrade Tingkat 2"
	quest.786073B57C901DB7.title: "Pola Spanduk Tambah"
	quest.7864C8F2CBC910CB.quest_desc: ["&a&lMekaSuit Helmet&r, jelas bagian yang masuk ke kepala! Lo butuh &dAntimatter Pellet&r, &aPolonium Pellet&r, &dUltimate Induction Cell&r, dan lainnya! \\n\\nBerfungsi sebagai Upgrade dari &5Unobtainium Helmet&r. Meski punya Armor Point jauh lebih sedikit, kerjanya beda dari &5Unobtainium Helmet&r. \\n\\nKalo &a&lMekaSuit Helmet&r gak di-Charge, bakal kerja dengan stat mirip &cNetherite Helmet&r, tapi ini bagian serunya! &a&lMekaSuit Helmet&r bakal blokir semua Damage (kecuali Magic Damage) dan pake &aEnergi&r. \\n\\nJuga pas dipakai, bakal nunjukin di HUD: Koordinat, &aEnergi&r di dalam &a&lMekaSuit&r, dan bakal ganti Armor Point dengan &aEnergy Bar&r. \\n\\nKita bisa pake &7&lModification Station&r buat kasih Upgrade ke &a&lMekaSuit Helmet&r, kayak lebih banyak &aEnergi&r buat dapet damage lebih sedikit! Napas dalam air, perlindungan dari &aRadiasi&r, bahkan &eCharging Solar&r!"]
	quest.7864C8F2CBC910CB.title: "&a&lMekaSuit Helmet"
	quest.78656C89EEE80DB5.quest_desc: ["&eTrowongan Kuningan&r bekerja seperti &eTerowongan Andesit&r tapi dengan jauh lebih banyak konfigurasi! \\n\\nPertama, kini ada Filter! Per sisi: kalau kamu Filter sisi Input, hanya &eItem&r Filter tersebut yang diizinkan melewati &eTerowongan&r. Kalau kamu Filter sisi Output, hanya &eItem&r tersebut yang keluar dari sisinya. \\n\\nSekarang kita juga bisa menggabungkan &eTerowongan Kuningan&r. Ini memungkinkan mereka menerima semua Input yang sama tapi memfilter ke &eSabuk&r tertentu! \\n\\nDi bagian atas &eTerowongan&r kita akan menemukan opsi untuk mengubah Mode Distribusinya. Aku tidak akan menjelaskan secara detail — Quest kita punya ruang terbatas — jadi aku akan meringkasnya! \\n\\nSplit: membagi tumpukan &eItem&r secara merata ke semua &eSabuk&r yang dituju. Forced Split: memastikan setiap &eSabuk&r mendapat jumlah yang merata, sementara Split biasa mungkin melewati beberapa. Round Robin: bergantian satu per satu di antara setiap &eSabuk&r. Forced Round Robin: tidak melewati &eItem&r apapun dan menunggu — semua kebagian giliran! Prefer Nearest: mengirim &eItem&r ke Output terdekat. Randomize: mengirim &eItem&r secara acak ke Output berbeda. Synchronize Inputs: hanya Output ketika setiap &eTerowongan Kuningan&r punya &eItem&r yang menunggu untuk di-Input."]
	quest.78656C89EEE80DB5.title: "&eTerowongan Kuningan"
	quest.787415570026FFAA.quest_desc: ["Upgrade ini menambahkan efek sihir (enchantment) pada &4Destructor&r milikmu.\\n\\nKenapa harus pakai ini? Bayangkan jika kamu punya Builder atau Quarry yang memasukkan bijih dengan efek Silk Touch ke sistem. Kamu bisa menyuruh &bConstructor&r menaruh bijih tersebut, lalu dihancurkan oleh &4Destructor&r yang memiliki &eFortune&r untuk mendapatkan lebih banyak bijih mentah."]
	quest.787415570026FFAA.title: "Upgrade Destructor"
	quest.7878F190BC8ADC82.quest_desc: ["Yang terbaik dari yang terbaik. Mulai dari Diamond, Nether Star, sampai Allthemodium. Rod ini hanya mencari item kasta tertinggi!"]
	quest.7878F190BC8ADC82.title: "Material Epik"
	quest.787E714014EC2C02.quest_subtitle: "Tingkat: &63"
	quest.78840993C7832E89.quest_desc: [
		"Upgrade yang Tersedia:"
		"- Penebang Pohon"
		"- Penghancur Daun"
		"- Pelebur Otomatis"
		"- Teleporter Barang Jatuhan"
		"- Hancur Seketika"
	]
	quest.788A7A2F1F438B64.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_cloggrum.png width:100 height:150 align:center}"]
	quest.788A7A2F1F438B64.title: "&7Cloggrum&r"
	quest.789AF6D0A6321945.quest_desc: [
		"Satu-satunya yang paling penting! Paling kuat! Dan paling berbahaya dari semua &l&3Artifact&r!"
		"{@pagebreak}"
		"Aku bahkan nggak yakin harus jelasin fungsinya apa, terlalu berbahaya!"
		"{@pagebreak}"
		"Kalau kamu yakin banget bisa nahan kekuatannya, ya udah lanjut baca..."
		"{@pagebreak}"
		"Belum terlambat buat balik badan!"
		"{@pagebreak}"
		"Oke, udah aku peringatin ya..."
		"{@pagebreak}"
		"Tekan Shift buat berpeluang 'Kentut' pas &dWhoopie Cushion&r ini dipakai."
	]
	quest.789AF6D0A6321945.quest_subtitle: "Unik"
	quest.789AF6D0A6321945.title: "&dWhoopie Cushion&r"
	quest.78AA7BFABBFB9973.quest_desc: ["&eSpell Book&r &2&lNature&r. \\n\\nIni punya 10 &3Spell&r dan memberikan boost untuk &2Nature Spell&r! \\n\\nKamu butuh Rotten Spell Book untuk craft-nya..."]
	quest.78AA7BFABBFB9973.title: "&2Druidic Tome"
	quest.78B7FC6A868F5C4D.quest_desc: ["Kamu harus menemukannya di struktur di &6&lBumblezone&r atau bisa menukarkannya dengan &5Ratu Lebah&r! \\n\\nSambil memakainya kamu bisa menahan tombol Spasi untuk terbang sebentar. \\n\\nTapi seperti lebah asli, sayapnya terlalu kecil untuk menopang tubuh gemukmu dari tanah."]
	quest.78BCED8699ADEDF4.quest_desc: ["&3Soundproof Glass&r dibuat dengan menggabungkan &3Soul Dust&r dan Glass. \\n\\nIni berfungsi untuk meredam Suara seperti Wool! Kalau &3Sculk Sensor &fatau &3Shrieker&r punya satu yang menutupi mereka, mereka tidak akan mendengar Suara. \\n\\nCuma ini kamu bisa melihat tembus!"]
	quest.78BCED8699ADEDF4.title: "&3Soundproof Glass"
	quest.78BFDD3A9B996655.quest_desc: ["Peningkatan signifikan dari &5Flimsy Ender Lead&r. Sekarang, ia bisa menahan mob agresif juga, dan akan hancur setelah 64 kali pakai. Untuk mendapatkannya, kita butuh setidaknya &a45 Eterna&r, &c25% Quanta&r, dan &540% Arcana&r.\\n\\nIni bisa dicapai dengan 9 &bCrystalline Seashelves&r, atau jika kamu lebih suka &4Hellshelf&r, gunakan 9 &4Glowing Hellshelf&r dan 8 Batang Lilin (Tips: Kamu bisa menaruh sampai 4 lilin dalam satu blok)."]
	quest.78BFDD3A9B996655.title: "Tali Ender"
	quest.78CCD8075249E2B7.quest_subtitle: "Magmatic + Water"
	quest.78CCD8075249E2B7.title: "BreezBee"
	quest.78CE2ECEF0B651DA.quest_desc: ["Ditemukan di &bAurora Palace&r, &3Ice Sword&r akan memberikan efek &bFrosted&r (beku) selama 10 detik ke musuh yang terkena serangannya."]
	quest.78CE2ECEF0B651DA.title: "Pedang Es (&3Ice Sword&r)"
	quest.78D1C97A542133D8.quest_desc: [
		"Augment adalah Upgrade buat Iron Furnace Furnace!"
		""
		"Di Kanan Atas Furnace GUI bakal ada tombol buat liat bagian Augment. Bakal ada spot Merah, Hijau, dan Biru, masing-masing bisa nampung 1 Augment warna mereka. "
	]
	quest.78D1C97A542133D8.title: "&lAugment"
	quest.78D8F40AA9568511.quest_desc: ["Powered Rolling Machine adalah versi yang jauh lebih baik dari Manual Rolling Machine. \\n\\nKamu tidak perlu terus melihat ke dalam mesin saat crafting dan ia akan bekerja secara otomatis. \\n\\nSatu-satunya masalah adalah mesin ini butuh energi listrik!"]
	quest.78DA970F97002975.quest_desc: ["Tong adalah cara sederhana menampung &bCairan&r. \\n\\nAda Tong Kayu dan Tong Logam. Kayu hanya bisa menampung &bCairan&r dingin dan suhu kamar, bukan &bCairan&r hangat atau Gas. Sedangkan Tong Logam bisa menampung semua jenis &bCairan&r dan Gas. \\n\\nKedua Tong bisa menampung 12 Ember &bCairan&r. Secara otomatis &9Memasukkan&r dari sisi Atas dan &6Mengeluarkan&r ke Bawah tetapi ini bisa diubah."]
	quest.78DA970F97002975.title: "Menyimpan &bCairan"
	quest.78DD2A3DFF6D1613.quest_desc: ["Dengan 2 &2Bio Fuel&r kita bisa bikin 1 &aSubstrate&r lewat &2&lP.R.C.&r. \\n\\nYah... kita juga butuh &9Air&r dan Hydrogen di &2&lP.R.C.&r tapi nanti kita dapat &aSubstrate&r dan juga &dChemical Ethene&r. \\n\\nBiar bisa bikin HDPE Pellet kita butuh &aSubstrate&r tadi dan ngerubah &dChemical Ethene&r tadi jadi &dLiquid Ethene&r. Kita bisa pakai &c&lRotary &bCondensator&r buat bikin dia jadi &bCair&r! \\n\\nTerus masukin &dLiquid Ethene &fdan &aSubstrate&r tadi ke &2&lP.R.C.&r buat bikin HDPE Pellet! \\n\\nKita bisa Craft 4 Pellet bareng-bareng buat bikin HDPE Rod atau &dEnrich&r 3 biji buat bikin HDPE Sheet."]
	quest.78DD2A3DFF6D1613.title: "Pakai semuanya buat ubah &2Bio Fuel&r jadi HDPE"
	quest.78E40BDB0E54B638.quest_desc: ["Bisa ditemukan di struktur di &6&lBumblezone&r atau ditukar dengan &5Bee Queen&r! \\n\\nPernah benci terjebak di &6Honey Block&r? Atau saat &eSerbuk Sari (Pollen)&r memperlambat jalanmu? Jangan takut karena Honey Bee Leggings ada di sini! Mereka akan membantumu bergerak lebih baik melalui blok-blok tersebut. Semakin banyak Bee Armor yang kamu pakai, perjalanan akan semakin mudah! \\n\\nJuga kamu bisa menekan Shift di atas &ePollen&r untuk mengumpulkannya! "]
	quest.78E51D22C16C4686.quest_desc: ["Storage Controller juga bisa terhubung ke penyimpanan lain secara nirkabel menggunakan Storage Tool. Cukup klik kanan Storage Controller untuk menyetelnya, lalu klik kanan pada penyimpanan yang ingin dihubungkan.\\n\\nJarak maksimal nirkabel sama seperti biasa, yaitu 14 blok."]
	quest.78E66F1DE42C747A.quest_desc: ["&9Echo Shard&r mungkin sangat menjengkelkan untuk di-farm, padahal kita butuh banyak! Jadi kenapa tidak mencari cara yang lebih mudah untuk menggandakannya. \\n\\nDengan &d&lInfusion&r, kita bisa mengubah 1 &9Echo Shard&r menjadi 4 buah! \\n\\nKita butuh &a70 Eterna&r, &c50% Quanta&r, dan &550% Arcana&r. \\n\\nUntuk mencapainya, kita bisa menggunakan 12 &4Glowing Hellshelves&r dan 2 &9Deepshelf&r (yang bukan versi &9Dormant&r)!"]
	quest.78E66F1DE42C747A.title: "Echo Shard Tak Terbatas?"
	quest.78EC7D19BE24FE06.quest_subtitle: "Sumpah nggak meledak"
	quest.78ECC28DD4BA9696.quest_desc: [
		"Meskipun kamu bisa mendapatkan sebagian besar material &dOtherworld&r menggunakan Spiritfire, kamu juga bisa menggunakan &9Divination Rod&r untuk melacak material tersebut."
		""
		"Pertama, kamu perlu menyelaraskan (attune) Rod tersebut ke material yang kamu cari. Contohnya, jika kamu sedang berburu &8Otherstone&r, kamu bisa menggunakan Rod pada &aAndesite&r untuk membantu melacak lokasi Otherstone di dunia."
		""
		"Setelah selaras dengan material, kamu bisa tahan klik kanan dengan Rod di tangan, dan sebuah partikel akan meluncur ke arah lokasi terdekat material tersebut."
		""
		"Kamu tetap harus berada di bawah efek &3Third Eye&r untuk bisa memanen blok Otherworld tersebut."
	]
	quest.78ECC28DD4BA9696.quest_subtitle: "Berburu Material &dOtherworld&r"
	quest.78ECC28DD4BA9696.title: "Peralatan Profesi: Divination Rod"
	quest.78FBB0C88182040E.quest_desc: ["Kalau kamu belum main Minecraft sejak 1.13 ini mungkin membingungkan, tapi kamu tahu Crossbow dan Piercing. Mereka punya enchantment yang membolehkan Arrow mereka menembus beberapa target dan terus memberikan damage. Module ini melakukan persis itu!"]
	quest.78FBB0C88182040E.title: "Wyvern Projectile Penetration Module"
	quest.78FEDE6FA4845585.quest_desc: ["Beberapa proses &d&lInfusion&r membutuhkan jumlah &aEterna&r, &cQuanta&r, atau &5Arcana&r yang sangat-sangat spesifik. \\n\\nUntuk mengaturnya, kamu mungkin butuh salah satu dari &7Rak&r ini. \\n\\nMasing-masing akan menurunkan jumlah dari nilai statistiknya masing-masing."]
	quest.78FEDE6FA4845585.title: "Statistik Negatif"
	quest.7900A4836CC55428.quest_desc: [
		"Assembler Matrix adalah multiblock yang efektif berisi banyak Molecular Assembler dan Pattern Provider, semua dalam satu channel."
		""
		"Assembler Matrix harus minimal kuboid 3x3x3 dan maksimal kuboid 7x7x7. Butuh part berikut:"
		"- Edge terdiri dari Assembler Matrix Frame"
		"- Face terdiri dari Assembler Matrix Wall/Glass"
		"- Interior terdiri dari Assembler Matrix Pattern/Craft/Speed Core"
		""
		"Assembler Matrix yang valid harus ada minimal satu pattern core dan craft core. Harus terisi penuh dan gak boleh hollow. Kalau Assembler Matrix terbentuk dengan benar dan powered, garis di frame akan jadi biru."
		""
		"{@pagebreak}"
		""
		"Di contoh ini, kita akan bikin Assembler Matrix 7x7x7, fokus utama di balance antara craft dan pattern core."
		""
		"Bikin 43 Assembler Matrix Frame pertama dan 125 Assembler Matrix Wall pertama. Gue kasih 25 masing-masing sebagai hadiah di reward quest ini (buat total 68 frame dan 150 wall)"
	]
	quest.7900A4836CC55428.quest_subtitle: "Banyak Molecular Assembler dan Pattern Provider di Satu Channel"
	quest.7900A4836CC55428.title: "Banyak Assembler Jadi Satu: Assembler Matrix"
	quest.790EC3EDC2DB1FB0.quest_desc: ["Seperti yang disebutkan sebelumnya, mod ini menambahkan banyak cara seru untuk menghasilkan power yang membutuhkan build spesifik."]
	quest.790EC3EDC2DB1FB0.title: "Generators Galore"
	quest.79110ACAAC8412EA.quest_subtitle: "Infusion Crafting"
	quest.79110ACAAC8412EA.title: "Tertium Bee"
	quest.791A981914CE345F.quest_subtitle: "&f10 &cAttack Damage"
	quest.791AE62ACACBD5BA.quest_subtitle: "Kamu akan buka, tutup, lalu buka lagi, karena bosan"
	quest.792990DC06DB98F9.quest_desc: ["Di sekitar &2&lOverworld&r kamu bisa nemuin Reruntuhan Portal &5&lEternal Starlight&r. Di sana kamu bisa challenge Gatekeeper buat fight! \\n\\nKalo kamu menang dia bakal kasih beberapa Item dan dengan itu kamu bisa masuk Portal ke dunia baru buat dijelajahi!"]
	quest.792990DC06DB98F9.title: "&5&lEternal Starlight"
	quest.7934873E784C4B3C.quest_desc: [
		"Ini kayaknya pernah lihat? \\n\\nSekarang kita punya &7Shard&r lagi. Tapi sebelum diapa-apain, kita butuh &bOxygen&r. \\n\\nMasukkan &9Air &fke &9&lElectrolytic Separator&r buat dapat &bOxygen&r. Terus hubungin &cTube&r &bOxygen &fdari &9&lSeparator&r ke &b&lPurifier&r. \\n\\nPakai &bOxygen&f itu, &b&lPurifier&r bisa ngerubah &7Shard &fjadi &7Ore Clump&r. \\n\\nSekarang, &cCrush&r &7Clump&f tadi buat dapat &7Dirty Dust&r. Terus, &dEnrich &f&7Dirty Dust&f itu buat dapat &7Ore Dust&r. \\n\\nDan terakhir &6Smelt&r &7Dust&r tadi, buat dapat &lOre Hasil Olahan&r kita yang mantap!"
		"{image:atm:textures/questpics/mek/mek_tier3_3.png width:250 height:100 align:center}"
	]
	quest.7934873E784C4B3C.quest_subtitle: "Pengolahan Bijih Tier 4"
	quest.7934873E784C4B3C.title: "&7Crystal&f, &7Shard&f, &7Clump&f, DLL"
	quest.7941938014E97A30.quest_desc: ["Pernah ingin menunggangi lebah?\\n\\nBumble Bee muncul secara alami di dunia, dan mereka bisa dijadikan tunggangan!\\n\\nBuatlah sebuah &6Treat on a Stick&r, pasang pelana (saddle) pada Bumble Bee, dan terbanglah tinggi!"]
	quest.7941938014E97A30.quest_subtitle: "Muncul di Overworld dari Bumble Bee Nest"
	quest.7941938014E97A30.title: "Bumble Bee"
	quest.794D6F9B8DB31E7D.quest_desc: ["&bIce Staff&r membuatku bingung cukup lama tapi untungnya sekarang aku tahu! \\n\\nKamu butuh &bPermafrost Shard&r dan &bFrosted Helve&r. &bPermafrost Shard&r adalah Loot di dalam struktur Ice Breaker. Ini adalah Shipwreck di Biome Es. \\n\\n&bFrosted Helve&r adalah Item yang di-Craft. Ini menggunakan &5Arcane Ingot &fdan&b Frozen Bone&r. Yang terakhir adalah Drop dari &bStray&r. \\n\\n&bIce Staff&r memberikan 5 &4Damage&r dan memberikan 25% Mana Regeneration. Ini memberikan 5% &3Spell Power&r untuk semua &3Spell&r, dan 15% hanya untuk &bIce Spell&r."]
	quest.794D6F9B8DB31E7D.title: "&bIce Staff"
	quest.795143471F31A64A.quest_subtitle: "Dibutuhkan untuk resep Laser"
	quest.7952DA35B4F5C598.quest_desc: ["Apa? Satu &7Bucket&r nggak cukup? Satu Stack &7Bucket&r juga nggak cukup? Kalau gitu sobat, kamu butuh &bFluid Tank&r! \\n\\n&bFluid Tank&r bisa nampung banyak &7Bucket&r satu jenis &bCairan&r dan bisa dibawa-bawa kayak &7Bucket&r biasa. Tapi sayangnya ini nggak bisa naruh Source Block. \\n\\nBuat isi atau ambil &bCairan&r, kamu butuh &bMechanical Pipes&r yang sudah disetel buat itu. \\n\\n&a&lBasic&r: nampung 32 Bucket cairan. \\n\\n&c&lAdvanced&r: nampung 64 Bucket cairan. \\n\\n&b&lElite&r: nampung 128 Bucket cairan. \\n\\n&d&lUltimate&r: nampung 256 Bucket."]
	quest.7952DA35B4F5C598.title: "&bFluid Tank"
	quest.7953C87C488A2AF7.quest_desc: ["Memungkinkanmu terbang seperti Iron Man.\\n\\nKamu hanya bisa memasang satu tingkat upgrade ini pada Boot dalam satu waktu. Setiap tingkatan memakai tekanan udara lebih banyak dari sebelumnya.\\n\\nGunakan upgrade ini, jangan cuma dibuat saja."]
	quest.7953C87C488A2AF7.quest_subtitle: "Maks: 1"
	quest.795A860668072830.quest_desc: ["{image:atm:textures/questpics/allthemodium/all_armor_vibarcane.png width:100 height:175 align:center}"]
	quest.795A860668072830.title: "&3Vibranium Arcanist Armor"
	quest.795B80BF12D23897.quest_desc: ["Ada di namanya, tapi karena ini Treasure Enchantment gak semua orang tau. \\n\\nPas jalan di atas &9Air&r dengan Boots yang di-enchant Frost Walker atau &a&lMekaSuit Boots&r dengan &bFrost Walker &7Unit&r, &9Air&r bakal jadi &bEs&r! \\n\\n&bEs&r gak bakal bertahan selamanya, bakal cair sebentar lagi! \\n\\nMakin banyak Frost Walker, makin banyak &bEs&r!"]
	quest.795B80BF12D23897.quest_subtitle: "Sepatu"
	quest.795B80BF12D23897.title: "&bFrost Walker &7Unit"
	quest.795FA102F6577368.quest_desc: ["Untuk mendapat &4&lMorgan&r harus membunuh anjing peliharaan dengan &e&lCaliburn&r. \\n\\nJuga Innate Cap &e&lCaliburn&r akan menjadi Innate Cap &4&lMorgan&r. \\n\\nSemoga berhasil!"]
	quest.795FA102F6577368.title: "Dapat &4&lMorgan"
	quest.796E922CA69BAE82.quest_desc: ["&4Mega Disk Interface&r memiliki 54 slot filter, bekerja 8x lebih cepat, dan sudah memiliki &eStack Upgrade&r terintegrasi."]
	quest.796E922CA69BAE82.title: "&4Mega Disk Interface"
	quest.7975C7145572C438.quest_desc: ["Baik pemain modded berpengalaman atau pemula MC, semua orang harus membuat &2Wooden Pickaxe&r.\\n\\nPickaxe memungkinkan memecah kebanyakan block batu dan metal. Yang kayu ini tidak akan bertahan lama, jadi pastikan kumpulkan &3Cobblestone&r dengannya!"]
	quest.7975C7145572C438.title: "Pickaxe Pertama"
	quest.79886D63280DBBF3.quest_desc: ["Filtering tidak cukup?!?! Kamu mau item dihancurkan?!?! Monster!"]
	quest.79886D63280DBBF3.title: "Selective Incineration Module"
	quest.798B592E956AD28C.quest_desc: [
		"&b&lRunic Crucible&r adalah Multiblock yang akan jadi cara kita dapet setengah dari Essence otomatis: Liquid Soul dan &bLiquid Aureal&r! \\n\\nCek halaman berikutnya di Quest Description untuk lihat cara bangunnya! \\n\\nKita perlu Pipe Item dan Liquid ke Port, lalu isi dengan &dSource&r untuk mulai kerja. Liquid Soul dan &bLiquid Aureal&r kita perlu input Item dan Liquid. \\n\\n&b&lRunic Crucible&r juga bisa dipakai untuk craft &9Corrupt Soul&r, &dEnchanted Soul&r, dan &5Obsidiansteel&r!"
		"{@pagebreak}"
		"{image:atm:textures/questpics/chap3/creative_crucible1.png width:100 height:100 align:center}"
		"Layer pertama &l&bRunic Crucible&r punya &6Gilded Chiseled Polished Darkstone&r di tengah, sekitarnya &9Polished Darkstone&r. Lalu, di sisi kita akan punya &9Polished Darkstone Stair&r terbalik, dengan Rune Block di corner."
		"{image:atm:textures/questpics/chap3/creative_crucible2.png width:100 height:100 align:center}"
		"Tepat di tengah kita taruh &bArcane Crystal&r dengan &9Polished Darkstone Stair&r di sekitarnya. Di sisi akan ada &6Arcane Polished Darkstone Pillar&r, &9Polished Darkstone&r yang akan diganti Hatch, dan &6Arcane Polished Darkstone&r."
		"{image:atm:textures/questpics/chap3/creative_crucible3.png width:100 height:100 align:center}"
		"Cuma taruh &bArcane Crystal Block&r di tiap corner dan selesai!"
		"{image:atm:textures/questpics/chap3/creative_crucible4.png width:100 height:100 align:center}"
		"Terakhir, dengan satu blok space, taruh &7Quantum Injector&r di atas &bArcane Crystal Block&r tengah."
		"{image:atm:textures/questpics/chap3/creative_crucible5.png width:150 height:100 align:center}"
		"&9Polished Darkstone block&r di layer tengah adalah tempat kita taruh Hatch!"
	]
	quest.798B592E956AD28C.title: "&b&lRunic Crucible&r"
	quest.7992C63F063BE908.quest_desc: ["Resep &7Scroll&r yang cukup sederhana untuk sesuatu yang sangat kuat! Cuma 2 &ePowdered Gold&r dan 1 &bPowdered Diamond&r. \\n\\nGunakan ini pada &7Spell Cloth&r dengan &cMahoujin&r di atasnya, setelah diatur Right Click untuk mendapat &7Scroll&r! \\n\\nKemudian, gunakan &7Scroll&r untuk mendapat &c&lExplosive Staff&r!"]
	quest.7992C63F063BE908.title: "&7Scroll of Explosive Mana Condensation"
	quest.799CC9FEEDE471B1.quest_subtitle: "Mango + Star Anise"
	quest.79AD74A863EA43CB.quest_desc: ["Flux Networks menyediakan cara untuk menyimpan daya yang kamu hasilkan untuk jaringanmu!\\n\\nAlat-alat ini menampung jumlah daya yang sangat besar, dan dapat ditingkatkan untuk menyimpan lebih banyak lagi!"]
	quest.79AD74A863EA43CB.quest_subtitle: "Menyimpan Daya"
	quest.79AD74A863EA43CB.title: "Flux Storage"
	quest.79AF63E77AD70A93.quest_desc: ["&7Rak Buku&r biasa adalah titik awalmu, tapi jelas bukan titik akhirmu. Setidaknya bukan rak buku normal. \\n\\nHanya dengan rak buku biasa, kamu cuma bisa meningkatkan &aEterna&r sampai maksimal 30. \\n(Aku akan menjelaskan soal &5Enchantment Level&r segera, tapi ketahuilah bahwa kamu butuh nilai itu terus naik)."]
	quest.79AF63E77AD70A93.title: "Batas Vanilla Cuma Permulaan"
	quest.79BBCC1BEE90DBBB.quest_desc: [
		"&lTipe Kemampuan:&r Pasif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Memungkinkan pemain untuk menghindari kematian, punya cooldown sangat panjang. Jadi seperti Totem Keabadian dengan cooldown yang tidak dikonsumsi."
	]
	quest.79BEECD4E545793F.quest_desc: ["Kawat Berduri bekerja seperti Sarang Laba-laba... hanya lebih tajam! \\n\\nKawat Berduri akan Merusak dan Memperlambat apa pun yang mencoba melewatinya, termasuk kita! \\n\\nBisa dengan aman membongkarnya dengan &6Pemotong Kabel Insinyur&r. \\n\\nAtau bisa menggunakan &6LV &cKabel&r untuk membuatnya memberikan lebih banyak Kerusakan dan Efek Stun!"]
	quest.79C1105A84B8BF8F.quest_desc: ["Variable Cards diperlukan untuk memulai Interaksi seperti Importing Items. Akan dimasukkan ke salah satu slot Importer untuk menambahkannya.\\n\\nDari sana bisa mengedit semuanya lewat tombol +. Bisa mengubah berapa banyak yang di-Import, slot Item mana, Channel mana, hampir semuanya hanya dengan Card itu.\\n\\nKalau hanya ingin memindahkan item, tidak terlalu rumit, cukup masukkan dan mungkin ubah Limit untuk berapa banyak yang dipindahkan."]
	quest.79C1105A84B8BF8F.title: "Variable Cards"
	quest.79C4CF8D7312FC28.quest_desc: ["Yang terbaik dari Vanilla! &5Netherite&r! Tenang aja ga perlu Smithing Template buat ini, cuma butuh banyak &5Netherite&r. \\n \\nSmelt item tiap 5 Tick yang berarti 4 Item di-Smelt tiap Detik. Iya ini bukan lagi S.P.S. (Seconds per Smelt) tapi sekarang S.P.S. (Smelt per Second). \\n \\nDi-craft dari &dObsidian Furnace&r... tunggu ini bukan Furnace terakhir?"]
	quest.79C4CF8D7312FC28.title: "&5Netherite Furnace&r"
	quest.79C652E3FCB88550.quest_desc: [
		"&5Gloomper&r secara teknis bersifat Pasif, tapi mereka punya mekanisme pertahanan melawanmu jadi aku menganggapnya Netral! \\n\\nSaat dipukul, mereka akan mengeluarkan efek mirip Lingering Potion. \\n\\nSaat mati mereka menjatuhkan kakinya (yang sangat lezat) dan kemungkinan menjatuhkan Leather. \\n\\nMereka juga bisa dikawinkan menggunakan Gloomgourd!"
		"{image:atm:textures/questpics/undergarden/undergarden_gloomper.png width:100 height:100 align:center}"
	]
	quest.79C652E3FCB88550.title: "&5Gloomper&r"
	quest.79C9875A1A494762.quest_desc: ["Kalau lebih suka gak pakai &9Corrupt Soul&r untuk tumbuh Edelwood, bisa andalkan Luck! \\n\\nWandering Trader punya kemungkinan jual Growing Edelwood ke kamu, yang bisa ditanam untuk tumbuh Edelwood. \\n\\nWandering Trader sangat random, coba pakai Trader Carpet untuk setidaknya tau dimana dia spawn!"]
	quest.79C9875A1A494762.quest_subtitle: "Dari Wandy T'"
	quest.79C9875A1A494762.title: "Beli Edelwood"
	quest.79CA2F401982C04F.quest_subtitle: "Berikan Arcanus Bee sebuah blok Rune"
	quest.79CA2F401982C04F.title: "Rune Bee"
	quest.79D2617E01481281.quest_desc: ["Kamu perlu menambang &bCertus Quartz&f dari Meteorit untuk mendapatkan Dust dan Crystal-nya sebagai bahan dasar mod ini."]
	quest.79D2617E01481281.title: "Certus Quartz"
	quest.79D3055DE0EEA6B0.quest_desc: ["&cFire Armor&r dari mod &d&lArs Elemental&r!"]
	quest.79D3055DE0EEA6B0.quest_subtitle: "15"
	quest.79D3055DE0EEA6B0.title: "&cPyromancer Outfit"
	quest.79D6A251FE3761B3.quest_desc: ["Saat diletakkan di biome rawa (swamp), Slimy Nest akan menarik Slimy Bee."]
	quest.79D6A251FE3761B3.quest_subtitle: "Memancing Slimy Bee di biome rawa"
	quest.79E30114ED8870EE.quest_subtitle: "&f7 &cAttack Damage"
	quest.79EC8A49368421BF.quest_desc: ["&6Pyrium&r adalah Loot terkonfirmasi dari Vault &cCitadel&r... \\n\\nKecuali Vault ini tidak mengambil Trial Key normal. Wow, sepertinya satu Kunci tidak bisa membuka setiap Kunci! \\n\\nKita butuh Decrepit Key, yang merupakan Drop dari &5Ancient Knight&r di &cCitadel&r. Mereka spawn di Menara dan level bawah Library."]
	quest.79EC8A49368421BF.title: "&6Pyrium"
	quest.79EF24E396779B9F.quest_subtitle: "Tingkat: &f2"
	quest.79FC674836B6340E.title: "Draconic Jump Module"
	quest.79FF12D7A4C8E821.quest_desc: [
		"Mengarungi 7 Samudra Gula, ada Kapal Bajak Laut berbahaya yang dipimpin oleh Kapten yang mengerikan. \\nDi dek bawah terdapat para Navigator. \\nDi dekat persenjataan di ruang kargo terdapat Quartermaster. \\n\\nDi seluruh bagian kapal kamu bisa menemukan Loot dari banyak petualangan para bajak laut ini!"
		"{image:atm:textures/questpics/bumblezone/bumble_pirates.png width:200 height:100 align:center}"
	]
	quest.79FF12D7A4C8E821.title: "&bKapal Bajak Laut"
	quest.7A066DD274F970C2.quest_subtitle: "2/5"
	quest.7A066DD274F970C2.title: "Bagian Kanan &6&lATM Star&r"
	quest.7A103577EAE7B3F1.quest_desc: ["Ini adalah Essence Tingkat 5 - Awakened, dibuat dengan nggabungin 4 Cognizant Dust, 10 dari setiap Elemental Essence dan 1 Blok Supremium di Altar Awakening."]
	quest.7A103577EAE7B3F1.quest_subtitle: "Tingkat: &c5 - Awakened"
	quest.7A103577EAE7B3F1.title: "&6Awakened Supremium"
	quest.7A16D2EB63359294.quest_desc: [
		"Aurora Deer adalah hewan berkuku ramah yang juga hidup di dingin. \\n\\nDeer ini gak bakal nyoba nyakitin kamu tapi kalau kamu menghalangi pas mereka lari kamu mungkin ngerasain Antler. \\n\\nAntler yang juga bisa di-drop mereka kalau mati yang bisa dipake sebagai senjata atau hoe! \\n\\nMereka juga mungkin drop Leather atau Aurora Deer Steak."
		"{image:atm:textures/questpics/eternal/starlight_deer.png width:200 height:100 align:center}"
	]
	quest.7A16D2EB63359294.title: "Aurora Deer"
	quest.7A1C117CA8FB7C31.quest_desc: ["Yang satu ini unik!\\n\\nAlih-alih mencari bijih, ia mencari blok Budding Amethyst!\\n\\nTidak perlu pusing lagi mencari Geode, tuan yang budiman!"]
	quest.7A1C117CA8FB7C31.title: "Pencari Amethyst"
	quest.7A1E3E7E2DF17AD2.quest_desc: ["Pertama, adalah &8Bilah Gergaji&r. Ini digunakan untuk memotong &2Pohon&r. Akan memotong setiap Log dan Daun di &2Pohon&r di atas Log yang dipotong. \\n\\nKedua, adalah &8Bilah Pemotong Batu&r. Yang satu ini tidak bisa memotong &2Pohon&r, melainkan digunakan sebagai Beliung dengan Silk Touch. Akan memecah Batu dan memberikan Batu bukan Cobble. \\n\\nKetiga adalah &8Disk Penggilingan&r. Tidak akan memotong &2Pohon&r atau Batu, melainkan akan memecah &7Blok Logam&r! Bagus untuk &8Perancah Baja&r dan mengikis Oksidasi dari &6Tembaga&r!"]
	quest.7A1E3E7E2DF17AD2.title: "Ammo untuk &2&lGergaji"
	quest.7A271F425C3934CE.quest_desc: ["Saat ini garam ini hanya bisa dibuat dengan membakar 2 &bPlant Salt&r menjadi 1 &bCreature Salt&r (Garam Makhluk Hidup). \\n\\nSemoga di update mendatang kita bisa berburu makhluk hidup demi &bGaram&r ini!"]
	quest.7A271F425C3934CE.title: "&bGaram Makhluk Hidup"
	quest.7A2B26CF0EDAA724.quest_subtitle: "Dibuat di Alloy Smelter"
	quest.7A2B26CF0EDAA724.title: "End Steel Bee"
	quest.7A32C50A6125E566.quest_desc: ["&aSpore Sack&r adalah tentang... tebak apa? &aSpora&r!!! Kemampuan pertamanya melepaskan sebuah &aSpora&r setiap kali kamu terpukul. &aSpora&r tersebut akan terbang berkeliling sampai menempel pada sebuah blok dan meledak saat mob mendekat. \\n \\nKemampuan kedua memungkinkanmu mengumpulkan &aSpora&r. Setiap kali terpukul, 1 &aSpora&r dilepaskan dan 1 disimpan di dalam tas spora untuk digunakan nanti. \\n \\nKemampuan ketiga membolehkan &aSpora&r yang melayang untuk bereproduksi seperti sel; membelah diri dan berlipat ganda! \\n \\nKemampuan terakhir adalah yang terbaik! Dengan menekan Alt Kiri kamu bisa melepaskan semua &aSpora&r yang terkumpul! Ukurannya juga bergantung pada jumlah HP milikmu."]
	quest.7A32C50A6125E566.quest_subtitle: "Ditemukan di Kuil Hutan (Jungle Pyramid)"
	quest.7A32C50A6125E566.title: "&aSpore Sack"
	quest.7A3DD8CAD6A5692D.quest_subtitle: "Red Delicious Apple + Sugar Maple"
	quest.7A41038180C06B00.quest_desc: ["&cKonektor&r adalah apa yang... menghubungkan! Mereka menghubungkan &cKabel&r dari Mesin, ke &cAkumulator&r, ke Generator, dari hampir semuanya! \\n\\nApakah &cKonektor &9Memasukkan &fatau &6Mengeluarkan&r ditentukan oleh konfigurasi apa yang terpasang! \\n\\nMereka juga memiliki penyimpanan &cEnergi&r internal sendiri, Tingkat Tegangan menentukan seberapa banyak."]
	quest.7A41038180C06B00.title: "&cKonektor"
	quest.7A4ABFCD12202A91.quest_desc: ["Operational Potential adalah sumber Energy dari Draconic Evolution. Cara utama (bukan satu-satunya cara) memindahkan OP adalah dengan IO Relay Crystals. Untuk benar-benar memasukkan OP ke item kamu butuh Energy Transfer."]
	quest.7A4ABFCD12202A91.title: "Apa itu Energy atau kita sebut, OP?"
	quest.7A514E27E1A7FE32.quest_desc: ["Diamond juga memungkinkan kita untuk membuat gadget keren untuk membantu membangun menggunakan mod &l&cBuilding Gadgets&r.\\n\\nIni adalah alat hebat untuk membantumu membangun markas yang lebih besar, atau untuk membersihkan area menggunakan &cDestruction Gadget&r.\\n\\nKamu bahkan bisa menghubungkan alat ini ke jaringan AE2 dengan memasukkannya ke dalam Wireless Access Point!"]
	quest.7A514E27E1A7FE32.title: "&l&cBuilding Gadgets"
	quest.7A579E233C69871F.quest_desc: ["&b&lHostile Neural Networks&r itu semua tentang mensimulasikan Mob buat farming Loot mereka! \\n\\nGak banyak lagi selain itu."]
	quest.7A579E233C69871F.title: "&b&lHostile Neural Networks"
	quest.7A615E2A152917AD.quest_desc: ["Buat ini kamu butuh 2 &5Netherite Furnace&r dan 7 kaca yang masing-masing warna Pelangi. &cMerah&r, &6Orange&r, &eKuning&r, &2Hijau&r, &3Biru&r, &9Nila&r- &5Ungu&r, dan &5Vi&r-&dMagenta&r. Yep! Roy G. Bpm lengkap!"]
	quest.7A615E2A152917AD.title: "&zRainbow Core"
	quest.7A873E48E38B5C0E.quest_desc: ["Mesin Baja (Steel) menggunakan uap dua kali lebih banyak daripada mesin Perunggu (Bronze), tetapi mereka mengimbanginya dengan peningkatan kecepatan dua kali lipat."]
	quest.7A89560F303A8BE6.quest_subtitle: "Tingkat: &63"
	quest.7A93F07BE2E6EC97.quest_desc: ["Kalau lagi hujan, lempar &aWeather Container&r bakal manfaatin kekuatan hujan.\\n\\nDengan ini, kamu bisa bikin &9Infinite Water Bucket&r, atau &9Infinite Water Source Block&r. Ini semua item yang sangat berguna!\\n\\nKamu juga bisa lakuin ini buat ilangin hujan!"]
	quest.7A93F07BE2E6EC97.title: "&aHentikan &9Hujan!"
	quest.7A979BEB20C9591E.quest_desc: ["Flux Dust bisa diotomatisasi menggunakan &6Productive Bees&r!\\n\\nRedstone Bee Spawn Egg dapat diubah menjadi Flux Dust Bee Spawn Egg menggunakan Obsidian Bee."]
	quest.7A979BEB20C9591E.title: "Otomatisasi Flux Dust"
	quest.7A9AE63998BB41FF.quest_desc: ["Untuk menentukan kapan spawner akan bekerja, ia akan memilih angka acak antara maximum dan minimum spawn delay. Nilai Minimum bisa serendah 20 hingga setinggi 32.767. Setiap Sugar (gula) akan mengubah min delay naik atau turun sebanyak 10."]
	quest.7A9AE63998BB41FF.title: "Minimum Spawn Delay"
	quest.7AB2FECE47F558F8.quest_desc: ["Stellagmite bisa ditemuin underground di Starlight. \\n\\nKerjanya sebagai Stone biasa bisa dibuat jadi Blok lain. \\n\\nVersi Molten-nya kerja sebagai Magma Block biasa!"]
	quest.7AD9DF3FFCB03495.quest_subtitle: "Tingkat: &a2"
	quest.7ADE214373DE135F.quest_subtitle: "Tingkat: &63"
	quest.7ADE27F9398D97F1.quest_desc: ["Yang ini nggak ada bedanya, ngapain kamu ngecek?"]
	quest.7ADE27F9398D97F1.quest_subtitle: "10"
	quest.7ADE27F9398D97F1.title: "Bee Armor 2"
	quest.7AE1459B0B862737.quest_subtitle: "Cukup di-craft saja"
	quest.7AE1459B0B862737.title: "Time Bee"
	quest.7AE3C8134F5ED726.quest_desc: ["Meningkatkan ukuran stack di dalam Tas sebanyak 16 kali lipat."]
	quest.7AE3C8134F5ED726.title: "&dStack Upgrade Tingkat 4"
	quest.7AE502EDB73BD57A.quest_desc: ["&4&lCrusher&r kerjanya sesuai namanya! Kayak &4Crusher&r di mod-mod lain... \\n\\nKita bisa dapat Dust dari Ingot, &7Cobble&r dari &7Stone&r, dan &2Bio Fuel&r dari &2Tanaman&r! \\n\\nDust bakal dibutuhin buat banyak resep jadi kamu pasti butuh ini. Apalagi buat bikin &8Upgrade&r!"]
	quest.7AE502EDB73BD57A.quest_subtitle: "Alat buat Menghancurkan."
	quest.7AE502EDB73BD57A.title: "&4&lCrusher"
	quest.7AE85F4FF4DDF4F2.quest_desc: ["Kincir Angin adalah pilihan lain yang bisa digunakan dengan Dinamo Kinetik! \\n\\nIni akan otomatis mulai bergerak dan dengan kecepatannya kita mendapatkan Energi, jadi lebih banyak kecepatan lebih banyak Energi. \\n\\nBagaimana mendapatkan kecepatan? Untuk satu, perlu ruang di depannya untuk bekerja. Semakin sedikit blok di depannya, semakin cepat! \\n\\nFaktor lain ke kecepatan adalah Layar Kincir Angin. Bisa menambahkan 8 Layar Kincir Angin total dengan Klik Kanan Blok Kincir Angin tengah dengan Layar di tangan."]
	quest.7AED8FD7FB023AD8.quest_desc: ["Untuk memberikan tenaga pada &4&lThe Harbinger&r kamu butuh Nether Star, yang didapat dari membunuh Wither. \\n\\nIni mekanik &2&lVanilla&r yang seharusnya tidak perlu kujelaskan lagi. \\n\\nLagi pula sudah ada di Bab 1."]
	quest.7AED8FD7FB023AD8.quest_subtitle: "Memberi tenaga pada The Harbinger"
	quest.7AED8FD7FB023AD8.title: "Nether Star"
	quest.7AEE4BE3AB41ED3E.quest_desc: ["Cukup gabungkan &bIgnitium Chestplate&r dengan Elytra... sesimpel itu!"]
	quest.7AEE4BE3AB41ED3E.title: "&bIgnitium Elytra Chestplate"
	quest.7AEFF81E7C8CF300.quest_desc: ["Menggunakan Shift Klik Kanan saat memegang alat atau tongkat JDT akan membuka menu konfigurasi di mana pemain bisa konfigurasi dan aktifkan/nonaktifkan kemampuan."]
	quest.7AF6C95816E82861.quest_desc: ["Mereaksikan &#5B75D4secara kimia&r antara &#8F49C4Deuterium&r dengan &#AABBFAOksigen&r akan menghasilkan &#9C51DBHeavy Water&r. Ini dapat dimasukkan kembali ke dalam &#45BF56Reaktor&r."]
	quest.7B0764DDE94E73D0.quest_desc: ["Di &2&lReaktor&r yang lebih gede kita butuh fail safe yang lebih canggih. \\nBuat yang ini, &2&lReaktor&r harus minimal 5 Blok lebarnya. Itu kasih 3 Blok lebar buat 2 &2FRLA&r. \\n\\nTaro 1 &2FRLA&r di &2&lReaktor&r dan set ke High Temperature atau Damage Critical. Terus, taro yang kedua minimal 1 Blok jauhnya sambil di Y Level yang sama. Yang kedua harus diset ke Activation. \\n\\nSekarang, mari bikin &4Redstone&r! \\n\\nTaro &4Redstone Repeater&r ngadep keluar dari &2FRLA&r pertama. Terus, di mana &4Repeater&r ngadep, taro Blok yang bisa transmit &4Redstone&r. \\n\\nDi Blok itu, taro &4Redstone Torch&r ke arah &2FRLA&r kedua. \\n\\nHabis itu, taro &4Redstone Dust&r di sebelah &4Torch&r, sambil di X/Z Level yang sama dengan &2FRLA&r kedua. Dan terakhir, taro &4Redstone Repeater&r kedua dari &4Redstone Dust&r ke &2FRLA&r kedua."]
	quest.7B0764DDE94E73D0.title: "Fail Safe Canggih"
	quest.7B0CE182D3FE3035.quest_subtitle: "Bunga setinggi 2 blok bisa dibuat dengan MA Essence"
	quest.7B0CE182D3FE3035.title: "Bunga yang dapat dibuat"
	quest.7B0DFA55B4D8B16D.quest_desc: [
		"&a&lTeleporter&r bolehin kita Teleport ke mana aja di dimensi mana pun selama &5Mesin&r-nya sudah dibuat dan punya &aTenaga&r! \\n\\nTerus gimana cara bikin dan kasih tenaganya? \\n\\nPertama, buat bikin &a&lTeleporter&r kita butuh 1 &aTeleporter Block&f dan 9 &aTeleporter Frame&r. \\n\\n&aTeleporter Block&r itu &aController&r utama dari &a&lTeleporter&r. Blok ini yang butuh &aEnergi&r, dan pas sudah &aNyala&r kita bisa buka. Di sini kita bisa setel Jaringan (Network) mirip kayak &5Quantum Entangloporter&r, ketik namanya terus klik tanda centang buat bikin Jaringannya! \\n\\nSekarang pas &a&lStruktur Teleporter&r atau &aTeleporter Block&r lain disetel ke Jaringan itu (dengan klik nama Jaringan di GUI-nya), kamu bisa pakai &a&lTeleporter&r buat pindah ke &a&lTeleporter&r lain di Jaringan yang sama. \\n\\nNah sekarang soal bikin &a&lStruktur Teleporter&r. Taruh satu &aTeleporter Frame&r di tiap sisi &aTeleporter Block&r. Di atasnya taruh lagi 3 buah biar tingginya jadi 4 blok. Dengan sisa 2 blok ruang kosong di atas &aTeleporter Block&r, kamu bisa taruh &aTeleporter Frame&r terakhirmu. \\n\\nSekarang pas sudah ada tenaga dan disetel, &a&lTeleporter&r sudah siap dan kamu bisa jalan ngelewatin Portal warna-warni yang muncul! \\n\\n(Kamu bisa ganti warnanya di GUI &a&lTeleporter&r!)"
		"{@pagebreak}"
		"{image:atm:textures/questpics/mek/meka_portal1.png width:200 height:75 align:center}"
		"Taruh &aTeleporter Block&r terus 2 &aTeleporter Frame&r di sampingnya."
		"{image:atm:textures/questpics/mek/meka_portal2.png width:150 height:125 align:center}"
		"Sekarang taruh &aTeleporter Frame&r di atas yang sebelumnya."
		"{image:atm:textures/questpics/mek/meka_portal3.png width:100 height:125 align:center}"
		"Ulangi."
		"{image:atm:textures/questpics/mek/meka_portal4.png width:100 height:140 align:center}"
		"Sekarang, kita butuh sebaris penuh &aTeleporter Frame&r buat bagian atasnya."
		"{image:atm:textures/questpics/mek/meka_portal5.png width:110 height:150 align:center}"
		"Pas semua sudah beres, Portal pilihanmu bakal muncul kayak gini!"
	]
	quest.7B0DFA55B4D8B16D.quest_subtitle: "Teleportasi Tingkat Tinggi"
	quest.7B0DFA55B4D8B16D.title: "Portal Kustom!"
	quest.7B140A034DF1291C.quest_desc: ["&7&lNexium Emitter&r butuh sesuatu buat gerakin, itu bisa antara &6Mechanical Arm&f atau &6Large Advanced Motor&r! \\n\\nKeduanya gerak, jadi keduanya jalan!"]
	quest.7B140A034DF1291C.title: "&6Mechanical Arm&f atau &6Large Advanced Motor"
	quest.7B1693793419B769.quest_subtitle: "Silver Lime + Cherry"
	quest.7B1818D2C5C2BB18.quest_desc: ["Soulstrider's Pickaxe dapat digunakan untuk melakukan \"vein-mine\" (menambang satu urat bijih sekaligus) pada bongkahan bijih."]
	quest.7B1818D2C5C2BB18.quest_subtitle: "Tingkat: &e5"
	quest.7B2008977702D0C8.quest_desc: ["Saat menghasilkan tekanan di Air Compressor, jika tidak ada tempat penampungan, tekanannya akan hilang begitu saja. Pastikan kamu sudah menyiapkan saluran pipa/mesin sebelum mulai memproduksi tekanan."]
	quest.7B2008977702D0C8.quest_subtitle: "Emang RF atau FE ke mana?"
	quest.7B21D2FAD5F3246A.quest_desc: ["Selamat datang di &b&lIce &fdan &cFire&r! Sekarang di &b&lThe Other&r \\n\\nMod ini nambah banyak banget Monster dan Mob, semuanya entah berhubungan sama Mitologi atau beberapa sepenuhnya unik ke Mod! \\n\\nLo bakal nemuin Monster ini di seluruh &b&lThe Other&r, tapi hati-hati, gak semuanya ramah!"]
	quest.7B21D2FAD5F3246A.title: "&b&lIce &fdan &cFire&r"
	quest.7B3613C01F0B1373.quest_desc: [
		"Untuk menggabungkan &3Vibranium&r dan &6Allthemodium&r, kita harus menjelajahi mod &l&cPowah&r! \\n\\nLetakkan Energizing Orb, lalu pasang Energizing Rod menghadap ke arahnya. Energizing Rod harus diletakkan pada sumber listrik (Power Source) agar bisa mengirimkan energi ke Orb. Jumlah energi yang bisa ditampung dan dikirim ditentukan oleh tingkatannya (Tier). \\n\\nMasukkan Ingot, 2 Piglich Heart, dan satu Compressed Block of Nitro Crystals X1 ke dalam Orb (urutannya bebas). Setelah 1 Miliar FE masuk ke dalam Orb melalui Rod, item tersebut akan siap!\\n"
		"{ \"text\": \"QUESTLINE POWAH\", \"color\": \"#55FF55\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"2A6EBEEBAB882679\" } }"
	]
	quest.7B385FD1CBE02C85.quest_desc: ["Kalo kita pake &9Air&r sebagai &bCoolant&r, kita bakal dapet Steam sebagai produk samping! \\n\\nSekarang apa yang kita lakuin sama itu?"]
	quest.7B385FD1CBE02C85.title: "Steam"
	quest.7B3920DE6306A94A.quest_subtitle: "Mandarin + Kumquat"
	quest.7B40A9DAA119DE59.quest_subtitle: "Crystalline + Neon Cuckoo"
	quest.7B40A9DAA119DE59.title: "Menril Bee"
	quest.7B447E986493AD6B.quest_desc: ["&7Minyak Kreosot&r adalah produk sampingan dari &lCoke Oven&r. \\n\\nPenggunaan utamanya akan untuk membuat Kayu yang Diolah, Blok Bangunan penting dari &8&lIE&r. \\n\\nJuga akan memerlukan untuk Cairan berbeda nanti, akan khawatir tentang itu ketika sampai di sana."]
	quest.7B447E986493AD6B.title: "&7Minyak Kreosot"
	quest.7B4A687EB505C2FF.quest_desc: ["&cCarminite Builder&r, saat ditenagai dengan sinyal Redstone, akan menghasilkan blok sementara ke arah datangnya sinyal.\\n\\n&cCarminite Reactor&r akan mengubah Obsidian dan Netherrack di sekitarnya menjadi &eEmas Palsu&r dan &3Diamond Palsu&r. Setelah beberapa saat, ia akan menyedot blok di sekitarnya dan meledak, menciptakan &cCarminite Ghastling&r di sekelilingnya."]
	quest.7B4A687EB505C2FF.title: "Builder \\& Reaktor &cCarminite"
	quest.7B4AAC741F0A6073.quest_desc: ["Setiap reactor butuh &9Reactor Control Rod&r dan &9Fuel Rod&r. Ini kontrol bagaimana fuel dimasukkan ke reactor.\\n\\nControl Rod ditaruh di sisi atas reactor. Kamu juga bisa punya lebih dari satu per reactor, tapi harus minimal 1. Biasanya, semakin banyak yang kamu punya, semakin banyak fuel yang bisa dipakai dan dibakar reactor. Itu bisa artinya lebih banyak power secara keseluruhan, tapi dengan biaya burn rate lebih tinggi, tergantung setup reactor kamu.\\n\\nUntuk setiap Control Rod, kamu butuh cukup Fuel Rod untuk memanjang ke dasar reactor. Contoh, kalau reactor kamu tinggi 5 blok, kamu butuh 3 Fuel Rod memanjang dari setiap Control Rod.\\n\\nKalau kamu klik kanan Control Rod, kamu bisa kontrol berapa banyak fuel yang dibakar di reactor dengan memasukkan atau menarik fuel rod. Semakin jauh kamu extend rod, semakin sedikit fuel yang akan dibakar."]
	quest.7B4AAC741F0A6073.title: "Reactor Control Rod"
	quest.7B4AF35313D7D779.quest_subtitle: "Tier: &64"
	quest.7B4AF35313D7D779.title: "&6Supreme Machine Frame"
	quest.7B500E0577BDFF8F.quest_desc: ["&6Bronze&r (Perunggu) adalah kombinasi dari &6Tembaga&r dan Timah (Tin). \\n\\nAda lusinan cara berbeda untuk membuat logam paduan ini, aku nggak akan bilang mana cara yang paling benar."]
	quest.7B500E0577BDFF8F.quest_subtitle: "18"
	quest.7B500E0577BDFF8F.title: "&6Bronze Armor"
	quest.7B524DAD8A33BF85.quest_desc: ["Butuh lebih banyak darah dari musuh kamu? Tentu saja!\\n\\n&dVein Sword&r bikin kamu bisa kumpulin lebih banyak darah, plus lebih banyak drop dengan Looting!"]
	quest.7B5A0BFD47D96BDE.quest_desc: ["Digunakan untuk menangkap lebah yang terbang di sekitarnya.\\n\\nKamu bisa pakai Filter Upgrade untuk memilih lebah mana yang ingin ditangkap, atau BaBee Upgrade untuk hanya menangkap bayi lebah."]
	quest.7B5A0BFD47D96BDE.quest_subtitle: "Menangkap Lebah"
	quest.7B5D34650BBD97D9.quest_desc: ["Sangat jarang di Starlight Dimension Meteor Shower mungkin terjadi. \\n\\nKebanyakan waktu Meteor-nya kecil dan hilang sebelum kena tanah. \\n\\nTapi beberapa lebih besar dan bertahan, di sana kamu bakal nemuin Aethersent Ore!"]
	quest.7B72CF322A3C985D.quest_desc: ["&8Obsidian Bee&r yang melakukan polinasi pada &4Redstone Bee Spawn Egg&r akan mengubahnya menjadi &2Flux Dust Bee Spawn Egg&r."]
	quest.7B72CF322A3C985D.title: "Flux Dust Bee"
	quest.7B76EC62E3F7E12C.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_aethersent.png width:100 height:150 align:center}"]
	quest.7B76EC62E3F7E12C.title: "&5Aethersent&r"
	quest.7B7D1F0CB326B28F.quest_desc: ["&bME IO Port&f memungkinkan pemindahan isi penyimpanan digital dengan cepat antara cell dan media penyimpanan eksternal yang terhubung ke bus jaringan."]
	quest.7B7D1F0CB326B28F.quest_subtitle: "Defragmentasi"
	quest.7B7D1F0CB326B28F.title: "ME IO Port"
	quest.7B9486981786AC47.quest_desc: [
		"&lTipe Kemampuan:&r Aktif"
		""
		"&lFungsi Kemampuan:&r"
		""
		"Permanen menghapus kecerdasan dari monster di sekitar, karena biaya tenaga hanya bisa mempengaruhi lima monster maksimal per aktivasi, punya cooldown sangat panjang."
	]
	quest.7B9672C4FCFFB887.quest_desc: ["&9Cetak Biru&r ini bisa Dibuat dan wow murah! \\n\\nTanda Peringatan adalah dekorasi yang sangat sederhana yang bisa dibuat dengan &7Pelat Logam&r, Pewarna, dan &9Cetak Biru&r ini."]
	quest.7B9672C4FCFFB887.title: "&9Cetak Biru Tanda Peringatan"
	quest.7B99AA20DC55263C.quest_subtitle: "Lead + Silver"
	quest.7B99AA20DC55263C.title: "Antimony Bee"
	quest.7B9F5EEC76FDD0D4.title: "Draconic Damage Module"
	quest.7BC289DEF023FEAA.quest_subtitle: "Tingkat: &63"
	quest.7BC616DDB5933479.quest_desc: ["Yang ini bisa dibuat dengan &5Blood Vial&r dan bahan normal buat Scroll. \\nKamu harus pastiin ini Level 10 dan &6Legendary&r yang bisa kamu upgrade."]
	quest.7BC616DDB5933479.title: "&4Wither Skull Scroll"
	quest.7BC8F50A89A3BE1A.quest_desc: ["Ini hanya digunakan untuk Menghubungkan &cLaser Node&r satu sama lain dan ke Connector. Tidak terlalu penting, aku hanya ingin tetap memakai tema Kunci Inggris (Wrench). \\n\\nIni juga berfungsi sebagai Wrench untuk konfigurasi lainnya!"]
	quest.7BC8F50A89A3BE1A.title: "Laser Wrench"
	quest.7BCD4A425CF6199B.quest_desc: ["Setelah membantai Goat of Mercy yang dipanggil dari &9Xeovrenth Adjure&r, kamu akan mendapatkan Cruelty Essence. Gabungkan ini dengan Biji Kakao (Cocoa Beans) untuk menciptakan Brown Chalk."]
	quest.7BCD4A425CF6199B.title: "&#4E2C00Brown Chalk (Kapur Cokelat)"
	quest.7BCE96070C36D547.quest_subtitle: "&f7.5 &cAttack Damage"
	quest.7BFC24607189B6D0.quest_desc: ["Membuatmu berenang lebih cepat."]
	quest.7BFC24607189B6D0.quest_subtitle: "Maks: 1"
	quest.7BFE7DAF18981843.quest_subtitle: "Dibutuhkan untuk resep Drill"
	quest.7C07D6A33F7ADB02.quest_desc: [
		"Ini adalah upgrade tas agar kamu bisa memasukkan tas ke dalam tas."
		""
		"Jadi kamu bisa membawa tas di dalam tasmu saat kamu butuh tas yang ada di dalam tasmu."
	]
	quest.7C07D6A33F7ADB02.quest_subtitle: "Tas di dalam Tas?"
	quest.7C0F7A1B3AB9A1A1.quest_subtitle: "Lebih Banyak Opsi Filter"
	quest.7C0F7A1B3AB9A1A1.title: "&eAdvanced Refill Upgrade"
	quest.7C169A4A39F37FAC.quest_desc: ["Bersama sarang lebah vanilla, kita buat &eAdvanced Beehive&r. Bisa pakai jenis kayu apa pun.\\n\\nLebah akan masuk-keluar sarang ini secara otomatis dan menaruh Honeycomb di inventarisnya. Kamu juga bisa memasukkan botol kaca untuk dapat Honey Bottle.\\n\\nKita butuh banyak sarang madu untuk membuat treat!"]
	quest.7C169A4A39F37FAC.quest_subtitle: "Nggak perlu repot mencukur sarang lagi."
	quest.7C169A4A39F37FAC.title: "Advanced Beehive"
	quest.7C1D407CF67786F6.quest_desc: ["&fAir Armor&r dari mod &d&lArs Elemental&r!"]
	quest.7C1D407CF67786F6.quest_subtitle: "15"
	quest.7C1D407CF67786F6.title: "&fAethermancer Outfit"
	quest.7C2ED69E07988DF4.quest_desc: ["Kursi &2&lMinecraft&r yang orisinal: tangga. \\n\\nSelamat datang di &2&lMinecraft&r Modded, kita punya jauh lebih banyak dari sekadar tangga untuk dekorasi. \\n\\nAda lusinan mod yang menambahkan dekorasi dan bahkan lebih banyak lagi yang menambahkan item yang bisa digunakan sebagai dekorasi!"]
	quest.7C2ED69E07988DF4.title: "Dekorasi!"
	quest.7C3D763CF22D167A.quest_desc: ["Starlight Charger bisa \"menyihir\" material dengan efek \"Star Charged\".\\n\\nSebuah struktur harus dibangun dengan Starlight Charger di tengahnya yang menghadap langsung ke langit malam. Alat ini hanya mendapatkan Starlight Power saat malam hari.\\n\\nCharger harus diletakkan di tengah struktur 7x7, dengan satu Pilar di setiap sudutnya. Setiap pilar harus memiliki \"Starlight Charger Cap\".\\n\\nProses ini juga membutuhkan satu katalis charger untuk setiap material."]
	quest.7C3D763CF22D167A.quest_subtitle: "\"Menyihir\" Material"
	quest.7C3D763CF22D167A.title: "&dStarlight Charger"
	quest.7C3F65B5DAC7E57B.quest_desc: ["&dShadow Glaive&r lebih mirip senjata daripada &6Relic&r. Kemampuan pertamanya adalah melempar 1 &dGlaive&r. Setelah mengenai mob, ia akan memantul ke mob lain, dan mungkin kembali padamu. Kamu bisa meng-upgrade-nya untuk damage lebih besar, pantulan lebih banyak, dan pengisian daya lebih cepat. \\n \\nKemampuan keduanya menggunakan semua muatannya untuk melepaskan &dgergaji&r raksasa! Sangat keren, aku sarankan untuk mencobanya!"]
	quest.7C3F65B5DAC7E57B.quest_subtitle: "Ditemukan di End City dan End Ship"
	quest.7C3F65B5DAC7E57B.title: "&dShadow Glaive"
	quest.7C4D8AA107780795.quest_desc: ["Pakai &aFluidizer&r, kita bisa gabungin &dBlutonium&r dengan &eYellorium&r untuk bikin &2Verderium.\\n\\nSaat dipakai sebagai fuel di reactor, &2Verderium&r produksi &cRossinite&r sebagai reactant. Kita butuh ini!\\n\\nBuat pakai &2Verderium&r sebagai fuel, kamu perlu bikin &cFuel Injection Port&r untuk reactor kamu.\\n\\nCatatan: Kamu mungkin perlu kosongin fuel yang sekarang di reactor, atau bikin reactor baru untuk tujuan ini. "]
	quest.7C4D8AA107780795.title: "Rossinite"
	quest.7C4E4793DA887DE4.quest_desc: ["Berdasarkan mod original &eBig Reactors&r, &aExtreme Reactors&r memungkinkan kamu bangun Reactor multiblock yang bisa dikustomisasi!\\n\\nElemen utama tentu saja, Uranium. Kamu butuh ini dan banyak coal dan iron untuk mulai bangun.\\n\\nKalau pernah tersesat di sepanjang jalan, lihat &aThe Extreme Book&r untuk bantuan! "]
	quest.7C4E4793DA887DE4.quest_subtitle: "Ini gak bisa dimakan... percaya deh"
	quest.7C4E4793DA887DE4.title: "Selamat Datang di &9Extreme Reactors&r!"
	quest.7C54581562D2EA75.quest_desc: ["Speed Module seru, bekerja di hampir semua hal dan membuat mereka lebih cepat! Sword swing lebih cepat, Pickaxe mine lebih cepat, Axe chop lebih cepat, Bow shoot lebih cepat, dan Chestplate membuatmu lebih cepat. Semakin baik Speed Module semakin cepat! (BTW waktu yang baik untuk menyebutkan kebanyakan stat stack. 2 Basic Speed Module meningkatkan Speed 20%% lalu!)"]
	quest.7C54581562D2EA75.title: "Basic Speed Module"
	quest.7C5FC2015F1E6DB1.quest_desc: ["Semua &8Troll&r bakal pegang Senjata. Mereka pake &8Senjata&r ini buat coba Bunuh kamu. \\n\\nSangat jarang mereka bakal Drop &8Senjata&r mereka pas Mati. \\n\\nSemua &8Senjata&r ini gede banget! Tapi Player tetep bisa Pegang dan Pake! Mereka kasih Damage banyak tapi sangat lambat buat Ayun."]
	quest.7C5FC2015F1E6DB1.title: "&8Senjata Troll"
	quest.7C651B90A738323E.quest_desc: ["Jangan tertukar dengan Awakened Supremium Bee."]
	quest.7C651B90A738323E.quest_subtitle: "Draconic Fusion Crafting"
	quest.7C651B90A738323E.title: "Awakened Bee"
	quest.7C687DCF71D77761.quest_desc: ["&c&lAdvanced&r itu upgrade-an dari &a&lBasic&r. \\n\\nMesin &c&lAdvanced&r bisa nampung lebih banyak &eItem&f, pindahin lebih banyak &eItem&r, dan punya slot lebih banyak dibanding &a&lBasic Tier&r. \\n\\n&c&lAdvanced&r dibuat dari &cInfused Alloy&f, &cAdvanced Control Circuit&f, dan biasanya pakai &7Osmium&r! \\n\\n&cAdvanced Control Circuit&r dibuat pakai 2 &cInfused Alloy&r dan satu &aBasic Control Circuit&r."]
	quest.7C687DCF71D77761.title: "&c&lAdvanced Tier"
	quest.7C73740F1B515F2C.quest_desc: ["&#C452C4Tungsten Dust&r perlu dihancurkan menjadi varian yang jauh lebih kecil agar bisa diproses."]
	quest.7C758209D06ED0E3.quest_desc: ["Dengan menggabungkan satu &4Infused Hellshelf&r dengan &eGlowstone&r, kita bisa membuat &4Glowing Hellshelf&r! \\n\\nRak ini memiliki &aEterna&r dan &cQuanta&r yang sama, tapi memberikan &53% Arcana&r. \\n\\nIni akan membantu dalam proses &d&lInfusion&r nanti, seperti jika kita ingin menggunakan 12 buah rak ini untuk melakukan &d&lInfuse&r pada &9Dormant Deepshelf&f menjadi &9Deepshelf&r asli!"]
	quest.7C758209D06ED0E3.title: "&4Glowing Hellshelf"
	quest.7C79BCE482A06199.quest_desc: ["&b&lIce&r adalah tentang Spell musim Dingin. Menggunakan &bEs&r dan &bSalju&r untuk mendinginkan dan menyakiti musuh. \\n\\n&b&lIce&r menggunakan &bFrozen Bone&r sebagai Material Fokusnya yang merupakan drop dari &bStray&r. Kamu bisa menggunakan itu untuk craft &bIce Rune&r atau membunuh &b&lCryomancer&r untuk mendapatkannya. \\n\\n&bScroll&r-nya berwarna &bBiru Muda&r dengan teks &9Biru Gelap&r."]
	quest.7C79BCE482A06199.title: "&b&lIce"
	quest.7C7BD54624ED9AC2.quest_desc: ["Beneran cuma Creative Flight. \\n\\nGak bisa dipake sama &cJetpack &7Unit&r dan iya bakal pake &aEnergi&r buat Terbang! \\n\\nDi Config bisa naikin seberapa cepet lo Terbang."]
	quest.7C7BD54624ED9AC2.quest_subtitle: "Bodyarmor"
	quest.7C7BD54624ED9AC2.title: "&dGravitational Modulating &7Unit"
	quest.7C7C0D3D7FCB0297.quest_desc: ["Bisa ditemukan di struktur di &6&lBumblezone&r atau ditukar dengan &5Bee Queen&r! \\n\\n&6L&8e&6b&8a&6h&r memiliki cara unik untuk saling menemukan dan berkomunikasi. Aku tidak tahu bagaimana mereka melakukannya, jadi aku asumsikan saja antena mereka mengirim dan menerima sinyal radio. \\n\\nSambil memakai Stingless Bee Helmet, kamu bisa menekan Shift untuk menyoroti (highlight) semua &6L&8e&6b&8a&6h&r di sekitarmu. \\n\\nJuga saat memakainya, efek racun dan mual akan hilang lebih cepat."]
	quest.7C848C7011726470.quest_desc: ["&cEye of Monstrous&r akan menuntunmu ke &cSoul BlackSmith&r untuk melawan &c&lNetherite Monstrosity&r."]
	quest.7C848C7011726470.title: "&cEye of Monstrous&r"
	quest.7C8CDD259495A31A.quest_desc: ["&eTerowongan&r pada dasarnya akan menutup &eSabuk&r-mu. Ini membuat &eItem&r tidak bisa diambil, dan semoga Mob tidak kabur. \\n\\nKalau kamu menaruh &eSabuk&r lain yang bergerak tegak lurus terhadap &eSabuk&r tempat &eTerowongan&r berada, &eTerowongan&r akan memfilter 1 &eItem&r dari tumpukan ke &eSabuk&r tegak lurus tersebut, sementara sisanya tetap di &eSabuk&r pertama. \\n\\nKalau hanya ada 1 &eItem&r, ia akan bergerak melewati &eTerowongan&r seperti biasa."]
	quest.7C8CDD259495A31A.title: "&eTerowongan Andesit"
	quest.7C90008081DEBECA.quest_desc: ["Kamu punya &ePeralatan&r dan kamu punya &aGem&r... jadi gimana cara menggabungkannya? \\n\\nPertama, pastikan peralatanmu punya &9Socket&r yang kosong. (Untuk info lebih lanjut soal &9Socket&r, cek bagian Sigil). \\n\\nJika ada slot kosong, kamu bisa menggabungkan peralatan dan &aGem&r tersebut di &8&lSmithing Table&r. \\n\\nJika kamu nggak puas dengan &aGem&r-mu saat ini, mungkin kamu butuh Meja (Table) yang berbeda!"]
	quest.7C90008081DEBECA.title: "Memasang &aGem&r (dan lainnya)"
	quest.7C9154EF6068BE27.quest_desc: ["Secara teknis, kamu juga bisa pakai Crusher buat ngancurin &6&lATM Star&r jadi 5 &6Star Shard&r... \\n\\nTapi masalahnya, kamu butuh 262 biji buat bikin &6&lStar&r baru... \\n\\nJadi... buat apa?"]
	quest.7C9154EF6068BE27.title: "Tapi kenapa?"
	quest.7C94F6AE2A793858.title: "&eKomponen Penyimpanan 1024k"
	quest.7C9D9D1C054874A7.quest_desc: ["Pernah menginginkan &5Enchantment&r yang paling sempurna? Seperti, semua statistik maksimal, semua enchant bagus tersedia? Kalau begitu, kamu butuh ini! \\n\\nPertama, siapkan 5 &9Soul-Touched Sculkshelf&r dan 5 &9Echoing Sculkshelf&r. Ini akan memberikan semua &cQuanta&r dan &5Arcana&r yang kita butuhkan! \\n\\nKedua adalah &dDraconic Endshelf&r yang akan memberikan &a100 Eterna&r, baik dalam jumlah poin maupun level maksimalnya. \\n\\nKetiga adalah &6Geode-Encased Bookshelf of Stability&r, ini akan memastikan &cQuanta&r tidak mengkhianati kita dengan memberikan &5Enchantment&r yang buruk! \\n\\nTerakhir ini opsional tapi sangat disarankan: &6Deepshelf of Arcane Treasures&r. Rak buku itu memungkinkan kita mendapatkan &5Enchantment&r yang biasanya tidak tersedia, seperti &5Mending&r!"]
	quest.7C9D9D1C054874A7.title: "Setup Enchanting Terbaik"
	quest.7CA60DC31447E57A.quest_subtitle: "&f7 &cAttack Damage"
	quest.7CB03F92F9ECEFFB.quest_desc: ["Untungnya &6&lApotheosis&r telah mempermudah cara mencopot &aGem&r dari &9Socket&r! \\n\\nSekarang kamu tidak perlu lagi memilih antara menyelamatkan peralatannya atau gem-nya; kamu bisa menyimpan keduanya. \\n\\nGunakan &aSigil of Withdrawal&r dengan &eAffixed Tool&r di &8&lSmithing Table&r dan kamu akan memisahkan &aGem&r dari peralatan tersebut."]
	quest.7CB03F92F9ECEFFB.title: "&aSigil of Withdrawal"
	quest.7CBAA67204CC258C.quest_desc: ["Tidak, &9&lWarden&r tidak pakai Sword dan Axe. Tapi kita bisa! \\n\\nBaik &9Warden Sword &fmaupun &9Axe&r adalah upgrade dari versi &cNetherite&r-nya dengan &9Reinforced Echo Shard &fdan &9Warden Upgrade Template&r. \\n\\nMasing-masing punya 1 &4Heart&r Damage lebih dan bahkan lebih banyak Durability! \\n\\nYa, Axe-nya masih bisa efisien menebang Pohon."]
	quest.7CBAA67204CC258C.title: "Senjata &9Warden&r"
	quest.7CBAD1047B087803.quest_desc: [
		"Sekarang setelah kamu memiliki &eclumps&r, menggunakan fluid addon pada centrifuge akan memungkinkanmu untuk memasukkan &aSulphuric Acid&r (Asam Sulfat) ke dalamnya. Ketika &eclumps&r diproses dengan asam ini, kamu akan mendapatkan permata (gems)."
		""
		"Sebagai alternatif, kamu bisa menggunakan &9Air&r namun dengan hasil yang lebih sedikit."
		""
		"&l&o&nCatatan&r"
		""
		"Saat ini, beberapa resep sedang bermasalah di mana hasilnya berupa debu (dust) atau nugget."
	]
	quest.7CBAD1047B087803.quest_subtitle: "Mengolah clump di centrifuge menghasilkan permata....?"
	quest.7CBAD1047B087803.title: "Memutar Menjadi Permata"
	quest.7CBEBBCB9D95D11A.quest_desc: ["&5Abyssal Egg&r juga merupakan drop dari &5&lThe Leviathan&r, sepertinya kamu baru saja membunuh indukan yang sedang hamil. \\n\\nLetakkan Telur ini, tunggu sebentar dan kamu akan punya &5Leviathan&r bayi sendiri. \\n\\nSetelah menetas, kamu bisa memberinya banyak Ikan Tropis untuk menjinakkannya. \\n\\nBayi ini punya 2400 &4HP&r dan bisa disembuhkan dengan memberinya Ikan Tropis. \\n\\nSetelah jinak, ia bisa di-Shift+Klik Kanan untuk mengatur apakah ia mengikuti, diam, atau berkeliaran. \\n\\nBayi ini punya 2400 &4HP&r dan bisa disembuhkan dengan memberinya Ikan Tropis. \\n\\nSetelah jinak, ia bisa di-Shift+Klik Kanan untuk mengatur apakah ia mengikuti, diam, atau berkeliaran."]
	quest.7CBEBBCB9D95D11A.title: "Abyssal Egg"
	quest.7CBF22CCCF599F26.quest_desc: ["Buat bikin &cSeruling Siren&r kamu butuh &bSisik Mengkilap&r yang disebutin sebelumnya, plus &cAir Mata Siren&r. \\n\\n&cAir Mata Siren&r adalah Drop langka dari &cSiren&r dan bakal bikin &cSeruling&r atau Banner. \\n\\n&cSeruling Siren&r pada dasarnya bakal kasih Weakness 1 Juta ke Mob yang kamu liat. Mereka bakal jatuh Cinta, dan pas Cinta mereka gak bakal Nyerang kamu. \\n\\n&cSeruling&r-nya ada Cooldown."]
	quest.7CBF22CCCF599F26.title: "&cSeruling Siren"
	quest.7CC49360D07086B8.quest_desc: ["&o\"Lewat penggunaan Permesinan Atom yang sangat detail, kita bisa memecah semua materi sampai ke tingkat molekul dan memindahkan molekul tersebut melalui panjang gelombang tertentu...\"&r Aduh elah, ini mah Sihir! \\nDengan 2 &5Quantum Entangloporter&r kita bisa mindahin &eItem&f, &bCairan&f, &cChemical&f, & Panas&f, dan &aEnergi&r secara nirkabel (wireless)! \\n\\nPertama, kita harus hubungin &5Quantum Entangloporter&r-nya. Caranya masuk ke Bar Teks di salah satunya, terus ketik nama Jaringannya. \\n\\nBisa angka, huruf, simbol, apa pun asal diketik terus tekan tombol centang! Terus, pergi ke &5Quantum Entangloporter&r kedua dan klik nama Jaringan yang sudah dibuat tadi. Sekarang mereka sudah terhubung. \\n\\nHabis itu, hubungin &bPipes&f, &cTubes&f, &aCables&r atau apa pun ke salah satu &5Quantum Entangloporter&r terus taruh satu lagi atau bahkan &5Mesin&r ke yang satunya. \\n\\nPas sudah siap semua, ganti Side Config-nya biar bisa mindahin barang-barang kita. Jangan lupa setel Auto-Eject!"]
	quest.7CC49360D07086B8.quest_subtitle: "Listrik, Gas, Cairan, Semuanya Wireless."
	quest.7CC49360D07086B8.title: "&5Quantum Entangloporters"
	quest.7CC96CE9901F25BB.quest_desc: ["&l&5Forbidden and Arcanus&r adalah mod sihir lainnya, yang satu ini berfokus pada struktur Multiblock bernama Hephaestus Forge.\\n\\nUntuk membuatnya, ikuti instruksi pada tooltip forge tersebut! Setelah jadi, kamu bisa memberinya 4 material untuk memperkuat ritual: Aureal, Soul, Blood, dan Experience.\\n\\nKamu juga perlu meningkatkan Forge tersebut melalui ritual (semuanya bisa ditemukan di JEI)."]
	quest.7CE86300AF8E9BCA.quest_desc: ["Craft 8 Generator yang sama bareng dengan Echo Shard combine jadi 1 Generator gede! Kerja sama kayak 8 generator biasa tapi cuma butuh space 1 aja."]
	quest.7CE86300AF8E9BCA.title: "8x Mantap!"
	quest.7CF13A4941F608E5.quest_desc: ["Mulai dari kaca normal, kaca dengan bingkai, sampai ke mosaik!"]
	quest.7CF13A4941F608E5.title: "Kaca &l&bChipped&r"
	quest.7CFA92CC48D1E7E3.quest_subtitle: "Tingkat: &c5"
	quest.7CFEE836C68B3903.quest_subtitle: "&f7.5 &cAttack Damage"
	quest.7D086BC5AC152E27.quest_desc: ["&cSiren&r pas Mati bakal Drop &3Pecahan Prismarine&f, &3Kristal&f, dan... &bSisik Mengkilap&r!!! \\n\\n&bSisik Mengkilap&r bisa dipake buat Craft beberapa Item, termasuk: &9Armor Penjaga Pasang&f, &cSeruling Siren&f, dan &9Potion Water Breathing&r. \\n\\nGue seneng mereka banyak banget!"]
	quest.7D086BC5AC152E27.title: "&bSisik Mengkilap"
	quest.7D0AE6FCB0996218.quest_subtitle: "Teak + Ipe"
	quest.7D159D333B2AC57E.quest_desc: [
		"500 Juta OP? Check. Fuel? Check. Heat di 2000 C? Check. Tinggal klik tombol activate dan berdoa tidak Meltdown!"
		"{image:atm:textures/questpics/draconic/draconic_reactor_on_down.png width:200 height:100 align:1}"
		"{image:atm:textures/questpics/draconic/draconic_reactor_on_up.png width:150 height:150 align:1}"
	]
	quest.7D159D333B2AC57E.quest_subtitle: "Sekarang kita berdoa dan berharap..."
	quest.7D159D333B2AC57E.title: "Mengaktifkan Reactor"
	quest.7D1A27CBF1508712.quest_desc: ["&3Snow Queen&r tinggal di &bAurora Palace&r di dalam Glacier Biome. \\n\\nKamu harus bunuh Alpha Yeti buat masuk Glacier Biome. \\n\\nSetelah dikalahkan, dia bakal drop banyak loot, termasuk Trophy!"]
	quest.7D1A27CBF1508712.title: "&eTrophy &3Snow Queen"
	quest.7D1D2A4E07E98709.quest_desc: ["Penghancur balok sederhana yang membutuhkan alat untuk menghancurkan balok."]
	quest.7D220876E8FF7AED.quest_desc: [
		"&#65C2A6Unpacker&r memiliki banyak kegunaan, mulai dari mengurai &#53E67BBlok kembali menjadi Ingot&r hingga &#53E67Bmendaur ulang komponen&r mesin."
		""
		"&oKamu bahkan bisa mendapatkan Ingot Silikon dengan lebih mudah melaluinya.&r"
	]
	quest.7D279FC39DA5C630.quest_desc: ["Kita belom selesai sama &cSulfur Trioxide&r! Kita butuh Water Vapor buat proses lebih lanjut. \\n\\nBuat dapet Water Vapor kita bisa pake &c&lRotary &bCondensator&r buat ubah &9Air&r jadi Water Vapor! \\n&cInfusing&r lagi! Gabungin Water Vapor dengan &cSulfuric Trioxide&r buat bikin &aSulfuric Acid&r. \\n\\nSekarang udah jadi Acid... tapi belom yang bener... \\n\\nOh iya, kita butuh &dFluorite&r yang bisa dari Nambang Ore. Terus, pake &3&lChemical Dissolution Chamber&r buat encerkan &aSulfuric Acid&r dengan &dFluorite&r buat akhirnya dapet &7Hydrofluoric Acid&r!"]
	quest.7D279FC39DA5C630.title: "&cSulfur Trioxide&r jadi &7Hydrofluoric Acid"
	quest.7D359283625C1869.quest_desc: ["&4&lCataclysm&r adalah Mod petualangan yang semua tentang nambah Boss baru! Dan semua dari dan sekitar mereka! \\n\\nKamu bakal nemuin Struktur di sekitar &2&lOverworld&r, &4&lThe Nether&r, dan &5&lThe End&r. \\n\\nDi dalam bakal ada Mob baru, Miniboss, dan Boss yang sangat susah. Kamu bisa bunuh semua buat dapetin Senjata, Armor, dan Item baru!"]
	quest.7D359283625C1869.title: "&4&lCataclysm"
	quest.7D38BC3DB3406F51.quest_desc: ["Dengan Wooden Pickaxe, batu seharusnya tidak masalah untuk dipecahkan!\\n\\n&3Cobblestone&r membuka bagian progres selanjutnya dengan memungkinkan craft Furnace untuk smelt ore.\\n\\nJuga ingin upgrade pickaxe ke stone untuk menambang ore lebih baik seperti &bIron&r!"]
	quest.7D38BC3DB3406F51.title: "Zaman Batu"
	quest.7D40B80DBBC4E160.quest_desc: ["Manual Rolling Machine akan menjadi alat crafting utamamu untuk berbagai material Railcraft! \\n\\nJika kamu memasukkan resep dan hasilnya bisa lebih dari 1, ia akan melakukan autocraft selama kamu melihat antarmukanya. Jika kamu menutup jendela mesin saat proses berlangsung, crafting akan dibatalkan. \\n\\nKamu harus menyusun resep terakhir secara manual!"]
	quest.7D43016926E77150.title: "&9Armor Imperium&r"
	quest.7D52DD751DDADA1B.quest_desc: ["Kabel dasar untuk mentransfer daya."]
	quest.7D57A14810BC0CBE.quest_desc: [
		"Setelah menggunakan &bBurning Ashes&r pada &bAltar of Flame&r, kamu akan memanggil &b&lIgnis&r. \\nIa punya 11.250 &4HP&r serta &bPedang&f dan &bPerisai&r raksasa. \\n\\n&bPerisai&r-nya akan menahan damage darimu dan &bPedang&r-nya digunakan untuk menebas serta menusukmu. Jika tertusuk, kamu tidak bisa bergerak, hanya bisa menyerang. \\n\\nIa bisa menerjangmu, dan saat melakukannya ia akan menghantamkan &bPerisai&r-nya ke tanah memicu Shockwave yang akan melontarkan blok dan dirimu ke udara. Ia bisa melakukan hal yang sama dengan pedangnya tanpa perlu menerjang. \\n\\nSerangan lainnya adalah bola api (&bFireball&r). Ia akan melempar 3 bola api ke udara yang akan meluncur ke arahmu! Pukul balik bola itu seolah-olah itu adalah bola api Ghast. \\n\\nSaat HP-nya mencapai sekitar 7.500, ia akan berubah warna menjadi &bbiru muda&r. Sekarang ia menyerang lebih cepat, damage lebih sakit, dan punya efek Lifesteal (menyedot darah). \\n\\nBola apinya juga tidak akan bisa dipantulkan lagi dan ia sekarang bisa memicu berbagai jenis Shockwave!"
		"{image:atm:textures/questpics/cataclysm/cataclysm_ignis.png width:100 height:100 align:center}"
	]
	quest.7D57A14810BC0CBE.title: "&b&lIgnis&r"
	quest.7D67058592EE5958.quest_desc: ["Meriam akan membangun struktur dari Skematik, mengambil material dari peti terdekat dan menggunakan bubuk mesiu sebagai bahan bakar."]
	quest.7D690A7D0FF6E328.title: "Katalis Grader Tingkat 3"
	quest.7D6B4AEF806AF62E.quest_desc: ["100% terlalu kencang! Hati-hati jangan sampai mati!"]
	quest.7D6B4AEF806AF62E.quest_subtitle: "Maks: 1"
	quest.7D7983F39E6E818D.title: "Tingkat: &9Niotic"
	quest.7D7BD1458CF12021.quest_desc: ["Ini Gurun tentu ada Kaktus! \\n\\nKaktus kalau udah sepenuhnya tumbuh bisa numbuh Buah di atasnya!"]
	quest.7D7DC3C695CD7236.quest_subtitle: "Silver Lime + Spruce"
	quest.7D7E4C31DFE59E29.quest_desc: ["Module ini hanya untuk DE Bow, tidak seperti yang sebelumnya. Projectile Damage Module meningkatkan damage Arrow yang ditembakkan oleh Bow. Beberapa Module kebetulan punya efek negatif dengannya, seperti ini memberikan sedikit lebih Ketidakakuratan ke Bow. Semua ini bisa stack!"]
	quest.7D7E4C31DFE59E29.title: "Wyvern Projectile Damage Module"
	quest.7D81F2381516204D.quest_subtitle: "Dibutuhkan untuk PCB Jadi"
	quest.7D81F2381516204D.title: "Transistor"
	quest.7D972A3C4211EB26.quest_desc: ["&zRainbow Coal&r didapetin dengan meledakin &zRainbow Furnace&r."]
	quest.7D972A3C4211EB26.title: "&zRainbow Coal"
	quest.7DA48EDCF28DBE03.quest_subtitle: "Ginkgo + Hazel"
	quest.7DA8ACE06DE8097F.quest_desc: ["&6Copper&r (Tembaga) adalah bijih yang paling melimpah di &2&lMinecraft&r dan kegunaan utamanya adalah untuk dekorasi. \\n\\nSudah ada banyak varian yang ditambahkan oleh &2&lMinecraft&r, tapi &l&bChipped&r merasa itu belum cukup! Jadi kita dapat lebih banyak lagi! \\n\\nBahkan varian untuk versi yang teroksidasi. \\n\\nKamu bisa membuat blok &aEmerald&r palsu."]
	quest.7DA8ACE06DE8097F.title: "Tembaga &l&bChipped&r"
	quest.7DABD82393713B5A.quest_desc: ["&c&lLuminax&r adalah mod yang sangat simpel. Kamu suka lampu berwarna? Kamu bisa punya lampu berwarna. \\n\\nSemuanya satu warna tanpa tekstur dan hadir dalam berbagai bentuk seperti Tangga atau Slab atau bahkan Pressure Plate! \\n\\nMereka bahkan berfungsi dengan &l&cDy&6en&ea&ami&bcs&r!"]
	quest.7DABD82393713B5A.title: "&l&cLuminax"
	quest.7DAED14CEC4CDA51.quest_desc: ["&aNature's Aura&r adalah mod sihir tentang penggunaan dan pemulihan &aAura&r. Quest ini akan membahas beberapa dasar-dasarnya.\\n\\nUntuk memulai, buatlah &eBrilliant Fiber&r yang dibuat dari &eGold Nugget&r, &adaun&r, dan &arumput&r. Klik Kanan pada daun apa pun menggunakan &eBrilliant Fiber&r akan mengubahnya menjadi &eGolden Leaves&r.\\n\\nPastikan untuk membaca &aBook of Natural Aura&r, kamu juga bisa menggunakannya untuk melihat cara membangun struktur multiblock di mod ini."]
	quest.7DAED14CEC4CDA51.title: "&eSelamat Datang di &aNature's Aura"
	quest.7DD638E4111D66E7.quest_desc: ["&8Advanced Storage Housing&r diperlukan untuk men-craft &9Storage Disk&r tingkat tinggi."]
	quest.7DD638E4111D66E7.title: "&8Advanced Storage Housing"
	quest.7DE2154159D273C3.quest_desc: [
		"&3Vibranium Armor&r adalah peningkatan dari &6AllTheModium Armor&r. \\n\\nKita mendapatkan peningkatan untuk setiap statistik! Sekarang mendapatkan 32 Armor Point, 36 Armor Toughness, dan 80% Knockback Resistance. \\n\\nSayangnya kita tidak mendapatkan efek atau kemampuan baru... tapi kita mendapatkan lebih banyak &dMagic Damage Resistance&r! Sekarang di angka 75%!"
		"{image:atm:textures/questpics/allthemodium/all_armor_vib.png width:100 height:175 align:center}"
	]
	quest.7DE2154159D273C3.title: "&3Vibranium Armor"
	quest.7DFF18CFEB0B8DBE.quest_desc: ["Kamu harus mulai nanem &aInferium&r secepat mungkin!\\n\\nWalaupun gak wajib buat nanem benih ini, kamu juga bisa bikin &eLahan Pertanian Essence&r yang bakal nambah kecepatan tumbuh benih (khususnya Benih Inferium). Tapi, benih tertentu bakal butuh lahan pertanian tertentu buat ditanem."]
	quest.7DFF18CFEB0B8DBE.title: "&aLahan Pertanian Inferium"
	quest.7E07C5A6FA6B6B1F.quest_desc: [
		"Setelah kamu bangun &aReprocessor&r yang berfungsi penuh, kamu bisa pompa power, air, dan &9Cyanite&r untuk bikin &dBlutonium&r."
		""
		"Ini bisa dipakai sebagai fuel untuk reactor kamu, dan bikin waste sendiri yang disebut &9Magentite&r. "
	]
	quest.7E07C5A6FA6B6B1F.title: "Blutonium"
	quest.7E13007340A818C5.quest_desc: ["Ini adalah Pillar Cap Tingkat 1 untuk Starlight Charger."]
	quest.7E13007340A818C5.title: "Pillar Cap Starlight Charger Tingkat 1"
	quest.7E373212AE6B27D0.quest_subtitle: "Infusion Crafting"
	quest.7E373212AE6B27D0.title: "Insanium Bee"
	quest.7E39FB9F3E973009.title: "Ether Gas"
	quest.7E3B19796870C2B1.quest_desc: ["&#9955EDChemical Reactor&r akan menjadi salah satu mesin paling berguna bagimu ke depannya. Alat ini digunakan untuk menciptakan berbagai bahan kimia."]
	quest.7E3C84D7FCEC9D52.quest_desc: [
		"&2&lFission Reactor&r paling kecil (yang berfungsi) yang bisa kita bikin adalah 3x4x3. \\n\\nBase sama frame harus dibuat dari &2Fission Reactor Casing&r sedangkan dalemnya harus Kosong, atau punya &2Fuel Rod Assembly&r atau &2Control Rod Assembly&r! \\n\\nBagian dalam dinding (bukan pinggiran) bisa punya &2Fission Reactor Port&r atau &2FRLA&r dan sisanya bisa diisi dengan &2Reactor Glass&r. \\n\\nBegitu &2&lFission Reactor&r udah dibangun, kita bisa Klik Kanan di mana aja (selain &2FRLA&r) di &2Reactor&r buat buka GUI-nya. "
		"{@pagebreak}"
		"Ini bisa keliatan menyeramkan buat Player baru jadi kita bakal pelan-pelan biar ngerti lebih baik! \\n\\nDi atas, kita bisa liat 4 Bar berbeda. Ini tempat kita liat berapa banyak &2Fissile Fuel&f, &bCoolant&f, &6Heated Coolant&f, sama &8Nuclear Waste&r. \\n\\nDi antara Bar kita bakal nemuin menu utama &2&lReaktor&r. Bakal kasih tau kita nyala atau mati, berapa &2Fissile Fuel&r yang dipake tiap Tick, berapa Temperature naik tiap Tick, dan berapa banyak Damage yang diderita &2&lReaktor&r! \\n\\nDi bawah semua ini kita bakal liat 2 Tombol! Satu buat nyalain &2&lReaktor&r bilang Activate dan yang lain buat matiin bilang SCRAM. Di sebelah Tombol SCRAM ada gambar kecil buat bantu Player tau nyala atau mati. Hijau pas nyala, Merah pas mati. \\n\\nDi bawah Tombol itu kita bakal liat seberapa Panas &2&lReaktor&r dan di bawahnya bakal nunjukin visual perubahan Temperature. "
		"{@pagebreak}"
		"Di luar menu ini, kita bisa Klik Tab Atas buat munculin Statistics. \\n\\nChart atas nunjukin berapa banyak Heat yang bisa ditahan sampe Damage terjadi, berapa banyak ruang &2Fuel&r di dalam &2&lReaktor&r, dan seberapa Efisien pake Heat buat pake &2Fuel&r. \\n\\nSisanya semua berdasar berapa banyak &2Fuel&r yang bisa dipake tiap Tick. Kita bisa set max di Type Box. Juga diset di mB per Tick! \\n\\nTab lain yang bisa kita temuin di samping menu utama buat Temperature! \\n\\nBakal nunjukin Dissipation rate sama Temperature Unit yang ditampilin. Kita bisa ganti Temperature Unit dengan Klik Tab. Lo kemungkinan bakal pake F (Fahrenheit) atau C (Celsius) tapi kita juga bisa pake K (Kelvin), R (Rankine), atau STP (Standard Temperature and Pressure)!"
		"{@pagebreak}"
		"MELTDOWN! \\n\\n&2&lFission Reactor&r bakal meledak kalo mencapai 250% Damage. Pas meledak bakal hancurin Blok, mulai Api, dan paling buruk... sebarin &aRadiasi&r! \\n\\nMari hindari itu! \\n\\nDamage bakal naik pas Temperature lewat 1,200K. Kita butuh pake &bCoolant&r buat jaga Temperature tetep rendah. \\n\\nPastikan punya supply &bCoolant&r konstan dan pastikan &bCoolant Output&r gak bottleneck. Kalo ini terjadi, lebih banyak &bCoolant&r gak bisa dipake dan Temperature bakal naik. \\n\\nLEAK! \\n\\n&aRadiasi&r leak juga bisa terjadi kalo Bar &8Nuclear Waste&r penuh. Ini bakal sebarin &aRadiasi&r sekitar &2&lReaktor&r. Hindari dengan terus keluarin &8Nuclear Waste&r dan bahkan pake &2FRLA&r buat tau kapan &8Waste&r penuh!"
		"{@pagebreak}"
		"Multiblock ini bisa dibuat dengan ukuran apapun yang tersedia, gak cuma yang ditampilin di Gambar. Gambar cuma nunjukin ukuran paling kecil yang bisa dibuat."
		"{image:atm:textures/questpics/mek/mek_fission1.png width:100 height:75 align:center}"
		"{image:atm:textures/questpics/mek/mek_fission2.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fission3.png width:100 height:100 align:center}"
		"{image:atm:textures/questpics/mek/mek_fission4.png width:100 height:110 align:center}"
	]
	quest.7E3C84D7FCEC9D52.quest_subtitle: "Membelah 1 Elemen jadi 2"
	quest.7E3C84D7FCEC9D52.title: "&2&lFission Reactor"
	quest.7E3DA4168D352B42.quest_desc: [
		"Aku janji ini rawa jamur terakhir! \\nJamur-jamur ini terlihat normal, tapi keunikannya adalah apa yang dihasilkan oleh mereka! \\n\\nMushroom Veil! Pastinya blok dekorasi yang berguna."
		"{image:atm:textures/questpics/undergarden/undergarden_veil.png width:200 height:100 align:center}"
	]
	quest.7E3DA4168D352B42.title: "Veil Mushroom Bog"
	quest.7E4367252A39BE6C.quest_desc: ["&c&lPowah&r itu tentang power! Generate Power kayak FE buat pake Mesin dari Mod lain kayak &5&lMekanism&r atau &lIndustrial Foregoing&r! \\n\\nAda Tier berbeda yang harus kamu craft sampe dan tentu aja kita butuh yang terakhir buat &6&lStar&r!"]
	quest.7E4367252A39BE6C.title: "&c&lPowah"
	quest.7E49C985A0433B20.quest_desc: ["&d&lArs Nouveau&r adalah mod sihir yang sangat seru dan ia membawakan set kayunya sendiri! \\n\\nArchwood hadir dalam 5 warna pohon berbeda yang muncul di sebagian besar biome, tapi paling sering di biome Archwood mereka sendiri!"]
	quest.7E49C985A0433B20.title: "Batang Kayu &d&lArs Nouveau&r"
	quest.7E57964F6AD5B060.quest_subtitle: "Leafcutter Bee mungkin sedang haus"
	quest.7E57964F6AD5B060.title: "Tea Bee"
	quest.7E7637DAD2C242CB.quest_subtitle: "European Larch + Spruce"
	quest.7E79F52147B606F9.quest_desc: ["Buat mulai ngumpulin darah, kita harus craft &cBlood Extractor&r.\\n\\nSelama kamu punya ini di inventory, bunuh mob bakal kumpulin darah ke extractor. &cBlood&r adalah resource penting di EvilCraft.\\n\\nButuh nambah storage Extractor? Tinggal bikin lagi, terus gabungin di crafting grid!\\n\\nIni juga bisa dipake buat extract darah dari &cBlood Stain&r yang kamu temuin (atau bikin) di tanah.\\n\\nTerakhir, dengan cukup darah tersimpan, kamu bisa sneak-klik kanan di tanah buat taro bucket darah."]
	quest.7E79F52147B606F9.title: "&aMengumpulkan&r &cDarah"
	quest.7E90138B0A2C3210.quest_desc: ["Northland Tree adalah Pohon besar kokoh di Permafrost Forest. \\n\\nMereka keliatan kayak Spruce tapi lebih terang! Mungkin mereka Spruce albino. \\n\\nSapling mereka harus ditaro di Dirt, bukan Grass, dan dalam formasi 2x2."]
	quest.7E92ED270C67FDE5.quest_desc: ["Hampir setiap mesin yang bisa kamu buat di mod ini membutuhkan &9Dielectric Casing&r.\\n\\nKamu perlu membuat &bPaste&r-nya terlebih dahulu, serta beberapa &aRod&r untuk bisa lanjut!"]
	quest.7E92ED270C67FDE5.title: "Memulai dengan Material Dielektrik"
	quest.7E9E03274A88347D.quest_desc: ["Meningkatkan ukuran stack di dalam Tas sebanyak 2 kali lipat."]
	quest.7E9E03274A88347D.title: "&fStack Upgrade Tingkat 1"
	quest.7EAFF64FFE8B5378.quest_subtitle: "Iron + Sweat"
	quest.7EAFF64FFE8B5378.title: "Zinc Bee"
	quest.7EB1C1AE52A0027F.title: "Chaotic Projectile Gravity Compensation Module"
	quest.7EB97C0DDE60DED4.quest_desc: ["Bow terbaik dari Draconic Evolution, juga dengan lebih banyak slot Module!"]
	quest.7EB97C0DDE60DED4.title: "Chaotic Bow"
	quest.7EC01E7DB045DB05.quest_desc: ["&aAugment&r adalah upgrade Furnace yang bisa mengubah atau meningkatkan fungsi Furnace.\\n\\n - Blasting: Mengubah Furnace untuk hanya memungkinkan resep Blasting.\\n\\n - Smoking: Mengubah Furnace untuk hanya memungkinkan resep Smoking.\\n\\n - Factory: Mengubah Furnace untuk menggunakan power daripada fuel, dan meng-upgrade-nya ke factory, memungkinkan smelt beberapa item sekaligus. Ini meningkat tergantung tier Furnace.\\n\\n - Speed: Menggandakan kecepatan furnace dengan cost fuel ganda.\\n\\n - Fuel Efficiency: Menggandakan jumlah item yang di-smelt per fuel, tapi mengurangi kecepatan 25%"]
	quest.7EC01E7DB045DB05.title: "&aAugment&r Furnace"
	quest.7EC7E12C0880F8F5.quest_subtitle: "Tingkat: &e5"
	quest.7EC8814940C4C3D7.quest_desc: ["Gunakan item ini untuk mengecilkan ukuran tubuhmu. Sangat membantu saat mengerjakan sistem otomatisasi dan juga seru untuk dimainkan."]
	quest.7EC8814940C4C3D7.quest_subtitle: "Sayang, Aku Mengecilkan Diriku Sendiri"
	quest.7EC8814940C4C3D7.title: "Personal Shrinking Device"
	quest.7EC89242980768B3.quest_subtitle: "Pecan + Wild Cherry"
	quest.7ECA0633AF1AEC19.quest_desc: ["&e&lPrecision Sawmill&r bakal kerja buat \"daur ulang\" &6Item Kayu&r. \\n\\nTinggal kasih &aEnergi&r terus masukin &6Item Kayu&r ke dalamnya dan tunggu! \\n\\nDia bakal ngerubah Bed jadi 3 &6Wood Plank&r dan 3 Wool. &6Pintu&r jadi &6Wood Plank&r. Dan &2Log&f jadi 6 &6Plank&r bukannya 4! \\n\\nDia juga bakal ngerubah &7Stick&r jadi &6Sawdust&r yang dibutuhin buat bikin &6Cardboard Box&r!"]
	quest.7ECA0633AF1AEC19.title: "&e&lPrecision Sawmill"
	quest.7ECE00D12CFC50A4.quest_desc: ["&bSilk Touch &7Unit&r bakal kerja kayak Enchantment Silk Touch buat &dMeka-Tool&r. \\n\\nTapi gak cuma bagian Pickaxe, juga Shovel dan Tool lain di dalam &dMeka-Tool&r! \\n\\nJadi lo bisa ambil Stone sama Ore plus Grass sama Mycelium. \\n\\nKita gak bisa pake &7Unit&r ini sama &dOre Refinement &7Unit&r di &dMeka-Tool&r."]
	quest.7ECE00D12CFC50A4.quest_subtitle: "Meka-Tool"
	quest.7ECE00D12CFC50A4.title: "&bSilk Touch &7Unit"
	quest.7EDBE88A2CFAB353.quest_desc: [
		"&#562FD6Assembler&r digunakan untuk membuat banyak komponen dan mesin. Alat ini mampu melakukan pekerjaan crafting secara otomatis."
		"Alat ini juga menawarkan varian resep yang &ajauh lebih murah&r untuk beberapa barang yang sudah pernah kamu buat sebelumnya."
	]
	quest.7EDBE88A2CFAB353.quest_subtitle: "Kamu bakal butuh banyak"
	quest.7EDF2CC08FC774F9.quest_subtitle: "&f10 &cAttack Damage"
	quest.7EE27C3908008E20.quest_desc: ["Jika kamu perlu merentangkan &cLaser Node&r dalam jarak jauh, cobalah gunakan Connector! Gunakan saja Wrench seperti biasa."]
	quest.7EE27C3908008E20.title: "Laser Connector"
	quest.7EEEEDD5FF31ACD3.quest_desc: ["&eSelokan Cerdas&r adalah &eSelokan&r dengan opsi Filter."]
	quest.7EEEEDD5FF31ACD3.title: "&eSelokan Cerdas"
	quest.7EF57BBEAA4B6B08.quest_desc: ["Ingin membuat penyimpanan virtual menggunakan mod seperti &9Applied Energistics 2&r?\\n\\nItu cara yang bagus, tapi penting untuk membahas soal &eItem NBT&r dan cara terbaik menyimpannya.\\n\\nItem NBT adalah item dengan data tambahan, seperti item yang memiliki mantra (enchant), durabilitas, atau data kustom lainnya. Karena data ini, biasanya mereka tidak bisa ditumpuk (stack).\\n\\nJika kamu menyimpan terlalu banyak item NBT ke dalam sistem penyimpanan digital seperti AE2, ada risiko membuat save file atau server menjadi bermasalah.\\n\\nKarena itu, cara terbaik adalah menyimpan item-item tersebut di dalam Peti atau Tas!"]
	quest.7EF873DCEB3B9D48.quest_desc: ["&lWorld Tier&r terakhir, &lWorld Tier: &4Pinnacle&r. Untuk membukanya, kamu harus membunuh &d&lEnder Dragon&r setidaknya sekali, dan memakai set lengkap &5Epic&r atau &6Mythic&r &eArmor &fserta &ePeralatan/Senjata&r. \\n\\nSekarang &5Epic&r dan &6Mythic&r adalah tingkatan yang paling umum untuk &aGem &fdan &ePeralatan&r, plus kita lebih berpeluang mendapatkan gem tingkat &zPerfect&r! Sebagai gantinya kita kehilangan tingkat &8Common&r dan &aUncommon&r, tapi hei, siapa yang bakal kangen sama mereka! \\n\\nSesuai pola peningkatannya, kita akan mendapat bonus 125% Experience dan 100% Luck. \\n\\n&4Monster&r akan menerima upgrade terakhir mereka: 16 Armor Point, 20 Armor Toughness, 25 Armor Pierce, dan 20 Protection Pierce."]
	quest.7EF873DCEB3B9D48.title: "&lWorld Tier: &4Pinnacle"
	quest.7EFBAF3E281D2EBE.quest_desc: [
		"&bME Storage Bus&f memungkinkan peti atau penyimpanan eksternal dianggap sebagai bagian dari jaringan ME. Kamu bisa mengambil atau memasukkan item ke sana murni melalui antarmuka ME. "
		""
		"Storage bus bisa difilter dan diberikan prioritas agar item tertentu selalu masuk ke sana terlebih dahulu."
	]
	quest.7EFBAF3E281D2EBE.quest_subtitle: "Peti Cadangan Jaringan"
	quest.7EFBAF3E281D2EBE.title: "Storage Bus"
	quest.7EFBFF5D0DA018E7.quest_desc: ["Menambahkan filter untuk item yang ingin kamu hapus otomatis di dalam Tas."]
	quest.7EFBFF5D0DA018E7.quest_subtitle: "Menambahkan filter hapus otomatis."
	quest.7EFEE009212A4FD4.quest_subtitle: "Tingkat: &63"
	quest.7F076FC4F2187692.quest_subtitle: "&f8 &cAttack Damage"
	quest.7F09F8F98C13F11B.quest_desc: [
		"Apalah arti Ritual Setan tanpa sebuah &cTumbal (Sacrifice)&r! :D\\n\\nSebagian besar waktu, para Setan hanya menyukai item jadi jangan terlalu takut dulu. Namun, jika kamu punya Sapi kesayangan, mungkin kamu harus khawatir. Maaf ya Moo.\\n\\n&aSacrifical Bowl&r digunakan untuk menaruh item yang dibutuhkan untuk Ritual. Ini bisa diletakkan di mana saja di dalam area Ritual, selama tidak menutupi Kapur yang dibutuhkan. "
		""
		"Untuk sekarang kamu hanya butuh empat, tapi nanti kamu akan butuh lebih dari sepuluh bowl untuk setiap ritual!\\n\\n&6Golden Ritual Bowl&r diletakkan di tengah-tengah Ritual untuk mengaktifkannya, dan biasanya juga membutuhkan Book of Binding di dalamnya."
	]
	quest.7F09F8F98C13F11B.title: "Persiapan Ritual: &6Wadah (Bowls)"
	quest.7F0B2D58361FB00E.quest_desc: ["Just Dire Things adalah mod serba guna. Just Dire Things menambahkan mekanik kerajinan baru bernama Penyebaran Lendir, bersama mesin yang membantu otomasi Penyebaran Lendir dan utilitas lainnya."]
	quest.7F0B2D58361FB00E.title: "Just Dire Things"
	quest.7F0F7111552F95A9.quest_desc: ["Oke, &5Kereta&r kita sudah sepenuhnya dirakit, sekarang bagaimana cara menggunakannya? \\n\\nKalau kamu yang mengemudikan, kamu perlu Klik Kanan &5Kontrol Kereta&r. \\n\\nKemudian, tahan W untuk bergerak Maju atau tahan S untuk Mundur. Tidak, &5Kereta&r tidak berbelok seperti mobil — mereka hanya mengikuti &7Rel&r. \\n\\nMaju akan menambah banyak Kecepatan, bisa dilihat di Bilah yang menggantikan &aXP Bar&r. Mundur tidak memberikan Kecepatan sebanyak itu. \\n\\nKalau kamu mendekati &5Stasiun Kereta&r dan tidak sedang melaju kencang, tahan Spasi untuk menghentikan &5Kereta&f di &5Stasiun&r. Berguna untuk membongkar atau bahkan menghubungkan &5Bogie&r tambahan."]
	quest.7F0F7111552F95A9.title: "Mengemudikan &5Kereta&r"
	quest.7F11ABFB2E21B7E4.quest_desc: ["Armor adalah bagian yang sangat penting di &l&2Minecraft&r, dialah yang melindungimu dari bahaya. \\n\\nBagian armor yang berbeda memberikan Poin Armor yang berbeda pula. Poin inilah yang menentukan efektivitas perlindunganmu, semakin besar semakin bagus!\\n\\nKebanyakan armor bisa dihias dengan Armor Trim. Gunakan bagian armor bersama dengan Armor Trim dan item pewarna untuk mengubah tampilannya!"]
	quest.7F11ABFB2E21B7E4.title: "&l&bArmor Dasar&r"
	quest.7F187E291C3D5BA7.quest_desc: ["Fluid Unloader adalah kebalikan dari Fluid Loader. Jika Loader ada di atas &6Rel&r, alat ini ada di bawah. Jika Loader mengisi air ke &3Steam Locomotive&r, alat ini justru mengosongkannya. Entah kenapa kamu mau melakukan itu, tapi ya bisa saja!"]
	quest.7F187E291C3D5BA7.title: "Fluid Unloader"
	quest.7F2D696AC9F4C4E4.quest_desc: ["'Cermin Ajaib di dinding, bagaimana caranya aku kembali ke titik Respawn dari perjalananku?' \\n \\n'Setelah menyetel &bMagic Mirror&r ke Tempat Tidur dengan Klik Kanan, kamu bisa menahan Klik Rikan agar &bMagic Mirror&r menteleportasimu kembali ke tempat tidurmu!' \\n \\n'Terima kasih, &bCermin&r!'"]
	quest.7F2D696AC9F4C4E4.quest_subtitle: "Ditemukan di Mineshaft atau Stronghold"
	quest.7F2D696AC9F4C4E4.title: "&bMagic Mirror"
	quest.7F4963FCAE5337EC.quest_desc: ["Karena melawan &b&lIgnis&r saja tidak cukup sulit, kamu harus melawan &bIgnited Revenant&r dulu untuk mendapatkan &bBurning Ashes&r. \\n\\nSetelah memilikinya, gunakan pada Altar of Fire untuk memanggil &b&lIgnis&r."]
	quest.7F4963FCAE5337EC.quest_subtitle: "Menyalakan Kembali Sang Ignis"
	quest.7F4963FCAE5337EC.title: "&bBurning Ashes"
	quest.7F4B734CFB0F0306.quest_desc: ["&7Cart&r baru ini mirip dengan &7Cart&r khusus &2Vanilla&r. &7Minecart with a Tank&r akan menyimpan dan membawa cairan apa pun. Sedangkan &7Minecart with an Energy cell&r akan menyimpan dan membawa Energi!"]
	quest.7F4B734CFB0F0306.title: "Minecart Baru"
	quest.7F59941D62E672B0.quest_desc: [
		"Occultism menyediakan lebih dari sekadar Setan untuk menghancurkan bijihmu!"
		""
		"Ada Setan yang bisa memindahkan barang untukmu, menebang kayu, dan banyak lagi!!"
		""
		"Ada juga cara untuk memanggil teman-teman keren yang dikenal sebagai &dFamiliar&r yang memberikan buff spesial dan bahkan ikut bertarung untukmu! Pastikan cek &dFamiliar Rituals&r di buku panduanmu!"
	]
	quest.7F59941D62E672B0.title: "&dFamiliar"
	quest.7F67849DE9F700D8.quest_desc: ["&2Augment&r: Speed bikin Furnace-mu lebih cepat! &bDiamond Furnace&r bakal smelt tiap 40 Tick daripada 80 Tick. Dengan cost pakai Fuel dua kali lipat."]
	quest.7F67849DE9F700D8.title: "&2Augment&r: Speed"
	quest.7F6B66566C211735.quest_desc: ["Dripstone yang digunakan pada spawner akan mengurangi darah maksimal (max health) dari mob yang muncul. Ini bisa menurunkan darah mereka hingga serendah 20%."]
	quest.7F6B66566C211735.title: "Kesehatan"
	quest.7F757CD6F8C57733.quest_desc: ["Energy Core adalah salah satu, kalau bukan, bank Energy terbaik di semua Minecraft. Dan semua dimulai dengan Core. Ini tengah dan jantung Energy Core Multiblock (pastikan sedikit di atas tanah). Saat kamu letakkan bisa lihat GUI-nya dengan: Build Guide, Tier Down, Tier Up, dan Assemble Core. Tier menentukan seberapa besar dan kuat Core. Build Guide menunjukkan cara merakit Tier Core ini. Kalau kamu punya semua block yang diperlukan kamu bisa tekan Assemble Core dan akan otomatis membuatnya!"]
	quest.7F757CD6F8C57733.quest_subtitle: "Penyimpanan Power Draconic"
	quest.7F757CD6F8C57733.title: "Energy Core Multiblock"
	quest.7F7ED94590B5B857.quest_desc: ["Beberapa &eSpell&r bisa dimasukkan ke &7Scroll&r untuk digunakan di mana saja. \\n\\nPertama, butuh &7Spell Cloth&r dan letakkan. Lalu, lakukan ritual yang sama tapi di atas &7Spell Cloth&r. \\n\\nSetelah semua &4Blood&r dan &bPowder&r selesai Right Click &7Spell Cloth&r dan BOOM &7Scroll&r! \\n\\nBeberapa &eSpell&r tidak bisa diubah jadi &7Scroll&r, jadi tidak bertanggung jawab atas material yang terbuang."]
	quest.7F7ED94590B5B857.title: "&eSpell&r yang bisa dibawa!"
	quest.7F85669FEA41CD97.quest_desc: [
		"Pelindung Netral &6Village&r. Dia akan menyerang semua Mob Hostile di dekat. Seperti Iron Golem tapi dia terlihat familiar karena alasan tertentu? Mungkinkah ini seseorang yang kita kenal berkostum? \\n\\nKamu bisa berdagang Healing Potion dengannya dan Emerald untuk Furled Map yang akan segera dibuat untuk membantu melawan &aEvoker Fort&r! \\n\\nJika kamu ingin membunuhnya dia akan berulang kali menyerangmu dengan &6Holy Spell&r. Dia juga akan Menyembuhkan dirinya sendiri saat hampir habis. \\n\\nSetelah dibunuh dia akan menjatuhkan Arcane Essence, Ink, &6Holy Rune&r, dan &6Holy Scroll&r."
		"{image:atm:textures/questpics/iron_spells/spells_priest.png width:100 height:200 align:center}"
	]
	quest.7F85669FEA41CD97.title: "&6&lPriest"
	quest.7F8B6D5F360D985A.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_fiery.png width:100 height:150 align:center}"]
	quest.7F8B6D5F360D985A.title: "&eFiery"
	quest.7F8DEDD0A54D1E11.quest_desc: ["Kira-kira apa ya fungsi Dropper? \\nKurasa menjatuhkan sesuatu... \\n\\nItem apa pun di Buffer akan dijatuhkan ke tanah. \\n\\nBisa sangat membantu untuk mod seperti Botania!"]
	quest.7F8E50FA436DB4E6.quest_desc: ["&dChain Drive Berselubung&r bekerja mirip &eSabuk&r dengan menghubungkan &8Poros&r satu sama lain dalam satu baris. \\n\\nAda beberapa perbedaan, seperti &dChain Drive Berselubung&r bisa diputar dengan &6Kunci Inggris&r. Mereka juga harus diletakkan langsung bersebelahan dengan &dChain Drive&r lain agar terus &dBerputar&r. \\n\\nSeperti &eSabuk&r, mereka mempertahankan Kecepatan dan Satuan Stres yang sama dari &8Poros&r aslinya. Ditambah arah yang sama pula!"]
	quest.7F8E50FA436DB4E6.title: "&dChain Drive Berselubung"
	quest.7F990FBC1A691020.quest_desc: ["Trapped Chest sama seperti peti biasa, hanya saja ia memancarkan sinyal Redstone saat dibuka dan tidak bisa digabung menjadi satu."]
	quest.7F990FBC1A691020.quest_subtitle: "\"Kira-kira apa isinya?\""
	quest.7FA85713C86166DA.quest_desc: ["Memungkinkanmu mengakses antrean crafting jaringan secara nirkabel."]
	quest.7FA85713C86166DA.title: "Wireless Crafting Monitor"
	quest.7FA9EA93602A98EC.quest_desc: [
		"&cSarang Naga Api&r adalah Sarang yang ditemuin di atas tanah terbuat dari &cBlok Hangus&r dan Abu. \\n\\nMereka bakal spawn dengan &lStage 1&r sampe &lStage 3 &cNaga Api&r. Dan makin gede &c&lNaga&r-nya, makin gede &cSarang&r-nya! \\n\\n&cSarang&r ini bakal punya Tumpukan &eEmas&r sama Chest. Chest cuma bakal isi sampe &bDiamond&r, tapi tetep sangat membantu!"
		"{image:atm:textures/questpics/iceandfire/iaf_struct_fireroost.png width:200 height:100 align:center}"
	]
	quest.7FA9EA93602A98EC.title: "&cSarang Naga Api"
	quest.7FABB77A60E7962C.quest_desc: ["Dengan mencampurkan Obsidian dengan &bDiamond&r, kita bisa mendapatkan Refined Obsidian Dust! \\n\\nLalu, kita bisa memadatkan &7Osmium&r ke dalamnya untuk menjadikannya bentuk Ingot. \\n\\nSetelah itu, kita bisa mengubah Ingot tersebut menjadi Armor dengan statistik yang bahkan lebih baik daripada &6Allthemodium Armor&r!"]
	quest.7FABB77A60E7962C.quest_subtitle: "31"
	quest.7FABB77A60E7962C.title: "&5Refined Obsidian Armor"
	quest.7FB12EC3A5888123.quest_desc: ["&3Tube Junction&r memberimu kendali lebih atas distribusi tekanan udara dengan memungkinkanmu mengarahkan Pipa Tekanan ke lebih banyak arah."]
	quest.7FB12EC3A5888123.quest_subtitle: "Nggak, lewat sini aja!"
	quest.7FBB431AC055FE93.quest_desc: ["Soulit Spectator di-craft dengan Trapped Soul dan Nightfal Spider Eye. \\n\\nKerjanya mirip kayak Sticky Camera dari Tom Clancy's Splinter Cell. Kamu bisa Right Click buat kirim Spectator dan setelah beberapa saat kamu bakal bisa lihat dari dia. Kamu bahkan bisa lihat diri kamu sendiri! \\n\\nGak bisa dihentiin lebih awal jadi hati-hati kalau pake. Dia juga punya durability dan cooldown."]
	quest.7FBC64E6408D8D7F.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_knightmetal.png width:100 height:150 align:center}"]
	quest.7FBC64E6408D8D7F.title: "&7Knightmetal"
	quest.7FC54AF87CBDD222.quest_desc: [
		"&5Ancient Battleground&r hanya fragmen dari masa lalu. \\n\\nSiapa tahu apa yang terjadi. \\n\\nSiapa tahu siapa melawan siapa. Yang kita punya sekarang hanya bagian dari tembok dan &5Tumpukan Armor&r ini. Lebih baik ambil saja dengan Menambangnya dengan Pickaxe-mu."
		"{image:atm:textures/questpics/iron_spells/spells_battleground.png width:200 height:100 align:center}"
	]
	quest.7FC54AF87CBDD222.title: "&5Ancient Battleground"
	quest.7FD3C1784F32F2AF.quest_subtitle: "Chaotic Fusion Crafting"
	quest.7FD3C1784F32F2AF.title: "Chaos Bee"
	quest.7FE273141D3DFFFD.quest_desc: ["Fusilier adalah unit menengah Pillager baru! \\n\\nMereka memiliki 12 Hati dan tanpa Armor. \\n\\nSenjata pilihan mereka adalah &5&lRailgun&r yang diisi oleh Ransel Akumulator yang mereka kenakan! \\n\\nSaat mati mereka akan menjatuhkan &aEmerald&r dan &7Batang Besi&r."]
	quest.7FE273141D3DFFFD.title: "Fusilier"
	quest.7FE5864E59D7B827.quest_desc: ["&#6784EBHull&r mengontrol jumlah daya yang bisa dimasukkan ke dalam mesin. Seiring kamu memasang upgrade ke dalam mesin, kamu akan membutuhkan tingkat &#6784EBHull&r yang lebih tinggi agar bisa menerima lebih banyak daya. Tingkatan &#6784EBHull&r juga mempengaruhi jenis kabel yang bisa terhubung dengannya."]
	quest.7FE5864E59D7B827.quest_subtitle: "Bahan bangunan dasar"
	quest.7FE969CB4B419FC6.quest_desc: ["Dengan sedikit usaha di mod Mekanism, mesin ini memungkinkanmu mentransfer apa pun secara nirkabel.\\n\\nKamu bisa mengatur channel spesifik untuk mentransfer item, energi, atau bahkan gas dari Mekanism. Sangat keren."]
	quest.7FE969CB4B419FC6.quest_subtitle: "Tidak Hanya Untuk Daya"
	quest.7FE969CB4B419FC6.title: "&9Mekanism: &6Quantum Entangloporter"
	quest.7FF3EA602FE7A546.quest_desc: ["&3Sculk Transmitter&r adalah Item sangat langka yang bisa kita temukan di Chest &6Ancient Temple&r. \\n\\nBegitu kamu menemukannya, ini akan jadi Sahabatmu! \\n\\nUntuk menggunakannya, tinggal Shift Klik Kanan Block yang punya GUI, pikirkan: Chest, Crafting Table, dan Furnace. Lalu, &3Transmitter&r akan terikat pada Item itu. \\n\\nSetelah itu, kita bisa pakai &3Transmitter&r untuk mengakses Block itu dari jarak jauh dari mana saja! \\n\\nUntuk melepas ikatan Block, Shift Klik Kanan Udara dengan &3Transmitter&r."]
	quest.7FF3EA602FE7A546.title: "&3Sculk Transmitter"
	quest.7FF77463F2A0E210.quest_desc: ["Nightfall Mud cuma bisa ditemuin di Dark Swamp. \\n\\nKamu bisa bikin Blok lebih banyak dari dia!"]
